      background: conic-gradient(from 180deg, #1ddcff 0 68%, #f84ca2 68% 100%);
      box-shadow: var(--shadow-light);
      display: grid;
      place-items: center;
      transition: transform var(--transition);
    }

    .score-disc span {
      width: 78px;
      height: 78px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(255,255,255,0.96);
      color: var(--dark-blue);
      font-size: 28px;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .car-card {
      margin-top: 14px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.84);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .car-visual {
      position: relative;
      height: 148px;
      margin-bottom: 14px;
      border-radius: 20px;
      overflow: hidden;
      background:
        radial-gradient(circle at 20% 18%, rgba(255,255,255,0.9), transparent 24%),
        linear-gradient(160deg, #dce8fb 0%, #eef5ff 46%, #ffe6f1 100%);
    }

    .car-glow {
      position: absolute;
      width: 180px;
      height: 180px;
      top: -60px;
      right: -40px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(248,76,162,0.20), transparent 70%);
    }

    .car-road {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 16px;
      height: 12px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(28,38,99,0.24), rgba(28,38,99,0.04));
      opacity: 0.26;
    }

    .car-shape {
      position: absolute;
      left: 22px;
      right: 22px;
      bottom: 28px;
      height: 60px;
      border-radius: 26px 30px 18px 18px;
      background: linear-gradient(135deg, #ffffff 0%, #d8e5ff 56%, #c4d5ff 100%);
      box-shadow: 0 14px 28px rgba(28,38,99,0.14);
    }

    .car-shape::before {
      content: "";
      position: absolute;
      left: 42px;
      right: 52px;
      top: -21px;
      height: 34px;
      border-radius: 18px 24px 6px 6px;
      background: linear-gradient(135deg, #ffffff 0%, #d8ecff 100%);
      transform: skewX(-12deg);
    }

    .wheel {
      position: absolute;
      bottom: -10px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #24306f;
      box-shadow: inset 0 0 0 8px #7c8ecb;
    }

    .wheel.left { left: 46px; }
    .wheel.right { right: 46px; }

    .car-meta {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .car-meta h3 {
      margin: 0 0 4px;
      font-size: 20px;
      line-height: 1.3;
      letter-spacing: -0.03em;
      color: var(--dark-blue);
    }

    .car-meta p {
      margin: 0;
      font-size: 12px;
      line-height: 1.7;
      color: #5d6682;
    }

    .mini-score {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 78px;
      min-height: 42px;
      padding: 0 12px;
      border-radius: 18px;
      background: rgba(29,220,255,0.14);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      text-align: center;
    }

    .spark-card {
      margin-top: 14px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.84);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .spark-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 10px;
    }

    .spark-top strong {
      font-size: 14px;
      color: var(--dark-blue);
    }

    .spark-top span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .spark-svg {
      width: 100%;
      height: 92px;
      display: block;
    }

    .point-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 10px;
    }

    .point-grid div {
      padding: 10px 8px;
      border-radius: 16px;
      background: rgba(28,38,99,0.05);
      text-align: center;
    }

    .point-grid span {
      display: block;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 4px;
    }

    .point-grid strong {
      font-size: 13px;
      color: var(--dark-blue);
    }

    .cta-row {
      display: flex;
      gap: 10px;
      margin-top: 14px;
    }

    .primary-btn,
    .ghost-btn,
    .cta-btn {
      min-height: 43px;
      padding: 0 18px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: -0.02em;
      transition: transform var(--transition), box-shadow var(--transition), opacity var(--transition);
    }

    .primary-btn,
    .cta-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 14px 28px rgba(77,180,255,0.28);
    }

    .ghost-btn {
      background: rgba(255,255,255,0.84);
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .primary-btn:active,
    .ghost-btn:active,
    .cta-btn:active {
      transform: scale(0.97);
    }

    .b-hero {
      padding: 18px;
      border-radius: 26px;
      background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 18px 40px rgba(0,0,0,0.16);
    }

    .b-hero span {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.12);
      color: #d8e8ff;
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.04em;
    }

    .b-hero strong {
      display: block;
      margin-top: 12px;
      font-size: 36px;
      line-height: 1.05;
      letter-spacing: -0.05em;
      color: var(--white);
    }

    .b-hero small {
      display: block;
      margin-top: 10px;
      font-size: 12px;
      line-height: 1.8;
      color: #d5e4ff;
    }

    .period-row {
      display: flex;
      gap: 8px;
      margin-top: 14px;
    }

    .period-btn {
      flex: 1;
      min-height: 40px;
      border-radius: 18px;
      background: rgba(255,255,255,0.10);
      color: #c9daff;
      border: 1px solid rgba(255,255,255,0.08);
      font-size: 12px;
      font-weight: 900;
      transition: transform var(--transition), background var(--transition), color var(--transition);
    }

    .period-btn.active {
      background: var(--white);
      color: var(--dark-blue);
      transform: translateY(-2px);
    }

    .b-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 12px;
      margin-top: 14px;
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .expense-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .expense-item span {
      font-size: 12px;
      color: #d8e8ff;
    }

    .expense-item strong {
      font-size: 15px;
      color: var(--white);
    }

    .tiny-kpi {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 12px;
    }

    .tiny-kpi div {
      padding: 10px 8px;
      border-radius: 16px;
      text-align: center;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .tiny-kpi span {
      display: block;
      font-size: 10px;
      color: #d5e4ff;
      margin-bottom: 4px;
    }

    .tiny-kpi strong {
      font-size: 14px;
      color: var(--white);
    }

    .forecast-card {
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 18px 36px rgba(0,0,0,0.14);
    }

    .forecast-card strong {
      display: block;
      font-size: 14px;
      color: var(--white);
    }

    .bars {
      height: 164px;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      margin-top: 16px;
    }

    .column {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      height: 100%;
    }

    .bar-stack {
      position: relative;
      width: 100%;
      max-width: 54px;
      height: 126px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 6px;
    }

    .value-bar,
    .cost-bar {
      width: 100%;
      border-radius: 18px 18px 12px 12px;
      transition: height var(--transition);
    }

    .value-bar {
      background: linear-gradient(180deg, #3fd8ff 0%, #6fc2ff 100%);
      box-shadow: 0 10px 24px rgba(63,216,255,0.24);
    }

    .cost-bar {
      background: linear-gradient(180deg, rgba(248,76,162,0.92), rgba(248,76,162,0.56));
      box-shadow: 0 10px 24px rgba(248,76,162,0.18);
    }

    .column span {
      font-size: 10px;
      color: #d5e4ff;
      text-align: center;
      line-height: 1.5;
    }

    .column strong {
      font-size: 12px;
      color: var(--white);
      text-align: center;
    }

    .recommend-card {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(29,220,255,0.12);
      border: 1px solid rgba(29,220,255,0.18);
      color: var(--white);
      font-size: 12px;
      line-height: 1.7;
    }

    .compare-hero {
      padding: 18px;
      border-radius: 26px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .compare-head {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 14px;
      align-items: center;
    }

    .compare-orb {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: conic-gradient(from 180deg, #1ddcff 0 32%, #f84ca2 32% 100%);
      box-shadow: var(--shadow-light);
    }

    .compare-orb span {
      width: 76px;
      height: 76px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(255,255,255,0.98);
      color: var(--dark-blue);
      font-size: 30px;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .compare-copy h3 {
      margin: 0;
      font-size: 26px;
      line-height: 1.12;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
    }

    .compare-copy p {
      margin: 8px 0 0;
      font-size: 13px;
      line-height: 1.75;
      color: #5b6480;
    }

    .compare-toggle {
      display: flex;
      gap: 8px;
      margin-top: 16px;
    }

    .compare-btn {
      flex: 1;
      min-height: 40px;
      border-radius: 18px;
      background: rgba(28,38,99,0.06);
      color: #6f7893;
      font-size: 12px;
      font-weight: 900;
      transition: background var(--transition), color var(--transition), transform var(--transition);
    }

    .compare-btn.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .compare-board {
      margin-top: 14px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 78px 1fr 54px;
      gap: 10px;
      align-items: center;
      margin-bottom: 12px;
    }

    .compare-row:last-child {
      margin-bottom: 0;
    }

    .compare-label {
      font-size: 12px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-track {
      position: relative;
      height: 12px;
      border-radius: 999px;
      background: rgba(28,38,99,0.08);
      overflow: hidden;
    }

    .compare-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 360ms cubic-bezier(.2,.85,.2,1);
    }

    .compare-fill.pink {
      background: var(--gradient-pink);
    }

    .compare-value {
      text-align: right;
      font-size: 12px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-note {
      margin: 14px 0 0;
      font-size: 12px;
      line-height: 1.8;
      color: #5e6782;
    }

    .call-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 14px;
    }

    .call-card {
      padding: 14px;
      border-radius: 22px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .call-card span {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .call-card strong {
      display: block;
      margin-top: 6px;
      font-size: 26px;
      line-height: 1;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
    }

    .call-card small {
      display: block;
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.7;
      color: #5d6682;
    }

    .footnote {
      margin-top: 12px;
      font-size: 11px;
      line-height: 1.7;
      color: #717a95;
      text-align: center;
    }

    .insight-panel {
      padding: 18px;
    }

    .panel-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .panel-kicker {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(28,38,99,0.06);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.05em;
    }

    .score-meter {
      width: 112px;
      padding: 10px 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.92);
      box-shadow: var(--shadow-light);
    }

    .score-meter span {
      display: block;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 6px;
    }

    .score-bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: rgba(28,38,99,0.08);
      overflow: hidden;
    }

    .score-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 360ms cubic-bezier(.2,.85,.2,1);
    }

    .score-num {
      display: block;
      margin-top: 8px;
      font-size: 24px;
      font-weight: 900;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
    }

    .panel-title {
      margin: 18px 0 8px;
      font-size: 30px;
      line-height: 1.15;
      letter-spacing: -0.05em;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .panel-lead {
      margin: 0;
      font-size: 14px;
      line-height: 1.9;
      color: #66708c;
    }

    .fact-grid {
      display: grid;
      gap: 10px;
      margin-top: 18px;
    }

    .fact-card {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255,255,255,0.84);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .fact-card span {
      display: block;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-gray);
      letter-spacing: 0.04em;
      margin-bottom: 8px;
    }

    .fact-card strong {
      display: block;
      font-size: 18px;
      line-height: 1.5;
      letter-spacing: -0.03em;
      color: var(--dark-blue);
    }

    .copy-box {
      margin-top: 18px;
      padding: 18px;
      border-radius: 24px;
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: var(--shadow-medium);
    }

    .copy-box span {
      display: block;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.05em;
      color: var(--text-light-blue);
      margin-bottom: 10px;
    }

    .copy-box p {
      margin: 0;
      font-size: 14px;
      line-height: 1.9;
      color: var(--white);
    }

    .panel-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 18px;
    }

    .dots {
      display: inline-flex;
      gap: 8px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(28,38,99,0.12);
      transition: transform var(--transition), background var(--transition);
    }

    .dot.active {
      transform: scale(1.2);
      background: var(--pink);
    }

    .footer-note {
      color: #69738f;
      font-size: 12px;
      font-weight: 700;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.18); opacity: 0.78; }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    @media (max-width: 1120px) {
      .workspace {
        grid-template-columns: 1fr;
      }

      .insight-panel {
        order: -1;
      }
    }

    @media (max-width: 780px) {
      .page {
        width: min(100%, calc(100% - 12px));
      }

      .hero,
      .stage-shell,
      .insight-panel {
        border-radius: 26px;
      }

      .hero-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .compare-head,
      .valuation-shell,
      .b-grid {
        grid-template-columns: 1fr;
      }

      .compare-orb,
      .score-disc {
        margin-inline: 0;
      }

      .cta-row,
      .period-row,
      .compare-toggle {
        flex-wrap: wrap;
      }

      .compare-row {
        grid-template-columns: 68px 1fr 50px;
      }
    }

    @media (max-width: 480px) {
      .hero-stats {
        grid-template-columns: 1fr;
      }

      .tabs {
        display: grid;
        grid-template-columns: 1fr;
      }

      .nav-chip {
        width: 100%;
      }

      .swipe-caption {
        flex-direction: column;
        align-items: flex-start;
      }

      .panel-title {
        font-size: 26px;
      }

      .headline {
        font-size: 28px;
      }

      .phone-inner {
        padding: 18px 16px 16px;
      }

      .call-cards {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <span class="eyebrow">ASO / ストアPV→DL率 改善検証 2026-04-15</span>
      <h1>AI査定で興味を作り、出費管理で残す理由を作り、電話不安を0本で切る。</h1>
      <p class="lead">
        1枚目で<strong>「何のアプリか」</strong>、2枚目で<strong>「消さない理由」</strong>、3枚目で<strong>「他より安心な理由」</strong>を順番に解消する、C案の体験型ストアスクショです。スワイプ、診断進行、状態切替で、静止画に載せるべき情報の優先順位を検証できます。
      </p>

      <div class="hero-stats">
        <div class="hero-stat">
          <span>現状CVR</span>
          <strong>17.3%</strong>
          <small>ストア詳細ページの閲覧からDLへの転換率</small>
        </div>
        <div class="hero-stat">
          <span>目標CVR</span>
          <strong>25%</strong>
          <small>ファーストスクショで理解速度を上げて改善</small>
        </div>
        <div class="hero-stat">
          <span>主役メッセージ</span>
          <strong>AI査定</strong>
          <small>個人情報なし、45秒、将来予測つきで差別化</small>
        </div>
        <div class="hero-stat">
          <span>不安解除</span>
          <strong>0本</strong>
          <small>相場チェック時は電話0本、売却相談でも1社だけ</small>
        </div>
      </div>

      <div class="tabs">
        <button class="nav-chip active" data-go="0" type="button">A | iOS向け AI査定</button>
        <button class="nav-chip" data-go="1" type="button">B | Android向け 出費管理</button>
        <button class="nav-chip" data-go="2" type="button">C | 比較訴求 電話0本</button>
      </div>

