                <p class="card-note">ホンダ フリード G 2020年式 / 月ごとの負担もアプリで一元管理</p>

                <div class="dash-grid">
                  <div class="ring-card">
                    <div class="ring">
                      <div class="ring-label">
                        月合計<br />
                        <span id="expenseTotal" style="font-size:16px;">32,800円</span>
                      </div>
                    </div>
                  </div>

                  <div class="expense-list">
                    <div class="expense-row"><span>ガソリン</span><span>14,200円</span></div>
                    <div class="expense-row"><span>保険</span><span>8,600円</span></div>
                    <div class="expense-row"><span>駐車場</span><span>7,000円</span></div>
                    <div class="expense-row"><span>洗車・整備</span><span>3,000円</span></div>
                  </div>
                </div>
              </section>

              <section class="forecast-card">
                <div class="forecast-top">
