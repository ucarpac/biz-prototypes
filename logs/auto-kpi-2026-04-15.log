    (function () {
      const body = document.body;
      const focusButtons = document.querySelectorAll("[data-focus]");
      const phones = document.querySelectorAll(".phone");
      const modeButtons = document.querySelectorAll("[data-mode-switch]");
      const priceTabs = document.querySelectorAll('[data-tabs="price"] .mini-tab');
      const compareTabs = document.querySelectorAll('[data-tabs="compare"] .mini-tab');

      const priceLabelA = document.getElementById("priceLabelA");
      const priceValueA = document.getElementById("priceValueA");
      const forecastValue = document.getElementById("forecastValue");
      const forecastTag = document.getElementById("forecastTag");
      const expenseTotal = document.getElementById("expenseTotal");
      const compareLabelCall = document.getElementById("compareLabelCall");
      const ucpCall = document.getElementById("ucpCall");
      const ikkatsuCall = document.getElementById("ikkatsuCall");
      const auctionCall = document.getElementById("auctionCall");

      const priceMap = {
        now: {
          label: "現在のAI査定",
          value: "218.4万円"
        },
        "3m": {
          label: "3か月後予測",
          value: "221.1万円"
        },
        "6m": {
          label: "6か月後予測",
          value: "224.6万円"
        }
      };

      const compareMap = {
        check: {
          label: "電話本数",
          ucp: "0本",
          ikkatsu: "複数社",
          auction: "1〜3社"
        },
        sell: {
          label: "売却時のやりとり",
          ucp: "1社",
          ikkatsu: "複数社",
          auction: "1社"
        }
      };

      const modeMap = {
        later: {
          forecast: "176.8万円",
          tag: "6か月後 +7.4万円予測",
          expense: "32,800円"
        },
        now: {
          forecast: "174.2万円",
          tag: "今売却で高値帯を維持",
          expense: "35,100円"
        }
      };

      function setFocus(targetId) {
        focusButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.focus === targetId);
        });

        phones.forEach((phone) => {
          phone.classList.toggle("is-selected", phone.id === targetId);
        });
      }

      function setMode(mode) {
        body.setAttribute("data-mode", mode);
        modeButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.modeSwitch === mode);
        });

        document.querySelectorAll(".mode-copy").forEach((node) => {
          node.classList.add("updating");
        });

        window.setTimeout(() => {
          forecastValue.textContent = modeMap[mode].forecast;
          forecastTag.textContent = modeMap[mode].tag;
          expenseTotal.textContent = modeMap[mode].expense;
          document.querySelectorAll(".mode-copy").forEach((node) => {
            node.classList.remove("updating");
          });
        }, 160);
      }

      function setPrice(type) {
        priceTabs.forEach((tab) => {
          tab.classList.toggle("is-active", tab.dataset.price === type);
        });
        priceLabelA.textContent = priceMap[type].label;
        priceValueA.textContent = priceMap[type].value;
      }

      function setCompare(type) {
        compareTabs.forEach((tab) => {
          tab.classList.toggle("is-active", tab.dataset.compare === type);
        });
        compareLabelCall.textContent = compareMap[type].label;
        ucpCall.textContent = compareMap[type].ucp;
        ikkatsuCall.textContent = compareMap[type].ikkatsu;
        auctionCall.textContent = compareMap[type].auction;
      }

      focusButtons.forEach((button) => {
        button.addEventListener("click", function () {
          setFocus(this.dataset.focus);
        });
      });

      modeButtons.forEach((button) => {
        button.addEventListener("click", function () {
          setMode(this.dataset.modeSwitch);
        });
      });

      priceTabs.forEach((tab) => {
        tab.addEventListener("click", function () {
          setPrice(this.dataset.price);
        });
      });

      compareTabs.forEach((tab) => {
        tab.addEventListener("click", function () {
          setCompare(this.dataset.compare);
        });
      });

      setFocus("screen-a");
      setMode("later");
      setPrice("now");
      setCompare("check");
    })();
  </script>
</body>
