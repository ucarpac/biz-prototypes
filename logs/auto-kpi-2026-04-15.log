      font-size: 10px;
      line-height: 1.5;
      font-weight: 800;
      transform: rotate(calc(var(--tilt, 0) * 1deg));
    }

    .trust-bubble:nth-child(1) { --tilt: -2; }
    .trust-bubble:nth-child(2) { --tilt: 1; }
    .trust-bubble:nth-child(3) { --tilt: -1; }

    .cta {
      margin-top: auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 16px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(248,76,162,0.12), rgba(255,255,255,0.85));
      border: 1px solid rgba(248, 76, 162, 0.12);
    }

    .cta-copy {
      flex: 1;
      min-width: 0;
    }

    .cta-copy strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.55;
    }

    .cta-copy span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
    }

    .inline-chip {
      min-height: 42px;
      padding: 10px 16px;
      border-radius: 999px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 12px;
      font-weight: 800;
      box-shadow: 0 14px 22px rgba(248, 76, 162, 0.23);
      animation: pulseGlow 2.2s ease-in-out infinite;
    }

    .dash-grid {
      display: grid;
      grid-template-columns: 118px 1fr;
      gap: 12px;
      align-items: stretch;
    }

    .ring-card {
      display: grid;
      place-items: center;
      padding: 12px;
      border-radius: 20px;
      background: linear-gradient(180deg, #ffffff 0%, #fff7f0 100%);
      border: 1px solid rgba(255,255,255,0.9);
    }

    .ring {
      position: relative;
      width: 94px;
      height: 94px;
      border-radius: 50%;
      background: conic-gradient(var(--pink) 0 34%, #ffbf78 34% 56%, #65d6ff 56% 82%, #e7edf3 82% 100%);
    }

    .ring::before {
      content: "";
      position: absolute;
      inset: 12px;
      border-radius: 50%;
      background: #fffdf9;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.04);
    }

    .ring-label {
      position: absolute;
      display: grid;
      place-items: center;
      inset: 0;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      line-height: 1.4;
      text-align: center;
    }

    .expense-list {
      display: grid;
      gap: 8px;
    }

    .expense-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.65);
      font-size: 11px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .expense-row span:last-child {
      color: var(--text-black);
      font-weight: 900;
    }

    .forecast-card {
      padding: 14px 14px 12px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.9), rgba(246,251,255,0.96));
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.04);
    }

    .forecast-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 10px;
      margin-bottom: 12px;
    }

    .forecast-value {
      color: var(--dark-blue);
      font-size: 24px;
      font-weight: 900;
      line-height: 1.2;
      letter-spacing: -0.03em;
    }

    .forecast-tag {
      padding: 8px 10px;
      border-radius: 14px;
      background: rgba(216, 248, 239, 0.9);
      color: #178e5e;
      font-size: 10px;
      font-weight: 900;
      line-height: 1.4;
    }

    .chart {
      position: relative;
      height: 120px;
      border-radius: 18px;
      background:
        linear-gradient(to top, rgba(28,38,99,0.05) 1px, transparent 1px) 0 0 / 100% 25%,
        linear-gradient(to right, rgba(28,38,99,0.03) 1px, transparent 1px) 0 0 / 25% 100%;
      overflow: hidden;
    }

    .chart-line {
      position: absolute;
      left: 14px;
      right: 14px;
      bottom: 20px;
      height: 70px;
    }

    .point {
      position: absolute;
      width: 12px;
      height: 12px;
      margin-left: -6px;
      margin-top: -6px;
      border-radius: 50%;
      background: var(--white);
      border: 4px solid var(--pink);
      box-shadow: 0 0 0 6px rgba(248, 76, 162, 0.12);
    }

    .path {
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      bottom: 0;
    }

    .path svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .path path {
      fill: none;
      stroke: url(#forecastGradient);
      stroke-width: 5;
      stroke-linecap: round;
      stroke-linejoin: round;
      filter: drop-shadow(0 6px 12px rgba(248, 76, 162, 0.14));
      stroke-dasharray: 260;
      stroke-dashoffset: 260;
      animation: drawPath 1.4s ease-out forwards;
    }

    .axis {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    .care-note {
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 245, 234, 0.85);
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 1.7;
      border: 1px dashed rgba(248, 76, 162, 0.18);
    }

    .compare-head {
      display: grid;
      gap: 8px;
    }

    .compare-table {
      display: grid;
      gap: 8px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr 0.8fr;
      gap: 8px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.84);
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
      box-shadow: 0 10px 18px rgba(28, 38, 99, 0.05);
    }

    .compare-row.header {
      background: rgba(28, 38, 99, 0.05);
      box-shadow: none;
      color: var(--text-gray);
      font-size: 10px;
      text-transform: uppercase;
    }

    .compare-row.highlight {
      background: linear-gradient(90deg, rgba(248,76,162,0.12), rgba(255,255,255,0.9));
      border: 1px solid rgba(248, 76, 162, 0.16);
    }

    .cell-main {
      font-weight: 900;
    }

    .ok,
    .ng,
    .mid {
      display: inline-grid;
      place-items: center;
      min-height: 28px;
      padding: 6px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 900;
      text-align: center;
    }

    .ok {
      background: rgba(216, 248, 239, 0.92);
      color: #178e5e;
    }

    .ng {
      background: rgba(255, 226, 207, 0.92);
      color: #bb5c2e;
    }

    .mid {
      background: rgba(223, 246, 255, 0.95);
      color: #1677b7;
    }

    .small-claim {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.78);
      border: 1px dashed rgba(28, 38, 99, 0.14);
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 1.65;
      font-weight: 700;
    }

    .small-claim::before {
      content: "メモ";
      flex: none;
      padding: 5px 8px;
      border-radius: 999px;
      background: var(--back-yellow);
      color: var(--dark-blue);
      font-size: 10px;
      font-weight: 900;
      transform: rotate(-4deg);
    }

    .footer-note {
      margin-top: 20px;
      padding: 18px 18px 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.8;
    }

    .footer-note strong {
      color: var(--dark-blue);
    }

    [data-mode="later"] .mode-now-only,
    [data-mode="now"] .mode-later-only {
      display: none !important;
    }

    .screen-a .mode-copy,
    .screen-b .mode-copy,
    .screen-c .mode-copy {
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .screen-a .mode-copy.updating,
    .screen-b .mode-copy.updating,
    .screen-c .mode-copy.updating {
      opacity: 0.45;
      transform: translateY(4px);
    }

    @media (min-width: 900px) {
      .page {
        width: min(1340px, calc(100% - 48px));
        padding-top: 30px;
      }

      .hero {
        padding: 34px 30px 28px;
      }

      .stage {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
      }
    }

    @media (max-width: 420px) {
      .page {
        width: calc(100% - 20px);
      }

      .hero {
        border-radius: 28px;
        padding-left: 16px;
        padding-right: 16px;
      }

      .headline {
        font-size: 26px;
      }

      .shell {
        border-width: 7px;
      }

      .compare-row {
        grid-template-columns: 1.15fr 0.8fr 0.8fr 0.8fr;
        padding-left: 10px;
        padding-right: 10px;
      }
    }

    @keyframes floatBlob {
      0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
      50% { transform: translate3d(0, 12px, 0) scale(1.08); }
    }

    @keyframes drawLine {
      0% {
        transform: scaleX(0.12) rotate(-1deg);
        transform-origin: left center;
        opacity: 0.4;
      }
      100% {
        transform: scaleX(1) rotate(-1deg);
        transform-origin: left center;
        opacity: 1;
      }
    }

    @keyframes pulseGlow {
      0%, 100% { transform: translateY(0); box-shadow: 0 14px 22px rgba(248, 76, 162, 0.23); }
      50% { transform: translateY(-2px); box-shadow: 0 20px 26px rgba(248, 76, 162, 0.30); }
    }

    @keyframes growBar {
      from { width: 0; }
      to { width: var(--w, 50%); }
    }

    @keyframes drawPath {
      to { stroke-dashoffset: 0; }
    }
  </style>
</head>
<body data-mode="later">
  <main class="page">
    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">ASO検証用 ストアスクリーン A案</p>
        <h1>不安に寄り添って、<br />「入れてみようかな」をつくる3枚構成</h1>
        <p class="hero-copy">
          AI査定の安心感、出費管理と将来予測の納得感、そして比較で伝わる「電話0本」の軽さを、
          あたたかい配色と手書き風ディテールでまとめたモバイルファーストのプロトタイプです。
        </p>

        <div class="support-row">
          <div class="support-chip">個人情報なしで相場チェック</div>
          <div class="support-chip">売却時のやりとりは1社だけ</div>
          <div class="support-chip">8,000社が競うオークション</div>
        </div>

        <div class="toolbar">
          <div class="toolbar-group">
            <p class="toolbar-title">表示フォーカス</p>
            <button class="tool-btn is-active" type="button" data-focus="screen-a">スクショAを中心に見る</button>
            <button class="tool-btn" type="button" data-focus="screen-b">スクショBを中心に見る</button>
            <button class="tool-btn" type="button" data-focus="screen-c">スクショCを中心に見る</button>
          </div>
          <div class="toolbar-group">
            <p class="toolbar-title">ユーザー心理の切り替え</p>
            <button class="mode-btn" type="button" data-mode-switch="later">まだ先だけど気になる</button>
            <button class="mode-btn" type="button" data-mode-switch="now">今すぐ売り時を知りたい</button>
          </div>
        </div>
      </div>
    </section>

    <section class="stage">
      <article class="phone is-selected" id="screen-a">
        <div class="device-label">
          <span>スクショA</span>
          <span>iOS向け / AI査定訴求</span>
        </div>
        <div class="shell">
          <div class="screen screen-a">
            <div class="screen-content">
              <div class="status-row">
                <span>9:41</span>
                <span>5G 100%</span>
              </div>

              <div class="brand-pill">
                <span class="brand-dot"></span>
                <span>UcarPAC AI査定</span>
              </div>

              <div class="sticker">個人情報なし<br />30秒で相場感</div>

              <h2 class="headline">「いくらで売れる？」に<br /><strong>やさしく答えるAI</strong></h2>
              <p class="subcopy mode-copy">
                <span class="mode-later-only">まだ売ると決めていなくても大丈夫。相場だけ見て、ゆっくり考えられます。</span>
                <span class="mode-now-only">今の売り時をすぐ確認。迷っている時間も、価格のチャンスも逃しません。</span>
              </p>

              <div class="mini-tabs" data-tabs="price">
                <button class="mini-tab is-active" type="button" data-price="now">現在価格</button>
                <button class="mini-tab" type="button" data-price="3m">3か月後</button>
                <button class="mini-tab" type="button" data-price="6m">6か月後</button>
              </div>

              <section class="card">
                <h3 class="card-title">あなたの愛車イメージ</h3>
                <p class="card-note">2021年式 トヨタ ヤリスクロス Z / パールホワイト / 31,800km</p>
                <div class="car-meta">
                  <div>
                    <p class="car-name">ヤリスクロス Z</p>
                    <p class="car-spec">1.5L / 2WD / 禁煙 / 純正ナビ / バックカメラ</p>
                  </div>
                  <div class="price-badge">
                    <span class="price-label" id="priceLabelA">現在のAI査定</span>
                    <span class="price-value" id="priceValueA">218.4万円</span>
                  </div>
                </div>

                <div class="meter">
                  <div class="meter-row">
                    <span>全国相場</span>
                    <div class="meter-bar"><div class="meter-fill" style="--w: 68%;"></div></div>
                    <strong>207万円</strong>
                  </div>
                  <div class="meter-row">
                    <span>装備補正</span>
                    <div class="meter-bar"><div class="meter-fill" style="--w: 84%;"></div></div>
                    <strong>+8.9万円</strong>
                  </div>
                  <div class="meter-row">
                    <span>人気度</span>
                    <div class="meter-bar"><div class="meter-fill" style="--w: 78%;"></div></div>
                    <strong>A判定</strong>
                  </div>
