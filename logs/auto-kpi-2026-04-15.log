  <script>
    (function () {
      var filterButtons = document.querySelectorAll('.mode-btn');
      var shotCards = document.querySelectorAll('.shot-card');

      filterButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          filterButtons.forEach(function (btn) {
            btn.classList.remove('is-active');
          });
          button.classList.add('is-active');

          var filter = button.getAttribute('data-filter');
          shotCards.forEach(function (card) {
            var group = card.getAttribute('data-group');
            var visible = filter === 'all' || filter === group;
            card.classList.toggle('dimmed', !visible && filter !== 'all');
            card.style.display = visible || filter === 'all' ? 'grid' : 'none';
          });

          if (filter === 'all') {
            shotCards.forEach(function (card) {
              card.classList.remove('dimmed');
              card.style.display = 'grid';
            });
          }
        });
      });

      var toggleGroups = document.querySelectorAll('.mini-toggle');
      toggleGroups.forEach(function (toggle) {
        toggle.addEventListener('click', function () {
          var target = toggle.getAttribute('data-copy-target');
          var index = toggle.getAttribute('data-copy-index');
          document.querySelectorAll('.mini-toggle[data-copy-target="' + target + '"]').forEach(function (btn) {
            btn.classList.remove('active');
          });
          toggle.classList.add('active');

          [0, 1, 2].forEach(function (i) {
            var panel = document.getElementById('copy-' + target + '-' + i);
            if (!panel) return;
            panel.className = String(i) === index ? 'visible-panel' : 'hidden-panel';
          });
        });
      });

      document.querySelectorAll('[data-cta]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var original = btn.textContent;
          var label = btn.getAttribute('data-cta');
          var messages = {
            estimate: 'AI査定に進む',
            notify: '通知設定を開く',
            expense: '記録フローを開始',
            future: '予測を表示中',
            compare: '比較表を拡大表示',
            auction: '売却フローを表示中'
          };
          btn.textContent = messages[label] || '表示中';
          btn.style.transform = 'scale(0.98)';
          window.setTimeout(function () {
            btn.textContent = original;
            btn.style.transform = '';
          }, 1200);
        });
      });
    })();
  </script>
