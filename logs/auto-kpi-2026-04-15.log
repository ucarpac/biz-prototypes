      --dark-blue: #1c2663;
      --white: #FFFFFF;
      --text-black: #404040;
      --text-gray: #737373;
      --text-disabled: #B3B3B3;
      --text-placeholder: rgba(28,38,99,0.3);
      --text-light-blue: #bfdbfe;
      --text-under-blue: #0056BA;
      --button-gray: #CACEE2;
      --button-link1: #4099FF;
      --button-link2: #40BFFF;
      --back-white: #FAFAFA;
      --light-gray: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-gray2: #e6e6e6;
      --back-blue: #091355;
      --back-dark-blue: #0a1348;
      --back-light-pink: #ffd8e8;
      --back-light-blue: #6fc2ff;
      --error: #EB4646;
      --shadow: rgba(0,0,0,0.11);
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --gradient-auction: linear-gradient(135deg, #091355, #1d2e93);
      --gradient-glow: radial-gradient(circle at top left, rgba(248,76,162,0.26), transparent 42%),
        radial-gradient(circle at bottom right, rgba(29,220,255,0.24), transparent 48%),
        linear-gradient(180deg, #fdfdff 0%, #edf3ff 100%);
      --font-sans: "Noto Sans JP", "Hiragino Sans", system-ui, sans-serif;
      --font-number: "Righteous", "Noto Sans JP", sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-7: 28px;
      --space-8: 32px;
      --space-10: 40px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 22px;
      --radius-button: 30px;
      --radius-device: 32px;
      --shadow-light: 0 12px 30px rgba(28, 38, 99, 0.08);
      --shadow-medium: 0 18px 50px rgba(28, 38, 99, 0.14);
      --shadow-heavy: 0 28px 80px rgba(10, 19, 72, 0.18);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      background: var(--gradient-glow);
      color: var(--text-black);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    body {
      overflow-x: hidden;
    }

    button {
      font: inherit;
      cursor: pointer;
      border: 0;
      background: none;
      padding: 0;
    }

    .page-shell {
      width: min(100%, 1180px);
      margin: 0 auto;
      padding: 20px 16px 64px;
      position: relative;
    }

    .page-shell::before,
    .page-shell::after {
      content: "";
      position: fixed;
      inset: auto;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      filter: blur(30px);
      opacity: 0.55;
      pointer-events: none;
      z-index: 0;
    }

    .page-shell::before {
      top: -80px;
      right: -60px;
      background: rgba(248, 76, 162, 0.22);
    }

    .page-shell::after {
      left: -60px;
      bottom: 8%;
      background: rgba(64, 191, 255, 0.22);
    }

    .hero {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 16px;
      padding: 20px 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(255,255,255,0.92), rgba(237,243,255,0.9));
      backdrop-filter: blur(16px);
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(255,255,255,0.75);
    }

    .hero-topline {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(9,19,85,0.06);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    .hero h1 {
      margin: 0;
      font-size: 30px;
      line-height: 1.35;
      color: var(--back-dark-blue);
      letter-spacing: -0.02em;
    }

    .hero p {
      margin: 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 1.8;
    }

    .hero-metrics {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .metric-chip {
      background: var(--white);
      border-radius: 16px;
      padding: 14px 14px 12px;
      box-shadow: 0 10px 24px rgba(28, 38, 99, 0.08);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .metric-chip .label {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      margin-bottom: 6px;
      letter-spacing: 0.03em;
    }

    .metric-chip strong {
      display: block;
      font-family: var(--font-number);
      font-size: 28px;
      line-height: 1;
      color: var(--dark-blue);
      letter-spacing: 0.01em;
    }

    .metric-chip .sub {
      display: block;
      margin-top: 6px;
      font-size: 11px;
      color: var(--text-under-blue);
      font-weight: 700;
    }

    .hero-controls {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .mode-btn {
      min-height: 43px;
      padding: 0 18px;
      border-radius: var(--radius-button);
      border: 1px solid rgba(28,38,99,0.08);
      background: rgba(255,255,255,0.82);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease, color 160ms ease;
      box-shadow: 0 8px 20px rgba(28, 38, 99, 0.06);
    }

    .mode-btn.is-active {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 12px 28px rgba(64, 191, 255, 0.22);
    }

    .mode-btn:active {
      transform: translateY(1px) scale(0.99);
    }

    .shots {
      position: relative;
      z-index: 1;
      margin-top: 24px;
      display: grid;
      gap: 24px;
    }

    .shot-card {
      display: grid;
      gap: 18px;
      padding: 18px;
      border-radius: 28px;
      background: rgba(255,255,255,0.88);
      backdrop-filter: blur(18px);
      box-shadow: var(--shadow-medium);
      border: 1px solid rgba(255,255,255,0.85);
      transition: transform 260ms ease, box-shadow 260ms ease, opacity 260ms ease;
    }

    .shot-card.dimmed {
      opacity: 0.52;
      transform: scale(0.985);
    }

    .shot-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
    }

    .shot-id {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(248,76,162,0.1);
      color: var(--pink);
      font-size: 12px;
      font-weight: 700;
    }

    .shot-platform {
      font-size: 12px;
      color: var(--dark-blue);
      font-weight: 700;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(9,19,85,0.07);
      white-space: nowrap;
    }

    .shot-copy h2 {
      margin: 0 0 8px;
      font-size: 24px;
      line-height: 1.35;
      color: var(--back-dark-blue);
    }

    .shot-copy p {
      margin: 0;
      font-size: 14px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .shot-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .badge-pink {
      background: rgba(248,76,162,0.12);
      color: #b41f6d;
      border-color: rgba(248,76,162,0.18);
    }

    .badge-blue {
      background: rgba(64,153,255,0.12);
      color: #1551b8;
      border-color: rgba(64,153,255,0.18);
    }

    .badge-dark {
      background: rgba(9,19,85,0.92);
      color: var(--white);
      border-color: transparent;
    }

    .panel-grid {
      display: grid;
      gap: 18px;
    }

    .device-wrap {
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .device {
      width: min(100%, 375px);
      min-height: 760px;
      background: linear-gradient(180deg, #fbfcff 0%, #eef4ff 100%);
      border-radius: var(--radius-device);
      padding: 14px;
      box-shadow: var(--shadow-heavy);
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.9);
    }

    .device::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 12% 12%, rgba(248,76,162,0.18), transparent 20%),
        radial-gradient(circle at 88% 0%, rgba(64,191,255,0.18), transparent 22%),
        linear-gradient(180deg, rgba(9,19,85,0.02), rgba(9,19,85,0.06));
      pointer-events: none;
    }

    .notch {
      width: 128px;
      height: 28px;
      border-radius: 0 0 18px 18px;
      background: #0f153f;
      margin: -14px auto 8px;
      position: relative;
      z-index: 2;
    }

    .screen {
      position: relative;
      z-index: 1;
      border-radius: 24px;
      overflow: hidden;
      min-height: 712px;
      background:
        radial-gradient(circle at top right, rgba(248,76,162,0.16), transparent 24%),
        linear-gradient(180deg, #f8fbff 0%, #eef3ff 38%, #f9fbff 100%);
      padding: 16px;
    }

    .statusbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      margin-bottom: 12px;
    }

    .status-icons {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .status-dot,
    .status-pill {
      background: var(--dark-blue);
      border-radius: 999px;
      height: 7px;
    }

    .status-dot {
      width: 7px;
      opacity: 0.7;
    }

    .status-pill {
      width: 16px;
    }

    .app-hero {
      position: relative;
      padding: 20px 18px 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, #0a1352 0%, #2337ab 100%);
      color: var(--white);
      overflow: hidden;
      box-shadow: 0 20px 40px rgba(17, 32, 120, 0.26);
    }

    .app-hero::before,
    .app-hero::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
    }

    .app-hero::before {
      width: 180px;
      height: 180px;
      top: -90px;
      right: -80px;
      background: rgba(248,76,162,0.24);
    }

    .app-hero::after {
      width: 130px;
      height: 130px;
      bottom: -60px;
      left: -50px;
      background: rgba(29,220,255,0.18);
    }

    .hero-kicker {
      display: inline-flex;
      gap: 6px;
      align-items: center;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.96);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      margin-bottom: 14px;
    }

    .app-hero h3 {
      margin: 0;
      font-size: 28px;
      line-height: 1.32;
      letter-spacing: -0.02em;
      position: relative;
      z-index: 1;
    }

    .hero-price-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      margin-top: 16px;
      position: relative;
      z-index: 1;
    }

    .price-box strong {
      display: block;
      font-family: var(--font-number);
      font-size: 42px;
      line-height: 1;
      letter-spacing: 0.01em;
    }

    .price-box span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      color: rgba(255,255,255,0.78);
    }

    .hero-mini {
      min-width: 120px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(8px);
    }

    .hero-mini .mini-label {
      display: block;
      font-size: 10px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.72);
      letter-spacing: 0.08em;
    }

    .hero-mini .mini-value {
      display: block;
      margin-top: 6px;
      font-size: 20px;
      font-weight: 700;
      color: var(--white);
    }

    .hero-mini .mini-foot {
      display: block;
      margin-top: 6px;
      font-size: 11px;
      color: #8ff0ff;
    }

    .quick-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
      position: relative;
      z-index: 1;
    }

    .quick-stat {
      padding: 12px 10px;
      border-radius: 16px;
      background: rgba(255,255,255,0.1);
      text-align: center;
      backdrop-filter: blur(6px);
    }

    .quick-stat strong {
      display: block;
      font-size: 18px;
      line-height: 1.1;
      margin-bottom: 5px;
    }

    .quick-stat span {
      display: block;
      font-size: 10px;
      color: rgba(255,255,255,0.74);
      line-height: 1.5;
    }

    .section {
      margin-top: 16px;
      padding: 16px;
      border-radius: 20px;
      background: rgba(255,255,255,0.9);
      border: 1px solid rgba(28,38,99,0.06);
      box-shadow: 0 12px 24px rgba(28,38,99,0.06);
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }

    .section-title {
      margin: 0;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .section-link {
      font-size: 11px;
      color: var(--text-under-blue);
      font-weight: 700;
    }

    .insight-card {
      display: grid;
      gap: 12px;
    }

    .insight-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .insight-row .label {
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.5;
    }

    .insight-row .value {
      font-size: 13px;
      color: var(--dark-blue);
      font-weight: 700;
      white-space: nowrap;
    }

    .bar {
      width: 100%;
      height: 10px;
      background: #eaf0fb;
      border-radius: 999px;
      overflow: hidden;
    }

    .bar > span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transform-origin: left center;
      animation: pulseBar 2.1s ease-in-out infinite alternate;
    }

    @keyframes pulseBar {
      from { transform: scaleX(0.95); }
      to { transform: scaleX(1); }
    }

    .chart-card {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(9,19,85,0.04), rgba(9,19,85,0.01));
      border: 1px solid rgba(28,38,99,0.06);
    }

    .chart-title {
      margin: 0 0 12px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .chart-title span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 500;
    }

    .chart-legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
      vertical-align: middle;
    }

    .forecast-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .forecast-box {
      padding: 12px 10px;
      border-radius: 16px;
      background: #f6f9ff;
      border: 1px solid rgba(28,38,99,0.06);
    }

    .forecast-box strong {
      display: block;
      font-family: var(--font-number);
      font-size: 22px;
      color: var(--dark-blue);
      line-height: 1.1;
    }

    .forecast-box span {
      display: block;
      margin-top: 6px;
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.45;
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 6px 12px;
      padding: 12px 14px;
      border-radius: 16px;
      background: #f7faff;
      border: 1px solid rgba(28,38,99,0.06);
    }

    .expense-item .name {
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .expense-item .amount {
      font-size: 16px;
      font-family: var(--font-number);
      color: var(--dark-blue);
      text-align: right;
    }

    .expense-item .note {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.5;
    }

    .expense-item .trend {
      font-size: 11px;
      font-weight: 700;
      color: #0d8d61;
      text-align: right;
    }

    .cta-band {
      margin-top: 16px;
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(248,76,162,0.12), rgba(64,191,255,0.12));
      border: 1px solid rgba(248,76,162,0.12);
      display: grid;
      gap: 12px;
    }

    .cta-band h4 {
      margin: 0;
      font-size: 18px;
      line-height: 1.45;
      color: var(--back-dark-blue);
    }

    .cta-band p {
      margin: 0;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .cta-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .pill-btn {
      min-height: 43px;
      padding: 0 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
    }

    .pill-btn.primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 12px 24px rgba(64,191,255,0.24);
    }

    .pill-btn.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 12px 24px rgba(248,76,162,0.2);
    }

    .pill-btn.white {
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .pill-btn:active {
      transform: translateY(1px);
      opacity: 0.94;
    }

    .aside-data {
      display: grid;
      gap: 16px;
    }

    .detail-card {
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,251,255,0.92));
      border: 1px solid rgba(28,38,99,0.06);
      box-shadow: 0 12px 24px rgba(28,38,99,0.06);
    }

    .detail-card h3 {
      margin: 0 0 12px;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .detail-card p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .detail-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .detail-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 6px 12px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--ruled-line);
    }

    .detail-item:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .detail-item .name {
      font-size: 12px;
      color: var(--text-gray);
    }

    .detail-item .score {
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .detail-item .desc {
      grid-column: 1 / -1;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: 18px;
      font-size: 12px;
    }

    .compare-table th,
    .compare-table td {
      padding: 10px 12px;
      text-align: center;
      border-bottom: 1px solid rgba(28,38,99,0.06);
    }

    .compare-table th {
      background: rgba(9,19,85,0.05);
      color: var(--dark-blue);
      font-weight: 700;
    }

    .compare-table td:first-child,
    .compare-table th:first-child {
      text-align: left;
    }

    .compare-table tr:last-child td {
      border-bottom: 0;
    }

    .table-yes {
      color: #0d8d61;
      font-weight: 700;
    }

    .table-no {
      color: var(--error);
      font-weight: 700;
    }

    .table-mid {
      color: #cb8a00;
      font-weight: 700;
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .kpi-cell {
      padding: 12px 10px;
      border-radius: 16px;
      background: #f6f9ff;
      border: 1px solid rgba(28,38,99,0.06);
      text-align: center;
    }

    .kpi-cell strong {
      display: block;
      font-size: 19px;
      line-height: 1.1;
      font-family: var(--font-number);
      color: var(--dark-blue);
    }

    .kpi-cell span {
      display: block;
      margin-top: 6px;
      font-size: 11px;
      line-height: 1.45;
      color: var(--text-gray);
    }

    .footer-note {
      position: relative;
      z-index: 1;
      margin-top: 28px;
      padding: 16px 18px;
      border-radius: 18px;
      background: rgba(9,19,85,0.94);
      color: rgba(255,255,255,0.82);
      font-size: 12px;
      line-height: 1.8;
      box-shadow: var(--shadow-light);
    }

    .toggle-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .mini-toggle {
      min-height: 36px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(9,19,85,0.06);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      transition: all 160ms ease;
    }

    .mini-toggle.active {
      background: rgba(248,76,162,0.14);
      color: #b41f6d;
    }

    .hidden-panel {
      display: none;
    }

    .visible-panel {
      display: block;
    }

    @media (min-width: 820px) {
      .page-shell {
        padding: 32px 24px 80px;
      }

      .hero {
        grid-template-columns: 1.25fr 0.95fr;
        align-items: end;
        padding: 28px;
      }

      .shots {
        gap: 28px;
      }

      .shot-card {
        grid-template-columns: minmax(0, 390px) minmax(0, 1fr);
        align-items: start;
        padding: 24px;
      }

      .panel-grid {
        grid-template-columns: 1fr;
      }

      .aside-data {
        gap: 18px;
      }
    }

    @media (min-width: 1080px) {
      .shot-card {
        grid-template-columns: minmax(0, 395px) minmax(0, 1fr);
      }

      .panel-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }
  </style>
