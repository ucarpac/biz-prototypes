                  <div><span class="ng">基本必要</span></div>
                </div>

                <div class="compare-row">
                  <div class="cell-main">将来予測</div>
                  <div><span class="ok">AIで見える</span></div>
                  <div><span class="ng">なし</span></div>
                  <div><span class="ng">なし</span></div>
                </div>

                <div class="compare-row">
