          </div>
        </div>
      </article>

      <article class="phone" id="screen-c">
        <div class="device-label">
          <span>スクショC</span>
          <span>競合比較 / 「電話0本」訴求</span>
        </div>
        <div class="shell">
          <div class="screen screen-c">
            <div class="screen-content">
              <div class="status-row">
                <span>9:41</span>
                <span>5G 84%</span>
              </div>

              <div class="brand-pill">
