      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--dark-blue);
    }

    .ring-text strong {
      font-family: var(--font-number);
      font-size: 32px;
      line-height: 36px;
      font-weight: 700;
    }

    .ring-text span {
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .proposal {
      margin-top: 14px;
      background: #fff5fa;
      border-radius: var(--radius-md);
      padding: 12px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
    }

    .proposal strong {
      display: block;
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      margin-bottom: 2px;
    }

    .proposal span {
      display: block;
      font-size: 11px;
      line-height: 16.5px;
      color: var(--text-gray);
    }

    .pink-button {
      min-width: 104px;
      height: 43px;
      border-radius: var(--radius-button);
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      box-shadow: 0 8px 14px rgba(248,76,162,0.24);
    }

    .report-card {
      padding: 0;
      overflow: hidden;
    }

    .report-header {
      padding: 16px;
      border-bottom: 1px solid var(--ruled-line);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .report-header h3 {
      margin: 0 0 4px;
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .report-header p {
      margin: 0;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .summary-number {
      text-align: right;
      color: var(--dark-blue);
      white-space: nowrap;
    }

    .summary-number strong {
      display: block;
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 36px;
      font-weight: 700;
    }

    .summary-number span {
      display: block;
      font-size: 10px;
      line-height: 15px;
      color: var(--pink);
      font-weight: 700;
    }

    .bar-list {
      padding: 16px;
      display: grid;
      gap: 14px;
    }

    .bar-item {
      display: grid;
      gap: 6px;
    }

    .bar-meta {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .bar-meta span:first-child {
      color: var(--text-black);
    }

    .bar-meta span:last-child {
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .bar-track {
      width: 100%;
      height: 10px;
      border-radius: 10px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 10px;
      background: var(--gradient-primary);
      width: var(--width);
      animation: barIn 1s ease-out;
    }

    .bar-fill.pink {
      background: var(--gradient-pink);
    }

    .comparison {
      margin: 0 16px 16px;
      border: 1px solid var(--ruled-line);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .comparison-row {
      display: grid;
      grid-template-columns: 1fr 78px 78px;
      min-height: 42px;
      border-bottom: 1px solid var(--ruled-line);
      align-items: center;
    }

    .comparison-row:last-child {
      border-bottom: 0;
    }

    .comparison-row.head {
      background: var(--back-gray);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .comparison-row div {
      padding: 10px 8px;
      font-size: 11px;
      line-height: 16.5px;
      border-right: 1px solid var(--ruled-line);
    }

    .comparison-row div:last-child {
      border-right: 0;
      text-align: right;
    }

    .comparison-row div:nth-child(2) {
      text-align: right;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .simulation-card {
      background: var(--back-dark-blue);
      border-radius: 13px;
      box-shadow: var(--shadow);
      color: var(--white);
      padding: 16px;
      overflow: hidden;
    }

    .simulation-card h3 {
      margin: 0 0 6px;
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
    }

    .simulation-card p {
      margin: 0 0 14px;
      font-size: 12px;
      line-height: 18px;
      color: #bfdbfe;
    }

    .break-even-number {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: end;
      margin-bottom: 14px;
    }

    .break-even-number strong {
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 54px;
      font-weight: 700;
      color: var(--white);
    }

    .break-even-number span {
      display: block;
      font-size: 12px;
      line-height: 18px;
      color: #bfdbfe;
      margin-bottom: 8px;
    }

    .primary-button {
      height: 43px;
      min-width: 140px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      box-shadow: 0 8px 14px rgba(29,220,255,0.22);
    }

    .chart-panel {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: var(--radius-md);
      padding: 12px;
      margin-bottom: 12px;
    }

    .line-chart {
      width: 100%;
      height: 168px;
      display: block;
    }

    .chart-axis {
      stroke: rgba(255,255,255,0.18);
      stroke-width: 1;
    }

    .chart-cost {
      fill: none;
      stroke: #1ddcff;
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: drawLine 1.3s ease-out forwards;
    }

    .chart-sale {
      fill: none;
      stroke: #F84CA2;
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: drawLine 1.3s ease-out 0.2s forwards;
    }

    .chart-dot {
      fill: var(--white);
      stroke: var(--pink);
      stroke-width: 4;
    }

    .legend {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      line-height: 15px;
      color: #bfdbfe;
      font-weight: 700;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #1ddcff;
    }

    .legend-dot.pink {
      background: var(--pink);
    }

    .auction-card {
      display: grid;
      gap: 14px;
    }

    .auction-row {
      display: grid;
      grid-template-columns: 68px 1fr;
      gap: 12px;
      align-items: center;
    }

    .auction-label {
      font-size: 11px;
      line-height: 16.5px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .auction-value {
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .timeline {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      margin-top: 2px;
    }

    .timeline-step {
      height: 8px;
      border-radius: 10px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .timeline-step.active {
      background: var(--gradient-primary);
    }

    .bottom-nav {
      position: fixed;
      left: 50%;
      bottom: 0;
      transform: translateX(-50%);
      width: 100%;
      max-width: 430px;
      background: var(--white);
      border-top: 1px solid var(--ruled-line);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      padding: 8px 8px 10px;
      box-shadow: 0 -8px 18px rgba(0,0,0,0.06);
      z-index: 5;
    }

    .nav-button {
      min-height: 48px;
      background: transparent;
      color: var(--text-gray);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      border-radius: var(--radius-md);
    }

    .nav-button.active {
      color: var(--pink);
      background: #fff5fa;
    }

    .nav-icon {
      width: 20px;
      height: 20px;
      display: block;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 78px;
      transform: translate(-50%, 20px);
      width: calc(100% - 32px);
      max-width: 398px;
      background: var(--dark-blue);
      color: var(--white);
      border-radius: var(--radius-md);
      padding: 12px 14px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      box-shadow: var(--shadow);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
      z-index: 10;
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    .hidden {
      display: none;
    }

    @keyframes ringIn {
      from {
        stroke-dashoffset: 292;
      }
      to {
        stroke-dashoffset: 96;
      }
    }

    @keyframes barIn {
      from {
        width: 0;
      }
      to {
        width: var(--width);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @media (min-width: 431px) {
      body {
        background: var(--back-gray);
      }

      .app-shell {
        box-shadow: 0 0 40px rgba(28,38,99,0.16);
      }
    }

    @media (max-width: 360px) {
      .countdown-grid {
        grid-template-columns: 1fr;
      }

      .ring {
        margin: 0 auto;
      }

      .proposal {
        grid-template-columns: 1fr;
      }

      .pink-button,
      .primary-button {
        width: 100%;
      }

      .comparison-row {
        grid-template-columns: 1fr 66px 66px;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="hero">
      <div class="hero-top">
        <div class="logo-mark">
          <strong>UcarPAC</strong>
          <span>出費管理 KPI Dashboard</span>
        </div>
        <div class="date-chip">2026.05.04 更新</div>
      </div>

      <h1 class="hero-title">出費管理を毎月使う理由にする</h1>
      <p class="hero-copy">車検・維持費・売却額を1画面で比較し、売り時判断までつなげる月次アクティブ率向上プロトタイプ。</p>

      <div class="hero-metrics">
        <div class="metric-tile">
          <span class="metric-label">月次アクティブ率</span>
          <span class="metric-value" id="activeRate">42%</span>
          <span class="metric-note">目標 +12pt</span>
        </div>
        <div class="metric-tile">
          <span class="metric-label">売却提案タップ率</span>
          <span class="metric-value" id="tapRate">18%</span>
          <span class="metric-note">車検90日前セグメント</span>
        </div>
      </div>
    </header>

    <main class="main-content">
      <section class="section">
        <div class="card vehicle-card">
          <div class="car-visual" aria-hidden="true">
            <svg viewBox="0 0 120 72">
              <path d="M20 45 L30 27 C33 21 38 18 45 18 H76 C83 18 89 22 93 29 L101 45 Z" fill="#1c2663"/>
              <path d="M39 25 H58 V43 H27 L34 30 C35 27 37 25 39 25 Z" fill="#6fc2ff"/>
              <path d="M62 25 H76 C81 25 84 28 87 33 L92 43 H62 Z" fill="#6fc2ff"/>
              <rect x="13" y="42" width="94" height="14" rx="7" fill="#F84CA2"/>
              <circle cx="34" cy="56" r="9" fill="#404040"/>
              <circle cx="86" cy="56" r="9" fill="#404040"/>
              <circle cx="34" cy="56" r="4" fill="#FAFAFA"/>
              <circle cx="86" cy="56" r="4" fill="#FAFAFA"/>
            </svg>
          </div>
          <div>
            <h2 class="vehicle-name">トヨタ プリウス S</h2>
            <p class="vehicle-detail">2018年式 / 58,200km / 東京都 / 次回車検 2026年8月</p>
            <div class="badge-row">
              <span class="badge">個人情報不要</span>
              <span class="badge blue">AI査定済み</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="tab-control">
          <button class="tab-button active" data-tab="month">月次</button>
          <button class="tab-button" data-tab="year">年次</button>
          <button class="tab-button" data-tab="same">同車種比較</button>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <h2>車検リマインド</h2>
          <span>期限カウントダウン</span>
        </div>

        <div class="countdown-card">
          <div class="countdown-grid">
            <div>
              <div class="countdown-kicker">車検まであと少し</div>
              <h3 class="countdown-title">残り 118 日</h3>
              <p class="countdown-desc">車検費用の想定は 128,000円。同車種平均より 14,000円高めです。</p>
            </div>

            <div class="ring">
              <svg viewBox="0 0 116 116">
                <circle class="ring-bg" cx="58" cy="58" r="46"></circle>
                <circle class="ring-progress" cx="58" cy="58" r="46"></circle>
              </svg>
              <div class="ring-text">
                <strong>118</strong>
                <span>days</span>
              </div>
            </div>
          </div>

          <div class="proposal">
            <div>
              <strong>車検前に売ると維持費を抑えられます</strong>
              <span>今のAI査定額 1,240,000円 / 3ヶ月後予測 1,180,000円</span>
            </div>
            <button class="pink-button" id="sellBeforeInspection">車検前に売る</button>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <h2>出費レポート</h2>
          <span id="reportPeriod">2026年4月</span>
        </div>

        <div class="card report-card">
          <div class="report-header">
            <div>
              <h3 id="reportTitle">月次出費サマリー</h3>
              <p id="reportLead">ガソリン代が先月比 +8%。車検積立を含めると固定費比率が上昇しています。</p>
            </div>
            <div class="summary-number">
              <strong id="totalCost">¥42,800</strong>
              <span id="costDelta">先月比 +6%</span>
            </div>
          </div>

          <div class="bar-list" id="barList">
            <div class="bar-item">
              <div class="bar-meta">
                <span>ガソリン</span>
                <span>¥18,400</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill" style="--width: 86%;"></div>
              </div>
            </div>

            <div class="bar-item">
              <div class="bar-meta">
                <span>保険</span>
                <span>¥9,600</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill" style="--width: 45%;"></div>
              </div>
            </div>

            <div class="bar-item">
              <div class="bar-meta">
                <span>車検積立</span>
                <span>¥10,700</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill pink" style="--width: 50%;"></div>
              </div>
            </div>

            <div class="bar-item">
              <div class="bar-meta">
                <span>メンテナンス</span>
                <span>¥4,100</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill" style="--width: 19%;"></div>
              </div>
            </div>
          </div>

          <div class="comparison">
            <div class="comparison-row head">
              <div>項目</div>
              <div>あなた</div>
              <div>同車種</div>
            </div>
            <div class="comparison-row">
              <div>月間出費</div>
              <div>42,800円</div>
              <div>39,200円</div>
            </div>
            <div class="comparison-row">
              <div>燃費換算</div>
              <div>21.8km/L</div>
              <div>23.1km/L</div>
            </div>
            <div class="comparison-row">
              <div>年間予測</div>
              <div>514,000円</div>
              <div>470,000円</div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <h2>損益分岐シミュレーション</h2>
          <span>売却額 vs 維持費</span>
        </div>

        <div class="simulation-card">
          <h3>あと 19 ヶ月で出費が売却額を超過</h3>
          <p>AI査定額の下落と維持費累計を重ねて、売却タイミングを月次で確認できます。</p>

          <div class="break-even-number">
            <div>
              <strong id="breakEvenMonth">19ヶ月</strong>
              <span>損益分岐まで</span>
            </div>
            <button class="primary-button" id="simulateButton">条件を変更</button>
          </div>

          <div class="chart-panel">
            <svg class="line-chart" viewBox="0 0 340 168" preserveAspectRatio="none" aria-label="損益分岐グラフ">
              <line class="chart-axis" x1="24" y1="26" x2="316" y2="26"></line>
              <line class="chart-axis" x1="24" y1="68" x2="316" y2="68"></line>
              <line class="chart-axis" x1="24" y1="110" x2="316" y2="110"></line>
              <line class="chart-axis" x1="24" y1="150" x2="316" y2="150"></line>
              <path class="chart-sale" d="M24 30 C80 38, 126 50, 172 66 C218 82, 266 98, 316 112"></path>
              <path class="chart-cost" d="M24 144 C82 132, 128 113, 174 88 C220 64, 266 42, 316 28"></path>
              <circle class="chart-dot" cx="176" cy="78" r="6"></circle>
              <text x="186" y="75" fill="#FFFFFF" font-size="10" font-weight="700">19ヶ月</text>
              <text x="24" y="164" fill="#bfdbfe" font-size="10">現在</text>
              <text x="292" y="164" fill="#bfdbfe" font-size="10">24ヶ月</text>
            </svg>

            <div class="legend">
              <div class="legend-item">
                <span class="legend-dot pink"></span>
                <span>AI査定売却額</span>
              </div>
              <div class="legend-item">
                <span class="legend-dot"></span>
                <span>維持費累計</span>
              </div>
            </div>
          </div>

          <div class="badge-row">
            <span class="badge">現在査定 124万円</span>
            <span class="badge blue">24ヶ月維持費 137万円</span>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <h2>オークション接続</h2>
          <span>出費管理から売却へ</span>
        </div>

        <div class="card auction-card">
          <div class="auction-row">
            <div class="auction-label">差別化</div>
            <div class="auction-value">8,000店が競う最高額オークション</div>
          </div>
          <div class="auction-row">
            <div class="auction-label">連絡負担</div>
            <div class="auction-value">電話はUcarPAC 1社のみ</div>
          </div>
          <div class="auction-row">
            <div class="auction-label">進捗</div>
            <div>
              <div class="auction-value">AI査定 → 売却相談 → 出品 → 入札</div>
              <div class="timeline">
                <div class="timeline-step active"></div>
                <div class="timeline-step active"></div>
                <div class="timeline-step"></div>
                <div class="timeline-step"></div>
              </div>
            </div>
          </div>
          <button class="primary-button" id="auctionButton">売却シナリオを見る</button>
        </div>
      </section>
    </main>

    <nav class="bottom-nav" aria-label="メインナビゲーション">
      <button class="nav-button">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 10.5L12 4L20 10.5V20H15V14H9V20H4V10.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        </svg>
        ホーム
      </button>
      <button class="nav-button active">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 19V10M12 19V5M19 19V13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        出費
      </button>
      <button class="nav-button">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 17L9 12L13 15L20 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M15 7H20V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        AI査定
      </button>
      <button class="nav-button">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 7H18M8 7V5H16V7M8 10H16M8 14H16M8 18H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        履歴
      </button>
    </nav>

    <div class="toast" id="toast">車検前売却シナリオを保存しました</div>
  </div>

  <script>
    window.PROTO_AUTH_CONFIG = {
