    }

    .quest-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 50px;
      padding: 10px 12px;
      border-radius: var(--radius-md);
      background: var(--back-gray);
      transition: background 180ms ease, transform 180ms ease;
    }

    .quest-item.done {
