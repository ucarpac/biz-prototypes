    const screens = {
      value: document.getElementById('screen-value'),
      summary: document.getElementById('screen-summary'),
      notify: document.getElementById('screen-notify')
    };

    const navButtons = Array.from(document.querySelectorAll('.nav-btn'));
    const goButtons = Array.from(document.querySelectorAll('[data-go]'));
    const toast = document.getElementById('toast');
    const bars = Array.from(document.querySelectorAll('.bar'));
    const mainPrice = document.getElementById('mainPrice');
    const valueMessage = document.getElementById('valueMessage');
    const notifySwitch = document.getElementById('notifySwitch');
    const toggleSub = document.getElementById('toggleSub');
    const notificationCard = document.getElementById('notificationCard');
    const noticeBody = document.getElementById('noticeBody');

    function showToast(text) {
      toast.textContent = text;
      toast.classList.add('show');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function activateBars() {
      bars.forEach((bar) => {
        const width = bar.dataset.width;
        window.setTimeout(() => {
          bar.style.width = width;
        }, 120);
      });
    }

    function changeScreen(name) {
      Object.keys(screens).forEach((key) => {
        screens[key].classList.toggle('active', key === name);
      });

      navButtons.forEach((button) => {
        button.classList.toggle('active', button.dataset.go === name);
      });

      if (name === 'summary') {
        activateBars();
      }

      if (name === 'notify') {
        notificationCard.classList.add('bump');
        window.setTimeout(() => notificationCard.classList.remove('bump'), 500);
      }
    }

    goButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const name = button.dataset.go;
        if (name) {
          changeScreen(name);
        }
      });
    });

    document.getElementById('refreshPrice').addEventListener('click', () => {
      const values = [
        { price: 128, text: 'いま売らなくても大丈夫。まずは価値を知って、売り時を一緒に見守れます。' },
        { price: 131, text: '直近の入札傾向では少し上向きです。あせらず、来月の通知でもう一度確認できます。' },
        { price: 126, text: '相場は小さく動いています。下がった月も、出費管理と合わせて見守れます。' }
      ];

      const current = Number(mainPrice.textContent);
      const next = values.find((item) => item.price !== current) || values[0];
      mainPrice.textContent = next.price;
      valueMessage.textContent = next.text;
      showToast('AI概算価格を更新しました');
    });

    document.getElementById('addCost').addEventListener('click', () => {
      showToast('給油 5,280円の記録画面を開きます');
    });

    document.getElementById('shareSummary').addEventListener('click', () => {
      showToast('4月の月次サマリーを共有できます');
    });

    notifySwitch.addEventListener('click', () => {
      const off = notifySwitch.classList.toggle('off');
      toggleSub.textContent = off ? 'オフ: 必要な時に手動で確認' : 'オン: 毎月1回だけ受け取る';
      showToast(off ? '価格変動通知をオフにしました' : '価格変動通知をオンにしました');
    });

    document.getElementById('simulateNotice').addEventListener('click', () => {
      const messages = [
        'プリウス Sツーリングの推定価格が前月より2万円上がりました。現在の目安は128万円です。',
        '10月の予測価格は134万円です。売却相談を急がず、もう少し見守る選択もできます。',
        '今月の維持費は32,840円でした。価格と出費のバランスを見て、売り時を考えられます。'
      ];

      const current = noticeBody.textContent;
      const next = messages.find((message) => message !== current.trim()) || messages[0];
      noticeBody.textContent = next;
      notificationCard.classList.add('bump');
      window.setTimeout(() => notificationCard.classList.remove('bump'), 520);
      showToast('通知プレビューを更新しました');
    });

    window.setTimeout(activateBars, 300);
  </script>
</body>
