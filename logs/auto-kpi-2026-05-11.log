      overflow: hidden;
      margin-bottom: 14px;
    }

    .car-body {
      position: absolute;
      left: 42px;
      right: 42px;
      bottom: 30px;
      height: 36px;
      border-radius: 22px 28px 12px 12px;
      background: var(--dark-blue);
      box-shadow: inset 0 -7px 0 rgba(0,0,0,0.12);
    }

    .car-roof {
      position: absolute;
      left: 98px;
      bottom: 58px;
      width: 94px;
      height: 36px;
      border-radius: 34px 34px 7px 7px;
      background: #2f3c86;
      transform: skewX(-12deg);
    }

    .car-window {
      position: absolute;
      left: 112px;
      bottom: 64px;
      width: 60px;
      height: 22px;
      border-radius: 20px 20px 4px 4px;
      background: var(--back-light-blue);
      opacity: 0.9;
    }

    .wheel {
      position: absolute;
      bottom: 20px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #22294f;
      box-shadow: inset 0 0 0 6px #7480bc;
    }

    .wheel.left {
      left: 72px;
    }

    .wheel.right {
      right: 72px;
    }

    .scan-line {
      position: absolute;
      left: 26px;
      right: 26px;
      top: 12px;
      height: 3px;
      border-radius: 99px;
      background: var(--gradient-primary);
      box-shadow: 0 0 18px rgba(29,220,255,0.8);
      animation: scanMove 2.2s ease-in-out infinite;
    }

    @keyframes scanMove {
      0%, 100% {
        transform: translateY(0);
      }
