  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App リテンション改善プロトタイプ',
      description: '削除率低減の検証材料',
      expiresInHours: 24
    };

    const tabButtons = document.querySelectorAll('.tab-button');
    const screens = document.querySelectorAll('.screen');
    const actionButtons = document.querySelectorAll('.action-button');
    const scenarioButtons = document.querySelectorAll('.scenario-button');
    const navItems = document.querySelectorAll('.nav-item');
    const toast = document.getElementById('toast');
    const currentRate = document.getElementById('currentRate');
    const notificationTitle = document.getElementById('notificationTitle');
    const notificationBody = document.getElementById('notificationBody');

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function activateTab(tabName) {
      tabButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.tab === tabName);
      });
      screens.forEach((screen) => {
        screen.classList.toggle('is-active', screen.id === `screen-${tabName}`);
      });
    }

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activateTab(button.dataset.tab);
      });
    });

    actionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        showToast(button.dataset.message || '操作しました');
      });
    });

    scenarioButtons.forEach((button) => {
      button.addEventListener('click', () => {
        scenarioButtons.forEach((item) => item.classList.remove('is-selected'));
        button.classList.add('is-selected');
        notificationTitle.textContent = button.dataset.title;
        notificationBody.textContent = button.dataset.body;
        animateRate(Number(button.dataset.rate));
        showToast('通知シナリオを切り替えました');
      });
    });

    navItems.forEach((item) => {
      item.addEventListener('click', () => {
        navItems.forEach((nav) => nav.classList.remove('is-active'));
        item.classList.add('is-active');
        showToast(`${item.textContent}を選択しました`);
      });
    });

    function animateRate(target) {
      const start = Number(currentRate.textContent);
      const diff = target - start;
      const duration = 420;
      const startTime = performance.now();

      function tick(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        currentRate.textContent = (start + diff * eased).toFixed(2);

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      }

      requestAnimationFrame(tick);
    }

    window.addEventListener('load', () => {
      setTimeout(() => {
        showToast('2026-05-11時点の削除率KPIを表示しました');
      }, 650);
    });
  </script>
