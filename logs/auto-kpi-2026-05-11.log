    }

    .unlock-overlay.hidden {
      opacity: 0;
      visibility: hidden;
    }

    .primary-button,
    .pink-button,
    .white-button {
      min-width: 182px;
      min-height: 43px;
      padding: 10px 18px;
      border-radius: var(--radius-button);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: transform 160ms ease, filter 160ms ease, opacity 160ms ease;
    }

    .primary-button {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 10px 20px rgba(64,153,255,0.2);
