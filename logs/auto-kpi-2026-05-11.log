    .primary-button:active,
    .pink-button:active,
    .white-button:active {
      transform: scale(0.97);
      filter: brightness(0.98);
    }

    .button-row {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .stepper {
      width: min(100%, 340px);
      margin: 0 auto 14px;
      padding: 14px;
      border-radius: var(--radius-lg);
      background: var(--white);
