      --back-white: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-gray2: #e6e6e6;
      --back-blue: #091355;
      --back-dark-blue: #0a1348;
      --back-light-pink: #ffd8e8;
      --back-light-blue: #6fc2ff;
      --error: #EB4646;
      --shadow: rgba(0,0,0,0.11);
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --font-sans: 'Noto Sans JP', 'Hiragino Sans', system-ui, sans-serif;
      --font-number: 'Righteous', 'Noto Sans JP', system-ui, sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-card: 13px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--font-sans);
      color: var(--text-black);
      background:
        radial-gradient(circle at 20% 8%, rgba(248,76,162,0.14), transparent 28%),
        radial-gradient(circle at 82% 18%, rgba(29,220,255,0.16), transparent 30%),
        var(--back-white);
      letter-spacing: 0;
    }

    button,
    input {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    .app-shell {
      width: 100%;
      max-width: 430px;
      min-height: 100vh;
      margin: 0 auto;
      padding: 16px 12px 96px;
      position: relative;
      overflow: hidden;
    }

    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 4px 12px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark-blue);
      font-weight: 800;
      font-size: 18px;
      line-height: 27px;
    }

    .brand-mark {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: var(--gradient-pink);
      color: var(--white);
      display: grid;
      place-items: center;
      font-weight: 900;
      box-shadow: 0 8px 18px rgba(248,76,162,0.24);
    }

    .kpi-pill {
      min-height: 34px;
      padding: 6px 12px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      box-shadow: 0 0 0 1px rgba(28,38,99,0.06), 0 8px 20px rgba(0,0,0,0.08);
    }

    .screen-title {
      padding: 0 4px 12px;
    }

    .screen-title h1 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 26px;
      line-height: 39px;
      font-weight: 900;
    }

    .screen-title p {
      margin: 4px 0 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 19.5px;
    }

    .progress-rail {
      width: 100%;
      height: 9px;
      border-radius: 99px;
      background: rgba(28,38,99,0.1);
      overflow: hidden;
      margin: 4px 4px 16px;
    }

    .progress-fill {
      width: 33.3%;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 360ms ease;
    }

    .mission-panel {
      width: 100%;
      border-radius: var(--radius-lg);
      padding: 14px;
      background: var(--back-blue);
      color: var(--white);
      box-shadow: 0 14px 34px rgba(9,19,85,0.22);
      margin-bottom: 14px;
      position: relative;
      overflow: hidden;
    }

    .mission-panel::after {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      right: -36px;
      top: -48px;
      border-radius: 50%;
      background: rgba(29,220,255,0.16);
    }

    .mission-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: var(--radius-chip);
      background: rgba(255,255,255,0.12);
      color: var(--text-light-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .mission-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-top: 12px;
      position: relative;
      z-index: 1;
    }

    .mission-copy {
      min-width: 0;
    }

    .mission-copy strong {
      display: block;
      font-size: 18px;
      line-height: 27px;
      margin-bottom: 2px;
    }

    .mission-copy span {
      display: block;
      color: rgba(255,255,255,0.72);
      font-size: 12px;
      line-height: 18px;
    }

    .ring {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: conic-gradient(var(--pink) 0deg, var(--pink) 118deg, rgba(255,255,255,0.2) 118deg);
      display: grid;
      place-items: center;
      flex: 0 0 auto;
      transition: background 360ms ease;
    }

    .ring-inner {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      background: var(--back-blue);
      display: grid;
      place-items: center;
      color: var(--white);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
    }

    .stage {
      position: relative;
      min-height: 602px;
    }

    .view {
      display: none;
      animation: viewIn 260ms ease both;
    }

    .view.active {
      display: block;
    }

    @keyframes viewIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .swipe-card {
      width: min(100%, 351px);
      min-height: 128px;
      margin: 0 auto 14px;
      padding: 16px;
      border-radius: var(--radius-card);
      background: var(--white);
      border: 1px solid #CDDCED;
      box-shadow: 0 8px 22px var(--shadow);
      touch-action: pan-y;
      transform: translateX(0) rotate(0deg);
      transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
    }

    .swipe-card.dragging {
      transition: none;
      box-shadow: 0 18px 34px rgba(28,38,99,0.2);
      border-color: var(--button-link);
    }

    .swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      margin: 0 0 12px;
    }

    .swipe-dots {
      display: inline-flex;
      gap: 4px;
    }

    .swipe-dots span {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(28,38,99,0.18);
      animation: dotPulse 1.2s ease infinite;
    }

    .swipe-dots span:nth-child(2) {
      animation-delay: 120ms;
    }

    .swipe-dots span:nth-child(3) {
      animation-delay: 240ms;
    }

    @keyframes dotPulse {
      0%, 100% {
        transform: translateX(0);
        opacity: 0.4;
      }
      50% {
        transform: translateX(4px);
        opacity: 1;
      }
    }

    .car-visual {
      height: 112px;
      border-radius: var(--radius-md);
      background:
        linear-gradient(180deg, rgba(111,194,255,0.22), rgba(255,216,232,0.28)),
