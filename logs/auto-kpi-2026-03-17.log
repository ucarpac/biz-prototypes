  <script>
    const carousel = document.getElementById('carousel');
    const chips = Array.from(document.querySelectorAll('.chip'));
    const dots = Array.from(document.querySelectorAll('.progress-dot'));
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const screenWrap = document.getElementById('screenWrap');
    const surpriseBtn = document.getElementById('surpriseBtn');

    const estimateValue = document.getElementById('estimateValue');
    const costValue = document.getElementById('costValue');
    const zeroCalls = document.getElementById('zeroCalls');

    const stepperA = Array.from(document.querySelectorAll('#stepperA .step'));
    const stepperB = Array.from(document.querySelectorAll('#stepperB .step'));
    const swipeStack = document.getElementById('swipeStack');

    const valuesA = ['¥2,684,000', '¥2,731,000', '¥2,705,000'];
    const valuesB = ['¥31,460', '¥28,980', '¥34,120'];
    let current = 0;
    let stepA = 0;
    let stepB = 0;
    let surpriseMode = false;

    function render(index) {
      current = (index + 3) % 3;
      carousel.style.transform = `translateX(-${current * 33.333333}%)`;

      chips.forEach((chip, i) => {
        const active = i === current;
        chip.classList.toggle('active', active);
        chip.setAttribute('aria-selected', String(active));
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === current);
      });

      if (current === 2) animateZeroCall();
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => render(Number(chip.dataset.index)));
    });

    prevBtn.addEventListener('click', () => render(current - 1));
    nextBtn.addEventListener('click', () => render(current + 1));

    let startX = 0;
    let deltaX = 0;
    let dragging = false;

    screenWrap.addEventListener('pointerdown', (e) => {
      dragging = true;
      startX = e.clientX;
      deltaX = 0;
    });

    screenWrap.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      deltaX = e.clientX - startX;
    });

    function finishSwipe() {
      if (!dragging) return;
      if (deltaX > 60) render(current - 1);
      if (deltaX < -60) render(current + 1);
      dragging = false;
      deltaX = 0;
    }

    screenWrap.addEventListener('pointerup', finishSwipe);
    screenWrap.addEventListener('pointerleave', finishSwipe);
    screenWrap.addEventListener('pointercancel', finishSwipe);

    function cycleStepper(nodes, stepIndex) {
      nodes.forEach((node, idx) => {
        node.classList.toggle('active', idx === stepIndex);
      });
    }

    function cycleA() {
      stepA = (stepA + 1) % 3;
      cycleStepper(stepperA, stepA);
      estimateValue.textContent = valuesA[stepA];

      const cards = Array.from(swipeStack.children);
      const topCard = cards[0];
      topCard.classList.add(stepA % 2 === 0 ? 'dismissed-left' : 'dismissed-right');

      setTimeout(() => {
        topCard.classList.remove('dismissed-left', 'dismissed-right');
        swipeStack.appendChild(topCard);
      }, 280);
    }

    function cycleB() {
      stepB = (stepB + 1) % 3;
      cycleStepper(stepperB, stepB);
      costValue.textContent = valuesB[stepB];
    }

    function animateZeroCall() {
      let n = 3;
      zeroCalls.textContent = '3';
      const tick = setInterval(() => {
        n -= 1;
        zeroCalls.textContent = String(Math.max(n, 0));
        if (n <= 0) clearInterval(tick);
      }, 120);
    }

    document.getElementById('advanceA').addEventListener('click', cycleA);
    document.getElementById('advanceB').addEventListener('click', cycleB);
    document.getElementById('advanceC').addEventListener('click', animateZeroCall);

    surpriseBtn.addEventListener('click', () => {
      surpriseMode = !surpriseMode;
      document.body.style.background = surpriseMode
        ? 'radial-gradient(circle at 10% 10%, rgba(29,220,255,0.42), transparent 24%), radial-gradient(circle at 90% 0%, rgba(248,76,162,0.32), transparent 26%), linear-gradient(180deg, #eff8ff 0%, #fff4fb 52%, #eef2ff 100%)'
        : 'radial-gradient(circle at 20% 15%, rgba(111,194,255,0.35), transparent 25%), radial-gradient(circle at 80% 10%, rgba(248,76,162,0.18), transparent 24%), linear-gradient(180deg, #f4fbff 0%, #fff7fb 56%, #f7f9fc 100%)';
      render((current + 1) % 3);
    });

    setInterval(() => {
      if (current === 0) cycleA();
      if (current === 1) cycleB();
    }, 3400);

    render(0);
    cycleStepper(stepperA, 0);
    cycleStepper(stepperB, 0);

    Array.from(document.querySelectorAll('.meter > span')).forEach((bar, i) => {
      const widths = ['88%', '76%', '81%'];
      requestAnimationFrame(() => {
        bar.style.width = widths[i] || '80%';
      });
    });
  </script>
