    <span class="dot"></span>
    スクショ訴求を切替
  </button>

  <div class="toast" id="toast"></div>

  <script>
    (function () {
      const chips = Array.from(document.querySelectorAll('.chip'));
      const cards = Array.from(document.querySelectorAll('.screen-card'));
      const toast = document.getElementById('toast');
      const actions = Array.from(document.querySelectorAll('[data-toast]'));
      const floatingCta = document.getElementById('floatingCta');
      const order = ['all', 'screen-a', 'screen-b', 'screen-c'];
      let currentIndex = 0;
      let toastTimer = null;

      function showToast(message) {
        toast.textContent = message;
        toast.classList.add('show');
        window.clearTimeout(toastTimer);
        toastTimer = window.setTimeout(() => {
          toast.classList.remove('show');
        }, 1800);
      }

      function applyFilter(target) {
        chips.forEach((chip) => {
          chip.classList.toggle('active', chip.dataset.target === target);
        });

        cards.forEach((card) => {
          if (target === 'all' || card.id === target) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });

        const labelMap = {
          'all': '3案を一覧表示しています',
          'screen-a': 'スクショA: AI査定訴求を表示',
          'screen-b': 'スクショB: 出費管理訴求を表示',
          'screen-c': 'スクショC: 電話0本比較を表示'
        };
        showToast(labelMap[target]);
      }

      chips.forEach((chip) => {
        chip.addEventListener('click', function () {
          currentIndex = order.indexOf(chip.dataset.target);
          applyFilter(chip.dataset.target);
        });
      });

      actions.forEach((button) => {
        button.addEventListener('click', function () {
          showToast(button.getAttribute('data-toast'));
        });
      });

      floatingCta.addEventListener('click', function () {
        currentIndex = (currentIndex + 1) % order.length;
        applyFilter(order[currentIndex]);
      });

      const bars = Array.from(document.querySelectorAll('.progress-bar'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const width = entry.target.style.width;
            entry.target.style.width = '0%';
            requestAnimationFrame(() => {
              entry.target.style.width = width;
            });
          }
        });
      }, { threshold: 0.5 });

      bars.forEach((bar) => observer.observe(bar));
    }());
  </script>
</body>
