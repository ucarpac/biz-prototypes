                      <text x="8" y="83">325</text>
                      <text x="8" y="113">310</text>
                      <text x="8" y="138">295</text>
                      <text x="26" y="152">2月</text>
                      <text x="90" y="152">3月</text>
                      <text x="152" y="152">4月</text>
                      <text x="214" y="152">5月</text>
                      <text x="274" y="152">6月</text>
                    </g>
                    <path d="M30,112 C65,105 90,92 122,86 C150,82 180,70 214,62 C238,55 262,53 290,41 L290,135 L30,135 Z"
                          fill="url(#fillGradientA)"></path>
                    <path class="line-path" d="M30,112 C65,105 90,92 122,86 C150,82 180,70 214,62 C238,55 262,53 290,41"
                          fill="none" stroke="url(#lineGradientA)" stroke-width="4" stroke-linecap="round"></path>
                    <g fill="#F84CA2">
                      <circle cx="30" cy="112" r="4"></circle>
                      <circle cx="122" cy="86" r="4"></circle>
                      <circle cx="214" cy="62" r="4"></circle>
                      <circle cx="290" cy="41" r="5"></circle>
                    </g>
                    <g fill="#1c2663" font-size="10" font-family="Noto Sans JP, sans-serif" font-weight="700">
                      <text x="248" y="28">予測 329万円</text>
                    </g>
                  </svg>

                  <div class="legend">
                    <span class="legend-item"><span class="legend-swatch" style="background:#F84CA2;"></span>AI査定価格</span>
                    <span class="legend-item"><span class="legend-swatch" style="background:#1ddcff;"></span>将来予測トレンド</span>
                  </div>

                  <div class="mini-cards">
                    <div class="mini-card">
                      <strong>入力3分</strong>
                      <span>メーカー・年式・走行距離だけで概算チェック</span>
                    </div>
                    <div class="mini-card">
