      background: linear-gradient(135deg, #F84CA2, #ff8bc2);
      display: grid;
      place-items: center;
      color: #fff;
      font-weight: 900;
      box-shadow: var(--shadow-light);
    }

    .brand h2 {
      margin: 0;
      font-size: 18px;
      color: var(--dark-blue);
      line-height: 1.2;
    }

    .brand p {
      margin: 2px 0 0;
      font-size: 11px;
      color: var(--text-gray);
    }

    .menu-dot {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      background: rgba(255,255,255,0.9);
      display: grid;
      place-items: center;
      box-shadow: var(--shadow-light);
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 900;
    }

    .hero-panel {
      padding: 18px;
      border-radius: 24px;
      color: var(--white);
      background:
        radial-gradient(circle at 10% 10%, rgba(255,255,255,0.20), transparent 26%),
        radial-gradient(circle at 100% 0%, rgba(29,220,255,0.18), transparent 30%),
        linear-gradient(145deg, #0a1348 0%, #1c2663 56%, #273ab1 100%);
      box-shadow: var(--shadow-medium);
      overflow: hidden;
      position: relative;
    }

    .hero-panel .badge-row,
    .insight-strip,
    .mini-cards,
    .compare-table,
    .expense-grid,
    .forecast-panel,
    .action-row,
    .progress-group {
      position: relative;
      z-index: 1;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.14);
      border: 1px solid rgba(255,255,255,0.16);
      font-size: 11px;
      font-weight: 700;
    }

    .hero-panel h3 {
      margin: 0;
      font-size: 30px;
      line-height: 1.25;
      letter-spacing: -0.02em;
    }

    .hero-panel .subline {
      margin-top: 10px;
      font-size: 13px;
      line-height: 1.7;
      color: rgba(255,255,255,0.82);
    }

    .insight-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 18px;
    }

    .insight {
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(6px);
    }

    .insight strong {
      display: block;
      font-family: var(--font-number);
      font-size: 22px;
      line-height: 1.2;
    }

    .insight span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      color: rgba(255,255,255,0.78);
      line-height: 1.5;
    }

    .section-card {
      margin-top: 14px;
      padding: 16px;
      border-radius: 20px;
      background: rgba(255,255,255,0.92);
      box-shadow: var(--shadow-light);
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      margin-bottom: 12px;
    }

    .section-title {
      margin: 0;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .section-note {
      margin: 4px 0 0;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .pill-note {
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(29,220,255,0.10);
      color: var(--button-link1);
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .price-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      margin-bottom: 14px;
    }

    .price-figure {
      font-family: var(--font-number);
      font-size: 36px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .price-caption {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .trend-up {
      color: #0ca678;
      font-weight: 800;
    }

    .trend-down {
      color: #e03131;
      font-weight: 800;
    }

    .svg-card {
      width: 100%;
      display: block;
      border-radius: 18px;
      background: linear-gradient(180deg, #fcfdff, #f2f7fe);
      border: 1px solid rgba(28,38,99,0.05);
    }

    .mini-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .mini-card {
      padding: 12px;
      border-radius: 16px;
      background: var(--gradient-surface);
      border: 1px solid rgba(28,38,99,0.05);
    }

    .mini-card strong {
      display: block;
      font-size: 18px;
      line-height: 1.3;
      color: var(--dark-blue);
    }

    .mini-card span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .progress-group {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .progress-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .progress-label {
      font-size: 12px;
      color: var(--text-black);
      font-weight: 700;
    }

    .progress-value {
      font-size: 12px;
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .progress-track {
      grid-column: 1 / -1;
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #e8eef8;
      overflow: hidden;
    }

    .progress-bar {
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 0.45s ease;
    }

    .action-row {
      display: flex;
      gap: 10px;
      margin-top: 16px;
    }

    .app-button {
      appearance: none;
      border: none;
      min-height: 43px;
      border-radius: var(--radius-button);
      padding: 0 18px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.2s ease, opacity 0.2s ease, filter 0.2s ease;
    }

    .app-button:hover {
      transform: translateY(-1px);
      filter: brightness(1.02);
    }

    .app-button.primary {
      flex: 1;
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .app-button.pink {
      flex: 1;
      background: var(--gradient-pink);
      color: var(--white);
    }

    .app-button.white {
      background: rgba(255,255,255,0.95);
      border: 1px solid rgba(28,38,99,0.12);
      color: var(--dark-blue);
      min-width: 92px;
    }

    .expense-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .expense-box {
      padding: 12px;
      border-radius: 16px;
      background: linear-gradient(180deg, #ffffff, #f5f8fd);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .expense-box .label {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.5;
    }

    .expense-box .value {
      margin-top: 6px;
      font-size: 20px;
      line-height: 1.3;
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .expense-box .meta {
      margin-top: 4px;
      font-size: 10px;
      color: var(--text-gray);
    }

    .forecast-panel {
      margin-top: 12px;
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(248,76,162,0.08), rgba(29,220,255,0.10));
      border: 1px solid rgba(28,38,99,0.05);
    }

    .forecast-title {
      margin: 0 0 10px;
      font-size: 14px;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .forecast-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .forecast-step {
      padding: 10px;
      border-radius: 14px;
      background: rgba(255,255,255,0.86);
      text-align: center;
    }

    .forecast-step .month {
      font-size: 10px;
      color: var(--text-gray);
    }

    .forecast-step .money {
      margin-top: 4px;
      font-family: var(--font-number);
      font-size: 20px;
      color: var(--dark-blue);
    }

    .forecast-step .delta {
      margin-top: 4px;
      font-size: 10px;
      font-weight: 700;
    }

    .compare-table {
      margin-top: 12px;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid rgba(28,38,99,0.06);
      background: #fff;
    }

    .compare-head,
    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr;
      align-items: center;
    }

    .compare-head {
      background: var(--back-blue);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      text-align: center;
    }

    .compare-head div,
    .compare-row div {
      padding: 12px 10px;
      border-bottom: 1px solid var(--ruled-line);
    }

    .compare-row {
      font-size: 11px;
      line-height: 1.5;
      background: #fff;
    }

    .compare-row:nth-child(even) {
      background: #fbfdff;
    }

    .compare-row .feature {
      font-weight: 700;
      color: var(--text-black);
    }

    .compare-row .good {
      color: #0ca678;
      font-weight: 800;
      text-align: center;
    }

    .compare-row .bad {
      color: #e03131;
      font-weight: 800;
      text-align: center;
    }

    .compare-row .mid {
      color: #f08c00;
      font-weight: 800;
      text-align: center;
    }

    .footer-tabs {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      padding: 10px 10px calc(10px + env(safe-area-inset-bottom));
      background: rgba(255,255,255,0.98);
      border-top: 1px solid rgba(28,38,99,0.08);
    }

    .footer-tab {
      display: grid;
      gap: 6px;
      justify-items: center;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    .footer-tab.active {
      color: var(--dark-blue);
    }

    .footer-icon {
      width: 22px;
      height: 22px;
      border-radius: 8px;
      background: rgba(28,38,99,0.08);
      position: relative;
    }

    .footer-tab.active .footer-icon {
      background: rgba(248,76,162,0.18);
    }

    .footer-icon::after {
      content: "";
      position: absolute;
      inset: 5px;
      border-radius: 5px;
      background: currentColor;
      opacity: 0.9;
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 12px;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend-swatch {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .summary-panel {
      margin-top: 24px;
      padding: 18px;
      border-radius: 20px;
      background: rgba(255,255,255,0.94);
      box-shadow: var(--shadow-light);
    }

    .summary-panel h4 {
      margin: 0 0 8px;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .summary-panel p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .cta-floating {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 20;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: none;
      border-radius: 999px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 900;
      padding: 14px 18px;
      box-shadow: var(--shadow-heavy);
      cursor: pointer;
    }

    .cta-floating .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--pink);
      animation: pulse 1.6s infinite;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 82px;
      transform: translateX(-50%) translateY(20px);
      width: min(calc(100% - 32px), 360px);
      padding: 14px 16px;
      border-radius: 16px;
      background: rgba(9,19,85,0.94);
      color: #fff;
      font-size: 13px;
      line-height: 1.6;
      box-shadow: var(--shadow-heavy);
      opacity: 0;
      pointer-events: none;
      transition: 0.3s ease;
      z-index: 25;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .kpi-box {
      padding: 12px;
      border-radius: 16px;
      background: linear-gradient(180deg, #ffffff, #f6f9fd);
      text-align: center;
      border: 1px solid rgba(28,38,99,0.06);
    }

    .kpi-box .big {
      font-family: var(--font-number);
      font-size: 24px;
      color: var(--dark-blue);
      line-height: 1.2;
    }

    .kpi-box .small {
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.8; }
      50% { transform: scale(1.5); opacity: 0.35; }
      100% { transform: scale(1); opacity: 0.8; }
    }

    @keyframes drawLine {
      from {
        stroke-dashoffset: 520;
      }
      to {
        stroke-dashoffset: 0;
      }
    }

    .line-path {
      stroke-dasharray: 520;
      stroke-dashoffset: 520;
      animation: drawLine 1.8s ease forwards;
    }

    @media (min-width: 920px) {
      .top-metrics {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .screens {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .screen-card.hidden {
        display: block;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="hero">
      <div class="eyebrow">ASO検証 / ストアPV→DL率 17.3% → 25%</div>
      <h1>数字で価値が伝わる<br>UcarPAC ストアスクショ試作</h1>
      <p class="lead">
        AI査定、出費管理、競合比較を1画面で理解できるダッシュボード型の構成。
        ストア詳細ページで「価値が見える」「違いが分かる」「今すぐ試せる」を数字とグラフで訴求します。
      </p>

      <div class="top-metrics">
        <div class="metric-card">
          <strong>17.3%</strong>
          <span>現状のストアPV→DL率</span>
        </div>
        <div class="metric-card">
          <strong>25.0%</strong>
          <span>今回の目標CVR</span>
        </div>
        <div class="metric-card">
          <strong>8,000社</strong>
          <span>入札ネットワーク規模</span>
        </div>
        <div class="metric-card">
          <strong>0本</strong>
          <span>相場チェック時の営業電話</span>
        </div>
      </div>
    </section>

    <div class="toolbar" aria-label="スクリーン切り替え">
      <button class="chip active" data-target="all">全て表示</button>
      <button class="chip" data-target="screen-a">スクショA / AI査定</button>
      <button class="chip" data-target="screen-b">スクショB / 出費管理</button>
      <button class="chip" data-target="screen-c">スクショC / 電話0本</button>
    </div>

    <main class="board">
      <section class="screens">
        <article class="screen-card" id="screen-a">
          <div class="screen-head">
            <div>
              <span class="screen-kicker">STORE SCREENSHOT A</span>
              <h2 class="screen-title">AI査定を全面訴求<br>iOS向けストアスクショ</h2>
              <p class="screen-sub">個人情報なしで今の相場と売り時を確認。価格の変化を折れ線グラフで視覚化。</p>
            </div>
            <div class="platform-tag">iOS<br>6.7inch</div>
          </div>

          <div class="phone">
            <div class="phone-screen">
              <div class="statusbar">
                <span>9:41</span>
                <span>5G 100%</span>
              </div>
              <div class="app-shell">
                <div class="navline">
                  <div class="brand">
                    <div class="logo">U</div>
                    <div>
                      <h2>UcarPAC</h2>
                      <p>AI査定ダッシュボード</p>
                    </div>
                  </div>
                  <div class="menu-dot">⋯</div>
                </div>

                <section class="hero-panel">
                  <div class="badge-row">
                    <span class="badge">個人情報不要</span>
                    <span class="badge">AI予測</span>
                    <span class="badge">今売るべき？が分かる</span>
                  </div>
                  <h3>今の査定額も<br>3か月後の予測も。</h3>
                  <p class="subline">
                    2021年式 トヨタ ハリアー Z Leather Package / 走行距離 28,400km の想定データ
                  </p>

                  <div class="insight-strip">
                    <div class="insight">
                      <strong>318万円</strong>
                      <span>現在のAI査定</span>
                    </div>
                    <div class="insight">
                      <strong>+11万円</strong>
                      <span>今月の上振れ</span>
                    </div>
                    <div class="insight">
                      <strong>91%</strong>
                      <span>推定精度レンジ</span>
                    </div>
                  </div>
                </section>

                <section class="section-card">
                  <div class="section-header">
                    <div>
                      <h4 class="section-title">価格推移と売り時予測</h4>
                      <p class="section-note">同条件の流通相場とオークション落札傾向から予測</p>
                    </div>
                    <div class="pill-note">毎週更新</div>
                  </div>

                  <div class="price-row">
                    <div>
                      <div class="price-figure">318<span style="font-size:18px;">万円</span></div>
                      <div class="price-caption">前月比 <span class="trend-up">+3.6%</span></div>
                    </div>
                    <div class="price-caption">売却おすすめ期間<br><span class="trend-up">今月中</span></div>
                  </div>

                  <svg class="svg-card" viewBox="0 0 320 170" aria-label="AI査定推移グラフ">
                    <defs>
                      <linearGradient id="lineGradientA" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#F84CA2"></stop>
                        <stop offset="100%" stop-color="#1ddcff"></stop>
                      </linearGradient>
                      <linearGradient id="fillGradientA" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="rgba(248,76,162,0.25)"></stop>
                        <stop offset="100%" stop-color="rgba(29,220,255,0.03)"></stop>
                      </linearGradient>
                    </defs>
                    <rect x="0" y="0" width="320" height="170" rx="18" fill="transparent"></rect>
                    <g stroke="#d9e4f3" stroke-width="1">
                      <line x1="30" y1="25" x2="30" y2="135"></line>
                      <line x1="30" y1="135" x2="290" y2="135"></line>
                      <line x1="30" y1="45" x2="290" y2="45"></line>
                      <line x1="30" y1="80" x2="290" y2="80"></line>
