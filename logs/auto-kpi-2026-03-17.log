  <script>
    const chips = document.querySelectorAll('.chip');
    const phones = document.querySelectorAll('.phone');
    const pulseButtons = document.querySelectorAll('[data-pulse]');
    const toastButtons = document.querySelectorAll('[data-toast]');

    function setActiveScreen(targetId) {
      chips.forEach(chip => {
        chip.classList.toggle('active', chip.dataset.target === targetId);
      });

      phones.forEach(phone => {
        const isTarget = phone.id === targetId;
        if (window.innerWidth >= 920) {
          phone.classList.remove('hidden');
          phone.classList.toggle('active-view', isTarget);
        } else {
          phone.classList.toggle('hidden', !isTarget);
          phone.classList.toggle('active-view', isTarget);
        }
      });
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => setActiveScreen(chip.dataset.target));
    });

    pulseButtons.forEach(button => {
      button.addEventListener('click', () => {
        const phone = document.getElementById(button.dataset.pulse);
        const heroCard = phone.querySelector('.hero-card');
        const headline = phone.querySelector('.headline');

        heroCard.animate(
          [
            { transform: 'scale(1)', boxShadow: 'var(--shadow-soft)' },
            { transform: 'scale(1.018)', boxShadow: '0 18px 42px rgba(248,76,162,0.28)' },
            { transform: 'scale(1)', boxShadow: 'var(--shadow-soft)' }
          ],
          { duration: 650, easing: 'ease-out' }
        );

        headline.animate(
          [
            { letterSpacing: '-0.03em' },
            { letterSpacing: '-0.01em' },
            { letterSpacing: '-0.03em' }
          ],
          { duration: 650, easing: 'ease-out' }
        );
      });
    });

    const toastVariants = {
      'screen-a': [
        'App Store 想定: 「AIがあなたの愛車を査定」',
        'App Store 想定: 「個人情報なしで、まず相場だけ」',
        'App Store 想定: 「今売るべき？AIが予測」'
      ],
      'screen-b': [
        'Google Play 想定: 「車の出費、見える化しよう」',
        'Google Play 想定: 「維持費も売り時も、これ1つ」',
        'Google Play 想定: 「将来の価格まで、見通せる」'
      ],
      'screen-c': [
        '比較訴求: 「電話0本で、まず相場だけ。」',
        '比較訴求: 「営業電話が不安なら、UcarPAC。」',
        '比較訴求: 「匿名スタート。売る時だけ次へ。」'
      ]
    };

    const toastIndex = {
      'screen-a': 0,
      'screen-b': 0,
      'screen-c': 0
    };

    toastButtons.forEach(button => {
      button.addEventListener('click', () => {
        const key = button.dataset.toast;
        const note = document.getElementById('toast-' + key);
        toastIndex[key] = (toastIndex[key] + 1) % toastVariants[key].length;
        note.textContent = toastVariants[key][toastIndex[key]];
        note.animate(
          [
            { opacity: 0.45, transform: 'translateY(4px)' },
            { opacity: 1, transform: 'translateY(0)' }
          ],
          { duration: 280, easing: 'ease-out' }
        );
      });
    });

    window.addEventListener('resize', () => {
      const activeChip = document.querySelector('.chip.active');
      setActiveScreen(activeChip ? activeChip.dataset.target : 'screen-a');
    });

    setActiveScreen('screen-a');
  </script>
