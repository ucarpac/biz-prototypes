      background: var(--pink);
      box-shadow: 0 0 0 0 rgba(248,76,162,0.5);
      animation: pulse 1.8s infinite;
    }

    .hero h1 {
      margin: 14px 0 8px;
      font-size: 26px;
      line-height: 39px;
      font-weight: 700;
      color: var(--white);
    }

    .hero-copy {
      margin: 0;
      color: #bfdbfe;
      font-size: 14px;
      line-height: 21px;
    }

    .hero-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .primary-button,
    .pink-button,
    .white-button {
      min-height: 43px;
      border-radius: var(--radius-button);
      padding: 0 18px;
      border: 0;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
    }

    .primary-button {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 8px 18px rgba(29,220,255,0.22);
    }

    .pink-button {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 8px 18px rgba(248,76,162,0.24);
    }

    .white-button {
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid var(--text-black);
    }

    .primary-button:active,
    .pink-button:active,
    .white-button:active {
      transform: translateY(1px) scale(0.99);
      opacity: 0.88;
    }

    .section {
      margin-top: 20px;
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .section-title {
      margin: 0;
      font-size: 20px;
      line-height: 30px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .section-subtitle {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .card {
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.08);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-light);
      padding: 16px;
    }

    .metric-card {
      display: grid;
      gap: 8px;
    }

    .metric-label {
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
    }

    .metric-value {
      display: flex;
      align-items: baseline;
      gap: 6px;
      color: var(--dark-blue);
    }

    .metric-number {
      font-family: var(--font-number);
      font-size: 32px;
      line-height: 48px;
      font-weight: 700;
    }

    .metric-unit {
      font-size: 12px;
      font-weight: 700;
    }

    .metric-delta {
      justify-self: start;
      padding: 4px 8px;
      border-radius: var(--radius-chip);
      background: rgba(248,76,162,0.12);
      color: var(--pink);
      font-size: 10px;
      font-weight: 700;
    }

    .progress {
      height: 8px;
      border-radius: 99px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .progress-fill {
      width: var(--value);
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transform-origin: left;
      animation: grow 900ms ease both;
    }

    .variant-list {
      display: grid;
      gap: 10px;
    }

    .variant-button {
      width: 100%;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      border-radius: var(--radius-md);
      padding: 12px;
      text-align: left;
      cursor: pointer;
      transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
    }

    .variant-button.active {
      border-color: var(--button-link);
      background: rgba(64,153,255,0.08);
      transform: translateY(-1px);
    }

    .variant-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 6px;
    }

    .variant-name {
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
    }

    .variant-badge {
      padding: 4px 8px;
      border-radius: var(--radius-chip);
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 10px;
      font-weight: 700;
      white-space: nowrap;
    }

    .variant-copy {
      margin: 0 0 8px;
      font-size: 13px;
      color: var(--text-black);
    }

    .variant-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
    }

    .mini-stat {
      padding: 8px;
      border-radius: var(--radius-sm);
      background: var(--back-gray);
    }

    .mini-stat span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    .mini-stat strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
    }

    .chart-card {
      overflow: hidden;
    }

    .chart-summary {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 12px;
    }

    .summary-box {
      padding: 10px;
      border-radius: var(--radius-sm);
      background: var(--back-gray);
    }

    .summary-box span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    .summary-box strong {
      display: block;
      margin-top: 2px;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
    }

    .svg-wrap {
      width: 100%;
      overflow: hidden;
      border-radius: var(--radius-md);
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      border: 1px solid rgba(28,38,99,0.08);
    }

    svg {
      display: block;
      width: 100%;
      height: auto;
    }

    .chart-line {
      fill: none;
      stroke: var(--pink);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 600;
      stroke-dashoffset: 600;
      animation: draw 1.1s ease forwards;
    }

    .chart-area {
      fill: rgba(248,76,162,0.12);
    }

    .axis-text {
      fill: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    .bar {
      fill: url(#barGradient);
      rx: 6;
      transform-origin: bottom;
      animation: barRise 800ms ease both;
    }

    .settings-layout {
      display: grid;
      gap: 12px;
    }

    .setting-row {
      display: grid;
      gap: 8px;
      padding: 12px 0;
      border-bottom: 1px solid var(--ruled-line);
    }

    .setting-row:last-child {
      border-bottom: 0;
    }

    .setting-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
    }

    .setting-help {
      color: var(--text-gray);
      font-size: 12px;
      margin: 0;
    }

    .toggle {
      width: 50px;
      height: 28px;
      border-radius: 999px;
      padding: 3px;
      border: 0;
      background: var(--button-disabled, #B3B3B3);
      cursor: pointer;
      transition: background 160ms ease;
    }

    .toggle:before {
      content: "";
      display: block;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--white);
      transition: transform 160ms ease;
    }

    .toggle.on {
      background: var(--pink);
    }

    .toggle.on:before {
      transform: translateX(22px);
    }

    .chip-grid {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .chip {
      min-height: 43px;
      border-radius: var(--radius-chip);
      padding: 0 14px;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
    }

    .chip.selected {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
    }

    .range-wrap {
      display: grid;
      gap: 8px;
    }

    .range-labels {
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    input[type="range"] {
      width: 100%;
      accent-color: var(--pink);
    }

    .route-card {
      background: var(--white);
      border-radius: var(--radius-md);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
      padding: 16px;
    }

    .phone-preview {
      width: min(100%, 351px);
      margin: 0 auto;
      border-radius: 28px;
      background: var(--back-dark-blue);
      padding: 14px;
      box-shadow: 0 18px 40px rgba(10,19,72,0.22);
    }

    .phone-screen {
      border-radius: 20px;
      background: var(--back-white);
      overflow: hidden;
      min-height: 460px;
    }

    .phone-status {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px 6px;
      color: var(--dark-blue);
      font-size: 10px;
      font-weight: 700;
    }

    .notification-card {
      margin: 8px 12px 12px;
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .notification-card.active {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(28,38,99,0.2);
    }

    .notification-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 700;
    }

    .notification-body {
      margin: 4px 0 0;
      color: var(--text-black);
      font-size: 12px;
    }

    .flow-panel {
      padding: 12px;
      display: grid;
      gap: 10px;
    }

    .vehicle-card {
      display: grid;
      gap: 10px;
      padding: 14px;
      border: 1px solid #CDDCED;
      border-radius: 13px;
      background: var(--white);
      box-shadow: var(--shadow-light);
    }

    .vehicle-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .vehicle-name {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .vehicle-meta {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 11px;
    }

    .price-large {
      color: var(--pink);
      font-family: var(--font-number);
      font-size: 32px;
      line-height: 48px;
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
    }

    .step-list {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .step-item {
      display: grid;
      grid-template-columns: 30px 1fr auto;
      align-items: center;
      gap: 8px;
      padding: 10px;
      border-radius: var(--radius-md);
      background: var(--back-gray);
      opacity: 0.58;
      transition: opacity 180ms ease, background 180ms ease, transform 180ms ease;
    }

    .step-item.done,
    .step-item.current {
      opacity: 1;
    }

    .step-item.current {
      background: rgba(248,76,162,0.12);
      transform: translateX(2px);
    }

    .step-number {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: var(--white);
      color: var(--dark-blue);
      display: grid;
      place-items: center;
      font-size: 12px;
      font-weight: 700;
    }

    .step-copy strong {
      display: block;
      color: var(--dark-blue);
      font-size: 12px;
    }

    .step-copy span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
    }

    .step-rate {
      color: var(--pink);
      font-size: 12px;
      font-weight: 700;
    }

    .route-actions {
      display: flex;
      gap: 8px;
      margin-top: 12px;
      flex-wrap: wrap;
    }

    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      overflow: hidden;
      border-radius: var(--radius-md);
    }

    .comparison-table th,
    .comparison-table td {
      padding: 10px 8px;
      text-align: left;
      border-bottom: 1px solid var(--ruled-line);
      vertical-align: top;
    }

    .comparison-table th {
      color: var(--dark-blue);
      background: var(--back-gray);
      font-weight: 700;
      white-space: nowrap;
    }

    .comparison-table td {
      color: var(--text-black);
      background: var(--white);
    }

    .check {
      color: var(--pink);
      font-weight: 700;
    }

    .muted {
      color: var(--text-gray);
    }

    .history-list {
      display: grid;
      gap: 10px;
    }

    .history-item {
      display: grid;
      grid-template-columns: 82px 1fr;
      gap: 10px;
      align-items: start;
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .history-date {
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
    }

    .history-text {
      margin: 0;
      color: var(--text-black);
      font-size: 12px;
    }

    .source-grid {
      display: grid;
      gap: 10px;
    }

    .source-card {
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .source-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 12px;
      margin-bottom: 4px;
    }

    .source-card p {
      margin: 0 0 6px;
      color: var(--text-black);
      font-size: 11px;
    }

    .source-card a {
      display: block;
      font-size: 10px;
      word-break: break-all;
    }

    .bottom-nav {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(255,255,255,0.96);
      border-top: 1px solid rgba(28,38,99,0.08);
      backdrop-filter: blur(14px);
      z-index: 20;
    }

    .bottom-nav-inner {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      max-width: 520px;
      margin: 0 auto;
      padding: 8px 12px;
      gap: 8px;
    }

    .nav-button {
      min-height: 42px;
      border-radius: var(--radius-chip);
      border: 0;
      background: transparent;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .nav-button.active {
      background: var(--dark-blue);
      color: var(--white);
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(248,76,162,0.5); }
      70% { box-shadow: 0 0 0 9px rgba(248,76,162,0); }
      100% { box-shadow: 0 0 0 0 rgba(248,76,162,0); }
    }

    @keyframes grow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }

    @keyframes draw {
      to { stroke-dashoffset: 0; }
    }

    @keyframes barRise {
      from { transform: scaleY(0.08); opacity: 0.5; }
      to { transform: scaleY(1); opacity: 1; }
    }

    @media (min-width: 760px) {
      .app-shell {
        padding: 24px 24px 96px;
      }

      .topbar {
        margin: 0 -24px 20px;
        padding: 14px 24px;
      }

      .hero {
        padding: 28px 30px;
      }

      .hero h1 {
        font-size: 32px;
        line-height: 48px;
        max-width: 760px;
      }

      .hero-copy {
        max-width: 760px;
      }

      .dashboard-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
        gap: 16px;
        align-items: start;
      }

      .settings-layout {
        grid-template-columns: 1fr 1fr;
      }

      .source-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="brand-mark">U</div>
        <div class="brand-title">UcarPAC App 通知KPI</div>
      </div>
      <div class="date-pill">2026-05-22 更新</div>
    </div>
  </div>

  <main class="app-shell">
    <section class="hero" id="overview">
      <div class="hero-label"><span class="pulse-dot"></span>日次差分 | プッシュ通知の最適化</div>
      <h1>通知開封率と通知経由申込数を、文言・頻度・導線で同時に上げる</h1>
      <p class="hero-copy">「相場変動」「売り時」「車検前」を通知タイプ別に出し分け、通知タップ後はAI査定結果まで1画面で到達させる検証用プロトタイプです。</p>
      <div class="hero-actions">
        <button class="primary-button" data-scroll="#copy-test">文言テストを見る</button>
        <button class="pink-button" data-scroll="#route">通知導線を試す</button>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <h2 class="section-title">KPIサマリー</h2>
          <p class="section-subtitle">対象KPI: プッシュ通知開封率・通知経由申込数</p>
        </div>
      </div>
      <div class="dashboard-grid">
        <article class="card metric-card">
          <div class="metric-label">通知開封率</div>
          <div class="metric-value"><span class="metric-number" id="openRate">18.2</span><span class="metric-unit">%</span></div>
          <div class="metric-delta">前週比 +4.6pt</div>
          <div class="progress"><div class="progress-fill" style="--value: 72%;"></div></div>
        </article>
        <article class="card metric-card">
          <div class="metric-label">通知経由AI査定</div>
          <div class="metric-value"><span class="metric-number" id="assessmentRate">41</span><span class="metric-unit">件/日</span></div>
          <div class="metric-delta">前週比 +13件</div>
          <div class="progress"><div class="progress-fill" style="--value: 64%;"></div></div>
        </article>
        <article class="card metric-card">
          <div class="metric-label">通知経由申込</div>
          <div class="metric-value"><span class="metric-number" id="applyCount">9</span><span class="metric-unit">件/日</span></div>
          <div class="metric-delta">前週比 +3件</div>
          <div class="progress"><div class="progress-fill" style="--value: 56%;"></div></div>
        </article>
        <article class="card metric-card">
          <div class="metric-label">通知許諾維持率</div>
          <div class="metric-value"><span class="metric-number" id="optRate">78</span><span class="metric-unit">%</span></div>
          <div class="metric-delta">頻度選択UIで維持</div>
          <div class="progress"><div class="progress-fill" style="--value: 78%;"></div></div>
        </article>
      </div>
    </section>

    <section class="section main-grid" id="copy-test">
      <div>
        <div class="section-header">
          <div>
            <h2 class="section-title">1. 通知文言テスト</h2>
            <p class="section-subtitle">相場変動を具体的な金額で伝える案を最優先に検証</p>
          </div>
        </div>
        <div class="variant-list">
          <button class="variant-button active" data-variant="priceUp">
            <div class="variant-top">
              <span class="variant-name">A. 相場UP通知</span>
              <span class="variant-badge">推奨</span>
            </div>
            <p class="variant-copy">愛車の相場が6万円UP。いまのAI査定額を確認しませんか？</p>
            <div class="variant-stats">
              <div class="mini-stat"><span>開封率</span><strong>18.2%</strong></div>
              <div class="mini-stat"><span>査定遷移</span><strong>41件</strong></div>
              <div class="mini-stat"><span>申込</span><strong>9件</strong></div>
            </div>
          </button>
          <button class="variant-button" data-variant="sellTiming">
            <div class="variant-top">
              <span class="variant-name">B. 売り時予報</span>
              <span class="variant-badge">比較</span>
            </div>
            <p class="variant-copy">3ヶ月後は-8万円予測。アルファードの売り時をAIが更新しました。</p>
            <div class="variant-stats">
              <div class="mini-stat"><span>開封率</span><strong>15.7%</strong></div>
              <div class="mini-stat"><span>査定遷移</span><strong>35件</strong></div>
              <div class="mini-stat"><span>申込</span><strong>7件</strong></div>
            </div>
          </button>
          <button class="variant-button" data-variant="inspection">
            <div class="variant-top">
              <span class="variant-name">C. 車検前通知</span>
              <span class="variant-badge">車検30日前</span>
            </div>
            <p class="variant-copy">来月の車検前に売ると維持費12.4万円を抑えられる可能性があります。</p>
            <div class="variant-stats">
              <div class="mini-stat"><span>開封率</span><strong>13.9%</strong></div>
              <div class="mini-stat"><span>査定遷移</span><strong>29件</strong></div>
              <div class="mini-stat"><span>申込</span><strong>6件</strong></div>
            </div>
          </button>
          <button class="variant-button" data-variant="expense">
            <div class="variant-top">
              <span class="variant-name">D. 出費管理通知</span>
