  <script>
    const variantData = {
      priceUp: {
        name: '相場UP通知',
        open: '18.2',
        assessment: '41',
        apply: '9',
        conversion: '3.1%',
        winning: '相場UP通知',
        notificationTitle: '愛車の相場が6万円UP',
        notificationBody: 'アルファードのAI査定額が更新されました。個人情報なしで確認できます。'
      },
      sellTiming: {
        name: '売り時予報',
        open: '15.7',
        assessment: '35',
        apply: '7',
        conversion: '2.6%',
        winning: '売り時予報',
        notificationTitle: '3ヶ月後は-8万円予測',
        notificationBody: 'アルファードの売り時をAIが更新しました。今の価格を確認できます。'
      },
      inspection: {
        name: '車検前通知',
        open: '13.9',
        assessment: '29',
        apply: '6',
        conversion: '2.2%',
        winning: '車検前通知',
        notificationTitle: '車検前に維持費を確認',
        notificationBody: '来月の車検前に売ると維持費12.4万円を抑えられる可能性があります。'
      },
      expense: {
        name: '出費管理通知',
        open: '11.8',
        assessment: '23',
        apply: '4',
        conversion: '1.7%',
        winning: '出費管理通知',
        notificationTitle: '今月の維持費が増加',
        notificationBody: '先月より1.8万円増。相場と合わせて車のコストを確認できます。'
      }
    };

    const frequencyLabels = {
      1: '月1回',
      2: '週2回',
      3: '週3回',
      4: '即時'
    };

    const scrollButtons = document.querySelectorAll('[data-scroll]');
    const variantButtons = document.querySelectorAll('.variant-button');
    const navButtons = document.querySelectorAll('.nav-button');
    const toggles = document.querySelectorAll('[data-toggle]');
    const chips = document.querySelectorAll('[data-chip]');
    const frequencyRange = document.getElementById('frequencyRange');
    const frequencyValue = document.getElementById('frequencyValue');
    const nextStepButton = document.getElementById('nextStepButton');
    const replayButton = document.getElementById('replayButton');
    const resetButton = document.getElementById('resetButton');
    const pushCard = document.getElementById('pushCard');
    const stepItems = document.querySelectorAll('.step-item');

    let currentStep = 0;

    function updateVariant(key) {
      const data = variantData[key];
      document.getElementById('openRate').textContent = data.open;
      document.getElementById('assessmentRate').textContent = data.assessment;
      document.getElementById('applyCount').textContent = data.apply;
      document.getElementById('winningText').textContent = data.winning;
      document.getElementById('conversionText').textContent = data.conversion;
      document.querySelector('.notification-title').textContent = data.notificationTitle;
      document.querySelector('.notification-body').textContent = data.notificationBody;
      pushCard.classList.remove('active');
      window.requestAnimationFrame(() => {
        pushCard.classList.add('active');
      });
    }

    function setRouteStep(index) {
      currentStep = index;
      stepItems.forEach((item, itemIndex) => {
        item.classList.toggle('done', itemIndex < index);
        item.classList.toggle('current', itemIndex === index);
      });
      if (index === 0) {
        nextStepButton.textContent = 'AI査定結果を見る';
      }
      if (index === 1) {
        nextStepButton.textContent = '電話1社で売却相談';
      }
      if (index === 2) {
        nextStepButton.textContent = '申込内容を確認';
      }
    }

    function replayRoute() {
      setRouteStep(0);
      setTimeout(() => setRouteStep(1), 620);
      setTimeout(() => setRouteStep(2), 1240);
    }

    scrollButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const target = document.querySelector(button.dataset.scroll);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        navButtons.forEach((nav) => nav.classList.toggle('active', nav.dataset.scroll === button.dataset.scroll));
      });
    });

    variantButtons.forEach((button) => {
      button.addEventListener('click', () => {
        variantButtons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        updateVariant(button.dataset.variant);
      });
    });

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('on');
      });
    });

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('selected');
      });
    });

    frequencyRange.addEventListener('input', () => {
      frequencyValue.textContent = frequencyLabels[frequencyRange.value];
    });

    nextStepButton.addEventListener('click', () => {
      const next = currentStep >= 2 ? 0 : currentStep + 1;
      setRouteStep(next);
    });

    replayButton.addEventListener('click', replayRoute);

    resetButton.addEventListener('click', () => {
      setRouteStep(0);
    });

    pushCard.addEventListener('click', () => {
      setRouteStep(1);
    });

    setRouteStep(0);
  </script>
</body>
