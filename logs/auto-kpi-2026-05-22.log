      font-weight: 700;
      line-height: 15px;
    }

    .tabs {
      position: sticky;
      top: 0;
      z-index: 10;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-2);
      padding: var(--space-3);
      border-radius: var(--radius-lg);
      background: rgba(255,255,255,0.92);
      box-shadow: 0 10px 24px rgba(28,38,99,0.08);
      backdrop-filter: blur(10px);
    }

    .tab-button {
      min-height: 43px;
      padding: 0 8px;
      border: 0;
      border-radius: var(--radius-button);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      box-shadow: inset 0 0 0 1px #e7ebf6;
      transition: transform 160ms ease, background 160ms ease, color 160ms ease;
    }

    .tab-button.is-active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: none;
      transform: translateY(-1px);
    }

    .panel {
      display: none;
      animation: panelIn 260ms ease both;
    }

    .panel.is-active {
      display: block;
    }

    @keyframes panelIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
      margin-top: var(--space-4);
    }

    .section-card {
      padding: var(--space-4);
      border-radius: var(--radius-lg);
      background: var(--white);
      box-shadow: 0 10px 28px rgba(28, 38, 99, 0.10);
    }

    .section-title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
    }

    .section-kicker {
      color: var(--pink);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .section-title {
      margin: var(--space-1) 0 0;
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
    }

    .section-desc {
      margin: var(--space-2) 0 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 19.5px;
    }

    .tiny-stat {
      flex: 0 0 auto;
      min-width: 78px;
      padding: 8px 10px;
      border-radius: var(--radius-md);
      background: #f4f8ff;
      color: var(--dark-blue);
      text-align: center;
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .tiny-stat strong {
      display: block;
      font-family: var(--font-number);
      font-size: 20px;
      line-height: 30px;
    }

    .phone-preview {
      width: min(100%, 351px);
      margin: 0 auto;
      border: 9px solid #18204e;
      border-radius: 34px;
      background: #f7f9ff;
      box-shadow: 0 18px 44px rgba(28, 38, 99, 0.24);
      overflow: hidden;
    }

    .phone-status {
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 34px;
      padding: 0 18px;
      background: #f7f9ff;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
    }

    .phone-screen {
      min-height: 424px;
      padding: var(--space-4);
      background:
        linear-gradient(180deg, rgba(111,194,255,0.18), rgba(255,255,255,0.55) 45%),
        #f9fbff;
    }

    .lock-date {
      color: var(--dark-blue);
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .lock-time {
      color: var(--dark-blue);
      text-align: center;
      font-family: var(--font-number);
      font-size: 44px;
      font-weight: 700;
      line-height: 66px;
    }

    .notification-card {
      margin-top: var(--space-4);
      padding: var(--space-4);
      border-radius: var(--radius-card);
      background: rgba(255,255,255,0.92);
      box-shadow: 0 10px 22px rgba(28, 38, 99, 0.14);
      transform-origin: center;
      transition: transform 220ms ease, box-shadow 220ms ease;
    }

    .notification-card.is-pulsing {
      animation: notificationPulse 520ms ease;
    }

    @keyframes notificationPulse {
      0% {
        transform: scale(1);
      }
      46% {
        transform: scale(1.025);
        box-shadow: 0 15px 30px rgba(248, 76, 162, 0.25);
      }
      100% {
        transform: scale(1);
      }
    }

    .notification-app {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--space-2);
    }

    .app-mark {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
    }

    .app-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 7px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 11px;
      font-weight: 700;
    }

    .notification-title {
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 700;
      line-height: 22.5px;
    }

    .notification-body {
      margin-top: 4px;
      color: var(--text-black);
      font-size: 13px;
      line-height: 19.5px;
    }

    .notification-meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: var(--space-3);
    }

    .mini-badge {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 4px 9px;
      border-radius: var(--radius-chip);
      background: #eef8ff;
      color: var(--dark-blue);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .mini-badge.pink {
      background: var(--back-light-pink);
      color: var(--dark-blue);
    }

    .primary-button,
    .pink-button,
    .white-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 43px;
      border-radius: var(--radius-button);
      padding: 0 18px;
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
    }

    .primary-button {
      border: 0;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 8px 18px rgba(64, 153, 255, 0.22);
    }

    .pink-button {
      border: 0;
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 8px 18px rgba(248, 76, 162, 0.22);
    }

    .white-button {
      border: 1px solid #dfe5f5;
      background: var(--white);
      color: var(--dark-blue);
    }

    .primary-button:active,
    .pink-button:active,
    .white-button:active,
    .chip:active,
    .copy-card:active {
      transform: scale(0.98);
    }

    .copy-toolbar {
      display: grid;
      grid-template-columns: 43px 1fr 43px;
      gap: var(--space-3);
      align-items: center;
      margin-top: var(--space-4);
    }

    .circle-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 43px;
      height: 43px;
      border: 0;
      border-radius: 50%;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
      transition: transform 160ms ease, background 160ms ease;
    }

    .copy-index {
      color: var(--text-gray);
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .copy-card {
      touch-action: pan-y;
      padding: var(--space-4);
      border: 2px solid #e7ebf6;
      border-radius: var(--radius-card);
      background: var(--white);
      transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
      user-select: none;
    }

    .copy-card.is-selected {
      border-color: var(--pink);
      box-shadow: 0 10px 24px rgba(248, 76, 162, 0.16);
    }

    .copy-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
    }

    .copy-card-title {
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .copy-card-score {
      min-width: 64px;
      padding: 5px 9px;
      border-radius: var(--radius-chip);
      background: var(--gradient-active);
      color: var(--white);
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
    }

    .copy-text {
      margin-top: var(--space-3);
      color: var(--text-black);
      font-size: 14px;
      line-height: 21px;
    }

    .metric-bars {
      display: grid;
      gap: var(--space-3);
      margin-top: var(--space-4);
    }

    .bar-row {
      display: grid;
      grid-template-columns: 74px 1fr 44px;
      gap: var(--space-2);
      align-items: center;
    }

    .bar-label,
    .bar-value {
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
    }

    .bar-value {
      color: var(--dark-blue);
      text-align: right;
    }

    .bar-track {
      height: 8px;
      border-radius: 99px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 99px;
      background: var(--gradient-primary);
      transition: width 320ms ease;
    }

    .bar-fill.pink {
      background: var(--gradient-pink);
    }

    .variant-list {
      display: grid;
      gap: var(--space-3);
    }

    .variant-button {
      width: 100%;
      padding: var(--space-3);
      border: 1px solid #e7ebf6;
      border-radius: var(--radius-md);
      background: #fbfcff;
      color: var(--text-black);
      text-align: left;
      transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
    }

    .variant-button.is-active {
      border-color: var(--pink);
      background: #fff4f9;
    }

    .variant-name {
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 700;
      line-height: 19.5px;
    }

    .variant-sub {
      margin-top: 3px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .settings-list {
      display: grid;
      gap: var(--space-3);
    }

    .setting-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      padding: var(--space-4);
      border: 1px solid #e7ebf6;
      border-radius: var(--radius-card);
      background: #fbfcff;
    }

    .setting-title {
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .setting-desc {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .toggle {
      position: relative;
      flex: 0 0 auto;
      width: 54px;
      height: 32px;
      border: 0;
      border-radius: 999px;
      background: #d8deef;
      transition: background 180ms ease;
    }

    .toggle::after {
      content: "";
      position: absolute;
      top: 4px;
      left: 4px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: var(--white);
      box-shadow: 0 2px 8px rgba(0,0,0,0.16);
      transition: transform 180ms ease;
    }

    .toggle.is-on {
      background: var(--pink);
    }

    .toggle.is-on::after {
      transform: translateX(22px);
    }

    .chip-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }

    .chip {
      min-height: 43px;
      padding: 0 12px;
      border: 1px solid #e7ebf6;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      transition: transform 160ms ease, background 160ms ease, color 160ms ease, border-color 160ms ease;
    }

    .chip.is-active {
      border-color: var(--dark-blue);
      background: var(--dark-blue);
      color: var(--white);
    }

    .slider-card {
      padding: var(--space-4);
      border: 1px solid #e7ebf6;
      border-radius: var(--radius-card);
      background: #fbfcff;
    }

    .range-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--space-3);
      align-items: center;
      margin-top: var(--space-3);
    }

    .range-row input {
      width: 100%;
      accent-color: var(--pink);
    }

    .range-value {
      min-width: 72px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      text-align: right;
    }

    .preview-stack {
      display: grid;
      gap: var(--space-3);
      margin-top: var(--space-4);
    }

    .preference-result {
      padding: var(--space-4);
      border-radius: var(--radius-card);
      background: var(--back-blue);
      color: var(--white);
    }

    .preference-result-title {
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .preference-result-copy {
      margin-top: var(--space-2);
      color: var(--text-light-blue, #bfdbfe);
      font-size: 12px;
      line-height: 18px;
    }

    .flow-stepper {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-2);
      margin-bottom: var(--space-4);
    }

    .flow-node {
      position: relative;
      padding: var(--space-3) 8px;
      border-radius: var(--radius-md);
      background: #eef2fb;
      color: var(--text-gray);
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
      transition: background 200ms ease, color 200ms ease, transform 200ms ease;
    }

    .flow-node.is-active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .flow-node.is-done {
      background: var(--back-light-pink);
      color: var(--dark-blue);
    }

    .assessment-card {
      display: none;
      margin-top: var(--space-4);
      padding: var(--space-4);
      border-radius: var(--radius-card);
      background: var(--white);
      box-shadow: 0 8px 20px rgba(28,38,99,0.08);
      animation: panelIn 260ms ease both;
    }

    .assessment-card.is-visible {
      display: block;
    }

    .car-summary {
      display: grid;
      grid-template-columns: 76px 1fr;
      gap: var(--space-3);
      align-items: center;
    }

    .car-visual {
      position: relative;
      width: 76px;
      height: 52px;
      border-radius: var(--radius-md);
      background: linear-gradient(135deg, #d9e8ff, #ffffff);
      overflow: hidden;
    }

    .car-visual::before {
      content: "";
      position: absolute;
      left: 10px;
      top: 19px;
      width: 56px;
      height: 18px;
      border-radius: 16px 18px 8px 8px;
      background: var(--dark-blue);
    }

    .car-visual::after {
      content: "";
      position: absolute;
      left: 20px;
      top: 13px;
      width: 32px;
      height: 14px;
      border-radius: 14px 14px 2px 2px;
      background: var(--button-link2);
      box-shadow: -7px 23px 0 -4px #ffffff, 24px 23px 0 -4px #ffffff;
    }

    .car-name {
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 700;
      line-height: 22.5px;
    }

    .car-meta {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .price-panel {
      margin-top: var(--space-4);
      padding: var(--space-4);
      border-radius: var(--radius-card);
      background: #f4f8ff;
    }

    .price-label {
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .price-main {
      margin-top: 2px;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 40px;
      font-weight: 700;
      line-height: 54px;
    }

    .price-main span {
      font-size: 16px;
      line-height: 24px;
    }

    .forecast-chart {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      align-items: end;
      gap: var(--space-2);
      height: 116px;
      margin-top: var(--space-4);
      padding: var(--space-3);
      border-radius: var(--radius-md);
      background: var(--white);
    }

    .forecast-bar {
      display: grid;
      align-items: end;
      gap: 5px;
      height: 92px;
      color: var(--text-gray);
      text-align: center;
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .forecast-bar span {
      display: block;
      width: 100%;
      min-height: 18px;
      border-radius: 10px 10px 4px 4px;
      background: var(--gradient-primary);
      animation: growBar 650ms ease both;
    }

    .forecast-bar:nth-child(2) span {
      background: var(--gradient-pink);
      animation-delay: 80ms;
    }

    .forecast-bar:nth-child(3) span {
      animation-delay: 160ms;
    }

    .forecast-bar:nth-child(4) span {
      background: var(--gradient-active);
      animation-delay: 240ms;
    }

    @keyframes growBar {
      from {
        transform: scaleY(0.2);
        opacity: 0.4;
      }
      to {
        transform: scaleY(1);
        opacity: 1;
      }
    }

    .action-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-3);
      margin-top: var(--space-4);
    }

    .complete-card {
      display: none;
      margin-top: var(--space-4);
      padding: var(--space-4);
      border-radius: var(--radius-card);
      background: var(--back-light-pink);
      color: var(--dark-blue);
      animation: completePop 400ms ease both;
    }

    .complete-card.is-visible {
      display: block;
    }

    @keyframes completePop {
      0% {
        opacity: 0;
        transform: scale(0.96);
      }
      70% {
        transform: scale(1.02);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    .complete-title {
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .complete-copy {
      margin-top: var(--space-2);
      font-size: 12px;
      line-height: 18px;
    }

    .source-list {
      display: grid;
      gap: var(--space-3);
    }

    .source-card {
      padding: var(--space-3);
      border: 1px solid #e7ebf6;
      border-radius: var(--radius-md);
      background: #fbfcff;
    }

    .source-title {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .source-text {
      margin-top: 3px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      word-break: break-all;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      z-index: 100;
      display: none;
      width: min(92%, 340px);
      padding: var(--space-3) var(--space-4);
      border-radius: var(--radius-button);
      background: var(--dark-blue);
      color: var(--white);
      text-align: center;
      font-size: 13px;
      font-weight: 700;
      line-height: 19.5px;
      box-shadow: 0 12px 30px rgba(28,38,99,0.28);
      transform: translateX(-50%);
    }

    .toast.is-visible {
      display: block;
      animation: toastIn 220ms ease both;
    }

    @keyframes toastIn {
      from {
        opacity: 0;
        transform: translate(-50%, 10px);
      }
      to {
        opacity: 1;
        transform: translate(-50%, 0);
      }
    }

    .confetti-layer {
      pointer-events: none;
      position: fixed;
      inset: 0;
      z-index: 90;
      overflow: hidden;
    }

    .confetti {
      position: absolute;
      top: -12px;
      width: 8px;
      height: 14px;
      border-radius: 3px;
      background: var(--pink);
      animation: confettiFall 1100ms ease-in forwards;
    }

    .confetti.blue {
      background: var(--button-link2);
    }

    .confetti.dark {
      background: var(--dark-blue);
    }

    @keyframes confettiFall {
      to {
        transform: translateY(110vh) rotate(540deg);
        opacity: 0;
      }
    }

    @media (min-width: 840px) {
      .page {
        padding: var(--space-6);
      }

      .app-shell {
        grid-template-columns: 370px 1fr;
        align-items: start;
      }

      .hero-board {
        position: sticky;
        top: var(--space-6);
      }

      .workspace {
        min-width: 0;
      }

      .content-grid {
        grid-template-columns: minmax(320px, 0.9fr) minmax(340px, 1.1fr);
      }

      .section-card.wide {
        grid-column: 1 / -1;
      }

      .action-row {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 1ms !important;
        transition-duration: 1ms !important;
      }
    }
  </style>
</head>
<body>
  <div class="confetti-layer" id="confettiLayer" aria-hidden="true"></div>
  <div class="page">
    <div class="app-shell">
      <aside class="hero-board">
        <div class="hero-top">
