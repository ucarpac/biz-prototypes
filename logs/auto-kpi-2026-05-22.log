    </main>

    <aside class="desktop-note">
      <h2>検証の狙い</h2>
      <p>
        A案は「不安解消」を中心に、相場変化をうれしい知らせとして届ける体験に寄せています。通知頻度をユーザーが選べるため、通知OFFを避けながら再起動の理由を作ります。
      </p>
      <div class="memo">
        重要仮説: 「価格が上がった」「電話なしで確認できる」の2文言が、通知開封率とAI査定復帰率を同時に押し上げる。
      </div>
    </aside>
  </div>

  <script>
    const tabs = document.querySelectorAll('.tab-button');
    const panels = document.querySelectorAll('.panel');
    const variantButtons = document.querySelectorAll('.variant-button');
    const pushTitle = document.getElementById('pushTitle');
    const pushBody = document.getElementById('pushBody');
    const pushCard = document.getElementById('pushCard');
    const openRate = document.getElementById('openRate');
    const applyCount = document.getElementById('applyCount');
    const openDelta = document.getElementById('openDelta');
    const applyDelta = document.getElementById('applyDelta');
    const switches = document.querySelectorAll('.switch');
    const frequencyButtons = document.querySelectorAll('#frequencySegment button');
    const settingsSummary = document.getElementById('settingsSummary');
    const quietStart = document.getElementById('quietStart');
    const quietEnd = document.getElementById('quietEnd');
    const flowStart = document.getElementById('flowStart');
    const tapNotification = document.getElementById('tapNotification');
    const flowNext = document.querySelectorAll('.flow-next');
    const flowPrev = document.querySelectorAll('.flow-prev');
    const flowReset = document.querySelectorAll('.flow-reset');
    const chips = document.querySelectorAll('.chip');
    let flowStep = 0;

    function activateTab(tabName) {
      tabs.forEach((tab) => {
        tab.classList.toggle('active', tab.dataset.tab === tabName);
      });

      panels.forEach((panel) => {
        panel.classList.toggle('active', panel.id === `panel-${tabName}`);
      });
    }

    function updatePush(button) {
      variantButtons.forEach((item) => item.classList.remove('active'));
      button.classList.add('active');

      pushTitle.textContent = button.dataset.title;
      pushBody.textContent = button.dataset.body;
      openRate.innerHTML = `${button.dataset.rate}<small>%</small>`;
      applyCount.innerHTML = `${button.dataset.count}<small>件</small>`;
      openDelta.textContent = button.dataset.delta;
      applyDelta.textContent = button.dataset.apply;

      pushCard.classList.remove('pulse');
      window.setTimeout(() => {
        pushCard.classList.add('pulse');
      }, 20);
    }

    function updateSettingsSummary() {
      const activeSettings = Array.from(switches)
        .filter((item) => item.classList.contains('on'))
        .map((item) => item.dataset.setting);

      const frequency = document.querySelector('#frequencySegment button.active').dataset.frequency;
      const activeText = activeSettings.length ? activeSettings.join('、') : '通知なし';

      settingsSummary.innerHTML = `<strong>現在:</strong> ${activeText}を${frequency}。${quietStart.value}-${quietEnd.value}は通知しません。`;
    }

    function setFlowStep(nextStep) {
      flowStep = Math.max(0, Math.min(3, nextStep));

      document.querySelectorAll('.screen-step').forEach((step) => {
        step.classList.toggle('active', Number(step.dataset.step) === flowStep);
      });

      for (let i = 0; i <= 3; i += 1) {
        const bar = document.getElementById(`bar${i}`);
        if (bar) {
          bar.classList.toggle('done', i <= flowStep);
        }
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateTab(tab.dataset.tab));
    });

    variantButtons.forEach((button) => {
      button.addEventListener('click', () => updatePush(button));
    });

    switches.forEach((switchButton) => {
      switchButton.addEventListener('click', () => {
        switchButton.classList.toggle('on');
        updateSettingsSummary();
      });
    });

    frequencyButtons.forEach((button) => {
      button.addEventListener('click', () => {
        frequencyButtons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        updateSettingsSummary();
      });
    });

    quietStart.addEventListener('change', updateSettingsSummary);
    quietEnd.addEventListener('change', updateSettingsSummary);

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((item) => item.classList.remove('active'));
        chip.classList.add('active');
      });
    });

    flowStart.addEventListener('click', () => setFlowStep(1));
    tapNotification.addEventListener('click', () => setFlowStep(1));

    flowNext.forEach((button) => {
      button.addEventListener('click', () => setFlowStep(flowStep + 1));
    });

    flowPrev.forEach((button) => {
      button.addEventListener('click', () => setFlowStep(flowStep - 1));
    });

    flowReset.forEach((button) => {
      button.addEventListener('click', () => setFlowStep(0));
    });

    updateSettingsSummary();
  </script>
