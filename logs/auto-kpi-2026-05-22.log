  <script>
    const variants = [
      {
        name: '相場UP通知',
        title: 'ハリアーの相場が上昇中',
        body: '愛車の相場が12万円UP。今週の売り時スコアは92です。',
        open: 8.4,
        apply: 62,
        fatigue: 79,
        score: 92,
        tag: '金額変化'
      },
      {
        name: '将来予測通知',
        title: '3ヶ月後は18万円下落予測',
        body: '今のAI査定価格は264万円。売る時期を30秒で確認できます。',
        open: 7.9,
        apply: 68,
        fatigue: 72,
        score: 89,
        tag: '将来予測'
      },
      {
        name: '個人情報不要通知',
        title: '電話なしで相場だけ更新',
        body: '個人情報不要。N-BOXの最新相場は143万円から158万円です。',
        open: 7.2,
        apply: 48,
        fatigue: 88,
        score: 84,
        tag: '安心'
      },
      {
        name: '出費連動通知',
        title: '車検前の売り時を診断',
        body: '次回車検まで62日。維持費18.6万円を含めて売却タイミングを比較できます。',
        open: 6.8,
        apply: 54,
        fatigue: 82,
        score: 81,
        tag: '出費管理'
      },
      {
        name: 'オークション通知',
        title: '8,000店の入札見込みを更新',
        body: '同型ハリアーの最高額は271万円。電話1社のみで売却相談できます。',
        open: 7.6,
        apply: 73,
        fatigue: 70,
        score: 87,
        tag: '申込促進'
      }
    ];

    let activeVariant = 0;
    let xp = 20;
    let selectedFrequency = '週1回';
    let quietStart = 22;
    let flowStep = 1;
    const toggles = {
      market: true,
      timing: true,
      expense: false,
      auction: true
    };

    const panelButtons = document.querySelectorAll('.tab-button');
    const panels = document.querySelectorAll('.panel');
    const variantList = document.getElementById('variantList');
    const copyCard = document.getElementById('copyCard');
    const notificationPreview = document.getElementById('notificationPreview');
    const toast = document.getElementById('toast');

    function setTab(tab) {
      panelButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.tab === tab);
      });

      panels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.id === `panel-${tab}`);
      });
    }

    panelButtons.forEach((button) => {
      button.addEventListener('click', () => setTab(button.dataset.tab));
    });

    function renderVariantList() {
      variantList.innerHTML = '';
      variants.forEach((variant, index) => {
        const button = document.createElement('button');
        button.className = `variant-button${index === activeVariant ? ' is-active' : ''}`;
        button.type = 'button';
        button.innerHTML = `
          <div class="variant-name">${variant.name} <span class="mini-badge">${variant.tag}</span></div>
          <div class="variant-sub">開封予測 ${variant.open.toFixed(1)}% / 申込寄与 ${variant.apply} / 疲労低さ ${variant.fatigue}</div>
        `;
        button.addEventListener('click', () => {
          activeVariant = index;
          updateVariant();
        });
        variantList.appendChild(button);
      });
    }

    function updateVariant() {
      const variant = variants[activeVariant];

      document.getElementById('copyCardName').textContent = variant.name;
      document.getElementById('copyCardScore').textContent = `${variant.score}点`;
      document.getElementById('copyCardText').textContent = variant.body;
      document.getElementById('copyIndex').textContent = `${activeVariant + 1} / ${variants.length}`;
      document.getElementById('bestScore').textContent = Math.max(...variants.map((item) => item.score));
      document.getElementById('previewTitle').textContent = variant.title;
      document.getElementById('previewBody').textContent = variant.body;
      document.getElementById('openValue').textContent = `${variant.open.toFixed(1)}%`;
      document.getElementById('applyValue').textContent = variant.apply;
      document.getElementById('fatigueValue').textContent = variant.fatigue;
      document.getElementById('openBar').style.width = `${Math.min(100, variant.open * 10)}%`;
      document.getElementById('applyBar').style.width = `${Math.min(100, variant.apply)}%`;
      document.getElementById('fatigueBar').style.width = `${Math.min(100, variant.fatigue)}%`;
      document.getElementById('openRateKpi').textContent = `${variant.open.toFixed(1)}%`;

      copyCard.classList.remove('is-selected');
      notificationPreview.classList.remove('is-pulsing');
      window.requestAnimationFrame(() => {
        copyCard.classList.add('is-selected');
        notificationPreview.classList.add('is-pulsing');
      });

      renderVariantList();
    }

    document.getElementById('prevCopy').addEventListener('click', () => {
      activeVariant = (activeVariant + variants.length - 1) % variants.length;
      updateVariant();
    });

    document.getElementById('nextCopy').addEventListener('click', () => {
      activeVariant = (activeVariant + 1) % variants.length;
      updateVariant();
    });

    document.getElementById('randomCopy').addEventListener('click', () => {
      activeVariant = Math.floor(Math.random() * variants.length);
      updateVariant();
      showToast('候補を切り替えました');
    });

    document.getElementById('adoptCopy').addEventListener('click', () => {
      xp += 30;
      document.getElementById('xpValue').textContent = xp;
      markMission(1);
      showToast(`${variants[activeVariant].name}をA/Bテスト案に採用しました`);
      burstConfetti(18);
    });

    let startX = 0;
    let currentX = 0;
    let isDragging = false;

    copyCard.addEventListener('pointerdown', (event) => {
      startX = event.clientX;
      currentX = startX;
      isDragging = true;
      copyCard.setPointerCapture(event.pointerId);
    });

    copyCard.addEventListener('pointermove', (event) => {
      if (!isDragging) {
        return;
      }

      currentX = event.clientX;
      const diff = currentX - startX;
      copyCard.style.transform = `translateX(${diff * 0.18}px) rotate(${diff * 0.015}deg)`;
    });

    copyCard.addEventListener('pointerup', () => {
      if (!isDragging) {
        return;
      }

      const diff = currentX - startX;
      copyCard.style.transform = '';

      if (Math.abs(diff) > 70) {
        activeVariant = diff < 0
          ? (activeVariant + 1) % variants.length
          : (activeVariant + variants.length - 1) % variants.length;
        updateVariant();
      }

      isDragging = false;
    });

    function markMission(step) {
      document.querySelectorAll('.mission-step').forEach((node) => {
        const mission = Number(node.dataset.mission);
        node.classList.toggle('is-done', mission <= step);
        node.classList.toggle('is-current', mission === step + 1);
      });
    }

    function updatePreferenceSummary() {
      const activeLabels = [];
      if (toggles.market) activeLabels.push('相場変動');
      if (toggles.timing) activeLabels.push('売り時スコア');
      if (toggles.expense) activeLabels.push('出費リマインド');
      if (toggles.auction) activeLabels.push('オークション進捗');

      const label = activeLabels.length ? activeLabels.join('、') : '重要なお知らせのみ';
      const optin = Math.min(88, 58 + activeLabels.length * 4 + (selectedFrequency === '重要のみ' ? 10 : 0) + (quietStart <= 21 ? 2 : 0));

      document.getElementById('preferenceSummary').textContent = `${label}を${selectedFrequency}。${quietStart}時以降は停止。`;
      document.getElementById('settingOptin').textContent = optin;
      document.getElementById('optinKpi').textContent = `${optin}%`;
      document.getElementById('optinValue').textContent = `${optin}%`;
      document.getElementById('optinBar').style.width = `${optin}%`;
    }

    document.querySelectorAll('.toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const key = button.dataset.toggle;
        toggles[key] = !toggles[key];
        button.classList.toggle('is-on', toggles[key]);
        updatePreferenceSummary();
      });
    });

    document.querySelectorAll('#frequencyChips .chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('#frequencyChips .chip').forEach((item) => item.classList.remove('is-active'));
        chip.classList.add('is-active');
        selectedFrequency = chip.dataset.frequency;
        updatePreferenceSummary();
      });
    });

    document.getElementById('quietStart').addEventListener('input', (event) => {
      quietStart = Number(event.target.value);
      document.getElementById('quietValue').textContent = `${quietStart}時以降`;
      updatePreferenceSummary();
    });

    document.getElementById('saveSettings').addEventListener('click', () => {
      xp += 25;
      document.getElementById('xpValue').textContent = xp;
      markMission(2);
      showToast('通知設定を保存しました');
      burstConfetti(14);
    });

    function updateFlowStep(step) {
      flowStep = step;
      document.querySelectorAll('.flow-node').forEach((node) => {
        const nodeStep = Number(node.dataset.flowNode);
        node.classList.toggle('is-active', nodeStep === step);
        node.classList.toggle('is-done', nodeStep < step);
      });
    }

    document.getElementById('tapNotification').addEventListener('click', () => {
      document.getElementById('assessmentCard').classList.add('is-visible');
      document.getElementById('flowNotification').classList.add('is-pulsing');
      updateFlowStep(2);
      xp += 20;
      document.getElementById('xpValue').textContent = xp;
      showToast('AI査定結果へ遷移しました');
    });

    document.getElementById('startAssessment').addEventListener('click', () => {
      showToast('AI査定価格を更新しました');
      document.querySelector('.price-main').innerHTML = '267<span>万円</span>';
      burstConfetti(10);
    });

    document.getElementById('applySell').addEventListener('click', () => {
      document.getElementById('completeCard').classList.add('is-visible');
      updateFlowStep(3);
      markMission(3);
      xp += 40;
      document.getElementById('xpValue').textContent = xp;
      document.getElementById('applyKpi').textContent = '43';
      showToast('通知経由申込を記録しました');
      burstConfetti(26);
    });

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('is-visible');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('is-visible');
      }, 1800);
    }

    function burstConfetti(count) {
      const layer = document.getElementById('confettiLayer');
      for (let index = 0; index < count; index += 1) {
        const piece = document.createElement('span');
        const colorClass = index % 3 === 0 ? 'blue' : index % 3 === 1 ? 'dark' : '';
        piece.className = `confetti ${colorClass}`;
        piece.style.left = `${Math.random() * 100}%`;
        piece.style.animationDelay = `${Math.random() * 160}ms`;
        piece.style.transform = `rotate(${Math.random() * 180}deg)`;
        layer.appendChild(piece);
        window.setTimeout(() => piece.remove(), 1300);
      }
    }

    renderVariantList();
    updateVariant();
    updatePreferenceSummary();
  </script>
</body>
</html>
