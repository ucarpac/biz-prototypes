      box-shadow: 0 8px 18px rgba(28,38,99,0.18);
    }

    .content {
      padding: 0 16px 24px;
    }

    .panel {
      display: none;
      animation: panelIn 260ms ease both;
    }

    .panel.active {
      display: block;
    }

    .section {
      margin-bottom: 24px;
    }

    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .section-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
      letter-spacing: 0;
    }

    .section-note {
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
      white-space: nowrap;
    }

    .card {
      border-radius: var(--radius-card);
      background: var(--white);
      border: 1px solid rgba(205,220,237,0.72);
      box-shadow: 0 0 18px rgba(0,0,0,0.08);
    }

    .warm-card {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,247,239,0.98));
      border-color: rgba(255,210,173,0.9);
    }

    .kpi-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }

    .kpi-card {
      padding: 14px 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid var(--ruled-line);
      box-shadow: 0 4px 16px rgba(28,38,99,0.07);
    }

    .kpi-label {
      margin: 0 0 4px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .kpi-value {
      margin: 0;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 32px;
      font-weight: 700;
      line-height: 48px;
    }

    .kpi-value small {
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .kpi-delta {
      margin: 2px 0 0;
      color: var(--pink);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .notification-preview {
      padding: 16px;
      margin-bottom: 16px;
      border-radius: 18px;
      background: #f2f4f8;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.06);
    }

    .lockscreen-time {
      margin: 0 0 12px;
      text-align: center;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 30px;
      font-weight: 700;
      line-height: 45px;
    }

    .push-card {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.94);
      box-shadow: 0 8px 24px rgba(28,38,99,0.12);
      border: 1px solid rgba(255,255,255,0.9);
      transition: transform 220ms ease, box-shadow 220ms ease;
    }

    .push-card.pulse {
      animation: pushPulse 560ms ease;
    }

    .push-top {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .push-icon {
      width: 28px;
      height: 28px;
      border-radius: 10px;
      background: var(--gradient-pink);
      position: relative;
      flex: 0 0 auto;
    }

    .push-icon::before {
      content: "";
      position: absolute;
      left: 7px;
      top: 9px;
      width: 14px;
      height: 8px;
      border-radius: 8px 8px 4px 4px;
      background: var(--white);
    }

    .push-app {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .push-now {
      margin-left: auto;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .push-title {
      margin: 0 0 3px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .push-body {
      margin: 0;
      color: var(--text-black);
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
    }

    .variant-list {
      display: grid;
      gap: 10px;
    }

    .variant-button {
      width: 100%;
      min-height: 76px;
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid #e8edf2;
      text-align: left;
      transition: border 180ms ease, box-shadow 180ms ease, transform 180ms ease, background 180ms ease;
    }

    .variant-button.active {
      border-color: var(--pink);
      background: #fff7fb;
      box-shadow: 0 7px 18px rgba(248,76,162,0.12);
    }

    .variant-button:active,
    .tab-button:active,
    .app-button:active,
    .chip:active,
    .flow-card:active {
      transform: scale(0.98);
    }

    .variant-meta {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 5px;
    }

    .variant-name {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .variant-score {
      padding: 2px 8px;
      border-radius: 999px;
      background: var(--soft-green);
      color: #0c7a41;
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
      white-space: nowrap;
    }

    .variant-text {
      margin: 0;
      color: var(--text-black);
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
    }

    .why-card {
      padding: 15px 16px;
      margin-top: 14px;
      border-radius: var(--radius-card);
      background: var(--soft-yellow);
      border: 1px dashed #e7c666;
      color: var(--warm-ink);
      position: relative;
      transform: rotate(-0.4deg);
    }

    .why-card strong {
      display: block;
      margin-bottom: 4px;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
    }

    .why-card p {
      margin: 0;
      font-size: 12px;
      line-height: 18px;
    }

    .setting-card {
      padding: 16px;
      margin-bottom: 12px;
    }

    .setting-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      padding: 13px 0;
      border-bottom: 1px solid var(--ruled-line);
    }

    .setting-row:first-child {
      padding-top: 0;
    }

    .setting-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .setting-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .setting-desc {
      margin: 3px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 400;
      line-height: 16.5px;
    }

    .switch {
      width: 48px;
      height: 28px;
      border-radius: 18px;
      background: #d7dbe7;
      padding: 3px;
      flex: 0 0 auto;
      transition: background 180ms ease;
    }

    .switch span {
      display: block;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--white);
      box-shadow: 0 2px 5px rgba(0,0,0,0.18);
      transition: transform 180ms ease;
    }

    .switch.on {
      background: var(--pink);
    }

    .switch.on span {
      transform: translateX(20px);
    }

    .frequency {
      padding: 16px;
      margin-bottom: 12px;
    }

    .segment {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
      padding: 5px;
      border-radius: 22px;
      background: var(--back-gray);
      margin-top: 12px;
    }

    .segment button {
      min-height: 36px;
      border-radius: 18px;
      background: transparent;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      transition: background 180ms ease, color 180ms ease, box-shadow 180ms ease;
    }

    .segment button.active {
      background: var(--white);
      color: var(--dark-blue);
      box-shadow: 0 4px 12px rgba(28,38,99,0.12);
    }

    .quiet-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 12px;
    }

    .time-box {
      padding: 12px;
      border-radius: var(--radius-md);
      border: 1px solid var(--ruled-line);
      background: var(--white);
    }

    .time-box label {
      display: block;
      margin-bottom: 4px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .time-box input {
      width: 100%;
      border: 0;
      color: var(--dark-blue);
      background: transparent;
      font-size: 18px;
      font-weight: 700;
      line-height: 27px;
      outline: none;
    }

    .summary-strip {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 13px 14px;
      border-radius: var(--radius-card);
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 8px 20px rgba(28,38,99,0.18);
    }

    .summary-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--pink);
      box-shadow: 0 0 0 7px rgba(248,76,162,0.2);
      flex: 0 0 auto;
    }

    .summary-strip p {
      margin: 0;
      color: #e7efff;
      font-size: 12px;
      line-height: 18px;
    }

    .summary-strip strong {
      color: var(--white);
    }

    .flow-stage {
      padding: 14px;
      margin-bottom: 14px;
    }

    .flow-progress {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      margin-bottom: 14px;
    }

    .flow-progress span {
      height: 7px;
      border-radius: 999px;
      background: var(--back-gray2);
      transition: background 220ms ease;
    }

    .flow-progress span.done {
      background: var(--pink);
    }

    .flow-screen {
      min-height: 388px;
      border-radius: 18px;
      background: linear-gradient(180deg, #ffffff, #fff9f4);
      border: 1px solid rgba(255,210,173,0.9);
      overflow: hidden;
      position: relative;
    }

    .screen-step {
      display: none;
      min-height: 388px;
      padding: 16px;
      animation: panelIn 260ms ease both;
    }

    .screen-step.active {
      display: block;
    }

    .flow-phone-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .flow-card {
      width: 100%;
      padding: 14px;
      border-radius: var(--radius-card);
      background: var(--white);
      border: 1px solid rgba(205,220,237,0.85);
      box-shadow: 0 8px 22px rgba(28,38,99,0.1);
      text-align: left;
      transition: transform 180ms ease, border 180ms ease;
    }

    .flow-card.active {
      border-color: var(--pink);
    }

    .flow-card-title {
      margin: 0 0 5px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .flow-card-text {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
    }

    .car-profile {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 12px;
      align-items: center;
      margin: 14px 0;
    }

    .car-thumb {
      height: 64px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.2), rgba(255,255,255,0)),
        linear-gradient(135deg, #1c2663, #4099ff);
      position: relative;
      overflow: hidden;
    }

    .car-thumb::before {
      content: "";
      position: absolute;
      left: 14px;
      bottom: 20px;
      width: 60px;
      height: 22px;
      border-radius: 18px 22px 9px 9px;
      background: var(--white);
    }

    .car-thumb::after {
      content: "";
      position: absolute;
      left: 22px;
      bottom: 13px;
      width: 44px;
      height: 11px;
      border-radius: 999px;
      background: var(--back-dark-blue);
      box-shadow: 0 0 0 4px rgba(255,255,255,0.18);
    }

    .car-name {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .car-meta {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .price-card {
      padding: 16px;
      border-radius: var(--radius-md);
      background: var(--dark-blue);
      color: var(--white);
      margin-bottom: 14px;
      position: relative;
      overflow: hidden;
    }

    .price-card::after {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      right: -52px;
      top: -52px;
      background: rgba(29,220,255,0.16);
    }

    .price-label {
      margin: 0;
      color: var(--text-light-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .price-value {
      margin: 2px 0 3px;
      font-family: var(--font-number);
      font-size: 40px;
      font-weight: 700;
      line-height: 54px;
    }

    .price-value small {
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 21px;
    }

    .price-sub {
      margin: 0;
      color: #dbeafe;
      font-size: 12px;
      line-height: 18px;
    }

    .forecast {
      padding: 14px;
      margin-bottom: 14px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid var(--ruled-line);
    }

    .chart {
      height: 116px;
      position: relative;
      margin-top: 8px;
    }

    .chart-line {
      position: absolute;
      inset: 0;
    }

    .chart-labels {
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .input-stack {
      display: grid;
      gap: 12px;
      margin: 12px 0 16px;
    }

    .field {
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid var(--ruled-line);
    }

    .field label {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .field input {
      width: 100%;
      border: 0;
      border-bottom: 2px solid var(--text-placeholder);
      padding: 4px 0 2px;
      background: transparent;
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
      text-align: center;
      outline: none;
    }

    .field input:focus {
      border-bottom-color: var(--dark-blue);
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 12px 0 14px;
    }

    .chip {
      min-height: 34px;
      padding: 0 13px;
      border-radius: var(--radius-chip);
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      transition: background 180ms ease, color 180ms ease;
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
    }

    .app-button {
      width: 100%;
      min-height: 43px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      box-shadow: 0 7px 18px rgba(64,153,255,0.23);
      transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
    }

    .app-button.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 7px 18px rgba(248,76,162,0.23);
    }

    .app-button.white {
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid var(--text-black);
      box-shadow: none;
    }

    .app-button:disabled {
      background: var(--gradient-disabled);
      color: var(--text-disabled);
      box-shadow: none;
      cursor: default;
    }

    .button-stack {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .complete-mark {
      width: 76px;
      height: 76px;
      margin: 18px auto 14px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--soft-green);
      border: 2px solid #86dcaa;
      position: relative;
    }

    .complete-mark::before {
      content: "";
      width: 28px;
      height: 15px;
      border-left: 5px solid #11a45b;
      border-bottom: 5px solid #11a45b;
      transform: rotate(-45deg) translate(2px, -2px);
    }

    .complete-title {
      margin: 0 0 8px;
      color: var(--dark-blue);
      text-align: center;
      font-size: 22px;
      font-weight: 700;
      line-height: 33px;
    }

    .complete-text {
      margin: 0;
      color: var(--text-gray);
      text-align: center;
      font-size: 13px;
      line-height: 19.5px;
    }

    .source-card {
      padding: 16px;
      margin-top: 20px;
      border-radius: var(--radius-card);
      background: #f8fbff;
      border: 1px solid #d9e7f7;
    }

    .source-card h2 {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .source-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 10px;
    }

    .source-list li {
      padding-left: 12px;
      border-left: 3px solid var(--button-link2);
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .source-list strong {
      color: var(--dark-blue);
    }

    .ops-card {
      padding: 16px;
      margin-top: 14px;
      border-radius: var(--radius-card);
      background: var(--white);
      border: 1px solid var(--ruled-line);
    }

    .ops-title {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .ops-grid {
      display: grid;
      gap: 8px;
    }

    .ops-item {
      display: flex;
      align-items: center;
      gap: 9px;
      color: var(--text-black);
      font-size: 12px;
      line-height: 18px;
    }

    .ops-check {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--soft-green);
      border: 1px solid #7ed9a6;
      position: relative;
      flex: 0 0 auto;
    }

    .ops-check::after {
      content: "";
      position: absolute;
      left: 5px;
      top: 4px;
      width: 7px;
      height: 4px;
      border-left: 2px solid #0d914a;
      border-bottom: 2px solid #0d914a;
      transform: rotate(-45deg);
    }

    .desktop-note {
      display: none;
    }

    @keyframes panelIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes carFloat {
      0%,
      100% {
        transform: translateY(0) rotate(-1deg);
      }

      50% {
        transform: translateY(-5px) rotate(1deg);
      }
    }

    @keyframes barWave {
      0%,
      100% {
        transform: scaleY(0.82);
        opacity: 0.72;
      }

      50% {
        transform: scaleY(1);
        opacity: 1;
      }
    }

    @keyframes pushPulse {
      0% {
        transform: scale(1);
      }

      45% {
        transform: scale(1.025);
        box-shadow: 0 12px 30px rgba(248,76,162,0.19);
      }

      100% {
        transform: scale(1);
      }
    }

    @media (min-width: 860px) {
      .page {
        display: grid;
        grid-template-columns: 430px 1fr;
        gap: 28px;
        align-items: start;
        padding: 32px 24px 56px;
      }

      .phone-shell {
        border-radius: 32px;
        min-height: auto;
      }

      .desktop-note {
        display: block;
        position: sticky;
        top: 32px;
        padding: 26px;
        border-radius: 24px;
        background: rgba(255,255,255,0.86);
        border: 1px solid rgba(255,210,173,0.72);
        box-shadow: 0 12px 36px rgba(28,38,99,0.12);
      }

      .desktop-note h2 {
        margin: 0 0 12px;
        color: var(--dark-blue);
        font-size: 26px;
        font-weight: 700;
        line-height: 39px;
      }

      .desktop-note p {
        margin: 0 0 16px;
        color: var(--text-gray);
        font-size: 14px;
        line-height: 21px;
      }

      .desktop-note .memo {
        padding: 16px;
        border-radius: var(--radius-card);
        background: var(--soft-yellow);
        border: 1px dashed #e7c666;
        color: var(--warm-ink);
        font-size: 13px;
        line-height: 19.5px;
      }
    }

    @media (max-width: 350px) {
      .hero h1 {
        font-size: 24px;
        line-height: 36px;
      }

      .speech {
        width: 132px;
        right: 12px;
      }

      .mini-car {
        left: 22px;
      }

      .kpi-value {
        font-size: 28px;
        line-height: 42px;
      }
    }
  </style>
</head>
<body>
