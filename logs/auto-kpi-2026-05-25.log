      align-items: center;
      gap: 4px;
      margin-top: 4px;
      padding: 3px 10px;
      border-radius: 999px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
    }

    .chart-wrap {
      margin-top: 18px;
      padding: 14px 10px 10px;
      border-radius: 12px;
      background: var(--back-white);
      border: 1px solid var(--ruled-line);
    }

    .chart-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
      padding: 0 4px;
    }

    .chart-title {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
    }

    .chart-unit {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .chart {
      width: 100%;
      height: 138px;
      display: block;
    }

    .chart-line {
      stroke-dasharray: 410;
      stroke-dashoffset: 410;
      animation: drawLine 1.2s ease forwards 260ms;
    }

    .best-timing {
      margin-top: 14px;
      border-radius: 12px;
      padding: 12px;
      background: var(--back-blue);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .best-timing strong {
      display: block;
      font-size: 16px;
      line-height: 24px;
    }

    .best-timing span {
      display: block;
      color: var(--text-light-blue);
      font-size: 11px;
      line-height: 16.5px;
    }

    .timing-pill {
      flex: 0 0 auto;
      min-width: 74px;
      padding: 8px 10px;
      border-radius: 22px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      text-align: center;
      font-size: 12px;
      line-height: 18px;
      font-weight: 900;
      animation: pulse 1.8s ease-in-out infinite;
    }

    .diagnosis-card {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      border-radius: 13px;
      background: var(--white);
      padding: 16px;
      border: 1px solid #CDDCED;
      box-shadow: 0 0 18px var(--shadow);
    }

    .diagnosis-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .diagnosis-title {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 900;
    }

    .diagnosis-step {
      color: var(--pink);
      font-size: 12px;
      line-height: 18px;
      font-weight: 900;
    }

    .question {
      margin: 0 0 12px;
      font-size: 14px;
      line-height: 21px;
      color: var(--text-black);
      font-weight: 700;
    }

    .choice-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .choice {
      min-height: 43px;
      border-radius: 22px;
      padding: 8px 10px;
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
      transition: transform 160ms ease, color 160ms ease, background 160ms ease, border 160ms ease;
    }

    .choice.selected {
      background: var(--dark-blue);
      border-color: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .choice:active {
      transform: scale(0.97);
    }

    .insight-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 14px;
    }

    .insight {
      min-height: 72px;
      border-radius: 12px;
      padding: 10px;
      background: var(--back-white);
      border: 1px solid var(--ruled-line);
    }

    .insight span {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      display: block;
    }

    .insight strong {
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      display: block;
      margin-top: 2px;
    }

    .similar-list {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .similar-item {
      border-radius: 12px;
      padding: 12px;
      background: var(--back-white);
      border: 1px solid var(--ruled-line);
      transform: translateY(8px);
      opacity: 0;
      animation: riseIn 520ms ease forwards;
    }

    .similar-item:nth-child(2) {
      animation-delay: 120ms;
    }

    .similar-item:nth-child(3) {
      animation-delay: 240ms;
    }

    .similar-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 8px;
    }

    .similar-name {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
    }

    .similar-spec {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .similar-price {
      color: var(--pink);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
      white-space: nowrap;
    }

    .match-meter {
      margin-top: 10px;
      height: 8px;
      border-radius: 999px;
      background: var(--back-gray2);
      overflow: hidden;
    }

    .match-fill {
      height: 100%;
      border-radius: 999px;
      background: var(--gradient-primary);
      width: var(--match);
    }

    .confidence {
      margin-top: 16px;
      padding: 14px;
      border-radius: 12px;
      background: linear-gradient(180deg, #fff8fc, #ffffff);
      border: 1px solid rgba(248,76,162,0.18);
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .ring {
      width: 68px;
      height: 68px;
      border-radius: 50%;
      background:
        conic-gradient(var(--pink) 0deg 313deg, #f1f1f1 313deg 360deg);
      display: grid;
      place-items: center;
      flex: 0 0 auto;
      animation: rotateIn 800ms ease;
    }

    .ring-inner {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: var(--white);
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
    }

    .confidence-copy strong {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      display: block;
    }

    .confidence-copy span {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      display: block;
      margin-top: 2px;
    }

    .apply-hero {
      margin-top: 16px;
      padding: 18px 14px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.08), transparent),
        var(--back-blue);
      color: var(--white);
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .apply-hero::after {
      content: "";
      position: absolute;
      inset: auto -30px -58px auto;
      width: 132px;
      height: 132px;
      border-radius: 50%;
      background: rgba(29,220,255,0.18);
    }

    .apply-hero p {
      margin: 0;
      color: var(--text-light-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .apply-hero strong {
      display: block;
      color: var(--white);
      font-size: 33px;
      line-height: 49.5px;
      margin-top: 4px;
      font-weight: 900;
      font-family: var(--font-number);
    }

    .apply-hero small {
      font-family: var(--font-sans);
      font-size: 16px;
      line-height: 24px;
    }

    .benefit-stack {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .benefit {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 54px;
      padding: 10px 12px;
      border-radius: 12px;
      background: var(--back-white);
      border: 1px solid var(--ruled-line);
    }

    .benefit-icon {
      width: 34px;
      height: 34px;
      border-radius: 17px;
      background: var(--back-light-pink);
      color: var(--pink);
      display: grid;
      place-items: center;
      font-weight: 900;
      flex: 0 0 auto;
    }

    .benefit strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
    }

    .benefit span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .primary-btn {
      width: 240px;
      min-height: 43px;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 8px 18px rgba(64,153,255,0.24);
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .pink-btn {
      width: 240px;
      min-height: 43px;
      border-radius: 30px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 8px 18px rgba(248,76,162,0.22);
      transition: transform 180ms ease, box-shadow 180ms ease;
      animation: ctaPulse 2.3s ease-in-out infinite;
    }

    .primary-btn:active,
    .pink-btn:active {
      transform: translateY(2px) scale(0.98);
      box-shadow: 0 3px 10px rgba(0,0,0,0.14);
    }

    .cta-area {
      width: 82%;
      max-width: 323px;
      margin: 2px auto 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .cta-note {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      text-align: center;
    }

    .swipe-hint {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .hint-arrow {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--white);
      color: var(--dark-blue);
      box-shadow: 0 0 10px var(--shadow);
      animation: nudge 1.5s ease-in-out infinite;
    }

    .source-card {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      border-radius: 12px;
      padding: 14px 16px;
      background: var(--white);
      border: 1px solid var(--ruled-line);
    }

    .source-card summary {
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 900;
      cursor: pointer;
    }

    .source-list {
      margin: 10px 0 0;
      padding-left: 18px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .source-list li {
      margin: 6px 0;
    }

    .source-list a {
      color: var(--text-under-blue);
      overflow-wrap: anywhere;
    }

    .bottom-nav {
      position: fixed;
      left: 50%;
      bottom: 0;
      transform: translateX(-50%);
      width: 100%;
      max-width: 430px;
      padding: 10px 16px calc(10px + env(safe-area-inset-bottom));
      background: rgba(255,255,255,0.94);
      backdrop-filter: blur(14px);
      border-top: 1px solid var(--ruled-line);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      z-index: 30;
    }

    .nav-item {
      min-height: 48px;
      border-radius: 12px;
      background: transparent;
      color: var(--text-gray);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      line-height: 15px;
      font-weight: 800;
      transition: background 160ms ease, color 160ms ease, transform 160ms ease;
    }

    .nav-item i {
      font-style: normal;
      font-size: 17px;
      line-height: 18px;
    }

    .nav-item.active {
      background: var(--back-light-pink);
      color: var(--pink);
    }

    .nav-item:active {
      transform: scale(0.96);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 84px;
      transform: translateX(-50%) translateY(20px);
      width: min(90%, 351px);
      max-width: 351px;
      min-height: 48px;
      border-radius: 12px;
      padding: 12px 16px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease, transform 220ms ease;
      z-index: 50;
      box-shadow: 0 8px 22px rgba(28,38,99,0.26);
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
      z-index: 80;
    }

    .modal-backdrop.show {
      display: flex;
    }

    .modal {
      width: 82%;
      max-width: 323px;
      border-radius: 12px;
      padding: 32px 28px;
      background: var(--white);
      text-align: center;
      animation: popIn 240ms ease;
      position: relative;
      overflow: hidden;
    }

    .modal-burst {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      margin: 0 auto 14px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      display: grid;
      place-items: center;
      font-size: 32px;
      font-weight: 900;
      animation: pulse 1.4s ease-in-out infinite;
    }

    .modal h2 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 33px;
    }

    .modal p {
      margin: 8px 0 20px;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 21px;
    }

    .confetti {
      position: fixed;
      width: 8px;
      height: 12px;
      border-radius: 2px;
      top: -20px;
      z-index: 100;
      animation: fall 900ms ease-in forwards;
    }

    @keyframes sheen {
      0% { transform: translateX(-100%); }
      45% { transform: translateX(120%); }
      100% { transform: translateX(120%); }
    }

    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.055); }
    }

    @keyframes ctaPulse {
      0%, 100% { box-shadow: 0 8px 18px rgba(248,76,162,0.22); }
      50% { box-shadow: 0 10px 26px rgba(248,76,162,0.36); }
    }

    @keyframes nudge {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(5px); }
    }

    @keyframes riseIn {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes rotateIn {
      from { transform: rotate(-90deg) scale(0.85); opacity: 0.2; }
      to { transform: rotate(0deg) scale(1); opacity: 1; }
    }

    @keyframes popIn {
      from { transform: scale(0.92); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    @keyframes fall {
      to {
        transform: translateY(105vh) rotate(360deg);
        opacity: 0;
      }
    }

    @media (min-width: 431px) {
      .phone {
        margin: 18px 0;
        min-height: calc(100vh - 36px);
        border-radius: 24px;
      }

      .bottom-nav {
        bottom: 18px;
        border-radius: 0 0 24px 24px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <main class="phone" aria-label="UcarPAC AI査定体験プロトタイプ">
      <div class="statusbar">
        <span>9:41</span>
        <div class="status-icons" aria-hidden="true">
          <span class="status-dot"></span>
          <span class="status-dot"></span>
          <span class="status-dot"></span>
        </div>
      </div>

      <header class="app-header">
        <div class="header-row">
          <button class="back-btn" type="button" aria-label="戻る">‹</button>
          <div class="header-title">
            <strong>AI査定結果</strong>
            <span>個人情報なしで相場チェック</span>
          </div>
          <button class="icon-btn" type="button" aria-label="通知">●</button>
        </div>

        <div class="progress-wrap" aria-label="査定完了までの進捗">
          <div class="progress-label">
            <span id="progressText">結果確認 74%</span>
            <span>あと1タップで申込</span>
          </div>
          <div class="progress-track">
            <div class="progress-bar" id="progressBar"></div>
          </div>
        </div>
      </header>

      <section class="content">
        <article class="hero-card">
          <div class="car-row">
            <div class="car-visual" aria-hidden="true"></div>
            <div class="car-meta">
              <div class="badge-row">
                <span class="badge badge-pink">AI査定済み</span>
                <span class="badge badge-blue">電話なし</span>
              </div>
              <h1 class="car-title">トヨタ ハリアー Z</h1>
              <p class="car-detail">2021年式 / 走行 32,400km / パールホワイト</p>
            </div>
          </div>
        </article>

        <article class="xp-card" aria-live="polite">
          <div class="xp-row">
            <div>
              <div class="xp-title" id="xpTitle">査定理解レベル 68</div>
              <div class="xp-sub">比較を見ると申込判断がしやすくなります</div>
            </div>
            <div class="xp-meter" aria-label="査定理解レベル">
              <div class="xp-fill" id="xpFill"></div>
            </div>
          </div>
        </article>

        <nav class="segment" aria-label="査定結果の表示切り替え">
          <button class="active" type="button" data-slide="0">相場予測</button>
          <button type="button" data-slide="1">実績比較</button>
          <button type="button" data-slide="2">申込</button>
        </nav>

        <div class="stage" id="stage">
          <div class="slides" id="slides">
            <section class="screen" aria-label="査定結果画面A">
              <article class="result-card">
                <p class="section-kicker">査定結果画面A</p>
                <h2 class="section-title">今の価値と売り時がひと目でわかる</h2>
                <p class="section-copy">AIが現在相場と3か月後の予測を比較し、高く売れるタイミングを提示します。</p>

                <div class="price-block">
                  <div class="price-label">AI査定価格</div>
                  <div class="price-main" id="mainPrice">312<small>万円</small></div>
                  <div class="price-delta" id="deltaText">+18万円 高値圏</div>
                </div>

                <div class="chart-wrap">
                  <div class="chart-head">
                    <div class="chart-title">相場予測グラフ</div>
                    <div class="chart-unit">単位: 万円</div>
                  </div>
                  <svg class="chart" viewBox="0 0 292 138" role="img" aria-label="現在から6か月後までの相場予測">
                    <line x1="16" y1="18" x2="16" y2="112" stroke="#e6e6e6" stroke-width="1"/>
                    <line x1="16" y1="112" x2="276" y2="112" stroke="#e6e6e6" stroke-width="1"/>
                    <line x1="16" y1="82" x2="276" y2="82" stroke="#f2f2f2" stroke-width="1"/>
                    <line x1="16" y1="52" x2="276" y2="52" stroke="#f2f2f2" stroke-width="1"/>
                    <text x="2" y="23" font-size="9" fill="#737373">330</text>
                    <text x="2" y="86" font-size="9" fill="#737373">300</text>
                    <text x="18" y="130" font-size="9" fill="#737373">今</text>
                    <text x="86" y="130" font-size="9" fill="#737373">1か月</text>
                    <text x="158" y="130" font-size="9" fill="#737373">3か月</text>
                    <text x="232" y="130" font-size="9" fill="#737373">6か月</text>
                    <path class="chart-line" d="M22 72 C62 58, 84 42, 118 46 S180 68, 210 58 S250 38, 270 48" fill="none" stroke="#F84CA2" stroke-width="4" stroke-linecap="round"/>
                    <path d="M22 72 C62 58, 84 42, 118 46 S180 68, 210 58 S250 38, 270 48 L270 112 L22 112 Z" fill="rgba(248,76,162,0.10)"/>
                    <circle cx="118" cy="46" r="5" fill="#F84CA2"/>
                    <circle cx="270" cy="48" r="5" fill="#1c2663"/>
                  </svg>
                </div>

                <div class="best-timing">
                  <div>
                    <strong>高く売れるタイミング</strong>
                    <span>同条件の推移では3か月以内が高値圏</span>
                  </div>
                  <div class="timing-pill">今月</div>
                </div>
              </article>

              <article class="diagnosis-card">
                <div class="diagnosis-head">
                  <div class="diagnosis-title">売り時ミニ診断</div>
                  <div class="diagnosis-step" id="diagnosisStep">1 / 2</div>
                </div>
                <p class="question" id="questionText">次の車検はいつ頃ですか？</p>
                <div class="choice-grid" id="choiceGrid">
                  <button class="choice" type="button" data-score="12">3か月以内</button>
                  <button class="choice" type="button" data-score="8">半年以内</button>
                  <button class="choice" type="button" data-score="4">1年以内</button>
                  <button class="choice" type="button" data-score="0">まだ先</button>
                </div>
                <div class="insight-row">
