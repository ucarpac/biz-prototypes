      applyButton.textContent = '申込準備中です';
    });

    saveButton.addEventListener('click', () => {
      successPanel.textContent = '見守り設定を保存しました。相場が上がりやすい7月上旬に通知します。';
      successPanel.classList.add('show');
    });

    calmButton.addEventListener('click', () => {
      handNote.textContent = '営業電話は申込するまで発生しません。まずは価格だけ見られます。';
      handNote.style.transform = 'rotate(1deg)';
      handNote.style.background = '#fff1a8';
    });
  </script>
