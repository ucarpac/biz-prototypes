  <div class="toast" id="toast" role="status" aria-live="polite">査定理解レベルが上がりました</div>

  <div class="modal-backdrop" id="modalBackdrop" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal">
      <div class="modal-burst">✓</div>
      <h2 id="modalTitle">申込準備が完了</h2>
      <p>AI査定データを引き継いで、売却相談の入力へ進みます。</p>
      <button class="primary-btn" type="button" id="closeModal">閉じる</button>
    </div>
  </div>

  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC AI査定体験プロトタイプ',
      description: 'AI査定結果画面A/Bと申込導線の検証用プロトタイプ',
      storageHours: 24
    };

    const slides = document.getElementById('slides');
    const stage = document.getElementById('stage');
    const segmentButtons = Array.from(document.querySelectorAll('.segment button'));
    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');
    const xpTitle = document.getElementById('xpTitle');
    const xpFill = document.getElementById('xpFill');
    const toast = document.getElementById('toast');
    const mainPrice = document.getElementById('mainPrice');
    const applyPrice = document.getElementById('applyPrice');
    const deltaText = document.getElementById('deltaText');
    const photoBtn = document.getElementById('photoBtn');
    const applyBtn = document.getElementById('applyBtn');
    const modalBackdrop = document.getElementById('modalBackdrop');
    const closeModal = document.getElementById('closeModal');
    const choiceGrid = document.getElementById('choiceGrid');
    const questionText = document.getElementById('questionText');
    const diagnosisStep = document.getElementById('diagnosisStep');
    const sellScore = document.getElementById('sellScore');
    const savePrice = document.getElementById('savePrice');

    let currentSlide = 0;
    let xp = 68;
    let price = 312;
    let touchStartX = 0;
    let touchCurrentX = 0;
    let diagnosisPage = 0;
    let diagnosisScore = 82;

    const questions = [
      {
        label: '次の車検はいつ頃ですか？',
        choices: [
          ['3か月以内', 12],
          ['半年以内', 8],
          ['1年以内', 4],
          ['まだ先', 0]
        ]
      },
      {
        label: '売却を考えている時期は？',
        choices: [
          ['今月中', 12],
          ['3か月以内', 9],
          ['半年以内', 5],
          ['未定', 1]
        ]
      }
    ];

    function setSlide(index) {
      currentSlide = Math.max(0, Math.min(2, index));
      slides.style.transform = `translateX(-${currentSlide * 33.3333}%)`;
      segmentButtons.forEach((button, buttonIndex) => {
        button.classList.toggle('active', buttonIndex === currentSlide);
      });

      const progress = [74, 86, 96][currentSlide];
      progressBar.style.width = `${progress}%`;
      progressText.textContent = currentSlide === 0 ? '結果確認 74%' : currentSlide === 1 ? '納得材料 86%' : '申込直前 96%';

      if (currentSlide === 1) {
        addXp(8, '類似実績を確認しました');
      }

      if (currentSlide === 2) {
        addXp(12, '申込判断の準備が整いました');
      }
    }

    function addXp(amount, message) {
      xp = Math.min(100, xp + amount);
      xpTitle.textContent = `査定理解レベル ${xp}`;
      xpFill.style.width = `${xp}%`;
      showToast(message);
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1600);
    }

    function updatePrice(newPrice, delta) {
      price = newPrice;
      mainPrice.innerHTML = `${price}<small>万円</small>`;
      applyPrice.innerHTML = `${price}<small>万円</small>`;
      deltaText.textContent = delta;
      mainPrice.animate(
        [
          { transform: 'scale(1)', opacity: 0.7 },
          { transform: 'scale(1.08)', opacity: 1 },
          { transform: 'scale(1)', opacity: 1 }
        ],
        { duration: 420, easing: 'ease-out' }
      );
    }

    function renderQuestion() {
      const current = questions[diagnosisPage];
      diagnosisStep.textContent = `${diagnosisPage + 1} / ${questions.length}`;
      questionText.textContent = current.label;
      choiceGrid.innerHTML = '';

      current.choices.forEach(([label, score]) => {
        const button = document.createElement('button');
        button.className = 'choice';
        button.type = 'button';
        button.textContent = label;
        button.dataset.score = score;
        choiceGrid.appendChild(button);
      });
    }

    function handleChoice(event) {
      const button = event.target.closest('.choice');
      if (!button) {
        return;
      }

      Array.from(choiceGrid.children).forEach((choice) => choice.classList.remove('selected'));
      button.classList.add('selected');

      const add = Number(button.dataset.score || 0);
      diagnosisScore = Math.min(99, diagnosisScore + add);
      sellScore.textContent = diagnosisScore;
      savePrice.textContent = `${Math.round(10 + add * 1.4)}万`;
      addXp(4, '売り時診断を更新しました');

      window.setTimeout(() => {
        if (diagnosisPage < questions.length - 1) {
          diagnosisPage += 1;
          renderQuestion();
        } else {
          showToast('売り時診断が完了しました');
        }
      }, 420);
    }

    function createConfetti() {
      const colors = ['#F84CA2', '#1ddcff', '#4db4ff', '#1c2663', '#ffd8e8'];

      for (let i = 0; i < 22; i += 1) {
        const piece = document.createElement('div');
        piece.className = 'confetti';
        piece.style.left = `${Math.random() * 100}%`;
        piece.style.background = colors[i % colors.length];
        piece.style.animationDelay = `${Math.random() * 220}ms`;
        piece.style.transform = `rotate(${Math.random() * 180}deg)`;
        document.body.appendChild(piece);

        window.setTimeout(() => {
          piece.remove();
        }, 1200);
      }
    }

    segmentButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setSlide(Number(button.dataset.slide));
      });
    });

    stage.addEventListener('touchstart', (event) => {
      touchStartX = event.touches[0].clientX;
      touchCurrentX = touchStartX;
    }, { passive: true });

    stage.addEventListener('touchmove', (event) => {
      touchCurrentX = event.touches[0].clientX;
    }, { passive: true });

    stage.addEventListener('touchend', () => {
      const delta = touchCurrentX - touchStartX;

      if (Math.abs(delta) > 48) {
        if (delta < 0) {
          setSlide(currentSlide + 1);
        } else {
          setSlide(currentSlide - 1);
        }
      }
    });

    photoBtn.addEventListener('click', () => {
      updatePrice(319, '+25万円 写真反映後');
      addXp(10, '写真追加で査定精度が上がりました');
      photoBtn.textContent = '再計算済み';
      photoBtn.style.opacity = '0.78';
    });

    applyBtn.addEventListener('click', () => {
      modalBackdrop.classList.add('show');
      createConfetti();
      addXp(4, '申込導線を確認しました');
    });

    closeModal.addEventListener('click', () => {
      modalBackdrop.classList.remove('show');
    });

    modalBackdrop.addEventListener('click', (event) => {
      if (event.target === modalBackdrop) {
        modalBackdrop.classList.remove('show');
      }
    });

    choiceGrid.addEventListener('click', handleChoice);

    document.querySelectorAll('.nav-item').forEach((item) => {
      item.addEventListener('click', () => {
        document.querySelectorAll('.nav-item').forEach((nav) => nav.classList.remove('active'));
        item.classList.add('active');
        showToast(`${item.textContent.trim()}を開きました`);
      });
    });

    renderQuestion();
  </script>
</body>
