    const applyButton = document.getElementById('applyButton');
    const saveButton = document.getElementById('saveButton');
    const successPanel = document.getElementById('successPanel');
    const calmButton = document.getElementById('calmButton');
    const handNote = document.getElementById('handNote');

    const compareData = {
      near: [
        ['ハリアー Z / 2021年式', '神奈川 / 29,000km / 黒 / 2026-05売却', '318万', true],
        ['ハリアー Z Leather / 2020年式', '東京 / 35,000km / 白 / 2026-04売却', '304万', false],
        ['ハリアー G / 2021年式', '埼玉 / 31,500km / 紺 / 2026-05売却', '296万', false]
      ],
      high: [
        ['ハリアー Z Leather / 2021年式', '千葉 / 18,000km / 白 / 2026-05売却', '337万', true],
        ['ハリアー Z / 2022年式', '東京 / 21,000km / 黒 / 2026-04売却', '331万', false],
        ['ハリアー Z / 2021年式', '大阪 / 24,000km / 白 / 2026-05売却', '326万', false]
      ]
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.screen;

        tabs.forEach((item) => item.classList.remove('active'));
        screens.forEach((screen) => screen.classList.remove('active'));

        tab.classList.add('active');
        document.getElementById(target).classList.add('active');
      });
    });

    compareButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;

        compareButtons.forEach((item) => item.classList.remove('selected'));
        button.classList.add('selected');

        compareList.innerHTML = compareData[filter].map((item) => {
          const highlightClass = item[3] ? ' highlight' : '';
          return `
            <article class="compare-item${highlightClass}">
              <div>
                <p class="compare-name">${item[0]}</p>
                <p class="compare-detail">${item[1]}</p>
              </div>
              <div class="compare-price">${item[2]}</div>
            </article>
          `;
        }).join('');
      });
    });

    applyButton.addEventListener('click', () => {
      successPanel.textContent = '申込準備を開始しました。希望日程の確認へ進めます。個人情報の入力は次の画面で明示します。';
