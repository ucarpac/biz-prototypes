        linear-gradient(to bottom, rgba(237,241,244,0.7) 1px, transparent 1px) 0 0 / 100% 42px,
        linear-gradient(180deg, #ffffff 0%, #fff7fb 100%);
      border-radius: 12px;
      padding: 12px;
      overflow: hidden;
    }

    .chart svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .chart-path {
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: drawLine 1.1s ease forwards;
    }

    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }

    .best-time {
      margin-top: 12px;
      display: grid;
      grid-template-columns: 42px 1fr;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border-radius: 12px;
      background: linear-gradient(135deg, #fff7ed, #ffffff);
      border: 1px solid rgba(248,76,162,0.16);
    }

    .best-icon {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--gradient-pink);
      color: var(--white);
      display: grid;
      place-items: center;
      font-weight: 900;
      box-shadow: 0 8px 16px rgba(248,76,162,0.22);
    }

    .best-time strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
    }

    .best-time span {
      display: block;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .compare-list {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .compare-item {
      padding: 13px 12px;
      background: var(--white);
      border-radius: 12px;
      box-shadow: var(--shadow-light);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
      border: 1px solid var(--ruled-line);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .compare-item.highlight {
      border-color: rgba(248,76,162,0.46);
      transform: translateY(-2px);
    }

    .compare-name {
      margin: 0;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
    }

    .compare-detail {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .compare-price {
      color: var(--pink);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
      white-space: nowrap;
    }

    .confidence {
      margin-top: 16px;
      padding: 16px;
      border-radius: 12px;
      background: var(--dark-blue);
      color: var(--white);
      overflow: hidden;
      position: relative;
    }

    .confidence::after {
      content: "";
      position: absolute;
      width: 130px;
      height: 130px;
      right: -72px;
      bottom: -84px;
      border-radius: 50%;
      border: 18px solid rgba(29,220,255,0.18);
    }

    .confidence h3 {
      margin: 0 0 8px;
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
      position: relative;
      z-index: 1;
    }

    .confidence p {
      margin: 0;
      color: var(--text-light-blue, #bfdbfe);
      font-size: 13px;
      line-height: 19.5px;
      position: relative;
      z-index: 1;
    }

    .meter {
      margin-top: 14px;
      height: 12px;
      border-radius: 22px;
      background: rgba(255,255,255,0.16);
      overflow: hidden;
      position: relative;
      z-index: 1;
    }

    .meter-fill {
      height: 100%;
      width: 88%;
      border-radius: 22px;
      background: var(--gradient-primary);
      animation: meterGrow 0.8s ease both;
    }

    @keyframes meterGrow {
      from { width: 0; }
      to { width: 88%; }
    }

    .toggle-row {
      margin-top: 14px;
      display: flex;
      gap: 8px;
    }

    .round-chip {
      flex: 1;
      border: 1px solid var(--ruled-line);
      min-height: 43px;
      border-radius: 22px;
      background: var(--white);
      color: var(--text-black);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 800;
      cursor: pointer;
    }

    .round-chip.selected {
      background: var(--pink);
      color: var(--white);
      border-color: var(--pink);
    }

    .cta-card {
      margin-top: 16px;
      padding: 20px 18px;
      border-radius: 12px;
      background: linear-gradient(180deg, #ffffff 0%, #fff7ed 100%);
      box-shadow: var(--shadow-medium);
      border: 1px solid rgba(248,76,162,0.16);
    }

    .cta-card h2 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 33px;
      font-weight: 900;
    }

    .cta-card p {
      margin: 8px 0 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 21px;
    }

    .price-confirm {
      margin-top: 16px;
      padding: 16px;
      background: var(--white);
      border-radius: 12px;
      border: 1px solid var(--ruled-line);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .price-confirm span {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .price-confirm strong {
      color: var(--dark-blue);
      font-size: 26px;
      line-height: 39px;
      font-weight: 900;
      white-space: nowrap;
    }

    .primary-button {
      width: 100%;
      min-height: 54px;
      margin-top: 16px;
      border: 0;
      border-radius: 30px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 16px;
      line-height: 24px;
      font-weight: 900;
      box-shadow: 0 12px 22px rgba(248,76,162,0.28);
      cursor: pointer;
      transition: transform 0.16s ease, box-shadow 0.16s ease;
    }

    .primary-button:active {
      transform: translateY(2px);
      box-shadow: 0 6px 14px rgba(248,76,162,0.24);
    }

    .secondary-button {
      width: 100%;
      min-height: 43px;
      margin-top: 10px;
      border: 1px solid #40BFFF;
      border-radius: 30px;
      background: var(--white);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
      cursor: pointer;
    }

    .step-list {
      margin-top: 16px;
      display: grid;
      gap: 10px;
    }

    .step {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 10px;
      align-items: start;
      padding: 12px;
      border-radius: 12px;
      background: var(--white);
      border: 1px solid var(--ruled-line);
    }

    .step-num {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--soft-cyan);
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 900;
    }

    .step h3 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
    }

    .step p {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .success-panel {
      display: none;
      margin-top: 14px;
      padding: 14px;
      border-radius: 12px;
      background: var(--mint);
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 800;
      animation: riseIn 0.28s ease both;
    }

    .success-panel.show {
      display: block;
    }

    .bottom-nav {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      min-height: 72px;
      background: rgba(255,255,255,0.94);
      border-top: 1px solid var(--ruled-line);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      padding: 8px 8px 10px;
      backdrop-filter: blur(10px);
    }

    .nav-item {
      border: 0;
      background: transparent;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 800;
      display: grid;
      place-items: center;
      gap: 3px;
    }

    .nav-item.active {
      color: var(--pink);
    }

    .nav-icon {
      width: 26px;
      height: 26px;
      border-radius: 10px;
      display: grid;
      place-items: center;
      background: var(--ruled-line);
    }

    .nav-item.active .nav-icon {
      background: var(--back-light-pink);
    }

    .research-block {
      max-width: 390px;
      margin: 18px auto 0;
      padding: 16px;
      background: rgba(255,255,255,0.84);
      border-radius: 12px;
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .research-block h2 {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 900;
    }

    .research-block p,
    .research-block li {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .research-block ul {
      padding-left: 18px;
      margin: 8px 0 0;
    }

    .source {
      color: var(--text-under-blue, #0056BA);
      overflow-wrap: anywhere;
    }

    @media (min-width: 760px) {
      .page {
        padding: 28px 24px 48px;
        display: grid;
        grid-template-columns: 390px minmax(320px, 520px);
        gap: 28px;
        align-items: start;
        justify-content: center;
      }

      .phone {
        margin: 0;
      }

      .research-block {
        margin: 0;
        max-width: 520px;
        position: sticky;
        top: 28px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="phone" aria-label="UcarPAC App AI査定結果プロトタイプ">
      <div class="status-bar">
        <span>9:41</span>
        <span>UcarPAC</span>
        <span>100%</span>
      </div>

      <div class="app">
        <header class="hero">
          <div class="top-row">
            <div class="brand">
              <div class="brand-mark">U</div>
              <span>AI査定</span>
            </div>
            <button class="help-chip" type="button" id="calmButton">☕ 不安を減らす</button>
          </div>

          <div class="hero-copy">
            <span class="hero-kicker">個人情報なしで結果表示</span>
            <h1>愛車の価値を、今とこれからで見守る。</h1>
            <p>売るか迷っていても大丈夫。相場、実績、申込までをひとつの流れで確認できます。</p>
            <div class="hand-note" id="handNote">手放す時期は、あなたのペースで。</div>
          </div>

          <svg class="mascot" viewBox="0 0 120 100" aria-hidden="true">
            <path d="M28 65 C31 43, 47 30, 71 32 C92 34, 105 49, 101 70 C96 93, 52 94, 34 80 C29 76, 27 71, 28 65Z" fill="#fff"/>
            <path d="M35 63 C40 49, 51 42, 70 43 C86 44, 94 54, 93 68 C92 81, 43 82, 35 70Z" fill="#ffd8e8"/>
            <circle cx="52" cy="61" r="4" fill="#1c2663"/>
            <circle cx="78" cy="61" r="4" fill="#1c2663"/>
            <path d="M59 71 C65 76, 72 76, 78 71" stroke="#1c2663" stroke-width="3" fill="none" stroke-linecap="round"/>
            <path d="M30 55 C17 52, 16 41, 28 38" stroke="#F84CA2" stroke-width="5" fill="none" stroke-linecap="round"/>
            <path d="M94 55 C109 51, 108 39, 95 36" stroke="#F84CA2" stroke-width="5" fill="none" stroke-linecap="round"/>
            <path d="M46 29 C42 17, 50 11, 58 21" stroke="#1ddcff" stroke-width="5" fill="none" stroke-linecap="round"/>
            <path d="M78 30 C85 18, 96 20, 93 34" stroke="#4db4ff" stroke-width="5" fill="none" stroke-linecap="round"/>
          </svg>
        </header>

        <div class="tabs-wrap">
          <nav class="tabs" aria-label="査定結果表示切り替え">
            <button class="tab active" type="button" data-screen="screenA">A 相場予測</button>
            <button class="tab" type="button" data-screen="screenB">B 実績比較</button>
            <button class="tab" type="button" data-screen="screenC">申込導線</button>
          </nav>
        </div>

        <div class="content">
          <section class="screen active" id="screenA">
            <article class="car-card">
              <div class="car-illustration">
                <svg viewBox="0 0 90 90" width="78" height="78" aria-hidden="true">
                  <path d="M18 55 L25 40 C28 35 33 32 40 32 H56 C63 32 68 35 71 41 L77 55" fill="#fff" stroke="#1c2663" stroke-width="3" stroke-linejoin="round"/>
                  <rect x="14" y="50" width="66" height="18" rx="8" fill="#F84CA2"/>
                  <circle cx="30" cy="68" r="7" fill="#1c2663"/>
                  <circle cx="63" cy="68" r="7" fill="#1c2663"/>
                  <path d="M34 38 H56 L62 50 H28Z" fill="#e5f8ff"/>
                </svg>
              </div>
              <div class="car-meta">
                <h2>トヨタ ハリアー</h2>
                <p>2021年式 / Z レザーパッケージ / 32,000km</p>
                <div class="badge-row">
                  <span class="badge">営業電話なし</span>
                  <span class="badge cyan">AI査定完了</span>
                </div>
              </div>
            </article>

            <article class="result-card">
              <p class="section-label">今日のAI査定価格</p>
              <div class="price-line">
                <span class="price-number" id="mainPrice">312</span>
                <span class="price-unit">万円</span>
              </div>
              <p class="price-sub">推定レンジ 296万〜326万円 / 近似データ 184件</p>
              <div class="trust-line">
                <span>🌤</span>
                <span>いま売る場合の目安が見えました。来月は需要期に入るため、少し待つ選択もできます。</span>
              </div>
            </article>

            <article class="graph-card">
              <div class="graph-head">
                <h3>相場グラフと高く売れるタイミング</h3>
                <span class="tiny-pill">6ヶ月予測</span>
              </div>
              <div class="chart" aria-label="相場予測グラフ">
                <svg viewBox="0 0 320 150" role="img" aria-label="現在312万円、2ヶ月後318万円、3ヶ月後323万円の予測">
                  <defs>
                    <linearGradient id="lineGradient" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="0%" stop-color="#F84CA2"/>
                      <stop offset="100%" stop-color="#4db4ff"/>
                    </linearGradient>
                    <linearGradient id="areaGradient" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#F84CA2" stop-opacity="0.24"/>
                      <stop offset="100%" stop-color="#F84CA2" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                  <path d="M16 112 C58 104, 78 92, 112 96 C153 101, 168 62, 208 58 C250 54, 265 76, 304 64 L304 138 L16 138Z" fill="url(#areaGradient)"/>
                  <path class="chart-path" d="M16 112 C58 104, 78 92, 112 96 C153 101, 168 62, 208 58 C250 54, 265 76, 304 64" fill="none" stroke="url(#lineGradient)" stroke-width="5" stroke-linecap="round"/>
                  <circle cx="16" cy="112" r="5" fill="#F84CA2"/>
                  <circle cx="208" cy="58" r="7" fill="#1c2663"/>
                  <circle cx="304" cy="64" r="5" fill="#4db4ff"/>
                  <text x="6" y="148" font-size="10" fill="#737373">今月</text>
                  <text x="188" y="48" font-size="10" fill="#1c2663" font-weight="800">323万</text>
                  <text x="270" y="148" font-size="10" fill="#737373">6ヶ月後</text>
                </svg>
              </div>
              <div class="best-time">
                <div class="best-icon">↗</div>
                <div>
                  <strong>高く売れやすい目安は「7月上旬」</strong>
                  <span>今すぐ売却より最大 +11万円の予測です。</span>
                </div>
              </div>
            </article>
          </section>

          <section class="screen" id="screenB">
            <article class="car-card">
              <div class="car-illustration">
                <svg viewBox="0 0 90 90" width="78" height="78" aria-hidden="true">
                  <rect x="18" y="18" width="54" height="54" rx="14" fill="#fff"/>
                  <path d="M29 55 L38 45 L47 51 L62 33" stroke="#F84CA2" stroke-width="5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="29" cy="55" r="4" fill="#1c2663"/>
                  <circle cx="38" cy="45" r="4" fill="#1c2663"/>
                  <circle cx="47" cy="51" r="4" fill="#1c2663"/>
                  <circle cx="62" cy="33" r="4" fill="#1c2663"/>
                </svg>
              </div>
              <div class="car-meta">
                <h2>似ている実績と比較</h2>
                <p>地域・年式・走行距離が近い売却データを表示</p>
                <div class="badge-row">
                  <span class="badge mint">納得感を確認</span>
                  <span class="badge cyan">価格差を表示</span>
                </div>
              </div>
            </article>

            <article class="result-card">
              <p class="section-label">あなたの査定価格</p>
              <div class="price-line">
                <span class="price-number">312</span>
                <span class="price-unit">万円</span>
              </div>
              <p class="price-sub">類似車両の中央値 305万円より +7万円</p>
              <div class="trust-line">
                <span>📝</span>
                <span>高すぎる金額だけを見せず、近い条件の実績と並べて安心して判断できる表示です。</span>
              </div>
            </article>

            <div class="toggle-row" role="group" aria-label="比較条件">
              <button class="round-chip selected" type="button" data-filter="near">近い条件</button>
              <button class="round-chip" type="button" data-filter="high">高額実績</button>
            </div>

            <div class="compare-list" id="compareList">
              <article class="compare-item highlight">
                <div>
                  <p class="compare-name">ハリアー Z / 2021年式</p>
                  <p class="compare-detail">神奈川 / 29,000km / 黒 / 2026-05売却</p>
                </div>
                <div class="compare-price">318万</div>
              </article>
              <article class="compare-item">
                <div>
                  <p class="compare-name">ハリアー Z Leather / 2020年式</p>
                  <p class="compare-detail">東京 / 35,000km / 白 / 2026-04売却</p>
                </div>
                <div class="compare-price">304万</div>
              </article>
              <article class="compare-item">
                <div>
                  <p class="compare-name">ハリアー G / 2021年式</p>
                  <p class="compare-detail">埼玉 / 31,500km / 紺 / 2026-05売却</p>
                </div>
                <div class="compare-price">296万</div>
              </article>
            </div>

            <article class="confidence">
              <h3>査定の納得度 88%</h3>
              <p>同条件の実績価格との差が小さく、申込前に価格の理由を理解しやすい状態です。</p>
              <div class="meter"><div class="meter-fill"></div></div>
            </article>
          </section>

          <section class="screen" id="screenC">
            <article class="cta-card">
              <h2>この価格で売れるなら、相談してみますか？</h2>
              <p>申込後も電話はUcarPACの1社のみ。8,000店の入札状況はアプリで確認できます。</p>

              <div class="price-confirm">
                <div>
                  <span>ワンタップ申込の目安価格</span>
                  <strong>312万円</strong>
                </div>
                <span class="tiny-pill">無料</span>
              </div>

              <button class="primary-button" type="button" id="applyButton">この価格で売りたい</button>
              <button class="secondary-button" type="button" id="saveButton">まだ売らずに見守る</button>

              <div class="success-panel" id="successPanel">
                申込準備を開始しました。希望日程の確認へ進めます。個人情報の入力は次の画面で明示します。
              </div>
            </article>

            <div class="step-list">
              <article class="step">
                <div class="step-num">1</div>
                <div>
                  <h3>価格に納得してから申込</h3>
                  <p>AI査定と実績比較を見たあとで、売却相談へ進みます。</p>
                </div>
              </article>
              <article class="step">
                <div class="step-num">2</div>
                <div>
                  <h3>電話対応はUcarPACだけ</h3>
                  <p>複数業者から一斉に連絡が来る不安を減らします。</p>
                </div>
              </article>
              <article class="step">
                <div class="step-num">3</div>
                <div>
                  <h3>8,000店の入札をアプリで確認</h3>
                  <p>最高額や進捗をプッシュ通知で見られる設計です。</p>
                </div>
              </article>
            </div>

            <article class="graph-card">
              <div class="graph-head">
                <h3>kpi-history 反映イメージ</h3>
                <span class="tiny-pill">日次差分</span>
              </div>
              <div class="best-time">
                <div class="best-icon">✓</div>
                <div>
                  <strong>AI査定開始→完了率の改善仮説を追加</strong>
                  <span>結果価格、実績比較、ワンタップ申込の3画面を検証対象に登録。</span>
                </div>
              </div>
            </article>
          </section>
        </div>

        <nav class="bottom-nav" aria-label="アプリ下部ナビゲーション">
          <button class="nav-item active" type="button">
            <span class="nav-icon">⌂</span>
            <span>ホーム</span>
          </button>
          <button class="nav-item" type="button">
            <span class="nav-icon">AI</span>
            <span>査定</span>
          </button>
          <button class="nav-item" type="button">
            <span class="nav-icon">¥</span>
            <span>出費</span>
