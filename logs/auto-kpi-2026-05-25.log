  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App AI査定体験改善',
      description: 'AI査定開始から完了率を高めるためのデータドリブンHTMLプロトタイプ',
      ttlHours: 24
    };

    const tabs = document.querySelectorAll('.tab-button');
    const screens = document.querySelectorAll('.screen');
    const sellButton = document.getElementById('sellButton');
    const toast = document.getElementById('toast');
    const confirmStep = document.getElementById('confirmStep');
    const modeChips = document.querySelectorAll('.mode-chip');
    const appealBox = document.getElementById('appealBox');
    const mainPrice = document.getElementById('mainPrice');

    let priceValue = 0;
    const priceTarget = 312;

    function setActiveScreen(targetId) {
      tabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.target === targetId);
      });

      screens.forEach((screen) => {
        screen.classList.toggle('is-active', screen.id === targetId);
      });

      if (targetId === 'screen-a') {
        animatePrice();
      }
    }

    function animatePrice() {
      priceValue = 284;
      mainPrice.textContent = priceValue;
      const timer = setInterval(() => {
        priceValue += 4;
        if (priceValue >= priceTarget) {
          priceValue = priceTarget;
          clearInterval(timer);
        }
        mainPrice.textContent = priceValue;
      }, 28);
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('is-show');
      window.setTimeout(() => {
        toast.classList.remove('is-show');
      }, 2200);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        setActiveScreen(tab.dataset.target);
      });
    });

    sellButton.addEventListener('click', () => {
      setActiveScreen('screen-c');
      confirmStep.classList.add('is-done');
      confirmStep.querySelector('.step-state').textContent = '入力中';
      showToast('申込ステップを更新しました。価格312万円を保持したまま確認へ進みます。');
    });

    modeChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        modeChips.forEach((item) => item.classList.remove('is-active'));
        chip.classList.add('is-active');
        appealBox.querySelector('h3').textContent = chip.textContent;
        appealBox.querySelector('p').textContent = chip.dataset.message;
        showToast(chip.dataset.message);
      });
    });

    window.addEventListener('load', () => {
      animatePrice();
    });
  </script>
