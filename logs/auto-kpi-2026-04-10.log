    }

    .hero-card,
    .glass-card,
    .comparison-card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.8);
      border: 1px solid rgba(255,255,255,0.65);
      border-radius: 24px;
      backdrop-filter: blur(8px);
      box-shadow: 0 18px 40px rgba(28, 38, 99, 0.08);
    }

    .hero-card {
      padding: 18px;
    }

    .car-line {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .car-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(255, 216, 232, 0.58);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .car-name {
      font-size: 14px;
      font-weight: 800;
      color: var(--soft-ink);
    }

    .mileage {
      font-size: 11px;
      color: var(--text-gray);
    }

    .price-row {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 10px;
      margin-bottom: 14px;
    }

    .price-label {
      font-size: 12px;
      color: var(--text-gray);
      margin-bottom: 6px;
    }

    .price-value {
      font-family: var(--font-sans);
      font-size: 34px;
      line-height: 1.1;
      letter-spacing: -0.04em;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .delta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 14px;
      background: rgba(255, 228, 142, 0.42);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }

    .delta.positive::before {
      content: "↗";
      color: #ff7c47;
    }

    .delta.neutral::before {
      content: "•";
      color: var(--button-link1);
    }

    .subnote {
      margin-bottom: 16px;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .graph-card {
      padding: 14px 14px 12px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(239,247,255,0.9));
      border: 1px solid rgba(29,220,255,0.14);
    }

    .graph-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 10px;
    }

    .graph-title {
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .graph-pill {
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(248,76,162,0.1);
      color: var(--pink);
      font-size: 11px;
      font-weight: 800;
    }

    .bars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      align-items: end;
      height: 152px;
      margin-top: 8px;
    }

    .bar {
      display: grid;
      gap: 8px;
      justify-items: center;
    }

    .bar-track {
      position: relative;
      width: 100%;
      height: 120px;
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.24), rgba(29,220,255,0.08)),
        repeating-linear-gradient(
          to top,
          rgba(28,38,99,0.06),
          rgba(28,38,99,0.06) 1px,
          transparent 1px,
          transparent 22px
        );
      overflow: hidden;
    }

    .bar-fill {
      position: absolute;
      left: 8px;
      right: 8px;
      bottom: 8px;
      height: 50%;
      border-radius: 12px 12px 16px 16px;
      background: linear-gradient(180deg, rgba(248,76,162,0.8), rgba(29,220,255,0.92));
      box-shadow: 0 10px 20px rgba(29,220,255,0.2);
      transition: height 0.45s ease;
    }

    .bar:nth-child(2) .bar-fill {
      background: linear-gradient(180deg, rgba(255,177,137,0.92), rgba(248,76,162,0.88));
    }

    .bar-top {
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .bar-label {
      font-size: 11px;
      color: var(--text-gray);
    }

    .toggle-row,
    .mode-row {
      display: flex;
      gap: 8px;
      margin-top: 14px;
    }

    .toggle-button,
    .mode-button {
      flex: 1;
      min-height: 42px;
      border: 0;
      border-radius: 30px;
      background: #ffffff;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.08);
      color: var(--text-gray);
      font: inherit;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.3s ease;
    }

    .toggle-button.active,
    .mode-button.active {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: none;
    }

    .support {
      margin-top: 14px;
      padding: 13px 14px;
      border-radius: 18px;
      background: rgba(255,248,239,0.9);
      border: 1px solid rgba(255,177,137,0.34);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.7;
      font-weight: 700;
    }

    .glass-card {
      padding: 16px;
    }

    .section-stack {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .metric-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .mini-panel {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.9);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.06);
    }

    .mini-label {
      font-size: 11px;
      color: var(--text-gray);
      margin-bottom: 8px;
    }

    .mini-value {
      font-size: 24px;
      line-height: 1.2;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .mini-caption {
      margin-top: 6px;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.9);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.06);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--pink);
    }

    .expense-item:nth-child(2) .expense-dot {
      background: #ff9e6d;
    }

    .expense-item:nth-child(3) .expense-dot {
      background: #52b8ff;
    }

    .expense-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--soft-ink);
    }

    .expense-price {
      font-size: 13px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .trend-box {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(239,247,255,0.92));
      box-shadow: inset 0 0 0 1px rgba(29,220,255,0.12);
    }

    .line-chart {
      position: relative;
      height: 130px;
      margin-top: 12px;
      border-radius: 16px;
      background:
        repeating-linear-gradient(
          to top,
          rgba(28,38,99,0.06),
          rgba(28,38,99,0.06) 1px,
          transparent 1px,
          transparent 24px
        );
      overflow: hidden;
    }

    .line-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .chart-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .cta-strip {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(248,76,162,0.08);
    }

    .cta-strip strong {
      display: block;
      font-size: 13px;
      color: var(--dark-blue);
      margin-bottom: 3px;
    }

    .cta-strip span {
      display: block;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .round-action {
      min-width: 98px;
      min-height: 42px;
      padding: 0 14px;
      border: 0;
      border-radius: 30px;
      background: var(--gradient-pink);
      color: #fff;
      font: inherit;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 10px 22px rgba(248,76,162,0.24);
    }

    .comparison-card {
      padding: 16px;
      margin-top: 16px;
    }

    .compare-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 14px;
    }

    .compare-title {
      font-size: 18px;
      line-height: 1.5;
      color: var(--soft-ink);
      font-weight: 900;
    }

    .compare-note {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
      max-width: 150px;
      text-align: right;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .compare-panel {
      padding: 16px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.88);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.06);
    }

    .compare-panel.primary {
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(234,248,255,0.96));
      box-shadow: inset 0 0 0 1px rgba(64, 191, 255, 0.18);
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 10px;
    }

    .panel-name {
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .panel-tag {
      padding: 5px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 800;
      color: #fff;
      background: var(--pink);
    }

    .panel-tag.gray {
      background: #a1a9c7;
    }

    .call-count {
      display: flex;
      align-items: end;
      gap: 4px;
      margin-bottom: 8px;
      color: var(--dark-blue);
    }

    .count-number {
      font-size: 34px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .count-unit {
      font-size: 14px;
      font-weight: 800;
      margin-bottom: 4px;
    }

    .count-copy {
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
      min-height: 58px;
    }

    .compare-list {
      display: grid;
      gap: 8px;
      margin-top: 10px;
    }

    .compare-item {
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(255,255,255,0.8);
      font-size: 11px;
      line-height: 1.6;
      color: var(--dark-blue);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.06);
    }

    .compare-actions {
      display: flex;
      gap: 8px;
      margin-top: 14px;
    }

    .hand-line {
      position: absolute;
      z-index: 1;
      width: 92px;
      height: 20px;
      border-bottom: 3px solid rgba(248, 76, 162, 0.55);
      border-radius: 50%;
      opacity: 0.85;
      transform: rotate(-4deg);
    }

    .hand-line.one {
      top: 238px;
      left: 24px;
    }

    .hand-line.two {
      top: 250px;
      right: 40px;
      border-color: rgba(255,177,137,0.8);
      transform: rotate(6deg);
    }

    .home-indicator {
      position: absolute;
      left: 50%;
      bottom: 10px;
      transform: translateX(-50%);
      width: 130px;
      height: 5px;
      border-radius: 999px;
      background: rgba(39,49,107,0.14);
      z-index: 4;
    }

    .android-nav {
      position: absolute;
      left: 50%;
      bottom: 10px;
      transform: translateX(-50%);
      width: 110px;
      display: flex;
      justify-content: center;
      gap: 16px;
      z-index: 4;
      opacity: 0.54;
    }

    .android-nav i {
      display: block;
      width: 14px;
      height: 14px;
      border: 2px solid rgba(39,49,107,0.3);
      border-radius: 50%;
    }

    .android-nav i:nth-child(2) {
      border-radius: 3px;
      width: 14px;
      height: 14px;
    }

    .android-nav i:nth-child(3) {
      width: 16px;
      height: 16px;
      border-radius: 5px;
      transform: rotate(45deg) scale(0.8);
    }

    .pager {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding: 8px 0 0;
    }

    .pager button {
      width: 10px;
      height: 10px;
      border: 0;
      border-radius: 50%;
      background: rgba(28,38,99,0.18);
      cursor: pointer;
      transition: 0.3s ease;
    }

    .pager button.active {
      width: 30px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--pink), #ffb189);
    }

    .footer-note {
      padding: 0 16px 12px;
      text-align: center;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0) rotate(-5deg); }
      50% { transform: translateY(-6px) rotate(-3deg); }
    }

    @keyframes pulseSoft {
      0%, 100% { box-shadow: 0 10px 22px rgba(248,76,162,0.18); }
      50% { box-shadow: 0 14px 30px rgba(248,76,162,0.28); }
    }

    .sticker,
    .round-action {
      animation: floaty 4.8s ease-in-out infinite;
    }

    .round-action {
      animation-name: pulseSoft;
      animation-duration: 3.2s;
    }

    @media (min-width: 920px) {
      .screen.active {
        grid-template-columns: minmax(0, 420px) minmax(0, 1fr);
        align-items: center;
      }

      .phone-wrap {
        order: 2;
      }

      .meta-card {
        min-height: 760px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .meta-card h2 {
        font-size: 32px;
      }

      .meta-card p {
        font-size: 15px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="hero">
      <div class="eyebrow">ストアPV→DL率 改善検証 / 目標 CVR 25%</div>
      <h1>不安をほどいて、<br>「入れてみよう」に変える3枚。</h1>
      <p>
        AI査定への期待、出費へのモヤモヤ、営業電話への不安。
        その感情をそのまま受け止めて、UcarPACなら「まず見てみる」が安心だと伝えるストアスクショ案です。
      </p>
      <div class="chips">
        <div class="chip hot">AI査定を主役化</div>
        <div class="chip">個人情報なしで相場チェック</div>
        <div class="chip">出費管理と将来予測を接続</div>
        <div class="chip">競合比較で電話不安を解消</div>
      </div>
    </section>

    <div class="nav-wrap">
      <div class="nav">
        <button class="nav-button active" data-target="a">スクショA<span>AI査定 / iOS</span></button>
        <button class="nav-button" data-target="b">スクショB<span>出費管理 / Android</span></button>
        <button class="nav-button" data-target="c">スクショC<span>電話0本 / 比較</span></button>
      </div>
    </div>

    <main class="screens">
      <section class="screen active" id="screen-a">
        <div class="meta-card">
          <div class="meta-kicker">ストアスクショA / AI査定を全面訴求</div>
          <h2>「いま知りたい」にすぐ応える。<br>愛車の価値がやさしく見える iOS 向け1枚。</h2>
          <p>
            一番大きな差別化であるAI査定を主役に置き、相場を知らない不安を安心に変える構成です。
            個人情報不要のバッジと、季節要因まで示す予測で「ただの概算ではない」期待感をつくります。
          </p>
          <div class="point-list">
            <div class="point">訴求軸: AI査定 × 将来予測</div>
            <div class="point">感情: 売り時が分かる安心</div>
            <div class="point">差別化: 競合ゼロ機能</div>
          </div>
        </div>

        <div class="phone-wrap">
          <div class="phone ios">
            <div class="phone-inner">
              <div class="statusbar">
                <span>9:41</span>
                <span>5G 100%</span>
              </div>
              <div class="island"></div>
              <div class="shot">
                <div class="platform">iOS向けストアスクショ</div>
                <div class="sticker a">個人情報なしでOK</div>
                <div class="hand-line one"></div>
                <h3>AIがあなたの愛車を、<br>やさしく査定。</h3>
                <p class="shot-copy">
                  今の相場だけでなく、少し待ったときの期待値まで。
                  売るか迷っている今でも、安心して見られます。
                </p>

                <div class="hero-card">
                  <div class="car-line">
                    <div>
                      <div class="car-name">トヨタ ハリアー Z Leather Package</div>
                      <div class="mileage">2021年式 / 27,800km / パールホワイト</div>
                    </div>
                    <div class="car-badge">AI査定中</div>
                  </div>

                  <div class="price-row">
                    <div>
                      <div class="price-label" id="forecast-label">いまの想定売却価格</div>
                      <div class="price-value" id="forecast-price">2,184,000円</div>
                    </div>
                    <div class="delta positive" id="forecast-delta">昨月比 +18,000円</div>
                  </div>

                  <div class="subnote" id="forecast-copy">
                    春のSUV需要が強く、いまでも十分高水準。さらに3か月後は流通タイミング次第で上振れが見込めます。
                  </div>

                  <div class="graph-card">
                    <div class="graph-head">
                      <div class="graph-title">AI予測グラフ</div>
                      <div class="graph-pill" id="forecast-pill">待つと +4.2万円予測</div>
                    </div>
                    <div class="bars">
                      <div class="bar">
                        <div class="bar-top" id="bar-top-1">218.4万円</div>
                        <div class="bar-track"><div class="bar-fill" id="bar-fill-1" style="height:56%;"></div></div>
                        <div class="bar-label">今</div>
                      </div>
                      <div class="bar">
                        <div class="bar-top" id="bar-top-2">222.6万円</div>
                        <div class="bar-track"><div class="bar-fill" id="bar-fill-2" style="height:72%;"></div></div>
                        <div class="bar-label">3か月後</div>
                      </div>
                      <div class="bar">
                        <div class="bar-top" id="bar-top-3">219.8万円</div>
                        <div class="bar-track"><div class="bar-fill" id="bar-fill-3" style="height:63%;"></div></div>
                        <div class="bar-label">6か月後</div>
                      </div>
                    </div>
                  </div>

                  <div class="toggle-row">
                    <button class="toggle-button active" data-forecast="now">今の価格を見る</button>
                    <button class="toggle-button" data-forecast="future">売り時を知る</button>
                  </div>

                  <div class="support" id="forecast-support">
                    今すぐ売らなくても大丈夫。まずは相場を知るだけでも、次の判断がラクになります。
                  </div>
                </div>
                <div class="home-indicator"></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="screen" id="screen-b">
        <div class="meta-card">
          <div class="meta-kicker">ストアスクショB / 出費管理 + 将来予測</div>
          <h2>「乗り続けるか、売るか」をひと目で。<br>家計と愛車価値をつなぐ Android 向け1枚。</h2>
          <p>
            出費管理は単体では地味に見えやすいため、将来予測と同じ画面で見せて「続けるほど価値があるアプリ」に変換します。
            車の維持費を見える化しながら、売却タイミングも考えられる設計です。
          </p>
          <div class="point-list">
            <div class="point">訴求軸: 出費管理 × 資産管理体験</div>
            <div class="point">感情: ムダな出費が見える安心</div>
            <div class="point">差別化: 管理機能を持つ競合ゼロ</div>
          </div>
        </div>

        <div class="phone-wrap">
          <div class="phone android">
            <div class="phone-inner">
              <div class="statusbar" style="color:#27316b;">
                <span>9:41</span>
                <span>VoLTE 87%</span>
              </div>
              <div class="punch-hole"></div>
              <div class="shot">
                <div class="platform">Android向けストアスクショ</div>
                <div class="sticker b">出費も売り時も、まとめて見える</div>
                <div class="hand-line two"></div>
