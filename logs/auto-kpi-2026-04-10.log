      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .primary-btn {
      flex: 1;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 14px 28px rgba(64,191,255,0.24);
    }

    .ghost-btn:hover,
    .primary-btn:hover,
    .step-button:hover,
    .thumb:hover {
      transform: translateY(-1px);
    }

    .swipe-hint {
      margin-top: 12px;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    .stage {
      padding: 18px 10px 16px;
    }

    .stage-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 0 8px 12px;
    }

    .stage-label {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
      letter-spacing: 0.06em;
    }

    .stage-dots {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .stage-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(28,38,99,0.18);
      transition: transform var(--transition), background var(--transition);
    }

    .stage-dot.active {
      background: var(--pink);
      transform: scale(1.25);
    }

    .phone-wrap {
      display: flex;
      justify-content: center;
      padding: 0 4px;
    }

    .phone {
      position: relative;
      width: min(100%, var(--phone-width));
      height: min(76vh, var(--phone-height));
      min-height: 680px;
      border-radius: var(--radius-phone);
      padding: 12px;
      background: linear-gradient(180deg, #121a4a 0%, #0b1131 100%);
      box-shadow: var(--shadow-heavy);
      overflow: hidden;
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 120px;
      height: 28px;
      border-radius: 20px;
      background: rgba(0,0,0,0.66);
      z-index: 3;
    }

    .phone-screen {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 28px;
      overflow: hidden;
      background: #fff;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
    }

    .track {
      display: flex;
      width: 300%;
      height: 100%;
      transition: transform 420ms cubic-bezier(.2,.9,.2,1);
    }

    .screen {
      position: relative;
      width: 33.333333%;
      height: 100%;
      padding: 22px 18px 18px;
      overflow: hidden;
    }

    .screen.active .float,
    .screen.active .store-chip,
    .screen.active .info-card,
    .screen.active .cta-main,
    .screen.active .hero-price,
    .screen.active .zero-orb,
    .screen.active .chart-shell,
    .screen.active .expense-card {
      animation: rise 700ms ease both;
    }

    .screen-a { background: var(--gradient-a); }
    .screen-b { background: var(--gradient-b); color: var(--white); }
    .screen-c { background: var(--gradient-c); }

    .screen-a::after,
    .screen-c::after {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      border-radius: 50%;
      right: -60px;
      top: -60px;
      filter: blur(8px);
      background: radial-gradient(circle, rgba(248,76,162,0.18), transparent 68%);
    }

    .screen-b::after {
      content: "";
      position: absolute;
      inset: auto -20% -10% auto;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(29,220,255,0.18), transparent 68%);
      filter: blur(12px);
    }

    .screen-head {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .store-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .store-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.03em;
      box-shadow: var(--shadow-light);
      backdrop-filter: blur(8px);
    }

    .screen-a .store-chip,
    .screen-c .store-chip {
      background: rgba(255,255,255,0.92);
      color: var(--dark-blue);
    }

    .screen-b .store-chip {
      background: rgba(255,255,255,0.12);
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.12);
    }

    .store-chip.pink {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .store-chip.cyan {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .screen-title {
      position: relative;
      z-index: 1;
      margin: 18px 0 8px;
      font-size: 34px;
      line-height: 1.16;
      letter-spacing: -0.06em;
      font-weight: 900;
    }

    .screen-sub {
      position: relative;
      z-index: 1;
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: inherit;
      opacity: 0.84;
      max-width: 300px;
    }

    .float {
      position: absolute;
      z-index: 1;
      min-height: 34px;
      padding: 8px 12px;
      border-radius: 18px;
      font-size: 11px;
      font-weight: 800;
      line-height: 1.4;
      box-shadow: var(--shadow-light);
      animation: floaty 4.4s ease-in-out infinite;
    }

    .screen-a .float,
    .screen-c .float {
      background: rgba(255,255,255,0.94);
      color: var(--dark-blue);
    }

    .screen-b .float {
      background: rgba(255,255,255,0.12);
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.12);
    }

    .float.one { top: 144px; right: 18px; animation-delay: 0.2s; }
    .float.two { top: 332px; left: 18px; animation-delay: 0.8s; }
    .float.three { top: 184px; right: 20px; animation-delay: 0.4s; }

    .hero-price {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 92px;
      gap: 12px;
      align-items: center;
      margin-top: 18px;
    }

    .price-card {
      padding: 18px 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.9);
      border: 1px solid rgba(28,38,99,0.08);
