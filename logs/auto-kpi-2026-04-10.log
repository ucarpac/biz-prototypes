    }

    .step-button.active {
      background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(237,246,255,0.95));
      border-color: rgba(64,153,255,0.26);
      color: var(--dark-blue);
      transform: translateY(-2px);
      box-shadow: 0 16px 34px rgba(28,38,99,0.12);
    }

    .panel-title {
      margin: 0 0 8px;
