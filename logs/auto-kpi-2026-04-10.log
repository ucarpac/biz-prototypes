  <script>
    const screens = [
      {
        kicker: "STEP 1 / iOS向け",
        stage: "STORE SCREENSHOT A / iOS",
        score: 72,
        title: "スクショA | AI査定を全面に出す",
        lead: "1枚目で「このアプリなら自分の車の価値がすぐ分かる」と感じさせ、ストア離脱を止める。",
        emotion: "見たい。試したい。今すぐ価格を知りたい。",
        message: "AIがいまの相場と売り時を予測",
        cta: "3分でAI査定をはじめる",
        hypothesis: "「個人情報なし」の即時価値訴求で1枚目CVRを押し上げる",
        copy: "AIがあなたの愛車を査定。個人情報なしで、今の相場と売り時まで見える。"
      },
      {
        kicker: "STEP 2 / Android向け",
        stage: "STORE SCREENSHOT B / Android",
        score: 84,
        title: "スクショB | 出費管理 + 将来予測を訴求",
        lead: "相場を見る理由を「売る時期の判断」まで広げ、DL後の継続利用イメージを作る。",
        emotion: "入れた後も役立ちそう。毎月見返したい。",
        message: "出費と価値を重ねて未来の手残りまで見る",
        cta: "半年の変化を見る",
        hypothesis: "価値推移と維持費の統合表示で、資産管理ニーズの層を取り込める",
        copy: "出費管理と将来予測で、いま売るか待つかが分かる。車の価値を毎月追えるアプリ体験。"
      },
      {
        kicker: "STEP 3 / 比較訴求",
        stage: "STORE SCREENSHOT C / PHONE 0",
        score: 91,
        title: "スクショC | 競合比較で『電話0本』を刺す",
        lead: "営業連絡への不安を比較で明文化し、相場チェックの心理ハードルを一気に下げる。",
        emotion: "それなら入れても大丈夫。まず試せる。",
        message: "相場チェックは電話0本ではじめる",
        cta: "0本で相場だけ見る",
        hypothesis: "比較表現で不安を言語化すると、DL前の躊躇を減らせる",
        copy: "まずはAI査定で相場だけ。電話が増えそうという不安を、最初の1枚で消しにいく。"
      }
    ];

    const track = document.getElementById("track");
    const stageLabel = document.getElementById("stageLabel");
    const scoreValue = document.getElementById("scoreValue");
    const scoreFill = document.getElementById("scoreFill");
    const panelKicker = document.getElementById("panelKicker");
    const panelTitle = document.getElementById("panelTitle");
    const panelLead = document.getElementById("panelLead");
    const factEmotion = document.getElementById("factEmotion");
    const factMessage = document.getElementById("factMessage");
    const factCTA = document.getElementById("factCTA");
    const factHypothesis = document.getElementById("factHypothesis");
    const copyBox = document.getElementById("copyBox");

    const stepButtons = [...document.querySelectorAll(".step-button")];
    const thumbButtons = [...document.querySelectorAll(".thumb")];
    const stageDots = [...document.querySelectorAll(".stage-dot")];
    const screenEls = [...document.querySelectorAll(".screen")];
    const goButtons = [...document.querySelectorAll("[data-go]")];
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const swipeArea = document.getElementById("swipeArea");

    let currentIndex = 0;
    let startX = null;

    function setActive(index) {
      currentIndex = (index + screens.length) % screens.length;
      track.style.transform = "translateX(-" + (currentIndex * 33.333333) + "%)";
      stageLabel.textContent = screens[currentIndex].stage;
      panelKicker.textContent = screens[currentIndex].kicker;
      panelTitle.textContent = screens[currentIndex].title;
      panelLead.textContent = screens[currentIndex].lead;
      factEmotion.textContent = screens[currentIndex].emotion;
      factMessage.textContent = screens[currentIndex].message;
      factCTA.textContent = screens[currentIndex].cta;
      factHypothesis.textContent = screens[currentIndex].hypothesis;
      copyBox.textContent = screens[currentIndex].copy;
      scoreValue.textContent = screens[currentIndex].score;
      scoreFill.style.width = screens[currentIndex].score + "%";

      stepButtons.forEach((button, i) => button.classList.toggle("active", i === currentIndex));
      thumbButtons.forEach((button, i) => button.classList.toggle("active", i === currentIndex));
      stageDots.forEach((dot, i) => dot.classList.toggle("active", i === currentIndex));
      screenEls.forEach((screen, i) => screen.classList.toggle("active", i === currentIndex));
    }

    goButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setActive(Number(button.dataset.go));
      });
    });

    prevBtn.addEventListener("click", () => setActive(currentIndex - 1));
    nextBtn.addEventListener("click", () => setActive(currentIndex + 1));

    swipeArea.addEventListener("touchstart", (event) => {
      startX = event.touches[0].clientX;
    }, { passive: true });

    swipeArea.addEventListener("touchend", (event) => {
      if (startX === null) return;
      const diff = event.changedTouches[0].clientX - startX;
      if (Math.abs(diff) > 40) {
        setActive(currentIndex + (diff < 0 ? 1 : -1));
      }
      startX = null;
    });

    swipeArea.addEventListener("mousedown", (event) => {
      startX = event.clientX;
    });

    swipeArea.addEventListener("mouseup", (event) => {
      if (startX === null) return;
      const diff = event.clientX - startX;
      if (Math.abs(diff) > 40) {
        setActive(currentIndex + (diff < 0 ? 1 : -1));
      }
      startX = null;
    });

    const aPrice = document.getElementById("aPrice");
    const aSub = document.getElementById("aSub");
    const aScore = document.getElementById("aScore");
    const aRange = document.getElementById("aRange");
    const aChartNote = document.getElementById("aChartNote");
    const aModeBase = document.getElementById("aModeBase");
    const aModeBoost = document.getElementById("aModeBoost");

    function setAMode(mode) {
      const boosted = mode === "boost";
      aModeBase.classList.toggle("active", !boosted);
      aModeBoost.classList.toggle("active", boosted);
      aPrice.textContent = boosted ? "251.4万円" : "248.7万円";
      aSub.textContent = boosted ? "写真入力後 / 信頼度 91% / 査定レンジ -11万円" : "現在相場 / 信頼度 82% / 2021年式 31,400km";
      aScore.textContent = boosted ? "91" : "84";
      aRange.textContent = boosted ? "誤差 ±5.4万" : "+7.9万";
      aChartNote.textContent = boosted ? "写真3枚で査定精度アップ。売り時の判断がしやすい。" : "今売るより 8週待ちで上振れ見込み";
    }

    aModeBase.addEventListener("click", () => setAMode("base"));
    aModeBoost.addEventListener("click", () => setAMode("boost"));

    const periodButtons = [...document.querySelectorAll(".period-btn")];
    const bHeroValue = document.getElementById("bHeroValue");
    const bHeroSub = document.getElementById("bHeroSub");
    const bFuel = document.getElementById("bFuel");
    const bInsurance = document.getElementById("bInsurance");
    const bService = document.getElementById("bService");
    const bMetaValue = document.getElementById("bMetaValue");
    const bMetaCost = document.getElementById("bMetaCost");
    const bMetaNet = document.getElementById("bMetaNet");
    const bValue1 = document.getElementById("bValue1");
    const bValue2 = document.getElementById("bValue2");
    const bValue3 = document.getElementById("bValue3");
    const bCost1 = document.getElementById("bCost1");
    const bCost2 = document.getElementById("bCost2");
    const bCost3 = document.getElementById("bCost3");
    const bLabel1 = document.getElementById("bLabel1");
    const bLabel2 = document.getElementById("bLabel2");
    const bLabel3 = document.getElementById("bLabel3");
    const bCol2Title = document.getElementById("bCol2Title");
    const bCol3Title = document.getElementById("bCol3Title");

    const bData = {
      month: {
        hero: "今月の手残り 246.5万円",
        heroSub: "査定予測 249.2万円 / 累計出費 2.7万円",
        fuel: "12,800円",
        insurance: "8,400円",
        service: "5,500円",
        metaValue: "249.2万",
        metaCost: "2.7万",
        metaNet: "246.5万",
        cols: [
          { title: "いま", label: "248.7万", valueHeight: 88, costHeight: 18 },
          { title: "1か月後", label: "249.2万", valueHeight: 92, costHeight: 24 },
          { title: "3か月後", label: "247.8万", valueHeight: 90, costHeight: 28 }
        ]
      },
      quarter: {
        hero: "3か月後の手残り 239.8万円",
        heroSub: "査定予測 248.7万円 / 累計出費 8.9万円",
        fuel: "38,400円",
        insurance: "25,200円",
        service: "16,500円",
        metaValue: "248.7万",
        metaCost: "8.9万",
        metaNet: "239.8万",
        cols: [
          { title: "いま", label: "248.7万", valueHeight: 88, costHeight: 18 },
          { title: "1か月後", label: "249.2万", valueHeight: 92, costHeight: 24 },
          { title: "3か月後", label: "248.7万", valueHeight: 90, costHeight: 44 }
        ]
      },
      half: {
        hero: "半年後の手残り 231.4万円",
        heroSub: "査定予測 245.8万円 / 維持費見込み 14.4万円",
        fuel: "76,800円",
        insurance: "50,400円",
        service: "33,000円",
        metaValue: "245.8万",
        metaCost: "14.4万",
        metaNet: "231.4万",
        cols: [
          { title: "いま", label: "248.7万", valueHeight: 88, costHeight: 18 },
          { title: "3か月後", label: "248.7万", valueHeight: 90, costHeight: 44 },
          { title: "半年後", label: "245.8万", valueHeight: 102, costHeight: 62 }
        ]
      }
    };

    function setBPeriod(period) {
      periodButtons.forEach((button) => button.classList.toggle("active", button.dataset.period === period));
      const data = bData[period];
      bHeroValue.textContent = data.hero;
      bHeroSub.innerHTML = data.heroSub.replace(" / ", "<br>");
      bFuel.textContent = data.fuel;
      bInsurance.textContent = data.insurance;
      bService.textContent = data.service;
      bMetaValue.textContent = data.metaValue;
      bMetaCost.textContent = data.metaCost;
      bMetaNet.textContent = data.metaNet;

      bValue1.style.height = data.cols[0].valueHeight + "px";
      bCost1.style.height = data.cols[0].costHeight + "px";
      bValue2.style.height = data.cols[1].valueHeight + "px";
      bCost2.style.height = data.cols[1].costHeight + "px";
      bValue3.style.height = data.cols[2].valueHeight + "px";
      bCost3.style.height = data.cols[2].costHeight + "px";

      bCol2Title.textContent = data.cols[1].title;
      bCol3Title.textContent = data.cols[2].title;
      bLabel1.textContent = data.cols[0].label;
      bLabel2.textContent = data.cols[1].label;
      bLabel3.textContent = data.cols[2].label;
    }

    periodButtons.forEach((button) => {
      button.addEventListener("click", () => setBPeriod(button.dataset.period));
    });

    const compareButtons = [...document.querySelectorAll(".compare-btn")];
    const cOrb = document.getElementById("cOrb");
    const cHeadline = document.getElementById("cHeadline");
    const cSubline = document.getElementById("cSubline");
    const cFillUcar = document.getElementById("cFillUcar");
    const cFillPre = document.getElementById("cFillPre");
    const cFillBulk = document.getElementById("cFillBulk");
    const cValueUcar = document.getElementById("cValueUcar");
    const cValuePre = document.getElementById("cValuePre");
    const cValueBulk = document.getElementById("cValueBulk");
    const cNote = document.getElementById("cNote");

    function setCompare(mode) {
      compareButtons.forEach((button) => button.classList.toggle("active", button.dataset.mode === mode));

      if (mode === "price") {
        cOrb.textContent = "0";
        cHeadline.textContent = "AI査定だけなら電話0本";
        cSubline.textContent = "まずは相場だけ知りたい人向け。売却相談に進む時も担当は1社のみ。";
        cFillUcar.style.width = "4%";
        cFillPre.style.width = "34%";
        cFillBulk.style.width = "78%";
        cValueUcar.textContent = "0本";
        cValuePre.textContent = "3本";
        cValueBulk.textContent = "5〜10本";
        cNote.textContent = "相場チェック段階では、車種・年式・走行距離からまずAI査定。営業電話を受ける前に判断材料を持てる。";
      } else {
        cOrb.textContent = "1";
        cHeadline.textContent = "売却相談でも担当は1社のみ";
        cSubline.textContent = "相場チェックは0本、売却相談に進んでもやり取りは1社だけ。";
        cFillUcar.style.width = "14%";
        cFillPre.style.width = "34%";
        cFillBulk.style.width = "78%";
        cValueUcar.textContent = "1本";
        cValuePre.textContent = "3本";
        cValueBulk.textContent = "5〜10本";
        cNote.textContent = "比較の軸を『連絡本数』にすると、複数社対応の面倒さを避けたい層に差別化が伝わりやすい。";
      }
    }

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => setCompare(button.dataset.mode));
    });

    setActive(0);
    setAMode("base");
    setBPeriod("month");
    setCompare("price");
  </script>
