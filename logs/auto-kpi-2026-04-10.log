      font-weight: 800;
      line-height: 1.8;
      font-size: 14px;
    }

    .thumbs {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 14px;
    }

    .thumb {
      position: relative;
      padding: 12px 10px;
      border-radius: 18px;
      text-align: left;
      border: 1px solid rgba(28,38,99,0.08);
      background: rgba(255,255,255,0.92);
      transition: var(--transition);
      overflow: hidden;
    }

    .thumb::before {
      content: "";
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity var(--transition);
    }

    .thumb-a::before { background: var(--gradient-a); }
    .thumb-b::before { background: var(--gradient-b); }
    .thumb-c::before { background: var(--gradient-c); }

    .thumb strong,
    .thumb span {
      position: relative;
      z-index: 1;
    }

    .thumb strong {
      display: block;
      font-size: 13px;
      line-height: 1.4;
      color: var(--dark-blue);
      margin-bottom: 2px;
    }

    .thumb span {
      display: block;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .thumb.active {
      transform: translateY(-2px);
      box-shadow: 0 16px 34px rgba(28,38,99,0.12);
      border-color: rgba(64,153,255,0.22);
    }

    .thumb.active::before {
      opacity: 1;
    }

    .panel-actions {
      display: flex;
      gap: 10px;
      margin-top: 16px;
    }

    .ghost-btn,
    .primary-btn {
      min-height: 46px;
      padding: 0 18px;
