    .badge-col {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
      flex-shrink: 0;
    }

    .platform,
    .mini-badge,
    .signal {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .platform {
      padding: 8px 12px;
      background: var(--dark-blue);
      color: var(--white);
    }

    .mini-badge {
      padding: 8px 10px;
      background: rgba(248, 76, 162, 0.12);
      color: var(--pink);
      border: 1px solid rgba(248, 76, 162, 0.18);
    }

    .signal {
      padding: 8px 12px;
      color: var(--white);
      background: var(--gradient-primary);
      box-shadow: 0 8px 22px rgba(64, 191, 255, 0.28);
    }

    .hero-card {
      background: linear-gradient(145deg, #0d195f 0%, #19339a 70%, #2448ca 100%);
      color: var(--white);
      border-radius: 22px;
      padding: 18px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 18px 34px rgba(9, 19, 85, 0.24);
    }

    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -40px -40px auto;
      width: 180px;
      height: 180px;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.34), rgba(248, 76, 162, 0));
      pointer-events: none;
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 12px;
    }

    .hero-overline {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.72);
      margin-bottom: 8px;
    }

    .hero-price {
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin: 0;
    }

    .hero-meta {
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.78);
    }

    .hero-tag {
      padding: 10px 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.12);
      font-size: 11px;
      line-height: 1.45;
      font-weight: 700;
      backdrop-filter: blur(10px);
      text-align: right;
    }

    .chart-card,
    .stats-row,
    .compare-card,
    .panel {
      background: var(--white);
      border-radius: 18px;
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: var(--shadow-light);
    }

    .chart-card {
      padding: 14px 14px 12px;
    }

    .chart-header {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-end;
      margin-bottom: 10px;
    }

    .section-title {
      margin: 0;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .section-note {
      margin: 2px 0 0;
      font-size: 11px;
      color: var(--text-gray);
    }

    .chart-value {
      text-align: right;
      font-family: var(--font-number);
      font-size: 24px;
      color: var(--dark-blue);
      line-height: 1;
    }

    .chart-legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 8px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .chart-legend span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .chart-legend i {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .stats-row {
      padding: 14px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .stat-box {
      padding: 10px;
      border-radius: 14px;
      background: #f7f8fe;
      text-align: center;
    }

    .stat-box strong {
      display: block;
      font-family: var(--font-number);
      font-size: 24px;
      color: var(--dark-blue);
      line-height: 1.15;
      margin-bottom: 4px;
    }

    .stat-box span {
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .cta {
      appearance: none;
      border: 0;
      width: 100%;
      min-height: 48px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 14px 26px rgba(64, 191, 255, 0.3);
      transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

    .cta:hover,
    .cta:focus-visible {
      transform: translateY(-1px);
      box-shadow: 0 18px 30px rgba(64, 191, 255, 0.36);
      filter: saturate(1.04);
      outline: none;
    }

    .cta.secondary {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 14px 26px rgba(248, 76, 162, 0.26);
    }

    .panel {
      padding: 14px;
    }

    .meter-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .meter-row {
      display: grid;
      grid-template-columns: 76px 1fr auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      color: var(--text-gray);
    }

    .meter-bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: #edf1f8;
      overflow: hidden;
    }

    .meter-fill {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      width: 0;
      transition: width 0.9s cubic-bezier(.22,1,.36,1);
    }

    .meter-row.active .meter-fill {
      width: var(--value);
    }

    .compare-card {
      padding: 16px 14px;
    }

    .compare-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
    }

    .compare-table {
      display: grid;
      gap: 10px;
    }

    .compare-line {
      display: grid;
      grid-template-columns: 1.1fr 1fr 1fr;
      gap: 8px;
      align-items: center;
      font-size: 12px;
    }

    .compare-line.header {
      color: var(--text-gray);
      font-weight: 700;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--ruled-line);
    }

    .compare-line .label {
      font-weight: 700;
      color: var(--dark-blue);
    }

    .compare-pill {
      padding: 8px 10px;
      border-radius: 14px;
      text-align: center;
      font-weight: 700;
    }

    .compare-pill.good {
      background: rgba(29, 220, 255, 0.14);
      color: #0074c7;
    }

    .compare-pill.bad {
      background: rgba(248, 76, 162, 0.1);
      color: var(--pink);
    }

    .compare-pill.neutral {
      background: #edf1f7;
      color: var(--text-gray);
    }

    .toggle-row {
      display: flex;
      gap: 8px;
    }

    .toggle {
      flex: 1;
      min-height: 42px;
      border-radius: 18px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: #f3f5fb;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.24s ease;
    }

    .toggle.is-on {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 10px 22px rgba(28, 38, 99, 0.2);
    }

    .footer-note {
      font-size: 10px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    .android-accent {
      background: linear-gradient(135deg, #0e845a 0%, #26b279 100%);
    }

    .android-highlight {
      background: linear-gradient(180deg, #f1fff8 0%, #ffffff 100%);
      border: 1px solid rgba(38, 178, 121, 0.18);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .expense-box {
      border-radius: 16px;
      padding: 12px;
      background: #f6fbf8;
    }

    .expense-box strong {
      display: block;
      font-family: var(--font-number);
      font-size: 20px;
      line-height: 1.15;
      color: #0d6f4c;
      margin-bottom: 3px;
    }

    .expense-box span {
      font-size: 11px;
      color: #4e7161;
      line-height: 1.5;
    }

    .floating-badge {
      position: absolute;
      right: 16px;
      bottom: 16px;
      padding: 10px 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.16);
      color: var(--white);
      font-size: 11px;
      font-weight: 700;
      backdrop-filter: blur(8px);
    }

    .comparison-hero {
      background: linear-gradient(145deg, #161f6f 0%, #172459 48%, #27196e 100%);
    }

    .zero-call {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 20px;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.1), rgba(29, 220, 255, 0.12));
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .zero-call strong {
      display: block;
      font-family: var(--font-number);
      font-size: 28px;
      line-height: 1;
      color: var(--pink);
    }

    .zero-call span {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
      margin-top: 4px;
    }

    .ring {
      width: 76px;
      height: 76px;
      position: relative;
      flex-shrink: 0;
    }

    .ring svg {
      width: 100%;
      height: 100%;
      transform: rotate(-90deg);
    }

    .ring-label {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-family: var(--font-number);
      font-size: 22px;
      color: var(--dark-blue);
    }

    .summary-box {
      background: #f7f8fe;
      border-radius: 16px;
      padding: 12px;
      display: grid;
      gap: 10px;
    }

    .summary-item {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      color: var(--text-gray);
    }

    .summary-item strong {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.3;
    }

    .desktop-summary {
      margin-top: 22px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .insight-card {
      background: rgba(255, 255, 255, 0.88);
      border-radius: 18px;
      border: 1px solid rgba(28, 38, 99, 0.06);
      padding: 16px;
      box-shadow: var(--shadow-light);
    }

    .insight-card h2 {
      margin: 0 0 8px;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .insight-card p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .insight-list {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .insight-item {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 12px;
      align-items: start;
      padding-top: 10px;
      border-top: 1px solid var(--ruled-line);
    }

    .insight-item:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .insight-tag {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 34px;
      border-radius: 16px;
      background: #f3f6ff;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      padding: 0 10px;
    }

    .insight-text {
      font-size: 13px;
      line-height: 1.75;
      color: var(--text-gray);
    }

    .insight-text strong {
      color: var(--dark-blue);
    }

    .caption {
      margin-top: 18px;
      text-align: center;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .pulse {
      animation: pulse 2.2s infinite;
    }

    .float {
      animation: float 4.8s ease-in-out infinite;
    }

    .draw-path {
      stroke-dasharray: 520;
      stroke-dashoffset: 520;
      animation: draw 2.2s ease forwards 0.3s;
    }

    @keyframes draw {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.22);
      }
      50% {
        transform: scale(1.03);
        box-shadow: 0 0 0 14px rgba(248, 76, 162, 0);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-5px);
      }
    }

    @media (min-width: 768px) {
      body {
        padding: 28px 20px 56px;
      }

      .kpi-strip {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .screen-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .desktop-summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1120px) {
      .screen-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        ASO検証用ストアスクショプロトタイプ / B案
      </div>
      <h1>数字で勝たせる。<br>ストアPV→DL率 17.3% を 25% へ引き上げるスクショ設計</h1>
      <p class="lead">
        AI査定、出費管理、競合比較をそれぞれ独立した訴求軸に分解し、ストア詳細ページでの理解負荷を下げながら価値を一瞬で伝える構成です。3枚ともダッシュボード風の見せ方に寄せ、数字・比較・進捗バーで「今DLする理由」を可視化します。
      </p>
      <div class="kpi-strip">
        <div class="kpi-card">
          <div class="kpi-label">現状CVR</div>
          <div class="kpi-value">17.3%</div>
          <div class="kpi-sub">ストア詳細ページ → DL</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">目標CVR</div>
          <div class="kpi-value">25.0%</div>
          <div class="kpi-sub"><strong>+7.7pt</strong> の改善余地</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">主要差別化</div>
          <div class="kpi-value">3</div>
          <div class="kpi-sub">AI査定 / 出費管理 / 電話0本訴求</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">オークション規模</div>
          <div class="kpi-value">8,000</div>
          <div class="kpi-sub">入札参加店の規模感を強調</div>
        </div>
      </div>
    </header>

    <div class="controls" aria-label="表示切替">
      <button class="chip active" data-filter="all">3画面を表示</button>
      <button class="chip" data-filter="a">A: AI査定</button>
      <button class="chip" data-filter="b">B: 出費管理 + 将来予測</button>
      <button class="chip" data-filter="c">C: 競合比較 / 電話0本</button>
    </div>

    <section class="hero-panel">
      <div class="screen-grid">
        <article class="phone-wrap" data-screen="a">
          <div class="phone float">
            <div class="camera"></div>
            <div class="screen">
              <div class="statusbar">
                <span>9:41</span>
                <span>UcarPAC</span>
                <span>100%</span>
              </div>
              <div class="screen-content">
                <div class="screen-head">
                  <div>
                    <h2 class="screen-title">ストアスクショA<br>AI査定を全面訴求</h2>
                    <p class="screen-copy">iOS向け。価格が見える、売り時が読める、個人情報なしで始められる。</p>
                  </div>
                  <div class="badge-col">
                    <span class="platform">iOS</span>
                    <span class="mini-badge">個人情報不要</span>
                    <span class="signal">AI予測ON</span>
                  </div>
                </div>

                <section class="hero-card">
                  <div class="hero-top">
                    <div>
                      <div class="hero-overline">AI ESTIMATE / TOYOTA HARRIER Z</div>
                      <p class="hero-price">312万円</p>
                      <div class="hero-meta">
                        2021年式 / 2.0 Z Leather Package / 2.8万km<br>
                        入力完了まで約90秒。価格チェックだけなら連絡先不要。
                      </div>
                    </div>
                    <div class="hero-tag pulse">
                      相場上位帯<br>
                      予測精度 92%
                    </div>
                  </div>
                  <button class="cta" type="button" data-toast="査定フローを再現中です。">今の相場をチェック</button>
                  <div class="floating-badge">3か月後予測 298万円</div>
                </section>

                <section class="chart-card">
                  <div class="chart-header">
                    <div>
                      <h3 class="section-title">価格推移とAI予測</h3>
                      <p class="section-note">現在価格に対して、売り時がひと目で分かる構成</p>
                    </div>
                    <div class="chart-value">-14万円</div>
                  </div>
                  <svg viewBox="0 0 320 176" width="100%" height="176" aria-label="価格推移グラフ">
                    <defs>
                      <linearGradient id="lineA" x1="0%" x2="100%" y1="0%" y2="0%">
                        <stop offset="0%" stop-color="#1ddcff"></stop>
                        <stop offset="100%" stop-color="#f84ca2"></stop>
                      </linearGradient>
                      <linearGradient id="areaA" x1="0%" x2="0%" y1="0%" y2="100%">
                        <stop offset="0%" stop-color="rgba(64,191,255,0.28)"></stop>
                        <stop offset="100%" stop-color="rgba(64,191,255,0.02)"></stop>
                      </linearGradient>
                    </defs>
                    <g>
                      <line x1="24" y1="24" x2="24" y2="148" stroke="#dfe5f0" stroke-width="1"></line>
                      <line x1="24" y1="148" x2="296" y2="148" stroke="#dfe5f0" stroke-width="1"></line>
                      <line x1="24" y1="116" x2="296" y2="116" stroke="#edf1f7" stroke-width="1"></line>
                      <line x1="24" y1="84" x2="296" y2="84" stroke="#edf1f7" stroke-width="1"></line>
                      <line x1="24" y1="52" x2="296" y2="52" stroke="#edf1f7" stroke-width="1"></line>
                      <path d="M24 64 C58 58, 72 54, 96 60 S142 76, 168 70 S220 44, 236 50 S274 66, 296 84 L296 148 L24 148 Z" fill="url(#areaA)"></path>
                      <path class="draw-path" d="M24 64 C58 58, 72 54, 96 60 S142 76, 168 70 S220 44, 236 50 S274 66, 296 84" fill="none" stroke="url(#lineA)" stroke-width="4" stroke-linecap="round"></path>
                      <circle cx="168" cy="70" r="6" fill="#ffffff" stroke="#1ddcff" stroke-width="4"></circle>
                      <circle cx="236" cy="50" r="6" fill="#ffffff" stroke="#f84ca2" stroke-width="4"></circle>
                      <text x="28" y="20" font-size="10" fill="#737373">330万</text>
                      <text x="28" y="48" font-size="10" fill="#737373">320万</text>
                      <text x="28" y="80" font-size="10" fill="#737373">310万</text>
                      <text x="28" y="112" font-size="10" fill="#737373">300万</text>
                      <text x="28" y="144" font-size="10" fill="#737373">290万</text>
                      <text x="22" y="166" font-size="10" fill="#737373">今月</text>
                      <text x="104" y="166" font-size="10" fill="#737373">1か月後</text>
                      <text x="182" y="166" font-size="10" fill="#737373">3か月後</text>
                      <text x="258" y="166" font-size="10" fill="#737373">6か月後</text>
                    </g>
                  </svg>
                  <div class="chart-legend">
                    <span><i style="background:#1ddcff"></i>現在相場</span>
                    <span><i style="background:#f84ca2"></i>AI予測カーブ</span>
                    <span>売り時ピークは今月〜1か月後</span>
                  </div>
                </section>

                <section class="stats-row">
                  <div class="stat-box">
                    <strong>92%</strong>
                    <span>査定精度</span>
                  </div>
                  <div class="stat-box">
                    <strong>90秒</strong>
                    <span>概算入力</span>
                  </div>
                  <div class="stat-box">
                    <strong>0件</strong>
                    <span>営業電話</span>
                  </div>
                </section>

                <section class="panel">
                  <div class="chart-header">
                    <div>
                      <h3 class="section-title">価値訴求の優先順位</h3>
                      <p class="section-note">DL前に見せるべき要素を進捗バーで整理</p>
                    </div>
                  </div>
                  <div class="meter-list" id="meter-a">
                    <div class="meter-row">
                      <span>AI査定</span>
                      <div class="meter-bar"><div class="meter-fill" style="--value:94%;"></div></div>
                      <strong>94%</strong>
                    </div>
                    <div class="meter-row">
                      <span>将来予測</span>
                      <div class="meter-bar"><div class="meter-fill" style="--value:88%;"></div></div>
                      <strong>88%</strong>
                    </div>
                    <div class="meter-row">
                      <span>個人情報不要</span>
                      <div class="meter-bar"><div class="meter-fill" style="--value:91%;"></div></div>
                      <strong>91%</strong>
                    </div>
                  </div>
