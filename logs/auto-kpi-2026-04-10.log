      margin-top: 8px;
      font-size: 12px;
      line-height: 1.6;
      color: #59637f;
    }

    .score-orb {
      width: 92px;
      height: 92px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: conic-gradient(from 180deg, #1ddcff 0 62%, #f84ca2 62% 100%);
      box-shadow: var(--shadow-light);
    }

    .score-orb span {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(255,255,255,0.96);
      color: var(--dark-blue);
      font-size: 26px;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .car-card {
      position: relative;
      z-index: 1;
      margin-top: 16px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
      overflow: hidden;
    }

    .car-visual {
      position: relative;
      height: 150px;
      margin-bottom: 14px;
      border-radius: 18px;
      background:
        radial-gradient(circle at 30% 30%, rgba(255,255,255,0.88), transparent 28%),
        linear-gradient(160deg, #dfe8f9 0%, #f1f6ff 48%, #ffe6f1 100%);
      overflow: hidden;
    }

    .car-road {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 18px;
      height: 12px;
      background: linear-gradient(90deg, rgba(28,38,99,0.22), rgba(28,38,99,0.04));
      border-radius: 999px;
      opacity: 0.28;
    }

    .car-shape {
      position: absolute;
      left: 20px;
      right: 20px;
      bottom: 30px;
      height: 62px;
      border-radius: 26px 30px 18px 18px;
      background: linear-gradient(135deg, #ffffff 0%, #d6e4ff 48%, #c9d8ff 100%);
      box-shadow: 0 14px 28px rgba(28,38,99,0.12);
    }

    .car-shape::before {
      content: "";
      position: absolute;
      left: 40px;
      right: 54px;
      top: -22px;
      height: 34px;
      border-radius: 20px 24px 6px 6px;
      background: linear-gradient(135deg, #fefefe 0%, #d9ecff 100%);
      transform: skewX(-12deg);
    }

    .wheel {
      position: absolute;
      bottom: -10px;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: #25316f;
      box-shadow: inset 0 0 0 8px #7f93d0;
    }

    .wheel.left { left: 48px; }
    .wheel.right { right: 48px; }

    .car-meta {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .car-meta h3 {
      margin: 0 0 4px;
      font-size: 20px;
      line-height: 1.35;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .car-meta p {
      margin: 0;
      font-size: 12px;
      line-height: 1.7;
      color: #5f6881;
    }

    .badge-mini {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 78px;
      min-height: 40px;
      padding: 0 12px;
      border-radius: 16px;
      background: rgba(29,220,255,0.12);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      text-align: center;
    }

    .chart-shell {
      position: relative;
      z-index: 1;
      margin-top: 16px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .chart-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .chart-top strong {
      font-size: 14px;
      color: var(--dark-blue);
    }

    .chart-top span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .chart-svg {
      width: 100%;
      height: 92px;
      display: block;
    }

    .point-labels {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 8px;
      font-size: 11px;
      color: var(--text-gray);
      text-align: center;
    }

    .action-pills {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 8px;
      margin-top: 16px;
    }

    .pill-button {
      flex: 1;
      min-height: 43px;
      padding: 0 14px;
      border-radius: var(--radius-chip);
      background: rgba(255,255,255,0.94);
      border: 1px solid rgba(28,38,99,0.08);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
      transition: var(--transition);
    }

    .pill-button.active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 12px 22px rgba(28,38,99,0.18);
    }

    .cta-main {
      position: relative;
      z-index: 1;
      width: 100%;
      min-height: 54px;
      margin-top: 16px;
      border-radius: 999px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 900;
      box-shadow: 0 18px 34px rgba(64,191,255,0.24);
    }

    .screen-b .hero-band {
      position: relative;
      z-index: 1;
      margin-top: 18px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      backdrop-filter: blur(12px);
      box-shadow: var(--shadow-light);
    }

    .value-line {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
    }

    .value-line strong {
      font-size: 34px;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .value-line span {
      font-size: 12px;
      line-height: 1.7;
      opacity: 0.76;
      text-align: right;
    }

    .expense-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .expense-card {
      padding: 12px 10px;
      border-radius: 18px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: var(--shadow-light);
    }

    .expense-card span {
      display: block;
      font-size: 10px;
      line-height: 1.5;
      opacity: 0.76;
      margin-bottom: 6px;
    }

    .expense-card strong {
      display: block;
      font-size: 16px;
      line-height: 1.2;
      letter-spacing: -0.03em;
    }

    .period-tabs {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 8px;
      margin-top: 16px;
    }

    .period-btn {
      flex: 1;
      min-height: 40px;
      border-radius: 999px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.72);
      font-size: 12px;
      font-weight: 800;
      transition: var(--transition);
    }

    .period-btn.active {
      background: rgba(255,255,255,0.94);
      color: var(--dark-blue);
    }

    .forecast-card {
      position: relative;
      z-index: 1;
      margin-top: 16px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: var(--shadow-light);
      overflow: hidden;
    }

    .forecast-meta {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 12px;
    }

    .forecast-meta .box {
      padding: 10px 8px;
      border-radius: 16px;
      background: rgba(255,255,255,0.08);
      text-align: center;
    }

    .forecast-meta .box span {
      display: block;
      font-size: 10px;
      line-height: 1.5;
      opacity: 0.74;
      margin-bottom: 4px;
    }

    .forecast-meta .box strong {
      display: block;
      font-size: 17px;
      line-height: 1.2;
      letter-spacing: -0.03em;
    }

    .bars {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 10px;
      height: 150px;
      margin-top: 6px;
    }

    .bar-col {
      flex: 1;
      text-align: center;
    }

    .bar-stack {
      position: relative;
      height: 122px;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }

    .bar-value,
    .bar-cost {
      width: 36px;
      border-radius: 16px 16px 10px 10px;
      transition: height 360ms ease;
    }

    .bar-value {
      position: absolute;
      bottom: 0;
      background: linear-gradient(180deg, #67d7ff 0%, #4db4ff 100%);
      box-shadow: 0 12px 24px rgba(77,180,255,0.22);
    }

    .bar-cost {
      position: absolute;
      bottom: 0;
      right: calc(50% - 24px);
      width: 16px;
      background: linear-gradient(180deg, #fbb3d7 0%, #f84ca2 100%);
      box-shadow: 0 10px 18px rgba(248,76,162,0.18);
    }

    .bar-col strong {
      display: block;
      margin-top: 8px;
      font-size: 11px;
      line-height: 1.5;
      color: rgba(255,255,255,0.82);
    }

    .bar-col span {
      display: block;
      margin-top: 2px;
      font-size: 10px;
      line-height: 1.4;
      color: rgba(255,255,255,0.58);
    }

    .screen-c .compare-shell {
      position: relative;
      z-index: 1;
      margin-top: 18px;
      padding: 18px 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.84);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .zero-stage {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 14px;
      align-items: center;
      margin-bottom: 16px;
    }

    .zero-orb {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #ffe3f0 38%, #f84ca2 100%);
      box-shadow: 0 16px 34px rgba(248,76,162,0.22);
    }

    .zero-orb span {
      color: var(--dark-blue);
      font-size: 42px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.06em;
    }

    .zero-copy strong {
      display: block;
      font-size: 22px;
      line-height: 1.25;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
      margin-bottom: 6px;
    }

    .zero-copy p {
      margin: 0;
      font-size: 12px;
      line-height: 1.8;
      color: #5d6882;
    }

    .compare-toggle {
      display: flex;
      gap: 8px;
      margin-bottom: 14px;
    }

    .compare-btn {
      flex: 1;
      min-height: 40px;
      border-radius: 999px;
      background: rgba(255,255,255,0.94);
      border: 1px solid rgba(28,38,99,0.08);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      transition: var(--transition);
    }

    .compare-btn.active {
      background: var(--dark-blue);
      color: var(--white);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 70px 1fr 58px;
      gap: 10px;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid rgba(28,38,99,0.08);
    }

    .compare-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .compare-label {
      font-size: 12px;
      font-weight: 800;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .compare-track {
      position: relative;
      height: 12px;
      border-radius: 999px;
      background: rgba(28,38,99,0.08);
      overflow: hidden;
    }

    .compare-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0;
      border-radius: 999px;
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
      transition: width 360ms ease;
    }

    .compare-fill.pink {
      background: linear-gradient(90deg, #f9b7d8, #f84ca2);
    }

    .compare-value {
      text-align: right;
      font-size: 12px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-note {
      margin: 14px 0 0;
      padding: 12px 14px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(29,220,255,0.09), rgba(248,76,162,0.09));
      font-size: 12px;
      line-height: 1.8;
      color: var(--dark-blue);
    }

    .screen-bottom-note {
      position: relative;
      z-index: 1;
      margin-top: 12px;
      font-size: 11px;
      line-height: 1.7;
      color: rgba(93,104,130,0.88);
    }

    .screen-b .screen-bottom-note {
      color: rgba(255,255,255,0.68);
    }

    .ghost-stars {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .ghost-stars span {
      position: absolute;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255,255,255,0.42);
      animation: twinkle 2.8s ease-in-out infinite;
    }

    .ghost-stars span:nth-child(1) { top: 18%; left: 18%; animation-delay: 0.2s; }
    .ghost-stars span:nth-child(2) { top: 24%; left: 74%; animation-delay: 0.8s; }
    .ghost-stars span:nth-child(3) { top: 38%; left: 62%; animation-delay: 1.2s; }
    .ghost-stars span:nth-child(4) { top: 54%; left: 22%; animation-delay: 1.8s; }
    .ghost-stars span:nth-child(5) { top: 70%; left: 76%; animation-delay: 0.6s; }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      border: 0;
    }

    @media (min-width: 960px) {
      .experience {
        grid-template-columns: minmax(330px, 390px) minmax(0, 1fr);
        align-items: start;
      }

      .panel {
        position: sticky;
        top: 18px;
      }

      .stage {
        padding: 18px 18px 18px;
      }
    }

    @media (max-width: 640px) {
      .page {
        width: min(100%, calc(100% - 16px));
        padding-top: 12px;
      }

      .hero {
        padding: 16px 14px 14px;
        border-radius: 24px;
      }

      .hero-stats {
        grid-template-columns: 1fr;
      }

      .stepper,
      .thumbs,
      .expense-grid,
      .forecast-meta {
        grid-template-columns: 1fr;
      }

      .panel-actions {
        flex-direction: column;
      }

      .phone {
        min-height: 640px;
        height: 76vh;
      }

      .screen {
        padding: 18px 16px 16px;
      }

      .screen-title {
        font-size: 30px;
      }

      .hero-price,
      .zero-stage {
        grid-template-columns: 1fr;
      }

      .score-orb,
      .zero-orb {
        margin: 0 auto;
      }

      .compare-row {
        grid-template-columns: 62px 1fr 52px;
      }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.1); opacity: 0.8; }
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    @keyframes twinkle {
      0%, 100% { opacity: 0.22; transform: scale(0.8); }
      50% { opacity: 0.82; transform: scale(1.25); }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div class="eyebrow">ASO検証 / ストアPV → DL率 17.3% → 25%</div>
      <h1>3つの不安をスワイプで潰す。<br>UcarPACの強みを1枚ずつ刺し分ける。</h1>
      <p class="lead">
        ストア詳細ページで迷う理由を <strong>「相場が分からない」「維持費と未来が見えない」「電話が怖い」</strong> の3つに分解し、
        <strong>AI査定・出費管理・電話0本</strong> をそれぞれ主役にしたスクショA/B/Cを1画面で検証するプロトタイプです。
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="label">対象KPI</span>
          <strong>17.3%</strong>
          <small>ストア詳細ページ閲覧からDLまでの現状CVR</small>
        </div>
        <div class="hero-stat">
          <span class="label">目標</span>
          <strong>25.0%</strong>
          <small>訴求順と1枚目の刺さり方を改善して到達したい水準</small>
        </div>
        <div class="hero-stat">
          <span class="label">今回の勝ち筋</span>
          <strong>3不安診断</strong>
          <small>操作体験で自分ごと化し、スクショ離脱を防ぐ構成</small>
        </div>
      </div>
    </section>

    <section class="experience">
      <aside class="panel">
        <div class="panel-head">
          <span class="panel-kicker" id="panelKicker">STEP 1 / iOS向け</span>
          <div class="scorebox">
            <span class="tiny">DL期待スコア</span>
            <strong id="scoreValue">72</strong>
            <div class="score-meter">
              <div class="score-fill" id="scoreFill"></div>
            </div>
          </div>
        </div>

        <div class="stepper">
          <button class="step-button active" data-go="0" type="button">
            <strong>01 AI査定</strong>
            <span>相場を知りたい</span>
          </button>
          <button class="step-button" data-go="1" type="button">
            <strong>02 出費管理</strong>
            <span>維持費も見たい</span>
          </button>
          <button class="step-button" data-go="2" type="button">
            <strong>03 電話0本</strong>
            <span>営業連絡が怖い</span>
          </button>
        </div>

        <h2 class="panel-title" id="panelTitle">スクショA | AI査定を全面に出す</h2>
        <p class="panel-lead" id="panelLead">
          1枚目で「このアプリなら自分の車の価値がすぐ分かる」と感じさせ、ストア離脱を止める。
        </p>

        <div class="facts">
          <div class="fact">
            <span>狙う感情</span>
            <strong id="factEmotion">見たい。試したい。今すぐ価格を知りたい。</strong>
          </div>
          <div class="fact">
            <span>主メッセージ</span>
            <strong id="factMessage">AIがいまの相場と売り時を予測</strong>
          </div>
          <div class="fact">
            <span>主なCTA</span>
            <strong id="factCTA">3分でAI査定をはじめる</strong>
          </div>
          <div class="fact">
            <span>検証仮説</span>
            <strong id="factHypothesis">「個人情報なし」の即時価値訴求で1枚目CVRを押し上げる</strong>
          </div>
        </div>

        <div class="copy-box" id="copyBox">
          AIがあなたの愛車を査定。個人情報なしで、今の相場と売り時まで見える。
        </div>

        <div class="thumbs">
          <button class="thumb thumb-a active" data-go="0" type="button">
            <strong>A / iOS</strong>
            <span>AI査定を1枚目の主役に</span>
          </button>
          <button class="thumb thumb-b" data-go="1" type="button">
            <strong>B / Android</strong>
            <span>出費管理と未来価値を重ねる</span>
          </button>
          <button class="thumb thumb-c" data-go="2" type="button">
            <strong>C / 比較</strong>
            <span>相場チェックは電話0本を訴求</span>
          </button>
        </div>

        <div class="panel-actions">
          <button class="ghost-btn" id="prevBtn" type="button">前のスクショ</button>
          <button class="primary-btn" id="nextBtn" type="button">次のスクショ</button>
        </div>

        <p class="swipe-hint">
          左右スワイプでも切り替えできます。画面内ボタンで数値や比較条件も変化します。
        </p>
      </aside>

      <section class="stage">
        <div class="stage-top">
          <span class="stage-label" id="stageLabel">STORE SCREENSHOT A / iOS</span>
          <div class="stage-dots" aria-hidden="true">
            <span class="stage-dot active"></span>
            <span class="stage-dot"></span>
            <span class="stage-dot"></span>
          </div>
        </div>

        <div class="phone-wrap">
          <div class="phone">
            <div class="phone-screen" id="swipeArea">
              <div class="track" id="track">
                <article class="screen screen-a active" aria-label="ストアスクショA">
                  <div class="screen-head">
                    <div class="store-chip-row">
                      <span class="store-chip">iOS向け</span>
                      <span class="store-chip pink">個人情報なし</span>
                    </div>
                    <span class="store-chip cyan">1枚目</span>
                  </div>

                  <h2 class="screen-title">AIがいまの相場と<br>売り時を予測</h2>
                  <p class="screen-sub">
                    トヨタ ハリアーの査定イメージ。相場チェックだけなら入力は最小限。まずは見たくなる1枚目。
                  </p>

                  <div class="float one">人気装備あり<br>+2.7万円</div>
                  <div class="float two">個人情報入力<br>まだ不要</div>

                  <div class="hero-price">
                    <div class="price-card">
                      <span class="eyeline">AI査定価格</span>
                      <strong id="aPrice">248.7万円</strong>
                      <small id="aSub">現在相場 / 信頼度 82% / 2021年式 31,400km</small>
                    </div>
                    <div class="score-orb">
                      <span id="aScore">84</span>
                    </div>
                  </div>

                  <div class="car-card">
                    <div class="car-visual">
                      <div class="car-road"></div>
                      <div class="car-shape">
                        <span class="wheel left"></span>
                        <span class="wheel right"></span>
                      </div>
                    </div>
                    <div class="car-meta">
                      <div>
                        <h3>トヨタ ハリアー Z<br>Leather Package</h3>
                        <p>パール / 2WD / パノラミックビュー / JBL / 31,400km</p>
                      </div>
                      <span class="badge-mini" id="aRange">+7.9万</span>
                    </div>
                  </div>

                  <div class="chart-shell">
                    <div class="chart-top">
                      <strong>AI予測レンジ</strong>
                      <span id="aChartNote">今売るより 8週待ちで上振れ見込み</span>
                    </div>
                    <svg class="chart-svg" viewBox="0 0 320 92" aria-hidden="true">
                      <defs>
                        <linearGradient id="aLine" x1="0" x2="1">
                          <stop offset="0%" stop-color="#1ddcff"/>
                          <stop offset="100%" stop-color="#f84ca2"/>
                        </linearGradient>
                      </defs>
                      <path d="M8 70 C52 60, 96 54, 110 52 S170 40, 214 34 S280 26, 312 18" fill="none" stroke="url(#aLine)" stroke-width="5" stroke-linecap="round"/>
