      border-radius: 999px;
      background: linear-gradient(90deg, #1ddcff, #4db4ff, #f84ca2);
      transition: width 400ms ease;
    }

    .stepper {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-bottom: 16px;
    }

    .step-button {
      padding: 12px 10px;
      border-radius: 18px;
      background: rgba(255,255,255,0.9);
      border: 1px solid rgba(28,38,99,0.08);
      color: var(--text-gray);
      text-align: left;
      transition: var(--transition);
      box-shadow: 0 8px 22px rgba(28,38,99,0.06);
    }

    .step-button strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
