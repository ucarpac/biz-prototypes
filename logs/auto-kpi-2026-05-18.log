      color: var(--text-light-blue, #bfdbfe);
    }

    .result-price {
      position: relative;
      margin-top: 2px;
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 54px;
      font-weight: 900;
    }

    .result-note {
      position: relative;
      margin-top: 2px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 600;
    }

    .forecast-panel {
      margin-top: 16px;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: var(--shadow-light);
    }

    .forecast-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .forecast-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 900;
    }

    .forecast-tag {
      min-height: 24px;
      padding: 4px 10px;
      border-radius: 14px;
      background: rgba(248,76,162,0.12);
      color: var(--pink);
      font-size: 10px;
      line-height: 15px;
      font-weight: 900;
      white-space: nowrap;
    }

    .chart {
      position: relative;
      height: 148px;
      margin-top: 16px;
      border-left: 2px solid #e6e6e6;
      border-bottom: 2px solid #e6e6e6;
    }

    .chart-line {
      position: absolute;
      left: 14px;
      right: 8px;
      top: 32px;
      height: 78px;
    }

    .chart-line svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .chart-line path {
      fill: none;
      stroke: var(--pink);
      stroke-width: 5;
      stroke-linecap: round;
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1.6s ease forwards;
    }

    .chart-point {
      position: absolute;
      width: 12px;
      height: 12px;
      border: 3px solid var(--pink);
      border-radius: 50%;
      background: var(--white);
      animation: pop 800ms ease both;
    }

    .chart-point.p1 {
      left: 16px;
      top: 56px;
      animation-delay: 300ms;
    }

    .chart-point.p2 {
      left: 42%;
      top: 74px;
      animation-delay: 600ms;
    }

    .chart-point.p3 {
      right: 10px;
      top: 96px;
      animation-delay: 900ms;
    }

    .chart-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 16px;
    }

    .expense-card {
      min-height: 86px;
      border-radius: 12px;
      background: #ffffff;
      padding: 12px;
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(28,38,99,0.06);
      transition: transform 180ms ease;
    }

    .expense-card.highlight {
      background: linear-gradient(135deg, rgba(29,220,255,0.18), rgba(255,216,232,0.62));
      transform: translateY(-2px);
    }

    .expense-icon {
      width: 26px;
      height: 26px;
      border-radius: 9px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 14px;
      font-weight: 900;
    }

    .expense-label {
      display: block;
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 800;
    }

    .expense-value {
      display: block;
      margin-top: 2px;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
    }

    .swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin: 14px auto 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 700;
    }

    .swipe-arrow {
      width: 32px;
      height: 18px;
      border-radius: 999px;
      background: var(--gradient-primary);
      position: relative;
      animation: nudge 1.4s ease-in-out infinite;
    }

    .swipe-arrow::after {
      content: '';
      position: absolute;
      right: 6px;
      top: 5px;
      width: 7px;
      height: 7px;
      border-top: 2px solid var(--dark-blue);
      border-right: 2px solid var(--dark-blue);
      transform: rotate(45deg);
    }

    .compare-card {
      margin-top: 16px;
      border-radius: 13px;
      overflow: hidden;
      background: var(--white);
      box-shadow: var(--shadow-medium);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 0.9fr 0.9fr;
      min-height: 54px;
      align-items: center;
      border-bottom: 1px solid var(--ruled-line);
    }

    .compare-row:last-child {
      border-bottom: 0;
    }

    .compare-cell {
      padding: 10px 8px;
      color: var(--text-black);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 800;
      text-align: center;
    }

    .compare-head {
      background: var(--dark-blue);
    }

    .compare-head .compare-cell {
      color: var(--white);
      font-size: 10px;
      line-height: 15px;
    }

    .compare-cell:first-child {
      text-align: left;
      padding-left: 12px;
    }

    .good {
      color: var(--pink);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
    }

    .bad {
      color: var(--text-disabled);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
    }

    .phone-zero {
      margin-top: 16px;
      padding: 18px 14px;
      border-radius: 13px;
      background: var(--gradient-pink);
      color: var(--white);
      text-align: center;
      box-shadow: 0 12px 24px rgba(248,76,162,0.24);
    }

    .phone-zero span {
      display: block;
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
    }

    .phone-zero strong {
      display: block;
      margin-top: 2px;
      font-size: 44px;
      line-height: 66px;
      font-weight: 900;
    }

    .auction-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .auction-chip {
      min-height: 32px;
      padding: 7px 11px;
      border-radius: 18px;
      background: rgba(9,19,85,0.08);
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 900;
    }

    .download-panel {
      margin-top: 16px;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: var(--shadow-light);
    }

    .download-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
      text-align: center;
    }

    .download-meter {
      position: relative;
      height: 14px;
      margin-top: 14px;
      border-radius: 999px;
      background: #e5e5e5;
      overflow: hidden;
    }

    .download-meter span {
      position: absolute;
      inset: 0 auto 0 0;
      width: 69%;
      border-radius: inherit;
      background: var(--gradient-primary);
      animation: meterGrow 1.1s ease forwards;
    }

    .download-caption {
      margin: 8px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 700;
      text-align: center;
    }

    .dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 14px;
    }

    .dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: #cacaca;
      transition: width 220ms ease, background 220ms ease;
    }

    .dot.active {
      width: 28px;
      background: var(--pink);
    }

    .floating-score {
      position: absolute;
      right: 18px;
      top: 112px;
      width: 74px;
      height: 74px;
      border-radius: 24px;
      background: var(--dark-blue);
      color: var(--white);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      box-shadow: 0 12px 26px rgba(28,38,99,0.28);
      animation: floaty 3s ease-in-out infinite;
    }

    .floating-score span {
      font-size: 10px;
      line-height: 15px;
      font-weight: 800;
      color: #bfdbfe;
    }

    .floating-score strong {
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 32px;
      font-weight: 900;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      z-index: 40;
      transform: translate(-50%, 18px);
      width: min(90%, 340px);
      min-height: 48px;
      padding: 13px 16px;
      border-radius: 24px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 800;
      text-align: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    @keyframes shine {
      0% {
        transform: translateX(-100%);
      }
      48% {
        transform: translateX(100%);
      }
      100% {
        transform: translateX(100%);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes pop {
      from {
        transform: scale(0);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    @keyframes nudge {
      0%, 100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(8px);
      }
    }

    @keyframes meterGrow {
      from {
        width: 0;
      }
      to {
        width: 69%;
      }
    }

    @keyframes floaty {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-8px);
      }
    }

    @media (min-width: 760px) {
      .page {
        padding: 28px 24px 40px;
      }

      .prototype-header {
        display: grid;
        grid-template-columns: 1fr 320px;
        align-items: end;
        gap: 24px;
        padding-bottom: 24px;
      }

      .hero-title {
        font-size: 32px;
        line-height: 48px;
      }

      .controller {
        border-radius: 18px;
        margin: 0 0 22px;
      }

      .screen-panel {
        padding: 8px 14px 18px;
      }

      .store-card {
        max-width: 430px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header class="prototype-header">
      <div>
        <a class="back-link" href="../index.html">Reports に戻る</a>
        <h1 class="hero-title">ストアPVからDLへつなげる、体験型スクショ検証</h1>
        <p class="hero-copy">AI査定、出費管理、電話0本の差別化をスワイプで比較できるストア向けプロトタイプ。</p>
      </div>
      <div class="kpi-strip" aria-label="対象KPI">
        <div class="kpi-card">
          <span class="kpi-label">現状DL率</span>
          <span class="kpi-value">17.3%</span>
        </div>
        <div class="kpi-card goal">
          <span class="kpi-label">目標DL率</span>
          <span class="kpi-value">25%</span>
        </div>
      </div>
