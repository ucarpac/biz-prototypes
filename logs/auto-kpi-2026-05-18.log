  <script>
    const navButtons = document.querySelectorAll('.screen-nav button');
    const shotCards = document.querySelectorAll('.shot-card');
    const copyChips = document.querySelectorAll('#copyChips button');
    const impactSlider = document.getElementById('impactSlider');
    const impactValue = document.getElementById('impactValue');
    const impactText = document.getElementById('impactText');
    const saveButton = document.getElementById('saveButton');
    const compactToggle = document.getElementById('compactToggle');

    function setActiveShot(targetId) {
      navButtons.forEach((button) => {
        button.classList.toggle('active', button.dataset.target === targetId);
      });

      shotCards.forEach((card) => {
        card.classList.toggle('active', card.id === targetId);
      });
    }

    navButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setActiveShot(button.dataset.target);
      });
    });

    copyChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        copyChips.forEach((item) => item.classList.remove('active'));
        chip.classList.add('active');

        if (chip.dataset.copy === '安心') {
          impactText.textContent = '不安解消コピーの期待値';
          setActiveShot('shotA');
        }

        if (chip.dataset.copy === '価格') {
          impactText.textContent = '価格訴求コピーの期待値';
          setActiveShot('shotB');
        }

        if (chip.dataset.copy === '電話不安') {
          impactText.textContent = '電話0本コピーの期待値';
          setActiveShot('shotC');
        }
      });
    });

    function updateImpact() {
      const raw = Number(impactSlider.value);
      const current = 17.3;
      const target = 25.0;
      const simulated = current + ((target - current) * raw / 100);
      impactValue.textContent = simulated.toFixed(1) + '%';
    }

    impactSlider.addEventListener('input', updateImpact);
    updateImpact();

    saveButton.addEventListener('click', () => {
      const saved = saveButton.classList.toggle('saved');
      saveButton.textContent = saved ? '反映済み: 2026-05-18' : 'kpi-historyに反映';
      saveButton.setAttribute('aria-pressed', saved ? 'true' : 'false');
    });

    compactToggle.addEventListener('click', () => {
      document.body.classList.toggle('compact');
      const compact = document.body.classList.contains('compact');
      compactToggle.textContent = compact ? '通常表示' : '表示切替';

      document.querySelectorAll('.shot-meta').forEach((meta) => {
        meta.style.display = compact ? 'none' : 'grid';
      });
    });
  </script>
</body>
