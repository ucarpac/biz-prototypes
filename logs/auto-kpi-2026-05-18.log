                  <span class="swipe-arrow"></span>
                </div>
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <div class="dots" aria-label="現在位置">
      <span class="dot active"></span>
      <span class="dot"></span>
      <span class="dot"></span>
    </div>
  </main>

  <div class="toast" id="toast">操作しました</div>

  <script>
    const screens = document.getElementById('screens');
    const tabs = Array.from(document.querySelectorAll('.tab-button'));
    const dots = Array.from(document.querySelectorAll('.dot'));
    const toast = document.getElementById('toast');
    let currentIndex = 0;
    let startX = 0;
    let dragging = false;

    function showToast(text) {
      toast.textContent = text;
      toast.classList.add('show');
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(function () {
        toast.classList.remove('show');
      }, 1600);
    }

    function setScreen(index) {
      currentIndex = Math.max(0, Math.min(2, index));
      screens.style.transform = 'translateX(' + (-currentIndex * 33.333333) + '%)';
      tabs.forEach(function (tab, i) {
        tab.classList.toggle('active', i === currentIndex);
      });
      dots.forEach(function (dot, i) {
        dot.classList.toggle('active', i === currentIndex);
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        setScreen(Number(tab.dataset.index));
      });
    });

    screens.addEventListener('pointerdown', function (event) {
      dragging = true;
      startX = event.clientX;
    });

    screens.addEventListener('pointerup', function (event) {
      if (!dragging) return;
      dragging = false;
      const delta = event.clientX - startX;
      if (Math.abs(delta) < 42) return;
      if (delta < 0) {
        setScreen(currentIndex + 1);
      } else {
        setScreen(currentIndex - 1);
      }
    });

    screens.addEventListener('pointercancel', function () {
      dragging = false;
    });

    const chipButtons = Array.from(document.querySelectorAll('.chip-button'));
    const estimatePrice = document.getElementById('estimatePrice');
    const thirdStep = document.getElementById('thirdStep');
    const aiMessage = document.getElementById('aiMessage');
    const aiCarCard = document.getElementById('aiCarCard');

    chipButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        chipButtons.forEach(function (chip) {
          chip.classList.remove('selected');
        });
        button.classList.add('selected');
        estimatePrice.textContent = button.dataset.price;
        thirdStep.classList.add('done');
        aiMessage.classList.add('show');
        aiCarCard.classList.add('selected');
        showToast('カラー条件を反映しました');
      });
    });

    document.getElementById('aiButton').addEventListener('click', function () {
      thirdStep.classList.add('done');
      aiMessage.classList.add('show');
      showToast('AI査定結果を更新しました');
    });

    const expenseCards = Array.from(document.querySelectorAll('.expense-card'));
    const expenseMessage = document.getElementById('expenseMessage');
    const expenseTexts = {
      gas: 'ガソリン代は前月比+2,140円です',
      insurance: '保険料は年間93,600円で安定しています',
      inspection: '次回車検までの積立目安は月12,500円です',
      repair: 'メンテナンス費は平均より低めです'
    };

    expenseCards.forEach(function (card) {
      card.addEventListener('click', function () {
        expenseCards.forEach(function (item) {
          item.classList.remove('highlight');
        });
        card.classList.add('highlight');
        expenseMessage.textContent = expenseTexts[card.dataset.expense];
        showToast('出費カテゴリを切り替えました');
      });
    });

    document.getElementById('expenseButton').addEventListener('click', function () {
      expenseMessage.textContent = '3か月以内の売却なら下落予測を抑えやすいです';
      showToast('売り時診断を表示しました');
    });

    document.getElementById('compareButton').addEventListener('click', function () {
      showToast('電話0本訴求をストアスクショCに反映済みです');
    });

    setScreen(0);
  </script>
</body>
</html>
