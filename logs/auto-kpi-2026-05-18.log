    <section class="controller" aria-label="スクリーンショット切り替え">
      <div class="tabs">
        <button class="tab-button active" type="button" data-index="0">A AI査定</button>
        <button class="tab-button" type="button" data-index="1">B 出費管理</button>
        <button class="tab-button" type="button" data-index="2">C 電話0本</button>
      </div>
    </section>

    <section class="stage" aria-label="ストアスクリーンショット案">
      <div class="screens" id="screens">
        <article class="screen-panel">
          <div class="store-card">
            <div class="store-inner">
              <div class="status-bar">
                <span>9:41</span>
                <span class="phone-icons">
                  <span class="dot-icon"></span>
                  <span class="dot-icon"></span>
                  <span class="dot-icon"></span>
                  <span class="battery"></span>
                </span>
              </div>

              <div class="app-screen">
                <div class="store-shot-header">
                  <div class="mini-logo">
                    <span class="logo-mark">U</span>
                    <span>UcarPAC</span>
                  </div>
                  <span class="badge">個人情報不要</span>
                </div>

                <h2 class="shot-title">AIが愛車の<br><span class="accent">今の価値</span>を診断</h2>
                <p class="shot-subtitle">メーカー・年式・走行距離だけで概算価格をチェック。</p>

                <div class="phone-card">
                  <div class="car-card selected" id="aiCarCard">
                    <div class="car-image" aria-hidden="true">
                      <div class="car-roof"></div>
                      <div class="car-window"></div>
                      <div class="car-body"></div>
                      <div class="wheel left"></div>
                      <div class="wheel right"></div>
                    </div>
                    <div class="car-meta">
                      <p class="car-name">トヨタ ハリアー</p>
                      <p class="car-detail">2020年式 / Z レザーパッケージ<br>走行距離 36,000km</p>
                      <div class="estimate-box">
                        <span class="estimate-label">AI概算価格</span>
                        <span class="estimate-price"><strong id="estimatePrice">286</strong><span>万円</span></span>
                      </div>
                    </div>
                  </div>

                  <div class="step-track" aria-label="診断ステップ">
                    <div class="step-node done"><span></span></div>
                    <div class="step-node done"><span></span></div>
                    <div class="step-node" id="thirdStep"><span></span></div>
                  </div>

                  <div class="quiz-area">
                    <span class="quiz-label">ボディカラーを選ぶと精度アップ</span>
                    <div class="chip-grid">
                      <button class="chip-button selected" type="button" data-price="286">パール白</button>
                      <button class="chip-button" type="button" data-price="278">黒</button>
                      <button class="chip-button" type="button" data-price="270">シルバー</button>
                      <button class="chip-button" type="button" data-price="262">その他</button>
                    </div>
                    <div class="button-row">
                      <button class="primary-button" type="button" id="aiButton">AI査定を進める</button>
                    </div>
                    <p class="micro-message" id="aiMessage">査定精度が92%まで上がりました</p>
                  </div>
                </div>

                <div class="result-banner">
                  <span class="result-label">オークション期待額</span>
                  <div class="result-price">312万円</div>
                  <div class="result-note">8,000店が競るから、最高額を狙える</div>
                </div>

                <div class="swipe-hint">
                  <span>横スワイプで別案を見る</span>
                  <span class="swipe-arrow"></span>
                </div>
              </div>
            </div>
          </div>
        </article>

        <article class="screen-panel">
          <div class="store-card">
            <div class="store-inner">
              <div class="status-bar">
                <span>9:41</span>
                <span class="phone-icons">
                  <span class="dot-icon"></span>
                  <span class="dot-icon"></span>
                  <span class="dot-icon"></span>
                  <span class="battery"></span>
                </span>
              </div>

              <div class="app-screen">
                <div class="store-shot-header">
                  <div class="mini-logo">
                    <span class="logo-mark">U</span>
                    <span>UcarPAC</span>
                  </div>
                  <span class="badge">Android向け</span>
                </div>

                <h2 class="shot-title">売り時も<br><span class="accent">維持費</span>も見える</h2>
                <p class="shot-subtitle">将来予測と出費管理で、車の資産価値を毎月チェック。</p>

                <div class="forecast-panel">
                  <div class="forecast-head">
                    <h3 class="forecast-title">レクサス NX 予測相場</h3>
                    <span class="forecast-tag">6か月予測</span>
                  </div>
                  <div class="chart" aria-label="将来予測グラフ">
                    <div class="chart-line">
                      <svg viewBox="0 0 300 90" aria-hidden="true">
                        <path d="M 4 28 C 78 22, 112 44, 152 54 S 240 72, 296 78"></path>
                      </svg>
                    </div>
                    <span class="chart-point p1"></span>
                    <span class="chart-point p2"></span>
                    <span class="chart-point p3"></span>
                  </div>
                  <div class="chart-labels">
                    <span>今月 418万円</span>
                    <span>3か月 402万円</span>
                    <span>6か月 386万円</span>
                  </div>
                </div>

                <div class="expense-grid">
                  <button class="expense-card highlight" type="button" data-expense="gas">
                    <span class="expense-icon">G</span>
                    <span class="expense-label">今月のガソリン</span>
                    <span class="expense-value">18,420円</span>
                  </button>
                  <button class="expense-card" type="button" data-expense="insurance">
                    <span class="expense-icon">保</span>
                    <span class="expense-label">自動車保険</span>
                    <span class="expense-value">7,800円</span>
                  </button>
                  <button class="expense-card" type="button" data-expense="inspection">
                    <span class="expense-icon">車</span>
                    <span class="expense-label">車検積立</span>
                    <span class="expense-value">12,500円</span>
                  </button>
                  <button class="expense-card" type="button" data-expense="repair">
                    <span class="expense-icon">修</span>
                    <span class="expense-label">メンテナンス</span>
                    <span class="expense-value">4,900円</span>
                  </button>
                </div>

                <div class="download-panel">
                  <h3 class="download-title">今月の車コスト診断</h3>
                  <div class="download-meter"><span></span></div>
                  <p class="download-caption" id="expenseMessage">年間維持費の予測は523,440円です</p>
                  <div class="button-row">
                    <button class="primary-button" type="button" id="expenseButton">売り時を診断</button>
                  </div>
                </div>

                <div class="swipe-hint">
                  <span>タップでカテゴリを切り替え</span>
                  <span class="swipe-arrow"></span>
                </div>
              </div>
            </div>
          </div>
        </article>

        <article class="screen-panel">
          <div class="store-card">
            <div class="store-inner">
              <div class="status-bar">
                <span>9:41</span>
                <span class="phone-icons">
                  <span class="dot-icon"></span>
                  <span class="dot-icon"></span>
                  <span class="dot-icon"></span>
                  <span class="battery"></span>
                </span>
              </div>

              <div class="app-screen">
                <div class="store-shot-header">
                  <div class="mini-logo">
                    <span class="logo-mark">U</span>
                    <span>UcarPAC</span>
                  </div>
                  <span class="badge">競合比較</span>
                </div>

                <h2 class="shot-title">相場チェックは<br><span class="accent">電話0本</span></h2>
                <p class="shot-subtitle">まず価格だけ見たい人も、営業電話を気にせず使える。</p>

                <div class="phone-zero">
                  <span>個人情報なしのAI査定なら</span>
                  <strong>電話0本</strong>
                  <span>売却相談に進むまで連絡なし</span>
                </div>

                <div class="compare-card">
                  <div class="compare-row compare-head">
                    <div class="compare-cell">比較項目</div>
                    <div class="compare-cell">UcarPAC</div>
                    <div class="compare-cell">一括査定</div>
                  </div>
                  <div class="compare-row">
                    <div class="compare-cell">個人情報不要査定</div>
                    <div class="compare-cell good">○</div>
                    <div class="compare-cell bad">×</div>
                  </div>
                  <div class="compare-row">
                    <div class="compare-cell">査定前の電話</div>
                    <div class="compare-cell good">0本</div>
                    <div class="compare-cell bad">複数社</div>
                  </div>
                  <div class="compare-row">
                    <div class="compare-cell">将来予測</div>
                    <div class="compare-cell good">○</div>
                    <div class="compare-cell bad">×</div>
                  </div>
                  <div class="compare-row">
                    <div class="compare-cell">出費管理</div>
                    <div class="compare-cell good">○</div>
                    <div class="compare-cell bad">×</div>
                  </div>
