  <script>
    const filterButtons = document.querySelectorAll("[data-filter]");
    const variantCards = document.querySelectorAll("[data-variant]");
    const shotButtons = document.querySelectorAll("[data-shot]");
    const testToggle = document.getElementById("testToggle");
    const toast = document.getElementById("toast");
    let toastTimer = null;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.remove("show");
      }, 1800);
    }

    function setFilter(filter) {
      filterButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.filter === filter);
      });

      variantCards.forEach((card) => {
        const isAll = filter === "all";
        const isTarget = card.dataset.variant === filter;
        card.classList.toggle("is-active", isAll || isTarget);
        card.classList.toggle("is-muted", !isAll && !isTarget);
      });

      const label = filter === "all" ? "全案" : `${filter.toUpperCase()}案`;
      showToast(`${label}を表示しました`);
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setFilter(button.dataset.filter);
      });
    });

    shotButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const shot = button.dataset.shot;
        showToast(`${shot}案をテスト候補に追加しました`);
        setFilter(shot.toLowerCase());
      });
    });

    testToggle.addEventListener("click", () => {
      testToggle.classList.toggle("on");
      const isOn = testToggle.classList.contains("on");
      showToast(isOn ? "A/Bテスト状態をONにしました" : "A/Bテスト状態をOFFにしました");
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.style.animationPlayState = "running";
        }
      });
    }, { threshold: 0.18 });

    document.querySelectorAll(".fade-in").forEach((node) => {
      node.style.animationPlayState = "paused";
      observer.observe(node);
    });
  </script>
