      line-height: 16.5px;
    }

    .sparkline {
      position: relative;
      height: 82px;
      margin-top: 10px;
      background:
        linear-gradient(180deg, rgba(28,38,99,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(28,38,99,0.04) 1px, transparent 1px);
      background-size: 100% 27px, 48px 100%;
      border-radius: 10px;
    }

    .sparkline svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .sparkline path {
      fill: none;
      stroke: var(--pink);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 220;
      stroke-dashoffset: 220;
      animation: drawLine 1.6s ease forwards;
    }

    .sparkline circle {
      fill: var(--white);
      stroke: var(--pink);
      stroke-width: 3;
      animation: dotPop 1.6s ease forwards;
    }

    .cta-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 43px;
      margin-top: 14px;
      padding: 0 18px;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      border-radius: var(--radius-button);
      box-shadow: 0 10px 18px rgba(64,153,255,0.22);
      font-size: 14px;
      font-weight: 900;
      line-height: 21px;
    }

    .warm-link {
      display: block;
      margin-top: 10px;
      color: var(--pink);
      font-size: 12px;
      font-weight: 900;
      line-height: 18px;
      text-align: center;
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 16px;
    }

    .expense-tile {
      min-height: 88px;
      padding: 12px;
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.10);
      border-radius: 12px;
      box-shadow: 0 7px 18px rgba(0,0,0,0.05);
    }

    .expense-tile.wide {
      grid-column: 1 / -1;
    }

    .expense-label {
      margin: 0;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 800;
      line-height: 15px;
    }

    .expense-value {
      margin: 2px 0 0;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 22px;
      font-weight: 900;
      line-height: 33px;
    }

    .expense-value small {
      font-family: var(--font-sans);
      font-size: 11px;
      line-height: 16.5px;
    }

    .bar-list {
      display: grid;
      gap: 8px;
      margin-top: 10px;
    }

    .bar-line {
      display: grid;
      grid-template-columns: 48px 1fr 42px;
      align-items: center;
      gap: 8px;
      font-size: 10px;
      font-weight: 800;
      line-height: 15px;
      color: var(--text-gray);
    }

    .bar-track {
      height: 8px;
      background: var(--back-gray);
      border-radius: 999px;
      overflow: hidden;
    }

    .bar-track span {
      display: block;
      height: 100%;
      background: var(--gradient-primary);
      border-radius: inherit;
      animation: barGrow 900ms ease both;
    }

    .bar-track .pink-bar {
      background: var(--gradient-pink);
    }

    .forecast-ribbon {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      margin-top: 14px;
      padding: 12px;
      color: var(--dark-blue);
      background: #fff2df;
      border: 1px dashed rgba(255,179,107,0.9);
      border-radius: 12px;
    }

    .forecast-ribbon strong {
      font-size: 13px;
      font-weight: 900;
      line-height: 19.5px;
    }

    .forecast-ribbon span {
      color: var(--pink);
      font-family: var(--font-number);
      font-size: 25px;
      font-weight: 900;
      line-height: 37.5px;
    }

    .compare-board {
      margin-top: 16px;
      overflow: hidden;
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.10);
      border-radius: 12px;
      box-shadow: 0 10px 24px rgba(0,0,0,0.08);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
      gap: 10px;
      min-height: 52px;
      padding: 10px 12px;
      border-bottom: 1px solid var(--ruled-line);
    }

    .compare-row:last-child {
      border-bottom: 0;
    }

    .compare-name {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      line-height: 18px;
    }

    .compare-value {
      justify-self: end;
      padding: 6px 9px;
      color: var(--text-black);
      background: var(--back-gray);
      border-radius: var(--radius-chip);
      font-size: 11px;
      font-weight: 900;
      line-height: 16.5px;
      white-space: nowrap;
    }

    .compare-value.best {
      color: var(--white);
      background: var(--pink);
      box-shadow: 0 6px 14px rgba(248,76,162,0.25);
    }

    .phone-note {
      margin: 10px 0 0;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .comfort-message {
      margin-top: 16px;
      padding: 13px;
      color: var(--dark-blue);
      background: #fff7d9;
      border: 1px solid rgba(255,179,107,0.55);
      border-radius: 12px;
      font-size: 12px;
      font-weight: 900;
      line-height: 18px;
      text-align: center;
    }

    .shot-meta {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .meta-line {
      display: grid;
      grid-template-columns: 94px 1fr;
      gap: 10px;
      padding: 10px 12px;
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(28,38,99,0.08);
      border-radius: 12px;
      font-size: 12px;
      line-height: 18px;
    }

    .meta-line strong {
      color: var(--dark-blue);
      font-weight: 900;
    }

    .controls-panel {
      padding: 16px;
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.08);
      border-radius: var(--radius-lg);
      box-shadow: 0 14px 32px rgba(28,38,99,0.08);
    }

    .controls-panel h3 {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 900;
      line-height: 27px;
    }

    .control-block {
      padding: 14px 0;
      border-top: 1px solid var(--ruled-line);
    }

    .control-block:first-of-type {
      border-top: 0;
      padding-top: 0;
    }

    .control-label {
      display: block;
      margin-bottom: 8px;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 800;
      line-height: 18px;
    }

    .chip-set {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chip-set button {
      min-height: 36px;
      padding: 0 12px;
      color: var(--text-black);
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.12);
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 800;
      line-height: 18px;
    }

    .chip-set button.active {
      color: var(--white);
      background: var(--pink);
      border-color: var(--pink);
    }

    .impact-slider {
      width: 100%;
      accent-color: var(--pink);
    }

    .impact-output {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 12px;
      margin-top: 8px;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
      line-height: 19.5px;
    }

    .impact-output strong {
      font-family: var(--font-number);
      font-size: 24px;
      font-weight: 900;
      line-height: 36px;
    }

    .save-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 43px;
      color: var(--white);
      background: var(--gradient-pink);
      border-radius: var(--radius-button);
      box-shadow: 0 10px 18px rgba(248,76,162,0.20);
      font-size: 14px;
      font-weight: 900;
      line-height: 21px;
    }

    .save-button.saved {
      color: var(--dark-blue);
      background: var(--warm-yellow);
    }

    .ops-grid {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    .ops-item {
      padding: 16px;
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.08);
      border-radius: var(--radius-card);
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .ops-item h3 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 900;
      line-height: 24px;
    }

    .ops-item p {
      margin: 8px 0 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 19.5px;
    }

    .ops-item code {
      padding: 2px 5px;
      color: var(--dark-blue);
      background: var(--back-gray);
      border-radius: 5px;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 12px;
    }

    .history-table {
      width: 100%;
      margin-top: 8px;
      border-collapse: collapse;
      font-size: 12px;
      line-height: 18px;
      overflow: hidden;
      border-radius: 12px;
    }

    .history-table th,
    .history-table td {
      padding: 10px 8px;
      border-bottom: 1px solid var(--ruled-line);
      text-align: left;
      vertical-align: top;
    }

    .history-table th {
      color: var(--dark-blue);
      background: #fff7fb;
      font-weight: 900;
    }

    .history-table td {
      color: var(--text-black);
      background: var(--white);
    }

    .source-list {
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .source-list li {
      padding: 12px;
      background: var(--white);
      border: 1px solid rgba(28,38,99,0.08);
      border-radius: 12px;
      font-size: 12px;
      line-height: 18px;
    }

    .source-list strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 900;
      line-height: 19.5px;
    }

    .source-list span {
      display: block;
      margin-top: 3px;
      color: var(--text-gray);
    }

    .source-list a {
      word-break: break-all;
    }

    @keyframes carFloat {
      0%,
      100% {
        transform: translateX(-50%) translateY(0);
      }
      50% {
        transform: translateX(-50%) translateY(-5px);
      }
    }

    @keyframes gentlePulse {
      0%,
      100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.04);
      }
    }

    @keyframes shotIn {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes dotPop {
      0%,
      70% {
        transform: scale(0);
        transform-origin: center;
      }
      100% {
        transform: scale(1);
        transform-origin: center;
      }
    }

    @keyframes barGrow {
      from {
        width: 0;
      }
    }

    @media (min-width: 720px) {
      .page {
        padding: 20px 24px 64px;
      }

      .top-bar {
        margin: 0 -24px 20px;
        padding: 12px 24px;
      }

      .hero-grid {
        grid-template-columns: 1.08fr 0.92fr;
        align-items: center;
      }

      .kpi-strip {
        grid-template-columns: repeat(3, 1fr);
      }

      .prototype-stage {
        grid-template-columns: minmax(390px, 1fr) 340px;
      }

      .shot-viewer {
        min-height: 790px;
        padding: 24px;
      }

      .store-shot {
        width: 360px;
      }

      .phone-screen {
        min-height: 720px;
      }

      .shot-content {
        min-height: 688px;
        padding: 22px;
      }

      .ops-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (min-width: 1040px) {
      .hero {
        padding-top: 38px;
      }

      .store-shot {
        width: 382px;
      }

      .shot-viewer {
        min-height: 842px;
      }

      .phone-screen {
        min-height: 760px;
      }

      .shot-content {
        min-height: 728px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <div class="top-bar">
    <div class="brand-lockup">
      <div class="brand-mark">U</div>
      <div class="brand-text">
        <strong>UcarPAC App ASO</strong>
        <span>2026-05-18 日次差分</span>
      </div>
    </div>
    <div class="top-actions">
      <a href="#screens">スクショ</a>
      <a href="#ops">反映</a>
      <button type="button" id="compactToggle">表示切替</button>
    </div>
  </div>

  <main class="page">
    <section class="hero" aria-labelledby="heroTitle">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">ストアPV→DL率 17.3% から 25%へ</p>
          <h1 id="heroTitle">売る前の不安を、最初の3枚で軽くする。</h1>
          <p class="hero-lead">
            AI査定、出費管理、相場チェック時の電話0本を、ストアスクリーンショットで直感的に伝える検証案です。
            暖かいトーンで「今すぐ申込」より先に「安心して試せる」感情を作ります。
          </p>
          <p class="marker-note">検証仮説: 価格の納得感と電話不安の解消を先に見せるとDL率が上がる</p>
        </div>
        <div class="hero-panel" aria-hidden="true">
          <div class="soft-illustration">
            <div class="heart-chip">安心して相場チェック</div>
            <div class="car-doodle">
              <div class="car-roof"></div>
              <div class="car-window"></div>
              <div class="car-window second"></div>
              <div class="car-body"></div>
              <div class="wheel left"></div>
              <div class="wheel right"></div>
            </div>
            <div class="road-line"></div>
          </div>
        </div>
      </div>

      <div class="kpi-strip" aria-label="KPIサマリー">
        <div class="kpi-card">
          <p class="kpi-label">現状CVR</p>
          <div class="kpi-value">17.3<small>%</small></div>
          <div class="kpi-progress"><span style="width:69.2%"></span></div>
        </div>
        <div class="kpi-card">
          <p class="kpi-label">目標CVR</p>
          <div class="kpi-value">25.0<small>%</small></div>
          <div class="kpi-progress"><span style="width:100%"></span></div>
        </div>
        <div class="kpi-card">
          <p class="kpi-label">必要差分</p>
          <div class="kpi-value">+7.7<small>pt</small></div>
          <div class="kpi-progress"><span style="width:77%"></span></div>
        </div>
      </div>
    </section>

    <section id="screens" aria-labelledby="screensTitle">
      <div class="section-head">
        <div>
          <h2 id="screensTitle">ストアスクリーンショット案</h2>
          <p>iOS、Android、競合比較の3枚を、ストア1〜3枚目に配置する想定です。</p>
        </div>
      </div>

      <nav class="screen-nav" aria-label="スクリーンショット切替">
        <button type="button" class="active" data-target="shotA">A: AI査定 iOS</button>
        <button type="button" data-target="shotB">B: 出費管理 Android</button>
        <button type="button" data-target="shotC">C: 電話0本 比較</button>
      </nav>

      <div class="prototype-stage">
        <div class="shot-viewer">
          <article id="shotA" class="shot-card active" aria-label="ストアスクショA AI査定機能">
            <div class="store-shot shot-a">
              <div class="phone-screen">
                <div class="phone-status">
                  <span>9:41</span>
                  <div class="status-icons">
                    <span class="status-dot"></span>
                    <span class="status-dot"></span>
                    <span class="battery"></span>
                  </div>
                </div>
                <div class="shot-content">
                  <div class="store-badge-row">
                    <span class="mini-badge pink">個人情報なし</span>
                    <span class="mini-badge">AI査定</span>
                    <span class="mini-badge">無料</span>
                  </div>
                  <h2 class="shot-title">あなたの愛車、<strong>いま何円？</strong></h2>
                  <p class="shot-subtitle">不安な売り時も、AIが相場と未来予測でそっと見える化。</p>

                  <div class="phone-app-card">
                    <div class="vehicle-row">
                      <div class="vehicle-thumb"></div>
                      <div class="vehicle-meta">
                        <h3>トヨタ ハリアー</h3>
                        <p>2021年式 Z Leather Package / 38,400km</p>
                      </div>
                    </div>

                    <div class="price-box">
                      <p class="price-label">AI査定レンジ</p>
                      <div class="price-value">142<span>〜</span>168<span>万円</span></div>
                      <p class="price-caption">現在の買取相場をビッグデータから推定</p>
                    </div>

                    <div class="future-card">
                      <div class="future-top">
                        <span>将来予測</span>
                        <span>3ヶ月後 +7万円の可能性</span>
                      </div>
                      <div class="sparkline" aria-hidden="true">
                        <svg viewBox="0 0 260 82">
                          <path d="M8 58 C52 52, 72 32, 112 38 S174 48, 210 26 S244 18, 252 16"></path>
                          <circle cx="252" cy="16" r="6"></circle>
                        </svg>
                      </div>
                    </div>

                    <button type="button" class="cta-button">まずは相場だけ見る</button>
                    <span class="warm-link">電話なしでチェックできます</span>
                  </div>

                  <p class="phone-note">App Store 1枚目想定: AI査定と個人情報不要をファーストビューで訴求</p>
                </div>
              </div>
            </div>
            <div class="shot-meta">
              <div class="meta-line">
                <strong>狙い</strong>
                <span>売却の不安を「価格が見える安心」に変換し、概算確認の心理的ハードルを下げる。</span>
              </div>
              <div class="meta-line">
                <strong>主要主張</strong>
                <span>UcarPACアプリは簡単な車両情報で現在相場とAIの将来相場を確認できる。出典: UcarPAC 2025-01-20 / 確認日 2026-05-18。</span>
              </div>
            </div>
          </article>

          <article id="shotB" class="shot-card" aria-label="ストアスクショB 出費管理と将来予測">
            <div class="store-shot android shot-b">
              <div class="phone-screen">
                <div class="phone-status">
                  <span>10:28</span>
                  <div class="status-icons">
                    <span class="status-dot"></span>
                    <span class="status-dot"></span>
                    <span class="battery"></span>
                  </div>
                </div>
                <div class="shot-content">
                  <div class="store-badge-row">
                    <span class="mini-badge blue">Android向け</span>
                    <span class="mini-badge">出費管理</span>
                    <span class="mini-badge pink">将来予測</span>
                  </div>
                  <h2 class="shot-title">維持費も、<strong>売り時</strong>も一緒に。</h2>
                  <p class="shot-subtitle">毎月の出費と愛車の価値を並べて、手放す時期を考えやすく。</p>

                  <div class="expense-grid">
                    <div class="expense-tile">
                      <p class="expense-label">今月の出費</p>
                      <p class="expense-value">28,640<small>円</small></p>
                    </div>
                    <div class="expense-tile">
                      <p class="expense-label">年間見込み</p>
                      <p class="expense-value">402,000<small>円</small></p>
                    </div>
                    <div class="expense-tile wide">
                      <p class="expense-label">カテゴリ内訳</p>
                      <div class="bar-list">
                        <div class="bar-line">
                          <span>ガソリン</span>
                          <div class="bar-track"><span style="width:72%"></span></div>
                          <span>12,800</span>
                        </div>
                        <div class="bar-line">
                          <span>保険</span>
                          <div class="bar-track"><span class="pink-bar" style="width:48%"></span></div>
                          <span>8,900</span>
                        </div>
                        <div class="bar-line">
                          <span>整備</span>
                          <div class="bar-track"><span style="width:32%"></span></div>
                          <span>6,940</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="phone-app-card">
                    <div class="future-top">
                      <span>愛車価値の予測</span>
                      <span>6ヶ月後 156万円</span>
                    </div>
                    <div class="sparkline" aria-hidden="true">
                      <svg viewBox="0 0 260 82">
                        <path d="M8 28 C44 24, 72 30, 104 38 S162 58, 196 49 S232 32, 252 30"></path>
                        <circle cx="252" cy="30" r="6"></circle>
                      </svg>
                    </div>
                    <div class="forecast-ribbon">
                      <strong>維持費を見ながら、納得できる売却タイミングへ</strong>
                      <span>+5.1</span>
                    </div>
                  </div>

                  <button type="button" class="cta-button">愛車の価値を記録する</button>
                  <p class="phone-note">Google Play 2枚目想定: 競合にない出費管理と資産価値トラッキングを訴求</p>
                </div>
              </div>
            </div>
            <div class="shot-meta">
              <div class="meta-line">
