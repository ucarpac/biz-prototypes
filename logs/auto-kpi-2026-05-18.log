      background: var(--white);
      font-size: 10px;
      font-weight: 700;
    }

    .store-shot {
      padding: 14px 14px 16px;
    }

    .shot-hero {
      position: relative;
      overflow: hidden;
      min-height: 172px;
      border-radius: 16px;
      padding: 16px;
      color: var(--white);
      background: var(--gradient-auction);
    }

    .shot-hero.pink {
      background:
        linear-gradient(135deg, rgba(248,76,162,0.96), rgba(28,38,99,0.92)),
        var(--pink);
    }

    .shot-hero.light {
      color: var(--dark-blue);
      background:
        linear-gradient(135deg, #ffffff 0%, #e6f6ff 62%, #ffd8e8 100%);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .shot-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 10px;
    }

    .shot-badge {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 5px 9px;
      border-radius: var(--radius-chip);
      color: var(--dark-blue);
      background: var(--white);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .shot-badge.blue {
      color: var(--white);
      background: var(--dark-blue);
    }

    .shot-badge.cyan {
      background: var(--gradient-primary);
    }

    .shot-hero h3 {
      margin: 0;
      font-size: 26px;
      font-weight: 700;
      line-height: 39px;
      letter-spacing: 0;
    }

    .shot-hero p {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 18px;
    }

    .price-panel {
      margin-top: -28px;
      position: relative;
      z-index: 2;
      padding: 14px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 10px 24px rgba(0,0,0,0.14);
    }

    .price-label {
      margin: 0;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .price-main {
      margin: 2px 0 0;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 32px;
      font-weight: 700;
      line-height: 48px;
    }

    .price-main small {
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 21px;
    }

    .mini-bars {
      display: grid;
      gap: 9px;
      margin-top: 10px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 72px 1fr 44px;
      align-items: center;
      gap: 8px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .thin-track {
      height: 8px;
      border-radius: 999px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .thin-fill {
      width: var(--fill);
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
    }

    .thin-fill.pink {
      background: var(--gradient-pink);
    }

    .svg-card {
      margin-top: 12px;
      padding: 12px;
      border-radius: 12px;
      background: #f8fbff;
      border: 1px solid rgba(28,38,99,0.08);
    }

    .chart-title {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .chart {
      display: block;
      width: 100%;
      height: auto;
    }

    .chart-line {
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: drawLine 1200ms ease forwards;
    }

    .feature-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .feature-box {
      min-height: 62px;
      padding: 8px;
      border-radius: 12px;
      background: var(--white);
      border: 1px solid var(--ruled-line);
      text-align: center;
    }

    .feature-box strong {
      display: block;
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 22.5px;
    }

    .feature-box span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .shot-button {
      display: grid;
      place-items: center;
      width: 182px;
      min-height: 43px;
      margin: 14px auto 0;
      border: 0;
      border-radius: var(--radius-button);
      color: var(--dark-blue);
      background: var(--gradient-primary);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 16px rgba(77,180,255,0.24);
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .shot-button:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 22px rgba(77,180,255,0.30);
    }

    .shot-button.pink {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 8px 16px rgba(248,76,162,0.24);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 10px;
      margin-top: -22px;
      position: relative;
      z-index: 2;
    }

    .expense-card {
      padding: 12px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 8px 22px rgba(0,0,0,0.12);
    }

    .expense-card h4 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .expense-price {
      margin: 4px 0 2px;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 24px;
      font-weight: 700;
      line-height: 36px;
    }

    .expense-note {
      margin: 0;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .donut-wrap {
      display: grid;
      place-items: center;
      min-height: 112px;
    }

    .forecast-list {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .forecast-item {
      display: grid;
      grid-template-columns: 62px 1fr auto;
      align-items: center;
      gap: 8px;
      padding: 8px;
      border-radius: 12px;
      background: var(--white);
      border: 1px solid var(--ruled-line);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .forecast-item strong {
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
    }

    .compare-table {
      margin-top: -18px;
      position: relative;
      z-index: 2;
      overflow: hidden;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 10px 24px rgba(0,0,0,0.14);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.05fr 0.8fr 0.85fr;
      border-bottom: 1px solid var(--ruled-line);
      min-height: 48px;
    }

    .compare-row:last-child {
      border-bottom: 0;
    }

    .compare-cell {
      display: flex;
      align-items: center;
      padding: 9px 8px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      border-right: 1px solid var(--ruled-line);
    }

    .compare-cell:last-child {
      border-right: 0;
    }

    .compare-cell.head {
      color: var(--dark-blue);
      background: #f7fbff;
      font-weight: 700;
    }

    .compare-cell.ucarpac {
      color: var(--dark-blue);
      background: rgba(29,220,255,0.12);
      font-weight: 700;
    }

    .zero-phone {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .zero-card {
      padding: 12px;
      border-radius: 12px;
      background: var(--back-blue);
      color: var(--white);
    }

    .zero-card.pink {
      background: var(--gradient-pink);
    }

    .zero-card p {
      margin: 0;
      color: rgba(255,255,255,0.76);
      font-size: 10px;
      line-height: 15px;
    }

    .zero-card strong {
      display: block;
      font-family: var(--font-number);
      font-size: 28px;
      line-height: 42px;
    }

    .analysis-grid {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .analysis-card {
      padding: 14px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 8px 22px var(--shadow);
    }

    .analysis-card h3 {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .metric-row {
      display: grid;
      grid-template-columns: 84px 1fr 52px;
      align-items: center;
      gap: 10px;
      min-height: 34px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .metric-row strong {
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
    }

    .rank-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .rank-list li {
      display: grid;
      grid-template-columns: 28px 1fr auto;
      align-items: center;
      gap: 8px;
      min-height: 42px;
      padding: 8px;
      border-radius: 12px;
      background: #f8fbff;
    }

    .rank-no {
      display: grid;
      place-items: center;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      color: var(--white);
      background: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
    }

    .rank-copy {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .rank-score {
      color: var(--pink);
      font-family: var(--font-number);
      font-size: 18px;
      font-weight: 700;
      line-height: 27px;
    }

    .source-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .source-list li {
      padding: 10px;
      border-radius: 12px;
      background: #f8fbff;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .source-list strong {
      color: var(--dark-blue);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translate(-50%, 24px);
      z-index: 20;
      width: min(calc(100% - 24px), 340px);
      padding: 12px 14px;
      border-radius: 13px;
      color: var(--white);
      background: var(--back-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      box-shadow: 0 12px 28px rgba(9,19,85,0.26);
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease, transform 180ms ease;
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    .fade-in {
      opacity: 0;
      transform: translateY(12px);
      animation: fadeUp 520ms ease forwards;
    }

    .delay-1 {
      animation-delay: 80ms;
    }

    .delay-2 {
      animation-delay: 160ms;
    }

    .delay-3 {
      animation-delay: 240ms;
    }

    .delay-4 {
      animation-delay: 320ms;
    }

    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @media (min-width: 760px) {
      .page {
        padding: 24px 20px 56px;
      }

      .hero {
        padding: 30px 28px;
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
        align-items: center;
      }

      .variant-grid {
        grid-template-columns: repeat(3, 1fr);
        align-items: start;
      }

      .controls {
        grid-template-columns: minmax(360px, 0.72fr) 1fr;
        align-items: center;
      }

      .analysis-grid {
        grid-template-columns: 1fr 1fr 1fr;
      }

      .section {
        margin-top: 28px;
      }
    }

    @media (max-width: 374px) {
      .segmented {
        grid-template-columns: repeat(2, 1fr);
      }

      .main-kpi {
        grid-template-columns: 1fr;
      }

      .phone-stage {
        padding: 9px;
      }

      .phone-screen {
        min-height: 548px;
      }

      .shot-hero h3 {
        font-size: 23px;
        line-height: 34.5px;
      }

      .price-main {
        font-size: 28px;
        line-height: 42px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="shell">
      <nav class="topbar" aria-label="ページナビゲーション">
        <div class="brand">
          <div class="brand-mark">UP</div>
          <div class="brand-text">
            <p class="brand-name">UcarPAC App ASO検証</p>
            <p class="brand-sub">ストアPVからDL率 17.3% → 25.0%</p>
          </div>
        </div>
        <a class="back-link" href="./index.html">Reports に戻る</a>
      </nav>

      <section class="hero fade-in">
        <div class="hero-grid">
          <div>
            <div class="label-row">
              <span class="label">日次差分 2026-05-18</span>
              <span class="label secondary">B案 データドリブン</span>
            </div>
            <h1>ストアスクショの訴求軸を3案で比較し、DL率25%への不足分を埋める</h1>
            <p class="hero-copy">
              AI査定、出費管理、電話0本の3訴求をストア詳細ページのファーストビューに載せ、閲覧者がDL前に価値を判断できる状態へ寄せる。
            </p>
          </div>
          <div class="hero-panel">
            <div class="main-kpi">
              <div class="kpi-card">
                <p class="kpi-label">現状DL率</p>
                <p class="kpi-value">17.3<span>%</span></p>
                <div class="progress-shell" aria-label="現状DL率 17.3%">
                  <div class="progress-fill" style="--value: 69.2%;"></div>
                </div>
              </div>
              <div class="kpi-card">
                <p class="kpi-label">KPI目標</p>
                <p class="kpi-value">25.0<span>%</span></p>
                <div class="progress-shell" aria-label="KPI目標 25%">
                  <div class="progress-fill pink" style="--value: 100%;"></div>
                </div>
              </div>
            </div>
            <p class="hero-note">
              必要改善幅は +7.7pt。現状比では約1.45倍のDL効率が必要なため、単なる装飾差分ではなく「DL前不安の解消」を検証対象にする。
            </p>
          </div>
        </div>
      </section>

      <section class="section fade-in delay-1" aria-labelledby="screenshots-title">
        <div class="section-head">
          <h2 class="section-title" id="screenshots-title">ストアスクショ3案</h2>
          <p class="section-meta">タップで表示案を切替</p>
        </div>

        <div class="controls">
          <div class="segmented" role="tablist" aria-label="スクリーンショット案">
            <button type="button" class="active" data-filter="all">全体</button>
            <button type="button" data-filter="a">A案</button>
            <button type="button" data-filter="b">B案</button>
            <button type="button" data-filter="c">C案</button>
          </div>
          <div class="control-line">
            <p class="control-copy">
              A/Bテスト対象を1つずつ見る。ストアでは最初の3枚に「価格の納得」「維持価値」「連絡不安の解消」を配置する。
            </p>
            <button type="button" class="toggle on" id="testToggle" aria-label="テスト中状態"></button>
          </div>
        </div>

        <div class="variant-grid">
          <article class="variant-card is-active" data-variant="a">
            <div class="variant-head">
              <div>
                <h3 class="variant-title">A. AI査定全面</h3>
                <p class="variant-copy">iOS向け。価格を最初に見せる。</p>
              </div>
              <div class="score-pill">期待 +4.2pt</div>
            </div>

            <div class="phone-stage">
              <div class="phone-screen">
                <div class="statusbar">
                  <span>9:41</span>
                  <span>UcarPAC</span>
                  <span>100%</span>
                </div>
                <div class="store-shot">
                  <div class="shot-hero pink">
                    <div class="shot-badge-row">
                      <span class="shot-badge">個人情報不要</span>
                      <span class="shot-badge cyan">AI査定</span>
                    </div>
                    <h3>AIがあなたの愛車を査定</h3>
                    <p>今の相場と売り時を、アプリで先に確認。</p>
                  </div>

                  <div class="price-panel">
                    <p class="price-label">2020年式 ハリアー Z Leather Package</p>
                    <p class="price-main">258<small>万円</small></p>
                    <div class="mini-bars">
                      <div class="bar-row">
                        <span>概算下限</span>
                        <div class="thin-track"><div class="thin-fill" style="--fill: 58%;"></div></div>
                        <span>232万</span>
                      </div>
                      <div class="bar-row">
                        <span>AI査定</span>
                        <div class="thin-track"><div class="thin-fill pink" style="--fill: 86%;"></div></div>
                        <span>258万</span>
                      </div>
                      <div class="bar-row">
                        <span>売り時</span>
                        <div class="thin-track"><div class="thin-fill" style="--fill: 74%;"></div></div>
                        <span>3月</span>
                      </div>
                    </div>
                  </div>

                  <div class="svg-card">
                    <p class="chart-title">将来予測 6か月</p>
                    <svg class="chart" viewBox="0 0 280 126" role="img" aria-label="AI査定価格の将来予測グラフ">
                      <line x1="16" y1="98" x2="264" y2="98" stroke="#E5E7EF" stroke-width="2"/>
                      <line x1="16" y1="68" x2="264" y2="68" stroke="#E5E7EF" stroke-width="2"/>
                      <line x1="16" y1="38" x2="264" y2="38" stroke="#E5E7EF" stroke-width="2"/>
                      <path class="chart-line" d="M20 76 C52 58 74 49 106 52 C138 56 158 42 188 38 C218 33 236 28 260 24" fill="none" stroke="#F84CA2" stroke-width="5" stroke-linecap="round"/>
                      <path d="M20 76 C52 58 74 49 106 52 C138 56 158 42 188 38 C218 33 236 28 260 24 L260 100 L20 100 Z" fill="rgba(248,76,162,0.12)"/>
                      <circle cx="20" cy="76" r="5" fill="#1c2663"/>
                      <circle cx="260" cy="24" r="6" fill="#F84CA2"/>
                      <text x="16" y="118" fill="#737373" font-size="10">現在</text>
                      <text x="226" y="118" fill="#737373" font-size="10">6か月後</text>
                      <text x="208" y="20" fill="#1c2663" font-size="12" font-weight="700">+12万円</text>
                    </svg>
                  </div>

                  <div class="feature-row">
                    <div class="feature-box">
                      <strong>0本</strong>
                      <span>査定まで電話なし</span>
                    </div>
                    <div class="feature-box">
                      <strong>6か月</strong>
                      <span>価格予測</span>
                    </div>
                    <div class="feature-box">
                      <strong>無料</strong>
                      <span>手数料なし</span>
                    </div>
                  </div>

                  <button type="button" class="shot-button pink" data-shot="A">この訴求でDL</button>
                </div>
              </div>
            </div>
          </article>

          <article class="variant-card" data-variant="b">
            <div class="variant-head">
              <div>
                <h3 class="variant-title">B. 出費管理+予測</h3>
                <p class="variant-copy">Android向け。資産管理の継続利用を訴求。</p>
              </div>
              <div class="score-pill">期待 +3.1pt</div>
            </div>

            <div class="phone-stage android">
              <div class="phone-screen">
                <div class="statusbar">
                  <span>10:18</span>
                  <span>UcarPAC</span>
                  <span>5G</span>
                </div>
                <div class="store-shot">
                  <div class="shot-hero light">
                    <div class="shot-badge-row">
                      <span class="shot-badge blue">Android</span>
                      <span class="shot-badge">出費管理</span>
                    </div>
                    <h3>車の出費と価値を一画面で</h3>
                    <p>売るまでの維持費も、将来の相場も見える化。</p>
                  </div>

                  <div class="expense-grid">
                    <div class="expense-card">
                      <h4>今月の維持費</h4>
                      <p class="expense-price">42,860<small>円</small></p>
                      <p class="expense-note">先月比 -8,420円</p>
                    </div>
                    <div class="expense-card">
                      <h4>6か月後予測</h4>
                      <p class="expense-price">246<small>万円</small></p>
                      <p class="expense-note">今売る差額 +12万円</p>
                    </div>
                  </div>

                  <div class="svg-card">
                    <p class="chart-title">費用カテゴリ内訳</p>
                    <div class="donut-wrap">
                      <svg class="chart" viewBox="0 0 190 118" role="img" aria-label="維持費カテゴリ別の円グラフ">
                        <circle cx="59" cy="59" r="42" fill="none" stroke="#EDF1F4" stroke-width="16"/>
                        <circle cx="59" cy="59" r="42" fill="none" stroke="#F84CA2" stroke-width="16" stroke-dasharray="96 264" stroke-linecap="round" transform="rotate(-90 59 59)"/>
                        <circle cx="59" cy="59" r="42" fill="none" stroke="#4db4ff" stroke-width="16" stroke-dasharray="72 264" stroke-dashoffset="-102" stroke-linecap="round" transform="rotate(-90 59 59)"/>
