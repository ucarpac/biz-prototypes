      margin-top: 18px;
      min-height: 52px;
      border-radius: 999px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 900;
      box-shadow: 0 12px 26px rgba(29, 220, 255, 0.32);
    }

    .primary-btn strong {
      margin-left: 8px;
      font-family: "Righteous", var(--font-sans);
      font-size: 17px;
      font-weight: 400;
    }

    .helper-note {
      margin-top: 10px;
      font-size: 11px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.74);
      text-align: center;
      font-weight: 700;
    }

    .screen.b .helper-note,
    .screen.c .helper-note {
      color: var(--text-gray);
    }

    .scanner-steps {
      margin-top: 18px;
      display: grid;
      gap: 10px;
    }

    .step-chip {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .step-chip.active {
      background: rgba(255, 255, 255, 0.18);
      transform: translateX(4px);
    }

    .step-index {
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.16);
      color: var(--white);
      font-size: 12px;
      font-weight: 900;
      flex: 0 0 auto;
    }

    .step-copy strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      font-weight: 900;
      color: inherit;
    }

    .step-copy span {
      display: block;
      margin-top: 2px;
      font-size: 11px;
      line-height: 1.6;
      color: inherit;
      opacity: 0.78;
      font-weight: 700;
    }

    .dashboard-card {
      margin-top: 22px;
      padding: 20px;
      background: rgba(255, 255, 255, 0.88);
    }

    .dashboard-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .dashboard-head strong {
      display: block;
      font-size: 18px;
      line-height: 1.5;
      font-weight: 900;
    }

    .dashboard-head span {
      display: block;
      margin-top: 4px;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
      font-weight: 700;
    }

    .profit-pill {
      padding: 10px 12px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.12), rgba(29, 220, 255, 0.14));
      text-align: right;
    }

    .profit-pill strong {
      display: block;
      font-family: "Righteous", var(--font-sans);
      font-weight: 400;
      color: var(--dark-blue);
      font-size: 24px;
      line-height: 1.1;
    }

    .profit-pill span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 800;
    }

    .mini-bars {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 82px 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .bar-label {
      font-size: 12px;
      font-weight: 800;
      color: var(--text-black);
    }

    .bar-track {
      height: 12px;
      border-radius: 999px;
      background: #e5eef8;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
      transition: width 0.35s ease;
    }

    .bar-fill.pink {
      background: linear-gradient(90deg, #f84ca2, #ff8cc5);
    }

    .bar-value {
      font-size: 12px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .forecast-switcher {
      display: flex;
      gap: 8px;
      margin-top: 18px;
      flex-wrap: wrap;
    }

    .forecast-chip {
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: #fff;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      box-shadow: var(--shadow-light);
      transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
      cursor: pointer;
    }

    .forecast-chip.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .insight-panel {
      margin-top: 18px;
      padding: 18px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.95), rgba(28, 38, 99, 0.94));
      color: var(--white);
      border-radius: 26px;
      box-shadow: var(--shadow-medium);
    }

    .insight-panel strong {
      display: block;
      font-size: 16px;
      line-height: 1.5;
      font-weight: 900;
    }

    .insight-panel p {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.8);
      font-weight: 700;
    }

    .insight-panel .impact {
      display: inline-flex;
      margin-top: 12px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      color: #86f5ff;
      font-size: 12px;
      font-weight: 900;
    }

    .comparison-wrap {
      margin-top: 26px;
      position: relative;
      z-index: 3;
    }

    .comparison-top {
      padding: 18px 18px 0;
      color: var(--white);
    }

    .comparison-top p {
      margin: 10px 0 0;
      font-size: 14px;
      line-height: 1.75;
      color: rgba(255, 255, 255, 0.82);
      max-width: 300px;
    }

    .comparison-card {
      margin-top: 18px;
      padding: 20px;
      background: rgba(255, 255, 255, 0.98);
      color: var(--dark-blue);
    }

    .scenario-toggle {
      display: flex;
      gap: 8px;
      margin-top: 16px;
    }

    .scenario-btn {
      flex: 1;
      padding: 12px;
      border-radius: 16px;
      border: none;
      font-size: 12px;
      font-weight: 900;
      background: #edf1f4;
      color: var(--dark-blue);
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .scenario-btn.active {
      background: var(--pink);
      color: var(--white);
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(248, 76, 162, 0.28);
    }

    .battle-row {
      margin-top: 18px;
      display: grid;
      gap: 10px;
    }

    .battle-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 16px;
      border-radius: 18px;
      background: #f8fbff;
      border: 1px solid #e8eef7;
      position: relative;
      overflow: hidden;
    }

    .battle-card.ucarpac {
      background: linear-gradient(135deg, rgba(9, 19, 85, 0.98), rgba(28, 38, 99, 0.96));
      color: var(--white);
      border: none;
    }

    .battle-card.ucarpac::after {
      content: "BEST";
      position: absolute;
      top: 10px;
      right: -24px;
      padding: 4px 28px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 10px;
      font-weight: 900;
      transform: rotate(34deg);
    }

    .battle-copy strong {
      display: block;
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
    }

    .battle-copy span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.6;
      color: inherit;
      opacity: 0.8;
      font-weight: 700;
    }

    .call-count {
      text-align: right;
      min-width: 72px;
    }

    .call-count strong {
      display: block;
      font-family: "Righteous", var(--font-sans);
      font-size: 28px;
      line-height: 1.1;
      font-weight: 400;
    }

    .call-count span {
      display: block;
      margin-top: 3px;
      font-size: 11px;
      line-height: 1.4;
      font-weight: 900;
    }

    .zero-call-highlight {
      margin-top: 16px;
      padding: 16px;
      border-radius: 22px;
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.12), rgba(29, 220, 255, 0.18));
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .shield {
      width: 52px;
      height: 52px;
      border-radius: 18px;
      background: linear-gradient(135deg, #f84ca2, #ff95c8);
      color: var(--white);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      box-shadow: 0 10px 22px rgba(248, 76, 162, 0.24);
      flex: 0 0 auto;
      animation: pulse 2.4s ease-in-out infinite;
    }

    .zero-call-highlight strong {
      display: block;
      font-size: 16px;
      line-height: 1.5;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .zero-call-highlight span {
      display: block;
      margin-top: 4px;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
      font-weight: 700;
    }

    .bottom-cta {
      margin-top: 18px;
      display: grid;
      gap: 10px;
    }

    .ghost-btn {
      min-height: 50px;
      border-radius: 999px;
      background: #fff;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 900;
      box-shadow: var(--shadow-light);
    }

    .nav-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
    }

    .nav-btn {
      width: 48px;
      height: 48px;
      border: none;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.86);
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 900;
      box-shadow: var(--shadow-light);
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .nav-btn:hover {
      transform: translateY(-2px);
    }

    .progress-dots {
      display: flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      flex: 1;
    }

    .progress-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.2);
      transition: width 0.25s ease, background 0.25s ease;
    }

    .progress-dot.active {
      width: 28px;
      background: var(--dark-blue);
    }

    .swipe-hint {
      margin-top: 10px;
      text-align: center;
      font-size: 11px;
      line-height: 1.6;
      font-weight: 800;
      color: var(--text-gray);
      animation: fadeSlide 2s ease-in-out infinite;
    }

    .floating-orb {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      z-index: 1;
      filter: blur(2px);
      opacity: 0.84;
    }

    .orb-1 {
      width: 100px;
      height: 100px;
      top: 140px;
      right: -24px;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.58), transparent 70%);
      animation: floaty 5.6s ease-in-out infinite;
    }

    .orb-2 {
      width: 120px;
      height: 120px;
      bottom: 120px;
      left: -38px;
      background: radial-gradient(circle, rgba(29, 220, 255, 0.44), transparent 70%);
      animation: floaty 6.8s ease-in-out infinite reverse;
    }

    .scan-status {
      margin-top: 8px;
      font-size: 11px;
      line-height: 1.6;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.78);
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }

    .chart-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 14px;
    }

    .chart-metrics .metric {
      padding: 12px 10px;
      border-radius: 16px;
      background: #f7fbff;
      text-align: center;
    }

    .chart-metrics strong {
      display: block;
      font-size: 16px;
      line-height: 1.3;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .chart-metrics span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 800;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.86; }
    }

    @keyframes glide {
      0% { transform: translateX(-4px); }
      100% { transform: translateX(12px); }
    }

    @keyframes shimmer {
      0% { transform: translateX(-40px) skewX(-20deg); }
      100% { transform: translateX(320px) skewX(-20deg); }
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0) translateX(0); }
      50% { transform: translateY(-16px) translateX(6px); }
    }

    @keyframes fadeSlide {
      0%, 100% { transform: translateX(0); opacity: 0.55; }
      50% { transform: translateX(6px); opacity: 1; }
    }

    @media (min-width: 768px) {
      body {
        padding-top: 28px;
      }

      .prototype-shell {
        max-width: 480px;
      }

      .phone {
        min-height: 790px;
      }

      .screen {
        min-height: 790px;
      }
    }
  </style>
</head>
<body>
  <main class="prototype-shell">
    <section class="ops-banner">
      <div class="eyebrow">
        <span class="dot"></span>
        ASO検証用ストアスクショ / C案
      </div>
      <h1>操作したくなる3枚で<br>ストアPVからDLを押し切る</h1>
      <p>AI査定、出費管理、電話0本の安心感を、1スワイプごとに発見が増える構成で再設計したプロトタイプです。</p>
      <div class="kpi-strip">
        <div class="kpi-copy">
          <strong>ストア詳細ページ → DL</strong>
          <span>現状 17.3% / 目標 25.0%</span>
        </div>
        <div class="kpi-gauge">
          <div class="kpi-values">
            <span class="current">17.3</span>
            <span class="target">25.0%</span>
          </div>
          <div class="gauge-track">
            <div class="gauge-fill"></div>
          </div>
        </div>
      </div>
    </section>

    <div class="top-controls">
      <div class="tabset" role="tablist" aria-label="Store screenshots">
        <button class="tab active" data-go="0" role="tab" aria-selected="true">A / iOS</button>
        <button class="tab" data-go="1" role="tab" aria-selected="false">B / Android</button>
        <button class="tab" data-go="2" role="tab" aria-selected="false">C / 比較</button>
      </div>
      <div class="meta-note">スワイプで切替 / タップで状態変化</div>
    </div>

    <section class="stage" id="stage">
      <div class="carousel-track" id="track">
        <div class="slide">
          <article class="phone" aria-label="ストアスクショA AI査定">
            <div class="floating-orb orb-1"></div>
            <div class="floating-orb orb-2"></div>
            <div class="statusbar">
              <span>9:41</span>
              <span>5G 100%</span>
            </div>
            <section class="screen a">
              <div class="platform-row">
                <div class="platform-pill">iOS向けスクショA</div>
                <div class="platform-pill">個人情報不要</div>
              </div>

              <div class="title-block">
                <span class="sub">AI査定を全面訴求</span>
                <h2>あなたの愛車、<br><strong>3秒で相場が動き出す</strong></h2>
                <p>ハリアー Z Leather Package 2021年式 / 28,400km を例に、査定のワクワク感をゲームのような進行で見せます。</p>
              </div>

              <div class="badge-row">
                <span class="feature-badge">AI査定</span>
                <span class="feature-badge">将来予測</span>
                <span class="feature-badge">8,000社オークション</span>
              </div>

              <div class="floating-card valuation-card">
                <div class="car-row">
                  <div class="car-avatar" aria-hidden="true"></div>
                  <div class="car-info">
                    <strong>トヨタ ハリアー Z</strong>
                    <span>2021年 / パールホワイト / 2WD</span>
                    <span>走行 28,400km / 修復歴なし</span>
                  </div>
                </div>

                <div class="meter-stack">
                  <div class="meter-head">
                    <div>
                      <small>AI査定価格レンジ</small>
                      <div class="meter-price" id="priceCounter">268.4<span>万円</span></div>
                    </div>
                    <div>
                      <small>精度スコア</small>
                      <div class="meter-price" style="font-size:28px;" id="scoreCounter">89<span>pt</span></div>
                    </div>
                  </div>

                  <div class="scan-track">
                    <div class="scan-fill" id="scanFill"></div>
                  </div>

                  <div class="scan-status">
                    <span id="scanLabel">写真・相場・オークション履歴を解析中</span>
                    <span id="scanPercent">56%</span>
                  </div>

                  <div class="insight-grid">
                    <div class="insight">
                      <strong>+12.8万</strong>
                      <span>6月売却予測</span>
                    </div>
                    <div class="insight">
                      <strong>24h</strong>
                      <span>更新スピード</span>
                    </div>
                    <div class="insight">
                      <strong>0件</strong>
                      <span>営業電話</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="floating-card wave-card">
                <div class="wave-head">
                  <strong>売り時スコア</strong>
                  <span>今月がチャンス</span>
                </div>
                <div class="forecast-chart">
                  <svg viewBox="0 0 320 140" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="lineA" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="#1ddcff"></stop>
                        <stop offset="100%" stop-color="#F84CA2"></stop>
                      </linearGradient>
                    </defs>
                    <path d="M10 106 C48 102 74 84 108 88 C145 93 168 58 206 46 C232 38 270 44 310 22" fill="none" stroke="url(#lineA)" stroke-width="6" stroke-linecap="round"></path>
                    <path d="M10 112 C48 108 74 90 108 94 C145 99 168 64 206 52 C232 44 270 50 310 28" fill="none" stroke="rgba(28,38,99,0.12)" stroke-width="16" stroke-linecap="round"></path>
                    <circle class="marker" cx="206" cy="46" r="8"></circle>
                  </svg>
                </div>
                <div class="forecast-legend">
                  <span>今月 268.4万円</span>
                  <span>3か月後 281.2万円</span>
                  <span>6か月後 259.0万円</span>
                </div>
              </div>

              <button class="primary-btn" id="runValuation" type="button">AI査定をスキャンする <strong>PLAY</strong></button>
              <div class="helper-note">タップすると査定スコアと価格が再計算されます</div>

              <div class="scanner-steps" id="stepFlow">
                <div class="step-chip active">
                  <div class="step-index">1</div>
                  <div class="step-copy">
                    <strong>メーカー・車種を選ぶ</strong>
                    <span>トヨタ / ハリアー / 2021年</span>
                  </div>
                </div>
                <div class="step-chip">
                  <div class="step-index">2</div>
                  <div class="step-copy">
                    <strong>カラーと装備を追加</strong>
                    <span>パノラマルーフ・純正ナビ・ETC</span>
                  </div>
                </div>
                <div class="step-chip">
                  <div class="step-index">3</div>
                  <div class="step-copy">
                    <strong>写真をアップして精度UP</strong>
                    <span>フロント・内装・タイヤの3枚でOK</span>
                  </div>
                </div>
              </div>
            </section>
          </article>
        </div>

        <div class="slide">
          <article class="phone" aria-label="ストアスクショB 出費管理と将来予測">
            <div class="statusbar light">
              <span>9:41</span>
              <span>5G 100%</span>
            </div>
            <section class="screen b">
              <div class="platform-row">
                <div class="platform-pill">Android向けスクショB</div>
                <div class="platform-pill">出費管理 + 将来予測</div>
              </div>

              <div class="title-block">
                <span class="sub">家計簿ではなく、愛車の資産管理へ</span>
                <h2>維持費も、売り時も、<br><strong>1画面でわかる</strong></h2>
                <p>ガソリン、保険、車検の出費と、今後の査定相場を連動表示。売却検討中ユーザーの再訪理由をつくる構成です。</p>
              </div>

              <div class="badge-row">
                <span class="feature-badge">出費管理</span>
                <span class="feature-badge">将来予測グラフ</span>
                <span class="feature-badge">毎月通知</span>
              </div>

              <div class="floating-card dashboard-card">
                <div class="dashboard-head">
                  <div>
                    <strong>2026年3月のカーコスト</strong>
                    <span>日産 セレナ e-POWER 2022 / 月間サマリー</span>
                  </div>
                  <div class="profit-pill">
                    <strong id="futureValue">+12.8万</strong>
                    <span>6月売却で上振れ</span>
                  </div>
                </div>

                <div class="mini-bars" id="expenseBars">
                  <div class="bar-row">
                    <div class="bar-label">ガソリン</div>
                    <div class="bar-track"><div class="bar-fill" data-width="74" style="width:74%;"></div></div>
                    <div class="bar-value">¥14,800</div>
                  </div>
