          ["アプリ完結", "あり", "なし", "なし"]
        ]
      }
    };

    const compareButtons = document.querySelectorAll("[data-compare]");
    const cHeroValue = document.getElementById("cHeroValue");
    const cHeroText = document.getElementById("cHeroText");
    const cStressNote = document.getElementById("cStressNote");
    const cTableBody = document.getElementById("cTableBody");
    const cStressU = document.getElementById("cStressU");
    const cStressB = document.getElementById("cStressB");
    const cStressO = document.getElementById("cStressO");
    const cBarU = document.getElementById("cBarU");
    const cBarB = document.getElementById("cBarB");
    const cBarO = document.getElementById("cBarO");

    function updateCompare(mode) {
      const data = compareData[mode];
      cHeroValue.textContent = data.heroValue;
      cHeroText.textContent = data.heroText;
      cStressNote.textContent = data.note;
      cStressU.textContent = data.stress[0];
      cStressB.textContent = data.stress[1];
      cStressO.textContent = data.stress[2];
      cBarU.style.width = data.stress[0] + "%";
      cBarB.style.width = data.stress[1] + "%";
      cBarO.style.width = data.stress[2] + "%";

      cTableBody.innerHTML = "";
      data.rows.forEach((row) => {
        const tr = document.createElement("tr");
        row.forEach((cell, index) => {
          const tag = "td";
          const el = document.createElement(tag);
          el.textContent = cell;
          if (index === 1) {
            el.className = "highlight-col";
          }
          if (index > 1 && (cell === "なし" || cell === "比較見積もり")) {
            el.classList.add("muted");
          }
          tr.appendChild(el);
        });
        cTableBody.appendChild(tr);
      });

      compareButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.compare === mode);
      });
    }

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => updateCompare(button.dataset.compare));
    });

    let demoTimer = null;

    function runDemoSequence() {
      const steps = [
        () => {
          setActiveShot("shot-a");
          updateForecast("m3");
        },
        () => {
          setActiveShot("shot-b");
          updateSpend("year");
        },
        () => {
          setActiveShot("shot-c");
          updateCompare("sell");
        },
        () => {
          setActiveShot("shot-a");
          updateForecast("now");
        }
      ];

      clearInterval(demoTimer);
      let index = 0;
      steps[index]();
      demoTimer = setInterval(() => {
        index += 1;
        if (index >= steps.length) {
          clearInterval(demoTimer);
          return;
        }
        steps[index]();
      }, 1800);
    }

    function resetAll() {
      clearInterval(demoTimer);
      setActiveShot("shot-a");
      updateForecast("now");
      updateSpend("month");
      updateCompare("check");
    }

    demoButton.addEventListener("click", runDemoSequence);
    resetButton.addEventListener("click", resetAll);

    resetAll();
