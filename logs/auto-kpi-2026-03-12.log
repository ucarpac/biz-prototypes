  </main>

  <script>
    (function () {
      const track = document.getElementById("track");
      const tabs = Array.from(document.querySelectorAll(".tab"));
      const dots = Array.from(document.querySelectorAll(".progress-dot"));
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const stage = document.getElementById("stage");
      let current = 0;
      let startX = 0;
      let deltaX = 0;

      function setSlide(index) {
        current = (index + 3) % 3;
        track.style.transform = "translateX(-" + (current * 33.333333) + "%)";
        tabs.forEach((tab, i) => {
          const active = i === current;
          tab.classList.toggle("active", active);
          tab.setAttribute("aria-selected", active ? "true" : "false");
        });
        dots.forEach((dot, i) => dot.classList.toggle("active", i === current));
      }

      tabs.forEach((tab) => {
        tab.addEventListener("click", function () {
          setSlide(Number(tab.dataset.go));
        });
      });

      prevBtn.addEventListener("click", function () {
        setSlide(current - 1);
      });

      nextBtn.addEventListener("click", function () {
        setSlide(current + 1);
      });

      stage.addEventListener("touchstart", function (event) {
        startX = event.touches[0].clientX;
      }, { passive: true });

      stage.addEventListener("touchmove", function (event) {
        deltaX = event.touches[0].clientX - startX;
      }, { passive: true });

      stage.addEventListener("touchend", function () {
        if (Math.abs(deltaX) > 40) {
          if (deltaX < 0) {
            setSlide(current + 1);
          } else {
            setSlide(current - 1);
          }
        }
        deltaX = 0;
      });

      const priceCounter = document.getElementById("priceCounter");
      const scoreCounter = document.getElementById("scoreCounter");
      const scanFill = document.getElementById("scanFill");
      const scanPercent = document.getElementById("scanPercent");
      const scanLabel = document.getElementById("scanLabel");
      const runValuation = document.getElementById("runValuation");
      const stepChips = Array.from(document.querySelectorAll("#stepFlow .step-chip"));

      let valuationRun = 0;

      function animateValue(element, start, end, duration, suffix, decimals) {
        const range = end - start;
        const startTime = performance.now();
        function frame(now) {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = start + range * eased;
          element.innerHTML = value.toFixed(decimals) + "<span>" + suffix + "</span>";
          if (progress < 1) {
            requestAnimationFrame(frame);
          }
        }
        requestAnimationFrame(frame);
      }

      runValuation.addEventListener("click", function () {
        valuationRun += 1;
        const modes = [
          { price: 268.4, score: 89, fill: 56, label: "写真・相場・オークション履歴を解析中" },
          { price: 274.9, score: 93, fill: 82, label: "純正オプションを検知。精度がさらに向上" },
          { price: 281.2, score: 96, fill: 100, label: "6月売却の上振れ予測まで算出完了" }
        ];
        const mode = modes[valuationRun % modes.length];
        animateValue(priceCounter, parseFloat(priceCounter.textContent), mode.price, 900, "万円", 1);
        animateValue(scoreCounter, parseFloat(scoreCounter.textContent), mode.score, 700, "pt", 0);
        scanFill.style.width = mode.fill + "%";
        scanPercent.textContent = mode.fill + "%";
        scanLabel.textContent = mode.label;
        stepChips.forEach((chip, index) => {
          chip.classList.toggle("active", index <= (valuationRun % 3));
        });
      });

      const forecastData = {
        "3": {
          path: "M8 100 C50 92 74 84 106 88 C144 94 172 72 210 64 C244 56 278 48 312 34",
          marker: { x: 210, y: 64 },
          badge: "3か月後 +6.4万",
          futureValue: "+6.4万",
          current: "241万",
          peak: "247万",
          spend: "¥49,900",
          insight: "春の需要でミニバン相場が上昇。短期なら価格を取りやすく、いまの維持費水準でも悪くありません。",
          impact: "今動くと 年間維持費を約4.1万円圧縮"
        },
        "6": {
          path: "M8 104 C50 96 74 88 106 92 C144 98 172 76 210 68 C244 60 278 52 312 40",
          marker: { x: 244, y: 60 },
          badge: "6か月後 +12.8万",
          futureValue: "+12.8万",
          current: "241万",
          peak: "253万",
          spend: "¥49,900",
          insight: "保険更新前の6月がベスト。維持費を払う前に価格ピークを取りに行けるタイミングです。",
          impact: "今動くと 年間維持費を約7.2万円圧縮"
        },
        "12": {
          path: "M8 110 C50 104 74 100 106 98 C144 94 172 88 210 84 C244 80 278 76 312 70",
          marker: { x: 278, y: 76 },
          badge: "12か月後 -9.1万",
          futureValue: "-9.1万",
          current: "241万",
          peak: "232万",
          spend: "¥58,200",
          insight: "来年まで保有すると車検と消耗品コストが重なり、手残りベースでは不利になりやすい見込みです。",
          impact: "先送りで 総コストが約11.6万円増加"
        }
      };

      const forecastChips = Array.from(document.querySelectorAll(".forecast-chip"));
      const forecastPath = document.getElementById("forecastPath");
      const forecastMarker = document.getElementById("forecastMarker");
      const termBadge = document.getElementById("termBadge");
      const futureValue = document.getElementById("futureValue");
      const metricCurrent = document.getElementById("metricCurrent");
      const metricPeak = document.getElementById("metricPeak");
      const metricSpend = document.getElementById("metricSpend");
      const insightText = document.getElementById("insightText");
      const impactPill = document.getElementById("impactPill");
      const shuffleForecast = document.getElementById("shuffleForecast");

      function setForecast(term) {
        const data = forecastData[term];
        forecastChips.forEach((chip) => chip.classList.toggle("active", chip.dataset.term === term));
        forecastPath.setAttribute("d", data.path);
        forecastMarker.setAttribute("cx", data.marker.x);
        forecastMarker.setAttribute("cy", data.marker.y);
        termBadge.textContent = data.badge;
        futureValue.textContent = data.futureValue;
        metricCurrent.textContent = data.current;
        metricPeak.textContent = data.peak;
        metricSpend.textContent = data.spend;
        insightText.textContent = data.insight;
        impactPill.textContent = data.impact;
      }

      forecastChips.forEach((chip) => {
        chip.addEventListener("click", function () {
          setForecast(chip.dataset.term);
        });
      });

      let forecastIndex = 0;
      shuffleForecast.addEventListener("click", function () {
        const order = ["3", "6", "12"];
        forecastIndex = (forecastIndex + 1) % order.length;
        setForecast(order[forecastIndex]);
      });

      const scenarioButtons = Array.from(document.querySelectorAll(".scenario-btn"));
      const ucarpacCopy = document.getElementById("ucarpacCopy");
      const bulkCopy = document.getElementById("bulkCopy");
      const auctionCopy = document.getElementById("auctionCopy");
      const ucarpacCalls = document.getElementById("ucarpacCalls");
      const bulkCalls = document.getElementById("bulkCalls");
      const auctionCalls = document.getElementById("auctionCalls");
      const zeroCallTitle = document.getElementById("zeroCallTitle");
      const zeroCallText = document.getElementById("zeroCallText");
      const compareAction = document.getElementById("compareAction");

      const scenarioData = {
        check: {
          ucarpacCopy: "AI査定で相場チェック。個人情報なしで売り時を見極める。",
          bulkCopy: "申し込み直後から複数社の連絡が来やすい。",
          auctionCopy: "事前入札や連絡調整が必要。アプリでの継続管理は弱い。",
          ucarpacCalls: "0本",
          bulkCalls: "5〜10本",
          auctionCalls: "1〜3本",
          zeroCallTitle: "迷っている間は、営業電話0本",
          zeroCallText: "相場確認と将来予測はアプリ内で完結。売ると決めてから相談すればいい。",
          button: "電話0本で相場を見る"
        },
        sell: {
          ucarpacCopy: "売却相談に進んでも、やりとりは基本1社。最高額オークションへ進める。",
          bulkCopy: "価格比較はしやすいが、業者ごとの調整負荷が高い。",
          auctionCopy: "連絡本数は抑えやすいが、事前査定の見通しが弱い。",
          ucarpacCalls: "1社",
          bulkCalls: "5〜10社",
          auctionCalls: "1〜3社",
          zeroCallTitle: "売る時だけ、必要なやりとりに絞る",
          zeroCallText: "普段は0本、売る時は基本1社。検討段階と申込段階で体験を分離できる。",
          button: "1社対応で売却を始める"
        }
      };

      function setScenario(mode) {
        const data = scenarioData[mode];
        scenarioButtons.forEach((button) => button.classList.toggle("active", button.dataset.mode === mode));
        ucarpacCopy.textContent = data.ucarpacCopy;
        bulkCopy.textContent = data.bulkCopy;
        auctionCopy.textContent = data.auctionCopy;
        ucarpacCalls.textContent = data.ucarpacCalls;
        bulkCalls.textContent = data.bulkCalls;
        auctionCalls.textContent = data.auctionCalls;
        zeroCallTitle.textContent = data.zeroCallTitle;
        zeroCallText.textContent = data.zeroCallText;
        compareAction.innerHTML = data.button + " <strong>" + (mode === "check" ? "TRY" : "GO") + "</strong>";
      }

      scenarioButtons.forEach((button) => {
        button.addEventListener("click", function () {
          setScenario(button.dataset.mode);
        });
      });

      setSlide(0);
      setForecast("3");
      setScenario("check");
    })();
  </script>
</body>
