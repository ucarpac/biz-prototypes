      content: "";
      position: absolute;
      inset: auto -10% -40% auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: rgba(29, 220, 255, 0.12);
    }

    .kpi-label {
      position: relative;
      z-index: 1;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--text-gray);
      text-transform: uppercase;
    }

    .kpi-value {
      position: relative;
      z-index: 1;
      margin-top: 6px;
      font-family: var(--font-number);
      font-size: clamp(28px, 4vw, 34px);
      line-height: 1;
      color: var(--dark-blue);
    }

    .kpi-meta {
      position: relative;
      z-index: 1;
      margin-top: 8px;
      font-size: 12px;
      color: var(--text-gray);
    }

    .positive {
      color: #0a8a58;
      font-weight: 700;
    }

    .controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }

    .tabs {
      display: inline-flex;
      gap: 8px;
      padding: 6px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
    }

    .tab {
      border: 0;
      border-radius: 999px;
      padding: 11px 16px;
      font: inherit;
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
      background: transparent;
      cursor: pointer;
      transition: 0.24s ease;
    }

    .tab.is-active {
      color: var(--white);
      background: var(--back-blue);
      box-shadow: 0 10px 20px rgba(9, 19, 85, 0.18);
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .action-btn {
      border: 0;
      border-radius: var(--radius-button);
      padding: 12px 18px;
      min-height: 43px;
      font: inherit;
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      cursor: pointer;
      box-shadow: 0 14px 28px rgba(77, 180, 255, 0.22);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .action-btn.secondary {
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.14);
      box-shadow: 0 10px 24px rgba(28, 38, 99, 0.08);
    }

    .action-btn:active {
      transform: translateY(1px) scale(0.99);
    }

    .gallery {
      display: grid;
      gap: 18px;
    }

    .shot {
      display: none;
      gap: 18px;
      align-items: start;
    }

    .shot.is-active {
      display: grid;
    }

    .shot-meta {
      display: grid;
      gap: 12px;
      max-width: 360px;
    }

    .meta-card {
      padding: 16px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(28, 38, 99, 0.1);
      box-shadow: 0 16px 32px rgba(28, 38, 99, 0.07);
    }

    .meta-title {
      margin: 0 0 6px;
      font-size: 18px;
      line-height: 1.4;
      color: var(--back-blue);
    }

    .meta-text {
      margin: 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.7;
    }

    .meta-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 10px;
    }

    .meta-list li {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 13px;
    }

    .meta-list strong {
      color: var(--dark-blue);
    }

    .device {
      position: relative;
      width: min(100%, var(--frame-width));
      min-height: var(--frame-height);
      margin: 0 auto;
      border-radius: 34px;
      background: var(--white);
      box-shadow:
        0 30px 60px rgba(9, 19, 85, 0.18),
        0 10px 24px rgba(9, 19, 85, 0.08);
      overflow: hidden;
      border: 1px solid rgba(9, 19, 85, 0.08);
    }

    .device::before {
      content: "";
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 136px;
      height: 28px;
      border-radius: 999px;
      background: #0b1020;
      z-index: 5;
    }

    .screen {
      position: relative;
      min-height: 100%;
      padding: 42px 18px 22px;
      overflow: hidden;
    }

    .screen::before,
    .screen::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      filter: blur(0.5px);
      pointer-events: none;
    }

    .screen::before {
      width: 180px;
      height: 180px;
      top: -60px;
      right: -40px;
      background: rgba(248, 76, 162, 0.12);
    }

    .screen::after {
      width: 220px;
      height: 220px;
      bottom: -90px;
      left: -70px;
      background: rgba(29, 220, 255, 0.15);
    }

    .ios-screen {
      background:
        radial-gradient(circle at top right, rgba(248, 76, 162, 0.18), transparent 34%),
        linear-gradient(180deg, #fdfdff 0%, #eef4fb 100%);
    }

    .android-screen {
      background:
        radial-gradient(circle at top left, rgba(29, 220, 255, 0.18), transparent 36%),
        linear-gradient(180deg, #f5fbff 0%, #eef2fa 100%);
    }

    .compare-screen {
      background:
        radial-gradient(circle at top center, rgba(248, 76, 162, 0.16), transparent 30%),
        linear-gradient(180deg, #fdfcff 0%, #f0f5fb 100%);
    }

    .status-row {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .signal {
      display: inline-flex;
      gap: 6px;
      align-items: center;
    }

    .signal-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #36d68f;
      box-shadow: 0 0 0 6px rgba(54, 214, 143, 0.16);
      animation: pulse 2s infinite;
    }

    .hero {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
    }

    .platform-pill {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(28, 38, 99, 0.08);
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .hero h2 {
      margin: 0;
      font-size: 30px;
      line-height: 1.18;
      letter-spacing: -0.04em;
      color: var(--back-blue);
    }

    .hero p {
      margin: 0;
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .stack {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 14px;
      margin-top: 18px;
    }

    .card {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 18px 36px rgba(28, 38, 99, 0.08);
    }

    .card.dark {
      background: linear-gradient(180deg, #0e1b66 0%, #152474 100%);
      color: var(--white);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 0 24px 42px rgba(9, 19, 85, 0.22);
    }

    .card-body {
      padding: 16px;
    }

    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(29, 220, 255, 0.13);
    }

    .badge.pink {
      color: #8b1454;
      background: rgba(248, 76, 162, 0.16);
    }

    .badge.dark {
      color: var(--white);
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .estimate-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: start;
      margin-top: 12px;
    }

    .vehicle-title {
      margin: 0;
      font-size: 15px;
      line-height: 1.5;
      color: var(--text-black);
      font-weight: 700;
    }

    .vehicle-sub {
      margin: 3px 0 0;
      font-size: 12px;
      color: var(--text-gray);
    }

    .confidence {
      text-align: right;
    }

    .confidence-label {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .confidence-value {
      margin-top: 4px;
      font-size: 18px;
      line-height: 1;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .price-block {
      margin-top: 16px;
      display: grid;
      gap: 8px;
    }

    .price-label {
      font-size: 12px;
      color: var(--text-gray);
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .price-value {
      font-family: var(--font-number);
      font-size: 42px;
      line-height: 0.95;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
    }

    .price-value small {
      font-family: var(--font-sans);
      font-size: 18px;
      font-weight: 700;
      margin-left: 4px;
    }

    .delta-text {
      font-size: 12px;
      color: #098b57;
      font-weight: 700;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .mini-stat {
      padding: 12px;
      border-radius: 14px;
      background: var(--back-white);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .mini-stat .label {
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .mini-stat .value {
      margin-top: 4px;
      font-size: 18px;
      line-height: 1.2;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .mini-stat .caption {
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .segmented {
      display: inline-flex;
      gap: 6px;
      padding: 6px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.06);
    }

    .segment {
      border: 0;
      min-width: 72px;
      min-height: 36px;
      border-radius: 999px;
      background: transparent;
      color: var(--dark-blue);
      font: inherit;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .segment.is-active {
      background: var(--back-blue);
      color: var(--white);
      box-shadow: 0 10px 20px rgba(9, 19, 85, 0.18);
    }

    .chart-card {
      padding: 16px;
    }

    .chart-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 12px;
      margin-bottom: 10px;
    }

    .chart-title {
      margin: 0;
      font-size: 15px;
      line-height: 1.5;
      color: inherit;
      font-weight: 800;
    }

    .chart-note {
      margin: 2px 0 0;
      font-size: 11px;
      line-height: 1.5;
      color: inherit;
      opacity: 0.75;
    }

    .chart-wrap {
      position: relative;
      border-radius: 14px;
      overflow: hidden;
    }

    .legend {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .legend-swatch {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .insight-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .insight {
      padding: 12px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.1);
    }

    .insight strong {
      display: block;
      font-size: 20px;
      line-height: 1.1;
      color: var(--white);
      font-family: var(--font-number);
    }

    .insight span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-light-blue);
    }

    .primary-cta {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      min-height: 46px;
      border: 0;
      border-radius: var(--radius-button);
      padding: 12px 18px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font: inherit;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 16px 30px rgba(77, 180, 255, 0.24);
    }

    .primary-cta.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 16px 30px rgba(248, 76, 162, 0.24);
    }

    .support {
      margin-top: 10px;
      text-align: center;
      font-size: 11px;
      color: var(--text-gray);
    }

    .spend-grid {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .spend-item {
      display: grid;
      gap: 6px;
    }

    .spend-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      font-size: 12px;
      font-weight: 700;
      color: inherit;
    }

    .progress {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.1);
      overflow: hidden;
    }

    .card.dark .progress {
      background: rgba(255, 255, 255, 0.14);
    }

    .progress > span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transform-origin: left center;
      transition: width 0.4s ease;
    }

    .progress.pink > span {
      background: var(--gradient-pink);
    }

    .compare-hero {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 12px;
      padding: 18px;
      border-radius: 22px;
      background: linear-gradient(180deg, #0f1d6b 0%, #16257a 100%);
      color: var(--white);
      box-shadow: 0 24px 42px rgba(9, 19, 85, 0.22);
    }

    .callout-big {
      display: flex;
      align-items: end;
      gap: 10px;
      flex-wrap: wrap;
    }

    .callout-big strong {
      font-family: var(--font-number);
      font-size: 76px;
      line-height: 0.88;
      letter-spacing: -0.06em;
      color: #6fe1ff;
    }

    .callout-big span {
      font-size: 24px;
      line-height: 1;
      font-weight: 800;
    }

    .callout-small {
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-light-blue);
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      margin-top: 12px;
    }

    .compare-table th,
    .compare-table td {
      padding: 12px 8px;
      text-align: center;
      border-bottom: 1px solid rgba(28, 38, 99, 0.08);
    }

    .compare-table th:first-child,
    .compare-table td:first-child {
      text-align: left;
      width: 34%;
    }

    .compare-table thead th {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 800;
    }

    .compare-table .highlight-col {
      color: var(--dark-blue);
      background: rgba(29, 220, 255, 0.09);
      font-weight: 800;
    }

    .compare-table .muted {
      color: var(--text-gray);
    }

    .stress-card {
      padding: 16px;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 18px 36px rgba(28, 38, 99, 0.08);
    }

    .stress-row {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .stress-item {
      display: grid;
      gap: 6px;
    }

    .stress-label {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .stress-track {
      height: 12px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .stress-bar {
      display: block;
      height: 100%;
      border-radius: inherit;
      transition: width 0.35s ease;
    }

    .stress-bar.ucarpac {
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
    }

    .stress-bar.bulk {
      background: linear-gradient(90deg, #ff9c4c, #ff784d);
    }

    .stress-bar.other {
      background: linear-gradient(90deg, #f84ca2, #ff7fbf);
    }

    .footer-badges {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 14px;
    }

    .footer-badges .badge {
      background: rgba(255, 255, 255, 0.88);
    }

    .sparkle {
      position: absolute;
      inset: auto 18px 118px auto;
      width: 84px;
      height: 84px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.25) 0%, rgba(248, 76, 162, 0) 70%);
      animation: floaty 3s ease-in-out infinite;
      pointer-events: none;
    }

    .screen-footer-space {
      height: 4px;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 0.9;
      }
      50% {
        transform: scale(1.18);
        opacity: 1;
      }
    }

    @keyframes floaty {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-8px);
      }
    }

    @media (min-width: 960px) {
      .shot {
        grid-template-columns: minmax(0, 380px) minmax(0, 1fr);
        justify-content: center;
      }

      .shot-meta {
        order: 1;
      }

      .device {
        order: 2;
      }
    }

    @media (max-width: 959px) {
      .kpi-strip {
        grid-template-columns: 1fr;
      }

      .shot-meta {
        max-width: none;
      }
    }

    @media (max-width: 460px) {
      body {
        padding-inline: 10px;
      }

      .device {
        border-radius: 28px;
      }

      .screen {
        padding-inline: 14px;
      }

      .hero h2 {
        font-size: 28px;
      }

      .price-value {
        font-size: 38px;
      }

      .callout-big strong {
        font-size: 68px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="topbar">
      <div class="title-block">
        <div>
          <div class="eyebrow">ASO / ストアPV→DL率 改善案 / 2026-03-12</div>
          <h1>UcarPAC ストアスクショ検証プロトタイプ</h1>
          <p class="summary">B案のデータドリブン訴求。数字、比較、時系列グラフで「ダウンロードする理由」を即理解させる構成です。3枚とも 375px 基準のストアスクリーンショットとして確認できます。</p>
        </div>
      </div>

      <div class="kpi-strip">
        <div class="kpi-card">
          <div class="kpi-label">Current CVR</div>
          <div class="kpi-value">17.3%</div>
          <div class="kpi-meta">ストア詳細ページ閲覧からDLへの現状値</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Target CVR</div>
          <div class="kpi-value">25.0%</div>
          <div class="kpi-meta">目標との差分 <span class="positive">+7.7pt</span></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">Focus Message</div>
          <div class="kpi-value">3軸</div>
          <div class="kpi-meta">AI査定 / 出費管理 / 電話0本の安心</div>
        </div>
      </div>
    </header>

    <section class="controls">
      <div class="tabs" role="tablist" aria-label="スクリーンショット切り替え">
        <button class="tab is-active" data-target="shot-a" role="tab" aria-selected="true">A: AI査定 / iOS</button>
        <button class="tab" data-target="shot-b" role="tab" aria-selected="false">B: 出費管理 / Android</button>
        <button class="tab" data-target="shot-c" role="tab" aria-selected="false">C: 競合比較 / 電話0本</button>
      </div>
      <div class="actions">
        <button class="action-btn" id="playDemo">数値アニメーションを見る</button>
        <button class="action-btn secondary" id="resetDemo">初期状態に戻す</button>
      </div>
    </section>

    <main class="gallery">
      <section class="shot is-active" id="shot-a">
        <aside class="shot-meta">
          <div class="meta-card">
            <h3 class="meta-title">スクショA: AI査定を最前面に出す</h3>
            <p class="meta-text">iOS向け。競合ゼロの「AI査定 + 将来予測 + 個人情報不要」を1枚で理解させます。価格の具体値と予測グラフで、アプリを入れる理由を数字で示す構成です。</p>
          </div>
          <div class="meta-card">
            <ul class="meta-list">
