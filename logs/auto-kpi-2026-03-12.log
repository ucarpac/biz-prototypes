    function renderSpendBars(mode) {
      const data = spendData[mode].bars;
      bBars.innerHTML = "";
      data.forEach((item, index) => {
        const group = document.createElementNS("http://www.w3.org/2000/svg", "g");
        const x = 24 + index * 47;
        const valueHeight = item.value;
        const spendHeight = item.spend;

        const valueRect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
        valueRect.setAttribute("x", x);
        valueRect.setAttribute("y", 156 - valueHeight);
        valueRect.setAttribute("width", 16);
        valueRect.setAttribute("height", valueHeight);
        valueRect.setAttribute("rx", 8);
        valueRect.setAttribute("fill", "#6FE1FF");

        const spendRect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
        spendRect.setAttribute("x", x + 20);
        spendRect.setAttribute("y", 156 - spendHeight);
        spendRect.setAttribute("width", 16);
        spendRect.setAttribute("height", spendHeight);
        spendRect.setAttribute("rx", 8);
        spendRect.setAttribute("fill", "#F84CA2");

        group.appendChild(valueRect);
        group.appendChild(spendRect);
        bBars.appendChild(group);
      });
    }

    function updateSpend(mode) {
      const data = spendData[mode];
      bAvg.textContent = data.avg;
      bFuture.textContent = data.future;
      bChartNote.textContent = data.note;
      bGasAmount.textContent = data.categories.gas[0];
      bInsuranceAmount.textContent = data.categories.insurance[0];
      bParkingAmount.textContent = data.categories.parking[0];
      bServiceAmount.textContent = data.categories.service[0];
      bGasBar.style.width = data.categories.gas[1] + "%";
      bInsuranceBar.style.width = data.categories.insurance[1] + "%";
      bParkingBar.style.width = data.categories.parking[1] + "%";
      bServiceBar.style.width = data.categories.service[1] + "%";
      spendButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.spend === mode);
      });
      renderSpendBars(mode);
    }

    spendButtons.forEach((button) => {
      button.addEventListener("click", () => updateSpend(button.dataset.spend));
    });

    const compareData = {
      check: {
