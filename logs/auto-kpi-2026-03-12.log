  </main>

  <script>
    (function () {
      const chips = Array.from(document.querySelectorAll(".control-chip"));
      const screens = Array.from(document.querySelectorAll(".screen"));
      let activeIndex = 0;
      let autoTimer = null;

      function showScreen(index) {
        activeIndex = index;
        chips.forEach((chip, chipIndex) => {
          chip.classList.toggle("is-active", chipIndex === index);
        });
        screens.forEach((screen, screenIndex) => {
          screen.classList.toggle("is-active", screenIndex === index);
        });
      }

      function startRotation() {
        clearInterval(autoTimer);
        autoTimer = setInterval(function () {
          showScreen((activeIndex + 1) % screens.length);
        }, 6500);
      }

      chips.forEach((chip, index) => {
        chip.addEventListener("click", function () {
          showScreen(index);
          startRotation();
        });
      });

      showScreen(0);
      startRotation();

      const forecastBtn = document.getElementById("forecastBtn");
      const forecastGrid = document.getElementById("forecastGrid");
      const forecastCaption = document.getElementById("forecastCaption");
      let forecastExpanded = false;

      forecastBtn.addEventListener("click", function () {
        forecastExpanded = !forecastExpanded;
        forecastCaption.textContent = forecastExpanded ? "1年先までの予測" : "3か月と6か月の予測";
        forecastGrid.innerHTML = forecastExpanded
          ? [
              '<div class="forecast-tile"><span>現在</span><strong>168.4万</strong></div>',
              '<div class="forecast-tile"><span>6か月後</span><strong>158.6万</strong></div>',
              '<div class="forecast-tile"><span>12か月後</span><strong>149.9万</strong></div>'
            ].join("")
          : [
              '<div class="forecast-tile"><span>現在</span><strong>168.4万</strong></div>',
              '<div class="forecast-tile"><span>3か月後</span><strong>164.2万</strong></div>',
              '<div class="forecast-tile"><span>6か月後</span><strong>158.6万</strong></div>'
            ].join("");
        forecastBtn.textContent = forecastExpanded ? "半年表示に戻す" : "売り時を見てみる";
      });

      const segmentButtons = Array.from(document.querySelectorAll(".segment-btn"));
      const fills = Array.from(document.querySelectorAll(".bar-fill"));
      const sumTotal = document.getElementById("sumTotal");
      const sumDiff = document.getElementById("sumDiff");
      const sumFeeling = document.getElementById("sumFeeling");
      const gasLabel = document.getElementById("gasLabel");
      const insLabel = document.getElementById("insLabel");
      const parkLabel = document.getElementById("parkLabel");
      const maintLabel = document.getElementById("maintLabel");
      const insightBanner = document.getElementById("insightBanner");

      function updateExpense(mode) {
        segmentButtons.forEach(btn => {
          btn.classList.toggle("is-active", btn.dataset.mode === mode);
        });

        fills.forEach(fill => {
          const value = fill.dataset[mode];
          fill.style.width = value + "%";
        });

        if (mode === "monthly") {
          sumTotal.textContent = "34,800円";
          sumDiff.textContent = "9.8万円";
          sumFeeling.textContent = "今が安心";
          gasLabel.textContent = "1.24万";
          insLabel.textContent = "0.81万";
          parkLabel.textContent = "1.10万";
          maintLabel.textContent = "0.65万";
          insightBanner.textContent = "6か月待つと査定予測は約9.8万円ダウン。維持費まで含めると、今売る判断に納得しやすい状態です。";
        } else {
          sumTotal.textContent = "41.8万円";
          sumDiff.textContent = "19.7万円";
          sumFeeling.textContent = "売り時接近";
          gasLabel.textContent = "14.9万";
          insLabel.textContent = "9.7万";
          parkLabel.textContent = "13.2万";
          maintLabel.textContent = "4.0万";
          insightBanner.textContent = "年間維持費の見込みは41.8万円。価格下落と合わせると、1年で約19.7万円分の差が見えてきます。";
        }
      }

      segmentButtons.forEach(btn => {
        btn.addEventListener("click", function () {
          updateExpense(btn.dataset.mode);
        });
      });

      setTimeout(function () {
        updateExpense("monthly");
      }, 250);

      const compareButtons = Array.from(document.querySelectorAll(".compare-pill"));
      const compareCaption = document.getElementById("compareCaption");
      const callsUcar = document.getElementById("callsUcar");
      const callsOther = document.getElementById("callsOther");
      const valueUcar = document.getElementById("valueUcar");
      const valueOther = document.getElementById("valueOther");
      const privacyUcar = document.getElementById("privacyUcar");
      const privacyOther = document.getElementById("privacyOther");
      const sellUcar = document.getElementById("sellUcar");
      const sellOther = document.getElementById("sellOther");
      const compareBtn = document.getElementById("compareBtn");
      const zeroCounter = document.getElementById("zeroCounter");
      let compareMode = "check";

      function updateCompare(mode) {
        compareMode = mode;
        compareButtons.forEach(btn => {
          btn.classList.toggle("is-active", btn.dataset.compare === mode);
        });

        if (mode === "check") {
          compareCaption.textContent = "相場チェック段階";
          callsUcar.textContent = "0本";
          callsOther.textContent = "複数社の可能性";
          valueUcar.textContent = "AIですぐ確認";
          valueOther.textContent = "申込後に確認";
          privacyUcar.textContent = "基本不要";
          privacyOther.textContent = "入力が必要な場合あり";
          sellUcar.textContent = "電話1社のみ";
          sellOther.textContent = "複数社対応";
          zeroCounter.textContent = "0本";
        } else {
          compareCaption.textContent = "売却申し込み段階";
          callsUcar.textContent = "1社のみ";
          callsOther.textContent = "複数社対応";
          valueUcar.textContent = "最高額オークション";
          valueOther.textContent = "各社と個別交渉";
          privacyUcar.textContent = "この段階で入力";
          privacyOther.textContent = "申込時に入力";
          sellUcar.textContent = "8,000社が入札";
          sellOther.textContent = "比較対象次第";
          zeroCounter.textContent = "1社";
        }
      }

      compareButtons.forEach(btn => {
        btn.addEventListener("click", function () {
          updateCompare(btn.dataset.compare);
        });
      });

      compareBtn.addEventListener("click", function () {
        updateCompare(compareMode === "check" ? "sell" : "check");
      });

      updateCompare("check");

      const expenseBtn = document.getElementById("expenseBtn");
      expenseBtn.addEventListener("click", function () {
        const nextMode = document.querySelector(".segment-btn.is-active").dataset.mode === "monthly" ? "yearly" : "monthly";
        updateExpense(nextMode);
      });
    })();
  </script>
</body>
