    }

    .number-big {
      font-family: var(--font-number);
      color: var(--dark-blue);
      font-size: 44px;
      line-height: 52px;
      letter-spacing: -0.03em;
    }

    .number-caption {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      max-width: 130px;
    }

    .line-chart-wrap {
      background: linear-gradient(180deg, rgba(109,194,255,0.10), rgba(248,76,162,0.04));
      border-radius: 18px;
      padding: 12px;
      border: 1px solid rgba(29,220,255,0.12);
    }

    .legend-row {
      margin-top: 10px;
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .legend {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }

    .actions {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .btn {
      border: 0;
      border-radius: var(--radius-button);
      min-height: 43px;
      padding: 12px 16px;
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
      cursor: pointer;
      transition: transform .2s ease, box-shadow .2s ease, opacity .2s ease;
    }

    .btn:active {
      transform: scale(0.98);
    }

    .btn-primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 12px 24px rgba(77,180,255,0.28);
    }

    .btn-secondary {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 12px 24px rgba(248,76,162,0.24);
    }

    .split-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .mini-card {
      background: var(--back-white);
      border: 1px solid rgba(28,38,99,0.06);
      border-radius: 16px;
      padding: 14px;
    }

    .mini-card h3 {
      margin: 0 0 6px;
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
    }

    .mini-card p {
      margin: 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 18px;
    }

    .progress-list {
      display: grid;
      gap: 14px;
    }

    .progress-item {
      display: grid;
      gap: 8px;
    }

    .progress-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      font-size: 12px;
      line-height: 18px;
    }

    .progress-top strong {
      color: var(--dark-blue);
    }

    .progress-bar {
      height: 10px;
      background: var(--back-gray);
      border-radius: 999px;
      overflow: hidden;
      position: relative;
    }

    .progress-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #1ddcff, #4db4ff, #f84ca2);
      width: 0;
      transition: width 0.9s cubic-bezier(.16,1,.3,1);
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      line-height: 18px;
      overflow: hidden;
      border-radius: 14px;
    }

    .compare-table thead th {
      background: var(--back-blue);
      color: var(--white);
      padding: 12px 8px;
      text-align: center;
      font-size: 11px;
    }

    .compare-table tbody td {
      padding: 12px 8px;
      border-bottom: 1px solid var(--ruled-line);
      text-align: center;
      background: rgba(255,255,255,0.78);
    }

    .compare-table tbody tr:last-child td {
      border-bottom: 0;
    }

    .compare-table tbody td:first-child {
      text-align: left;
      font-weight: 700;
      color: var(--dark-blue);
      background: #f8fbff;
    }

    .ok {
      color: #007d48;
      font-weight: 800;
    }

    .ng {
      color: var(--text-disabled);
      font-weight: 700;
    }

    .warn {
      color: #c06e00;
      font-weight: 800;
    }

    .auction-card {
      background: linear-gradient(135deg, rgba(9,19,85,0.96), rgba(28,38,99,0.92));
      border-radius: 22px;
      padding: 16px;
      color: var(--white);
      position: relative;
      overflow: hidden;
    }

    .auction-card::after {
      content: "";
      position: absolute;
      inset: auto -60px -70px auto;
      width: 180px;
      height: 180px;
      background: rgba(29,220,255,0.15);
      border-radius: 50%;
    }

    .auction-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .auction-price {
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 46px;
      margin: 8px 0 4px;
    }

    .auction-meta {
      color: rgba(255,255,255,0.72);
      font-size: 12px;
      line-height: 18px;
    }

    .tag-stack {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: flex-end;
    }

    .auction-tag {
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .auction-tag.active {
      background: linear-gradient(90deg, #091355, #1d2e93);
      border: 1px solid rgba(255,255,255,0.16);
      color: var(--white);
    }

    .auction-tag.phone {
      background: rgba(248,76,162,0.18);
      color: #ffc5e1;
      border: 1px solid rgba(248,76,162,0.3);
    }

    .timeline {
      margin-top: 18px;
      display: grid;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .timeline-step {
      display: grid;
      grid-template-columns: 20px 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .timeline-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: rgba(255,255,255,0.22);
      border: 2px solid rgba(255,255,255,0.26);
    }

    .timeline-step.done .timeline-dot {
      background: #4dffca;
      border-color: #4dffca;
      box-shadow: 0 0 0 5px rgba(77,255,202,0.14);
    }

    .timeline-label {
      font-size: 12px;
      line-height: 18px;
    }

    .timeline-time {
      font-size: 10px;
      line-height: 15px;
      color: rgba(255,255,255,0.66);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 12px;
    }

    .expense-item {
      background: var(--back-white);
      border-radius: 16px;
      padding: 12px;
      border: 1px solid rgba(28,38,99,0.06);
    }

    .expense-item span {
      display: block;
    }

    .expense-label {
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
      margin-bottom: 6px;
    }

    .expense-value {
      font-family: var(--font-number);
      font-size: 22px;
      line-height: 28px;
      color: var(--dark-blue);
    }

    .expense-diff {
      margin-top: 4px;
      font-size: 10px;
      line-height: 15px;
      color: var(--pink);
      font-weight: 700;
    }

    .tabs {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
      margin-bottom: 14px;
    }

    .tab {
      flex: 0 0 auto;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      border-radius: 22px;
      min-height: 43px;
      padding: 10px 16px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: .25s ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
    }

    .insight-box {
      margin-top: 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(248,76,162,0.08), rgba(29,220,255,0.10));
      border: 1px solid rgba(248,76,162,0.12);
      padding: 14px;
      display: grid;
      gap: 8px;
    }

    .insight-box strong {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
    }

    .insight-box p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .floating-cta {
      position: fixed;
      left: 50%;
      bottom: 16px;
      transform: translateX(-50%);
      width: calc(100% - 32px);
      max-width: 398px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: 0 18px 40px rgba(9,19,85,0.16);
      backdrop-filter: blur(12px);
      border-radius: 24px;
      padding: 10px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      z-index: 20;
    }

    .floating-copy {
      padding-left: 8px;
    }

    .floating-copy strong {
      display: block;
      font-size: 13px;
      line-height: 20px;
      color: var(--dark-blue);
    }

    .floating-copy span {
      display: block;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .hidden {
      display: none;
    }

    .fade-up {
      opacity: 0;
      transform: translateY(14px);
      animation: fadeUp .7s ease forwards;
    }

    .fade-up.delay-1 { animation-delay: .08s; }
    .fade-up.delay-2 { animation-delay: .16s; }
    .fade-up.delay-3 { animation-delay: .24s; }
    .fade-up.delay-4 { animation-delay: .32s; }

    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (min-width: 768px) {
      .app-shell {
        max-width: 960px;
      }

      main {
        grid-template-columns: 1.15fr 0.85fr;
        align-items: start;
      }

      .hero,
      .full-span,
      .floating-cta {
        grid-column: 1 / -1;
      }

      .floating-cta {
        max-width: 720px;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="topbar fade-up">
      <div class="brand">
        <small>AI Valuation Dashboard</small>
        <strong>UcarPAC</strong>
      </div>
      <div class="status-pill">2026年3月相場更新済み</div>
    </header>

    <main>
      <section class="hero fade-up delay-1 full-span">
        <div class="hero-head">
          <div>
            <span class="eyebrow">個人情報なしで相場チェック</span>
            <h1>愛車の価値を<br />数字で判断する</h1>
            <p>現在価格、3ヶ月後予測、出費推移、競合比較を1画面に統合。売るタイミングの納得感をデータでつくる。</p>
          </div>
          <div class="badge">電話は1社のみ</div>
        </div>

        <div class="chip-row" id="carSelector">
          <button class="chip active" data-car="harrier">2021 ハリアー Z</button>
          <button class="chip" data-car="voxy">2020 ヴォクシー煌III</button>
          <button class="chip" data-car="fit">2019 フィット e:HEV</button>
        </div>

        <div class="hero-metrics">
          <div class="metric-card">
            <span class="metric-label">AI査定価格</span>
            <span class="metric-value" id="heroPrice">¥2.84M</span>
            <span class="metric-sub">前月比 +4.2%</span>
          </div>
          <div class="metric-card">
            <span class="metric-label">3ヶ月後予測</span>
            <span class="metric-value" id="heroForecast">¥2.71M</span>
            <span class="metric-sub">売り時指数 87</span>
          </div>
          <div class="metric-card">
            <span class="metric-label">入札ポテンシャル</span>
            <span class="metric-value" id="heroBidders">7,842</span>
            <span class="metric-sub">参加店ネットワーク</span>
          </div>
        </div>
      </section>

      <section class="panel fade-up delay-2">
        <div class="panel-header">
          <div>
            <h2 class="panel-title">AI査定トレンド</h2>
            <p class="panel-note">今売る場合と3ヶ月後の差額をグラフで可視化</p>
          </div>
          <div class="badge" id="deltaBadge">今売ると +13万円</div>
        </div>

        <div class="number-hero">
          <div>
            <div class="number-big" id="mainPrice">284万円</div>
            <div class="number-caption">オークション想定上限を加味したAI査定レンジ中央値</div>
          </div>
          <svg width="96" height="72" viewBox="0 0 96 72" aria-hidden="true">
            <defs>
              <linearGradient id="miniGrad" x1="0%" x2="100%">
                <stop offset="0%" stop-color="#1ddcff"></stop>
                <stop offset="100%" stop-color="#f84ca2"></stop>
              </linearGradient>
            </defs>
            <polyline fill="none" stroke="url(#miniGrad)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"
              points="4,52 22,44 40,47 58,31 76,28 92,12"></polyline>
            <circle cx="92" cy="12" r="4.5" fill="#f84ca2"></circle>
          </svg>
        </div>

        <div class="line-chart-wrap">
          <svg id="lineChart" viewBox="0 0 320 180" width="100%" height="180" role="img" aria-label="価格推移グラフ">
            <defs>
              <linearGradient id="lineArea" x1="0%" x2="0%" y1="0%" y2="100%">
                <stop offset="0%" stop-color="rgba(29,220,255,0.32)"></stop>
                <stop offset="100%" stop-color="rgba(29,220,255,0.02)"></stop>
              </linearGradient>
            </defs>
            <g opacity="0.2" stroke="#1c2663" stroke-width="1">
              <line x1="18" y1="24" x2="302" y2="24"></line>
              <line x1="18" y1="66" x2="302" y2="66"></line>
              <line x1="18" y1="108" x2="302" y2="108"></line>
              <line x1="18" y1="150" x2="302" y2="150"></line>
            </g>
            <path id="areaPath" fill="rgba(29,220,255,0.12)"></path>
            <path id="linePath" fill="none" stroke="#1ddcff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
            <path id="forecastPath" fill="none" stroke="#f84ca2" stroke-width="4" stroke-dasharray="8 6" stroke-linecap="round" stroke-linejoin="round"></path>
            <g id="chartDots"></g>
            <g fill="#737373" font-size="10" font-family="Noto Sans JP">
              <text x="18" y="170">現在</text>
              <text x="108" y="170">1ヶ月</text>
              <text x="196" y="170">2ヶ月</text>
              <text x="272" y="170">3ヶ月</text>
            </g>
          </svg>
        </div>

        <div class="legend-row">
          <span class="legend"><i class="legend-dot" style="background:#1ddcff"></i>現在相場</span>
          <span class="legend"><i class="legend-dot" style="background:#f84ca2"></i>将来予測</span>
          <span class="legend"><i class="legend-dot" style="background:#091355"></i>上位入札帯</span>
        </div>

        <div class="actions">
          <button class="btn btn-primary" id="simulateBtn">写真を追加して査定精度を上げる</button>
          <button class="btn btn-secondary" id="toggleViewBtn">比較表をハイライト表示</button>
        </div>
      </section>

      <section class="panel fade-up delay-2">
        <div class="panel-header">
          <div>
            <h2 class="panel-title">売却判断スコア</h2>
            <p class="panel-note">KPIベースで「今売る理由」を数値化</p>
          </div>
          <div class="badge">更新頻度 週次</div>
        </div>

        <div class="progress-list">
          <div class="progress-item">
            <div class="progress-top">
              <strong>査定価格の優位性</strong>
              <span id="scoreA">89 / 100</span>
            </div>
            <div class="progress-bar"><div class="progress-fill" data-value="89"></div></div>
          </div>
          <div class="progress-item">
            <div class="progress-top">
              <strong>電話負担の低さ</strong>
              <span id="scoreB">96 / 100</span>
            </div>
            <div class="progress-bar"><div class="progress-fill" data-value="96"></div></div>
          </div>
          <div class="progress-item">
            <div class="progress-top">
              <strong>個人情報不要の安心感</strong>
              <span id="scoreC">94 / 100</span>
            </div>
            <div class="progress-bar"><div class="progress-fill" data-value="94"></div></div>
          </div>
          <div class="progress-item">
            <div class="progress-top">
              <strong>将来値下がりリスク</strong>
              <span id="scoreD">74 / 100</span>
            </div>
            <div class="progress-bar"><div class="progress-fill" data-value="74"></div></div>
          </div>
        </div>

        <div class="insight-box" id="insightBox">
          <strong>データインサイト</strong>
          <p>ハリアー Z は4月の需要ピーク前で、3ヶ月後予測との差が13万円。写真入力を完了すると中央値の上振れ余地がさらに2.8万円あります。</p>
        </div>
      </section>

      <section class="panel fade-up delay-3">
        <div class="panel-header">
          <div>
            <h2 class="panel-title">競合比較</h2>
            <p class="panel-note">オークション規模、連絡負荷、AI機能で定量比較</p>
          </div>
          <div class="badge">UcarPAC優位</div>
        </div>

        <table class="compare-table" id="compareTable">
          <thead>
            <tr>
              <th>機能</th>
              <th>UcarPAC</th>
              <th>MOTA</th>
              <th>セルカ</th>
              <th>ズバット</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>AI査定</td>
              <td class="ok">あり</td>
              <td class="ng">なし</td>
              <td class="ng">なし</td>
              <td class="ng">なし</td>
            </tr>
            <tr>
              <td>将来予測</td>
              <td class="ok">3ヶ月先</td>
              <td class="ng">なし</td>
              <td class="ng">なし</td>
              <td class="ng">なし</td>
            </tr>
            <tr>
              <td>電話本数</td>
              <td class="ok">1社のみ</td>
              <td class="warn">最大3社</td>
              <td class="ok">1社のみ</td>
              <td class="ng">最大10社</td>
            </tr>
            <tr>
              <td>入札ネットワーク</td>
              <td class="ok">8,000社</td>
              <td class="warn">数百社</td>
              <td class="ok">8,000社</td>
              <td class="warn">最大10社</td>
            </tr>
            <tr>
              <td>個人情報不要査定</td>
              <td class="ok">対応</td>
              <td class="ng">非対応</td>
              <td class="ng">非対応</td>
              <td class="ng">非対応</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="auction-card fade-up delay-3">
        <div class="auction-top">
          <div>
            <div class="eyebrow">オークション進捗</div>
            <div class="auction-price" id="bidPrice">291万円</div>
            <div class="auction-meta">最高入札額 / 残り 16時間 / 東京都・2021年式ハリアー Z</div>
          </div>
          <div class="tag-stack">
            <div class="auction-tag active">8,000社が競う</div>
            <div class="auction-tag phone">やりとりは1社</div>
          </div>
        </div>

        <div class="timeline">
          <div class="timeline-step done">
            <div class="timeline-dot"></div>
            <div class="timeline-label">AI査定完了</div>
            <div class="timeline-time">09:10</div>
          </div>
          <div class="timeline-step done">
            <div class="timeline-dot"></div>
            <div class="timeline-label">出品情報を公開</div>
            <div class="timeline-time">11:25</div>
          </div>
          <div class="timeline-step done">
            <div class="timeline-dot"></div>
            <div class="timeline-label">最高額が更新</div>
            <div class="timeline-time">15:42</div>
          </div>
          <div class="timeline-step">
            <div class="timeline-dot"></div>
            <div class="timeline-label">売却先の1社と日程調整</div>
            <div class="timeline-time">次回</div>
          </div>
        </div>
      </section>

      <section class="panel fade-up delay-4 full-span">
        <div class="panel-header">
          <div>
            <h2 class="panel-title">資産価値と出費管理</h2>
            <p class="panel-note">価格変動と維持費を同じタイムラインで見る</p>
          </div>
          <div class="badge">出費管理連携</div>
        </div>

        <div class="tabs" id="tabs">
          <button class="tab active" data-view="month">月別サマリー</button>
          <button class="tab" data-view="fuel">ガソリン</button>
          <button class="tab" data-view="insurance">保険</button>
          <button class="tab" data-view="inspection">車検・整備</button>
        </div>

        <div class="split-grid">
          <div class="mini-card">
            <h3>年間維持費</h3>
            <div class="number-big" style="font-size:32px;line-height:38px;" id="annualCost">42.6万円</div>
            <p>月平均 35,500円。前年より 6.4% 改善。</p>
          </div>
          <div class="mini-card">
            <h3>価値残存率</h3>
            <div class="number-big" style="font-size:32px;line-height:38px;" id="retentionRate">68%</div>
            <p>購入価格 대비の残価。SUV市場は同クラス平均より高水準。</p>
