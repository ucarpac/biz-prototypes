    function buildPath(values, offsetX, segment, heightScale) {
      return values.map((value, i) => {
        const x = offsetX + (segment * i);
        const y = 150 - ((value - 120) * heightScale);
        return `${i === 0 ? "M" : "L"} ${x} ${y}`;
      }).join(" ");
    }

    function drawChart(current, forecast) {
      const currentPath = buildPath(current, 36, 72, 1.45);
      const lastX = 36 + 72 * (current.length - 1);
      const lastY = 150 - ((current[current.length - 1] - 120) * 1.45);
      const forecastPathData = forecast.map((value, i) => {
        const x = lastX + 72 * (i + 1);
        const y = 150 - ((value - 120) * 1.45);
        return `${i === 0 ? "M" : "L"} ${x} ${y}`;
      }).join(" ");

      document.getElementById("linePath").setAttribute("d", currentPath);
      document.getElementById("forecastPath").setAttribute("d", `M ${lastX} ${lastY} ${forecastPathData.replace("M ", "L ")}`);
      document.getElementById("areaPath").setAttribute(
        "d",
        `${currentPath} L ${lastX} 150 L 36 150 Z`
      );

      const dots = [];
      current.forEach((value, i) => {
        const x = 36 + 72 * i;
        const y = 150 - ((value - 120) * 1.45);
        dots.push(`<circle cx="${x}" cy="${y}" r="4.5" fill="#1ddcff"></circle>`);
      });
      forecast.forEach((value, i) => {
        const x = lastX + 72 * (i + 1);
        const y = 150 - ((value - 120) * 1.45);
        dots.push(`<circle cx="${x}" cy="${y}" r="4.5" fill="#f84ca2"></circle>`);
      });
      document.getElementById("chartDots").innerHTML = dots.join("");
    }

