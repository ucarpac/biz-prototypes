    document.getElementById("toggleViewBtn").addEventListener("click", () => {
      document.getElementById("compareTable").classList.toggle("highlight");
      const ucarCells = document.querySelectorAll("#compareTable tbody td:nth-child(2)");
      ucarCells.forEach(cell => {
        cell.style.background = cell.style.background ? "" : "linear-gradient(135deg, rgba(29,220,255,0.16), rgba(248,76,162,0.10))";
