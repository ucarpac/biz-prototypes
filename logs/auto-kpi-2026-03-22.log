<!-- A案: 感情に訴えるアプローチ。ユーザーの不安や期待に寄り添い、安心感を与えるデザイン。暖色系のアクセント、手書き風要素、親しみやすいイラスト的表現 -->
<!DOCTYPE html>
<html lang="ja">
<script src="../auth.js"></script>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UcarPAC App Prototype - A案</title>
  <style>
    :root {
      --pink: #F84CA2;
      --dark-blue: #1c2663;
      --white: #FFFFFF;
      --text-black: #404040;
      --text-gray: #737373;
      --text-disabled: #B3B3B3;
      --text-placeholder: rgba(28,38,99,0.3);
      --text-under-blue: #0056BA;
      --button-gray: #CACEE2;
      --button-link1: #4099FF;
      --button-link2: #40BFFF;
      --back-white: #FAFAFA;
      --light-gray: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-gray2: #e6e6e6;
      --back-blue: #091355;
      --back-dark-blue: #0a1348;
      --back-light-pink: #ffd8e8;
      --back-light-blue: #6fc2ff;
      --warm-cream: #fff6ef;
      --warm-peach: #ffd7c2;
      --warm-orange: #ff9d70;
      --warm-yellow: #ffe8a3;
      --error: #EB4646;
      --shadow: rgba(0,0,0,0.11);
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --gradient-warm: linear-gradient(135deg, #fff2d9, #ffd8e8 55%, #ffe8a3);
      --font-sans: "Noto Sans JP", "Hiragino Sans", system-ui, sans-serif;
      --font-number: "Righteous", "Noto Sans JP", sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-7: 27px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-card: 13px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
      --radius-button-lg: 43px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      background:
        radial-gradient(circle at top left, rgba(255, 232, 163, 0.7), transparent 32%),
        radial-gradient(circle at top right, rgba(248, 76, 162, 0.14), transparent 28%),
        linear-gradient(180deg, #fff9f4 0%, #fafcff 52%, #fff4f8 100%);
      color: var(--text-black);
      font-family: var(--font-sans);
      min-height: 100%;
    }

    body {
      display: flex;
      justify-content: center;
      padding: 0;
    }

    .app-shell {
      width: 100%;
      max-width: 430px;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
      padding-bottom: 120px;
    }

    .background-doodle,
    .background-doodle::before,
    .background-doodle::after {
      position: absolute;
      content: "";
      pointer-events: none;
    }

    .background-doodle {
      inset: 0;
      opacity: 0.85;
    }

    .background-doodle::before {
      width: 170px;
      height: 170px;
      right: -54px;
      top: 86px;
      background: rgba(255, 157, 112, 0.18);
      border-radius: 56% 44% 60% 40%;
      filter: blur(2px);
    }

    .background-doodle::after {
      width: 130px;
      height: 130px;
      left: -40px;
      top: 430px;
      background: rgba(248, 76, 162, 0.12);
      border-radius: 64% 36% 45% 55%;
    }

    .container {
      position: relative;
      z-index: 1;
      padding: 20px 16px 0;
    }

    .hero {
      position: relative;
      padding: 22px 18px 20px;
      border-radius: 28px;
      background: var(--gradient-warm);
      box-shadow: 0 16px 42px rgba(248, 76, 162, 0.12);
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      width: 150px;
      height: 150px;
      right: -24px;
      bottom: -52px;
      background: rgba(255,255,255,0.45);
      border-radius: 50%;
    }

    .hero-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .soft-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.82);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      box-shadow: 0 6px 14px rgba(28,38,99,0.08);
      white-space: nowrap;
    }

    .hero-title {
      margin: 0;
      font-size: 32px;
      line-height: 48px;
      font-weight: 800;
      color: var(--dark-blue);
      letter-spacing: -0.02em;
    }

    .hero-title .accent {
      position: relative;
      display: inline-block;
    }

    .hero-title .accent::after {
      content: "";
      position: absolute;
      left: -2px;
      right: -2px;
      bottom: 6px;
      height: 12px;
      background: rgba(255, 157, 112, 0.35);
      border-radius: 999px;
      z-index: -1;
      transform: rotate(-1.4deg);
    }

    .hero-copy {
      margin: 8px 0 18px;
      font-size: 14px;
      line-height: 21px;
      color: var(--text-black);
      max-width: 285px;
    }

    .hero-illustration {
      display: grid;
      grid-template-columns: 1fr 122px;
      gap: 12px;
      align-items: end;
    }

    .trust-note {
      background: rgba(255,255,255,0.86);
      border: 1px dashed rgba(248, 76, 162, 0.36);
      padding: 14px;
      border-radius: 18px;
    }

    .trust-note strong {
      display: block;
      font-size: 16px;
      line-height: 24px;
      color: var(--dark-blue);
      margin-bottom: 4px;
    }

    .trust-note span {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .car-face {
      width: 122px;
      height: 114px;
      position: relative;
      margin-left: auto;
    }

    .car-face .body {
      position: absolute;
      left: 8px;
      right: 8px;
      top: 28px;
      height: 54px;
      background: linear-gradient(180deg, #ffb890, #ff8f7a);
      border-radius: 20px 26px 18px 18px;
      border: 3px solid var(--dark-blue);
    }

    .car-face .roof {
      position: absolute;
      left: 28px;
      right: 24px;
      top: 8px;
      height: 34px;
      background: #fff6ef;
      border: 3px solid var(--dark-blue);
      border-bottom: none;
      border-radius: 26px 24px 8px 8px;
      transform: skewX(-10deg);
    }

    .car-face .wheel,
    .car-face .wheel::after {
      position: absolute;
      bottom: 6px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: var(--dark-blue);
      content: "";
    }

    .car-face .wheel {
      left: 22px;
    }

    .car-face .wheel::after {
      left: 54px;
      top: 0;
    }

    .car-face .eye,
    .car-face .eye::after {
      position: absolute;
      top: 48px;
      width: 8px;
      height: 14px;
      border-radius: 8px;
      background: var(--dark-blue);
      content: "";
    }

    .car-face .eye {
      left: 36px;
    }

    .car-face .eye::after {
      left: 38px;
      top: 0;
    }

    .car-face .smile {
      position: absolute;
      left: 46px;
      top: 63px;
      width: 28px;
      height: 14px;
      border-bottom: 3px solid var(--dark-blue);
      border-radius: 0 0 20px 20px;
    }

    .section {
      margin-top: 18px;
    }

    .section-title {
      margin: 0 0 10px;
      font-size: 22px;
      line-height: 33px;
      color: var(--dark-blue);
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .hand-note {
      display: inline-block;
      margin-left: 6px;
      padding: 3px 10px;
      border-radius: 999px;
      background: #fff5d8;
      color: #9a5b2f;
      font-size: 11px;
      line-height: 15px;
      transform: rotate(-4deg);
      font-weight: 700;
    }

    .card {
      background: rgba(255,255,255,0.92);
      border-radius: 13px;
      box-shadow: 0 8px 26px var(--shadow);
      padding: 16px;
      border: 1px solid rgba(205, 220, 237, 0.92);
    }

    .car-summary {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .car-thumb {
      width: 92px;
      height: 92px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.2), rgba(255,255,255,0)),
        linear-gradient(135deg, #dfe9ff, #eff8ff 48%, #ffdce9);
      position: relative;
      overflow: hidden;
      flex: 0 0 auto;
    }

    .car-thumb::before {
      content: "";
      position: absolute;
      inset: 20px 12px 18px;
      background: linear-gradient(180deg, #47b4ff, #1c2663);
      border-radius: 18px 18px 12px 12px;
      clip-path: polygon(10% 72%, 18% 42%, 37% 25%, 74% 25%, 90% 54%, 90% 72%);
      opacity: 0.85;
    }

    .car-thumb::after {
      content: "";
      position: absolute;
      width: 20px;
      height: 20px;
      left: 18px;
      bottom: 11px;
      border-radius: 50%;
      background: rgba(28,38,99,0.95);
      box-shadow: 38px 0 0 rgba(28,38,99,0.95);
    }

    .car-meta {
      flex: 1;
      min-width: 0;
    }

    .car-name {
      margin: 0 0 4px;
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .car-detail {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      margin: 0 0 10px;
    }

    .mini-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .mini-tag {
      font-size: 10px;
      line-height: 15px;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--back-gray);
      color: var(--dark-blue);
      font-weight: 700;
    }

    .status-row {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
      margin-top: 14px;
    }

    .status-row::-webkit-scrollbar {
      display: none;
    }

    .chip {
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      border-radius: 22px;
      min-height: 43px;
      padding: 10px 14px;
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      white-space: nowrap;
      transition: 0.25s ease;
      cursor: pointer;
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
      transform: translateY(-1px);
    }

    .estimate-card {
      padding: 18px 16px 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,247,251,0.92));
    }

    .estimate-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .estimate-label {
      margin: 0;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .estimate-price {
      margin: 4px 0 0;
      font-size: 32px;
      line-height: 48px;
      font-weight: 800;
      font-family: var(--font-number);
      color: var(--dark-blue);
      letter-spacing: 0.01em;
    }

    .estimate-price small {
      font-size: 14px;
      font-family: var(--font-sans);
      margin-left: 4px;
    }

    .comfort-pill {
      background: #fff5d8;
      color: #8a5e12;
      padding: 8px 10px;
      border-radius: 12px;
      font-size: 11px;
      line-height: 15px;
      font-weight: 700;
      text-align: center;
      min-width: 92px;
    }

    .range {
      margin-top: 8px;
      font-size: 14px;
      line-height: 21px;
      color: var(--text-black);
    }

    .range strong {
      color: var(--pink);
      font-weight: 800;
    }

    .graph {
      display: flex;
      gap: 10px;
      align-items: end;
      margin: 18px 0 10px;
      height: 160px;
      padding: 14px 10px 10px;
      border-radius: 16px;
      background: linear-gradient(180deg, #fff8fb, #eef8ff);
      position: relative;
      overflow: hidden;
    }

    .graph::before,
    .graph::after {
      content: "";
      position: absolute;
      left: 10px;
      right: 10px;
      border-top: 1px dashed rgba(28,38,99,0.12);
    }

    .graph::before {
      top: 58px;
    }

    .graph::after {
      top: 104px;
    }

    .bar-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      position: relative;
      z-index: 1;
    }

    .bar-value {
      font-size: 10px;
      line-height: 15px;
      color: var(--dark-blue);
      margin-bottom: 6px;
      font-weight: 700;
    }

    .bar {
      width: 100%;
      max-width: 72px;
      border-radius: 18px 18px 10px 10px;
      background: linear-gradient(180deg, #ffc79e, #f84ca2 58%, #1ddcff);
      box-shadow: inset 0 -8px 16px rgba(255,255,255,0.18);
      transition: height 0.45s ease, filter 0.3s ease;
      min-height: 20px;
    }

    .bar.current {
      background: linear-gradient(180deg, #ffdd91, #ff9f70 62%, #f84ca2);
    }

    .bar.future {
      background: linear-gradient(180deg, #8ce9ff, #4db4ff 60%, #1c2663);
    }

    .bar-wrap.active .bar {
      filter: saturate(1.05) brightness(1.02);
    }

    .bar-label {
      margin-top: 8px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .reassurance {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .reassurance .item {
      background: #fff;
      border-radius: 12px;
      padding: 10px 8px;
      text-align: center;
      border: 1px solid #f4eef2;
    }

    .reassurance strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      margin-bottom: 3px;
    }

    .reassurance span {
      font-size: 10px;
      line-height: 15px;
      color: var(--text-gray);
    }

    .primary-button,
    .secondary-button {
      width: 100%;
      min-height: 43px;
      border: none;
      border-radius: 30px;
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.2s ease;
    }

    .primary-button {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 10px 24px rgba(77,180,255,0.26);
    }

    .secondary-button {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 10px 24px rgba(248,76,162,0.24);
    }

    .primary-button:active,
    .secondary-button:active,
    .chip:active {
      transform: scale(0.98);
    }

    .button-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 14px;
    }

    .insight-grid {
      display: grid;
      gap: 12px;
    }

    .soft-card {
      border-radius: 16px;
      padding: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,246,239,0.92));
      border: 1px solid rgba(255, 215, 194, 0.8);
      box-shadow: 0 10px 24px rgba(255,157,112,0.08);
    }

    .soft-card h3 {
      margin: 0 0 6px;
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
    }

    .soft-card p {
      margin: 0;
      font-size: 13px;
      line-height: 19.5px;
      color: var(--text-gray);
    }

    .expense-figure {
      display: flex;
      align-items: end;
      gap: 10px;
      margin-top: 14px;
    }

    .expense-col {
      flex: 1;
      text-align: center;
    }

    .expense-bar {
      width: 100%;
      border-radius: 14px 14px 8px 8px;
      background: linear-gradient(180deg, #ffd39d, #ff9d70);
      margin: 0 auto 6px;
      transition: height 0.35s ease;
      min-height: 18px;
      max-width: 56px;
    }

    .expense-bar.blue {
      background: linear-gradient(180deg, #9cecff, #4db4ff);
    }

    .expense-caption {
      font-size: 11px;
      line-height: 15px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .expense-total {
      margin-top: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.85);
    }

    .expense-total strong {
      font-size: 20px;
      line-height: 30px;
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .timeline {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .timeline-step {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      align-items: start;
    }

    .timeline-dot {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: linear-gradient(180deg, #fff0c9, #ffd8e8);
      color: var(--dark-blue);
      display: grid;
      place-items: center;
      font-size: 12px;
      font-weight: 800;
      border: 1px solid rgba(248,76,162,0.18);
    }

    .timeline-step strong {
      display: block;
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      margin-bottom: 2px;
    }

    .timeline-step span {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .auction-card {
      background: linear-gradient(180deg, #fff, #f7fbff);
    }

    .auction-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .auction-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: linear-gradient(90deg, #091355, #1d2e93);
      color: #fff;
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 11px;
      line-height: 15px;
      font-weight: 700;
    }

    .auction-price {
      margin: 10px 0 6px;
      font-size: 26px;
      line-height: 39px;
      font-weight: 800;
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .progress-track {
      width: 100%;
      height: 12px;
      border-radius: 999px;
      background: #e8edf7;
      overflow: hidden;
      margin-top: 12px;
    }

    .progress-fill {
      height: 100%;
      width: 34%;
      background: linear-gradient(90deg, #f84ca2, #ff9d70, #ffd36f);
      border-radius: inherit;
      transition: width 0.5s ease;
    }

    .progress-meta {
      margin-top: 8px;
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .sticky-cta {
      position: fixed;
      left: 50%;
      bottom: 14px;
      transform: translateX(-50%);
      width: calc(100% - 24px);
      max-width: 406px;
      z-index: 10;
      padding: 10px 12px 12px;
      background: rgba(255,255,255,0.84);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.7);
      box-shadow: 0 12px 32px rgba(28,38,99,0.14);
      border-radius: 24px;
    }

    .sticky-cta .caption {
      display: block;
      margin-bottom: 8px;
      font-size: 11px;
      line-height: 15px;
      color: var(--text-gray);
      text-align: center;
    }

    .toast {
      position: fixed;
      left: 50%;
      top: 18px;
      transform: translateX(-50%) translateY(-12px);
