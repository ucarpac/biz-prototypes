      background: rgba(28,38,99,0.94);
      color: #fff;
      padding: 13px 16px;
      border-radius: 16px;
      font-size: 13px;
      line-height: 19.5px;
      box-shadow: 0 12px 24px rgba(9,19,85,0.24);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s ease, transform 0.28s ease;
      z-index: 20;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .helper-row {
      margin-top: 12px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .helper-link {
      color: var(--text-under-blue);
      text-decoration: underline;
      font-size: 12px;
      line-height: 18px;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
    }

    .section-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(28,38,99,0.12), transparent);
      margin: 18px 0;
    }

    @media (min-width: 768px) {
      .app-shell {
        max-width: 980px;
      }

      .container {
        padding: 24px 20px 0;
      }

      .hero {
        padding: 28px 26px;
      }

      .hero-illustration {
        grid-template-columns: 1fr 150px;
      }

      .car-face {
        width: 150px;
        height: 132px;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 16px;
