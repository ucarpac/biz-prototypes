                <span>メーカー・年式・走行距離だけで、まずは相場の目安を確認。</span>
              </div>
            </div>
            <div class="timeline-step">
              <div class="timeline-dot">2</div>
              <div>
                <strong>AI査定で精度アップ</strong>
                <span>カラー・装備・写真を追加すると、より実感に近い価格に近づきます。</span>
              </div>
            </div>
            <div class="timeline-step">
              <div class="timeline-dot">3</div>
              <div>
                <strong>納得できたらオークションへ</strong>
                <span>8,000社が競っても、やりとりは1社のみ。負担を増やさず最高額を目指せます。</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">オークション進捗イメージ <span class="hand-note">不安を見える化</span></h2>
        <div class="card auction-card">
          <div class="auction-head">
            <div>
              <div class="auction-tag">オークション準備中</div>
              <div class="auction-price" id="auctionPrice">最高額 156.8万円</div>
            </div>
            <div class="comfort-pill" id="auctionCount">入札想定 23社</div>
          </div>
          <p class="estimate-label">出品前でも、過去の近似車両データから動き方をイメージできます。</p>
          <div class="progress-track">
            <div class="progress-fill" id="progressFill"></div>
          </div>
          <div class="progress-meta">
            <span id="progressLabel">準備完了まで 34%</span>
            <span>書類確認 → 出品 → 入札</span>
          </div>
          <div class="button-row">
            <button class="primary-button" id="advanceProgress">進捗を進める</button>
            <button class="secondary-button" id="resetProgress">最初から見る</button>
          </div>
        </div>
      </section>
    </main>

    <div class="sticky-cta">
      <span class="caption">まだ申し込みたくない方は、価格だけ見てホームに戻れます</span>
      <button class="primary-button" id="stickyButton">個人情報なしで価格を見る</button>
    </div>
  </div>

  <script>
    const datasets = {
      current: {
        label: "現在のAI査定価格",
        price: "148.7",
        range: "オークション想定レンジ <strong>143.0万〜154.0万円</strong>",
        comfort: "今は様子見でもOK",
        toast: "今の相場を表示しています。売却時期の判断材料として使えます。",
        bars: [98, 112, 94]
      },
      "3m": {
        label: "3ヶ月後の予測価格",
        price: "153.4",
        range: "夏前の需要で <strong>149.0万〜158.0万円</strong> を想定",
        comfort: "3ヶ月後がやや有利",
        toast: "需要が高まりやすい時期の予測です。急がないなら待つ選択もあります。",
        bars: [98, 112, 94]
      },
      "6m": {
        label: "6ヶ月後の予測価格",
        price: "146.2",
        range: "年末に向けて <strong>140.0万〜150.0万円</strong> を想定",
        comfort: "半年後は少し下がる予測",
        toast: "時間が空くほど相場が落ち着く見込みです。売るなら早めが無難です。",
        bars: [98, 112, 94]
      },
      sell: {
        label: "売却準備モードの想定価格",
        price: "156.8",
        range: "装備・写真反映後の想定 <strong>151.0万〜162.0万円</strong>",
        comfort: "写真追加で上振れ期待",
        toast: "売却準備モードに切り替えました。写真と装備入力で精度が上がります。",
        bars: [104, 118, 99]
      }
    };

    const chips = document.querySelectorAll("#modeChips .chip");
    const estimateLabel = document.getElementById("estimateLabel");
    const estimatePrice = document.getElementById("estimatePrice");
    const estimateRange = document.getElementById("estimateRange");
    const comfortPill = document.getElementById("comfortPill");
    const toast = document.getElementById("toast");
    const barCurrent = document.getElementById("barCurrent");
    const bar3m = document.getElementById("bar3m");
    const bar6m = document.getElementById("bar6m");
    const progressFill = document.getElementById("progressFill");
    const progressLabel = document.getElementById("progressLabel");
    const auctionPrice = document.getElementById("auctionPrice");
    const auctionCount = document.getElementById("auctionCount");
    const fuelBar = document.getElementById("fuelBar");
    const insuranceBar = document.getElementById("insuranceBar");
    const maintBar = document.getElementById("maintBar");
    const expenseTotal = document.getElementById("expenseTotal");

    let toastTimer = null;
    let progress = 34;
    let fuel = 13200;
    let totalAnnual = 394000;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove("show"), 2200);
    }

    function setMode(mode) {
      const data = datasets[mode];
      chips.forEach(chip => chip.classList.toggle("active", chip.dataset.mode === mode));
      estimateLabel.textContent = data.label;
      estimatePrice.innerHTML = `${data.price}<small>万円</small>`;
      estimateRange.innerHTML = data.range;
      comfortPill.textContent = data.comfort;
      barCurrent.style.height = `${data.bars[0]}px`;
      bar3m.style.height = `${data.bars[1]}px`;
      bar6m.style.height = `${data.bars[2]}px`;
      showToast(data.toast);
    }

    chips.forEach(chip => {
      chip.addEventListener("click", () => setMode(chip.dataset.mode));
    });

    document.getElementById("ctaEstimate").addEventListener("click", () => {
      setMode("sell");
      showToast("写真と装備を追加すると、査定の納得感がさらに高まります。");
    });

    document.getElementById("ctaAuction").addEventListener("click", () => {
      progress = 64;
      progressFill.style.width = progress + "%";
      progressLabel.textContent = "準備完了まで 64%";
      auctionPrice.textContent = "最高額 159.2万円";
      auctionCount.textContent = "入札想定 31社";
      showToast("売却相談のイメージを表示しました。やりとりは1社のみです。");
    });

    document.getElementById("helperFuture").addEventListener("click", () => {
      showToast("将来予測は、季節需要・走行距離の増加・近似成約データをもとに表示しています。");
    });

    document.getElementById("helperPrivacy").addEventListener("click", () => {
      showToast("価格確認の段階では氏名や電話番号の入力は不要です。申し込み時のみ必要になります。");
    });

    document.getElementById("addExpense").addEventListener("click", () => {
      fuel += 4200;
      totalAnnual += 50400;
      fuelBar.style.height = "104px";
      expenseTotal.textContent = (totalAnnual / 10000).toFixed(1) + "万円";
      document.querySelector(".expense-caption").innerHTML = "ガソリン<br>" + fuel.toLocaleString() + "円";
      showToast("給油 4,200円を追加しました。出費と売り時を一緒に見直せます。");
    });

    document.getElementById("shareInsight").addEventListener("click", () => {
      showToast("維持費が増える前に売る選択もあります。今の相場と比べて判断できます。");
    });

    document.getElementById("advanceProgress").addEventListener("click", () => {
      progress = Math.min(100, progress + 22);
      progressFill.style.width = progress + "%";
      progressLabel.textContent = `準備完了まで ${progress}%`;
      if (progress >= 100) {
        auctionPrice.textContent = "最高額 161.4万円";
        auctionCount.textContent = "入札 42社";
        showToast("出品イメージが完了しました。最高額に近づく流れが見えます。");
      } else {
        auctionPrice.textContent = "最高額 158.6万円";
        auctionCount.textContent = "入札想定 35社";
        showToast("進捗を更新しました。状況はプッシュ通知でも追えます。");
      }
    });

    document.getElementById("resetProgress").addEventListener("click", () => {
      progress = 34;
      progressFill.style.width = progress + "%";
      progressLabel.textContent = "準備完了まで 34%";
      auctionPrice.textContent = "最高額 156.8万円";
      auctionCount.textContent = "入札想定 23社";
      showToast("進捗イメージを初期状態に戻しました。");
    });

    document.getElementById("stickyButton").addEventListener("click", () => {
      setMode("current");
      showToast("まずは価格だけ確認できます。そのままホームに戻っても問題ありません。");
    });

    setTimeout(() => {
      showToast("AI査定の準備ができました。個人情報の入力はまだ不要です。");
    }, 500);
  </script>
</body>
</html>
