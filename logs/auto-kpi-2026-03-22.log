    document.getElementById("ctaButton").addEventListener("click", () => {
      const btn = document.getElementById("ctaButton");
      btn.textContent = "査定入力を開始しました";
      btn.style.opacity = "0.75";
      setTimeout(() => {
        btn.textContent = "AI査定を続ける";
        btn.style.opacity = "1";
