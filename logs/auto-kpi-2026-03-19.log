    </section>

    <p class="footer-note">
      Prototype note: ストアスクショ想定のため、UIはダッシュボード調に情報密度を上げつつ、
      主要メッセージは 3秒で読めるよう大見出しと数値を優先しています。
    </p>
  </div>

  <script>
    (function () {
      const bars = document.querySelectorAll('.bar[data-width]');
      requestAnimationFrame(() => {
        bars.forEach((bar, index) => {
          setTimeout(() => {
            bar.style.width = bar.dataset.width + '%';
          }, index * 160);
        });
      });

      const screens = document.querySelectorAll('[data-screen]');
      const navButtons = document.querySelectorAll('.nav-controls button');
      const title = document.getElementById('caption-title');
      const copy = document.getElementById('caption-copy');
      const points = document.getElementById('caption-points');

      const captions = {
        a: {
          title: 'スクショA: AI査定を全面に出す',
          copy: 'ストア1枚目を想定。AI査定の即時価値を中心に、具体価格・将来予測・個人情報不要を一画面へ集約します。',
          points: [
            '<strong>狙い:</strong> 「価格がすぐ見える」ベネフィットを最短で理解させる。',
            '<strong>数値表現:</strong> 査定額、精度、上位価格帯で信頼感を補強。',
            '<strong>ASO仮説:</strong> 価格不透明ユーザーの不安を減らし、DL意思決定を前倒し。'
          ]
        },
        b: {
          title: 'スクショB: 出費管理 + 将来予測を訴求',
          copy: 'Android向けの継続利用価値訴求。維持費の見える化と売り時予測を並べ、相場チェックだけで終わらない理由を作ります。',
          points: [
            '<strong>狙い:</strong> 「入れた後も役立つ」印象を作り、DL後の利用想起を強化。',
            '<strong>数値表現:</strong> 年間維持費、カテゴリ別支出、価値推移グラフを併置。',
            '<strong>ASO仮説:</strong> 将来売却層や家計管理層のCVR改善に寄与。'
          ]
        },
        c: {
          title: 'スクショC: 競合比較で「電話0本」を訴求',
          copy: '3枚目の比較訴求。競合の電話ストレスを定量的に見せ、UcarPACの心理的ハードルの低さを端的に伝えます。',
          points: [
            '<strong>狙い:</strong> 一括査定に不安がある層へ、比較優位を即理解させる。',
            '<strong>数値表現:</strong> 電話本数、入札社数、連絡先数、AI予測有無を一覧化。',
            '<strong>ASO仮説:</strong> 「面倒そう」を払拭し、DL直前の迷いを解消。'
          ]
        }
      };

      function setScreen(target) {
        screens.forEach(screen => {
          screen.classList.toggle('is-active', screen.dataset.screen === target);
        });

        navButtons.forEach(button => {
          button.classList.toggle('is-current', button.dataset.target === target);
        });

        title.textContent = captions[target].title;
        copy.textContent = captions[target].copy;
        points.innerHTML = captions[target].points.map(item => '<div>' + item + '</div>').join('');
      }

      navButtons.forEach(button => {
        button.addEventListener('click', function () {
          setScreen(this.dataset.target);
        });
      });

      document.querySelectorAll('[data-toast]').forEach(button => {
        button.addEventListener('click', function () {
          const existing = document.querySelector('.prototype-toast');
          if (existing) existing.remove();

          const toast = document.createElement('div');
          toast.className = 'prototype-toast';
          toast.textContent = this.dataset.toast;
          toast.style.position = 'fixed';
          toast.style.left = '50%';
          toast.style.bottom = '28px';
          toast.style.transform = 'translateX(-50%)';
          toast.style.padding = '12px 16px';
          toast.style.borderRadius = '999px';
          toast.style.background = 'rgba(9,19,85,0.94)';
          toast.style.color = '#fff';
          toast.style.fontSize = '12px';
          toast.style.fontWeight = '800';
          toast.style.boxShadow = '0 18px 40px rgba(9,19,85,0.22)';
          toast.style.zIndex = '9999';
          toast.style.opacity = '0';
          toast.style.transition = 'opacity 180ms ease, transform 180ms ease';
          document.body.appendChild(toast);

          requestAnimationFrame(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateX(-50%) translateY(-4px)';
          });

          setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(-50%) translateY(8px)';
            setTimeout(() => toast.remove(), 220);
          }, 1400);
        });
      });

      let autoIndex = 0;
