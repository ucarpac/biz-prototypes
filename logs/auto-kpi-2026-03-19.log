  <div class="toast" id="toast">スワイプで次のスクショへ</div>

  <script>
    const slides = document.getElementById("slides");
    const slider = document.getElementById("slider");
    const chips = Array.from(document.querySelectorAll(".chip"));
    const dots = Array.from(document.querySelectorAll(".swipe-dot"));
    const toast = document.getElementById("toast");
    const total = 3;
    let index = 0;
    let startX = 0;
    let diffX = 0;
    let dragging = false;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => toast.classList.remove("show"), 1500);
    }

    function updateSlider(nextIndex) {
      index = (nextIndex + total) % total;
      slides.style.transform = "translateX(" + (index * -100) + "%)";
      chips.forEach((chip, i) => chip.classList.toggle("active", i === index));
      dots.forEach((dot, i) => dot.classList.toggle("active", i === index));
      const messages = [
        "A: AI査定を最前面に訴求",
        "B: 出費管理と将来予測を訴求",
        "C: 電話0本の競合比較を訴求"
      ];
      showToast(messages[index]);
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => updateSlider(Number(chip.dataset.target)));
    });

    document.getElementById("prevBtn").addEventListener("click", () => updateSlider(index - 1));
    document.getElementById("nextBtn").addEventListener("click", () => updateSlider(index + 1));

    slider.addEventListener("pointerdown", (e) => {
      dragging = true;
      startX = e.clientX;
      diffX = 0;
      slides.style.transition = "none";
    });

    slider.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      diffX = e.clientX - startX;
      const offset = -index * slider.offsetWidth + diffX;
      slides.style.transform = "translateX(" + offset + "px)";
    });

    function endDrag() {
      if (!dragging) return;
      dragging = false;
      slides.style.transition = "transform .45s cubic-bezier(.22,.8,.24,1)";
      if (Math.abs(diffX) > 60) {
        updateSlider(index + (diffX < 0 ? 1 : -1));
      } else {
        updateSlider(index);
      }
    }

    slider.addEventListener("pointerup", endDrag);
    slider.addEventListener("pointerleave", endDrag);
    slider.addEventListener("pointercancel", endDrag);

    const aiButton = document.getElementById("aiButton");
    const priceMain = document.getElementById("priceMain");
    const priceSub = document.getElementById("priceSub");
    const meterFill = document.getElementById("meterFill");
    const stepperA = document.querySelectorAll("#stepperA .step");
    let aiState = 0;
    const aiStates = [
      { price: "412", score: "AI査定スコア 84", width: "78%" },
      { price: "426", score: "装備反映後 スコア 89", width: "86%" },
      { price: "438", score: "写真診断後 スコア 92", width: "93%" }
    ];

    aiButton.addEventListener("click", () => {
      aiState = (aiState + 1) % aiStates.length;
      const state = aiStates[aiState];
      priceMain.textContent = state.price;
      priceSub.textContent = state.score;
      meterFill.style.width = state.width;
      stepperA.forEach((step, i) => step.classList.toggle("active", i <= aiState));
      showToast("AI診断が進行中: " + state.price + "万円");
    });

    const forecastButton = document.getElementById("forecastButton");
    const stepperB = document.querySelectorAll("#stepperB .step");
    let bState = 0;
    forecastButton.addEventListener("click", () => {
      bState = (bState + 1) % 3;
      stepperB.forEach((step, i) => step.classList.toggle("active", i <= bState));
      const labels = ["出費を整理", "価値変動を把握", "売り時を確認"];
      showToast("Bステップ: " + labels[bState]);
    });

    const compareButton = document.getElementById("compareButton");
    const stepperC = document.querySelectorAll("#stepperC .step");
    let cState = 0;
    compareButton.addEventListener("click", () => {
      cState = (cState + 1) % 3;
      stepperC.forEach((step, i) => step.classList.toggle("active", i <= cState));
      const labels = ["比較で不安を解消", "電話0本を理解", "DL意向を後押し"];
      showToast("Cステップ: " + labels[cState]);
    });

    window.addEventListener("resize", () => updateSlider(index));

    updateSlider(0);
  </script>
</body>
