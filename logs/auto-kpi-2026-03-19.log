      --back-white: #FAFAFA;
      --light-gray: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-gray2: #e6e6e6;
      --back-blue: #091355;
      --back-dark-blue: #0a1348;
      --back-light-pink: #ffd8e8;
      --back-light-blue: #6fc2ff;
      --error: #EB4646;
      --shadow: rgba(0,0,0,0.11);
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --gradient-panel: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.84));
      --font-sans: "Noto Sans JP", "Hiragino Sans", system-ui, sans-serif;
      --font-number: "Righteous", "Noto Sans JP", sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-7: 27px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-card: 13px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
      --radius-button-lg: 43px;
      --shadow-light: 0 8px 24px rgba(0, 0, 0, 0.08);
      --shadow-medium: 0 18px 40px rgba(28, 38, 99, 0.16);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top left, rgba(248,76,162,0.18), transparent 32%),
        radial-gradient(circle at 100% 20%, rgba(111,194,255,0.22), transparent 28%),
        linear-gradient(180deg, #eef7ff 0%, #f8fbff 38%, #eef1fb 100%);
      color: var(--text-black);
      font-family: var(--font-sans);
    }

    body {
      overflow-x: hidden;
    }

    .shell {
      max-width: 1280px;
      margin: 0 auto;
      padding: 20px 14px 48px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--pink), #ff95c9);
      box-shadow: var(--shadow-light);
      position: relative;
    }

    .brand-mark::before,
    .brand-mark::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      background: rgba(255,255,255,0.9);
    }

    .brand-mark::before {
      width: 18px;
      height: 6px;
      top: 11px;
      left: 11px;
      transform: rotate(-12deg);
    }

    .brand-mark::after {
      width: 10px;
      height: 10px;
      bottom: 9px;
      right: 9px;
    }

    .brand-text h1 {
      margin: 0;
      font-size: 18px;
      line-height: 1.3;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .brand-text p {
      margin: 2px 0 0;
      font-size: 12px;
      color: var(--text-gray);
    }

    .status-chip-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .chip {
      border: 0;
      border-radius: var(--radius-chip);
      padding: 10px 14px;
      font-size: 12px;
      font-weight: 700;
      background: rgba(255,255,255,0.74);
      color: var(--dark-blue);
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.08);
      backdrop-filter: blur(12px);
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
    }

    .hero {
      background: rgba(9,19,85,0.95);
      color: var(--white);
      border-radius: 28px;
      padding: 22px 18px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-medium);
    }

    .hero::before,
    .hero::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      filter: blur(4px);
    }

    .hero::before {
      width: 180px;
      height: 180px;
      right: -30px;
      top: -20px;
      background: rgba(77,180,255,0.26);
    }

    .hero::after {
      width: 120px;
      height: 120px;
      left: -14px;
      bottom: -40px;
      background: rgba(248,76,162,0.24);
    }

    .hero-grid {
      position: relative;
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
      z-index: 1;
    }

    .hero-copy h2 {
      margin: 0;
      font-size: 28px;
      line-height: 1.3;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .hero-copy p {
      margin: 12px 0 0;
      font-size: 14px;
      line-height: 1.7;
      color: rgba(255,255,255,0.82);
      max-width: 720px;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .hero-stat {
      background: rgba(255,255,255,0.1);
      border-radius: 18px;
      padding: 14px 12px;
      backdrop-filter: blur(10px);
      min-height: 84px;
    }

    .hero-stat .label {
      font-size: 11px;
      color: rgba(255,255,255,0.68);
      display: block;
      margin-bottom: 8px;
    }

    .hero-stat .value {
      display: block;
      font-family: var(--font-number);
      font-size: 28px;
      line-height: 1;
      letter-spacing: 0.02em;
    }

    .hero-stat .sub {
      margin-top: 6px;
      font-size: 11px;
      color: #c4d9ff;
    }

    .section {
      margin-top: 20px;
    }

    .section-header {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }

    .section-header h3 {
      margin: 0;
      font-size: 22px;
      line-height: 1.4;
      color: var(--dark-blue);
    }

    .section-header p {
      margin: 0;
      font-size: 13px;
      color: var(--text-gray);
    }

    .panel-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .panel {
      background: var(--gradient-panel);
      border-radius: 22px;
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(255,255,255,0.72);
      backdrop-filter: blur(16px);
      overflow: hidden;
    }

    .panel-body {
      padding: 18px;
    }

    .progress-card {
      display: grid;
      gap: 14px;
    }

    .kpi-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: end;
    }

    .kpi-row h4 {
      margin: 0;
      font-size: 16px;
      color: var(--dark-blue);
    }

    .kpi-row .big-number {
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .progress-stack {
      display: grid;
      gap: 12px;
    }

    .progress-item label {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 6px;
    }

    .track {
      height: 12px;
      background: #dde6f4;
      border-radius: 999px;
      overflow: hidden;
      position: relative;
    }

    .bar {
      height: 100%;
      border-radius: 999px;
      background: var(--gradient-primary);
      width: 0;
      transition: width 900ms cubic-bezier(.2,.8,.2,1);
      position: relative;
      overflow: hidden;
    }

    .bar::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.42), transparent);
      transform: translateX(-100%);
      animation: shine 2.4s infinite;
    }

    @keyframes shine {
      to { transform: translateX(100%); }
    }

    .bar.pink {
      background: var(--gradient-pink);
    }

    .bar.dark {
      background: linear-gradient(90deg, #091355, #1d2e93);
    }

    .insight-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 10px;
    }

    .insight-list li {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      align-items: start;
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-black);
    }

    .insight-badge {
      width: 28px;
      height: 28px;
      border-radius: 10px;
      background: rgba(77,180,255,0.16);
      color: var(--button-link1);
      display: grid;
      place-items: center;
      font-weight: 800;
      font-size: 12px;
    }

    .phone-area {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      align-items: start;
    }

    .phone-wrap {
      display: flex;
      justify-content: center;
    }

    .phone {
      width: min(100%, 375px);
      min-height: 760px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(246,249,255,0.98)),
        #fff;
      border-radius: 38px;
      border: 8px solid #12172e;
      box-shadow: 0 30px 80px rgba(9,19,85,0.24);
      overflow: hidden;
      position: relative;
      transform: translateY(0);
      transition: transform 300ms ease, box-shadow 300ms ease;
    }

    .phone:hover {
      transform: translateY(-4px);
      box-shadow: 0 34px 96px rgba(9,19,85,0.28);
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      width: 118px;
      height: 22px;
      border-radius: 0 0 16px 16px;
      background: #12172e;
      z-index: 5;
    }

    .screen {
      padding: 24px 16px 18px;
      min-height: 100%;
      position: relative;
      background:
        radial-gradient(circle at top right, rgba(248,76,162,0.14), transparent 28%),
        radial-gradient(circle at left 20%, rgba(111,194,255,0.18), transparent 30%),
        linear-gradient(180deg, #f7fbff 0%, #eef3ff 46%, #f7f8fc 100%);
    }

    .statusbar {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      margin: 4px 2px 16px;
    }

    .store-card {
      border-radius: 22px;
      background: rgba(255,255,255,0.82);
      backdrop-filter: blur(10px);
      box-shadow: var(--shadow-light);
      padding: 16px;
      border: 1px solid rgba(255,255,255,0.72);
    }

    .mini-head {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 14px;
    }

    .mini-title {
      margin: 0;
      font-size: 20px;
      line-height: 1.4;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .mini-copy {
      margin: 6px 0 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(248,76,162,0.12);
      color: var(--pink);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .kpi-hero {
      background: linear-gradient(135deg, var(--dark-blue), #1f49a0);
      color: var(--white);
      border-radius: 24px;
      padding: 18px;
      position: relative;
      overflow: hidden;
    }

    .kpi-hero::after {
      content: "";
      position: absolute;
      inset: auto -18px -20px auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: rgba(248,76,162,0.22);
    }

    .eyebrow {
      margin: 0 0 8px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #b6d4ff;
      font-weight: 800;
    }

    .main-number {
      margin: 0;
      font-family: var(--font-number);
      font-size: 48px;
      line-height: 1;
      letter-spacing: 0.02em;
    }

    .main-number small {
      font-size: 18px;
      font-family: var(--font-sans);
      font-weight: 800;
    }

    .delta {
      margin-top: 8px;
      font-size: 13px;
      color: #d8e7ff;
      line-height: 1.6;
    }

    .delta strong {
      color: #8df4ff;
    }

    .metric-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 14px;
    }

    .metric-box {
      background: rgba(255,255,255,0.12);
      border-radius: 16px;
      padding: 12px 10px;
      min-height: 76px;
    }

    .metric-box span {
      display: block;
    }

    .metric-box .metric-label {
      font-size: 10px;
      color: #bbd0ff;
      margin-bottom: 8px;
    }

    .metric-box .metric-value {
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 1;
    }

    .metric-box .metric-note {
      margin-top: 6px;
      font-size: 10px;
      color: #dce7ff;
    }

    .chart-card {
      margin-top: 14px;
      border-radius: 22px;
      background: #fff;
      padding: 14px;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.05);
    }

    .chart-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .chart-head h4 {
      margin: 0;
      font-size: 14px;
      color: var(--dark-blue);
    }

    .chart-head p {
      margin: 0;
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      font-size: 10px;
      color: var(--text-gray);
      margin-top: 6px;
    }

    .legend span {
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .legend i {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      display: inline-block;
    }

    .list-table {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .table-row {
      display: grid;
      grid-template-columns: 1.4fr 1fr auto;
      gap: 8px;
      align-items: center;
      border-radius: 16px;
      background: rgba(237,241,244,0.72);
      padding: 12px;
      font-size: 12px;
    }

    .table-row strong {
      color: var(--dark-blue);
      font-size: 13px;
    }

    .table-row .price {
      text-align: right;
      font-family: var(--font-number);
      font-size: 22px;
      color: var(--dark-blue);
      line-height: 1;
    }

    .table-row .tag {
      display: inline-flex;
      padding: 7px 9px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 800;
      background: rgba(9,19,85,0.12);
      color: var(--dark-blue);
    }

    .store-cta {
      margin-top: 16px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .cta-copy {
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .btn {
      border: 0;
      border-radius: var(--radius-button);
      min-height: 43px;
      padding: 0 18px;
      font-size: 14px;
      font-weight: 800;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      box-shadow: 0 12px 24px rgba(77,180,255,0.26);
      cursor: pointer;
      transition: transform 180ms ease, filter 180ms ease;
    }

    .btn:hover,
    .btn:active {
      transform: translateY(-1px) scale(1.01);
      filter: saturate(1.05);
    }

    .btn.pink {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 12px 24px rgba(248,76,162,0.26);
    }

    .forecast-ribbon {
      margin: 14px 0;
      border-radius: 20px;
      padding: 12px 14px;
      background: linear-gradient(90deg, rgba(248,76,162,0.1), rgba(111,194,255,0.14));
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .forecast-ribbon strong {
      font-family: var(--font-number);
      font-size: 26px;
      line-height: 1;
    }

    .expense-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 14px;
    }

    .expense-item {
      border-radius: 18px;
      background: rgba(255,255,255,0.88);
      padding: 12px;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.05);
      min-height: 86px;
    }

    .expense-item .category {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      margin-bottom: 8px;
    }

    .expense-item .yen {
      display: block;
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .expense-item .hint {
      display: block;
      margin-top: 6px;
      font-size: 10px;
      color: var(--text-gray);
    }

    .compare-card {
      background: linear-gradient(180deg, #07104a 0%, #0e1f6d 100%);
      color: var(--white);
      border-radius: 24px;
      padding: 16px;
      position: relative;
      overflow: hidden;
    }

    .compare-card::before {
      content: "";
      position: absolute;
      left: -36px;
      bottom: -42px;
      width: 140px;
      height: 140px;
      background: rgba(248,76,162,0.16);
      border-radius: 50%;
    }

    .compare-title {
      margin: 0;
      font-size: 24px;
      line-height: 1.35;
      font-weight: 800;
    }

    .compare-sub {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 1.6;
      color: #c8d8ff;
    }

    .compare-pill-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .compare-pill {
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 11px;
      font-weight: 800;
      color: var(--white);
      background: rgba(255,255,255,0.12);
    }

    .compare-table {
      margin-top: 16px;
      border-radius: 18px;
      overflow: hidden;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(8px);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.1fr .9fr .9fr;
      gap: 8px;
      padding: 12px 14px;
      font-size: 12px;
      align-items: center;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .compare-row:first-child {
      border-top: 0;
      font-size: 11px;
      color: #c4d3ff;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .compare-row strong {
      font-size: 18px;
      line-height: 1;
      font-family: var(--font-number);
      color: #8df4ff;
    }

    .compare-row .bad {
      color: #ffcfda;
      font-weight: 800;
    }

    .compare-foot {
      margin-top: 14px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.1);
      font-size: 12px;
      line-height: 1.6;
      color: #dde7ff;
    }

    .nav-controls {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 16px;
      flex-wrap: wrap;
    }

    .nav-controls button {
      border: 0;
      border-radius: 999px;
      padding: 10px 16px;
      background: rgba(255,255,255,0.8);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: var(--shadow-light);
      transition: all 180ms ease;
    }

    .nav-controls button.is-current {
      background: var(--dark-blue);
      color: var(--white);
    }

    .caption-card {
      padding: 18px;
      display: grid;
      gap: 14px;
    }

    .caption-card h4 {
      margin: 0;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .caption-card p {
      margin: 0;
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .caption-points {
      display: grid;
      gap: 10px;
    }

    .caption-points div {
      border-radius: 16px;
      background: rgba(237,241,244,0.68);
      padding: 12px;
      font-size: 12px;
      line-height: 1.6;
    }

    .caption-points strong {
      color: var(--dark-blue);
    }

    .footer-note {
      margin-top: 20px;
      text-align: center;
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    [data-screen] {
      display: none;
    }

    [data-screen].is-active {
      display: block;
      animation: fadeUp 340ms ease;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .pulse {
      animation: pulse 2.2s infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.03); }
    }

    @media (min-width: 768px) {
      .shell {
        padding: 24px 20px 60px;
      }

      .hero {
        padding: 28px 24px;
      }

      .hero-grid {
        grid-template-columns: 1.2fr .8fr;
        align-items: center;
      }

      .panel-grid {
        grid-template-columns: 0.92fr 1.08fr;
      }

      .phone-area {
        grid-template-columns: 420px 1fr;
      }
    }

    @media (min-width: 1100px) {
      .shell {
        padding-left: 28px;
        padding-right: 28px;
      }

      .section {
        margin-top: 24px;
      }
    }
  </style>
</head>
