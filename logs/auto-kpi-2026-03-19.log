      background: rgba(255,255,255,0.84);
      border-top: 1px solid var(--ruled-line);
      font-size: 13px;
      line-height: 1.6;
    }

    .compare-row b {
      color: var(--dark-blue);
      font-size: 14px;
    }

    .good {
      color: #008a66;
      font-weight: 800;
    }

    .bad {
      color: var(--error);
      font-weight: 800;
    }

    .compare-pills {
      display: flex;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .compare-pill {
      appearance: none;
      border: 0;
      min-height: 36px;
      border-radius: 999px;
      padding: 8px 12px;
      background: rgba(255,255,255,0.82);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 10px 18px rgba(28,38,99,0.06);
    }

    .compare-pill.active {
      background: var(--dark-blue);
      color: var(--white);
    }

    .story-box {
      margin-top: 14px;
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(28,38,99,0.06);
      color: var(--text-black);
      font-size: 13px;
      line-height: 1.8;
    }

    .story-box strong {
      color: var(--dark-blue);
    }

    .section-title {
      margin: 12px 16px 10px;
      font-size: 13px;
      font-weight: 800;
      color: #8b5b30;
      letter-spacing: 0.04em;
    }

    .platform-stamp {
      position: absolute;
      right: 16px;
      top: 16px;
      min-height: 28px;
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.84);
      box-shadow: 0 8px 20px rgba(28,38,99,0.08);
    }

    .screen.hidden {
      display: none;
    }

    @keyframes drawLine {
      0% { stroke-dashoffset: 420; }
      40% { stroke-dashoffset: 80; }
      100% { stroke-dashoffset: 0; }
    }

    @keyframes pulseFuture {
      0%, 100% { opacity: 0.45; }
      50% { opacity: 1; }
    }

    @keyframes popPoint {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.18); }
    }

    @keyframes floatPulse {
      0%, 100% { transform: translateY(0); box-shadow: 0 16px 28px rgba(77,180,255,0.28); }
      50% { transform: translateY(-2px); box-shadow: 0 20px 30px rgba(248,76,162,0.18); }
    }

    @media (min-width: 900px) {
      .page {
        padding-left: 20px;
        padding-right: 20px;
      }

      .intro p {
        font-size: 15px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="intro">
      <div class="eyebrow">ストアPVからDLの後押しを想定したスクリーン提案</div>
      <h1>「売るか迷う」気持ちに寄り添いながら、<br>まずは安心してタップできる3枚構成</h1>
      <p>
        UcarPACの差別化であるAI査定、将来予測、出費管理、そして「電話0本」体験を、
        暖色アクセントとやわらかな手書き風表現で整理したストアスクリーン案です。
      </p>
    </section>

    <div class="toolbar" aria-label="画面切り替え">
      <button class="active" data-target="all">3枚まとめて表示</button>
      <button data-target="screen-a">スクショA / iOS</button>
      <button data-target="screen-b">スクショB / Android</button>
      <button data-target="screen-c">スクショC / 比較訴求</button>
    </div>

    <section class="screens">
      <div class="frame-wrap">
        <div class="phone-frame">
          <div class="screen screen-a" id="screen-a">
            <div class="platform-stamp">iOS向け</div>
            <div class="status-bar">
              <span>9:41</span>
              <span>UcarPAC</span>
              <span>100%</span>
            </div>

            <div class="hero">
              <div class="label-row">
                <div class="badge pink">個人情報なしでOK</div>
                <div class="badge">最短30秒で相場チェック</div>
              </div>
              <h2>AIが愛車のいまの価値を<br>やさしく見える化</h2>
              <p class="subcopy">
                「売るかまだ迷っている」段階でも大丈夫。まずはトヨタ プリウスの相場を、
                気軽に、営業電話なしで確認できます。
              </p>
              <div class="hand-note">まず知るだけで安心。急かされません。</div>
            </div>

            <div class="card">
              <div class="car-summary">
                <div class="car-thumb" aria-hidden="true"></div>
                <div class="car-meta">
                  <h3>トヨタ プリウス S</h3>
                  <p>2019年式 / パールホワイト / 4.8万km</p>
                  <p>東京都世田谷区 / 修復歴なし</p>
                </div>
              </div>

              <div class="price-row">
                <div>
                  <div class="caption">AI査定の目安価格</div>
                  <div class="price">182<small>万円</small></div>
                </div>
                <div class="delta">
                  先月比 +6万円<br>
                  春需要で上向き
                </div>
              </div>
            </div>

            <div class="card spark-card">
              <div class="spark-head">
                <strong>いま売る？少し待つ？</strong>
                <span>AIが価格推移を予測</span>
              </div>
              <div class="graph">
                <svg viewBox="0 0 320 120" role="img" aria-label="AI査定の価格推移グラフ">
                  <path class="area" d="M10,95 C48,86 74,58 106,62 C138,66 168,52 196,40 C220,30 245,26 272,32 C292,36 305,26 315,18 L315,120 L10,120 Z"></path>
                  <path class="line" d="M10,95 C48,86 74,58 106,62 C138,66 168,52 196,40"></path>
                  <path class="future-line" d="M196,40 C220,30 245,26 272,32 C292,36 305,26 315,18"></path>
                  <circle class="point" cx="196" cy="40" r="5"></circle>
                  <circle class="point" cx="272" cy="32" r="5"></circle>
                  <circle class="point" cx="315" cy="18" r="5"></circle>
                </svg>
                <div class="axis">
                  <span>現在</span>
                  <span>3ヶ月後 186万円</span>
                  <span>6ヶ月後 191万円</span>
                </div>
              </div>

              <div class="insight-list">
                <div class="insight">
                  <div class="icon-bubble">AI</div>
                  <div>
                    <b>写真なしでも概算チェック</b>
                    <span>メーカー・年式・走行距離だけで、まず相場を把握。</span>
                  </div>
                </div>
                <div class="insight">
                  <div class="icon-bubble">◎</div>
                  <div>
                    <b>売り時のヒントが分かる</b>
                    <span>値動きの理由も一緒に見えるから、迷いにくい設計です。</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="cta-group">
              <button class="primary-btn" type="button" id="aiPulseBtn">無料でAI査定を試す</button>
              <button class="secondary-btn" type="button" id="aiInfoBtn">個人情報なしの流れを見る</button>
            </div>

            <div class="footer-note">
              査定価格は市場データをもとにした予測です。売却時期や車両状態により変動します。
            </div>
          </div>
        </div>
      </div>

      <div class="frame-wrap">
        <div class="phone-frame">
          <div class="screen screen-b" id="screen-b">
            <div class="platform-stamp">Android向け</div>
            <div class="status-bar">
              <span>9:41</span>
              <span>UcarPAC</span>
              <span>5G</span>
            </div>

            <div class="hero">
              <div class="label-row">
                <div class="badge">出費も価値もまとめて管理</div>
                <div class="badge pink">未来の相場まで予測</div>
              </div>
              <h2>維持費と売り時を<br>ひと目で見守れる</h2>
              <p class="subcopy">
                ただの査定アプリではなく、毎月のガソリン代や保険も把握。
                「まだ乗る」選択にも寄り添う、家計にやさしい見え方です。
              </p>
              <div class="hand-note">車にかかるお金、不安なままにしない。</div>
            </div>

            <div class="card">
              <div class="spark-head">
                <strong>2026年3月の維持費サマリー</strong>
