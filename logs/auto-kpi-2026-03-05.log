  <script>
    const tabs = document.querySelectorAll(".tab");
    const shots = document.querySelectorAll(".shot");
    const kpiBadge = document.getElementById("kpiBadge");
    const kpiMap = {
      screenA: "PV→DL: 17.3% → 22.8%",
      screenB: "PV→DL: 17.3% → 24.1%",
      screenC: "PV→DL: 17.3% → 25.0%"
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => {
          t.classList.remove("active");
          t.setAttribute("aria-selected", "false");
        });
        tab.classList.add("active");
        tab.setAttribute("aria-selected", "true");

        const target = tab.dataset.target;
        shots.forEach((shot) => shot.classList.remove("active"));
        const activeShot = document.getElementById(target);
        if (activeShot) activeShot.classList.add("active");

        kpiBadge.textContent = kpiMap[target] || "PV→DL: 17.3% → 25%";
      });
    });

    const monthRange = document.getElementById("monthRange");
    const monthText = document.getElementById("monthText");
    const futureValue = document.getElementById("futureValue");
    const axisFuture = document.getElementById("axisFuture");
    const futureDot = document.getElementById("futureDot");
    const forecastLine = document.getElementById("forecastLine");

    function formatYen(v) {
      return v.toLocaleString("ja-JP") + "円";
    }

    function updateForecast() {
      const month = Number(monthRange.value);
      const currentPrice = 2184000;
      const decayPerMonth = 25500;
      const demandBoost = month <= 3 ? 18000 : 0;
      const estimated = Math.max(1730000, currentPrice - (month * decayPerMonth) + demandBoost);
      monthText.textContent = month + "か月";
      axisFuture.textContent = month + "か月";
      futureValue.textContent = month + "か月後の予測価格: " + formatYen(estimated);

      const y = Math.max(46, 96 - month * 3.8);
      futureDot.setAttribute("cy", y.toFixed(1));
      forecastLine.setAttribute("d", "M16 86 L112 78 L208 66 L304 " + y.toFixed(1));
    }

    if (monthRange) {
      monthRange.addEventListener("input", updateForecast);
      updateForecast();
    }

    const toggleCompare = document.getElementById("toggleCompare");
    const oldCalls = document.getElementById("oldCalls");
    const newCalls = document.getElementById("newCalls");
    const barOther = document.getElementById("barOther");
    let flipped = false;

    function animateCount(el, from, to, suffix) {
      const duration = 360;
      const start = performance.now();
      function step(now) {
        const p = Math.min((now - start) / duration, 1);
        const value = Math.round(from + (to - from) * p);
        el.textContent = value + suffix;
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    if (toggleCompare) {
      toggleCompare.addEventListener("click", () => {
        flipped = !flipped;
        if (flipped) {
          animateCount(oldCalls, 7, 10, "本");
          animateCount(newCalls, 0, 0, "本");
          barOther.style.width = "32%";
          toggleCompare.textContent = "比較を通常表示に戻す";
        } else {
          animateCount(oldCalls, 10, 7, "本");
          animateCount(newCalls, 0, 0, "本");
          barOther.style.width = "22%";
          toggleCompare.textContent = "従来体験とのギャップを切り替える";
        }
      });
    }

    const toast = document.getElementById("toast");
    const ctas = document.querySelectorAll(".js-cta");

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(showToast._timer);
      showToast._timer = setTimeout(() => {
        toast.classList.remove("show");
      }, 1450);
    }

    ctas.forEach((btn) => {
      btn.addEventListener("click", () => {
        showToast(btn.dataset.message || "検証項目を保存しました");
      });
    });
  </script>
</body>
