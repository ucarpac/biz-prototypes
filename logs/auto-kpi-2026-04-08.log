+      border-color: rgba(248, 76, 162, 0.22);
+    }
+
+    .deck {
+      display: grid;
+      gap: 24px;
+      margin-top: 22px;
+    }
+
+    .shot {
+      padding: 18px;
+      border-radius: 28px;
+      background: rgba(255, 255, 255, 0.72);
+      border: 1px solid rgba(255, 255, 255, 0.86);
