+
+    .shot-note strong {
+      color: var(--dark-blue);
+    }
+
+    .phone {
+      position: relative;
+      width: 100%;
+      max-width: var(--phone-width);
+      margin: 0 auto;
+      padding: 14px;
+      border-radius: var(--radius-phone);
