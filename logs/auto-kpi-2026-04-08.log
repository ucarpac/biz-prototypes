      bValueParking: document.getElementById("b-value-parking"),
      bValueMaintenance: document.getElementById("b-value-maintenance"),
      bBarFuel: document.getElementById("b-bar-fuel"),
      bBarInsurance: document.getElementById("b-bar-insurance"),
      bBarParking: document.getElementById("b-bar-parking"),
      bBarMaintenance: document.getElementById("b-bar-maintenance"),
      bCurrentPrice: document.getElementById("b-current-price"),
      bFuturePrice: document.getElementById("b-future-price"),
      bMemoryTitle: document.getElementById("b-memory-title"),
      bMemorySub: document.getElementById("b-memory-sub"),
