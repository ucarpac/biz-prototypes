+    function formatYen(value) {
+      return `${value.toLocaleString("ja-JP")}円`;
+    }
+
+    function buildPoints(values, width, height, topPad, bottomPad) {
+      const min = Math.min(...values) - 6;
+      const max = Math.max(...values) + 6;
+      const usable = height - topPad - bottomPad;
+      const step = width / (values.length - 1);
+      return values.map((value, index) => {
+        const x = 12 + step * index;
+        const y = topPad + ((max - value) / (max - min || 1)) * usable;
+        return { x, y };
+      });
+    }
+
+    function linePath(points) {
