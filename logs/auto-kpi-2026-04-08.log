+      font-size: 13px;
+    }
+
+    .kpi-pill.soft {
+      background: rgba(255, 245, 223, 0.94);
+    }
+
+    .control-panel {
+      margin-top: 18px;
+      padding: 16px;
+      border-radius: 26px;
+      background: rgba(255, 255, 255, 0.80);
+      border: 1px solid rgba(255, 255, 255, 0.88);
