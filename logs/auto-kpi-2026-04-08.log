+    .toast {
+      position: fixed;
+      left: 50%;
+      bottom: 18px;
+      transform: translateX(-50%) translateY(18px);
+      min-width: 240px;
+      max-width: calc(100vw - 32px);
+      padding: 12px 16px;
+      border-radius: 16px;
+      background: rgba(9, 19, 85, 0.92);
+      color: var(--white);
+      font-size: 12px;
+      line-height: 1.6;
+      text-align: center;
+      box-shadow: var(--shadow-heavy);
+      opacity: 0;
+      pointer-events: none;
