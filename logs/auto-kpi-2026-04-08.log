      cCarName: document.getElementById("c-car-name"),
      cCarMeta: document.getElementById("c-car-meta"),
      cPrice: document.getElementById("c-price")
    };

    function formatMan(value) {
      return `${value.toFixed(1)}万円`;
    }

    function formatYen(value) {
      return `${value.toLocaleString("ja-JP")}円`;
    }

    function buildPoints(values, width, height, topPad, bottomPad) {
      const min = Math.min(...values) - 6;
      const max = Math.max(...values) + 6;
      const usable = height - topPad - bottomPad;
      const step = width / (values.length - 1);
      return values.map((value, index) => {
        const x = 12 + step * index;
        const y = topPad + ((max - value) / (max - min || 1)) * usable;
        return { x, y };
      });
    }

    function linePath(points) {
      return points.map((point, index) => `${index === 0 ? "M" : "L"}${point.x},${point.y}`).join(" ");
    }

    function areaPath(points, baseY) {
      const top = points.map((point, index) => `${index === 0 ? "M" : "L"}${point.x},${point.y}`).join(" ");
      const last = points[points.length - 1];
      const first = points[0];
      return `${top} L${last.x},${baseY} L${first.x},${baseY} Z`;
    }

    function setPressed(selector, activeValue, attrName) {
      document.querySelectorAll(selector).forEach((button) => {
        const active = button.getAttribute(attrName) === activeValue;
        button.classList.toggle("is-active", active);
        button.setAttribute("aria-pressed", String(active));
      });
    }

    function showToast(message) {
      refs.toast.textContent = message;
      refs.toast.classList.add("is-visible");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        refs.toast.classList.remove("is-visible");
      }, 2200);
    }

    function updateShotFocus() {
      document.querySelectorAll(".shot").forEach((shot) => {
        shot.classList.toggle("is-focused", shot.dataset.shot === state.focus);
      });
      setPressed(".focus-button", state.focus, "data-focus");
    }

    function updateA(data) {
      refs.aCarName.textContent = data.name;
      refs.aCarMeta.textContent = data.meta;
      refs.aPrice.innerHTML = `${formatMan(data.current)}<span class="yen">円</span>`.replace("万円円", "万円");
      refs.aPillRange.textContent = `下限 ${formatMan(data.floor)}`;
      refs.aPillConfidence.textContent = `信頼度 ${data.confidence}%`;
      refs.aStat1.textContent = data.momentum;
      refs.aStat3.textContent = state.mode === "check" ? "0件" : "1社";
      refs.aHook.innerHTML = state.mode === "check"
        ? "AIがあなたの愛車を査定"
        : "AI査定から、そのまま売却相談へ";
      refs.aSupport.innerHTML = state.mode === "check"
        ? "相場が見えると、気持ちは少し軽くなる。<span class=\"line-mark\">まだ売らなくても</span>、まずは今日の価値を知るところから。"
        : "価格が見えたあとに、そのまま売る相談まで進める。<span class=\"line-mark\">やりとりは1社だけ</span>で整理しやすく。";

      const values = [data.current, data.future3, data.future6];
      const points = buildPoints(values, 296, 120, 16, 20);
      refs.aLine.setAttribute("d", linePath(points));
      refs.aArea.setAttribute("d", areaPath(points, 104));
      refs.aDots.forEach((dot, index) => {
        dot.setAttribute("cx", points[index].x);
        dot.setAttribute("cy", points[index].y);
      });
    }

    function updateB(data) {
      refs.bExpenseCaption.textContent = data.expenseCaption;
      refs.bExpenseTotal.textContent = formatYen(data.monthlyExpense);
      refs.bExpenseMeta.innerHTML = `${data.expenseDelta}<br />${data.expenseShare}`;
      refs.bValueFuel.textContent = formatYen(data.expenses.fuel);
      refs.bValueInsurance.textContent = formatYen(data.expenses.insurance);
      refs.bValueParking.textContent = formatYen(data.expenses.parking);
      refs.bValueMaintenance.textContent = formatYen(data.expenses.maintenance);
      refs.bCurrentPrice.textContent = formatMan(data.current);
      refs.bFuturePrice.textContent = formatMan(data.future6);
      refs.bMemoryTitle.textContent = state.mode === "check" ? "先月より出費が落ち着いています" : "いま売ると負担を軽くしやすいです";
      refs.bMemorySub.textContent = data.memory1;
      refs.bMemorySub2.textContent = data.memory2;
      refs.bSupport.innerHTML = state.mode === "check"
        ? "車の価値だけでなく、毎月の維持費まで見えると、<span class=\"line-mark\">次の判断がしやすくなる</span>。"
        : "売る相談に進む前に、出費と価格の両方を見せることで、<span class=\"line-mark\">納得して動ける</span>ようにする。";

      const maxExpense = Math.max(...Object.values(data.expenses));
      refs.bBarFuel.style.width = `${(data.expenses.fuel / maxExpense) * 100}%`;
      refs.bBarInsurance.style.width = `${(data.expenses.insurance / maxExpense) * 100}%`;
      refs.bBarParking.style.width = `${(data.expenses.parking / maxExpense) * 100}%`;
      refs.bBarMaintenance.style.width = `${(data.expenses.maintenance / maxExpense) * 100}%`;

      const values = [data.current, data.future3, data.future6];
      const points = buildPoints(values, 296, 94, 10, 14);
      refs.bLine.setAttribute("d", linePath(points));
      refs.bDots.forEach((dot, index) => {
        dot.setAttribute("cx", points[index].x);
        dot.setAttribute("cy", points[index].y);
      });
    }

    function updateC(data) {
      refs.cCarName.textContent = data.name;
      refs.cCarMeta.textContent = `AI査定価格 ${formatMan(data.current)} / 6ヶ月後 ${formatMan(data.future6)}予測`;
      refs.cPrice.innerHTML = `${formatMan(data.current)}<span class="yen">円</span>`.replace("万円円", "万円");

      if (state.mode === "check") {
        refs.cBadgeMain.textContent = "0本";
        refs.cBadgeNote.textContent = "相場チェック時の営業電話";
        refs.cHook.innerHTML = "まずは相場だけ。<br />それなら電話0本。";
        refs.cSupport.innerHTML = "比較したいだけなのに電話が鳴る。<br />その不安をなくせば、ダウンロードする理由はぐっと明確になります。";
        refs.cPhoneUcp.textContent = "0本";
        refs.cPhoneNote.textContent = "相場チェック時は連絡なし";
        refs.cPhoneCelca.textContent = "1社";
        refs.cQuote.textContent = "「まだ売るかわからないけど、今の価値だけは知っておきたい。」そんな気分にいちばん近いのが、電話0本で始められる相場チェックです。";
      } else {
        refs.cBadgeMain.textContent = "1社";
        refs.cBadgeNote.textContent = "売却相談に進んでもやりとりは1社";
        refs.cHook.innerHTML = "売る相談に進んでも、<br />やりとりは1社だけ。";
        refs.cSupport.innerHTML = "比較のために何社とも調整する負担を減らし、<br />最高額を狙う流れだけを残します。";
        refs.cPhoneUcp.textContent = "1社";
        refs.cPhoneNote.textContent = "オークション後の対応は1社";
        refs.cPhoneCelca.textContent = "1社";
        refs.cQuote.textContent = "「価格は比較したい。でも、電話ラッシュは避けたい。」その板挟みを減らすために、売却相談へ進んでも対応は1社に絞ります。";
      }
    }

    function render() {
      const data = vehicleData[state.vehicle];
      updateShotFocus();
      updateA(data);
      updateB(data);
      updateC(data);
      setPressed(".chip-button", state.vehicle, "data-vehicle");
      setPressed(".mode-button", state.mode, "data-mode");
      setPressed(".compare-switch", state.mode, "data-mode");
    }

    document.querySelectorAll(".focus-button").forEach((button) => {
      button.addEventListener("click", () => {
        state.focus = button.dataset.focus;
        render();
      });
    });

    document.querySelectorAll(".chip-button").forEach((button) => {
      button.addEventListener("click", () => {
        state.vehicle = button.dataset.vehicle;
        render();
      });
    });

    document.querySelectorAll(".mode-button, .compare-switch").forEach((button) => {
      button.addEventListener("click", () => {
        state.mode = button.dataset.mode;
        render();
      });
    });

    document.querySelectorAll("[data-toast]").forEach((button) => {
      button.addEventListener("click", () => {
        showToast(button.dataset.toast);
      });
    });

    render();
  </script>
