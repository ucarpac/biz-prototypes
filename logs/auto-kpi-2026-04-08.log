+
+    function formatMan(value) {
+      return `${value.toFixed(1)}万円`;
+    }
+
+    function formatYen(value) {
+      return `${value.toLocaleString("ja-JP")}円`;
+    }
+
+    function buildPoints(values, width, height, topPad, bottomPad) {
+      const min = Math.min(...values) - 6;
+      const max = Math.max(...values) + 6;
+      const usable = height - topPad - bottomPad;
+      const step = width / (values.length - 1);
+      return values.map((value, index) => {
+        const x = 12 + step * index;
+        const y = topPad + ((max - value) / (max - min || 1)) * usable;
+        return { x, y };
+      });
+    }
+
+    function linePath(points) {
+      return points.map((point, index) => `${index === 0 ? "M" : "L"}${point.x},${point.y}`).join(" ");
+    }
+
+    function areaPath(points, baseY) {
+      const top = points.map((point, index) => `${index === 0 ? "M" : "L"}${point.x},${point.y}`).join(" ");
+      const last = points[points.length - 1];
+      const first = points[0];
+      return `${top} L${last.x},${baseY} L${first.x},${baseY} Z`;
+    }
+
+    function setPressed(selector, activeValue, attrName) {
+      document.querySelectorAll(selector).forEach((button) => {
+        const active = button.getAttribute(attrName) === activeValue;
+        button.classList.toggle("is-active", active);
+        button.setAttribute("aria-pressed", String(active));
+      });
+    }
+
+    function showToast(message) {
