+
+    function formatMan(value) {
+      return `${value.toFixed(1)}万円`;
+    }
+
+    function formatYen(value) {
+      return `${value.toLocaleString("ja-JP")}円`;
+    }
+
+    function buildPoints(values, width, height, topPad, bottomPad) {
+      const min = Math.min(...values) - 6;
+      const max = Math.max(...values) + 6;
+      const usable = height - topPad - bottomPad;
+      const step = width / (values.length - 1);
+      return values.map((value, index) => {
+        const x = 12 + step * index;
+        const y = topPad + ((max - value) / (max - min || 1)) * usable;
+        return { x, y };
+      });
+    }
+
+    function linePath(points) {
+      return points.map((point, index) => `${index === 0 ? "M" : "L"}${point.x},${point.y}`).join(" ");
+    }
+
+    function areaPath(points, baseY) {
+      const top = points.map((point, index) => `${index === 0 ? "M" : "L"}${point.x},${point.y}`).join(" ");
+      const last = points[points.length - 1];
+      const first = points[0];
+      return `${top} L${last.x},${baseY} L${first.x},${baseY} Z`;
+    }
+
+    function setPressed(selector, activeValue, attrName) {
+      document.querySelectorAll(selector).forEach((button) => {
+        const active = button.getAttribute(attrName) === activeValue;
+        button.classList.toggle("is-active", active);
+        button.setAttribute("aria-pressed", String(active));
+      });
+    }
+
+    function showToast(message) {
+      refs.toast.textContent = message;
+      refs.toast.classList.add("is-visible");
+      window.clearTimeout(showToast.timer);
+      showToast.timer = window.setTimeout(() => {
+        refs.toast.classList.remove("is-visible");
+      }, 2200);
+    }
+
+    function updateShotFocus() {
+      document.querySelectorAll(".shot").forEach((shot) => {
+        shot.classList.toggle("is-focused", shot.dataset.shot === state.focus);
+      });
+      setPressed(".focus-button", state.focus, "data-focus");
+    }
+
+    function updateA(data) {
+      refs.aCarName.textContent = data.name;
+      refs.aCarMeta.textContent = data.meta;
+      refs.aPrice.innerHTML = `${formatMan(data.current)}<span class="yen">円</span>`.replace("万円円", "万円");
+      refs.aPillRange.textContent = `下限 ${formatMan(data.floor)}`;
+      refs.aPillConfidence.textContent = `信頼度 ${data.confidence}%`;
+      refs.aStat1.textContent = data.momentum;
+      refs.aStat3.textContent = state.mode === "check" ? "0件" : "1社";
+      refs.aHook.innerHTML = state.mode === "check"
+        ? "AIがあなたの愛車を査定"
+        : "AI査定から、そのまま売却相談へ";
+      refs.aSupport.innerHTML = state.mode === "check"
+        ? "相場が見えると、気持ちは少し軽くなる。<span class=\"line-mark\">まだ売らなくても</span>、まずは今日の価値を知るところから。"
+        : "価格が見えたあとに、そのまま売る相談まで進める。<span class=\"line-mark\">やりとりは1社だけ</span>で整理しやすく。";
+
+      const values = [data.current, data.future3, data.future6];
+      const points = buildPoints(values, 296, 120, 16, 20);
+      refs.aLine.setAttribute("d", linePath(points));
+      refs.aArea.setAttribute("d", areaPath(points, 104));
+      refs.aDots.forEach((dot, index) => {
+        dot.setAttribute("cx", points[index].x);
+        dot.setAttribute("cy", points[index].y);
+      });
+    }
+
+    function updateB(data) {
+      refs.bExpenseCaption.textContent = data.expenseCaption;
+      refs.bExpenseTotal.textContent = formatYen(data.monthlyExpense);
+      refs.bExpenseMeta.innerHTML = `${data.expenseDelta}<br />${data.expenseShare}`;
+      refs.bValueFuel.textContent = formatYen(data.expenses.fuel);
+      refs.bValueInsurance.textContent = formatYen(data.expenses.insurance);
