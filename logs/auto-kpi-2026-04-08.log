+      color: var(--dark-blue);
+      font-size: 12px;
+      font-weight: 900;
+    }
+
+    .shot-tag.android {
+      background: #eff8ff;
+    }
+
+    .shot-tag.compare {
+      background: #fff7e9;
+    }
+
+    .shot-title {
+      margin: 6px 0 0;
+      color: var(--dark-blue);
+      font-size: 24px;
+      line-height: 1.45;
+      font-weight: 900;
