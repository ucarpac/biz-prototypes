        expenseCaption: "セレナ / 2026年4月の集計",
        expenses: {
          fuel: 21400,
          insurance: 10900,
          parking: 12000,
          maintenance: 6900
        },
        memory1: "春休みの移動増でガソリン代が上昇",
        memory2: "ミニバン需要が強い時期に通知を推奨"
      },
      nbox: {
        name: "ホンダ N-BOX カスタムLターボ",
        meta: "2022年式 / 12,600km / プレミアムサンライトホワイト",
        current: 168.4,
        floor: 161.3,
        future3: 166.8,
        future6: 159.9,
        confidence: 90,
        momentum: "+3.7万円",
        monthlyExpense: 33700,
        expenseDelta: "先月より 2,100円ダウン",
        expenseShare: "家計負担 6.1%",
        expenseCaption: "N-BOX / 2026年4月の集計",
        expenses: {
          fuel: 8800,
          insurance: 7600,
          parking: 12000,
          maintenance: 5300
        },
        memory1: "軽自動車の高需要で査定が堅調です",
        memory2: "車検前の売却検討で負担を軽くできます"
      }
    };

    const state = {
      vehicle: "prius",
      mode: "check",
      focus: "a"
    };

    const refs = {
      toast: document.getElementById("toast"),
      aHook: document.getElementById("a-hook"),
      aSupport: document.getElementById("a-support"),
      aCarName: document.getElementById("a-car-name"),
      aCarMeta: document.getElementById("a-car-meta"),
      aPrice: document.getElementById("a-price"),
      aPillRange: document.getElementById("a-pill-range"),
      aPillConfidence: document.getElementById("a-pill-confidence"),
