+    body {
+      margin: 0;
+      min-height: 100%;
+      font-family: var(--font-sans);
+      color: var(--text-black);
+      background:
+        radial-gradient(circle at 10% 10%, rgba(255, 203, 170, 0.26), transparent 24%),
+        radial-gradient(circle at 88% 8%, rgba(248, 76, 162, 0.18), transparent 22%),
+        radial-gradient(circle at 90% 88%, rgba(111, 194, 255, 0.18), transparent 24%),
+        #fffaf7;
+      overflow-x: hidden;
+    }
+
+    body::before,
+    body::after {
+      content: "";
+      position: fixed;
+      width: 280px;
+      height: 280px;
+      border-radius: 999px;
+      filter: blur(46px);
+      opacity: 0.48;
+      pointer-events: none;
+      z-index: 0;
+    }
+
+    body::before {
+      top: 32px;
+      left: -92px;
+      background: rgba(255, 176, 128, 0.26);
+    }
+
+    body::after {
+      right: -96px;
+      bottom: 8px;
+      background: rgba(77, 180, 255, 0.20);
+    }
+
+    button {
+      font: inherit;
+    }
+
+    .page {
+      position: relative;
+      z-index: 1;
+      width: 100%;
+      max-width: 1380px;
+      margin: 0 auto;
+      padding: 18px 14px 52px;
+    }
+
+    .masthead {
+      position: relative;
+      overflow: hidden;
+      padding: 20px 18px 22px;
+      border-radius: 30px;
+      background: rgba(255, 255, 255, 0.78);
+      border: 1px solid rgba(255, 255, 255, 0.88);
+      box-shadow: var(--shadow-medium);
+      backdrop-filter: blur(18px);
+    }
+
+    .masthead::after {
+      content: "";
+      position: absolute;
+      width: 240px;
+      height: 240px;
+      right: -36px;
+      bottom: -72px;
+      border-radius: 999px;
+      background: radial-gradient(circle, rgba(248, 76, 162, 0.18), transparent 70%);
+      pointer-events: none;
+    }
+
+    .eyebrow {
+      display: inline-flex;
+      align-items: center;
+      gap: 8px;
+      min-height: 36px;
+      padding: 0 14px;
+      border-radius: 999px;
+      background: rgba(255, 255, 255, 0.92);
+      color: var(--dark-blue);
+      font-size: 12px;
+      font-weight: 900;
+      letter-spacing: 0.05em;
+      box-shadow: var(--shadow-light);
+    }
+
+    .eyebrow .pulse {
+      width: 9px;
+      height: 9px;
+      border-radius: 999px;
+      background: var(--pink);
+      box-shadow: 0 0 0 8px rgba(248, 76, 162, 0.12);
+      animation: pulse 2.4s ease-in-out infinite;
+    }
+
+    h1 {
+      margin: 16px 0 10px;
+      max-width: 880px;
+      color: var(--dark-blue);
+      font-size: clamp(32px, 5.8vw, 56px);
+      line-height: 1.16;
+      letter-spacing: -0.05em;
+      font-weight: 900;
+    }
+
+    .lead {
+      max-width: 860px;
+      margin: 0;
+      color: #68728d;
+      font-size: 14px;
+      line-height: 1.9;
+    }
+
+    .lead strong {
+      color: var(--dark-blue);
+    }
+
+    .lead .marker {
+      background: linear-gradient(transparent 60%, rgba(255, 232, 132, 0.86) 60%);
+      padding: 0 2px;
+    }
+
+    .kpi-strip {
+      display: flex;
+      flex-wrap: wrap;
+      gap: 10px;
+      margin-top: 18px;
+    }
+
+    .kpi-pill {
+      display: inline-flex;
+      align-items: center;
+      gap: 8px;
+      min-height: 38px;
+      padding: 0 14px;
+      border-radius: 999px;
+      background: rgba(255, 255, 255, 0.92);
+      color: var(--dark-blue);
+      font-size: 12px;
+      font-weight: 800;
+      box-shadow: var(--shadow-light);
