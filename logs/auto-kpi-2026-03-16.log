  <script>
    (function () {
      var filterButtons = Array.prototype.slice.call(document.querySelectorAll("[data-filter]"));
      var screenCards = Array.prototype.slice.call(document.querySelectorAll(".screen-card"));
      var animateButton = document.getElementById("animateButton");
      var insightButton = document.getElementById("insightButton");
      var motionEnabled = true;
      var insightMode = 0;

      function applyFilter(filter) {
        screenCards.forEach(function (card) {
          var show = filter === "all" || card.dataset.kind === filter;
          card.classList.toggle("hidden", !show);
          if (show && motionEnabled) {
            requestAnimationFrame(function () {
              card.classList.add("is-visible");
            });
          }
        });
        filterButtons.forEach(function (button) {
          button.classList.toggle("is-active", button.dataset.filter === filter);
        });
      }

      function setMotionState(enabled) {
        motionEnabled = enabled;
        animateButton.textContent = enabled ? "アニメーションON" : "アニメーションOFF";
        animateButton.classList.toggle("is-active", enabled);
        screenCards.forEach(function (card) {
          card.classList.toggle("is-visible", enabled);
        });
      }

      function cycleInsight() {
        insightMode = (insightMode + 1) % 3;
        insightButton.classList.toggle("is-active", insightMode !== 0);

        var heroA = document.querySelector("[data-copy-target='a']");
        var heroA2 = document.querySelector("[data-copy-target='a2']");
        var heroB = document.querySelector("[data-copy-target='b']");
        var heroB2 = document.querySelector("[data-copy-target='b2']");
