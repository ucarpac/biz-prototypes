  <script>
    (function () {
      var filterButtons = Array.prototype.slice.call(document.querySelectorAll("[data-filter]"));
      var screenCards = Array.prototype.slice.call(document.querySelectorAll(".screen-card"));
      var animateButton = document.getElementById("animateButton");
      var insightButton = document.getElementById("insightButton");
      var motionEnabled = true;
      var insightMode = 0;

      function applyFilter(filter) {
        screenCards.forEach(function (card) {
          var show = filter === "all" || card.dataset.kind === filter;
          card.classList.toggle("hidden", !show);
          if (show && motionEnabled) {
            requestAnimationFrame(function () {
              card.classList.add("is-visible");
            });
          }
        });
        filterButtons.forEach(function (button) {
          button.classList.toggle("is-active", button.dataset.filter === filter);
        });
      }

      function setMotionState(enabled) {
        motionEnabled = enabled;
        animateButton.textContent = enabled ? "アニメーションON" : "アニメーションOFF";
        animateButton.classList.toggle("is-active", enabled);
        screenCards.forEach(function (card) {
          card.classList.toggle("is-visible", enabled);
        });
      }

      function cycleInsight() {
        insightMode = (insightMode + 1) % 3;
        insightButton.classList.toggle("is-active", insightMode !== 0);

        var heroA = document.querySelector("[data-copy-target='a']");
        var heroA2 = document.querySelector("[data-copy-target='a2']");
        var heroB = document.querySelector("[data-copy-target='b']");
        var heroB2 = document.querySelector("[data-copy-target='b2']");
        var heroC = document.querySelector("[data-copy-target='c']");
        var heroC2 = document.querySelector("[data-copy-target='c2']");
        var compareCallout = document.getElementById("calloutCompare");
        var floatingNote = document.getElementById("floatingNote");

        if (insightMode === 1) {
          heroA.textContent = "価格グラフの説得力を強調";
          heroA2.textContent = "入力60秒を強調";
          heroB.textContent = "維持費の見える化を強調";
          heroB2.textContent = "売り時通知を強調";
          heroC.textContent = "個人情報不要を強調";
          heroC2.textContent = "1社のみ対応を強調";
          compareCallout.querySelector(".big").innerHTML = "連絡が怖い人ほど<br>最初の一歩が軽い。";
          compareCallout.querySelector(".small").textContent = "ストア1枚目では安心、2枚目で価値、3枚目で売却期待へつなげる。";
          floatingNote.textContent = "比較表の主役は料金より先に、心理負荷の低さ。";
        } else if (insightMode === 2) {
          heroA.textContent = "95%精度を強調";
          heroA2.textContent = "3か月予測を強調";
          heroB.textContent = "年間維持費を強調";
          heroB2.textContent = "半年後価値を強調";
          heroC.textContent = "電話0本を強調";
          heroC2.textContent = "8,000社入札を強調";
          compareCallout.querySelector(".big").innerHTML = "まず相場だけ知る。<br>だからDLしやすい。";
          compareCallout.querySelector(".small").textContent = "一括査定の文脈を知るユーザーほど、差分理解が早い構図。";
          floatingNote.textContent = "CVR改善では、複雑な機能説明より『試せる安心』が強い。";
        } else {
          heroA.textContent = "AI査定の訴求を強調";
          heroA2.textContent = "個人情報不要を強調";
          heroB.textContent = "出費管理を強調";
          heroB2.textContent = "将来予測を強調";
          heroC.textContent = "電話0本を強調";
          heroC2.textContent = "8,000社を強調";
          compareCallout.querySelector(".big").innerHTML = "査定しただけで<br>電話ラッシュ、ありません。";
          compareCallout.querySelector(".small").textContent = "UcarPACアプリは相場チェック時の個人情報入力なし。まず価値を知りたい人向け。";
          floatingNote.textContent = "DL前の不安は「高く売れるか」より「面倒な連絡が来ないか」で判断されやすい。";
        }
      }

      filterButtons.forEach(function (button) {
        button.addEventListener("click", function () {
          applyFilter(button.dataset.filter);
        });
      });

      animateButton.addEventListener("click", function () {
        setMotionState(!motionEnabled);
      });

      insightButton.addEventListener("click", cycleInsight);

      document.querySelectorAll("[data-copy-target]").forEach(function (button) {
        button.addEventListener("click", function () {
          var panel = button.closest(".panel");
          panel.style.transform = "scale(1.01)";
          panel.style.transition = "transform 0.18s ease";
          setTimeout(function () {
            panel.style.transform = "";
          }, 180);
          cycleInsight();
        });
      });

      applyFilter("all");
      setMotionState(true);
    })();
  </script>
