      transform: rotate(-3deg);
      display: inline-block;
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 22px 0 20px;
    }

    .tab {
      appearance: none;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: rgba(255,255,255,0.84);
      color: var(--dark-blue);
      border-radius: 999px;
      padding: 12px 18px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.05);
    }

    .tab.active {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 14px 24px rgba(248, 76, 162, 0.24);
      transform: translateY(-1px);
    }

    .stage {
      display: grid;
      gap: 20px;
    }

    .shot {
      display: none;
      align-items: center;
      gap: 28px;
      grid-template-columns: 1fr;
      background: rgba(255,255,255,0.55);
      border-radius: 30px;
      padding: 20px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.65), 0 28px 60px rgba(28, 38, 99, 0.08);
    }

    .shot.active {
      display: grid;
      animation: fadeIn 0.5s ease;
    }

    .shot-copy {
      order: 2;
    }

    .shot-copy h2 {
      margin: 0 0 10px;
      font-size: clamp(24px, 4vw, 34px);
      line-height: 1.2;
      color: var(--dark-blue);
    }

    .shot-copy p {
      margin: 0 0 12px;
      font-size: 15px;
      color: var(--text-gray);
      line-height: var(--line-height);
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 16px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      padding: 10px 14px;
      font-size: 12px;
      font-weight: 700;
      background: #fff;
      color: var(--dark-blue);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.06);
    }

    .pill.hot {
      background: rgba(255, 185, 163, 0.2);
    }

    .phone-wrap {
      display: flex;
      justify-content: center;
      order: 1;
    }

    .phone {
      width: min(100%, 375px);
      aspect-ratio: 375 / 812;
      border-radius: 38px;
      padding: 14px;
      background:
        linear-gradient(145deg, rgba(255,255,255,0.98), rgba(248,250,255,0.9)),
        linear-gradient(145deg, #091355, #1c2663);
      box-shadow: 0 30px 60px rgba(28, 38, 99, 0.18);
      position: relative;
      overflow: hidden;
    }

    .phone::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 8px;
      transform: translateX(-50%);
      width: 112px;
      height: 24px;
      border-radius: 0 0 18px 18px;
      background: rgba(9, 19, 85, 0.9);
      z-index: 5;
    }

    .screen {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 28px;
      overflow: hidden;
      background: var(--paper);
    }

    .screen::before,
    .screen::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      filter: blur(2px);
    }

    .screen::before {
      width: 180px;
      height: 180px;
      right: -45px;
      top: -30px;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.2), rgba(248, 76, 162, 0));
    }

    .screen::after {
      width: 160px;
      height: 160px;
      left: -65px;
      bottom: 60px;
      background: radial-gradient(circle, rgba(255, 217, 150, 0.42), rgba(255, 217, 150, 0));
    }

    .status-bar {
      position: relative;
      z-index: 2;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 18px 8px;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
    }

    .status-icons {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .status-icons span {
      display: inline-block;
      width: 18px;
      height: 8px;
      border-radius: 999px;
      border: 1.8px solid var(--dark-blue);
      position: relative;
    }

    .status-icons span::after {
      content: "";
      position: absolute;
      right: 2px;
      top: 1px;
      width: 10px;
      height: 4px;
      border-radius: 999px;
      background: var(--dark-blue);
    }

    .screen-body {
      position: relative;
      z-index: 2;
      height: calc(100% - 40px);
      padding: 6px 18px 22px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .store-tag {
      align-self: flex-start;
      display: inline-flex;
      gap: 8px;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.84);
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      box-shadow: 0 10px 20px rgba(28,38,99,0.06);
    }

    .store-tag .spark {
      width: 10px;
      height: 10px;
      background: linear-gradient(180deg, #ffb98c, #f84ca2);
      border-radius: 50%;
    }

    .hero-card {
      position: relative;
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,245,240,0.96));
      border: 1px solid rgba(255,255,255,0.7);
      border-radius: 28px;
      padding: 18px 16px 18px;
      box-shadow: 0 18px 40px rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .hero-card .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 10px;
    }

    .mini-badge {
      padding: 7px 11px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(29, 220, 255, 0.16);
    }

    .mini-badge.pink {
      background: rgba(248, 76, 162, 0.14);
    }

    .hero-title {
      margin: 0;
      font-size: 31px;
      line-height: 1.2;
      letter-spacing: -0.04em;
      color: var(--dark-blue);
    }

    .hero-title strong {
      display: block;
      font-size: 42px;
      line-height: 1.1;
      margin-top: 4px;
      color: var(--pink);
    }

    .hero-sub {
      margin: 10px 0 0;
      font-size: 13px;
      line-height: 1.55;
      color: var(--text-gray);
    }

    .doodle {
      position: absolute;
      right: 16px;
      top: 18px;
      width: 84px;
      height: 84px;
      border-radius: 50%;
      border: 2px dashed rgba(248, 76, 162, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      transform: rotate(8deg);
      color: #c56a45;
      font-family: var(--font-note);
      font-size: 14px;
      background: rgba(255,255,255,0.5);
    }

    .car-illustration {
      display: grid;
      place-items: center;
      height: 156px;
      margin: 8px 0 4px;
      position: relative;
    }

    .car {
      position: relative;
      width: 210px;
      height: 88px;
      border-radius: 36px 36px 26px 26px;
      background: linear-gradient(180deg, #ffcf9e, #ff9c9c 55%, #f84ca2 100%);
      box-shadow: 0 18px 35px rgba(248, 76, 162, 0.18);
      animation: floatCar 3.6s ease-in-out infinite;
    }

    .car::before,
    .car::after {
      content: "";
      position: absolute;
      bottom: -12px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #26315f;
      box-shadow: inset 0 0 0 8px #fff;
    }

    .car::before {
      left: 24px;
    }

    .car::after {
      right: 24px;
    }

    .roof {
      position: absolute;
      width: 112px;
      height: 44px;
      left: 48px;
      top: -20px;
      border-radius: 28px 28px 12px 12px;
      background: linear-gradient(180deg, #fff8ec, #ffe7c1);
    }

    .window {
      position: absolute;
      top: 9px;
      width: 42px;
      height: 20px;
      border-radius: 12px;
      background: rgba(29, 220, 255, 0.22);
    }

    .window.left {
      left: 10px;
    }

    .window.right {
      right: 10px;
    }

    .heart {
      position: absolute;
      font-size: 18px;
      color: var(--pink);
      animation: drift 4.2s ease-in-out infinite;
    }

    .heart.h1 {
      top: 18px;
      left: 18%;
    }

    .heart.h2 {
      top: 12px;
      right: 16%;
      animation-delay: 1.2s;
    }

    .price-panel,
    .list-card,
    .compare-card,
    .expense-card {
      background: rgba(255,255,255,0.92);
      border-radius: 24px;
      box-shadow: 0 14px 30px rgba(28, 38, 99, 0.08);
    }

    .price-panel {
      padding: 16px;
    }

    .label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--text-gray);
      text-transform: uppercase;
    }

    .car-name {
      margin-top: 4px;
      font-size: 15px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .price-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 8px;
      margin-top: 8px;
    }

    .price-main {
      color: var(--dark-blue);
    }

    .price-main .yen {
      font-size: 17px;
      font-weight: 700;
    }

    .price-main .amount {
      font-family: var(--font-number);
      font-size: 36px;
      line-height: 1.1;
      letter-spacing: 0.02em;
    }

    .delta {
      text-align: right;
      font-size: 12px;
      font-weight: 700;
      color: #c56a45;
    }

    .progress-line {
      position: relative;
      margin-top: 14px;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      width: 68%;
      border-radius: 999px;
      background: linear-gradient(90deg, #f84ca2, #ffb98c);
      transition: width 0.45s ease;
    }

    .range-meta {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      font-size: 12px;
      color: var(--text-gray);
    }

    .ghost-note {
      margin-top: 10px;
      font-family: var(--font-note);
      color: #b76747;
      font-size: 14px;
      transform: rotate(-2deg);
    }

    .graph-card {
      margin-top: 10px;
      display: none;
      gap: 12px;
      padding-top: 12px;
      border-top: 1px dashed rgba(28, 38, 99, 0.12);
    }

    .graph-card.show {
      display: grid;
    }

    .graph-bars {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 8px;
      height: 90px;
      margin-top: 8px;
    }

    .bar-col {
      flex: 1;
      text-align: center;
    }

    .bar {
      width: 100%;
      border-radius: 14px 14px 6px 6px;
      background: linear-gradient(180deg, rgba(248, 76, 162, 0.28), rgba(29, 220, 255, 0.9));
      transition: height 0.4s ease;
    }

    .bar-label {
      margin-top: 6px;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .cta {
      appearance: none;
      width: 100%;
      border: 0;
      border-radius: 30px;
      padding: 15px 18px;
      font-size: 14px;
      font-weight: 800;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      cursor: pointer;
      box-shadow: 0 16px 28px rgba(64, 153, 255, 0.26);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .cta:active {
      transform: scale(0.98);
    }

    .cta.pink {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 16px 28px rgba(248, 76, 162, 0.28);
    }

    .action-row {
      display: grid;
      gap: 10px;
    }

    .sub-action {
      appearance: none;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: rgba(255,255,255,0.85);
      color: var(--dark-blue);
      border-radius: 30px;
      padding: 13px 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .sub-action.active {
      background: rgba(248, 76, 162, 0.1);
    }

    .list-card {
      padding: 14px;
      display: grid;
      gap: 12px;
    }

    .list-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--ruled-line);
    }

    .list-item:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .list-item strong {
      display: block;
      font-size: 14px;
      color: var(--dark-blue);
    }

    .list-item span {
      font-size: 12px;
      color: var(--text-gray);
    }

    .list-price {
      font-size: 15px;
      font-weight: 800;
      color: var(--pink);
      white-space: nowrap;
    }

    .section-title {
      font-size: 18px;
      line-height: 1.35;
      font-weight: 800;
      color: var(--dark-blue);
      margin: 0;
    }

    .chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    .chips::-webkit-scrollbar {
      display: none;
    }

    .chip {
      flex: 0 0 auto;
      appearance: none;
      border: 0;
      min-height: 43px;
      padding: 12px 15px;
      border-radius: 22px;
      background: #fff;
      color: var(--text-black);
      box-shadow: inset 0 0 0 1px var(--ruled-line);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: none;
    }

    .expense-card {
      padding: 16px;
      display: grid;
      gap: 14px;
    }

    .expense-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .expense-total {
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .expense-total small {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 700;
      margin-left: 4px;
      color: var(--text-gray);
    }

    .tag-plain {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 217, 150, 0.28);
      font-size: 11px;
      font-weight: 700;
      color: #9b5a20;
      white-space: nowrap;
    }

    .stack-bars {
      display: flex;
      align-items: flex-end;
      gap: 10px;
      height: 100px;
    }

    .stack {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 5px;
      height: 100%;
    }

    .stack span {
      display: block;
      border-radius: 10px;
      transition: height 0.4s ease;
    }

    .stack .a {
      background: #6fc2ff;
    }

    .stack .b {
      background: #ffd996;
    }

    .stack .c {
      background: #f84ca2;
    }

    .month {
      margin-top: 8px;
      font-size: 11px;
      text-align: center;
      color: var(--text-gray);
      font-weight: 700;
    }

    .forecast-sheet {
      position: relative;
      padding: 14px;
      border-radius: 22px;
      background: linear-gradient(180deg, #fff5fb, #ffffff);
      border: 1px dashed rgba(248, 76, 162, 0.22);
    }

    .forecast-sheet h3,
    .compare-card h3 {
      margin: 0 0 8px;
      font-size: 16px;
      color: var(--dark-blue);
    }

    .forecast-sheet p,
    .compare-card p {
      margin: 0;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.55;
    }

    .forecast-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .forecast-cell {
      padding: 10px 8px;
      border-radius: 16px;
      background: rgba(255,255,255,0.9);
      text-align: center;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.06);
    }

    .forecast-cell strong {
      display: block;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .forecast-cell span {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      margin-bottom: 5px;
    }

    .compare-card {
      padding: 16px;
      display: grid;
      gap: 12px;
    }

    .callout {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 14px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255, 217, 150, 0.34), rgba(255,255,255,0.9));
    }

    .callout strong {
      display: block;
      font-size: 16px;
      color: var(--dark-blue);
    }

    .callout span {
      display: block;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.5;
    }

    .call-count {
      min-width: 92px;
      text-align: center;
      padding: 10px 12px;
      border-radius: 18px;
      background: var(--dark-blue);
      color: #fff;
      box-shadow: 0 12px 22px rgba(28, 38, 99, 0.18);
    }

    .call-count b {
      display: block;
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 1;
      color: #fff4a3;
    }

    .compare-list {
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr 0.9fr;
      align-items: center;
      gap: 10px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.84);
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.06);
    }

    .compare-row strong {
      font-size: 13px;
      color: var(--dark-blue);
    }

    .compare-row .bad {
      color: #c15d2c;
      font-size: 12px;
      font-weight: 700;
      text-align: center;
    }

    .compare-row .good {
      color: var(--pink);
      font-size: 12px;
      font-weight: 800;
      text-align: center;
    }

    .phone-footer {
      margin-top: auto;
      display: grid;
      gap: 10px;
    }

    .tiny {
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
      text-align: center;
    }

    .platform {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.76);
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      box-shadow: 0 12px 20px rgba(28,38,99,0.06);
    }

    .platform .icon {
      width: 18px;
      height: 18px;
      border-radius: 6px;
      display: inline-grid;
      place-items: center;
      font-size: 12px;
      color: var(--white);
      background: var(--dark-blue);
    }

    .pulse {
      animation: pulse 2.2s ease-in-out infinite;
    }

    .meter {
      width: 100%;
      height: 8px;
      border-radius: 999px;
      background: rgba(28,38,99,0.08);
      overflow: hidden;
      margin-top: 8px;
    }

    .meter > div {
      height: 100%;
      width: 74%;
      background: linear-gradient(90deg, #ffd996, #f84ca2);
      border-radius: 999px;
      transition: width 0.35s ease;
    }

    .floating-note {
      position: absolute;
      right: 12px;
      bottom: 10px;
      font-family: var(--font-note);
      font-size: 13px;
      color: #b86a46;
      transform: rotate(-4deg);
    }

    .legend {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend span::before {
      content: "";
      display: inline-block;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      margin-right: 6px;
      vertical-align: middle;
    }

    .legend .fuel::before {
      background: #6fc2ff;
    }

    .legend .maint::before {
      background: #ffd996;
    }

    .legend .other::before {
      background: #f84ca2;
    }

    .desktop-hint {
      margin-top: 16px;
      font-size: 12px;
      color: var(--text-gray);
    }

    @media (min-width: 920px) {
      .shot {
        grid-template-columns: minmax(320px, 395px) 1fr;
        padding: 24px;
      }

      .phone-wrap {
        order: 1;
      }

      .shot-copy {
        order: 2;
        padding-right: 8px;
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes floatCar {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-7px); }
    }

    @keyframes drift {
      0%, 100% { transform: translateY(0) rotate(0); opacity: 0.85; }
      50% { transform: translateY(-10px) rotate(8deg); opacity: 1; }
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 16px 28px rgba(64, 153, 255, 0.26); }
      50% { box-shadow: 0 18px 36px rgba(248, 76, 162, 0.28); }
    }
  </style>
</head>
<body>
  <main class="app">
    <section class="intro">
      <div class="eyebrow"><span class="dot"></span> UcarPAC ストアスクショ検証プロトタイプ</div>
      <h1>「いま売る？」の不安を、<br>やさしくほどく3つの訴求。</h1>
      <p class="lead">ストア詳細ページの閲覧からDLまでのCVR改善を想定した、感情訴求型のモバイルファースト試作です。AI査定の安心感、出費管理と将来予測の納得感、そして相場チェック時の「電話0本」という心理的ハードル低減を、暖色アクセントと親しみやすい表現でまとめています。</p>
      <div class="note">手ざわりは、やわらかく。判断材料は、しっかりと。</div>
    </section>

    <div class="controls" aria-label="スクリーン切替">
      <button class="tab active" data-target="shot-a">スクショA / iOS</button>
      <button class="tab" data-target="shot-b">スクショB / Android</button>
      <button class="tab" data-target="shot-c">スクショC / 比較訴求</button>
    </div>

    <section class="stage">
      <article class="shot active" id="shot-a">
        <div class="phone-wrap">
          <div class="phone">
            <div class="screen">
              <div class="status-bar">
                <span>9:41</span>
                <div class="status-icons">
                  <span></span>
                  <strong>5G</strong>
                </div>
              </div>
              <div class="screen-body">
                <div class="store-tag"><span class="spark"></span> iOS向けストアスクショA</div>

                <div class="hero-card">
                  <div class="badge-row">
                    <span class="mini-badge">個人情報不要</span>
                    <span class="mini-badge pink">AI査定</span>
                  </div>
                  <h3 class="hero-title">いまの価値も、<strong>次の売りどきも。</strong></h3>
                  <p class="hero-sub">トヨタ プリウス Sツーリングセレクション 2019年式 / 42,800km のような実データ感で、まずは相場をやさしく可視化。</p>
                  <div class="doodle">ほっとする<br>査定体験</div>
                  <div class="car-illustration" aria-hidden="true">
                    <div class="heart h1">♥</div>
                    <div class="heart h2">♥</div>
                    <div class="car">
                      <div class="roof">
                        <div class="window left"></div>
                        <div class="window right"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="price-panel">
                  <div class="label">AI査定価格</div>
                  <div class="car-name">プリウス Sツーリングセレクション / パールホワイト</div>
                  <div class="price-row">
                    <div class="price-main">
                      <span class="yen">¥</span><span class="amount" id="estimatePrice">184.2万</span>
                    </div>
                    <div class="delta">前月比<br>+4.8万円</div>
                  </div>
                  <div class="progress-line">
                    <div class="progress-fill" id="estimateProgress"></div>
                  </div>
                  <div class="range-meta">
                    <span>下限 176.0万</span>
                    <span>上限 198.6万</span>
                  </div>
                  <div class="ghost-note">「まだ売らなくても、見ておくだけで安心」</div>

                  <div class="graph-card" id="futureGraph">
                    <div>
                      <div class="label">3ヶ月先までの予測</div>
                      <div class="graph-bars">
                        <div class="bar-col">
                          <div class="bar" style="height:70px;"></div>
                          <div class="bar-label">今月</div>
                        </div>
                        <div class="bar-col">
                          <div class="bar" style="height:76px;"></div>
                          <div class="bar-label">1ヶ月後</div>
                        </div>
                        <div class="bar-col">
                          <div class="bar" style="height:82px;"></div>
                          <div class="bar-label">2ヶ月後</div>
                        </div>
                        <div class="bar-col">
                          <div class="bar" style="height:78px;"></div>
                          <div class="bar-label">3ヶ月後</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="phone-footer">
                  <div class="action-row">
                    <button class="sub-action" id="toggleFuture">未来の相場をみる</button>
                    <button class="cta pink pulse">AIで愛車価格をチェック</button>
                  </div>
                  <p class="tiny">査定結果は車種・年式・走行距離などの入力内容に基づくイメージです。相場チェック段階では個人情報入力不要。</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="shot-copy">
          <div class="platform"><span class="icon"></span> ストアスクショA / iOS向け</div>
          <h2>AI査定を「高機能」ではなく、<br>「心が軽くなる体験」として見せる。</h2>
          <p>最初の訴求は機能説明よりも、ユーザーの不安を和らげることを優先しています。相場がわからない、売りどきがわからない、個人情報を入れるのはまだ怖い。その迷いに対して、暖かいビジュアルと丸みのあるカードで安心感を演出します。</p>
          <p>価格だけでなく未来予測をボタンで展開できるため、静止スクショの見た目と、HTMLプロトタイプとしてのインタラクティブ性を両立しています。</p>
          <div class="pill-row">
