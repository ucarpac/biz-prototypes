  <script>
    (function () {
      const slides = document.getElementById("slides");
      const dots = Array.from(document.querySelectorAll(".dot"));
      const thumbs = Array.from(document.querySelectorAll(".thumb"));
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const floatingHint = document.getElementById("floatingHint");

      let currentIndex = 0;
      let startX = 0;
      let deltaX = 0;
      let autoplayTimer = null;

      function setSlide(index) {
        currentIndex = (index + 3) % 3;
        slides.style.transform = "translateX(-" + (currentIndex * 100) + "%)";
        dots.forEach((dot, i) => dot.classList.toggle("active", i === currentIndex));
        thumbs.forEach((thumb, i) => thumb.classList.toggle("active", i === currentIndex));
        floatingHint.textContent = ["AI査定訴求", "出費管理 + 将来予測", "電話0本 比較訴求"][currentIndex] + " を表示中";
        triggerSlideEffect(currentIndex);
      }

      function triggerSlideEffect(index) {
        if (index === 0) {
          flash(document.getElementById("aiCard"));
        }
        if (index === 1) {
          flash(document.getElementById("graphBox"));
        }
        if (index === 2) {
          flash(document.getElementById("stressFill"));
        }
      }

      function flash(element) {
        if (!element) return;
        element.classList.remove("flash");
        void element.offsetWidth;
        element.classList.add("flash");
      }

      dots.forEach((dot) => {
        dot.addEventListener("click", function () {
          setSlide(Number(this.dataset.index));
        });
      });

      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", function () {
          setSlide(Number(this.dataset.index));
        });
      });

      prevBtn.addEventListener("click", function () {
        setSlide(currentIndex - 1);
      });

      nextBtn.addEventListener("click", function () {
        setSlide(currentIndex + 1);
      });

      slides.addEventListener("touchstart", function (e) {
        startX = e.touches[0].clientX;
        deltaX = 0;
      }, { passive: true });

      slides.addEventListener("touchmove", function (e) {
        deltaX = e.touches[0].clientX - startX;
      }, { passive: true });

      slides.addEventListener("touchend", function () {
        if (Math.abs(deltaX) > 48) {
          if (deltaX < 0) {
            setSlide(currentIndex + 1);
          } else {
            setSlide(currentIndex - 1);
          }
        }
      });

      const aiPrice = document.getElementById("aiPrice");
      const aiChipButtons = Array.from(document.querySelectorAll("#aiChips .chip"));
      let aiCurrent = 3184000;

      function formatYen(value) {
        return "¥" + Number(value).toLocaleString("ja-JP");
      }

      function animateNumber(from, to, onUpdate) {
        const duration = 420;
        const start = performance.now();

        function tick(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = Math.round(from + (to - from) * eased);
          onUpdate(value);
          if (progress < 1) {
            requestAnimationFrame(tick);
          }
        }

        requestAnimationFrame(tick);
      }

      aiChipButtons.forEach((button) => {
        button.addEventListener("click", function () {
          aiChipButtons.forEach((chip) => chip.classList.remove("active"));
          this.classList.add("active");
          const nextPrice = Number(this.dataset.price);
          animateNumber(aiCurrent, nextPrice, function (value) {
            aiPrice.textContent = formatYen(value);
          });
          aiCurrent = nextPrice;
          flash(document.getElementById("aiCard"));
        });
      });

      const ctaA = document.getElementById("ctaA");
      ctaA.addEventListener("click", function () {
        const boosted = aiCurrent + 26000;
        animateNumber(aiCurrent, boosted, function (value) {
          aiPrice.textContent = formatYen(value);
        });
        aiCurrent = boosted;
        floatingHint.textContent = "診断完了: CTA押下で価格が伸びる演出";
        flash(document.getElementById("aiCard"));
      });

      const forecastData = {
        3: { value: 3054000, score: 88, total: 47200, points: [58, 68, 80, 112] },
        6: { value: 2980000, score: 82, total: 47200, points: [58, 72, 88, 118] },
        12: { value: 2760000, score: 64, total: 49200, points: [58, 78, 98, 132] }
      };

      const forecastTabs = Array.from(document.querySelectorAll("#forecastTabs .chip"));
      const forecastValue = document.getElementById("forecastValue");
      const sellScore = document.getElementById("sellScore");
      const expenseTotal = document.getElementById("expenseTotal");
      const scoreFill = document.getElementById("scoreFill");
      const forecastPath = document.getElementById("forecastPath");
      const forecastPoint = document.getElementById("forecastPoint");

      function drawForecast(month) {
        const data = forecastData[month];
        const xPoints = [16, 98, 178, 258];
        const path = "M" + xPoints[0] + " " + data.points[0] +
          " C" + (xPoints[0] + 24) + " " + data.points[0] + ", " + (xPoints[1] - 24) + " " + data.points[1] + ", " + xPoints[1] + " " + data.points[1] +
          " S" + (xPoints[2] - 24) + " " + data.points[2] + ", " + xPoints[2] + " " + data.points[2] +
          " S" + (xPoints[3] - 24) + " " + data.points[3] + ", " + xPoints[3] + " " + data.points[3];

        forecastPath.setAttribute("d", path);

        const pointMap = { 3: 98, 6: 178, 12: 258 };
        const yMap = { 3: data.points[1], 6: data.points[2], 12: data.points[3] };
        forecastPoint.setAttribute("cx", pointMap[month]);
        forecastPoint.setAttribute("cy", yMap[month]);

        forecastValue.textContent = formatYen(data.value);
        sellScore.textContent = data.score + "%";
        expenseTotal.textContent = formatYen(data.total);
        scoreFill.style.width = data.score + "%";
        flash(document.getElementById("graphBox"));
      }

      forecastTabs.forEach((tab) => {
        tab.addEventListener("click", function () {
          forecastTabs.forEach((btn) => btn.classList.remove("active"));
          this.classList.add("active");
          drawForecast(Number(this.dataset.month));
        });
      });

      drawForecast(6);

      const ctaB = document.getElementById("ctaB");
      ctaB.addEventListener("click", function () {
        forecastTabs.forEach((btn) => btn.classList.remove("active"));
        forecastTabs[0].classList.add("active");
        drawForecast(3);
        floatingHint.textContent = "通知訴求: 直近3か月の売り時を強調";
      });

      const phaseTabs = Array.from(document.querySelectorAll("#phaseTabs .chip"));
      const phaseState = {
        check: {
          u: 0,
          m: 3,
          z: 10,
          noteU: "AI査定は個人情報不要。相場を見るだけなら電話0本で完結。",
          noteM: "上位数社との連絡が発生しやすい。比較では電話前提の重さが目立つ。",
          noteZ: "複数社からの連絡集中が発生しやすい。最もストレスが高い導線。",
          stress: 100
        },
        consult: {
          u: 1,
          m: 3,
          z: 10,
          noteU: "売却相談に進んでも対応は1社のみ。負荷を最小化したままオークションへ。",
          noteM: "事前入札後は上位数社との折衝が必要になりやすい。",
          noteZ: "売却相談時は複数社対応が継続し、電話負荷が残る。",
          stress: 90
        }
      };

      const countU = document.getElementById("countU");
      const countM = document.getElementById("countM");
      const countZ = document.getElementById("countZ");
      const barU = document.getElementById("barU");
      const barM = document.getElementById("barM");
      const barZ = document.getElementById("barZ");
      const noteU = document.getElementById("noteU");
      const noteM = document.getElementById("noteM");
      const noteZ = document.getElementById("noteZ");
      const stressCut = document.getElementById("stressCut");
      const stressFill = document.getElementById("stressFill");

      function applyPhase(phase) {
        const data = phaseState[phase];
        countU.textContent = data.u + "本";
        countM.textContent = data.m + "本";
        countZ.textContent = data.z + "本";

        countU.classList.toggle("zero", data.u === 0);

        barU.style.width = Math.max(data.u * 10, data.u === 0 ? 4 : 12) + "%";
        barM.style.width = Math.min(data.m * 18, 80) + "%";
        barZ.style.width = Math.min(data.z * 9, 100) + "%";

        noteU.textContent = data.noteU;
        noteM.textContent = data.noteM;
        noteZ.textContent = data.noteZ;

        stressCut.textContent = data.stress + "%";
        stressFill.style.width = data.stress + "%";
        flash(document.querySelector(".compare-card"));
      }

      phaseTabs.forEach((tab) => {
        tab.addEventListener("click", function () {
          phaseTabs.forEach((btn) => btn.classList.remove("active"));
          this.classList.add("active");
          applyPhase(this.dataset.phase);
        });
      });

      applyPhase("check");

      const ctaC = document.getElementById("ctaC");
      ctaC.addEventListener("click", function () {
        phaseTabs.forEach((btn) => btn.classList.remove("active"));
        phaseTabs[0].classList.add("active");
        applyPhase("check");
        floatingHint.textContent = "比較訴求: 電話0本の安心感を最大化";
      });

      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = setInterval(function () {
          setSlide(currentIndex + 1);
        }, 5600);
      }

      function stopAutoplay() {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      document.addEventListener("visibilitychange", function () {
        if (document.hidden) {
          stopAutoplay();
        } else {
          startAutoplay();
        }
      });

      slides.addEventListener("pointerdown", stopAutoplay);
      prevBtn.addEventListener("click", startAutoplay);
      nextBtn.addEventListener("click", startAutoplay);
      dots.forEach((dot) => dot.addEventListener("click", startAutoplay));
      thumbs.forEach((thumb) => thumb.addEventListener("click", startAutoplay));

      setSlide(0);
      startAutoplay();
    })();
  </script>
</body>
