              <div class="thumb-visual b"></div>
              <div>
                <strong>スクショB</strong>
                <span>出費管理と将来予測を一画面化した Android 向け構成</span>
              </div>
            </button>
            <button class="thumb" data-index="2" type="button">
              <div class="thumb-visual c"></div>
              <div>
                <strong>スクショC</strong>
                <span>競合比較で「電話0本」を印象付ける構成</span>
              </div>
            </button>
