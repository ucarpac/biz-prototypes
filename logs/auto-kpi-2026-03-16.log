      opacity: 0.92;
      letter-spacing: 0.04em;
    }

    .title-xl {
      margin: 0;
      font-size: 34px;
      line-height: 1.2;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .title-md {
      margin: 0;
      font-size: 28px;
      line-height: 1.25;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .subcopy {
      margin: 0;
      font-size: 13px;
      line-height: 1.6;
      opacity: 0.95;
    }

    .glass-card,
    .solid-card,
    .compare-card {
      position: relative;
      z-index: 1;
      border-radius: 18px;
      overflow: hidden;
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow: 0 18px 42px rgba(0, 0, 0, 0.14);
      backdrop-filter: blur(12px);
      padding: 16px;
    }

    .solid-card {
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 18px 40px rgba(28, 38, 99, 0.08);
      padding: 16px;
    }

    .compare-card {
      background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 18px 40px rgba(28, 38, 99, 0.08);
      padding: 14px;
    }

    .car-line,
    .metric-line {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .car-meta {
      display: grid;
      gap: 4px;
    }

    .car-meta h3,
    .metric-title {
      margin: 0;
      font-size: 14px;
      line-height: 1.5;
      font-weight: 800;
    }

    .car-meta p,
    .metric-note {
      margin: 0;
      font-size: 11px;
      line-height: 1.5;
      opacity: 0.9;
    }

    .score-ball {
      display: grid;
      place-items: center;
      width: 54px;
      height: 54px;
      border-radius: 50%;
      background: linear-gradient(180deg, rgba(29, 220, 255, 0.26), rgba(248, 76, 162, 0.24));
      font-size: 15px;
      font-weight: 900;
      color: #fff;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
    }

    .price-stack {
      display: grid;
      gap: 4px;
      margin-top: 12px;
    }

    .price-label {
      margin: 0;
      font-size: 11px;
      line-height: 1.5;
      opacity: 0.88;
    }

    .price-value {
      margin: 0;
      font-family: var(--font-number);
      font-size: 38px;
      line-height: 1.15;
      letter-spacing: 0.01em;
      color: #fff;
      text-shadow: 0 10px 26px rgba(0, 0, 0, 0.18);
    }

    .price-value.dark {
      color: var(--dark-blue);
      text-shadow: none;
    }

    .range-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      font-size: 11px;
      line-height: 1.5;
      font-weight: 700;
    }

    .range-chip {
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.16);
    }

    .range-chip.light {
      background: rgba(28, 38, 99, 0.06);
      border-color: rgba(28, 38, 99, 0.08);
      color: var(--dark-blue);
    }

    .chip-grid {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 4px;
    }

    .chip {
      border: none;
      min-height: 43px;
      padding: 10px 14px;
      border-radius: var(--radius-chip);
      font-size: 12px;
      line-height: 1.5;
      font-weight: 800;
      cursor: pointer;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease;
    }

    .screen-a .chip {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.16);
    }

    .screen-a .chip.active {
      background: #fff;
      color: var(--dark-blue);
      box-shadow: 0 10px 24px rgba(255, 255, 255, 0.18);
      transform: translateY(-2px);
    }

    .screen-b .chip,
    .screen-c .chip {
      background: #fff;
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 12px 20px rgba(28, 38, 99, 0.06);
    }

    .screen-b .chip.active,
    .screen-c .chip.active {
      background: var(--dark-blue);
      color: #fff;
      transform: translateY(-2px);
    }

    .step-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .step {
      padding: 10px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.12);
      text-align: center;
    }

    .step small {
      display: block;
      font-size: 10px;
      line-height: 1.5;
      opacity: 0.8;
    }

    .step strong {
      display: block;
      font-size: 12px;
      line-height: 1.5;
      margin-top: 2px;
    }

    .cta {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      min-height: 54px;
      border: none;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
      cursor: pointer;
      box-shadow: 0 14px 28px rgba(29, 220, 255, 0.28);
      transition: transform 180ms ease, box-shadow 180ms ease;
      animation: pulse 2.6s ease-in-out infinite;
    }

    .cta.alt {
      background: var(--gradient-pink);
      color: #fff;
      box-shadow: 0 14px 28px rgba(248, 76, 162, 0.28);
    }

    .cta:active {
      transform: scale(0.98);
    }

    @keyframes pulse {
      0%, 100% {
        transform: translateY(0);
        box-shadow: 0 14px 28px rgba(29, 220, 255, 0.28);
      }
      50% {
        transform: translateY(-2px);
        box-shadow: 0 18px 34px rgba(29, 220, 255, 0.34);
      }
    }

    .spark {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.8);
      animation: sparkMove 3.2s linear infinite;
    }

    .spark.s1 {
      top: 140px;
      right: 36px;
    }

    .spark.s2 {
      top: 240px;
      right: 110px;
      animation-delay: -1.1s;
    }

    .spark.s3 {
      top: 420px;
      right: 52px;
      animation-delay: -2.2s;
    }

    @keyframes sparkMove {
      0% {
        opacity: 0;
        transform: translateY(10px) scale(0.6);
      }
      30% {
        opacity: 1;
      }
      100% {
        opacity: 0;
        transform: translateY(-24px) scale(1.4);
      }
    }

    .forecast-wrap {
      display: grid;
      gap: 12px;
    }

    .forecast-top {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 10px;
    }

    .forecast-value {
      margin: 0;
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 1.2;
      color: var(--dark-blue);
    }

    .mini-stat {
      display: grid;
      gap: 2px;
      justify-items: end;
      text-align: right;
    }

    .mini-stat strong {
      font-size: 18px;
      line-height: 1.5;
      color: var(--pink);
    }

    .mini-stat span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .graph-box {
      border-radius: 18px;
      background: linear-gradient(180deg, #ffffff 0%, #eff8ff 100%);
      border: 1px solid rgba(28, 38, 99, 0.06);
      padding: 12px;
    }

    .graph-grid {
      width: 100%;
      height: 150px;
      display: block;
    }

    .axis-labels {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      margin-top: 6px;
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(28, 38, 99, 0.04);
    }

    .expense-icon {
      width: 34px;
      height: 34px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, rgba(29, 220, 255, 0.16), rgba(77, 180, 255, 0.2));
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 900;
    }

    .expense-item strong {
      font-size: 13px;
      line-height: 1.5;
    }

    .expense-item span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .expense-item b {
      font-family: var(--font-number);
      font-size: 20px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .score-bar {
      position: relative;
      height: 12px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
      margin-top: 8px;
    }

    .score-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 82%;
      border-radius: inherit;
      background: linear-gradient(90deg, #f84ca2, #1ddcff);
      transition: width 320ms ease;
    }

    .compare-head {
      display: grid;
      gap: 6px;
    }

    .phase-tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .compare-list {
      display: grid;
      gap: 10px;
      margin-top: 8px;
    }

    .compare-row {
      display: grid;
      gap: 8px;
      padding: 12px;
      border-radius: 16px;
      background: rgba(28, 38, 99, 0.04);
      border: 1px solid rgba(28, 38, 99, 0.05);
    }

    .compare-row.ucarpac {
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.12), rgba(248, 76, 162, 0.1));
      border-color: rgba(64, 153, 255, 0.22);
    }

    .compare-row-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }

    .compare-row strong {
      font-size: 13px;
      line-height: 1.5;
    }

    .call-count {
      min-width: 64px;
      text-align: right;
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .call-count.zero {
      color: var(--pink);
    }

    .bar-track {
      position: relative;
      height: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(28, 38, 99, 0.08);
    }

    .bar-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 30%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 320ms ease;
    }

    .bar-fill.warn {
      background: linear-gradient(90deg, #ffd36c, #ff8d5f);
    }

    .bar-fill.alert {
      background: linear-gradient(90deg, #ff86a7, #f84ca2);
    }

    .compare-note {
      font-size: 11px;
      line-height: 1.55;
      color: var(--text-gray);
    }

    .floating-hint {
      position: absolute;
      left: 50%;
      bottom: 14px;
      transform: translateX(-50%);
      z-index: 6;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(3, 7, 24, 0.8);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      pointer-events: none;
      animation: hintFade 3.8s ease-in-out infinite;
      white-space: nowrap;
    }

    @keyframes hintFade {
      0%, 100% {
        opacity: 0.45;
      }
      50% {
        opacity: 1;
      }
    }

    .panel-card {
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(28, 38, 99, 0.08);
      padding: 14px;
      box-shadow: 0 14px 30px rgba(28, 38, 99, 0.06);
    }

    .panel-card h2 {
      margin: 0 0 6px;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .panel-card p {
      margin: 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .meter {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .meter-row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      font-weight: 700;
    }

    .meter-track {
      position: relative;
      width: 100%;
      height: 14px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .meter-current,
    .meter-target {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 0;
      border-radius: inherit;
    }

    .meter-current {
      width: 17.3%;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.95), rgba(248, 76, 162, 0.55));
    }

    .meter-target {
      width: 25%;
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.44), rgba(77, 180, 255, 0.9));
      mix-blend-mode: multiply;
    }

    .dots {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 4px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: none;
      background: rgba(28, 38, 99, 0.16);
      cursor: pointer;
      transition: transform 180ms ease, background 180ms ease;
    }

    .dot.active {
      background: var(--pink);
      transform: scale(1.18);
    }

    .nav-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .nav-btn {
      min-height: 44px;
      border-radius: 22px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: #fff;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.5;
      font-weight: 800;
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .nav-btn.primary {
      background: var(--dark-blue);
      color: #fff;
      box-shadow: 0 14px 28px rgba(28, 38, 99, 0.16);
    }

    .nav-btn:active {
      transform: scale(0.98);
    }

    .thumbs {
      display: grid;
      gap: 10px;
    }

    .thumb {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 10px;
      align-items: center;
      padding: 10px;
      border-radius: 16px;
      border: 1px solid rgba(28, 38, 99, 0.06);
      background: rgba(255, 255, 255, 0.72);
      cursor: pointer;
      transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
    }

    .thumb.active {
      border-color: rgba(64, 153, 255, 0.4);
      box-shadow: 0 14px 28px rgba(64, 153, 255, 0.14);
      transform: translateY(-2px);
    }

    .thumb-visual {
      height: 72px;
      border-radius: 16px;
      overflow: hidden;
      position: relative;
    }

    .thumb-visual.a {
      background: linear-gradient(180deg, #10207b, #091355);
    }

    .thumb-visual.b {
      background: linear-gradient(180deg, #f7fbff, #eef6ff);
    }

    .thumb-visual.c {
      background: linear-gradient(180deg, #ffffff, #eff4ff);
    }

    .thumb-visual::before,
    .thumb-visual::after {
      content: "";
      position: absolute;
      border-radius: 999px;
    }

    .thumb-visual.a::before {
      inset: 12px 12px auto;
      height: 10px;
      background: rgba(255, 255, 255, 0.7);
    }

    .thumb-visual.a::after {
      left: 12px;
      right: 12px;
      bottom: 14px;
      height: 22px;
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
    }

    .thumb-visual.b::before {
      top: 12px;
      left: 12px;
      width: 48px;
      height: 48px;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.2), transparent 60%);
    }

    .thumb-visual.b::after {
      left: 12px;
      right: 12px;
      bottom: 14px;
      height: 18px;
      background: linear-gradient(90deg, #f84ca2, #1ddcff);
    }

    .thumb-visual.c::before {
      inset: 12px auto 12px 12px;
      width: 18px;
      background: var(--pink);
    }

    .thumb-visual.c::after {
      top: 12px;
      right: 12px;
      bottom: 12px;
      width: 42px;
      background: linear-gradient(180deg, rgba(29, 220, 255, 0.42), rgba(29, 220, 255, 0.1));
    }

    .thumb strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .thumb span {
      display: block;
      margin-top: 2px;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .legend {
      display: grid;
      gap: 8px;
      margin-top: 6px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      font-size: 12px;
      line-height: 1.5;
    }

    .legend-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
    }

    .legend-swatch {
      width: 18px;
      height: 10px;
      border-radius: 999px;
    }

    .legend-swatch.cyan {
      background: var(--gradient-primary);
    }

    .legend-swatch.pink {
      background: var(--gradient-pink);
    }

    .legend-swatch.gray {
      background: linear-gradient(90deg, #e9eef7, #d9e3f2);
    }

    .micro-note {
      margin-top: 8px;
      font-size: 10px;
      line-height: 1.55;
      color: var(--text-gray);
    }

    .flash {
      animation: flashPulse 420ms ease;
    }

    @keyframes flashPulse {
      0% {
        transform: scale(0.98);
      }
      40% {
        transform: scale(1.02);
      }
      100% {
        transform: scale(1);
      }
    }

    .hidden {
      display: none;
    }

    @media (min-width: 960px) {
      .page {
        padding: 22px 22px 44px;
      }

      .layout {
        grid-template-columns: minmax(420px, 460px) minmax(320px, 1fr);
      }

      .topbar {
        margin-bottom: 18px;
      }

      .mission h1 {
        font-size: 26px;
      }
    }

    @media (max-width: 374px) {
      .title-xl {
        font-size: 30px;
      }

      .title-md {
        font-size: 25px;
      }

      .price-value,
      .forecast-value {
        font-size: 32px;
      }

      .phone-panel,
      .control-panel,
      .mission {
        border-radius: 22px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar">
      <section class="mission">
        <div class="mission-row">
          <div>
            <h1>UcarPAC ストアスクショ検証ラボ</h1>
            <p>目的: ストア詳細ページの閲覧からDLへのCVRを 17.3% から 25% へ引き上げる。スワイプで訴求順を比較できます。</p>
          </div>
          <div class="pill-set">
            <div class="pill kpi">PV→DL CVR 17.3%</div>
            <div class="pill">目標 25%</div>
            <div class="pill">2026-03-16 想定更新</div>
          </div>
        </div>
      </section>
    </div>

    <div class="layout">
      <section class="phone-panel">
        <div class="phone-wrap">
          <div class="phone-frame">
            <div class="phone-inner">
              <div class="slides" id="slides">
                <section class="screen screen-a" data-slide="0">
                  <div class="spark s1"></div>
                  <div class="spark s2"></div>
                  <div class="spark s3"></div>

                  <div class="status-top">
                    <strong>9:41</strong>
                    <span>Screenshot A / iOS</span>
                  </div>

                  <div class="badge-row">
                    <span class="badge light">iOS向け</span>
                    <span class="badge pink">個人情報なし</span>
                    <span class="badge light">AI査定を全面訴求</span>
                  </div>

                  <div class="hero-copy">
                    <p class="eyebrow">3問で、今の相場が動き出す</p>
                    <h2 class="title-xl">AIがあなたの愛車を<br>最高到達点まで査定</h2>
                    <p class="subcopy">トヨタ ハリアー Z Leather Package / 2021年式 / 31,800km の相場を15秒で診断。人気装備を選ぶたび、査定レンジが伸びます。</p>
                  </div>

                  <div class="glass-card" id="aiCard">
                    <div class="car-line">
                      <div class="car-meta">
                        <h3>トヨタ ハリアー Z Leather Package</h3>
                        <p>パールホワイト / 2WD / JBL / 31,800km</p>
                      </div>
                      <div class="score-ball">92</div>
                    </div>

                    <div class="price-stack">
                      <p class="price-label">現在のAI査定レンジ</p>
                      <p class="price-value" id="aiPrice">¥3,184,000</p>
                      <div class="range-row">
                        <span class="range-chip">下限 ¥3,040,000</span>
                        <span class="range-chip">上限 ¥3,360,000</span>
                      </div>
                    </div>

                    <div class="chip-grid" id="aiChips">
                      <button class="chip active" data-price="3184000">人気SUV</button>
                      <button class="chip" data-price="3268000">低走行</button>
                      <button class="chip" data-price="3312000">サンルーフ</button>
                      <button class="chip" data-price="3346000">JBL装備</button>
                    </div>
