        radial-gradient(circle at 0% 0%, rgba(248, 76, 162, 0.16), transparent 25%),
        radial-gradient(circle at 100% 5%, rgba(29, 220, 255, 0.18), transparent 25%),
        linear-gradient(180deg, #f9fbff 0%, #eff4ff 100%);
      overflow: hidden;
    }

    .status-row,
    .action-row,
    .cta-row,
    .metric-row,
    .list-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .status-row {
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
    }

    .status-row .signal {
      display: flex;
      gap: 5px;
      align-items: center;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--pink);
      box-shadow: 0 0 10px rgba(248, 76, 162, 0.8);
      animation: pulse 1.8s infinite;
    }

    .hero-panel {
      margin-top: 16px;
      padding: 18px;
      border-radius: 24px;
      color: var(--white);
      background:
        linear-gradient(130deg, rgba(9, 19, 85, 0.96), rgba(28, 38, 99, 0.9)),
        var(--gradient-primary);
      box-shadow: 0 18px 42px rgba(9, 19, 85, 0.18);
      overflow: hidden;
    }

    .hero-panel .mini {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
    }

    .hero-panel h2 {
      margin: 14px 0 8px;
      font-size: 30px;
      line-height: 1.35;
      letter-spacing: -0.03em;
    }

    .hero-panel p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.82);
    }

    .kpi-banner {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 18px;
    }

    .kpi-box {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .kpi-box .tag {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.74);
    }

    .kpi-box .num {
      margin-top: 8px;
      font-size: 22px;
      font-weight: 800;
      line-height: 1.2;
    }

    .kpi-box .delta {
      margin-top: 6px;
      font-size: 11px;
      color: #9ff1ff;
    }

    .panel {
      margin-top: 14px;
      padding: 16px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 10px 28px rgba(28, 38, 99, 0.08);
    }

    .panel-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .panel-title h3 {
      margin: 0;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(29, 220, 255, 0.14);
    }

    .badge.pink {
      color: var(--white);
      background: rgba(248, 76, 162, 0.92);
    }

    .number {
      font-weight: 800;
      color: var(--dark-blue);
      font-size: 32px;
      line-height: 1.2;
      letter-spacing: -0.03em;
    }

    .number small {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-gray);
      letter-spacing: 0;
    }

    .subtext {
      margin-top: 6px;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .bar-group {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .bar-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      font-size: 12px;
      color: var(--text-black);
    }

    .bar-track {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #dde7ff;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      background: var(--gradient-primary);
      transform-origin: left center;
      transform: scaleX(0.2);
      transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .screen-card.is-visible .bar-fill {
      transform: scaleX(var(--scale, 1));
    }

    .insight-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .insight {
      padding: 12px;
      border-radius: 16px;
      background: #f7f9ff;
      border: 1px solid #e2ebff;
    }

    .insight .value {
      font-size: 22px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .insight .caption {
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .chart-shell {
      margin-top: 14px;
      padding: 14px 12px 10px;
      border-radius: 20px;
      background: linear-gradient(180deg, #f3f7ff 0%, #ffffff 100%);
      border: 1px solid #e5eeff;
    }

    svg {
      display: block;
      width: 100%;
      height: auto;
    }

    .chart-note {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .action-row {
      margin-top: 14px;
    }

    .button-primary,
    .button-secondary {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 43px;
      border-radius: var(--radius-button);
      padding: 0 18px;
      border: 0;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    }

    .button-primary {
      color: var(--dark-blue);
      background: var(--gradient-primary);
      box-shadow: 0 14px 30px rgba(29, 220, 255, 0.25);
    }

    .button-secondary {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 14px 30px rgba(248, 76, 162, 0.25);
    }

    .button-primary:hover,
    .button-secondary:hover {
      transform: translateY(-1px);
    }

    .expense-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 14px;
      font-size: 12px;
    }

    .expense-table th,
    .expense-table td {
      padding: 10px 0;
      border-bottom: 1px solid var(--ruled-line);
      text-align: left;
    }

    .expense-table th:last-child,
    .expense-table td:last-child {
      text-align: right;
    }

    .expense-table th {
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .expense-table .emphasis {
      color: var(--dark-blue);
      font-weight: 800;
    }

    .compare {
      margin-top: 14px;
      padding: 14px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.04), rgba(248, 76, 162, 0.08));
      border: 1px solid rgba(248, 76, 162, 0.12);
    }

    .compare table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }

    .compare th,
    .compare td {
      padding: 10px 6px;
      border-bottom: 1px solid rgba(28, 38, 99, 0.08);
      text-align: center;
    }

    .compare th:first-child,
    .compare td:first-child {
      text-align: left;
      padding-left: 0;
    }

    .compare th {
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .yes {
      color: #0d8d5f;
      font-weight: 800;
    }

    .no {
      color: var(--error);
      font-weight: 800;
    }

    .callout {
      margin-top: 14px;
      padding: 16px;
      border-radius: 20px;
      color: var(--white);
      background: linear-gradient(135deg, #ff5aac, #f84ca2 56%, #ca2a73);
      box-shadow: 0 16px 34px rgba(248, 76, 162, 0.28);
    }

    .callout .tiny {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.82;
    }

    .callout .big {
      margin-top: 8px;
      font-size: 30px;
      line-height: 1.2;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .callout .small {
      margin-top: 6px;
      font-size: 12px;
      line-height: 1.7;
      opacity: 0.92;
    }

    .floating-note {
      position: absolute;
      right: 20px;
      bottom: 84px;
      max-width: 142px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.95);
      box-shadow: 0 18px 30px rgba(9, 19, 85, 0.12);
      font-size: 11px;
      line-height: 1.6;
      color: var(--dark-blue);
      transform: rotate(-4deg);
    }

    .footer-panel {
      display: grid;
      gap: 12px;
      margin-top: 28px;
      padding: 22px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: 0 18px 44px rgba(28, 38, 99, 0.08);
    }

    .footer-panel h4 {
      margin: 0;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .footer-panel p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .legend span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 12px;
      background: #f4f7ff;
      color: var(--dark-blue);
    }

    .swatch {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: currentColor;
    }

    .hidden {
      display: none;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 0.75;
      }
      50% {
        transform: scale(1.35);
        opacity: 1;
      }
    }

    @media (min-width: 840px) {
      .hero-grid {
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
        align-items: end;
      }

      .screens {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 839px) {
      .hero-stats {
        grid-template-columns: 1fr;
      }

      .kpi-banner {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 420px) {
      body {
        padding: 14px 10px 36px;
      }

      .hero,
      .screen-card,
      .footer-panel {
        border-radius: 22px;
      }

      .phone {
        padding: 12px;
      }

      .screen-ui {
        min-height: 654px;
        padding-left: 12px;
        padding-right: 12px;
      }

      .hero-panel h2 {
        font-size: 26px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div class="hero-grid">
        <div>
          <div class="eyebrow">ASO / ストアPV→DL率改善</div>
          <h1>数字で伝えると、DL理由が一瞬で理解される。</h1>
          <p>
            現状CVR 17.3%から目標25%へ。競合にない「AI査定」「将来予測」「出費管理」「電話0本級の安心感」を、
            ストアスクショ3枚で比較可能な数値体験として再構成したプロトタイプです。
          </p>
        </div>
        <div class="hero-stats">
          <article class="stat-card">
            <div class="label">Current Store CVR</div>
            <div class="value">17.3%</div>
            <div class="sub">ストア詳細ページ閲覧からDLまで</div>
          </article>
          <article class="stat-card">
            <div class="label">Target CVR</div>
            <div class="value">25.0%</div>
            <div class="sub">必要改善幅: +7.7pt</div>
          </article>
          <article class="stat-card">
            <div class="label">Message Focus</div>
            <div class="value">3 Screens</div>
            <div class="sub">AI査定 / 資産管理 / 比較訴求</div>
          </article>
        </div>
      </div>
    </section>

    <section class="toolbar">
      <div class="filters" aria-label="表示切替">
        <button class="chip is-active" type="button" data-filter="all">全表示</button>
        <button class="chip" type="button" data-filter="ios">iOS向け</button>
        <button class="chip" type="button" data-filter="android">Android向け</button>
        <button class="chip" type="button" data-filter="compare">比較訴求</button>
      </div>
      <div class="view-switch">
        <button class="chip is-active" type="button" id="animateButton">アニメーションON</button>
        <button class="chip" type="button" id="insightButton">強調ポイント切替</button>
      </div>
    </section>

    <section class="screens">
      <article class="screen-card is-visible" data-kind="ios">
        <header class="screen-header">
          <div>
            <h2 class="screen-title">A. iOS向け AI査定全面訴求</h2>
            <p class="screen-copy">車両価値の現在地と3か月先予測をひと目で。高精度感を数字とグラフで出す構成。</p>
          </div>
          <div class="platform">iOS App Store</div>
        </header>
        <div class="phone">
          <div class="screen-ui">
            <div class="status-row">
              <span>9:41</span>
              <div class="signal">
                <span class="status-dot"></span>
                <span>5G</span>
                <span>100%</span>
              </div>
            </div>

            <section class="hero-panel">
              <div class="mini">個人情報なしで AI査定</div>
              <h2>あなたの愛車、<br>いま売ると 286万円</h2>
              <p>トヨタ ハリアー Z 2021年 / 28,400km / パール。登録60秒、相場レンジではなく現在の推定中心価格を提示。</p>
              <div class="kpi-banner">
                <div class="kpi-box">
                  <div class="tag">現在推定</div>
                  <div class="num">286万円</div>
                  <div class="delta">前月比 +4.2万円</div>
                </div>
                <div class="kpi-box">
                  <div class="tag">3か月予測</div>
                  <div class="num">279万円</div>
                  <div class="delta">売り時指数 82/100</div>
                </div>
                <div class="kpi-box">
                  <div class="tag">査定精度</div>
                  <div class="num">95%</div>
                  <div class="delta">装備・色・写真を反映</div>
                </div>
              </div>
            </section>

            <section class="panel">
              <div class="panel-title">
                <h3>価格トレンド</h3>
                <span class="badge">AI予測更新 3時間前</span>
              </div>
              <div class="chart-shell">
                <svg viewBox="0 0 320 168" aria-label="価格推移チャート">
                  <defs>
                    <linearGradient id="lineA" x1="0" x2="1">
                      <stop offset="0%" stop-color="#1ddcff"></stop>
                      <stop offset="100%" stop-color="#f84ca2"></stop>
                    </linearGradient>
                    <linearGradient id="areaA" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="rgba(29,220,255,0.32)"></stop>
                      <stop offset="100%" stop-color="rgba(29,220,255,0.02)"></stop>
                    </linearGradient>
                  </defs>
                  <g opacity="0.18" stroke="#1c2663" stroke-width="1">
                    <line x1="18" y1="24" x2="302" y2="24"></line>
                    <line x1="18" y1="62" x2="302" y2="62"></line>
                    <line x1="18" y1="100" x2="302" y2="100"></line>
                    <line x1="18" y1="138" x2="302" y2="138"></line>
                  </g>
                  <path d="M18 118 C45 112, 62 95, 89 90 S137 72, 160 78 S207 86, 232 73 S278 66, 302 58 L302 146 L18 146 Z" fill="url(#areaA)"></path>
                  <path d="M18 118 C45 112, 62 95, 89 90 S137 72, 160 78 S207 86, 232 73 S278 66, 302 58" fill="none" stroke="url(#lineA)" stroke-width="5" stroke-linecap="round"></path>
                  <circle cx="232" cy="73" r="6" fill="#ffffff" stroke="#f84ca2" stroke-width="4"></circle>
                  <circle cx="302" cy="58" r="7" fill="#ffffff" stroke="#1ddcff" stroke-width="4"></circle>
                  <text x="214" y="54" fill="#f84ca2" font-size="11" font-weight="700">現在 286万</text>
                  <text x="248" y="38" fill="#1c2663" font-size="11" font-weight="700">6月予測 279万</text>
                  <g fill="#737373" font-size="10" font-weight="700">
                    <text x="18" y="160">12月</text>
                    <text x="86" y="160">1月</text>
                    <text x="154" y="160">2月</text>
                    <text x="222" y="160">3月</text>
                    <text x="282" y="160">6月</text>
                  </g>
                </svg>
                <div class="chart-note">
                  <span>高値圏を維持。春の需要期で売却相談が増加。</span>
                  <span>相場変動幅: 7万円</span>
                </div>
              </div>

              <div class="bar-group">
                <div>
                  <div class="bar-label"><span>今売るメリット</span><strong>82%</strong></div>
                  <div class="bar-track"><div class="bar-fill" style="--scale:0.82;"></div></div>
                </div>
                <div>
                  <div class="bar-label"><span>相場安定性</span><strong>76%</strong></div>
                  <div class="bar-track"><div class="bar-fill" style="--scale:0.76;"></div></div>
                </div>
                <div>
                  <div class="bar-label"><span>登録完了のしやすさ</span><strong>94%</strong></div>
                  <div class="bar-track"><div class="bar-fill" style="--scale:0.94;"></div></div>
                </div>
              </div>
            </section>

            <section class="panel">
              <div class="panel-title">
                <h3>DL判断につながる根拠</h3>
                <span class="badge pink">電話連絡なしで相場確認</span>
              </div>
              <div class="insight-grid">
                <div class="insight">
                  <div class="value">60秒</div>
                  <div class="caption">メーカー・年式・走行距離だけで概算確認。入力障壁を極小化。</div>
                </div>
                <div class="insight">
                  <div class="value">8,000社</div>
                  <div class="caption">売却時はオークションで競争原理。高値期待までつながる。</div>
                </div>
              </div>
              <div class="action-row">
                <button class="button-primary" type="button" data-copy-target="a">AI査定の訴求を強調</button>
                <button class="button-secondary" type="button" data-copy-target="a2">個人情報不要を強調</button>
              </div>
            </section>
          </div>
        </div>
      </article>

      <article class="screen-card is-visible" data-kind="android">
        <header class="screen-header">
          <div>
            <h2 class="screen-title">B. Android向け 出費管理 + 将来予測</h2>
            <p class="screen-copy">資産管理アプリ的な理解しやすさで「入れておく理由」を明確にする構成。</p>
          </div>
          <div class="platform">Google Play</div>
        </header>
        <div class="phone">
          <div class="screen-ui">
            <div class="status-row">
              <span>9:41</span>
              <div class="signal">
                <span class="status-dot"></span>
                <span>Wi-Fi</span>
                <span>97%</span>
              </div>
            </div>

            <section class="hero-panel" style="background: linear-gradient(135deg, rgba(9,19,85,0.96), rgba(16,72,132,0.9));">
              <div class="mini">出費管理で維持費も可視化</div>
              <h2>クルマの価値と<br>維持費を同時に追える</h2>
              <p>ホンダ N-BOX Custom 2020年 / 41,200km。売却価格とガソリン・保険・車検を一つのダッシュボードで確認。</p>
              <div class="kpi-banner">
                <div class="kpi-box">
                  <div class="tag">現在価値</div>
                  <div class="num">118万円</div>
                  <div class="delta">年初比 -6万円</div>
                </div>
                <div class="kpi-box">
                  <div class="tag">年間維持費</div>
                  <div class="num">24.6万円</div>
                  <div class="delta">月平均 2.05万円</div>
                </div>
                <div class="kpi-box">
                  <div class="tag">半年後予測</div>
                  <div class="num">112万円</div>
                  <div class="delta">買替検討ライン接近</div>
                </div>
              </div>
            </section>

            <section class="panel">
              <div class="panel-title">
                <h3>価値推移と出費の重なり</h3>
                <span class="badge">通知で売り時を提案</span>
              </div>
              <div class="chart-shell">
                <svg viewBox="0 0 320 174" aria-label="価値と維持費の複合チャート">
                  <g opacity="0.16" stroke="#1c2663" stroke-width="1">
                    <line x1="20" y1="30" x2="300" y2="30"></line>
                    <line x1="20" y1="70" x2="300" y2="70"></line>
                    <line x1="20" y1="110" x2="300" y2="110"></line>
                    <line x1="20" y1="150" x2="300" y2="150"></line>
