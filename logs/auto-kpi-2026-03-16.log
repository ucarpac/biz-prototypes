<!-- A案: 感情に訴えるアプローチ。ユーザーの不安や期待に寄り添い、安心感を与えるデザイン。暖色系のアクセント、手書き風要素、親しみやすいイラスト的表現 -->
<!DOCTYPE html>
<html lang="ja">
<script src="../auth.js"></script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>UcarPAC Store Screenshot Prototype</title>
  <style>
    :root {
      --pink: #F84CA2;
      --dark-blue: #1c2663;
      --white: #FFFFFF;
      --text-black: #404040;
      --text-gray: #737373;
      --text-disabled: #B3B3B3;
      --text-placeholder: rgba(28,38,99,0.3);
      --text-under-blue: #0056BA;
      --button-gray: #CACEE2;
      --button-link1: #4099FF;
      --button-link2: #40BFFF;
      --back-white: #FAFAFA;
      --light-gray: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-gray2: #e6e6e6;
      --back-blue: #091355;
      --back-dark-blue: #0a1348;
      --back-light-pink: #ffd8e8;
      --back-light-blue: #6fc2ff;
      --error: #EB4646;
      --shadow: rgba(0,0,0,0.11);
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --warm-cream: #fff6ef;
      --warm-peach: #ffe3d2;
      --warm-orange: #ffb37d;
      --warm-yellow: #ffe7a6;
      --ink: #6b4a3b;
      --font-sans: "Noto Sans JP", "Hiragino Sans", system-ui, sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-7: 27px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-card: 13px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
      --radius-button-lg: 43px;
      color-scheme: light;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: var(--font-sans);
      background:
        radial-gradient(circle at 15% 20%, rgba(248, 76, 162, 0.15), transparent 20%),
        radial-gradient(circle at 80% 10%, rgba(255, 179, 125, 0.2), transparent 18%),
        radial-gradient(circle at 85% 80%, rgba(29, 220, 255, 0.18), transparent 22%),
        linear-gradient(180deg, #fffaf7 0%, #fff1f7 38%, #f7fbff 100%);
      color: var(--text-black);
    }

    body {
      overflow-x: hidden;
    }

    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 16px 40px;
      position: relative;
    }

    .page::before,
    .page::after {
      content: "";
      position: fixed;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      pointer-events: none;
      filter: blur(28px);
      opacity: 0.45;
      z-index: 0;
    }

    .page::before {
      top: -60px;
      left: -40px;
      background: rgba(255, 179, 125, 0.35);
    }

    .page::after {
      right: -50px;
      bottom: -50px;
      background: rgba(248, 76, 162, 0.24);
    }

    .layout {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 24px;
      align-items: start;
    }

    .intro {
      display: grid;
      gap: 14px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      padding: 8px 14px;
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(248, 76, 162, 0.2);
      border-radius: 999px;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 12px 30px rgba(28, 38, 99, 0.08);
      backdrop-filter: blur(10px);
    }

    .eyebrow .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--pink);
      box-shadow: 0 0 0 5px rgba(248, 76, 162, 0.14);
    }

    .intro h1 {
      margin: 0;
      font-size: clamp(28px, 6vw, 44px);
      line-height: 1.25;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .intro p {
      margin: 0;
      font-size: 14px;
      line-height: 1.8;
      color: var(--text-gray);
      max-width: 760px;
    }

    .controls {
      display: grid;
      gap: 12px;
    }

    .tab-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      background: rgba(255,255,255,0.76);
      padding: 8px;
      border-radius: 20px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 16px 40px rgba(28, 38, 99, 0.08);
      backdrop-filter: blur(12px);
    }

    .tab {
      border: 0;
      border-radius: 18px;
      padding: 12px 10px;
      background: transparent;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 700;
      line-height: 1.4;
      cursor: pointer;
      transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
    }

    .tab.is-active {
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.18), rgba(255, 179, 125, 0.22));
      color: var(--dark-blue);
      box-shadow: inset 0 0 0 1px rgba(248, 76, 162, 0.22), 0 10px 20px rgba(248, 76, 162, 0.12);
      transform: translateY(-1px);
    }

    .sub-controls {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .ghost-btn,
    .pill {
      border: 0;
      cursor: pointer;
      border-radius: 999px;
      font-family: inherit;
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }

    .ghost-btn {
      padding: 11px 14px;
      background: rgba(255,255,255,0.82);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 12px 26px rgba(28, 38, 99, 0.08);
    }

    .ghost-btn.is-on {
      background: rgba(248, 76, 162, 0.14);
      box-shadow: inset 0 0 0 1px rgba(248, 76, 162, 0.24);
    }

    .meta-note {
      font-size: 12px;
      color: var(--text-gray);
    }

    .stage {
      display: grid;
      gap: 20px;
      align-items: start;
    }

    .phone-zone {
      position: relative;
      display: flex;
      justify-content: center;
      padding: 8px 0 0;
    }

    .phone-shell {
      width: min(100%, 390px);
      aspect-ratio: 390 / 844;
      background: linear-gradient(180deg, #252525, #0f0f0f);
      border-radius: 42px;
      padding: 14px;
      position: relative;
      box-shadow: 0 28px 80px rgba(28, 38, 99, 0.24);
    }

    .phone-shell::before {
      content: "";
      position: absolute;
      inset: 8px;
      border-radius: 34px;
      border: 1px solid rgba(255,255,255,0.08);
      pointer-events: none;
    }

    .notch {
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 132px;
      height: 28px;
      background: #0d0d0d;
      border-radius: 0 0 18px 18px;
      z-index: 3;
    }

    .screen {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
      border-radius: 30px;
      background: linear-gradient(180deg, #fff9f5 0%, #fff7fb 35%, #f5fbff 100%);
    }

    .slide {
      position: absolute;
      inset: 0;
      padding: 56px 18px 22px;
      opacity: 0;
      pointer-events: none;
      transform: translateX(24px) scale(0.985);
      transition: opacity 0.45s ease, transform 0.45s ease;
      overflow: hidden;
    }

    .slide.is-active {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0) scale(1);
    }

    .screen::before,
    .screen::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      filter: blur(12px);
      opacity: 0.55;
      pointer-events: none;
    }

    .screen::before {
      width: 130px;
      height: 130px;
      top: 80px;
      left: -24px;
      background: rgba(255, 179, 125, 0.22);
    }

    .screen::after {
      width: 160px;
      height: 160px;
      bottom: 80px;
      right: -44px;
      background: rgba(248, 76, 162, 0.18);
    }

    .scribble,
    .bubble-tag,
    .platform-tag,
    .warm-card,
    .feature-chip,
    .metric-card,
    .comparison-card {
      box-shadow: 0 16px 30px rgba(28, 38, 99, 0.08);
    }

    .platform-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(28, 38, 99, 0.06);
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      backdrop-filter: blur(8px);
    }

    .platform-tag .badge {
      padding: 3px 8px;
      border-radius: 999px;
      background: rgba(248, 76, 162, 0.14);
      color: var(--pink);
    }

    .slide h2 {
      margin: 14px 0 8px;
      font-size: 32px;
      line-height: 1.3;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
    }

    .slide p.lead {
      margin: 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.75;
    }

    .scribble {
      position: absolute;
      font-size: 12px;
      color: var(--ink);
      background: var(--warm-yellow);
      border-radius: 18px;
      padding: 10px 12px;
      transform: rotate(-7deg);
      border: 2px solid rgba(107, 74, 59, 0.08);
      font-weight: 700;
      z-index: 2;
      animation: bob 4.2s ease-in-out infinite;
    }

    .scribble::after {
      content: "";
      position: absolute;
      inset: 5px;
      border: 1px dashed rgba(107, 74, 59, 0.18);
      border-radius: 14px;
      pointer-events: none;
    }

    .scribble.one {
      top: 110px;
      right: 16px;
    }

    .scribble.two {
      bottom: 184px;
      left: 18px;
      transform: rotate(6deg);
      background: var(--warm-peach);
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0) rotate(-7deg); }
      50% { transform: translateY(-5px) rotate(-5deg); }
    }

    .hero-illustration {
      position: relative;
      height: 150px;
      margin-top: 18px;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      filter: drop-shadow(0 18px 24px rgba(28, 38, 99, 0.08));
    }

    .blob.left {
      width: 140px;
      height: 112px;
      left: 4px;
      top: 18px;
      background: linear-gradient(180deg, rgba(255, 179, 125, 0.45), rgba(255, 255, 255, 0.4));
    }

    .blob.right {
      width: 126px;
      height: 126px;
      right: 10px;
      top: 0;
      background: linear-gradient(180deg, rgba(248, 76, 162, 0.22), rgba(109, 194, 255, 0.16));
    }

    .car {
      position: absolute;
      left: 28px;
      bottom: 12px;
      width: 180px;
      height: 84px;
      animation: floatCar 3.8s ease-in-out infinite;
    }

    .car-body {
      position: absolute;
      left: 10px;
      bottom: 18px;
      width: 150px;
      height: 42px;
      background: linear-gradient(135deg, #ff8ebf, #f84ca2);
      border-radius: 30px 26px 18px 16px;
    }

    .car-top {
      position: absolute;
      left: 40px;
      bottom: 48px;
      width: 72px;
      height: 30px;
      background: linear-gradient(135deg, #ffe0ee, #ffd0e6);
      border-radius: 20px 24px 8px 8px;
      border: 2px solid rgba(255,255,255,0.5);
    }

    .car-wheel {
      position: absolute;
      bottom: 8px;
      width: 28px;
      height: 28px;
      background: var(--dark-blue);
      border-radius: 50%;
      box-shadow: inset 0 0 0 6px #f4f7fb;
    }

    .car-wheel.one {
      left: 28px;
    }

    .car-wheel.two {
      right: 20px;
    }

    .smile {
      position: absolute;
      right: 24px;
      bottom: 30px;
      width: 54px;
      height: 54px;
      border-radius: 50%;
      background: rgba(255,255,255,0.82);
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      font-size: 26px;
      font-weight: 700;
      box-shadow: 0 16px 28px rgba(28, 38, 99, 0.1);
    }

    @keyframes floatCar {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    .warm-card {
      background: rgba(255,255,255,0.9);
      border-radius: var(--radius-card);
      padding: 16px;
      border: 1px solid rgba(28, 38, 99, 0.05);
      backdrop-filter: blur(10px);
    }

    .headline-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .bubble-tag {
      padding: 9px 12px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.12), rgba(255, 179, 125, 0.16));
      color: var(--pink);
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .vehicle {
      color: var(--text-gray);
      font-size: 12px;
      margin-top: 4px;
    }

    .big-number {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      margin-top: 14px;
      color: var(--dark-blue);
    }

    .big-number .label {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
      display: block;
      margin-bottom: 6px;
    }

    .big-number strong {
      font-size: 42px;
      line-height: 1;
      letter-spacing: -0.04em;
      font-weight: 800;
    }

    .big-number .unit {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 5px;
    }

    .chip-row {
      display: flex;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .mini-chip,
    .filter-chip,
    .phase-chip {
      border: 0;
      cursor: pointer;
      padding: 10px 14px;
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 700;
      background: var(--white);
      color: var(--text-black);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.08);
      transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    }

    .mini-chip.is-active,
    .filter-chip.is-active,
    .phase-chip.is-active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-1px);
      box-shadow: 0 12px 24px rgba(28, 38, 99, 0.18);
    }

    .forecast-box {
      margin-top: 14px;
      background: linear-gradient(180deg, rgba(237, 241, 244, 0.7), rgba(255,255,255,0.82));
      border-radius: var(--radius-md);
      padding: 12px;
    }

    .forecast-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .forecast-item {
      background: rgba(255,255,255,0.8);
      border-radius: 12px;
      padding: 10px 8px;
      text-align: center;
    }

    .forecast-item .k {
      display: block;
      font-size: 10px;
      color: var(--text-gray);
      margin-bottom: 4px;
    }

    .forecast-item .v {
      font-size: 14px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .line-chart {
      width: 100%;
      height: 86px;
      margin-top: 4px;
    }

    .line-chart path.line {
      fill: none;
      stroke: url(#lineGradient);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: dash 1.2s ease forwards 0.2s;
    }

    .line-chart path.area {
      fill: rgba(248, 76, 162, 0.08);
    }

    .line-chart circle {
      fill: var(--pink);
      stroke: white;
      stroke-width: 4;
      filter: drop-shadow(0 8px 10px rgba(248, 76, 162, 0.18));
    }

    @keyframes dash {
      to { stroke-dashoffset: 0; }
    }

    .safe-strip {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .feature-chip {
      display: grid;
      gap: 4px;
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(28, 38, 99, 0.05);
    }

    .feature-chip strong {
      color: var(--dark-blue);
      font-size: 13px;
    }

    .feature-chip span {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
    }

    .cta {
      margin-top: 16px;
      width: 100%;
      min-height: 48px;
      border: 0;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 16px 30px rgba(77, 180, 255, 0.26);
      transition: transform 0.25s ease, filter 0.25s ease;
    }

    .cta.alt {
      background: linear-gradient(90deg, #ffb37d, #f84ca2);
      color: var(--white);
      box-shadow: 0 16px 30px rgba(248, 76, 162, 0.22);
    }

    .cta:active,
    .tab:active,
    .mini-chip:active,
    .filter-chip:active,
    .phase-chip:active,
    .ghost-btn:active,
    .pill:active {
      transform: scale(0.98);
    }

    .micro-note {
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
      text-align: center;
    }

    .expense-header {
      margin-top: 18px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: end;
    }

    .expense-total strong {
      display: block;
      font-size: 34px;
      line-height: 1;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .expense-total span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .delta-pill {
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(255, 179, 125, 0.18);
      color: #aa5c2c;
      font-size: 11px;
      font-weight: 700;
    }

    .expense-graph {
      margin-top: 14px;
      background: rgba(255,255,255,0.72);
      border-radius: 16px;
      padding: 14px 12px 10px;
    }

    .bar-row {
      height: 120px;
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 8px;
    }

    .bar {
      flex: 1;
      border-radius: 12px 12px 6px 6px;
      background: linear-gradient(180deg, rgba(255, 179, 125, 0.4), rgba(248, 76, 162, 0.7));
      min-height: 20px;
      position: relative;
      transition: height 0.4s ease;
    }

    .bar.future {
      background: linear-gradient(180deg, rgba(29, 220, 255, 0.45), rgba(77, 180, 255, 0.9));
    }

    .bar::before {
      content: attr(data-value);
      position: absolute;
      top: -22px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 10px;
      color: var(--text-gray);
      white-space: nowrap;
    }

    .bar-labels {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      margin-top: 8px;
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .expense-list {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(28, 38, 99, 0.04);
    }

    .icon-badge {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      font-size: 18px;
      background: linear-gradient(180deg, rgba(255, 179, 125, 0.3), rgba(248, 76, 162, 0.18));
    }

    .expense-item strong {
      color: var(--dark-blue);
      font-size: 13px;
      display: block;
      margin-bottom: 2px;
    }

    .expense-item span {
      color: var(--text-gray);
      font-size: 11px;
    }

    .expense-item b {
      color: var(--dark-blue);
      font-size: 14px;
    }

    .compare-switch {
      display: flex;
      gap: 8px;
      margin-top: 18px;
    }

    .comparison-wrap {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .comparison-card {
      background: rgba(255,255,255,0.9);
      border-radius: 18px;
      padding: 14px;
      border: 1px solid rgba(28, 38, 99, 0.05);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
    }

    .comparison-card.highlight {
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.08), rgba(255, 179, 125, 0.12), rgba(255,255,255,0.95));
      border-color: rgba(248, 76, 162, 0.18);
    }

    .comparison-card strong {
      display: block;
      font-size: 14px;
      color: var(--dark-blue);
      margin-bottom: 3px;
    }

    .comparison-card span {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .phone-count {
      font-size: 28px;
      line-height: 1;
      font-weight: 800;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .phone-count.zero {
      color: var(--pink);
    }

    .stat-grid {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .metric-card {
      padding: 12px 10px;
      border-radius: 14px;
      background: rgba(255,255,255,0.9);
      text-align: center;
      border: 1px solid rgba(28, 38, 99, 0.04);
    }

    .metric-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      margin-bottom: 4px;
    }

    .metric-card span {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
    }

    .callout {
      margin-top: 16px;
      padding: 14px;
      background: rgba(255, 231, 166, 0.58);
      border-radius: 18px;
      color: var(--ink);
      font-size: 12px;
      line-height: 1.8;
      font-weight: 700;
      position: relative;
    }

    .callout::before {
      content: "!";
      position: absolute;
      top: -10px;
      right: 16px;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--pink);
      color: white;
      box-shadow: 0 10px 20px rgba(248, 76, 162, 0.18);
    }

    .side-panel {
      display: grid;
      gap: 12px;
    }

    .side-card {
      padding: 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 16px 34px rgba(28, 38, 99, 0.08);
      backdrop-filter: blur(10px);
    }

    .side-card h3 {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 16px;
    }

    .side-card p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.8;
    }

    .thumb-list {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .thumb {
      width: 100%;
      border: 0;
      cursor: pointer;
      padding: 12px;
      text-align: left;
      border-radius: 14px;
      background: rgba(255,255,255,0.9);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.06);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .thumb.is-active {
      box-shadow: inset 0 0 0 1px rgba(248, 76, 162, 0.24), 0 14px 26px rgba(248, 76, 162, 0.12);
      transform: translateY(-1px);
    }

    .thumb strong {
      display: block;
      margin-bottom: 4px;
      color: var(--dark-blue);
      font-size: 13px;
    }

    .thumb span {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .footer-line {
      margin-top: 8px;
      font-size: 11px;
      color: var(--text-gray);
      text-align: center;
    }

    .sparkle {
      position: absolute;
      width: 12px;
      height: 12px;
      border-radius: 4px;
      background: linear-gradient(135deg, rgba(255, 179, 125, 0.9), rgba(248, 76, 162, 0.7));
      transform: rotate(45deg);
      animation: twinkle 2.8s ease-in-out infinite;
    }

    .sparkle.a { top: 136px; left: 164px; }
    .sparkle.b { top: 208px; right: 32px; animation-delay: 0.8s; }
    .sparkle.c { bottom: 178px; right: 70px; animation-delay: 1.4s; }

    @keyframes twinkle {
      0%, 100% { opacity: 0.3; transform: rotate(45deg) scale(0.8); }
      50% { opacity: 1; transform: rotate(45deg) scale(1.08); }
    }

    @media (min-width: 900px) {
      .stage {
        grid-template-columns: minmax(360px, 420px) minmax(280px, 1fr);
        gap: 28px;
      }

      .page {
        padding: 32px 24px 60px;
      }

      .controls {
        grid-template-columns: 1fr auto;
        align-items: center;
      }

      .sub-controls {
        justify-content: flex-end;
      }
    }

    @media (max-width: 374px) {
      .slide {
        padding-left: 14px;
        padding-right: 14px;
      }

      .slide h2 {
        font-size: 28px;
      }

      .big-number strong {
        font-size: 36px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="layout">
      <section class="intro">
        <div class="eyebrow"><span class="dot"></span>ストアPV→DL率改善向けスクリーンショット試作</div>
        <h1>不安をほどいて、<br>「入れてみよう」に変える3枚。</h1>
        <p>
          A案の感情訴求を前面に出し、最初の一歩で感じる「営業電話が怖い」「まだ売るかわからない」
          「維持費も気になる」に寄り添う構成です。375px基準で、App Store / Google Play の訴求差も見分けやすくしています。
        </p>
      </section>

      <section class="controls">
        <div class="tab-row" aria-label="スクリーンショット切り替え">
          <button class="tab is-active" data-slide="0">A AI査定</button>
          <button class="tab" data-slide="1">B 出費管理</button>
          <button class="tab" data-slide="2">C 電話0本比較</button>
        </div>
        <div class="sub-controls">
          <button class="ghost-btn is-on" id="autoplayToggle" type="button">自動再生 ON</button>
          <span class="meta-note">ボタン操作で各スクショ内の状態も切り替えできます</span>
        </div>
      </section>

      <section class="stage">
        <div class="phone-zone">
          <div class="phone-shell">
            <div class="notch"></div>
            <div class="screen">
              <div class="sparkle a"></div>
              <div class="sparkle b"></div>
              <div class="sparkle c"></div>

              <section class="slide is-active" data-index="0" aria-label="スクリーンショットA">
                <div class="platform-tag"><span class="badge">iOS向け</span> AI査定を全面訴求</div>
                <div class="scribble one">連絡先なしで<br>まず相場だけ</div>
                <div class="scribble two">いま売らなくても<br>大丈夫</div>

                <h2>まだ売らなくても、<br>いまの価値がわかる。</h2>
                <p class="lead">愛車の価値を先に知れると、売るか迷っている時期でも動きやすい。安心して始められる第一印象に寄せています。</p>

                <div class="hero-illustration" aria-hidden="true">
                  <div class="blob left"></div>
                  <div class="blob right"></div>
                  <div class="car">
                    <div class="car-top"></div>
                    <div class="car-body"></div>
                    <div class="car-wheel one"></div>
                    <div class="car-wheel two"></div>
                  </div>
                  <div class="smile">☺</div>
                </div>

                <div class="warm-card">
                  <div class="headline-row">
                    <div>
                      <strong style="display:block;color:var(--dark-blue);font-size:15px;">AI査定の目安</strong>
                      <div class="vehicle">トヨタ プリウス S / 2019年 / 48,200km</div>
                    </div>
                    <div class="bubble-tag">個人情報なしでOK</div>
                  </div>

                  <div class="big-number">
                    <div>
                      <span class="label" id="estimateLabel">いま売るなら</span>
                      <strong id="estimateValue">184.2</strong>
                    </div>
                    <span class="unit">万円</span>
                  </div>

                  <div class="chip-row">
                    <button class="mini-chip is-active" type="button" data-scenario="now">いま</button>
                    <button class="mini-chip" type="button" data-scenario="3m">3か月後</button>
                    <button class="mini-chip" type="button" data-scenario="6m">6か月後</button>
                  </div>

                  <div class="forecast-box">
                    <svg class="line-chart" viewBox="0 0 320 86" preserveAspectRatio="none" aria-label="価格推移予測">
                      <defs>
                        <linearGradient id="lineGradient" x1="0" x2="1">
                          <stop offset="0%" stop-color="#ffb37d"></stop>
                          <stop offset="100%" stop-color="#f84ca2"></stop>
                        </linearGradient>
                      </defs>
                      <path class="area" d="M20,55 C65,44 105,34 150,38 C190,42 228,50 300,22 L300,86 L20,86 Z"></path>
                      <path class="line" id="forecastPath" d="M20,55 C65,44 105,34 150,38 C190,42 228,50 300,22"></path>
                      <circle id="dotNow" cx="20" cy="55" r="6"></circle>
                      <circle id="dot3m" cx="150" cy="38" r="6"></circle>
                      <circle id="dot6m" cx="300" cy="22" r="6"></circle>
                    </svg>
                    <div class="forecast-grid">
                      <div class="forecast-item">
                        <span class="k">いま</span>
                        <span class="v" id="miniNow">184.2万円</span>
                      </div>
                      <div class="forecast-item">
                        <span class="k">3か月後</span>
                        <span class="v" id="mini3m">181.5万円</span>
                      </div>
                      <div class="forecast-item">
                        <span class="k">6か月後</span>
                        <span class="v" id="mini6m">176.8万円</span>
                      </div>
                    </div>
                  </div>

                  <div class="safe-strip">
                    <div class="feature-chip">
                      <strong>1分でチェック</strong>
                      <span>メーカー・年式・走行距離だけで概算スタート</span>
                    </div>
                    <div class="feature-chip">
                      <strong>売る時期まで見守る</strong>
                      <span>将来予測で「待つ」判断もできる</span>
                    </div>
                  </div>

                  <button class="cta" type="button">1分で愛車をチェック</button>
                  <div class="micro-note">査定だけなら営業電話の心配はありません</div>
                </div>
              </section>

              <section class="slide" data-index="1" aria-label="スクリーンショットB">
                <div class="platform-tag"><span class="badge">Android向け</span> 出費管理 + 将来予測</div>

                <h2>出費も、売りどきも。<br>まとめて見えると安心。</h2>
                <p class="lead">ガソリン代や保険料に向き合う不安を、見える化と予測でやわらげる構成です。資産管理アプリの安心感を車体験に置き換えています。</p>

                <div class="expense-header">
                  <div class="expense-total">
                    <span>今月の維持費</span>
                    <strong id="expenseTotal">43,600円</strong>
                  </div>
                  <div class="delta-pill" id="forecastDelta">6か月後予測 -7.4万円</div>
                </div>

                <div class="chip-row">
                  <button class="filter-chip is-active" type="button" data-expense="monthly">月別</button>
                  <button class="filter-chip" type="button" data-expense="fuel">ガソリン中心</button>
                  <button class="filter-chip" type="button" data-expense="care">保険・整備中心</button>
                </div>

                <div class="expense-graph">
                  <div class="bar-row">
                    <div class="bar" id="bar1" data-value="3.8万" style="height:52%;"></div>
                    <div class="bar" id="bar2" data-value="4.3万" style="height:64%;"></div>
                    <div class="bar" id="bar3" data-value="4.1万" style="height:58%;"></div>
                    <div class="bar future" id="bar4" data-value="183万" style="height:76%;"></div>
                    <div class="bar future" id="bar5" data-value="176万" style="height:62%;"></div>
                  </div>
                  <div class="bar-labels">
                    <span>1月</span>
                    <span>2月</span>
                    <span>3月</span>
                    <span>3か月後</span>
                    <span>6か月後</span>
                  </div>
                </div>

                <div class="expense-list" id="expenseList">
                  <div class="expense-item">
                    <div class="icon-badge">⛽</div>
                    <div>
                      <strong>ガソリン</strong>
                      <span>レギュラー 48L / 3月12日</span>
                    </div>
                    <b>12,800円</b>
                  </div>
                  <div class="expense-item">
                    <div class="icon-badge">🛡</div>
                    <div>
                      <strong>任意保険</strong>
                      <span>月割り換算 / 東京海上</span>
                    </div>
                    <b>18,400円</b>
                  </div>
                  <div class="expense-item">
                    <div class="icon-badge">🔧</div>
                    <div>
                      <strong>定期メンテ</strong>
                      <span>オイル交換 / 次回4月</span>
                    </div>
                    <b>12,400円</b>
                  </div>
                </div>

                <div class="safe-strip">
                  <div class="feature-chip">
                    <strong>維持費も見える</strong>
                    <span>「いくらかかる？」を月単位で整理</span>
                  </div>
                  <div class="feature-chip">
