  <script>
    const tabs = document.querySelectorAll('.tab');
    const shots = document.querySelectorAll('.shot');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.target;
        tabs.forEach((btn) => btn.classList.toggle('active', btn === tab));
        shots.forEach((shot) => shot.classList.toggle('active', shot.id === target));
      });
    });

    const toggleFuture = document.getElementById('toggleFuture');
    const futureGraph = document.getElementById('futureGraph');
    const estimateProgress = document.getElementById('estimateProgress');
    const estimatePrice = document.getElementById('estimatePrice');
    let futureOpen = false;

    toggleFuture.addEventListener('click', () => {
      futureOpen = !futureOpen;
      futureGraph.classList.toggle('show', futureOpen);
      toggleFuture.classList.toggle('active', futureOpen);
      toggleFuture.textContent = futureOpen ? '現在価格にもどす' : '未来の相場をみる';
      estimateProgress.style.width = futureOpen ? '74%' : '68%';
      estimatePrice.textContent = futureOpen ? '187.6万' : '184.2万';
    });

    const expenseProfiles = {
      all: {
        total: '51,300',
        tag: '前年同月比 -6,400円',
        meter: '74%',
        bars: [30,18,20, 36,24,25, 32,16,20]
      },
      fuel: {
        total: '12,400',
        tag: 'ガソリン代は先月比 -1,200円',
        meter: '46%',
        bars: [22,6,6, 28,6,7, 24,5,6]
      },
      maintenance: {
        total: '10,000',
        tag: '点検積立を今月追加',
        meter: '63%',
        bars: [8,14,6, 8,20,7, 8,16,6]
      },
      insurance: {
        total: '8,700',
        tag: '保険更新まであと39日',
        meter: '58%',
        bars: [6,8,14, 6,8,18, 6,8,14]
      }
    };

    const chipButtons = document.querySelectorAll('.chip');
    const expenseTotal = document.getElementById('expenseTotal');
    const expenseTag = document.getElementById('expenseTag');
    const forecastMeter = document.getElementById('forecastMeter');
    const barIds = ['m1a','m1b','m1c','m2a','m2b','m2c','m3a','m3b','m3c'];

    chipButtons.forEach((chip) => {
      chip.addEventListener('click', () => {
        const key = chip.dataset.expense;
        const profile = expenseProfiles[key];
        chipButtons.forEach((btn) => btn.classList.toggle('active', btn === chip));
        expenseTotal.innerHTML = profile.total + '<small>円</small>';
        expenseTag.textContent = profile.tag;
        forecastMeter.style.width = profile.meter;
        profile.bars.forEach((height, index) => {
          document.getElementById(barIds[index]).style.height = height + 'px';
        });
      });
    });

    const callToggle = document.getElementById('callToggle');
    const callCount = document.getElementById('callCount');
    const compareCta = document.getElementById('compareCta');
    let compareState = 0;

    callToggle.addEventListener('click', () => {
      compareState = (compareState + 1) % 3;
      if (compareState === 0) {
        callToggle.textContent = '電話0本の理由をみる';
        callCount.textContent = '0';
        compareCta.textContent = 'まずは相場だけチェック';
      } else if (compareState === 1) {
        callToggle.textContent = '売却相談の流れをみる';
        callCount.textContent = '0';
        compareCta.textContent = '個人情報なしでAI査定';
      } else {
        callToggle.textContent = '相場チェックに戻る';
        callCount.textContent = '1';
        compareCta.textContent = '売却相談は1社対応で進める';
      }
    });

    const expenseCta = document.getElementById('expenseCta');
    expenseCta.addEventListener('click', () => {
      const activeChip = document.querySelector('.chip.active');
      if (activeChip && activeChip.dataset.expense !== 'all') {
        document.querySelector('.chip[data-expense="all"]').click();
        expenseCta.textContent = '今月全体の出費に戻しました';
      } else {
        document.querySelector('.chip[data-expense="maintenance"]').click();
        expenseCta.textContent = '整備コスト視点に切り替えました';
      }
      setTimeout(() => {
        expenseCta.textContent = '出費と査定をまとめてみる';
      }, 1400);
    });
  </script>
</body>
