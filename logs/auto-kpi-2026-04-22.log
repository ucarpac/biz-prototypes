        document.querySelectorAll(".forecast-chip").forEach((item) => item.classList.remove("active"));
        chip.classList.add("active");
        const data = forecastData[chip.dataset.forecast];
        forecastPrice.textContent = data.price;
        forecastCaption.textContent = data.caption;
        forecastConfidence.textContent = data.confidence;
        forecastDelta.textContent = data.delta;
        forecastMarker.setAttribute("cx", data.marker.x);
        forecastMarker.setAttribute("cy", data.marker.y);
        forecastMarkerCore.setAttribute("cx", data.marker.x);
        forecastMarkerCore.setAttribute("cy", data.marker.y);
