      background: rgba(255, 255, 255, 0.86);
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .illustration {
      position: absolute;
      right: 12px;
      bottom: 18px;
      width: 126px;
      height: 142px;
      z-index: 1;
    }

    .app-card {
      border-radius: 24px;
      padding: 18px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 12px 26px rgba(28, 38, 99, 0.08);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .title-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .title-row h4 {
      margin: 0;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .title-row .caption {
      font-size: 11px;
      font-weight: 800;
      color: var(--pink);
      background: rgba(248, 76, 162, 0.1);
      padding: 6px 10px;
      border-radius: var(--radius-pill);
      white-space: nowrap;
    }

    .price-main {
      display: flex;
      align-items: end;
      gap: 8px;
      margin-bottom: 6px;
      color: var(--dark-blue);
    }

    .price-main .value {
      font-size: 42px;
      line-height: 1;
      font-family: var(--font-number);
      letter-spacing: 0.03em;
    }

    .price-main .unit {
      font-size: 20px;
      font-weight: 900;
      margin-bottom: 4px;
    }

    .sub-text {
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
      margin: 0;
    }

    .graph-wrap {
      margin-top: 14px;
      border-radius: 18px;
      padding: 14px 12px 12px;
      background: linear-gradient(180deg, #fff 0%, #f6fbff 100%);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.05);
    }

    .graph-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .graph-top strong {
      font-size: 13px;
      color: var(--dark-blue);
    }

    .graph-top span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .graph {
      position: relative;
      height: 120px;
      border-radius: 14px;
      background:
        repeating-linear-gradient(
          to top,
          rgba(28, 38, 99, 0.06),
          rgba(28, 38, 99, 0.06) 1px,
          transparent 1px,
          transparent 24px
        );
      overflow: hidden;
    }

    .graph svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .graph-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .mini-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 14px;
    }

    .mini-card {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, #fff 0%, #fff7fb 100%);
      box-shadow: inset 0 0 0 1px rgba(248, 76, 162, 0.08);
    }

    .mini-card strong {
      display: block;
      font-size: 12px;
      color: var(--text-gray);
      margin-bottom: 6px;
    }

    .mini-card span {
      display: block;
      font-size: 24px;
      line-height: 1.2;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .mini-card em {
      display: block;
      margin-top: 4px;
      font-style: normal;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .list-card {
      display: grid;
      gap: 10px;
    }

    .list-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px dashed rgba(28, 38, 99, 0.1);
      align-items: center;
    }

    .list-row:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .list-row strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .list-row span {
      display: block;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .list-row b {
      font-size: 16px;
      line-height: 1.3;
      color: var(--dark-blue);
      white-space: nowrap;
    }

    .comfort-banner {
      border-radius: 22px;
      padding: 18px;
      background: linear-gradient(135deg, #fff5ed 0%, #fffdf8 56%, #eef7ff 100%);
      border: 1px solid rgba(255, 201, 160, 0.44);
      display: grid;
      grid-template-columns: 62px 1fr;
      gap: 14px;
      align-items: center;
    }

    .comfort-icon {
      width: 62px;
      height: 62px;
      border-radius: 20px;
      background: var(--gradient-heart);
      display: grid;
      place-items: center;
      font-size: 28px;
      color: #fff;
      box-shadow: 0 12px 24px rgba(248, 76, 162, 0.18);
    }

    .comfort-banner strong {
      display: block;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.5;
      margin-bottom: 4px;
    }

    .comfort-banner span {
      display: block;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.75;
    }

    .compare-board {
      border-radius: 24px;
      overflow: hidden;
      background: #fff;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 12px 26px rgba(28, 38, 99, 0.08);
    }

    .compare-head {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      background: linear-gradient(90deg, #fff3f8 0%, #fff8ef 100%);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 900;
      text-align: center;
    }

    .compare-head div {
      padding: 12px 8px;
      border-right: 1px solid rgba(28, 38, 99, 0.06);
    }

    .compare-head div:last-child {
      border-right: none;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      text-align: center;
      font-size: 12px;
      align-items: center;
      min-height: 62px;
      color: var(--text-black);
      border-top: 1px solid rgba(28, 38, 99, 0.06);
    }

    .compare-row strong {
      text-align: left;
      padding: 12px 14px;
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.5;
    }

    .compare-row span {
      padding: 12px 8px;
      font-weight: 800;
    }

    .yes {
      color: #e95986;
    }

    .no {
      color: var(--text-gray);
    }

    .highlight-zero {
      display: grid;
      gap: 12px;
      padding: 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, #fff1f7 0%, #fff8e9 100%);
      border: 2px dashed rgba(248, 76, 162, 0.22);
      text-align: center;
    }

    .highlight-zero strong {
      display: block;
      font-size: 16px;
      line-height: 1.6;
      color: var(--dark-blue);
    }

    .highlight-zero .zero {
      font-size: 78px;
      line-height: 1;
      color: var(--pink);
      font-weight: 900;
      letter-spacing: -0.06em;
      text-shadow: 0 12px 24px rgba(248, 76, 162, 0.16);
    }

    .highlight-zero span {
      display: block;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .floating-sticker {
      position: absolute;
      right: 18px;
      top: 90px;
      transform: rotate(8deg);
      background: #fff;
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.5;
      font-weight: 900;
      padding: 10px 12px;
      border-radius: 16px;
      box-shadow: 0 14px 24px rgba(28, 38, 99, 0.12);
      border: 2px solid rgba(255, 201, 160, 0.5);
    }

    .bottom-bar {
      position: sticky;
      bottom: 10px;
      z-index: 5;
      margin-top: 22px;
      padding: 12px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 20px 40px rgba(28, 38, 99, 0.14);
      backdrop-filter: blur(14px);
      display: grid;
      gap: 10px;
    }

    .bottom-bar p {
      margin: 0;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
      text-align: center;
    }

    .bottom-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .toggle-state {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.72);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .toggle-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #ffb35c;
      box-shadow: 0 0 0 4px rgba(255, 179, 92, 0.18);
      transition: background var(--transition), box-shadow var(--transition);
    }

    .toggle-state.active .toggle-dot {
      background: #1ddcff;
      box-shadow: 0 0 0 4px rgba(29, 220, 255, 0.18);
    }

    .pulse {
      animation: pulse 2.2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%,
      100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.04);
      }
    }

    @media (min-width: 768px) {
      .page {
        padding: 36px 24px 72px;
      }

      .hero {
        grid-template-columns: 1.1fr 0.9fr;
        align-items: end;
      }

      .control-panel {
        padding: 18px;
      }

      .tab-list {
        grid-template-columns: repeat(3, 1fr);
      }

      .screens-stage {
        gap: 24px;
      }

      .screen-panel {
        grid-template-columns: minmax(300px, 380px) minmax(340px, 1fr);
        align-items: start;
      }

      .bottom-bar {
        grid-template-columns: 1fr auto;
        align-items: center;
      }

      .bottom-bar p {
        text-align: left;
      }

      .bottom-actions {
        width: 360px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="bg-doodle" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>

    <section class="hero">
      <div class="hero-copy">
        <div class="eyebrow">
          <span class="dot"></span>
          ストアPV→DL率改善向け / 感情に訴えるA案
        </div>
        <h1>「今すぐ売らなくてもいい」<br>その気持ちに寄り添う、やさしいストアスクショ。</h1>
        <p>
          UcarPAC Appの強みであるAI査定、将来予測、出費管理、そして「電話0本」級の安心感を、
          暖色系の空気感と手書き風の余白で包み込む構成です。ユーザーの不安をやわらげ、
          「まずは見てみよう」「入れておこう」と感じさせるストア体験を想定しています。
        </p>
        <div class="hero-notes">
          <div class="hero-note">個人情報なしで相場チェック</div>
          <div class="hero-note">8,000社が競うオークション</div>
          <div class="hero-note">毎月の出費もひと目で見える</div>
        </div>
      </div>

      <div class="control-panel">
        <div class="tab-list" role="tablist" aria-label="スクリーン選択">
          <button class="tab-button active" id="tab-a" role="tab" aria-selected="true" aria-controls="panel-a" data-target="panel-a">
            <strong>スクショA / iOS向け</strong>
            <span>AI査定を全面に。感情を動かす「愛車の今」を主役にする。</span>
          </button>
          <button class="tab-button" id="tab-b" role="tab" aria-selected="false" aria-controls="panel-b" data-target="panel-b">
            <strong>スクショB / Android向け</strong>
            <span>出費管理と将来予測で、車を持つ不安を安心に変える。</span>
          </button>
          <button class="tab-button" id="tab-c" role="tab" aria-selected="false" aria-controls="panel-c" data-target="panel-c">
            <strong>スクショC / 比較訴求</strong>
            <span>競合比較で「電話0本」の気楽さを強く印象づける。</span>
          </button>
        </div>
        <div class="meta-row">
          <div class="meta-chip">現状CVR<strong>17.3%</strong></div>
          <div class="meta-chip">目標CVR<strong>25%</strong></div>
          <div class="meta-chip">感情キーワード<strong>安心 / 気軽 / 将来が見える</strong></div>
        </div>
      </div>
    </section>

    <section class="screens-stage">
      <article class="screen-panel active" id="panel-a" role="tabpanel" aria-labelledby="tab-a">
        <div class="panel-side">
          <div class="context-card">
            <h2>スクショAの狙い</h2>
            <p>
              「この車、いくらなんだろう」という一番素直な気持ちに、最短で安心感を返す構成です。
              価格の大きな数字と将来予測の可視化を中心に据え、売る決断を急がせず、
              “とりあえず入れておきたい”理由をつくります。
            </p>
            <div class="point-list">
              <div class="point">
                <div class="point-icon">AI</div>
                <div>
                  <strong>AI査定を最上段で可視化</strong>
                  <span>トヨタ プリウス Z / 2021年式 / 走行2.8万kmの具体例で、価格の実感を高めます。</span>
                </div>
              </div>
              <div class="point">
                <div class="point-icon">◎</div>
                <div>
                  <strong>個人情報なしの安心バッジ</strong>
                  <span>営業電話への不安が大きいユーザーに、心理的ハードルの低さを先に伝えます。</span>
                </div>
              </div>
              <div class="point">
                <div class="point-icon">↗</div>
                <div>
                  <strong>3ヶ月後予測で価値を継続提示</strong>
                  <span>今すぐ売らないユーザーでも、アプリを保持する理由を残せます。</span>
                </div>
              </div>
            </div>
            <div class="toggle-state active" id="mode-a">
              <span class="toggle-dot"></span>
              安心モード: やさしいコピーと価格予測を強調中
            </div>
          </div>

          <div class="cta-card">
            <h2>訴求コピー候補</h2>
            <p>
              「AIが、愛車の今をやさしく見える化。」
              「個人情報なしで、まずは相場だけ。」
              「迷っている今にも、意味がある。」
            </p>
            <div class="action-row">
              <button class="action-button primary" data-pulse-target="#panel-a .hero-card">主役コピーを強調</button>
              <button class="action-button secondary" data-toggle="mode-a">安心モード切替</button>
            </div>
          </div>
        </div>

        <div class="phone-wrap">
          <div class="phone-frame">
            <div class="phone-screen">
              <div class="floating-sticker">iOS向け<br>1枚目想定</div>
              <div class="status-bar">
                <span>9:41</span>
                <span>5G 100%</span>
              </div>
              <div class="screen-body">
                <div class="store-badge-row">
                  <div class="store-badge">
                    <span class="mini"></span>
                    App Store スクリーンショット
                  </div>
                  <div class="store-badge">愛車の価値を、今すぐ確認</div>
                </div>

                <section class="hero-card pulse">
                  <h3>AIがあなたの愛車を査定</h3>
                  <p>
                    トヨタ プリウス Z 2021年式なら、
                    いまの予測相場はこのくらい。
                  </p>
                  <div class="pill-row">
                    <div class="pill">個人情報なし</div>
                    <div class="pill">最短すぐ確認</div>
                    <div class="pill">将来予測つき</div>
                  </div>
                  <div class="scribble"></div>
                  <svg class="illustration" viewBox="0 0 126 142" aria-hidden="true">
                    <path d="M21 92c0-23 17-41 40-41 14 0 27 7 34 18 3-1 6-2 10-2 12 0 21 9 21 21 0 12-10 22-22 22H35C27 110 21 102 21 92z" fill="#ffffff" opacity="0.92"></path>
                    <path d="M24 92c0-21 15-37 37-37 14 0 26 7 33 18 3-2 6-3 10-3 10 0 18 8 18 18 0 10-8 18-18 18H38c-8 0-14-6-14-14z" fill="#ffe7f2"></path>
                    <rect x="20" y="80" width="70" height="24" rx="12" fill="#1c2663"></rect>
                    <rect x="30" y="72" width="36" height="16" rx="8" fill="#4db4ff"></rect>
                    <circle cx="36" cy="106" r="9" fill="#404040"></circle>
                    <circle cx="75" cy="106" r="9" fill="#404040"></circle>
                    <path d="M86 28c9 0 16 7 16 16s-7 16-16 16-16-7-16-16 7-16 16-16z" fill="#fff7c2"></path>
                    <path d="M87 16l4 9 9 3-9 4-4 9-4-9-9-4 9-3 4-9z" fill="#f84ca2"></path>
                    <path d="M84 84c7-7 18-7 25 0" stroke="#f84ca2" stroke-width="4" stroke-linecap="round" fill="none"></path>
                  </svg>
                </section>

                <section class="app-card">
                  <div class="title-row">
                    <h4>現在のAI査定額</h4>
                    <div class="caption">登録例: 走行28,400km</div>
                  </div>
                  <div class="price-main">
                    <span class="value">214</span>
                    <span class="unit">万円</span>
                  </div>
                  <p class="sub-text">
                    市場の近似データと装備条件から算出。売るか迷っている段階でも、
                    “今の相場感”をやさしく把握できます。
                  </p>

                  <div class="graph-wrap">
                    <div class="graph-top">
                      <strong>将来予測</strong>
                      <span>今売る？ 3ヶ月後まで待つ？</span>
                    </div>
                    <div class="graph">
                      <svg viewBox="0 0 320 120" preserveAspectRatio="none" aria-hidden="true">
                        <defs>
                          <linearGradient id="lineA" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" stop-color="#f84ca2"></stop>
                            <stop offset="100%" stop-color="#4db4ff"></stop>
                          </linearGradient>
                          <linearGradient id="fillA" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" stop-color="rgba(248,76,162,0.28)"></stop>
                            <stop offset="100%" stop-color="rgba(77,180,255,0.03)"></stop>
                          </linearGradient>
                        </defs>
                        <path d="M12 100 C58 96, 90 84, 118 76 S186 54, 214 58 S274 72, 308 40 L308 120 L12 120 Z" fill="url(#fillA)"></path>
                        <path d="M12 100 C58 96, 90 84, 118 76 S186 54, 214 58 S274 72, 308 40" fill="none" stroke="url(#lineA)" stroke-width="4" stroke-linecap="round"></path>
                        <circle cx="12" cy="100" r="5" fill="#f84ca2"></circle>
                        <circle cx="118" cy="76" r="5" fill="#ffb35c"></circle>
                        <circle cx="214" cy="58" r="5" fill="#4db4ff"></circle>
                        <circle cx="308" cy="40" r="6" fill="#1c2663"></circle>
                      </svg>
                    </div>
                    <div class="graph-labels">
                      <span>今月 214万</span>
                      <span>来月 218万</span>
                      <span>2ヶ月後 221万</span>
                      <span>3ヶ月後 227万</span>
                    </div>
                  </div>

                  <div class="mini-grid">
                    <div class="mini-card">
                      <strong>人気装備</strong>
                      <span>評価+8万</span>
                      <em>純正ナビ / ETC2.0 / セーフティセンス</em>
                    </div>
                    <div class="mini-card">
                      <strong>売りやすさ</strong>
                      <span>高め</span>
                      <em>春の需要で入札が伸びやすい時期</em>
                    </div>
                  </div>
                </section>

                <section class="comfort-banner">
                  <div class="comfort-icon">♡</div>
                  <div>
                    <strong>まずは、見るだけで大丈夫。</strong>
                    <span>
                      UcarPAC Appなら個人情報なしで価格チェック。
                      売る時期が来たら、そのまま最高額オークションへ進めます。
                    </span>
                  </div>
                </section>
              </div>
            </div>
          </div>
        </div>
      </article>

      <article class="screen-panel" id="panel-b" role="tabpanel" aria-labelledby="tab-b">
        <div class="panel-side">
          <div class="context-card">
            <h2>スクショBの狙い</h2>
            <p>
              「車って、持っているだけでもお金がかかる」という現実に寄り添い、
              出費管理と将来予測を並べて見せる構成です。アプリを入れる理由を
              “売却だけ”に限定せず、日常の役立ち感まで広げます。
            </p>
            <div class="point-list">
              <div class="point">
                <div class="point-icon">¥</div>
                <div>
                  <strong>月々の出費を見える化</strong>
                  <span>ガソリン・保険・洗車・駐車場をリアルな数字で表示し、生活者の実感に近づけます。</span>
                </div>
              </div>
              <div class="point">
                <div class="point-icon">↘</div>
                <div>
                  <strong>価値と維持費を同時に考えられる</strong>
                  <span>「あと何ヶ月乗るか」の判断を、感覚だけでなく数字でも後押しします。</span>
                </div>
              </div>
              <div class="point">
                <div class="point-icon">⟲</div>
