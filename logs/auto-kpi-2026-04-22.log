  <script>
    (function () {
      var tabs = Array.prototype.slice.call(document.querySelectorAll(".tab-button"));
      var panels = Array.prototype.slice.call(document.querySelectorAll(".screen-panel"));
      var footerMessage = document.getElementById("footer-message");
      var footerTexts = {
        "panel-a": "現在表示中: スクショA。AI査定の安心感を前面に出し、ストア詳細ページ閲覧後の初回DLを後押しする構成です。",
        "panel-b": "現在表示中: スクショB。出費管理と将来予測を組み合わせ、売却検討前のユーザーにもアプリ保持理由を作る構成です。",
        "panel-c": "現在表示中: スクショC。競合比較で不安要素を先回りし、『電話0本』の気楽さを強く印象づける構成です。"
      };

      function activatePanel(targetId) {
        tabs.forEach(function (tab) {
          var active = tab.getAttribute("data-target") === targetId;
          tab.classList.toggle("active", active);
          tab.setAttribute("aria-selected", active ? "true" : "false");
        });

        panels.forEach(function (panel) {
          var active = panel.id === targetId;
          panel.classList.toggle("active", active);
        });

        footerMessage.textContent = footerTexts[targetId] || "";
      }

      tabs.forEach(function (tab) {
        tab.addEventListener("click", function () {
          activatePanel(tab.getAttribute("data-target"));
        });
      });

      var orderedIds = ["panel-a", "panel-b", "panel-c"];

      function getActiveIndex() {
        var activePanel = document.querySelector(".screen-panel.active");
        return orderedIds.indexOf(activePanel ? activePanel.id : "panel-a");
      }

      document.getElementById("prev-button").addEventListener("click", function () {
        var nextIndex = (getActiveIndex() + orderedIds.length - 1) % orderedIds.length;
        activatePanel(orderedIds[nextIndex]);
      });

      document.getElementById("next-button").addEventListener("click", function () {
        var nextIndex = (getActiveIndex() + 1) % orderedIds.length;
        activatePanel(orderedIds[nextIndex]);
      });

      Array.prototype.slice.call(document.querySelectorAll("[data-pulse-target]")).forEach(function (button) {
        button.addEventListener("click", function () {
          var selector = button.getAttribute("data-pulse-target");
          var target = document.querySelector(selector);
          if (!target) return;
          target.classList.remove("pulse");
          void target.offsetWidth;
          target.classList.add("pulse");
        });
      });

      Array.prototype.slice.call(document.querySelectorAll("[data-toggle]")).forEach(function (button) {
        button.addEventListener("click", function () {
          var targetId = button.getAttribute("data-toggle");
          var target = document.getElementById(targetId);
          if (!target) return;
          target.classList.toggle("active");

          if (targetId === "mode-a") {
            target.lastChild.textContent = target.classList.contains("active")
              ? " 安心モード: やさしいコピーと価格予測を強調中"
              : " 情報モード: 査定ロジックと数値の具体性を強調中";
          }

          if (targetId === "mode-b") {
            target.lastChild.textContent = target.classList.contains("active")
              ? " 出費と相場のバランス説明を短く表示中"
              : " 出費管理の利便性を前面に表示中";
          }

          if (targetId === "mode-c") {
            target.lastChild.textContent = target.classList.contains("active")
              ? " 比較訴求モード: 不安解消のコピーを表示中"
              : " 優位性訴求モード: 8,000社入札と1社対応を表示中";
          }
        });
      });

      document.addEventListener("keydown", function (event) {
        if (event.key === "ArrowRight") {
          document.getElementById("next-button").click();
        }
        if (event.key === "ArrowLeft") {
          document.getElementById("prev-button").click();
        }
      });
    })();
  </script>
