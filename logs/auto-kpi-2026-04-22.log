      tab.addEventListener("click", () => setScreen(tab.dataset.screen));
    });

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => setScreen(thumb.dataset.screen));
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => setScreen(dot.dataset.dot));
    });

    nextBtn.addEventListener("click", () => {
      const order = ["a", "b", "c"];
      const next = order[(order.indexOf(currentScreen) + 1) % order.length];
      setScreen(next);
    });

    replayBtn.addEventListener("click", () => {
      document.querySelectorAll(".progress-fill, .kpi-bar i, .stress-bar i").forEach((node) => {
        const width = node.style.width;
        node.style.transition = "none";
        node.style.width = "0";
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            node.style.transition = "";
            node.style.width = width;
          });
        });
      });
    });

    const forecastPrice = document.getElementById("forecastPrice");
    const forecastCaption = document.getElementById("forecastCaption");
    const forecastConfidence = document.getElementById("forecastConfidence");
