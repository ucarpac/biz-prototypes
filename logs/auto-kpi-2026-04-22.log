      barB.style.width = meta.bars[1] + "%";
      barC.style.width = meta.bars[2] + "%";
      barLabelA.textContent = meta.bars[0] + " / 100";
      barLabelB.textContent = meta.bars[1] + " / 100";
      barLabelC.textContent = meta.bars[2] + " / 100";
    }

