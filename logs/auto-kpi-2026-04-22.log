          { value: "136.8万", height: "88px", label: "1年後" }
        ]
      }
    };

    const compareData = {
      privacy: {
        copy: "相場チェック段階では営業電話なし。車種・年式・走行距離だけでAI査定を開始できます。",
        ucarCopy: "最初は軽い入力だけ。いまの相場を見るための心理的ハードルが低い。",
        rivalCopy: "詳細入力を求められる印象が強く、相場だけ見たい層には重く感じやすい。",
        ucarScore: "90秒",
        rivalScore: "入力多め",
        inputText: "軽い",
        callText: "高い",
        timingText: "深い",
        inputFill: "22%",
        callFill: "84%",
        timingFill: "88%"
      },
      stress: {
        copy: "比較したいだけなら電話0本。営業対応を先に想像させないことで、DL前の不安を減らします。",
        ucarCopy: "相場チェック中は連絡負荷がゼロ。まずは自分のペースで価格を理解できる。",
        rivalCopy: "複数社とのやりとりを想像させやすく、ストア段階で敬遠される可能性がある。",
        ucarScore: "0本",
        rivalScore: "5-10社",
        inputText: "普通",
        callText: "高い",
        timingText: "中",
        inputFill: "40%",
        callFill: "92%",
        timingFill: "62%"
      },
      timing: {
        copy: "ただ価格を見るだけでなく、3か月後の変動まで見えるから売り時判断の解像度が上がります。",
        ucarCopy: "AI査定と将来予測で、今売るべきか待つべきかを1アプリで判断できる。",
        rivalCopy: "今の見積もり比較に寄りやすく、時間経過を含めた売り時判断までは伝わりにくい。",
        ucarScore: "予測あり",
        rivalScore: "今だけ",
        inputText: "軽い",
        callText: "中",
        timingText: "深い",
        inputFill: "26%",
        callFill: "66%",
        timingFill: "94%"
      }
    };

    const track = document.getElementById("track");
    const deck = document.getElementById("deck");
    const screenButtons = Array.from(document.querySelectorAll(".screen-btn"));
    const dotButtons = Array.from(document.querySelectorAll(".dot-btn"));
    const noteButtons = Array.from(document.querySelectorAll("[data-jump]"));
    const progressText = document.getElementById("progressText");
    const progressFill = document.getElementById("progressFill");
    const insightEyebrow = document.getElementById("insightEyebrow");
    const insightScore = document.getElementById("insightScore");
    const insightTitle = document.getElementById("insightTitle");
    const insightCopy = document.getElementById("insightCopy");
    const insightTags = document.getElementById("insightTags");

    let current = 0;
    let startX = 0;
    let currentTranslate = 0;
    let isDragging = false;
    let autoTimer = null;

    function renderInsight(index) {
      const meta = slideMeta[index];
      insightEyebrow.textContent = meta.eyebrow;
      insightScore.textContent = meta.score;
      insightTitle.textContent = meta.title;
      insightCopy.textContent = meta.copy;
      insightTags.innerHTML = meta.tags.map(function(tag) {
        return '<span class="insight-tag">' + tag + '</span>';
      }).join("");
    }

    function renderProgress(index) {
      progressText.textContent = "STEP " + (index + 1) + " / 3";
      progressFill.style.width = ((index + 1) / 3 * 100) + "%";
      [0, 1, 2].forEach(function(i) {
        const el = document.getElementById("progressStep" + i);
        el.classList.remove("is-current", "is-done");
        if (i < index) el.classList.add("is-done");
        if (i === index) el.classList.add("is-current");
      });
    }

    function setActive(index, userTriggered) {
      current = (index + 3) % 3;
      currentTranslate = -current * 100;
      track.style.transform = "translateX(" + currentTranslate + "%)";
      screenButtons.forEach(function(btn, i) {
        btn.classList.toggle("is-active", i === current);
      });
      dotButtons.forEach(function(btn, i) {
        btn.classList.toggle("is-active", i === current);
      });
      renderInsight(current);
      renderProgress(current);
      if (userTriggered) restartAuto();
    }

    function restartAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(function() {
        setActive(current + 1, false);
      }, 6800);
    }

    screenButtons.forEach(function(btn) {
      btn.addEventListener("click", function() {
        setActive(Number(btn.dataset.target), true);
      });
    });

    dotButtons.forEach(function(btn) {
      btn.addEventListener("click", function() {
        setActive(Number(btn.dataset.target), true);
      });
    });

    noteButtons.forEach(function(btn) {
      btn.addEventListener("click", function() {
        setActive(Number(btn.dataset.jump), true);
      });
    });

    document.getElementById("prevBtn").addEventListener("click", function() {
      setActive(current - 1, true);
    });

    document.getElementById("nextBtn").addEventListener("click", function() {
      setActive(current + 1, true);
    });

    deck.addEventListener("touchstart", function(event) {
      isDragging = true;
      startX = event.touches[0].clientX;
      clearInterval(autoTimer);
    }, { passive: true });

    deck.addEventListener("touchmove", function(event) {
      if (!isDragging) return;
      const delta = event.touches[0].clientX - startX;
      const width = deck.clientWidth || 1;
      const percent = (delta / width) * 100;
      track.style.transform = "translateX(calc(" + currentTranslate + "% + " + percent + "%))";
    }, { passive: true });

    deck.addEventListener("touchend", function(event) {
      if (!isDragging) return;
      isDragging = false;
      const delta = event.changedTouches[0].clientX - startX;
      if (delta < -50) {
        setActive(current + 1, true);
      } else if (delta > 50) {
        setActive(current - 1, true);
      } else {
        setActive(current, true);
      }
    });

    const aNow = document.getElementById("aPriceNow");
    const aFuture = document.getElementById("aPriceFuture");
    const aConfidence = document.getElementById("aConfidence");
    const aDelta = document.getElementById("aDeltaText");
    const aContextLabel = document.getElementById("aContextLabel");
    const aContextSub = document.getElementById("aContextSub");
    const aMileageChoices = Array.from(document.querySelectorAll("#aMileageChoices .choice-chip"));

    function updateMileage(key) {
      const data = mileageData[key];
      aNow.textContent = data.now;
      aFuture.textContent = data.future;
      aConfidence.textContent = data.confidence;
      aDelta.textContent = data.delta;
      aContextLabel.textContent = data.label;
      aContextSub.textContent = data.sub;
      aMileageChoices.forEach(function(btn) {
        btn.classList.toggle("is-active", btn.dataset.mileage === key);
      });
    }

    aMileageChoices.forEach(function(btn) {
      btn.addEventListener("click", function() {
        updateMileage(btn.dataset.mileage);
      });
    });

    const bCostTotal = document.getElementById("bCostTotal");
    const bFutureMain = document.getElementById("bFutureMain");
    const bFuel = document.getElementById("bFuel");
    const bInsurance = document.getElementById("bInsurance");
    const bMaintenance = document.getElementById("bMaintenance");
    const bInsightMain = document.getElementById("bInsightMain");
    const bInsightSub = document.getElementById("bInsightSub");
    const bBar0 = document.getElementById("bBar0");
    const bBar1 = document.getElementById("bBar1");
    const bBar2 = document.getElementById("bBar2");
    const bLabel0 = document.getElementById("bLabel0");
    const bLabel1 = document.getElementById("bLabel1");
    const bLabel2 = document.getElementById("bLabel2");
    const bTermChoices = Array.from(document.querySelectorAll("#bTermChoices .choice-chip"));

    function updateTerm(key) {
      const data = termData[key];
      bCostTotal.textContent = data.total;
      bFutureMain.textContent = data.future;
      bFuel.textContent = data.fuel;
      bInsurance.textContent = data.insurance;
      bMaintenance.textContent = data.maintenance;
      bInsightMain.textContent = data.insightMain;
      bInsightSub.textContent = data.insightSub;

      [bBar0, bBar1, bBar2].forEach(function(bar, i) {
        bar.style.setProperty("--bar-height", data.bars[i].height);
        bar.setAttribute("data-value", data.bars[i].value);
      });
      [bLabel0, bLabel1, bLabel2].forEach(function(label, i) {
        label.textContent = data.bars[i].label;
      });

      bTermChoices.forEach(function(btn) {
        btn.classList.toggle("is-active", btn.dataset.term === key);
      });
    }

    bTermChoices.forEach(function(btn) {
      btn.addEventListener("click", function() {
        updateTerm(btn.dataset.term);
      });
    });

    const cCallCount = document.getElementById("cCallCount");
    const cCompareCopy = document.getElementById("cCompareCopy");
    const cUcarCopy = document.getElementById("cUcarCopy");
    const cRivalCopy = document.getElementById("cRivalCopy");
    const cUcarScore = document.getElementById("cUcarScore");
    const cRivalScore = document.getElementById("cRivalScore");
    const cMeterInputText = document.getElementById("cMeterInputText");
    const cMeterCallText = document.getElementById("cMeterCallText");
    const cMeterTimingText = document.getElementById("cMeterTimingText");
    const cMeterInputUcar = document.getElementById("cMeterInputUcar");
    const cMeterCallRival = document.getElementById("cMeterCallRival");
    const cMeterTimingUcar = document.getElementById("cMeterTimingUcar");
    const cModeChoices = Array.from(document.querySelectorAll("#cModeChoices .choice-chip"));

    function updateCompare(mode) {
      const data = compareData[mode];
      cCallCount.textContent = "0";
      cCompareCopy.textContent = data.copy;
      cUcarCopy.textContent = data.ucarCopy;
      cRivalCopy.textContent = data.rivalCopy;
      cUcarScore.textContent = data.ucarScore;
      cRivalScore.textContent = data.rivalScore;
      cMeterInputText.textContent = data.inputText;
      cMeterCallText.textContent = data.callText;
      cMeterTimingText.textContent = data.timingText;
      cMeterInputUcar.style.setProperty("--fill", data.inputFill);
      cMeterCallRival.style.setProperty("--fill", data.callFill);
      cMeterTimingUcar.style.setProperty("--fill", data.timingFill);
      cModeChoices.forEach(function(btn) {
        btn.classList.toggle("is-active", btn.dataset.mode === mode);
      });
    }

    cModeChoices.forEach(function(btn) {
      btn.addEventListener("click", function() {
        updateCompare(btn.dataset.mode);
      });
    });

    updateMileage("standard");
    updateTerm("month");
    updateCompare("privacy");
    setActive(0, false);
    restartAuto();
  </script>
