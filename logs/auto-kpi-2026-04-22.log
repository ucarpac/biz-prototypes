    const barLabelB = document.getElementById("barLabelB");
    const barLabelC = document.getElementById("barLabelC");

    let currentScreen = "a";

    function setScreen(id) {
      currentScreen = id;

      tabs.forEach((tab) => {
        const active = tab.dataset.screen === id;
        tab.classList.toggle("active", active);
        tab.setAttribute("aria-selected", active ? "true" : "false");
      });

      thumbs.forEach((thumb) => {
        thumb.classList.toggle("active", thumb.dataset.screen === id);
      });

      dots.forEach((dot) => {
        dot.classList.toggle("active", dot.dataset.dot === id);
      });

      phones.forEach((phone) => {
        phone.classList.toggle("active", phone.dataset.phone === id);
      });

      const meta = screenMeta[id];
      stageTitle.textContent = meta.stageTitle;
      stageCopy.textContent = meta.stageCopy;
      stagePill.textContent = meta.stagePill;
      insightTitle.textContent = meta.insightTitle;
      insightCopy.textContent = meta.insightCopy;
      impactPoint.textContent = meta.impactPoint;
      impactNote.innerHTML = meta.impactNote;
