      color: var(--dark-blue);
    }

    .screen.b .chart-head strong {
      color: var(--white);
    }

    .chart-head span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .screen.b .chart-head span {
      color: rgba(255,255,255,0.64);
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .mini-card {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .screen.b .mini-card {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.12);
      box-shadow: none;
    }

    .mini-card span {
      display: block;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
      letter-spacing: 0.04em;
    }

    .screen.b .mini-card span {
      color: rgba(255,255,255,0.64);
    }

    .mini-card strong {
      display: block;
      margin-top: 6px;
      font-size: 20px;
      line-height: 1.25;
      color: var(--dark-blue);
    }

    .screen.b .mini-card strong {
      color: var(--white);
    }

    .mini-card small {
      display: block;
      margin-top: 6px;
      font-size: 11px;
      line-height: 1.65;
      color: #64718b;
    }

    .screen.b .mini-card small {
      color: rgba(255,255,255,0.70);
    }

    .cta {
      margin-top: 16px;
      width: 100%;
      min-height: 52px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
      box-shadow: 0 16px 32px rgba(64, 153, 255, 0.24);
    }

    .screen.b .cta {
      background: linear-gradient(90deg, #7ce7ff 0%, #4db4ff 100%);
    }

    .disclaimer {
      margin-top: 10px;
      font-size: 10px;
      line-height: 1.6;
      color: #7181a0;
      text-align: center;
    }

    .screen.b .disclaimer {
      color: rgba(255,255,255,0.54);
    }

    .compare-hero {
      margin-top: 16px;
      padding: 16px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(248,76,162,0.14), rgba(29,220,255,0.14));
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .compare-hero .zero {
      display: flex;
      align-items: end;
      gap: 8px;
      margin-top: 8px;
      color: var(--dark-blue);
    }

    .compare-hero .zero strong {
      font-family: var(--font-number);
      font-size: 60px;
      line-height: 0.9;
      letter-spacing: -0.05em;
    }

    .compare-hero .zero span {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.4;
      padding-bottom: 8px;
    }

    .compare-caption {
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.8;
      color: #5f6d8c;
    }

    .compare-table {
      margin-top: 14px;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid rgba(28,38,99,0.08);
      background: rgba(255,255,255,0.88);
      box-shadow: var(--shadow-light);
    }

    .compare-header,
    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr repeat(3, minmax(0, 1fr));
      gap: 8px;
      align-items: center;
      padding: 12px 14px;
    }

    .compare-header {
      background: rgba(9,19,85,0.06);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.04em;
      color: var(--dark-blue);
    }

    .compare-row {
      border-top: 1px solid rgba(28,38,99,0.06);
      font-size: 12px;
      color: var(--text-black);
    }

    .compare-row strong {
      font-size: 12px;
      line-height: 1.6;
      color: var(--dark-blue);
    }

    .cell-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 28px;
      min-width: 58px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(9,19,85,0.06);
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .cell-badge.pink {
      background: rgba(248,76,162,0.12);
      color: var(--pink);
    }

    .cell-badge.blue {
      background: rgba(64,153,255,0.14);
      color: var(--text-under-blue);
    }

    .stress-card {
      margin-top: 14px;
      padding: 14px;
      border-radius: 20px;
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
    }

    .stress-row {
      display: grid;
      grid-template-columns: 88px 1fr auto;
      gap: 10px;
      align-items: center;
      margin-top: 10px;
      font-size: 12px;
      color: var(--text-black);
    }

    .stress-row:first-child {
      margin-top: 0;
    }

    .stress-bar {
      height: 10px;
      border-radius: 999px;
      background: rgba(9,19,85,0.08);
      overflow: hidden;
    }

    .stress-bar i {
      display: block;
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: linear-gradient(90deg, #f84ca2, #ffaccc);
      transition: width 420ms ease;
    }

    .stress-bar.blue i {
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
    }

    .info-grid {
      display: grid;
      gap: 12px;
    }

    .kpi-stack {
      display: grid;
      gap: 10px;
      margin-top: 10px;
    }

    .kpi-line {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      font-size: 12px;
      color: #5e6b88;
    }

    .kpi-bar {
      height: 10px;
      border-radius: 999px;
      background: rgba(9,19,85,0.08);
      overflow: hidden;
      margin-top: 6px;
    }

    .kpi-bar i {
      display: block;
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 420ms ease;
    }

    .kpi-bar.pink i {
      background: linear-gradient(90deg, #f84ca2, #ffb2d3);
    }

    .kpi-bar.dark i {
      background: linear-gradient(90deg, #091355, #1d2e93);
    }

    .detail-metric {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin-top: 12px;
    }

    .detail-metric strong {
      font-family: var(--font-number);
      font-size: 36px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .detail-metric span {
      font-size: 12px;
      color: #62708b;
      text-align: right;
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .legend span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(9,19,85,0.06);
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .legend span::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--button-link1);
    }

    .legend span:nth-child(2)::before {
      background: var(--pink);
    }

    .legend span:nth-child(3)::before {
      background: var(--dark-blue);
    }

    .control-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .secondary-btn {
      min-height: 40px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.90);
      border: 1px solid rgba(28,38,99,0.08);
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      box-shadow: var(--shadow-light);
      transition: transform var(--transition), border-color var(--transition);
    }

    .secondary-btn:hover {
      transform: translateY(-1px);
      border-color: rgba(248, 76, 162, 0.24);
    }

    .thumbs {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .thumb {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.90);
      border: 1px solid rgba(28,38,99,0.08);
      box-shadow: var(--shadow-light);
      transition: all var(--transition);
    }

    .thumb.active {
      border-color: rgba(248,76,162,0.24);
      background: linear-gradient(135deg, rgba(248,76,162,0.10), rgba(29,220,255,0.10));
    }

    .thumb span {
      display: block;
      font-size: 11px;
      font-weight: 800;
      color: var(--text-gray);
    }

    .thumb strong {
      display: block;
      margin-top: 6px;
      font-size: 13px;
      line-height: 1.6;
      color: var(--dark-blue);
    }

    .thumb small {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.6;
      color: #63708c;
    }

    .footer-note {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(9,19,85,0.94);
      color: rgba(255,255,255,0.86);
      font-size: 12px;
      line-height: 1.8;
      box-shadow: var(--shadow-medium);
    }

    .footer-note strong {
      color: var(--white);
    }

    .dot-nav {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 12px;
    }

    .dot-nav button {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(28,38,99,0.16);
      transition: transform var(--transition), background var(--transition);
    }

    .dot-nav button.active {
      background: var(--pink);
      transform: scale(1.25);
    }

    .screen-footer {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .tiny-stat {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 11px;
      color: #5f6e8b;
    }

    .screen.b .tiny-stat {
      color: rgba(255,255,255,0.72);
    }

    .tiny-stat strong {
      color: var(--dark-blue);
    }

    .screen.b .tiny-stat strong {
      color: var(--white);
    }

    @media (min-width: 980px) {
      .layout {
        grid-template-columns: minmax(0, 430px) minmax(0, 1fr);
        align-items: start;
      }

      .hero {
        padding: 24px 24px 20px;
      }

      .hero-stats {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }

    @media (max-width: 979px) {
      .phone-stage {
        min-height: auto;
      }
    }

    @media (max-width: 480px) {
      .page {
        width: min(100%, calc(100% - 14px));
        padding-top: 10px;
      }

      .hero,
      .panel {
        padding-left: 14px;
        padding-right: 14px;
      }

      .tabs,
      .thumbs,
      .hero-stats,
      .mini-grid {
        grid-template-columns: 1fr;
      }

      .compare-header,
      .compare-row {
        grid-template-columns: 1.1fr repeat(3, minmax(0, 58px));
        gap: 6px;
        padding-left: 10px;
        padding-right: 10px;
      }

      .stress-row {
        grid-template-columns: 74px 1fr auto;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div class="eyebrow">ASO検証 / 2026-04-22 / ストアPV→DL率改善</div>
      <h1>「何ができるアプリか」を<br>3秒で理解させるストアスクショ。</h1>
      <p>
        目的は <strong>ストアPV→DL率 17.3% を 25% に引き上げる</strong> こと。
        AI査定、出費管理、比較訴求を <strong>数字・グラフ・比較表</strong> で分担し、
        iOS向けA、Android向けB、比較訴求Cを1ファイルで検証できるようにしています。
      </p>

      <div class="hero-stats">
        <article class="hero-stat">
          <span>現状CVR</span>
          <strong>17.3%</strong>
          <small>ストア詳細ページ閲覧からDLへの現状値</small>
        </article>
        <article class="hero-stat">
          <span>目標CVR</span>
          <strong>25.0%</strong>
          <small>必要改善幅は +7.7pt</small>
        </article>
        <article class="hero-stat">
          <span>差別化軸</span>
          <strong>8000社</strong>
          <small>オークション規模とAI査定を同時訴求</small>
        </article>
        <article class="hero-stat">
          <span>不安解消</span>
          <strong>電話0本</strong>
          <small>相場チェック時の心理障壁を最小化</small>
        </article>
      </div>

      <div class="hero-progress">
        <div class="hero-progress-head">
          <strong>CVR改善進捗イメージ</strong>
          <span>17.3% → 25.0%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill"></div>
        </div>
        <div class="progress-labels">
          <span>現状 17.3%</span>
          <span>到達率 69.2%</span>
          <span>目標 25.0%</span>
        </div>
      </div>

      <div class="tabs" role="tablist" aria-label="ストアスクリーン切り替え">
        <button class="tab active" data-screen="a" role="tab" aria-selected="true">
          <span>スクショA / iOS向け</span>
          <strong>AI査定を最初の1枚で理解させる</strong>
        </button>
        <button class="tab" data-screen="b" role="tab" aria-selected="false">
          <span>スクショB / Android向け</span>
          <strong>出費管理 + 将来予測で残す理由を作る</strong>
        </button>
        <button class="tab" data-screen="c" role="tab" aria-selected="false">
          <span>スクショC / 比較訴求</span>
          <strong>相場チェック時の電話0本を可視化</strong>
        </button>
      </div>
    </section>

    <section class="layout">
      <div class="viewer">
        <section class="panel">
          <div class="stage-head">
            <div>
              <h2 id="stageTitle">スクショA: AI査定機能を全面に出したiOS向け</h2>
              <p id="stageCopy">現在価格、3か月後、6か月後の予測を1画面で見せ、個人情報不要の安心感まで同居させる構成です。</p>
            </div>
            <div class="pill" id="stagePill">主訴求: AI査定</div>
          </div>

          <div class="phone-stage">
            <article class="phone active" data-phone="a" aria-label="ストアスクショA">
              <div class="screen a">
                <div class="status-row">
                  <div class="brand-mark"><span class="brand-dot"></span>UcarPAC App</div>
                  <div class="status-chip">iOS / 1枚目スクショ</div>
                </div>

                <h3 class="headline">AIが愛車の価格を<br><strong>すぐ予測</strong></h3>
                <p class="subline">
                  2021年式 トヨタ ハリアー Z Leather Package / 29,800km
                </p>

                <div class="chip-row">
                  <div class="chip">個人情報入力なし</div>
                  <div class="chip">最短30秒で相場確認</div>
                  <div class="chip">写真追加で精度 +14%</div>
                </div>

                <section class="metric-card">
                  <div class="metric-top">
                    <div>
                      <span class="metric-label">AI査定価格</span>
                      <strong class="metric-value" id="forecastPrice">318.4万円</strong>
                      <div class="metric-caption" id="forecastCaption">現在の相場中央値。売り時スコアは 92 / 100。</div>
                    </div>
                    <div class="metric-badge">
                      <span>予測信頼度</span>
                      <strong id="forecastConfidence">92%</strong>
                    </div>
                  </div>

                  <div class="switch-row" role="group" aria-label="価格予測切り替え">
                    <button class="switch-chip active forecast-chip" data-forecast="now">現在</button>
                    <button class="switch-chip forecast-chip" data-forecast="three">3か月後</button>
                    <button class="switch-chip forecast-chip" data-forecast="six">6か月後</button>
                  </div>
                </section>

                <section class="chart-card">
                  <div class="chart-head">
                    <strong>価格推移グラフ</strong>
                    <span id="forecastDelta">売り時指数 +2.4万円</span>
                  </div>
                  <svg viewBox="0 0 320 170" width="100%" height="170" aria-hidden="true">
                    <defs>
                      <linearGradient id="forecastFill" x1="0%" x2="0%" y1="0%" y2="100%">
                        <stop offset="0%" stop-color="#4db4ff" stop-opacity="0.28"></stop>
                        <stop offset="100%" stop-color="#4db4ff" stop-opacity="0"></stop>
                      </linearGradient>
                    </defs>
                    <line x1="22" y1="24" x2="22" y2="144" stroke="rgba(28,38,99,0.12)" stroke-width="1"></line>
                    <line x1="22" y1="144" x2="302" y2="144" stroke="rgba(28,38,99,0.12)" stroke-width="1"></line>
                    <path d="M22 48 C72 56, 102 60, 152 78 C190 90, 230 98, 302 116 L302 144 L22 144 Z" fill="url(#forecastFill)"></path>
                    <path d="M22 48 C72 56, 102 60, 152 78 C190 90, 230 98, 302 116" fill="none" stroke="#1ddcff" stroke-width="4" stroke-linecap="round"></path>
                    <circle cx="22" cy="48" r="7" fill="#1c2663"></circle>
                    <circle cx="152" cy="78" r="7" fill="#1c2663"></circle>
                    <circle cx="302" cy="116" r="7" fill="#1c2663"></circle>
                    <circle id="forecastMarker" cx="22" cy="48" r="12" fill="rgba(248,76,162,0.16)"></circle>
                    <circle id="forecastMarkerCore" cx="22" cy="48" r="6" fill="#f84ca2"></circle>
                    <text x="22" y="160" text-anchor="middle" font-size="11" fill="#63708c">現在</text>
                    <text x="152" y="160" text-anchor="middle" font-size="11" fill="#63708c">3か月後</text>
                    <text x="302" y="160" text-anchor="middle" font-size="11" fill="#63708c">6か月後</text>
                  </svg>
                </section>

                <div class="mini-grid">
                  <article class="mini-card">
                    <span>オークション規模</span>
                    <strong>8,000社</strong>
                    <small>売却時は多数の入札で最高額を狙える</small>
                  </article>
                  <article class="mini-card">
                    <span>おすすめ理由</span>
                    <strong>今が高水準</strong>
                    <small>同型平均より +11.2万円のレンジ</small>
                  </article>
                </div>

                <button class="cta">個人情報なしで相場を見る</button>
                <div class="disclaimer">※ 参考価格。走行距離・カラー・装備・写真入力でさらに精度が上がります。</div>
              </div>
            </article>

            <article class="phone" data-phone="b" aria-label="ストアスクショB">
              <div class="screen b">
                <div class="status-row">
                  <div class="brand-mark" style="color:#fff;"><span class="brand-dot"></span>UcarPAC App</div>
                  <div class="status-chip">Android / 2枚目スクショ</div>
                </div>

                <h3 class="headline">出費管理と相場予測を<br><strong>1つの画面で</strong></h3>
                <p class="subline">
                  2020年式 ホンダ フリード G / 41,200km / 家計に近い感覚で維持費を把握
                </p>

                <div class="chip-row">
                  <div class="chip">ガソリン・保険を自動集計</div>
                  <div class="chip">次回車検まで 87日</div>
                  <div class="chip">売り時アラート対応</div>
                </div>

                <section class="metric-card">
                  <div class="metric-top">
                    <div>
                      <span class="metric-label">出費サマリー</span>
                      <strong class="metric-value" id="expenseTotal">20.3万円</strong>
                      <div class="metric-caption" id="expenseCaption">直近12か月の維持費。売却判断に必要な固定費が一目でわかります。</div>
                    </div>
                    <div class="metric-badge">
                      <span>将来予測</span>
                      <strong id="futurePrice">182.6万円</strong>
                    </div>
                  </div>

                  <div class="switch-row" role="group" aria-label="出費単位切り替え">
                    <button class="switch-chip active expense-chip" data-expense="month">今月</button>
                    <button class="switch-chip expense-chip" data-expense="year">年換算</button>
                    <button class="switch-chip expense-chip" data-expense="sell">売却時差分</button>
                  </div>
                </section>

                <section class="chart-card">
                  <div class="chart-head">
                    <strong>カテゴリ別の出費内訳</strong>
                    <span id="expenseHint">月ごとの負担を圧縮しやすい順に表示</span>
                  </div>

                  <div class="screen-footer">
                    <div class="tiny-stat"><span>ガソリン</span><strong id="fuelValue">12,400円</strong></div>
                    <div class="progress-track"><div class="progress-fill" id="fuelBar" style="width:68%;"></div></div>

                    <div class="tiny-stat"><span>保険</span><strong id="insuranceValue">4,800円</strong></div>
                    <div class="progress-track"><div class="progress-fill" id="insuranceBar" style="width:38%;"></div></div>

                    <div class="tiny-stat"><span>駐車場</span><strong id="parkingValue">0円</strong></div>
                    <div class="progress-track"><div class="progress-fill" id="parkingBar" style="width:8%;"></div></div>

                    <div class="tiny-stat"><span>整備・消耗品</span><strong id="serviceValue">3,100円</strong></div>
                    <div class="progress-track"><div class="progress-fill" id="serviceBar" style="width:22%;"></div></div>
