      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .stage-title h2 {
      margin: 0;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .stage-title p {
      margin: 6px 0 0;
      font-size: 12px;
      line-height: 1.8;
      color: #6b758f;
    }

    .swipe-hint {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 38px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      box-shadow: var(--shadow-light);
      white-space: nowrap;
    }

    .swipe-hint::before {
      content: "⇄";
      font-size: 16px;
      color: var(--pink);
      animation: nudge 1.6s ease-in-out infinite;
    }

    .deck {
      overflow: hidden;
      border-radius: 28px;
      user-select: none;
    }

    .deck-track {
      display: flex;
      transition: transform 420ms cubic-bezier(.2, .9, .2, 1);
      will-change: transform;
    }

    .slide {
      flex: 0 0 100%;
      min-width: 100%;
      display: grid;
      place-items: center;
      padding: 12px 4px 2px;
    }

    .phone {
      position: relative;
      width: min(100%, var(--phone-width));
      max-width: 100%;
      border-radius: var(--radius-phone);
      padding: 10px;
      background: linear-gradient(180deg, #232a3c 0%, #0e1325 100%);
      box-shadow: 0 24px 80px rgba(10, 19, 72, 0.24);
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      width: 140px;
      height: 26px;
      border-radius: 0 0 18px 18px;
      background: #0a1021;
      z-index: 4;
    }

    .screen {
      position: relative;
      width: 100%;
      min-height: 740px;
      overflow: hidden;
      border-radius: calc(var(--radius-phone) - 8px);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    }

    .screenshot-a {
      background: var(--gradient-a);
      color: var(--dark-blue);
    }

    .screenshot-b {
      background: var(--gradient-b);
      color: var(--white);
    }

    .screenshot-c {
      background: var(--gradient-c);
      color: var(--dark-blue);
    }

    .float-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(3px);
      opacity: 0.75;
      pointer-events: none;
      animation: float 7s ease-in-out infinite;
    }

    .float-orb.a1 {
      width: 92px;
      height: 92px;
      left: -24px;
      top: 110px;
      background: rgba(29, 220, 255, 0.18);
    }

    .float-orb.a2 {
      width: 126px;
      height: 126px;
      right: -24px;
      top: 72px;
      background: rgba(248, 76, 162, 0.15);
      animation-delay: -1.8s;
    }

    .float-orb.b1 {
      width: 110px;
      height: 110px;
      right: -18px;
      top: 140px;
      background: rgba(29, 220, 255, 0.16);
    }

    .float-orb.b2 {
      width: 84px;
      height: 84px;
      left: -10px;
      bottom: 210px;
      background: rgba(248, 76, 162, 0.18);
      animation-delay: -2.1s;
    }

    .float-orb.c1 {
      width: 108px;
      height: 108px;
      left: -28px;
      top: 120px;
      background: rgba(248, 76, 162, 0.15);
    }

    .float-orb.c2 {
      width: 94px;
      height: 94px;
      right: -14px;
      bottom: 180px;
      background: rgba(29, 220, 255, 0.16);
      animation-delay: -1.6s;
    }

    .statusbar {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 18px 0;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.05em;
    }

    .status-icons {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-icons i {
      display: block;
      width: 16px;
      height: 9px;
      border-radius: 999px;
      border: 1.5px solid currentColor;
      opacity: 0.7;
    }

    .status-icons b {
      display: block;
      width: 24px;
      height: 10px;
      border-radius: 999px;
      background: currentColor;
      opacity: 0.85;
    }

    .shot {
      position: relative;
      z-index: 2;
      padding: 28px 18px 24px;
    }

    .shot-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .platform-badge,
    .mini-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    .platform-badge {
      background: rgba(255, 255, 255, 0.78);
      color: var(--dark-blue);
      box-shadow: var(--shadow-light);
    }

    .screenshot-b .platform-badge {
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.94);
    }

    .mini-badge {
      background: rgba(248, 76, 162, 0.14);
      color: var(--pink);
    }

    .screenshot-b .mini-badge {
      background: rgba(248, 76, 162, 0.18);
      color: #ffd8e8;
    }

    .hero-shot-title {
      margin: 16px 0 8px;
      font-size: 32px;
      line-height: 1.22;
      letter-spacing: -0.06em;
      font-weight: 900;
    }

    .hero-shot-copy {
      margin: 0;
      font-size: 14px;
      line-height: 1.85;
      color: rgba(28, 38, 99, 0.76);
    }

    .screenshot-b .hero-shot-copy {
      color: rgba(255, 255, 255, 0.78);
    }

    .glass-card {
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      padding: 16px;
      margin-top: 16px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(255, 255, 255, 0.78);
      box-shadow: var(--shadow-light);
    }

    .glass-card.dark {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.10);
      color: var(--white);
    }

    .glass-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 20%, rgba(255, 255, 255, 0.24) 50%, transparent 80%);
      transform: translateX(-140%);
      animation: shimmer 4.5s linear infinite;
      pointer-events: none;
    }

    .car-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 40px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(9, 19, 85, 0.06);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .screenshot-b .car-chip {
      background: rgba(255, 255, 255, 0.10);
      color: rgba(255, 255, 255, 0.92);
    }

    .car-chip::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--pink);
      box-shadow: 0 0 0 6px rgba(248, 76, 162, 0.12);
    }

    .value-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 12px;
      margin-top: 14px;
      align-items: stretch;
    }

    .value-main {
      border-radius: 22px;
      padding: 16px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.98), rgba(29, 46, 147, 0.94));
      color: var(--white);
      box-shadow: var(--shadow-medium);
    }

    .value-main .label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      opacity: 0.8;
    }

    .value-main strong {
      display: block;
      margin-top: 10px;
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .value-main small {
      display: block;
      margin-top: 10px;
      font-size: 12px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.82);
    }

    .value-side {
      display: grid;
      gap: 12px;
    }

    .mini-stat {
      padding: 14px;
      border-radius: 20px;
      background: rgba(248, 76, 162, 0.10);
    }

    .mini-stat strong {
      display: block;
      margin-top: 6px;
      font-size: 22px;
      line-height: 1.3;
      letter-spacing: -0.04em;
      color: var(--dark-blue);
    }

    .mini-stat span,
    .mini-stat small {
      display: block;
    }

    .mini-stat span {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
      letter-spacing: 0.04em;
    }

    .mini-stat small {
      margin-top: 5px;
      font-size: 11px;
      line-height: 1.6;
      color: #6b758f;
    }

    .choice-row {
      display: flex;
      gap: 10px;
      overflow-x: auto;
      padding-bottom: 4px;
      margin-top: 14px;
      scrollbar-width: none;
    }

    .choice-row::-webkit-scrollbar {
      display: none;
    }

    .choice-chip {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 96px;
      min-height: 44px;
      padding: 0 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.90);
      color: var(--text-black);
      border: 1px solid rgba(28, 38, 99, 0.08);
      font-size: 13px;
      font-weight: 800;
      transition: transform var(--transition), background var(--transition), color var(--transition), border-color var(--transition);
      box-shadow: var(--shadow-light);
    }

    .choice-chip.is-active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
      transform: translateY(-1px);
    }

    .screenshot-b .choice-chip {
      background: rgba(255, 255, 255, 0.10);
      color: rgba(255, 255, 255, 0.86);
      border-color: rgba(255, 255, 255, 0.12);
      box-shadow: none;
    }

    .screenshot-b .choice-chip.is-active {
      background: var(--pink);
      border-color: var(--pink);
      color: var(--white);
    }

    .trust-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .trust-item {
      min-height: 78px;
      padding: 14px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.74);
      text-align: center;
      box-shadow: var(--shadow-light);
    }

    .trust-item strong {
      display: block;
      font-size: 22px;
      line-height: 1.2;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
    }

    .trust-item span {
      display: block;
      margin-top: 6px;
      font-size: 11px;
      line-height: 1.6;
      color: #69738d;
      font-weight: 700;
    }

    .screenshot-b .trust-item {
      background: rgba(255, 255, 255, 0.09);
      box-shadow: none;
    }

    .screenshot-b .trust-item strong,
    .screenshot-b .trust-item span {
      color: rgba(255, 255, 255, 0.94);
    }

    .caption-strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .caption-strip strong {
      font-size: 14px;
      letter-spacing: -0.02em;
    }

    .screenshot-b .caption-strip {
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.94);
    }

    .forecast-panel {
      margin-top: 16px;
      padding: 18px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .forecast-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
    }

    .forecast-head .left span,
    .forecast-head .right span {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      opacity: 0.72;
    }

    .forecast-head .left strong,
    .forecast-head .right strong {
      display: block;
      margin-top: 6px;
      font-size: 28px;
      line-height: 1.2;
      letter-spacing: -0.05em;
    }

    .forecast-graph {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      align-items: end;
      height: 176px;
      margin-top: 18px;
    }

    .forecast-bar-wrap {
      display: grid;
      justify-items: center;
      gap: 10px;
    }

    .forecast-bar {
      position: relative;
      width: 62px;
      height: var(--bar-height, 120px);
      border-radius: 22px 22px 14px 14px;
      background: linear-gradient(180deg, rgba(29, 220, 255, 0.98), rgba(77, 180, 255, 0.44));
      box-shadow: 0 14px 34px rgba(29, 220, 255, 0.24);
      transition: height var(--transition);
    }

    .forecast-bar.secondary {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.18));
      box-shadow: none;
    }

    .forecast-bar.tertiary {
      background: linear-gradient(180deg, rgba(248, 76, 162, 0.98), rgba(248, 76, 162, 0.34));
      box-shadow: 0 14px 34px rgba(248, 76, 162, 0.22);
    }

    .forecast-bar::after {
      content: attr(data-value);
      position: absolute;
      left: 50%;
      top: 12px;
      transform: translateX(-50%);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: rgba(255, 255, 255, 0.94);
      white-space: nowrap;
    }

    .forecast-bar-wrap span {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
      opacity: 0.86;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 16px;
    }

    .cost-box {
      padding: 14px 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
    }

    .cost-box span {
      display: block;
      font-size: 11px;
      font-weight: 700;
      opacity: 0.72;
      letter-spacing: 0.04em;
    }

    .cost-box strong {
      display: block;
      margin-top: 7px;
      font-size: 18px;
      line-height: 1.3;
      letter-spacing: -0.03em;
    }

    .comparison-stage {
      margin-top: 18px;
      display: grid;
      gap: 14px;
    }

    .zero-meter {
      display: grid;
      justify-items: center;
      gap: 10px;
      padding: 18px 16px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.98), rgba(29, 46, 147, 0.94));
      color: var(--white);
      box-shadow: var(--shadow-medium);
    }

    .zero-ring {
      position: relative;
      display: grid;
      place-items: center;
      width: 156px;
      height: 156px;
      border-radius: 50%;
      background:
        radial-gradient(circle at center, rgba(255, 255, 255, 0.08) 0 52%, transparent 53% 100%),
        conic-gradient(from 0deg, #1ddcff 0 280deg, rgba(255, 255, 255, 0.12) 280deg 360deg);
      animation: spinSlow 9s linear infinite;
    }

    .zero-ring::before {
      content: "";
      position: absolute;
      inset: 16px;
      border-radius: 50%;
      background: linear-gradient(180deg, #10194f, #1a2872);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    .zero-ring strong {
      position: relative;
      z-index: 1;
      font-family: var(--font-number);
      font-size: 58px;
      line-height: 1;
      letter-spacing: -0.06em;
    }

    .zero-ring span {
      position: relative;
      z-index: 1;
      margin-top: -6px;
      font-size: 12px;
      font-weight: 800;
      opacity: 0.8;
      letter-spacing: 0.06em;
    }

    .zero-meter p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      text-align: center;
      color: rgba(255, 255, 255, 0.84);
    }

    .compare-cards {
      display: grid;
      gap: 10px;
    }

    .compare-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      padding: 15px 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-light);
      align-items: center;
    }

    .compare-card h3 {
      margin: 0;
      font-size: 15px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .compare-card p {
      margin: 6px 0 0;
      font-size: 12px;
      line-height: 1.7;
      color: #65708a;
    }

    .compare-score {
      display: inline-grid;
      place-items: center;
      min-width: 78px;
      min-height: 52px;
      padding: 0 12px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.06);
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .compare-score.hot {
      background: rgba(248, 76, 162, 0.12);
      color: var(--pink);
    }

    .rival-meter {
      margin-top: 16px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-light);
    }

    .meter-row {
      display: grid;
      grid-template-columns: 74px 1fr auto;
      gap: 10px;
      align-items: center;
      margin-top: 12px;
    }

    .meter-row:first-child {
      margin-top: 0;
    }

    .meter-row span,
    .meter-row strong {
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .meter-bar {
      position: relative;
      height: 12px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .meter-bar b {
      position: absolute;
      inset: 0 auto 0 0;
      width: var(--fill, 50%);
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width var(--transition);
    }

    .meter-bar.pink b {
      background: var(--gradient-pink);
    }

    .dots {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 14px;
    }

    .dot-btn {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: rgba(28, 38, 99, 0.18);
      transition: transform var(--transition), background var(--transition), box-shadow var(--transition);
    }

    .dot-btn.is-active {
      background: var(--pink);
      transform: scale(1.15);
      box-shadow: 0 0 0 8px rgba(248, 76, 162, 0.10);
    }

    .notes-panel {
      margin-top: 16px;
      padding: 16px;
    }

    .notes-grid {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .note-card {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.86);
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .note-card .top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .note-card strong {
      font-size: 15px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .note-card span {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(9, 19, 85, 0.06);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .note-card p {
      margin: 10px 0 14px;
      font-size: 13px;
      line-height: 1.8;
      color: #66718a;
    }

    .note-card button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.98);
      border: 1px solid rgba(28, 38, 99, 0.10);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
      box-shadow: var(--shadow-light);
    }

    .store-footer {
      margin-top: 18px;
      text-align: center;
      font-size: 11px;
      line-height: 1.7;
      color: #73809b;
    }

    .store-footer strong {
      color: var(--dark-blue);
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 1;
      }
      50% {
        transform: scale(1.12);
        opacity: 0.78;
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-12px);
      }
    }

    @keyframes shimmer {
      0% {
        transform: translateX(-140%);
      }
      100% {
        transform: translateX(160%);
      }
    }

    @keyframes nudge {
      0%, 100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(4px);
      }
    }

    @keyframes spinSlow {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

    @media (max-width: 1024px) {
      .main-grid {
        grid-template-columns: 1fr;
      }

      .notes-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 767px) {
      .page {
        width: min(100%, calc(100% - 16px));
        padding-top: 12px;
      }

      .hero {
