  <script>
    (function () {
      const tabs = Array.from(document.querySelectorAll(".tab"));
      const screens = Array.from(document.querySelectorAll(".screen"));
      const toggles = Array.from(document.querySelectorAll(".toggle"));
      const root = document.documentElement;
      const meterA = document.getElementById("meterA");
      const chartFill = document.getElementById("chartFill");
      const forecastPath = document.getElementById("forecastPath");
      const zeroCount = document.getElementById("zeroCount");

      function showScreen(id) {
        tabs.forEach((tab) => {
          tab.classList.toggle("active", tab.dataset.screen === id);
        });
        screens.forEach((screen) => {
          const active = screen.id === id;
          screen.classList.toggle("active", active);
          if (active) {
            screen.classList.remove("fade-in");
            void screen.offsetWidth;
            screen.classList.add("fade-in");
          }
        });
      }

      function setTheme(mode) {
        toggles.forEach((toggle) => {
          toggle.classList.toggle("active", toggle.dataset.theme === mode);
        });

        if (mode === "focus") {
          root.style.setProperty("--warm-gradient", "linear-gradient(135deg, #f7fbff 0%, #ffe6f1 38%, #ffffff 100%)");
          root.style.setProperty("--sunrise-gradient", "linear-gradient(180deg, #f8fbff 0%, #fff0f7 58%, #ffffff 100%)");
          meterA.style.width = "84%";
          chartFill.style.height = "72%";
          forecastPath.setAttribute("d", "M8 138 C42 130, 68 120, 96 104 S150 82, 176 66 S228 40, 292 18");
          zeroCount.textContent = "0本";
        } else {
          root.style.setProperty("--warm-gradient", "linear-gradient(135deg, #fff4ea 0%, #ffd8e8 48%, #e4f7ff 100%)");
          root.style.setProperty("--sunrise-gradient", "linear-gradient(180deg, #fffaf4 0%, #ffe3ef 55%, #fff 100%)");
          meterA.style.width = "72%";
          chartFill.style.height = "64%";
          forecastPath.setAttribute("d", "M8 132 C42 126, 70 118, 96 106 S150 86, 175 74 S228 48, 292 24");
          zeroCount.textContent = "0本";
        }
      }

      tabs.forEach((tab) => {
        tab.addEventListener("click", function () {
          showScreen(this.dataset.screen);
        });
      });

      toggles.forEach((toggle) => {
        toggle.addEventListener("click", function () {
          setTheme(this.dataset.theme);
        });
      });

      const pulseButtons = ["ctaA1", "ctaA2", "ctaB1", "ctaB2", "ctaC1", "ctaC2"];
      pulseButtons.forEach((id) => {
        const button = document.getElementById(id);
        if (!button) return;
        button.addEventListener("click", function () {
          this.classList.add("active-mood");
          setTimeout(() => this.classList.remove("active-mood"), 420);
          if (id === "ctaC2") {
            const focusToggle = document.querySelector('.toggle[data-theme="focus"]');
            focusToggle.click();
          }
          if (id === "ctaA2") {
            showScreen("screen-a");
            meterA.style.width = meterA.style.width === "58%" ? "72%" : "58%";
          }
          if (id === "ctaB2") {
            chartFill.style.height = chartFill.style.height === "76%" ? "64%" : "76%";
          }
        });
      });

      showScreen("screen-a");
      setTheme("warm");
    })();
  </script>
</body>
