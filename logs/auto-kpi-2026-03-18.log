      gap: 12px;
      align-items: center;
      font-size: 12px;
      color: var(--text-black);
    }

    .legend-left {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      min-width: 0;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex: 0 0 10px;
    }

    .trend-card {
      border-radius: 18px;
      padding: 14px 14px 12px;
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,248,251,0.96));
      box-shadow: inset 0 0 0 1px rgba(248,76,162,0.08);
    }

    .trend-card .price-number strong {
      font-size: 34px;
    }

    .compare-grid {
      display: grid;
      gap: 10px;
    }

    .compare-head,
    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 0.9fr 0.9fr 0.9fr;
      gap: 8px;
      align-items: center;
    }

    .compare-head {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 800;
      padding: 0 4px;
    }

    .compare-row {
      background: rgba(255,255,255,0.92);
      border-radius: 16px;
      padding: 12px 10px;
      font-size: 12px;
      box-shadow: 0 10px 20px rgba(28,38,99,0.06);
    }

    .compare-row.highlight {
      background: linear-gradient(90deg, rgba(248,76,162,0.11), rgba(255,255,255,0.94));
      box-shadow: 0 14px 28px rgba(248,76,162,0.12);
    }

    .brand {
      font-weight: 800;
      color: var(--dark-blue);
    }

    .ok,
    .ng {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 30px;
      border-radius: 999px;
      padding: 0 10px;
      font-weight: 800;
    }

    .ok {
      background: rgba(29,220,255,0.14);
      color: var(--dark-blue);
    }

    .ng {
      background: rgba(248,76,162,0.14);
      color: #c83378;
    }

    .footer-note {
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
      text-align: center;
    }

    .pulse {
      animation: pulse 1.9s ease-in-out infinite;
    }

    .hidden {
      display: none !important;
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    @keyframes float {
      0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.88; }
      50% { transform: rotate(45deg) translateY(-8px); opacity: 1; }
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(248,76,162,0.22); }
      50% { box-shadow: 0 0 0 10px rgba(248,76,162,0); }
    }

    @media (min-width: 980px) {
      .screens {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .screen-card {
        min-height: 100%;
      }
    }

    @media (max-width: 390px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .expense-summary {
        grid-template-columns: 1fr;
      }

      .cta-row {
        grid-template-columns: 1fr;
      }

      .compare-head,
      .compare-row {
        grid-template-columns: 1.1fr 0.8fr 0.8fr 0.8fr;
        font-size: 11px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="toolbar" aria-label="スクリーン切り替え">
      <button class="chip active" data-target="all">3案まとめて見る</button>
      <button class="chip" data-target="shot-a">スクショA</button>
      <button class="chip" data-target="shot-b">スクショB</button>
      <button class="chip" data-target="shot-c">スクショC</button>
    </div>

    <section class="intro">
      <span class="eyebrow">ストアPV → DL率改善に向けた感情訴求プロトタイプ</span>
      <h1>「売るか迷う」気持ちに寄り添いながら、<br>安心してDLしたくなる3枚構成</h1>
      <p>
        AI査定の安心感、出費管理で続ける理由、そして「電話0本」という明快な差別化を、
        暖色アクセントとやわらかな手書き表現でまとめたストアスクリーン案です。
      </p>
    </section>

    <section class="screens">
      <article class="screen-card screen-block" id="shot-a">
        <div class="screen-meta">
          <div>
            <h2 class="screen-title">1. ストアスクショA</h2>
            <p class="screen-note">iOS向け / AI査定を全面訴求 / 不安を安心に変えるファーストビュー</p>
          </div>
