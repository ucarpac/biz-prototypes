      padding: 10px;
      box-shadow:
        0 30px 80px rgba(28,38,99,0.22),
        inset 0 0 0 1px rgba(255,255,255,0.12);
      position: relative;
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      width: 140px;
      height: 28px;
      background: #0a0f2d;
      border-radius: 0 0 18px 18px;
      z-index: 4;
    }

    .screen {
      position: relative;
      min-height: calc(min(var(--phone-height), calc(100vh - 80px)) - 20px);
      border-radius: 28px;
      overflow: hidden;
      background: var(--back-white);
      display: flex;
      flex-direction: column;
    }

    .screen.a {
      background:
        radial-gradient(circle at top right, rgba(29,220,255,0.26), transparent 24%),
        linear-gradient(180deg, #0b185c 0%, #162572 28%, #f8fbff 28%, #f8fbff 100%);
    }

    .screen.b {
      background:
        radial-gradient(circle at top left, rgba(248,76,162,0.22), transparent 28%),
        linear-gradient(180deg, #fff6fb 0%, #fff8fc 26%, #f8fbff 26%, #f8fbff 100%);
    }

    .screen.c {
      background:
        radial-gradient(circle at 85% 6%, rgba(29,220,255,0.18), transparent 20%),
        linear-gradient(180deg, #071147 0%, #121f69 24%, #f7faff 24%, #f7faff 100%);
    }

    .statusbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 18px 8px;
      color: var(--white);
      font-size: 12px;
      font-weight: 700;
      position: relative;
      z-index: 3;
    }

    .top-content {
      padding: 8px 20px 0;
      position: relative;
      z-index: 2;
    }

    .platform-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border-radius: 999px;
      padding: 8px 12px;
      background: rgba(255,255,255,0.16);
      color: var(--white);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      backdrop-filter: blur(10px);
    }

    .platform-pill .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #79ffca;
      box-shadow: 0 0 0 4px rgba(121,255,202,0.18);
      animation: pulse 1.8s infinite;
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.9; }
      70% { transform: scale(1.35); opacity: 0.2; }
      100% { transform: scale(1); opacity: 0.9; }
    }

    .headline {
      margin-top: 16px;
      color: var(--white);
    }

    .headline .kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.14);
      font-size: 11px;
      font-weight: 700;
    }

    .headline h2 {
      margin: 0;
      font-size: 33px;
      line-height: 1.32;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .headline p {
      margin: 10px 0 0;
      color: rgba(255,255,255,0.82);
      font-size: 14px;
      line-height: 1.7;
    }

    .main-pane {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 14px;
      padding: 18px 16px 18px;
    }

    .panel {
      border-radius: 20px;
      background: rgba(255,255,255,0.98);
      box-shadow: 0 12px 32px rgba(0,0,0,0.08);
      padding: 16px;
    }

    .panel.soft {
      background: linear-gradient(180deg, #ffffff, #f7fbff);
    }

    .panel.dark {
      background: var(--gradient-auction);
      color: var(--white);
    }

    .card-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .card-title strong {
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .card-title span {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .dark .card-title strong,
    .dark .card-title span {
      color: var(--white);
    }

    .scan-card {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 14px;
      align-items: center;
    }

    .car-thumb {
      height: 92px;
      border-radius: 18px;
      background:
        linear-gradient(145deg, rgba(9,19,85,0.06), rgba(29,220,255,0.12)),
        linear-gradient(180deg, #ffffff, #f3f7ff);
      position: relative;
      overflow: hidden;
    }

    .car-thumb::before {
      content: "";
      position: absolute;
      width: 66px;
      height: 26px;
      border-radius: 30px 20px 12px 12px;
      background: linear-gradient(90deg, #28357c, #4db4ff);
      left: 12px;
      top: 34px;
      box-shadow: 0 10px 24px rgba(28,38,99,0.16);
    }

    .car-thumb::after {
      content: "";
      position: absolute;
      width: 72px;
      height: 10px;
      border-radius: 999px;
      background: rgba(9,19,85,0.12);
      left: 10px;
      bottom: 14px;
      filter: blur(3px);
    }

    .scan-card h3 {
      margin: 0 0 4px;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .scan-card p {
      margin: 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 30px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      line-height: 1;
      white-space: nowrap;
    }

    .badge.pink {
      background: var(--back-light-pink);
      color: var(--pink);
    }

    .badge.blue {
      background: rgba(64,153,255,0.12);
      color: var(--button-link1);
    }

    .badge.navy {
      background: rgba(9,19,85,0.12);
      color: var(--dark-blue);
    }

    .price-box {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 12px;
      padding: 14px;
      border-radius: 18px;
      background:
        linear-gradient(135deg, rgba(248,76,162,0.08), rgba(29,220,255,0.14));
      margin-top: 14px;
    }

    .price-box small {
      display: block;
      margin-bottom: 4px;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
    }

    .price-value {
      color: var(--dark-blue);
      font-size: 36px;
      line-height: 1.2;
      font-family: var(--font-number);
      letter-spacing: 0.02em;
    }

    .price-trend {
      color: #00a86b;
      font-size: 12px;
      font-weight: 800;
      text-align: right;
    }

    .steps {
      display: flex;
      gap: 10px;
      margin-top: 14px;
    }

    .step {
      flex: 1;
      min-height: 74px;
      border-radius: 16px;
      padding: 12px 10px;
      background: #f6f8ff;
      border: 1px solid rgba(28,38,99,0.06);
      transition: transform 220ms ease, background 220ms ease, color 220ms ease, box-shadow 220ms ease;
    }

    .step.is-on {
      background: linear-gradient(135deg, rgba(29,220,255,0.18), rgba(248,76,162,0.18));
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(28,38,99,0.08);
    }

    .step b {
      display: block;
      margin-bottom: 5px;
      font-size: 11px;
      color: var(--pink);
      line-height: 1.4;
    }

    .step span {
      display: block;
      font-size: 12px;
      line-height: 1.5;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .diagnosis-flow {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .option-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .option {
      appearance: none;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      border-radius: var(--radius-chip);
      min-height: 43px;
      padding: 0 14px;
      font-size: 13px;
      font-weight: 700;
      transition: all 180ms ease;
      cursor: pointer;
    }

    .option.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
      box-shadow: 0 10px 24px rgba(28,38,99,0.15);
    }

    .graph {
      height: 168px;
      margin-top: 12px;
      padding: 12px 12px 8px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(29,220,255,0.12), rgba(248,76,162,0.08)),
        #fff;
      position: relative;
      overflow: hidden;
    }

    .graph-grid {
      position: absolute;
      inset: 14px 12px 28px;
      background-image:
        linear-gradient(to right, rgba(28,38,99,0.06) 1px, transparent 1px),
        linear-gradient(to top, rgba(28,38,99,0.06) 1px, transparent 1px);
      background-size: 25% 100%, 100% 25%;
      border-radius: 10px;
    }

    .graph svg {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
    }

    .graph-labels {
      position: absolute;
      left: 14px;
      right: 14px;
      bottom: 8px;
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      z-index: 2;
    }

    .mini-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 12px;
    }

    .mini-stat {
      border-radius: 16px;
      background: rgba(255,255,255,0.12);
      padding: 12px 10px;
      text-align: center;
    }

    .mini-stat strong {
      display: block;
      font-size: 20px;
      line-height: 1.3;
      font-family: var(--font-number);
      margin-bottom: 4px;
    }

    .mini-stat span {
      font-size: 11px;
      line-height: 1.4;
      color: rgba(255,255,255,0.82);
    }

    .expense-bars {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 8px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: 74px 1fr auto;
      align-items: center;
      gap: 10px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: #edf2ff;
      overflow: hidden;
    }

    .bar > i {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #4db4ff, #f84ca2);
      transform-origin: left center;
      animation: grow 900ms cubic-bezier(.2,.8,.2,1);
    }

    @keyframes grow {
      from { transform: scaleX(0.2); opacity: 0.5; }
      to { transform: scaleX(1); opacity: 1; }
    }

    .streak {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, #fff7fb, #f4fbff);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .streak strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
    }

    .streak p {
      margin: 4px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.6;
    }

    .streak-badge {
      min-width: 84px;
      height: 84px;
      border-radius: 24px;
      background: linear-gradient(145deg, rgba(248,76,162,0.2), rgba(29,220,255,0.2));
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      text-align: center;
      font-weight: 800;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.7);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 8px;
      margin-top: 10px;
    }

    .compare-cell {
      padding: 12px 8px;
      border-radius: 16px;
      text-align: center;
      font-size: 12px;
      line-height: 1.5;
      font-weight: 700;
      background: #fff;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.06);
    }

    .compare-cell.header {
      background: rgba(9,19,85,0.06);
      color: var(--dark-blue);
    }

    .compare-cell.brand {
      background: linear-gradient(135deg, rgba(248,76,162,0.14), rgba(29,220,255,0.14));
      color: var(--dark-blue);
    }

    .phone-zero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 12px;
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(9,19,85,0.96), rgba(248,76,162,0.88));
      color: var(--white);
      overflow: hidden;
      position: relative;
    }

    .phone-zero::after {
      content: "";
      position: absolute;
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: rgba(255,255,255,0.1);
      right: -20px;
      top: -25px;
    }

    .zero-ring {
      width: 92px;
      height: 92px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at center, rgba(255,255,255,0.98) 0 35%, transparent 36%),
        conic-gradient(#79ffca 0deg 260deg, rgba(255,255,255,0.18) 260deg 360deg);
      font-family: var(--font-number);
      font-size: 34px;
      color: var(--dark-blue);
      box-shadow: inset 0 0 0 12px rgba(255,255,255,0.08);
      position: relative;
      z-index: 1;
    }

    .phone-zero h3 {
      margin: 0 0 6px;
      font-size: 22px;
      line-height: 1.4;
    }

    .phone-zero p {
      margin: 0;
      color: rgba(255,255,255,0.82);
      font-size: 12px;
      line-height: 1.7;
      position: relative;
      z-index: 1;
    }

    .auction-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      margin-top: 12px;
    }

    .auction-card strong {
      display: block;
      margin-bottom: 4px;
      font-size: 16px;
      line-height: 1.5;
    }

    .auction-card p {
      margin: 0;
      font-size: 12px;
      line-height: 1.6;
      color: rgba(255,255,255,0.82);
    }

    .auction-score {
      border-radius: 18px;
      background: rgba(255,255,255,0.14);
      padding: 12px 14px;
      min-width: 112px;
      text-align: center;
    }

    .auction-score b {
      display: block;
      font-size: 28px;
      line-height: 1.2;
      font-family: var(--font-number);
      margin-bottom: 3px;
    }

    .auction-score span {
      font-size: 11px;
      line-height: 1.4;
      color: rgba(255,255,255,0.85);
    }

    .cta-row {
      display: flex;
      gap: 10px;
      margin-top: auto;
      padding-top: 4px;
    }

    .btn {
      appearance: none;
      border: 0;
      cursor: pointer;
      border-radius: var(--radius-button);
      min-height: 43px;
      padding: 0 18px;
      font-size: 14px;
      font-weight: 800;
      transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 26px rgba(28,38,99,0.12);
    }

    .btn.primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .btn.pink {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .btn.white {
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid rgba(64,64,64,0.14);
    }

    .pager {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 14px;
    }

    .dot-btn {
      width: 12px;
      height: 12px;
      border: 0;
      padding: 0;
      border-radius: 999px;
      background: rgba(28,38,99,0.16);
      cursor: pointer;
      transition: transform 160ms ease, background 160ms ease, width 160ms ease;
    }

    .dot-btn.active {
      width: 34px;
      background: linear-gradient(90deg, var(--pink), #4db4ff);
    }

    .footer-note {
      text-align: center;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
      margin-top: 14px;
    }

    .floating-help {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 50;
      appearance: none;
      border: 0;
      background: linear-gradient(135deg, var(--dark-blue), #3044b5);
      color: var(--white);
      border-radius: 999px;
      min-height: 52px;
      padding: 0 18px;
      font-size: 13px;
      font-weight: 800;
      box-shadow: 0 18px 36px rgba(28,38,99,0.2);
      cursor: pointer;
    }

    .coach {
      position: fixed;
      left: 16px;
      right: 16px;
      bottom: 78px;
      z-index: 49;
      border-radius: 18px;
      background: rgba(255,255,255,0.94);
      color: var(--dark-blue);
      padding: 14px 16px;
      box-shadow: 0 24px 60px rgba(28,38,99,0.18);
      backdrop-filter: blur(16px);
      transform: translateY(24px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 240ms ease, transform 240ms ease;
    }

    .coach.open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .coach strong {
      display: block;
      margin-bottom: 6px;
      font-size: 15px;
      line-height: 1.5;
    }

    .coach p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    @media (min-width: 900px) {
      body {
        padding-top: 28px;
      }

      .hero {
        padding: 22px 24px 24px;
      }

      .hero h1 {
        font-size: 36px;
      }

      .hint {
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="stage">
    <div class="topbar">
      <div class="brand">
        <div class="brand-mark"></div>
        <div class="brand-copy">
          <strong>UcarPAC Store Visual Lab</strong>
          <span>ASO検証用 / スワイプで3案を比較</span>
        </div>
      </div>
      <div class="mode-badge">C案 / Interactive</div>
    </div>

    <section class="hero">
      <h1>AI査定、将来予測、電話0本体験を<br>ストアスクショで即理解させる</h1>
      <p>App Store / Google Play 向けの訴求を1ファイルで確認できるプロトタイプです。スワイプ、チップ切替、ステップ進行の動きで「アプリ独自の価値」を短時間で伝える構成にしています。</p>
      <div class="hero-actions">
        <button class="chip is-active" data-jump="0">スクショA / iOS</button>
        <button class="chip" data-jump="1">スクショB / Android</button>
        <button class="chip" data-jump="2">スクショC / 比較訴求</button>
      </div>
    </section>

    <p class="hint">左右スワイプ、または上のチップと下のドットで切り替え。各スクリーン内のボタンで状態変化します。</p>

    <div class="slider-shell" id="sliderShell">
      <div class="slider" id="slider">
        <section class="slide">
          <div class="phone">
            <div class="screen a">
              <div class="statusbar">
                <span>9:41</span>
                <span>5G 100%</span>
              </div>
              <div class="top-content">
                <div class="platform-pill">
                  <span class="dot"></span>
                  <span>STORE SCREENSHOT A / iOS</span>
                </div>
                <div class="headline">
                  <div class="kicker">個人情報なしで すぐ相場チェック</div>
                  <h2>AIがあなたの愛車を査定</h2>
                  <p>ハリアー 2021 / 29,000km のような具体車両で、今の相場も売り時も直感的に見える。</p>
                </div>
              </div>

              <div class="main-pane">
                <div class="panel soft">
                  <div class="scan-card">
                    <div class="car-thumb"></div>
                    <div>
                      <h3>トヨタ ハリアー Z</h3>
                      <p>2021年式 / パール / 2WD / 29,000km</p>
                      <div class="badge-row">
                        <span class="badge pink">個人情報不要</span>
                        <span class="badge blue">最短30秒</span>
                      </div>
                    </div>
                  </div>

                  <div class="price-box">
                    <div>
                      <small>AI査定レンジ</small>
                      <div class="price-value" id="priceA">288〜314万円</div>
                    </div>
                    <div class="price-trend" id="trendA">+9万円の余地</div>
                  </div>

                  <div class="steps" id="stepsA">
                    <div class="step is-on">
                      <b>STEP 1</b>
                      <span>車種登録</span>
                    </div>
                    <div class="step">
                      <b>STEP 2</b>
                      <span>AI補正</span>
                    </div>
                    <div class="step">
                      <b>STEP 3</b>
                      <span>結果表示</span>
                    </div>
                  </div>
                </div>

                <div class="panel">
                  <div class="card-title">
                    <strong>査定精度を上げる診断フロー</strong>
                    <span>タップで切替</span>
                  </div>
                  <div class="diagnosis-flow">
