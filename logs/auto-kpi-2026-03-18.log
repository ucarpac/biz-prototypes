      <section class="screen fade-in" id="screen-c" aria-label="ストアスクショC">
        <div class="phone-wrap">
          <div class="phone">
            <div class="phone-screen">
              <div class="shot">
                <div class="statusbar">
                  <span>9:41</span>
                  <div class="status-icons">
                    <span>5G</span>
                    <span class="status-pill"></span>
                  </div>
                </div>

                <article class="hero-card">
