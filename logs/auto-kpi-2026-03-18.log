        <div class="phone-wrap">
          <div class="phone">
            <div class="screen">
              <div class="screen-bg-paper" style="top:auto; bottom:22px; right:14px; transform:rotate(-11deg);"></div>
              <div class="screen-inner">
                <div class="statusbar">
                  <span>9:41</span>
                  <span>VoLTE 82%</span>
