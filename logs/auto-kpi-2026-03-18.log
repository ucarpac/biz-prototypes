                <p class="footer-note">価格を見るだけで終わらず、削除されにくい“使い続ける理由”を訴求。</p>
              </div>
            </div>
          </div>
        </div>
      </article>

      <article class="screen-card screen-block" id="shot-c">
        <div class="screen-meta">
          <div>
            <h2 class="screen-title">3. ストアスクショC</h2>
            <p class="screen-note">競合比較 / 「電話0本」を感情的にわかりやすく訴求 / 不安を一撃で払拭</p>
          </div>
          <div class="device-tag">比較訴求 ・ 電話ストレス回避</div>
        </div>

        <div class="phone-wrap">
          <div class="phone">
            <div class="screen">
              <div class="screen-bg-paper" style="left:18px; right:auto; top:110px; transform:rotate(-8deg);"></div>
              <div class="screen-inner">
                <div class="statusbar">
                  <span>9:41</span>
                  <span>Wi-Fi 91%</span>
                </div>

                <div class="top-badges">
                  <span class="badge white">比較でわかる安心</span>
                  <span class="badge pink pulse">電話0本で相場チェック</span>
                </div>

                <div class="hero" style="grid-template-columns: 1fr;">
                  <div class="hero-copy">
                    <h2><span class="marker">知らない番号に</span><br>びくびくしない査定へ。</h2>
                    <p>「とりあえず相場だけ見たいのに、電話が何本も来るのはつらい」。その不安に正面から応える比較スクリーンです。</p>
                    <span class="hand-note">はじめの一歩が軽くなる設計</span>
                  </div>
                </div>

                <section class="compare-card">
                  <p class="section-label">主要サービス比較</p>

                  <div class="toggle-row" aria-label="比較モード">
                    <button class="toggle-btn active" data-compare="phone">電話ストレス</button>
                    <button class="toggle-btn" data-compare="privacy">個人情報</button>
                    <button class="toggle-btn" data-compare="auction">高値売却</button>
                  </div>

                  <div class="compare-grid">
                    <div class="compare-head">
                      <span>サービス</span>
                      <span>電話本数</span>
                      <span>個人情報</span>
                      <span>高値期待</span>
                    </div>

                    <div class="compare-row highlight">
                      <span class="brand">UcarPAC</span>
                      <span class="ok" id="ucarpacPhone">0本</span>
                      <span class="ok" id="ucarpacPrivacy">不要</span>
                      <span class="ok" id="ucarpacAuction">8,000社</span>
                    </div>

                    <div class="compare-row">
                      <span class="brand">MOTA</span>
                      <span class="ng" id="motaPhone">最大3社</span>
                      <span class="ng" id="motaPrivacy">必要</span>
                      <span class="ok" id="motaAuction">事前入札</span>
                    </div>

                    <div class="compare-row">
                      <span class="brand">ズバット</span>
                      <span class="ng" id="zubatPhone">最大10社</span>
                      <span class="ng" id="zubatPrivacy">必要</span>
                      <span class="ng" id="zubatAuction">一括査定</span>
                    </div>

                    <div class="compare-row">
                      <span class="brand">セルカ</span>
                      <span class="ok" id="celcaPhone">1社のみ</span>
                      <span class="ng" id="celcaPrivacy">必要</span>
                      <span class="ok" id="celcaAuction">8,000社</span>
                    </div>
                  </div>

                  <div class="price-card" style="padding:14px 16px;">
                    <div class="car-row">
                      <div>
                        <p class="car-name">まずは AI査定だけ</p>
                        <p class="car-sub">売ると決める前の相場確認にぴったり</p>
                      </div>
                      <div class="badge pink" style="box-shadow:none;">電話0本</div>
                    </div>
                    <div class="stats-row">
                      <div class="mini-card">
                        <b>個人情報不要</b>
                        <span>相場だけ先に確認</span>
                      </div>
                      <div class="mini-card">
                        <b>1社対応</b>
                        <span>売却時も負担軽減</span>
                      </div>
                      <div class="mini-card">
                        <b>無料</b>
                        <span>気軽に試せる</span>
                      </div>
                    </div>
                  </div>
                </section>

                <div class="cta-row">
                  <button class="primary-btn" id="compareToggleBtn">比較ポイントを切り替える</button>
                  <button class="secondary-btn">電話なしで価格を見る</button>
                </div>

                <p class="footer-note">「営業電話が怖い」という離脱理由を、ストア上で先回りして解消する構成。</p>
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>
  </main>

  <script>
    const filterButtons = document.querySelectorAll('.chip');
    const screenBlocks = document.querySelectorAll('.screen-block');

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        filterButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');
        const target = button.dataset.target;

        screenBlocks.forEach((block) => {
          if (target === 'all' || block.id === target) {
            block.classList.remove('hidden');
          } else {
            block.classList.add('hidden');
          }
        });
      });
    });

    const heroStates = [
      { price: '298', bubble: '3か月後も高値予測', button: '3か月後の価格を見る' },
      { price: '286', bubble: '今が売り時の可能性', button: '現在価格に戻す' }
    ];
    let heroIndex = 0;
    const heroPrice = document.getElementById('heroPrice');
    const heroBubble = document.getElementById('heroBubble');
    const priceToggleBtn = document.getElementById('priceToggleBtn');

    priceToggleBtn.addEventListener('click', () => {
      heroIndex = (heroIndex + 1) % heroStates.length;
      heroPrice.textContent = heroStates[heroIndex].price;
      heroBubble.textContent = heroStates[heroIndex].bubble;
      priceToggleBtn.textContent = heroStates[heroIndex].button;
    });

    const expenseData = {
      month: { total: '4.8', gas: '1.5万円', ins: '1.2万円', park: '1.4万円', maint: '0.7万円', bubble: '6か月後査定 286万円予測' },
      quarter: { total: '4.5', gas: '1.4万円', ins: '1.2万円', park: '1.4万円', maint: '0.5万円', bubble: '3か月後査定 292万円予測' },
      year: { total: '58', gas: '18万円', ins: '14万円', park: '17万円', maint: '9万円', bubble: '維持費上昇前の売却検討がおすすめ' }
    };

    const expenseButtons = document.querySelectorAll('[data-expense]');
    const expenseTotal = document.getElementById('expenseTotal');
    const ringValue = document.getElementById('ringValue');
    const trendBubble = document.getElementById('trendBubble');
    const gasolineCost = document.getElementById('gasolineCost');
    const insuranceCost = document.getElementById('insuranceCost');
    const parkingCost = document.getElementById('parkingCost');
    const maintCost = document.getElementById('maintCost');
    const expenseToggleBtn = document.getElementById('expenseToggleBtn');
    let expenseModeOrder = ['month', 'quarter', 'year'];
    let expenseModeIndex = 0;

    function updateExpense(mode) {
      const data = expenseData[mode];
      expenseButtons.forEach((btn) => btn.classList.toggle('active', btn.dataset.expense === mode));
      expenseTotal.textContent = data.total;
      ringValue.textContent = data.total;
      trendBubble.textContent = data.bubble;
      gasolineCost.textContent = data.gas;
      insuranceCost.textContent = data.ins;
      parkingCost.textContent = data.park;
      maintCost.textContent = data.maint;
      expenseToggleBtn.textContent = mode === 'year' ? '今月表示に戻す' : '年間予測に切り替え';
    }

    expenseButtons.forEach((button) => {
      button.addEventListener('click', () => {
        expenseModeIndex = expenseModeOrder.indexOf(button.dataset.expense);
        updateExpense(button.dataset.expense);
      });
    });

    expenseToggleBtn.addEventListener('click', () => {
      expenseModeIndex = (expenseModeIndex + 1) % expenseModeOrder.length;
      updateExpense(expenseModeOrder[expenseModeIndex]);
    });

    const compareButtons = document.querySelectorAll('[data-compare]');
    const compareToggleBtn = document.getElementById('compareToggleBtn');
    const compareModes = ['phone', 'privacy', 'auction'];
    let compareIndex = 0;

    const compareValues = {
      phone: {
        ucarpacPhone: '0本',
        motaPhone: '最大3社',
        zubatPhone: '最大10社',
        celcaPhone: '1社のみ'
      },
      privacy: {
        ucarpacPhone: '不要',
        motaPhone: '必要',
        zubatPhone: '必要',
        celcaPhone: '必要'
      },
      auction: {
        ucarpacPhone: '8,000社',
        motaPhone: '事前入札',
        zubatPhone: '一括査定',
        celcaPhone: '8,000社'
      }
    };

    function updateCompare(mode) {
      compareButtons.forEach((btn) => btn.classList.toggle('active', btn.dataset.compare === mode));
      if (mode === 'phone') {
        document.getElementById('ucarpacPhone').textContent = '0本';
        document.getElementById('motaPhone').textContent = '最大3社';
        document.getElementById('zubatPhone').textContent = '最大10社';
        document.getElementById('celcaPhone').textContent = '1社のみ';
      }
      if (mode === 'privacy') {
        document.getElementById('ucarpacPhone').textContent = '不要';
        document.getElementById('motaPhone').textContent = '必要';
        document.getElementById('zubatPhone').textContent = '必要';
        document.getElementById('celcaPhone').textContent = '必要';
      }
      if (mode === 'auction') {
        document.getElementById('ucarpacPhone').textContent = '8,000社';
        document.getElementById('motaPhone').textContent = '事前入札';
        document.getElementById('zubatPhone').textContent = '一括査定';
        document.getElementById('celcaPhone').textContent = '8,000社';
      }
    }

    compareButtons.forEach((button) => {
      button.addEventListener('click', () => {
        compareIndex = compareModes.indexOf(button.dataset.compare);
        updateCompare(button.dataset.compare);
      });
    });

    compareToggleBtn.addEventListener('click', () => {
      compareIndex = (compareIndex + 1) % compareModes.length;
      updateCompare(compareModes[compareIndex]);
    });

    updateExpense('month');
    updateCompare('phone');
  </script>
