                <article class="compare-card">
                  <div class="compare-head">
                    <h3>比較してわかる、やさしさの差</h3>
                    <span class="versus">UcarPAC vs 一括査定</span>
                  </div>
                  <div class="compare-table">
                    <div class="compare-row header">
                      <div>比較項目</div>
