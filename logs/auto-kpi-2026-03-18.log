        );
      position: relative;
      overflow: hidden;
    }

    .chart-fill {
      position: absolute;
      inset: auto 0 0 0;
      height: 64%;
      background: linear-gradient(180deg, rgba(111, 194, 255, 0.18), rgba(248, 76, 162, 0.06));
      clip-path: polygon(0 80%, 14% 74%, 28% 64%, 42% 58%, 58% 43%, 72% 32%, 86% 20%, 100% 8%, 100% 100%, 0 100%);
    }

    .chart-line {
      position: absolute;
      inset: 0;
    }

    .chart-line svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .chart-dot {
      fill: var(--pink);
      stroke: #fff;
      stroke-width: 4;
      filter: drop-shadow(0 6px 10px rgba(248, 76, 162, 0.22));
    }

    .chart-caption {
      display: flex;
      justify-content: space-between;
      margin-top: 12px;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
    }

    .savings-band {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
      padding: 13px 14px;
      border-radius: 18px;
      background: linear-gradient(90deg, rgba(223, 249, 239, 0.85), rgba(255, 244, 234, 0.85));
    }

    .savings-band strong {
      color: var(--dark-blue);
      font-size: 16px;
    }

    .compare-card {
      padding: 18px 16px;
    }

    .compare-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }

    .versus {
      font-size: 12px;
      font-weight: 800;
      color: var(--pink);
      background: rgba(248, 76, 162, 0.12);
      padding: 6px 10px;
      border-radius: var(--radius-pill);
    }

    .compare-table {
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 8px;
      align-items: center;
      padding: 12px;
      border-radius: 18px;
      background: #fffafc;
    }

    .compare-row.header {
      background: transparent;
      padding: 0 4px 4px;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 800;
    }

    .compare-row strong {
      color: var(--dark-blue);
      font-size: 13px;
    }

    .good,
    .bad {
      text-align: center;
      padding: 8px 10px;
      border-radius: 14px;
      font-weight: 900;
      font-size: 13px;
    }

    .good {
      background: rgba(223, 249, 239, 0.9);
      color: #0a7b53;
    }

    .bad {
      background: rgba(255, 224, 224, 0.82);
      color: #ba2d2d;
    }

    .zero-badge {
      margin-top: 14px;
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, #fff0f7, #ffffff);
      border: 2px dashed rgba(248, 76, 162, 0.28);
      text-align: center;
    }

    .zero-badge .big {
      display: block;
      margin-top: 4px;
      color: var(--pink);
      font-size: 42px;
      line-height: 1;
      font-family: var(--font-number);
    }

    .quote-card {
      padding: 18px 16px 16px;
      background: rgba(255, 255, 255, 0.86);
    }

    .quote-card::before {
      content: "✎";
      position: absolute;
      top: 12px;
      right: 14px;
      color: rgba(248, 76, 162, 0.36);
      font-size: 22px;
      transform: rotate(-12deg);
    }

    .quote {
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 800;
      line-height: 1.7;
      margin-bottom: 10px;
    }

    .handwritten {
      font-size: 13px;
      color: #a65e17;
      font-weight: 800;
      transform: rotate(-2deg);
      display: inline-block;
      padding: 5px 10px;
      border-radius: 14px;
      background: rgba(255, 244, 234, 0.8);
    }

    .side-panel {
      display: grid;
      gap: 16px;
      align-content: start;
    }

    .note-card {
      padding: 18px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(12px);
      box-shadow: 0 16px 32px rgba(28, 38, 99, 0.07);
    }

    .note-card h4 {
      margin: 0 0 10px;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .point-list {
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .point-list li {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.7;
    }

    .point-list li::before {
      content: "";
      width: 10px;
      height: 10px;
      margin-top: 6px;
      border-radius: 50%;
      flex: 0 0 auto;
      background: var(--gradient-primary);
      box-shadow: 0 0 0 4px rgba(77, 180, 255, 0.12);
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .legend .badge {
      min-height: 28px;
    }

    .preview-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      margin-bottom: 10px;
    }

    .preview-label .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--pink);
      box-shadow: 12px 0 0 var(--soft-yellow);
    }

    .footer-note {
      width: min(100%, 920px);
      margin: 26px auto 0;
      text-align: center;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .pulse {
      animation: pulse 1.8s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.18); }
      50% { box-shadow: 0 0 0 12px rgba(248, 76, 162, 0); }
    }

    .fade-in {
      animation: fadeInUp 0.45s ease both;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 420px) {
      .shot h2 {
        font-size: 28px;
      }

      .price-main {
        font-size: 34px;
      }

      .hero-grid {
        grid-template-columns: 1fr 98px;
      }

      .car-illustration {
        width: 98px;
      }
    }
  </style>
</head>
<body>
  <div class="bg-doodle" aria-hidden="true"></div>

  <main class="page">
    <section class="intro fade-in">
      <span class="eyebrow">A案 / 感情に寄り添うストアスクショ検証</span>
      <h1>「まず相場だけ知りたい」に、やさしく答える。</h1>
      <p>
        AI査定、出費管理、電話負担の少なさを、安心感のある暖色アクセントと親しみやすい表現でストア向けに可視化した1ファイルプロトタイプです。
        画面上部の切替で、iOS向けA、Android向けB、競合比較Cを確認できます。
      </p>
    </section>

    <section class="controls fade-in">
      <div class="tab-list" role="tablist" aria-label="スクリーン切替">
        <button class="tab active" type="button" data-screen="screen-a">スクショA / AI査定</button>
        <button class="tab" type="button" data-screen="screen-b">スクショB / 出費管理</button>
        <button class="tab" type="button" data-screen="screen-c">スクショC / 電話0本</button>
      </div>
      <div class="toggle-list" aria-label="演出切替">
        <button class="toggle active" type="button" data-theme="warm">安心モード</button>
        <button class="toggle" type="button" data-theme="focus">比較強調</button>
      </div>
    </section>

    <section class="frames">
      <section class="screen active fade-in" id="screen-a" aria-label="ストアスクショA">
        <div class="phone-wrap">
          <div class="phone">
            <div class="phone-screen">
              <div class="shot">
                <div class="statusbar">
                  <span>9:41</span>
                  <div class="status-icons">
                    <span>5G</span>
                    <span class="status-pill"></span>
                  </div>
                </div>

                <article class="hero-card pulse">
                  <div class="label-row">
                    <span class="badge badge-pink">iOS向け</span>
                    <span class="badge badge-blue">個人情報なし</span>
                    <span class="badge badge-orange">まずは安心チェック</span>
                  </div>
                  <h2>AIがあなたの愛車を査定。<br>いまの相場が、すぐわかる。</h2>
                  <p>営業電話の心配なく、トヨタ プリウス 2021年式の相場をやさしく可視化。迷っている段階でも始めやすい導線です。</p>

                  <div class="hero-grid">
                    <div>
                      <span class="car-chip">トヨタ プリウス S / 2021年 / 2.8万km</span>
                      <div class="price-panel">
                        <div class="price-line">
                          <div>
                            <div class="price-sub">AI査定の目安</div>
                            <div class="price-main">182.4万円</div>
                          </div>
                          <div class="price-sub">上位相場帯<br>176.0〜189.0万円</div>
                        </div>
                        <div class="meter"><span id="meterA"></span></div>
                        <div class="meter-note">
                          <span>個人情報入力なし</span>
                          <span>約30秒で確認</span>
                        </div>
                      </div>
                    </div>
                    <div class="car-illustration" aria-hidden="true">
                      <div class="roof"></div>
                      <div class="body"></div>
                      <div class="wheel"></div>
                      <div class="spark one"></div>
                      <div class="spark two"></div>
                      <div class="spark three"></div>
                    </div>
                  </div>

                  <div class="cta-group">
                    <button class="btn btn-primary active-mood" type="button" id="ctaA1">AI査定をはじめる</button>
                    <button class="btn btn-white" type="button" id="ctaA2">写真なしで概算価格を見る</button>
                  </div>
                </article>

                <article class="info-card">
                  <div class="label-row">
                    <span class="badge badge-blue">不安を減らす3つの安心</span>
                  </div>
                  <h3>「いきなり売る」は、まだ早くて大丈夫。</h3>
                  <div class="info-grid">
                    <div class="mini-stat">
                      <strong>0件</strong>
                      <span>査定前の電話</span>
                    </div>
                    <div class="mini-stat">
                      <strong>8,000社</strong>
                      <span>売却時の入札ネットワーク</span>
                    </div>
                    <div class="mini-stat">
                      <strong>1社</strong>
                      <span>やりとりは必要最小限</span>
                    </div>
                  </div>
                </article>

                <article class="mini-card">
                  <div class="list-row">
                    <div class="list-left">
                      <div class="icon-bubble">🧠</div>
                      <div>
                        <div class="row-title">AI査定で今の相場が見える</div>
                        <div class="row-sub">メーカー・年式・走行距離からすぐ確認</div>
                      </div>
                    </div>
                    <div class="row-value">最短30秒</div>
                  </div>
                  <div class="list-row">
                    <div class="list-left">
                      <div class="icon-bubble">📷</div>
                      <div>
                        <div class="row-title">写真追加で精度アップ</div>
                        <div class="row-sub">カラー・装備・状態も反映</div>
                      </div>
                    </div>
                    <div class="row-value">精度向上</div>
                  </div>
                  <div class="list-row">
                    <div class="list-left">
                      <div class="icon-bubble">🤝</div>
                      <div>
                        <div class="row-title">売る時だけ次の一歩へ</div>
                        <div class="row-sub">申し込みはタイミングが来てからでOK</div>
                      </div>
                    </div>
                    <div class="row-value">安心設計</div>
                  </div>
                  <div class="assist-note">いま知るだけでも、十分前進です。</div>
                </article>
              </div>
            </div>
          </div>
        </div>

        <aside class="side-panel">
          <div class="note-card fade-in">
            <div class="preview-label"><span class="dot"></span>スクショAの狙い</div>
            <h4>AI査定を主役にして、最初の心理ハードルを下げる</h4>
            <ul class="point-list">
              <li>ストア上で最初に伝える価値を「今すぐ売却」ではなく「安心して相場確認」に寄せています。</li>
              <li>「個人情報なし」「約30秒」「電話の心配なし」を近接配置し、DL前の不安を先回りして解消します。</li>
              <li>暖色の吹き出しと柔らかいイラストで、査定アプリにありがちな圧迫感を抑えています。</li>
            </ul>
          </div>

          <div class="note-card">
            <div class="legend">
              <span class="badge badge-pink">ファーストビュー訴求</span>
              <span class="badge badge-blue">CVR改善仮説</span>
              <span class="badge badge-orange">感情的安心</span>
            </div>
            <p style="margin-top:12px;">
              「AIがあなたの愛車を査定」「個人情報なしで相場チェック」を同時に提示し、競合にない独自性と使いやすさを一画面で成立させます。
            </p>
          </div>
        </aside>
      </section>

      <section class="screen fade-in" id="screen-b" aria-label="ストアスクショB">
        <div class="phone-wrap">
          <div class="phone">
            <div class="phone-screen">
              <div class="shot">
                <div class="statusbar">
                  <span>9:41</span>
                  <div class="status-icons">
                    <span>4G</span>
                    <span class="status-pill"></span>
                  </div>
                </div>

                <article class="hero-card">
                  <div class="label-row">
                    <span class="badge badge-blue">Android向け</span>
                    <span class="badge badge-pink">出費管理 + 将来予測</span>
                    <span class="badge badge-orange">売り時が見える</span>
                  </div>
                  <h2>維持費も、売り時も。<br>愛車の価値をまるごと見える化。</h2>
                  <p>ホンダ フリード G 2020年式を例に、出費の負担感と将来価格の見通しを一緒に提示。迷いの理由を、判断材料に変えます。</p>
                </article>

                <article class="chart-card">
                  <div class="label-row">
                    <span class="badge badge-blue">AI将来予測</span>
                  </div>
                  <h3>3ヶ月後に売ると +8.6万円の可能性</h3>
                  <div class="chart-box">
                    <div class="chart-fill" id="chartFill"></div>
                    <div class="chart-line">
                      <svg viewBox="0 0 300 170" role="img" aria-label="将来予測グラフ">
                        <path id="forecastPath" d="M8 132 C42 126, 70 118, 96 106 S150 86, 175 74 S228 48, 292 24" fill="none" stroke="#F84CA2" stroke-width="5" stroke-linecap="round"/>
                        <circle class="chart-dot" cx="8" cy="132" r="6"></circle>
                        <circle class="chart-dot" cx="96" cy="106" r="6"></circle>
                        <circle class="chart-dot" cx="175" cy="74" r="6"></circle>
                        <circle class="chart-dot" cx="292" cy="24" r="7"></circle>
                      </svg>
                    </div>
                  </div>
                  <div class="chart-caption">
                    <span>現在 152.8万円</span>
                    <span>1ヶ月後 156.4万円</span>
                    <span>3ヶ月後 161.4万円</span>
                  </div>
                  <div class="savings-band">
                    <div>
                      <div class="row-title">今月の維持費</div>
                      <strong>24,780円</strong>
                    </div>
                    <div>
                      <div class="row-title">年間見込み</div>
                      <strong>28.9万円</strong>
                    </div>
                  </div>
                </article>

                <article class="mini-card">
                  <div class="list-row">
                    <div class="list-left">
                      <div class="icon-bubble">⛽</div>
                      <div>
                        <div class="row-title">ガソリン代</div>
                        <div class="row-sub">3月 / 2回給油</div>
                      </div>
                    </div>
                    <div class="row-value">12,480円</div>
                  </div>
                  <div class="list-row">
                    <div class="list-left">
                      <div class="icon-bubble">🛡</div>
                      <div>
                        <div class="row-title">任意保険</div>
                        <div class="row-sub">月割り目安</div>
                      </div>
                    </div>
                    <div class="row-value">8,300円</div>
                  </div>
                  <div class="list-row">
