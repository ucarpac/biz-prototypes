    }

    .floating-stat {
      position: absolute;
      right: 14px;
      bottom: 14px;
      background: rgba(255,255,255,0.96);
      border-radius: 18px;
      padding: 10px 12px;
      box-shadow: 0 12px 22px rgba(28,38,99,0.16);
