  <button class="floating-help" id="helpButton">操作ヒント</button>
  <div class="coach" id="coach">
    <strong>このプロトタイプで確認できること</strong>
    <p>1. 左右スワイプで訴求テーマを比較 2. 各画面のチップやCTAで数値・コピーの変化を確認 3. ストアスクショでも“操作したくなる印象”を再現。</p>
  </div>

  <script>
    (function () {
      const slider = document.getElementById("slider");
      const dots = Array.from(document.querySelectorAll(".dot-btn"));
      const jumpChips = Array.from(document.querySelectorAll("[data-jump]"));
      const screens = 3;
      let index = 0;
      let startX = 0;
      let deltaX = 0;
      let dragging = false;

      function updateSlider(nextIndex) {
        index = Math.max(0, Math.min(screens - 1, nextIndex));
        slider.style.transform = "translateX(" + (-index * 100) + "%)";
        dots.forEach((dot, i) => dot.classList.toggle("active", i === index));
        jumpChips.forEach((chip, i) => chip.classList.toggle("is-active", i === index));
      }

      dots.forEach((dot) => {
        dot.addEventListener("click", function () {
          updateSlider(Number(dot.dataset.index));
        });
      });

      jumpChips.forEach((chip) => {
        chip.addEventListener("click", function () {
          updateSlider(Number(chip.dataset.jump));
        });
      });

      slider.addEventListener("touchstart", function (e) {
        dragging = true;
        startX = e.touches[0].clientX;
        deltaX = 0;
      }, { passive: true });

      slider.addEventListener("touchmove", function (e) {
        if (!dragging) return;
        deltaX = e.touches[0].clientX - startX;
      }, { passive: true });

      slider.addEventListener("touchend", function () {
        if (!dragging) return;
        dragging = false;
        if (Math.abs(deltaX) > 44) {
          updateSlider(index + (deltaX < 0 ? 1 : -1));
        }
      });

      let mouseDown = false;
      slider.addEventListener("mousedown", function (e) {
        mouseDown = true;
        startX = e.clientX;
        deltaX = 0;
      });
      window.addEventListener("mousemove", function (e) {
        if (!mouseDown) return;
        deltaX = e.clientX - startX;
      });
      window.addEventListener("mouseup", function () {
        if (!mouseDown) return;
        mouseDown = false;
        if (Math.abs(deltaX) > 60) {
          updateSlider(index + (deltaX < 0 ? 1 : -1));
        }
      });

      const colorOptions = document.querySelectorAll("#colorOptions .option");
      const equipOptions = document.querySelectorAll("#equipOptions .option");
      const priceA = document.getElementById("priceA");
      const trendA = document.getElementById("trendA");

      colorOptions.forEach((btn) => {
        btn.addEventListener("click", function () {
          colorOptions.forEach((el) => el.classList.remove("active"));
          btn.classList.add("active");
          priceA.textContent = btn.dataset.price;
          trendA.textContent = btn.dataset.trend;
        });
      });

      equipOptions.forEach((btn) => {
        btn.addEventListener("click", function () {
          equipOptions.forEach((el) => el.classList.remove("active"));
          btn.classList.add("active");
        });
      });

      const stepButton = document.getElementById("stepButton");
      const stepNodes = Array.from(document.querySelectorAll("#stepsA .step"));
      let stepIndex = 0;
      stepButton.addEventListener("click", function () {
        stepIndex = (stepIndex + 1) % stepNodes.length;
        stepNodes.forEach((node, i) => node.classList.toggle("is-on", i <= stepIndex));
      });

      document.getElementById("jumpB").addEventListener("click", function () {
        updateSlider(1);
      });

      const futureOptions = document.querySelectorAll("#futureOptions .option");
      const forecastB = document.getElementById("forecastB");
      const supportB = document.getElementById("supportB");

      futureOptions.forEach((btn) => {
        btn.addEventListener("click", function () {
          futureOptions.forEach((el) => el.classList.remove("active"));
          btn.classList.add("active");
          forecastB.textContent = btn.dataset.forecast;
          supportB.textContent = btn.dataset.support;
        });
      });

      document.getElementById("pulseB").addEventListener("click", function (e) {
        const target = document.querySelector(".screen.b .streak");
        target.animate([
          { transform: "scale(1)", boxShadow: "0 0 0 rgba(248,76,162,0)" },
          { transform: "scale(1.015)", boxShadow: "0 18px 36px rgba(248,76,162,0.16)" },
          { transform: "scale(1)" }
        ], {
          duration: 620,
          easing: "cubic-bezier(.2,.8,.2,1)"
        });
        e.currentTarget.textContent = "連続利用を強調中";
        setTimeout(() => {
          e.currentTarget.textContent = "推しポイント更新";
        }, 1400);
      });

      document.getElementById("jumpC").addEventListener("click", function () {
        updateSlider(2);
      });

      const compareOptions = document.querySelectorAll("#compareOptions .option");
      const compareCalls = document.getElementById("compareCalls");
      const compareNote = document.getElementById("compareNote");
      const zeroRing = document.getElementById("zeroRing");

      compareOptions.forEach((btn) => {
        btn.addEventListener("click", function () {
          compareOptions.forEach((el) => el.classList.remove("active"));
          btn.classList.add("active");
          compareCalls.textContent = btn.dataset.calls;
          compareNote.textContent = btn.dataset.note;
          zeroRing.textContent = btn.dataset.calls === "0本" ? "0" : "1";
          zeroRing.animate([
            { transform: "scale(0.9)" },
            { transform: "scale(1.08)" },
            { transform: "scale(1)" }
          ], {
            duration: 420,
            easing: "ease-out"
          });
        });
      });

      document.getElementById("flashC").addEventListener("click", function () {
        const card = document.querySelector(".phone-zero");
        card.animate([
          { transform: "translateY(0)" },
          { transform: "translateY(-4px)" },
          { transform: "translateY(0)" }
        ], {
          duration: 480,
          easing: "cubic-bezier(.2,.8,.2,1)"
        });
      });

      document.getElementById("resetAll").addEventListener("click", function () {
        updateSlider(0);
        stepIndex = 0;
        stepNodes.forEach((node, i) => node.classList.toggle("is-on", i === 0));
      });

      const helpButton = document.getElementById("helpButton");
      const coach = document.getElementById("coach");
      helpButton.addEventListener("click", function () {
        coach.classList.toggle("open");
      });

      updateSlider(0);
    })();
  </script>
</body>
