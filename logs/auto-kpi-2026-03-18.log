      font-size: 22px;
      color: var(--dark-blue);
    }

    .pulse {
      animation: pulse 2.4s infinite;
    }

    .rise {
      animation: rise 1.2s ease forwards;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); box-shadow: 0 12px 22px rgba(28,38,99,0.16); }
      50% { transform: scale(1.03); box-shadow: 0 18px 28px rgba(248,76,162,0.26); }
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 980px) {
      .layout {
        grid-template-columns: 1fr;
