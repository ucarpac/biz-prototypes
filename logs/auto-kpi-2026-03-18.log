        grid-template-columns: 1fr;
      }

      .delta {
        text-align: left;
      }

      .footer-cta {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero rise">
      <div class="eyebrow">ASO検証 / ストアPV→DL率改善</div>
      <h1>数字で伝える3枚構成。<br>AI査定・維持費・電話0本を一気に理解させる。</h1>
      <p>ストア詳細ページの離脱要因を「何ができるか分からない」「他社との違いが伝わらない」と仮定し、1秒で差別化が伝わるデータドリブンなスクリーンショットを設計。AI査定の現在価格、3か月予測、維持費、競合比較をダッシュボード風に再構成しています。</p>
      <div class="hero-metrics">
        <div class="metric-card">
          <div class="label">現状CVR</div>
          <div class="value">17.3%</div>
          <div class="sub">ストアPV → DL</div>
        </div>
        <div class="metric-card">
          <div class="label">目標CVR</div>
          <div class="value">25.0%</div>
          <div class="sub">+7.7pt 改善目標</div>
        </div>
        <div class="metric-card">
          <div class="label">最大訴求値</div>
          <div class="value">8,000社</div>
          <div class="sub">入札 × 電話0本 × AI予測</div>
        </div>
      </div>
    </section>

    <div class="toolbar">
      <button class="chip active" data-filter="all">3画面を表示</button>
      <button class="chip" data-filter="ios">A / iOS</button>
      <button class="chip" data-filter="android">B / Android</button>
      <button class="chip" data-filter="compare">C / 比較訴求</button>
      <button class="primary-button" id="animateButton">数値アニメーションを再生</button>
    </div>

    <section class="layout">
      <article class="phone rise" data-screen="ios">
        <div class="device">
          <div class="notch"></div>
          <div class="status">
            <span>9:41</span>
            <span>5G 100%</span>
          </div>
          <div class="screen-header">
            <div class="badge-row">
              <span class="badge light">iOS向け</span>
              <span class="badge">個人情報なし</span>
              <span class="badge">AI査定</span>
            </div>
            <h2 class="screen-title">愛車の価格、<br>いま数秒で見える</h2>
            <p class="screen-sub">2021年式 トヨタ ハリアー Z Leather Package を想定。現在相場と3か月予測を同時表示し、「売るか迷っている人」にまず価値を体感させる構成。</p>
          </div>

          <div class="content">
            <div class="card">
              <div class="card-title">
                <strong>AI査定サマリー</strong>
                <span class="mini-note">精度 87%</span>
              </div>
