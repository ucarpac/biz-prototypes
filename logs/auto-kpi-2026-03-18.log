                  <div class="car-row">
                    <div>
                      <p class="car-name">トヨタ ハリアー Z</p>
                      <p class="car-sub">2021年式 / 走行 28,400km / パール</p>
                    </div>
                    <div class="plate">品川 330</div>
                  </div>

                  <div class="price-number">
                    <strong id="heroPrice">298</strong>
                    <span>万円</span>
                  </div>

                  <div class="graph">
                    <div class="graph-bubble" id="heroBubble">3か月後も高値予測</div>
                    <svg viewBox="0 0 300 90" fill="none" aria-label="将来予測グラフ">
                      <path d="M12 70 C 52 62, 84 52, 112 48 C 138 44, 168 40, 194 34 C 220 28, 248 16, 288 14" stroke="rgba(248,76,162,0.18)" stroke-width="18" stroke-linecap="round"/>
                      <path d="M12 70 C 52 62, 84 52, 112 48 C 138 44, 168 40, 194 34 C 220 28, 248 16, 288 14" stroke="#F84CA2" stroke-width="5" stroke-linecap="round"/>
                      <circle cx="194" cy="34" r="6" fill="#FFFFFF" stroke="#1c2663" stroke-width="3"></circle>
                      <circle cx="288" cy="14" r="7" fill="#FFFFFF" stroke="#F84CA2" stroke-width="4"></circle>
                    </svg>
                    <div class="graph-labels">
                      <span>今月</span>
                      <span>3か月後</span>
                      <span>6か月後</span>
                    </div>
                  </div>

                  <div class="stats-row">
