      font-weight: 700;
      line-height: 18px;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 22px;
      width: calc(100% - 32px);
      max-width: 351px;
      transform: translate(-50%, 120px);
      padding: 14px 16px;
      border-radius: 13px;
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 12px 30px rgba(28, 38, 99, 0.28);
      font-size: 13px;
      font-weight: 700;
      line-height: 20px;
      opacity: 0;
      transition: 0.25s ease;
      z-index: 20;
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    .kpi-strip {
      width: 90%;
      max-width: 351px;
      margin: 16px auto 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
