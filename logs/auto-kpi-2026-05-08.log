  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC 通知最適化プロトタイプ',
      description: 'プッシュ通知開封率と通知経由申込数の改善検証'
    };

    const tabs = document.querySelectorAll('.tab');
    const screens = document.querySelectorAll('.screen');
    const toast = document.getElementById('toast');
    const meterFill = document.getElementById('meterFill');
    const meterScore = document.getElementById('meterScore');
    const bellButton = document.getElementById('bellButton');
    const stack = document.getElementById('notificationStack');
    const startSettingButton = document.getElementById('startSettingButton');
    const saveSettingsButton = document.getElementById('saveSettingsButton');
    const switches = document.querySelectorAll('.switch');
    const chips = document.querySelectorAll('.chip');
    const freqRange = document.getElementById('freqRange');
    const freqLabel = document.getElementById('freqLabel');
    const previewTitle = document.getElementById('previewTitle');
    const previewBody = document.getElementById('previewBody');
    const stepDots = document.querySelectorAll('.step-dot');
    const stages = document.querySelectorAll('.stage');
    const nextSteps = document.querySelectorAll('.next-step');
    const restartJourneyButton = document.getElementById('restartJourneyButton');

    let currentJourneyStep = 0;
    let cardPointerX = 0;
    let isDragging = false;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function activateScreen(id) {
      tabs.forEach(tab => {
        tab.classList.toggle('active', tab.dataset.screen === id);
      });
      screens.forEach(screen => {
        screen.classList.toggle('active', screen.id === id);
      });
    }

    function updateMeter(score) {
      meterScore.textContent = score;
      meterFill.style.width = score + '%';
    }

    function refreshCards() {
      const cards = [...stack.querySelectorAll('.notify-card')];
      cards.forEach((card, index) => {
        card.classList.toggle('front', index === 0);
        card.style.zIndex = String(3 - index);
        if (index === 0) {
          card.style.transform = 'translate(0, 0) rotate(0deg) scale(1)';
          card.style.opacity = '1';
        }
        if (index === 1) {
          card.style.transform = 'translateY(13px) scale(0.96)';
          card.style.opacity = '0.74';
        }
        if (index === 2) {
          card.style.transform = 'translateY(26px) scale(0.92)';
          card.style.opacity = '0.45';
        }
      });
    }

    function moveFrontCard(direction, adopted) {
      const front = stack.querySelector('.notify-card.front');
      if (!front) return;

      const score = front.dataset.score;
      const name = front.dataset.name;
      front.style.transform = `translateX(${direction * 380}px) rotate(${direction * 12}deg)`;
      front.style.opacity = '0';
      updateMeter(score);

      setTimeout(() => {
        stack.appendChild(front);
        refreshCards();
        showToast(adopted ? `${name}を採用候補にしました` : `${name}を見送りました`);
      }, 260);
    }

    function updateFrequency() {
      const map = {
        1: '週1回まで',
        2: '週2回まで',
        3: '週3回まで',
        4: '重要時のみ毎日可'
      };
      freqLabel.textContent = map[freqRange.value];
      previewBody.textContent = `${map[freqRange.value]}、相場変動と売り時だけ通知します。`;
      updateMeter(58 + Number(freqRange.value) * 6);
    }

    function setJourneyStep(step) {
      currentJourneyStep = step;
      stages.forEach((stage, index) => {
        stage.classList.toggle('active', index === currentJourneyStep);
      });
      stepDots.forEach((dot, index) => {
        dot.classList.toggle('done', index <= currentJourneyStep);
      });
      updateMeter([64, 72, 81, 88][currentJourneyStep]);
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        activateScreen(tab.dataset.screen);
      });
    });

    stack.addEventListener('pointerdown', event => {
      const front = stack.querySelector('.notify-card.front');
      if (!front || !event.target.closest('.notify-card.front')) return;
      isDragging = true;
      cardPointerX = event.clientX;
      front.setPointerCapture(event.pointerId);
    });

    stack.addEventListener('pointermove', event => {
      if (!isDragging) return;
      const front = stack.querySelector('.notify-card.front');
      if (!front) return;
      const diff = event.clientX - cardPointerX;
      front.style.transform = `translateX(${diff}px) rotate(${diff / 28}deg)`;
    });

    stack.addEventListener('pointerup', event => {
      if (!isDragging) return;
      isDragging = false;
      const front = stack.querySelector('.notify-card.front');
      if (!front) return;
      const diff = event.clientX - cardPointerX;
      if (Math.abs(diff) > 86) {
        moveFrontCard(diff > 0 ? 1 : -1, diff > 0);
      } else {
        front.style.transform = 'translate(0, 0) rotate(0deg) scale(1)';
      }
    });

    stack.addEventListener('click', event => {
      if (event.target.classList.contains('choose')) {
        moveFrontCard(1, true);
      }
      if (event.target.classList.contains('reject')) {
        moveFrontCard(-1, false);
      }
    });

    bellButton.addEventListener('click', () => {
      bellButton.style.transform = 'rotate(14deg) scale(1.08)';
      setTimeout(() => {
        bellButton.style.transform = '';
      }, 240);
      activateScreen('copy');
      showToast('未読通知から文言テストを開始しました');
    });

    startSettingButton.addEventListener('click', () => {
      activateScreen('settings');
    });

    switches.forEach(item => {
      item.addEventListener('click', () => {
        item.classList.toggle('on');
        const activeCount = document.querySelectorAll('.switch.on').length;
        updateMeter(52 + activeCount * 10);
        showToast(item.classList.contains('on') ? '通知をオンにしました' : '通知をオフにしました');
      });
    });

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('selected');
        const selected = [...chips].filter(item => item.classList.contains('selected')).map(item => item.textContent);
        previewTitle.textContent = selected.includes('相場が上がった時') ? '愛車の相場が12万円UP' : '売り時をAIが再診断';
        showToast('通知カテゴリを更新しました');
      });
    });

    freqRange.addEventListener('input', updateFrequency);

    saveSettingsButton.addEventListener('click', () => {
      showToast('通知設定を保存しました');
      setTimeout(() => {
        activateScreen('journey');
      }, 520);
    });

    nextSteps.forEach(button => {
      button.addEventListener('click', () => {
        const next = Math.min(currentJourneyStep + 1, stages.length - 1);
        setJourneyStep(next);
      });
    });

    restartJourneyButton.addEventListener('click', () => {
      setJourneyStep(0);
      showToast('導線シミュレーションをリセットしました');
    });

    refreshCards();
    updateFrequency();
  </script>
</body>
