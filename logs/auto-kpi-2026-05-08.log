    }

    .tab.is-active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 6px 14px rgba(28,38,99,0.22);
    }

    .chart-wrap {
      position: relative;
      padding: 12px 4px 2px;
    }

    .chart-caption {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .legend {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }

    .dot-pink {
      background: var(--pink);
    }

    .dot-blue {
      background: #4db4ff;
    }

    .dot-navy {
      background: var(--dark-blue);
    }

    .variant-list {
      display: grid;
      gap: 12px;
    }

    .variant {
      padding: 14px;
      border-radius: var(--radius-md);
      background: #fff;
      border: 1px solid #e7eef6;
    }

    .variant.is-selected {
      border-color: var(--pink);
      box-shadow: 0 0 0 2px rgba(248,76,162,0.12);
    }

    .variant-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 10px;
    }

    .variant-copy {
      margin: 0;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .winner-badge {
      flex: 0 0 auto;
      padding: 3px 8px;
      border-radius: 999px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .variant-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .mini-stat {
      padding: 8px;
      border-radius: 8px;
      background: var(--back-gray);
    }

    .mini-label {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .mini-value {
      margin-top: 2px;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 22px;
      font-weight: 700;
      line-height: 28px;
    }

    .progress-row {
      margin-top: 10px;
    }

    .progress-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 6px;
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
      color: var(--text-gray);
    }

    .progress {
      height: 8px;
      overflow: hidden;
      border-radius: 999px;
      background: var(--back-gray);
    }

    .progress-fill {
      width: var(--value);
      height: 100%;
      border-radius: 999px;
      background: var(--gradient-primary);
      transition: width 360ms ease;
    }

    .progress-fill.pink {
      background: var(--gradient-pink);
    }

    .settings-panel {
      display: grid;
      gap: 16px;
    }

    .setting-group {
      padding: 14px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid #e7eef6;
    }

    .setting-title {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    .chips::-webkit-scrollbar {
      display: none;
    }

    .chip {
      flex: 0 0 auto;
      min-width: 88px;
      min-height: 43px;
      padding: 0 14px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .chip.is-active {
      background: var(--pink);
      color: var(--white);
      border-color: var(--pink);
    }

    .toggle-list {
      display: grid;
      gap: 10px;
    }

    .toggle-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      min-height: 44px;
    }

    .toggle-text strong {
      display: block;
      color: var(--text-black);
      font-size: 14px;
      line-height: 21px;
    }

    .toggle-text span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .switch {
      position: relative;
      flex: 0 0 auto;
      width: 48px;
      height: 28px;
      border-radius: 999px;
      background: #d7dde8;
      transition: background 180ms ease;
    }

    .switch::after {
      content: "";
      position: absolute;
      top: 4px;
      left: 4px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--white);
      box-shadow: 0 2px 8px rgba(0,0,0,0.18);
      transition: transform 180ms ease;
    }

    .switch.is-on {
      background: var(--pink);
    }

    .switch.is-on::after {
      transform: translateX(20px);
    }

    .funnel {
      display: grid;
      gap: 12px;
    }

    .funnel-step {
      display: grid;
      grid-template-columns: 42px 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid #e7eef6;
    }

    .step-icon {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--back-gray);
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 700;
    }

    .funnel-step.is-current .step-icon {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .step-main strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
    }

    .step-main span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .step-rate {
      color: var(--pink);
      font-family: var(--font-number);
      font-size: 20px;
      font-weight: 700;
      line-height: 26px;
    }

    .notice-preview {
      margin: 14px 0 0;
      padding: 14px;
      border-radius: 16px;
      background: rgba(237,241,244,0.92);
      border: 1px solid #dbe5ef;
    }

    .phone-notice {
      display: grid;
      grid-template-columns: 38px 1fr;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.92);
      box-shadow: 0 8px 22px rgba(28,38,99,0.14);
      animation: floatIn 480ms ease;
    }

    @keyframes floatIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .notice-icon {
      display: grid;
      place-items: center;
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 18px;
      font-weight: 700;
    }

    .notice-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .notice-body {
      margin: 2px 0 0;
      color: var(--text-black);
      font-size: 12px;
      line-height: 18px;
    }

    .cta-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 14px;
    }

    .primary-btn,
    .pink-btn {
      min-height: 43px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .primary-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .pink-btn {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: var(--radius-md);
      font-size: 11px;
      line-height: 16.5px;
    }

    .compare-table th,
    .compare-table td {
      padding: 10px 8px;
      text-align: center;
      border-bottom: 1px solid var(--ruled-line);
    }

    .compare-table th {
      background: var(--dark-blue);
      color: var(--white);
      font-weight: 700;
    }

    .compare-table td:first-child {
      text-align: left;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .compare-table tr:nth-child(even) td {
      background: #f7f9fc;
    }

    .score-good {
      color: var(--pink);
      font-weight: 700;
    }

    .score-mid {
      color: #4099FF;
      font-weight: 700;
    }

    .source-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .source-list li {
      padding: 10px 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid #e7eef6;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .source-list strong {
      color: var(--dark-blue);
    }

    .bottom-nav {
      position: sticky;
      bottom: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      padding: 8px 12px 10px;
      background: rgba(255,255,255,0.94);
      border-top: 1px solid #e7eef6;
      backdrop-filter: blur(12px);
    }

    .nav-item {
      min-height: 44px;
      border-radius: 14px;
      background: transparent;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .nav-item.is-active {
      background: var(--back-light-pink);
      color: var(--pink);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 72px;
      z-index: 20;
      width: min(340px, calc(100% - 32px));
      padding: 12px 14px;
      border-radius: var(--radius-md);
      background: var(--dark-blue);
      color: var(--white);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      opacity: 0;
      transform: translate(-50%, 16px);
      pointer-events: none;
      transition: opacity 180ms ease, transform 180ms ease;
      box-shadow: 0 10px 26px rgba(28,38,99,0.28);
    }

    .toast.is-show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    @media (min-width: 760px) {
      body {
        padding: 28px 0;
      }

      .app {
        max-width: 960px;
        border-radius: 28px;
        overflow: hidden;
        min-height: auto;
      }

      .hero {
        border-radius: 0;
        padding: 28px 32px;
      }

      .hero h1 {
        font-size: 32px;
        line-height: 48px;
      }

      .hero-metrics {
        grid-template-columns: repeat(4, 1fr);
      }

      .content {
        padding: 28px 32px 40px;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 20px;
        align-items: start;
      }

      .wide-section {
        grid-column: 1 / -1;
      }

      .bottom-nav {
        position: static;
      }
    }
  </style>
</head>
<body>
  <main class="app">
    <header class="hero">
      <div class="topbar">
        <div class="brand">UcarPAC App KPI Lab</div>
        <div class="date-pill">2026-05-08 更新</div>
      </div>
      <h1>プッシュ通知最適化<br>再起動から申込までを数値で追う</h1>
      <p>相場変動・売り時・出費管理を通知の文脈に変換し、開封率と通知経由申込数を改善する検証画面。</p>
      <div class="hero-metrics">
        <div class="metric-card">
          <span class="metric-label">通知開封率</span>
          <div class="metric-value">18.6<span class="metric-unit">%</span></div>
          <div class="metric-delta">前回比 +4.2pt</div>
        </div>
        <div class="metric-card">
          <span class="metric-label">通知経由申込</span>
          <div class="metric-value">142<span class="metric-unit">件</span></div>
          <div class="metric-delta">前回比 +31件</div>
        </div>
        <div class="metric-card">
          <span class="metric-label">AI査定到達率</span>
          <div class="metric-value">41.8<span class="metric-unit">%</span></div>
          <div class="metric-delta">目標まで +3.2pt</div>
        </div>
        <div class="metric-card">
          <span class="metric-label">申込CVR</span>
          <div class="metric-value">6.4<span class="metric-unit">%</span></div>
          <div class="metric-delta">前回比 +1.1pt</div>
        </div>
      </div>
    </header>

    <div class="content">
      <div class="dashboard-grid">
        <section class="section">
          <div class="section-head">
            <h2 class="section-title">日次KPI推移</h2>
            <span class="section-note">過去7日</span>
          </div>
          <div class="card">
            <div class="card-body">
              <div class="tab-row">
                <button class="tab is-active" data-chart="open">開封率</button>
                <button class="tab" data-chart="apply">申込数</button>
                <button class="tab" data-chart="route">導線到達</button>
              </div>
              <div class="chart-wrap">
                <svg id="kpiChart" width="100%" height="190" viewBox="0 0 340 190" role="img" aria-label="KPI推移グラフ">
                  <line x1="34" y1="20" x2="34" y2="150" stroke="#dbe5ef" stroke-width="1"/>
                  <line x1="34" y1="150" x2="326" y2="150" stroke="#dbe5ef" stroke-width="1"/>
                  <line x1="34" y1="118" x2="326" y2="118" stroke="#edf1f4" stroke-width="1"/>
                  <line x1="34" y1="86" x2="326" y2="86" stroke="#edf1f4" stroke-width="1"/>
                  <line x1="34" y1="54" x2="326" y2="54" stroke="#edf1f4" stroke-width="1"/>
                  <text x="4" y="24" fill="#737373" font-size="10">高</text>
                  <text x="4" y="151" fill="#737373" font-size="10">低</text>
                  <path id="chartArea" d="M34 126 L82 118 L130 108 L178 94 L226 88 L274 74 L322 62 L322 150 L34 150 Z" fill="rgba(248,76,162,0.12)"/>
                  <path id="chartLine" d="M34 126 L82 118 L130 108 L178 94 L226 88 L274 74 L322 62" fill="none" stroke="#F84CA2" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                  <g id="chartDots" fill="#F84CA2">
                    <circle cx="34" cy="126" r="4"/>
                    <circle cx="82" cy="118" r="4"/>
                    <circle cx="130" cy="108" r="4"/>
                    <circle cx="178" cy="94" r="4"/>
                    <circle cx="226" cy="88" r="4"/>
                    <circle cx="274" cy="74" r="4"/>
                    <circle cx="322" cy="62" r="4"/>
                  </g>
                  <text x="28" y="172" fill="#737373" font-size="10">5/2</text>
                  <text x="76" y="172" fill="#737373" font-size="10">5/3</text>
                  <text x="124" y="172" fill="#737373" font-size="10">5/4</text>
                  <text x="172" y="172" fill="#737373" font-size="10">5/5</text>
                  <text x="220" y="172" fill="#737373" font-size="10">5/6</text>
                  <text x="268" y="172" fill="#737373" font-size="10">5/7</text>
                  <text x="316" y="172" fill="#737373" font-size="10">5/8</text>
                </svg>
                <div class="chart-caption">
                  <div class="legend">
                    <span class="legend-item"><i class="dot dot-pink"></i>相場UP通知</span>
                    <span class="legend-item"><i class="dot dot-blue"></i>売り時通知</span>
                  </div>
                  <span id="chartSummary">18.6% / +4.2pt</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <h2 class="section-title">通知プレビュー</h2>
            <span class="section-note">タップ導線</span>
          </div>
          <div class="card">
            <div class="card-body">
              <div class="notice-preview">
                <div class="phone-notice" id="noticePreview">
                  <div class="notice-icon">U</div>
                  <div>
                    <p class="notice-title">UcarPAC</p>
                    <p class="notice-body" id="noticeBody">プリウスの相場が前週比12万円UP。今のAI査定額を確認できます。</p>
                  </div>
                </div>
              </div>
              <div class="cta-row">
                <button class="primary-btn" id="tapNotice">通知をタップ</button>
                <button class="pink-btn" id="applyNow">申込へ進む</button>
              </div>
            </div>
          </div>
        </section>

        <section class="section wide-section">
          <div class="section-head">
            <h2 class="section-title">通知文言テスト</h2>
            <span class="section-note">A/B/C 配信</span>
          </div>
          <div class="variant-list">
            <article class="variant is-selected" data-copy="プリウスの相場が前週比12万円UP。今のAI査定額を確認できます。">
              <div class="variant-top">
                <p class="variant-copy">A. 愛車の相場が12万円UP。今の査定額を確認</p>
                <span class="winner-badge">暫定1位</span>
              </div>
              <div class="variant-grid">
                <div class="mini-stat">
                  <span class="mini-label">開封率</span>
                  <div class="mini-value">18.6%</div>
                </div>
                <div class="mini-stat">
                  <span class="mini-label">申込数</span>
                  <div class="mini-value">142</div>
                </div>
              </div>
              <div class="progress-row">
                <div class="progress-meta">
                  <span>目標開封率 20%</span>
                  <span>93%</span>
                </div>
                <div class="progress"><div class="progress-fill pink" style="--value:93%"></div></div>
              </div>
            </article>

            <article class="variant" data-copy="ゴールデンウィーク後の相場変動を検知。ヴェゼルの売り時をAIが再計算しました。">
              <div class="variant-top">
                <p class="variant-copy">B. 相場変動を検知。売り時をAIが再計算</p>
                <span class="winner-badge">申込効率高</span>
              </div>
              <div class="variant-grid">
                <div class="mini-stat">
                  <span class="mini-label">開封率</span>
                  <div class="mini-value">16.9%</div>
                </div>
                <div class="mini-stat">
                  <span class="mini-label">申込数</span>
                  <div class="mini-value">128</div>
                </div>
              </div>
              <div class="progress-row">
                <div class="progress-meta">
                  <span>目標開封率 20%</span>
                  <span>84%</span>
                </div>
                <div class="progress"><div class="progress-fill" style="--value:84%"></div></div>
              </div>
            </article>

            <article class="variant" data-copy="今月の維持費は34,200円。売却時の手残りをAI査定と一緒に確認できます。">
              <div class="variant-top">
                <p class="variant-copy">C. 維持費34,200円。手残りをAI査定で確認</p>
                <span class="winner-badge">再起動高</span>
              </div>
              <div class="variant-grid">
                <div class="mini-stat">
                  <span class="mini-label">開封率</span>
                  <div class="mini-value">15.2%</div>
                </div>
                <div class="mini-stat">
                  <span class="mini-label">申込数</span>
                  <div class="mini-value">96</div>
                </div>
              </div>
              <div class="progress-row">
                <div class="progress-meta">
                  <span>目標開封率 20%</span>
                  <span>76%</span>
                </div>
                <div class="progress"><div class="progress-fill" style="--value:76%"></div></div>
              </div>
            </article>
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <h2 class="section-title">通知設定UI</h2>
            <span class="section-note">ユーザー選択</span>
          </div>
          <div class="card">
            <div class="card-body settings-panel">
              <div class="setting-group">
                <h3 class="setting-title">通知頻度</h3>
                <div class="chips" id="frequencyChips">
                  <button class="chip">毎日</button>
                  <button class="chip is-active">週2回</button>
                  <button class="chip">相場変動時</button>
                  <button class="chip">月1回</button>
                </div>
              </div>

              <div class="setting-group">
                <h3 class="setting-title">受け取る通知</h3>
                <div class="toggle-list">
                  <div class="toggle-row">
                    <div class="toggle-text">
                      <strong>相場UP通知</strong>
                      <span>前週比5万円以上の変動で通知</span>
                    </div>
                    <button class="switch is-on" aria-label="相場UP通知"></button>
                  </div>
                  <div class="toggle-row">
                    <div class="toggle-text">
                      <strong>売り時予測</strong>
                      <span>3ヶ月後予測が下落する前に通知</span>
                    </div>
                    <button class="switch is-on" aria-label="売り時予測"></button>
                  </div>
                  <div class="toggle-row">
                    <div class="toggle-text">
                      <strong>出費サマリー</strong>
                      <span>給油・保険・車検の月次集計</span>
                    </div>
                    <button class="switch" aria-label="出費サマリー"></button>
                  </div>
                </div>
              </div>

              <div class="setting-group">
                <h3 class="setting-title">通知許容度スコア</h3>
