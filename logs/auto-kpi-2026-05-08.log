  <script>
    const tabs = document.querySelectorAll('.tab-button');
    const screens = document.querySelectorAll('.screen');
    const toast = document.getElementById('toast');

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.screen;

        tabs.forEach((item) => item.classList.remove('active'));
        screens.forEach((screen) => screen.classList.remove('active'));

        tab.classList.add('active');
        document.getElementById(target).classList.add('active');
      });
    });

    const notificationCards = document.querySelectorAll('.notification-card');

    notificationCards.forEach((card) => {
      const button = card.querySelector('.select-button');

      button.addEventListener('click', () => {
        notificationCards.forEach((item) => {
          item.classList.remove('selected');
          item.querySelector('.select-button').textContent = 'この文言を試す';
        });

        card.classList.add('selected');
        button.textContent = 'この文言を選択中';

        const variant = card.dataset.variant;
        showToast(`${variant}案をテスト配信候補にしました`);
      });
    });

    const switches = document.querySelectorAll('.switch');
    const permissionRate = document.getElementById('permissionRate');
    const monthlyCount = document.getElementById('monthlyCount');

    function updateSettingKpi() {
      const activeCount = document.querySelectorAll('.switch.on').length;
      const rate = 78 + activeCount * 2;
      const count = activeCount * 2;
      permissionRate.textContent = `${rate}%`;
      monthlyCount.textContent = `${count}通`;
    }

    switches.forEach((switchButton) => {
      switchButton.addEventListener('click', () => {
        switchButton.classList.toggle('on');
        updateSettingKpi();

        const isOn = switchButton.classList.contains('on');
        const label = switchButton.parentElement.querySelector('strong').textContent;
        showToast(`${label}を${isOn ? 'ON' : 'OFF'}にしました`);
      });
    });

    const chipGroups = document.querySelectorAll('[data-chip-group]');

    chipGroups.forEach((group) => {
      const chips = group.querySelectorAll('.chip');

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          chips.forEach((item) => item.classList.remove('active'));
          chip.classList.add('active');

          monthlyCount.textContent = chip.textContent === '大きな変化のみ' ? '2通' :
            chip.textContent === '週1回' ? '4通' :
            chip.textContent === '毎日' ? '18通' : '6通';

          showToast(`頻度を「${chip.textContent}」にしました`);
        });
      });
    });

    const toneRange = document.getElementById('toneRange');
    const rangeText = document.getElementById('rangeText');

    toneRange.addEventListener('input', () => {
      const value = Number(toneRange.value);
      const labels = {
        1: 'かなり静かめ',
        2: '静かめ',
        3: 'おすすめ',
        4: 'やや多め',
        5: 'しっかり通知'
      };

      rangeText.textContent = labels[value];
    });

    toneRange.addEventListener('change', () => {
      showToast(`通知の強さを「${rangeText.textContent}」にしました`);
    });

    const tapNotice = document.getElementById('tapNotice');
    const step1 = document.getElementById('step1');
    const step2 = document.getElementById('step2');
    const step3 = document.getElementById('step3');
    const aiCount = document.getElementById('aiCount');
    const applyCount = document.getElementById('applyCount');
    const priceValue = document.getElementById('priceValue');

    tapNotice.addEventListener('click', () => {
      step1.classList.add('active');
      step2.classList.add('active');
      aiCount.textContent = String(Number(aiCount.textContent) + 1);
      priceValue.style.transform = 'scale(1.04)';
      priceValue.style.transition = 'transform 0.18s ease';

      window.setTimeout(() => {
        priceValue.style.transform = 'scale(1)';
      }, 220);

      showToast('通知からAI査定画面を開きました');
    });

    document.getElementById('applyButton').addEventListener('click', () => {
      step1.classList.add('active');
      step2.classList.add('active');
      step3.classList.add('active');
      applyCount.textContent = String(Number(applyCount.textContent) + 1);
      showToast('売却相談の申込導線に進みました');
    });

    document.getElementById('laterButton').addEventListener('click', () => {
      showToast('価格確認のみでホームに戻る想定です');
    });
  </script>
</body>
