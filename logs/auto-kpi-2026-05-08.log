    .bar:nth-child(1) { height: 44%; animation-delay: 0.02s; }
    .bar:nth-child(2) { height: 52%; animation-delay: 0.08s; }
    .bar:nth-child(3) { height: 49%; animation-delay: 0.14s; }
    .bar:nth-child(4) { height: 61%; animation-delay: 0.2s; }
    .bar:nth-child(5) { height: 76%; animation-delay: 0.26s; }
    .bar:nth-child(6) { height: 88%; animation-delay: 0.32s; }

    @keyframes barGrow {
      from {
        transform: scaleY(0);
      }
      to {
        transform: scaleY(1);
      }
    }

    .action-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 16px;
    }

    .route-list {
      display: grid;
      gap: 10px;
      margin: 14px 0;
    }

    .route-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      border-radius: 12px;
      background: var(--white);
      border: 1px solid #e5eef8;
    }

    .route-num {
      width: 28px;
      height: 28px;
      border-radius: 14px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      display: grid;
      place-items: center;
      font-size: 14px;
      font-weight: 700;
    }

    .route-text {
      flex: 1;
    }

    .route-title {
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .route-desc {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .complete-badge {
      display: grid;
      place-items: center;
      width: 118px;
      height: 118px;
      margin: 10px auto 18px;
      border-radius: 50%;
      color: var(--white);
      background: var(--gradient-pink);
      font-size: 28px;
      font-weight: 700;
      box-shadow: 0 12px 30px rgba(248,76,162,0.28);
      animation: pop 0.42s ease both;
    }

    @keyframes pop {
      0% {
        transform: scale(0.82);
      }
      70% {
        transform: scale(1.06);
      }
      100% {
        transform: scale(1);
      }
    }

    .kpi-strip {
      display: grid;
