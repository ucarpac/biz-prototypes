<!-- A案: 感情に訴えるアプローチ。ユーザーの不安や期待に寄り添い、安心感を与えるデザイン。暖色系のアクセント、手書き風要素、親しみやすいイラスト的表現 -->
<!DOCTYPE html>
<html lang="ja">
<script src="../auth.js"></script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UcarPAC 通知最適化プロトタイプ</title>
  <style>
    :root {
      --pink: #F84CA2;
      --dark-blue: #1c2663;
      --white: #FFFFFF;
      --text-black: #404040;
      --text-gray: #737373;
      --text-disabled: #B3B3B3;
      --text-placeholder: rgba(28,38,99,0.3);
      --button-gray: #CACEE2;
      --button-link: #4099FF;
      --back-white: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-blue: #091355;
      --back-light-pink: #ffd8e8;
      --error: #EB4646;
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --font-sans: 'Noto Sans JP', 'Hiragino Sans', system-ui, sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
      --warm: #fff3e8;
      --warm-line: #ffd0ac;
      --warm-strong: #ff8a4c;
      --soft-yellow: #fff7cf;
      --soft-green: #e7f8ef;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background: #edf1f4;
      color: var(--text-black);
      font-family: var(--font-sans);
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 8% 2%, rgba(255, 216, 232, 0.75), transparent 28%),
        radial-gradient(circle at 96% 12%, rgba(255, 247, 207, 0.85), transparent 26%),
        linear-gradient(180deg, #fffaf6 0%, #fafafa 42%, #edf1f4 100%);
    }

    button,
    input {
      font-family: inherit;
    }

    button {
      cursor: pointer;
      border: 0;
      -webkit-tap-highlight-color: transparent;
    }

    .app {
      width: 100%;
      max-width: 430px;
      margin: 0 auto;
      min-height: 100vh;
      padding: 18px 0 92px;
      position: relative;
      overflow: hidden;
    }

    .top-bar {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 700;
      color: var(--dark-blue);
      line-height: 21px;
    }

    .brand-mark {
      width: 31px;
      height: 31px;
      border-radius: 12px;
      background: var(--gradient-pink);
      display: grid;
      place-items: center;
      color: var(--white);
      box-shadow: 0 4px 14px rgba(248, 76, 162, 0.28);
    }

    .date-pill {
      min-height: 31px;
      padding: 0 12px;
      border-radius: 22px;
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(255, 208, 172, 0.85);
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .hero {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 18px;
      padding: 18px 16px 16px;
      border-radius: 16px;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 243, 232, 0.96)),
        var(--white);
      box-shadow: 0 8px 28px rgba(28, 38, 99, 0.1);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      right: -30px;
      top: -32px;
      width: 116px;
      height: 116px;
      border-radius: 50%;
      background: rgba(248, 76, 162, 0.11);
    }

    .hero::after {
      content: "";
      position: absolute;
      left: 16px;
      bottom: 13px;
      width: 102px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 138, 76, 0.16);
      transform: rotate(-2deg);
    }

    .hero-inner {
      position: relative;
      z-index: 1;
    }

    .emotion-label {
      width: fit-content;
      padding: 6px 10px;
      border-radius: 22px;
      background: var(--soft-yellow);
      color: #965400;
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      border: 1px solid #ffe8a3;
      transform: rotate(-1deg);
    }

    h1 {
      margin: 12px 0 8px;
      color: var(--dark-blue);
      font-size: 26px;
      font-weight: 700;
      line-height: 39px;
      letter-spacing: 0;
    }

    .hero-copy {
      margin: 0;
      color: var(--text-gray);
      font-size: 14px;
      font-weight: 400;
      line-height: 21px;
    }

    .hero-illustration {
      margin: 16px 0 0;
      min-height: 112px;
      border-radius: 13px;
      background: linear-gradient(180deg, #fff 0%, #fff6ed 100%);
      border: 1px solid var(--warm-line);
      position: relative;
      overflow: hidden;
    }

    .road {
      position: absolute;
      left: -12px;
      right: -12px;
      bottom: 0;
      height: 38px;
      background: #ffe2cb;
      border-radius: 50% 50% 0 0 / 34px 34px 0 0;
    }

    .little-car {
      position: absolute;
      left: 36px;
      bottom: 28px;
      width: 122px;
      height: 46px;
      animation: floatCar 3.2s ease-in-out infinite;
    }

    .car-body {
      position: absolute;
      left: 0;
      bottom: 8px;
      width: 122px;
      height: 31px;
      border-radius: 20px 24px 13px 13px;
      background: #ffffff;
      border: 2px solid var(--dark-blue);
      box-shadow: 0 7px 0 rgba(28, 38, 99, 0.08);
    }

    .car-top {
      position: absolute;
      left: 34px;
      bottom: 30px;
      width: 52px;
      height: 22px;
      border-radius: 20px 20px 4px 4px;
      background: #dff5ff;
      border: 2px solid var(--dark-blue);
    }

    .wheel {
      position: absolute;
      bottom: 0;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--dark-blue);
      border: 4px solid #ffffff;
    }

    .wheel.left {
      left: 21px;
    }

    .wheel.right {
      right: 20px;
    }

    .heart-bubble {
      position: absolute;
      right: 28px;
      top: 18px;
      width: 76px;
      min-height: 58px;
      padding: 10px 8px;
      border-radius: 18px 18px 18px 4px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 20px;
      font-weight: 700;
      text-align: center;
      box-shadow: 0 8px 20px rgba(248, 76, 162, 0.13);
      animation: pulse 2.4s ease-in-out infinite;
    }

    .heart-bubble span {
      display: block;
      color: var(--dark-blue);
      font-size: 10px;
      line-height: 15px;
      margin-top: 2px;
    }

    .tabs {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      padding: 4px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 4px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid var(--ruled-line);
      border-radius: 22px;
      box-shadow: 0 3px 12px rgba(0, 0, 0, 0.04);
      position: sticky;
      top: 8px;
      z-index: 5;
      backdrop-filter: blur(10px);
    }

    .tab-button {
      min-height: 43px;
      border-radius: 22px;
      background: transparent;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      transition: 0.2s ease;
    }

    .tab-button.active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 6px 12px rgba(28, 38, 99, 0.18);
    }

    .screen {
      display: none;
      width: 100%;
      animation: fadeIn 0.24s ease-out;
    }

    .screen.active {
      display: block;
    }

    .section-title {
      width: 90%;
      max-width: 351px;
      margin: 22px auto 10px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
    }

    .section-title h2 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
    }

    .section-title p {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
    }

    .tiny-note {
      flex: 0 0 auto;
      padding: 4px 8px;
      border-radius: 14px;
      background: #fff;
      border: 1px solid #ffe0c4;
      color: #a45a18;
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .card {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 12px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 0 18px rgba(0, 0, 0, 0.08);
      border: 1px solid #f4eef1;
      overflow: hidden;
    }

    .notification-card {
      padding: 16px;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .notification-card.selected {
      border-color: var(--pink);
      box-shadow: 0 8px 26px rgba(248, 76, 162, 0.18);
      transform: translateY(-2px);
    }

    .notification-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }

    .variant-name {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .variant-icon {
      width: 30px;
      height: 30px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: var(--warm);
      border: 1px solid var(--warm-line);
      color: var(--warm-strong);
    }

    .score {
      color: var(--pink);
      font-size: 18px;
      font-weight: 700;
      line-height: 27px;
    }

    .push-preview {
      padding: 12px;
      border-radius: 12px;
      background: #f8f9fb;
      border: 1px solid #edf1f4;
    }

    .push-title {
      margin: 0 0 4px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .push-body {
      margin: 0;
      color: var(--text-black);
      font-size: 13px;
      font-weight: 400;
      line-height: 20px;
    }

    .metrics-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .metric {
      padding: 10px 6px;
      border-radius: 12px;
      background: #fffaf6;
      text-align: center;
      border: 1px solid #ffe8d8;
    }

    .metric strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .metric span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 400;
      line-height: 15px;
      margin-top: 1px;
    }

    .select-button {
      width: 100%;
      min-height: 43px;
      margin-top: 12px;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      transition: transform 0.18s ease;
    }

    .notification-card.selected .select-button {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .select-button:active {
      transform: scale(0.98);
    }

    .insight-band {
      width: 90%;
      max-width: 351px;
      margin: 16px auto 0;
      padding: 16px;
      border-radius: 13px;
      background: linear-gradient(135deg, #091355, #1d2e93);
      color: var(--white);
      box-shadow: 0 8px 22px rgba(9, 19, 85, 0.2);
    }

    .insight-band h3 {
      margin: 0 0 8px;
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .insight-band p {
      margin: 0;
      color: #dbeafe;
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
    }

    .settings-card {
      padding: 16px;
    }

    .setting-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 14px 0;
      border-bottom: 1px solid var(--ruled-line);
    }

    .setting-row:last-child {
      border-bottom: 0;
    }

    .setting-label strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .setting-label span {
      display: block;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
      margin-top: 2px;
    }

    .switch {
      width: 54px;
      height: 31px;
      border-radius: 31px;
      background: #d8dce8;
      padding: 3px;
      flex: 0 0 auto;
      transition: background 0.2s ease;
    }

    .switch.on {
      background: var(--pink);
    }

    .switch-knob {
      width: 25px;
      height: 25px;
      border-radius: 50%;
      background: var(--white);
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
      transition: transform 0.2s ease;
    }

    .switch.on .switch-knob {
      transform: translateX(23px);
    }

    .chips {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding: 4px 0 2px;
      scrollbar-width: none;
    }

    .chips::-webkit-scrollbar {
      display: none;
    }

    .chip {
      flex: 0 0 auto;
      min-width: 88px;
      min-height: 43px;
      padding: 0 14px;
      border-radius: 22px;
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      transition: 0.2s ease;
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
    }

    .range-wrap {
      padding: 16px 0 4px;
    }

    .range-labels {
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      margin-bottom: 8px;
    }

    input[type="range"] {
      width: 100%;
      accent-color: var(--pink);
    }

    .preview-phone {
      width: 90%;
      max-width: 351px;
      margin: 0 auto;
      padding: 16px;
      border-radius: 22px;
      background: #1c2663;
      box-shadow: 0 14px 34px rgba(28, 38, 99, 0.22);
    }

    .phone-screen {
      min-height: 428px;
      border-radius: 18px;
      background: #fffaf6;
      overflow: hidden;
      position: relative;
    }

    .phone-status {
      height: 30px;
      padding: 8px 14px 0;
      display: flex;
      justify-content: space-between;
      color: var(--dark-blue);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
    }

    .tap-notification {
      width: calc(100% - 24px);
      margin: 10px auto 0;
      padding: 12px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid #ffe0ec;
      box-shadow: 0 8px 22px rgba(248, 76, 162, 0.18);
      transform-origin: top;
      animation: dropNotice 0.6s ease-out;
    }

    .tap-notification h3 {
      margin: 0 0 4px;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 700;
      line-height: 20px;
    }

    .tap-notification p {
      margin: 0;
      color: var(--text-black);
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
    }

    .flow-content {
      padding: 18px 14px 16px;
    }

    .car-mini-card {
      padding: 14px;
      border-radius: 13px;
      background: var(--white);
      border: 1px solid #f1d9e5;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
    }

    .car-mini-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .car-name {
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
    }

    .car-detail {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 400;
      line-height: 17px;
    }

    .badge {
      padding: 5px 8px;
      border-radius: 22px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 10px;
      font-weight: 700;
      line-height: 15px;
      white-space: nowrap;
    }

    .price-box {
      margin-top: 14px;
      padding: 13px 12px;
      border-radius: 12px;
      background: #f6fbff;
      border: 1px solid #d9f1ff;
    }

    .price-label {
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 400;
      line-height: 17px;
    }

    .price-value {
      margin-top: 2px;
      color: var(--dark-blue);
      font-size: 32px;
      font-weight: 700;
      line-height: 48px;
    }

    .price-value span {
      font-size: 16px;
      line-height: 24px;
    }

    .up-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 4px;
      padding: 5px 8px;
      border-radius: 22px;
      background: var(--soft-green);
      color: #17834d;
      font-size: 11px;
      font-weight: 700;
      line-height: 17px;
    }

    .graph {
      height: 116px;
      margin-top: 14px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, transparent 24%, rgba(28, 38, 99, 0.06) 25%, transparent 26%),
        linear-gradient(180deg, transparent 49%, rgba(28, 38, 99, 0.06) 50%, transparent 51%),
        linear-gradient(180deg, transparent 74%, rgba(28, 38, 99, 0.06) 75%, transparent 76%),
        #ffffff;
      position: relative;
      overflow: hidden;
      border: 1px solid #edf1f4;
    }

    .graph-line {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 24px;
      height: 68px;
    }

    .graph-line svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .graph-labels {
      position: absolute;
      left: 12px;
      right: 12px;
      bottom: 8px;
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 9px;
      line-height: 14px;
    }

    .flow-steps {
      margin-top: 14px;
      display: grid;
      gap: 8px;
    }

    .flow-step {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid #f2f2f2;
    }

    .step-dot {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
      flex: 0 0 auto;
    }

    .flow-step.active .step-dot {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .flow-step-text strong {
      display: block;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .flow-step-text span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 400;
      line-height: 15px;
    }

    .bottom-action {
      width: 100%;
      margin-top: 16px;
      display: grid;
      gap: 8px;
    }

    .primary-button {
      width: 240px;
      min-height: 43px;
      border-radius: 30px;
      margin: 0 auto;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      box-shadow: 0 8px 18px rgba(29, 220, 255, 0.22);
    }

    .pink-button {
      width: 240px;
      min-height: 43px;
      border-radius: 30px;
      margin: 0 auto;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
