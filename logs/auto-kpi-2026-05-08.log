                    <path d="M0 58 C42 48, 62 52, 90 41 C124 28, 148 36, 176 25 C208 13, 230 19, 260 10 L260 80 L0 80 Z" fill="rgba(248,76,162,0.12)"/>
                    <circle cx="260" cy="10" r="6" fill="#F84CA2"/>
