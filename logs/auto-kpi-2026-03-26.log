      padding: 0 18px 20px;
      font-size: 11px;
      line-height: 1.7;
      color: #6b708d;
    }

    .sparkle {
      position: absolute;
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.74);
      box-shadow: 0 0 20px rgba(255,255,255,0.8);
      animation: sparkle 2.8s infinite ease-in-out;
    }

    .sparkle.s1 { top: 154px; right: 42px; animation-delay: 0s; }
    .sparkle.s2 { top: 270px; left: 28px; animation-delay: 0.8s; }
    .sparkle.s3 { top: 498px; right: 18px; animation-delay: 1.4s; }

    .floating-note {
      position: absolute;
      right: 16px;
      top: 228px;
      background: #fff7d0;
      color: #c67019;
      font-size: 11px;
      font-weight: 900;
      padding: 7px 10px;
      border-radius: 12px;
      transform: rotate(6deg);
      box-shadow: var(--shadow-light);
    }

    .scenario {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .scenario-row {
      display: flex;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.85);
    }

    .scenario-icon {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, #fff2da, #ffe4ea);
      font-size: 19px;
      flex: 0 0 auto;
    }

    .scenario-row strong {
      display: block;
      font-size: 13px;
      color: var(--dark-blue);
      line-height: 1.5;
    }

    .scenario-row span {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .toggle-panel {
      display: flex;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .toggle {
      min-height: 38px;
      border-radius: 22px;
      padding: 8px 12px;
      border: 0;
      font-size: 12px;
      font-weight: 900;
      cursor: pointer;
      background: #fff;
      color: var(--dark-blue);
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.08);
    }

    .toggle.active {
      background: var(--gradient-pink);
      color: #fff;
      box-shadow: none;
    }

    .fade-panel {
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .hidden-panel {
      opacity: 0.28;
      transform: translateY(4px);
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.18); opacity: 0.78; }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    @keyframes sparkle {
      0%, 100% { transform: scale(0.85); opacity: 0.32; }
      50% { transform: scale(1.2); opacity: 1; }
    }

    @media (min-width: 900px) {
      .screens {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 420px) {
      .page {
        padding-left: 10px;
        padding-right: 10px;
      }

      .shot-card {
        padding: 12px;
      }

      .phone {
        padding: 12px;
      }

      .hero-grid {
        grid-template-columns: 1fr 120px;
      }

      .hero-copy h2 {
        font-size: 28px;
      }

      .compare-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
