  <script>
    const focusButtons = document.querySelectorAll('.filter-button');
    const shotCards = document.querySelectorAll('.shot-card');

    focusButtons.forEach((button) => {
      button.addEventListener('click', () => {
        focusButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');
        const focus = button.dataset.focus;
        shotCards.forEach((card) => {
          const visible = focus === 'all' || card.dataset.group === focus;
          card.style.opacity = visible ? '1' : '0.34';
          card.style.transform = visible ? 'translateY(0)' : 'translateY(8px)';
          card.style.transition = 'opacity 220ms ease, transform 220ms ease';
        });
      });
    });

    const aiToggle = document.getElementById('ai-toggle');
    const aiMain = document.getElementById('ai-card-main');
    const aiAlt = document.getElementById('ai-card-alt');
    let aiExpanded = false;

    aiAlt.style.display = 'none';
    aiToggle.addEventListener('click', () => {
      aiExpanded = !aiExpanded;
      aiAlt.style.display = aiExpanded ? 'block' : 'none';
      aiMain.querySelector('.handwritten').textContent = aiExpanded
        ? '予測シナリオで、気持ちの準備までできる。'
        : '「今のうちに知っておく」と安心。';
      aiToggle.textContent = aiExpanded ? '基本表示に戻す' : '予測を見比べる';
    });

    const expensePanel = document.getElementById('expense-panel');
    const futurePanel = document.getElementById('future-panel');
    const modeButtons = document.querySelectorAll('.toggle');

    modeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        modeButtons.forEach((btn) => btn.classList.remove('active'));
        button.classList.add('active');
        const mode = button.dataset.mode;
        const showExpense = mode === 'expense';
        expensePanel.classList.toggle('hidden-panel', !showExpense);
        futurePanel.classList.toggle('hidden-panel', showExpense);
      });
    });

    const quietButton = document.getElementById('quiet-button');
    const quietPanel = document.getElementById('quiet-panel');
    let quietOpen = true;

    quietButton.addEventListener('click', () => {
      quietOpen = !quietOpen;
      quietPanel.style.display = quietOpen ? 'block' : 'none';
      quietButton.textContent = quietOpen ? '安心ポイントを見る' : '売却時の流れを見る';
    });

    document.querySelectorAll('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const parent = chip.parentElement;
        parent.querySelectorAll('.chip').forEach((sibling) => sibling.classList.remove('selected'));
        chip.classList.add('selected');
      });
    });
  </script>
