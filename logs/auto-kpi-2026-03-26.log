    }

    .auction-panel h3 {
      margin: 0 0 8px;
      font-size: 18px;
    }

    .auction-panel p {
      margin: 0;
      font-size: 12px;
      color: var(--text-light-blue);
      line-height: 1.7;
    }

    .auction-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 14px;
    }

    .auction-stat {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 16px;
      padding: 12px 10px;
      text-align: center;
    }

    .auction-stat strong {
      display: block;
      font-size: 20px;
      line-height: 1.2;
    }

    .auction-stat span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      color: var(--text-light-blue);
    }

    .footnote {
      padding: 12px 16px 18px;
      font-size: 10px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    .spark {
      animation: float 3s ease-in-out infinite;
      transform-origin: center;
    }

    .pulse {
      animation: pulse 2.4s ease-in-out infinite;
    }

    .hidden-panel {
      display: none;
    }

    .phone[data-mode="summary"] .mode-summary,
    .phone[data-mode="detail"] .mode-detail,
    .phone[data-mode="compare"] .mode-compare {
      display: block;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-4px); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.88; }
      50% { opacity: 1; }
    }

    @media (max-width: 780px) {
      .kpi-row {
        grid-template-columns: 1fr;
      }

      .hero {
        padding: 18px 14px;
      }

      h1 {
        font-size: 25px;
      }

      .phone {
        max-width: 100%;
      }
    }
  </style>
