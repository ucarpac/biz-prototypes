  <script>
    (function () {
      const track = document.getElementById("track");
      const dots = Array.from(document.querySelectorAll(".dot"));
      const steps = Array.from(document.querySelectorAll(".step"));
      const progressLabel = document.getElementById("progressLabel");
      const heroScore = document.getElementById("heroScore");
      const playFlow = document.getElementById("playFlow");
      const shuffleShots = document.getElementById("shuffleShots");
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const resultBoard = document.getElementById("resultBoard");
      const modeButtons = Array.from(document.querySelectorAll(".lab-toggle button"));
      const kpiChip = document.getElementById("kpiChip");

      let index = 0;
      let autoTimer = null;
      let startX = 0;
      let currentX = 0;
      let dragging = false;

      const scoreMap = [83, 87, 91];
      const resultModes = {
        impact: [
          { title: "AI査定の即時理解", body: "価格レンジが数秒で伝わり、ストアでの離脱抑制に強い。", score: 92 },
          { title: "出費管理 + 未来予測", body: "インストール後の継続価値まで見せられ、比較検討に強い。", score: 84 },
          { title: "電話0本の比較訴求", body: "競合不安を一瞬で反転。特に未認知層向けに刺さる。", score: 89 }
        ],
        retain: [
          { title: "出費管理 + 未来予測", body: "売らない期間でも使い続ける理由を作り、アンインストールを減らす。", score: 93 },
          { title: "AI査定の即時理解", body: "初回利用の満足度が高く、再訪導線の入口を作りやすい。", score: 85 },
          { title: "電話0本の比較訴求", body: "安心して試せるため初回転換に強いが、継続価値の補足が必要。", score: 78 }
        ]
      };

      function updateSlide(nextIndex) {
        index = (nextIndex + 3) % 3;
        track.style.transform = "translateX(-" + (index * 33.333333) + "%)";
        dots.forEach((dot, i) => dot.classList.toggle("active", i === index));
        steps.forEach((step, i) => step.classList.toggle("active", i === index));
        progressLabel.textContent = "STEP " + (index + 1) + " / 3";
        heroScore.textContent = scoreMap[index];
      }

      function renderResults(mode) {
        resultBoard.innerHTML = "";
        resultModes[mode].forEach((item, i) => {
          const row = document.createElement("div");
          row.className = "result" + (i === 0 ? " active" : "");
          row.innerHTML = `
            <div>
              <strong>${item.title}</strong>
              <span>${item.body}</span>
            </div>
            <div class="result-score">${item.score}</div>
          `;
          resultBoard.appendChild(row);
        });
      }

      function startAutoFlow() {
        clearInterval(autoTimer);
        autoTimer = setInterval(() => updateSlide(index + 1), 1700);
        setTimeout(() => clearInterval(autoTimer), 5600);
      }

      function shuffleFlow() {
        const next = Math.floor(Math.random() * 3);
        updateSlide(next);
      }

      dots.forEach((dot) => {
        dot.addEventListener("click", () => updateSlide(Number(dot.dataset.index)));
      });

      prevBtn.addEventListener("click", () => updateSlide(index - 1));
      nextBtn.addEventListener("click", () => updateSlide(index + 1));
      playFlow.addEventListener("click", startAutoFlow);
      shuffleShots.addEventListener("click", shuffleFlow);

      modeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          modeButtons.forEach((b) => b.classList.toggle("active", b === button));
          renderResults(button.dataset.mode);
        });
      });

      kpiChip.addEventListener("click", () => {
        const cycle = ["17.3% 現状", "21.4% 中間仮説", "25.0% KPI"];
        const current = kpiChip.querySelector("span:last-child");
        const now = cycle.indexOf(current.textContent);
        current.textContent = cycle[(now + 1) % cycle.length];
      });

      const stage = document.getElementById("stage");

      stage.addEventListener("touchstart", (e) => {
        dragging = true;
        startX = e.touches[0].clientX;
        currentX = startX;
      }, { passive: true });

      stage.addEventListener("touchmove", (e) => {
        if (!dragging) return;
        currentX = e.touches[0].clientX;
      }, { passive: true });

      stage.addEventListener("touchend", () => {
        if (!dragging) return;
        const delta = currentX - startX;
        if (Math.abs(delta) > 40) {
          updateSlide(index + (delta < 0 ? 1 : -1));
        }
        dragging = false;
      });

      let mouseDown = false;
      stage.addEventListener("mousedown", (e) => {
        mouseDown = true;
        startX = e.clientX;
        currentX = startX;
      });

      window.addEventListener("mousemove", (e) => {
        if (!mouseDown) return;
        currentX = e.clientX;
      });

      window.addEventListener("mouseup", () => {
        if (!mouseDown) return;
        const delta = currentX - startX;
        if (Math.abs(delta) > 50) {
          updateSlide(index + (delta < 0 ? 1 : -1));
        }
        mouseDown = false;
      });

      updateSlide(0);
      renderResults("impact");
    })();
  </script>
</body>
