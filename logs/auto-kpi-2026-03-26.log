    }

    .kpi-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--pink);
      box-shadow: 0 0 0 6px rgba(248,76,162,0.14);
      animation: pulse 1.8s infinite;
    }

    .shell {
      background: rgba(255,255,255,0.78);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.75);
      border-radius: 28px;
      box-shadow: 0 20px 50px rgba(28,38,99,0.12);
      overflow: hidden;
    }

    .hero {
      background: var(--gradient-hero);
      padding: 20px 18px 18px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      right: -60px;
      top: -70px;
      background: radial-gradient(circle, rgba(248,76,162,0.28), transparent 68%);
      animation: float 5s ease-in-out infinite;
    }

    .hero::after {
      content: "";
      position: absolute;
      width: 190px;
      height: 190px;
      left: -90px;
      bottom: -100px;
      background: radial-gradient(circle, rgba(29,220,255,0.25), transparent 68%);
      animation: float 6s ease-in-out infinite reverse;
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      position: relative;
      z-index: 1;
    }

    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .badge {
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .badge.blue {
      color: var(--dark-blue);
      background: rgba(255,255,255,0.85);
      border: 1px solid rgba(64,153,255,0.24);
    }

    .badge.pink {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 8px 16px rgba(248,76,162,0.24);
    }

    .score-orb {
      width: 76px;
      height: 76px;
      border-radius: 50%;
      background: linear-gradient(180deg, #ffffff, #eef8ff);
      display: grid;
      place-items: center;
      box-shadow: inset 0 0 0 7px rgba(29,220,255,0.18), 0 12px 24px rgba(28,38,99,0.12);
      position: relative;
    }

    .score-orb span {
      font-family: var(--font-number);
      color: var(--dark-blue);
      font-size: 28px;
      line-height: 1;
    }

    .hero h1 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 32px;
      line-height: 1.28;
      font-weight: 800;
      letter-spacing: -0.03em;
      position: relative;
      z-index: 1;
    }

    .hero p {
      margin: 10px 0 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 1.65;
      position: relative;
      z-index: 1;
    }

    .hero-cta {
      margin-top: 16px;
      display: flex;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

    .btn {
      appearance: none;
      border: none;
      border-radius: var(--radius-button);
      min-height: 43px;
      padding: 0 18px;
      font-size: 14px;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      transition: transform var(--transition), opacity var(--transition), box-shadow var(--transition);
    }

    .btn:active {
      transform: translateY(1px) scale(0.985);
    }

    .btn-primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 14px 24px rgba(77,180,255,0.28);
      flex: 1;
    }

    .btn-secondary {
      background: rgba(255,255,255,0.84);
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .progress-panel {
      padding: 16px 18px 10px;
      background: linear-gradient(180deg, rgba(255,255,255,0.55), rgba(255,255,255,0));
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }

    .progress-head strong {
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .progress-head span {
      color: var(--text-gray);
      font-size: 12px;
    }

    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .step {
      background: #fff;
      border-radius: 16px;
      padding: 12px 10px;
      border: 1px solid rgba(28,38,99,0.07);
      min-height: 74px;
      transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition), background var(--transition);
    }

    .step.active {
      background: linear-gradient(180deg, rgba(29,220,255,0.12), rgba(248,76,162,0.08));
      border-color: rgba(64,153,255,0.32);
      box-shadow: 0 10px 18px rgba(28,38,99,0.08);
      transform: translateY(-2px);
    }

    .step-index {
      width: 22px;
      height: 22px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--back-gray);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .step.active .step-index {
      background: var(--dark-blue);
      color: #fff;
    }

    .step-title {
      font-size: 12px;
      line-height: 1.35;
      font-weight: 700;
      color: var(--text-black);
    }

    .step-sub {
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.4;
      color: var(--text-gray);
    }

    .carousel-wrap {
      padding: 12px 0 6px;
    }

    .carousel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 18px 14px;
    }

    .carousel-head strong {
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.5;
    }

    .carousel-head span {
      color: var(--text-gray);
      font-size: 12px;
    }

    .stage {
      overflow: hidden;
      position: relative;
    }

    .track {
      display: flex;
      width: 300%;
      transition: transform 420ms cubic-bezier(.2,.82,.18,1);
      touch-action: pan-y;
    }

    .slide {
      width: 100%;
      flex: 0 0 100%;
      padding: 0 18px 20px;
    }

    .screen {
      border-radius: 30px;
      padding: 16px;
      min-height: 620px;
      color: #fff;
      position: relative;
      overflow: hidden;
      box-shadow: 0 16px 32px rgba(28,38,99,0.16);
    }

    .screen::before,
    .screen::after {
      content: "";
      position: absolute;
      border-radius: 50%;
      opacity: 0.24;
      filter: blur(2px);
    }

    .screen-a {
      background: linear-gradient(180deg, #091355 0%, #1c2663 44%, #25379b 100%);
    }

    .screen-a::before {
      width: 180px;
      height: 180px;
      background: #1ddcff;
      right: -60px;
      top: -40px;
    }

    .screen-a::after {
      width: 160px;
      height: 160px;
      background: #F84CA2;
      left: -50px;
      bottom: 80px;
    }

    .screen-b {
      background: linear-gradient(180deg, #fefcff 0%, #ecf7ff 48%, #fff1f8 100%);
      color: var(--dark-blue);
    }

    .screen-b::before {
      width: 180px;
      height: 180px;
      background: rgba(29,220,255,0.28);
      right: -50px;
      top: -30px;
    }

    .screen-b::after {
      width: 190px;
      height: 190px;
      background: rgba(248,76,162,0.22);
      left: -70px;
      bottom: -40px;
    }

    .screen-c {
      background: linear-gradient(180deg, #170f47 0%, #091355 52%, #1f195f 100%);
    }

    .screen-c::before {
      width: 200px;
      height: 200px;
      background: rgba(248,76,162,0.22);
      right: -60px;
      top: 90px;
    }

    .screen-c::after {
      width: 160px;
      height: 160px;
      background: rgba(29,220,255,0.2);
      left: -50px;
      top: -30px;
    }

    .screen-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
      position: relative;
      z-index: 1;
    }

    .platform-tag,
    .shot-index {
      background: rgba(255,255,255,0.16);
      color: #fff;
      border-radius: 999px;
      padding: 7px 11px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.03em;
      backdrop-filter: blur(8px);
    }

    .screen-b .platform-tag,
    .screen-b .shot-index {
      background: rgba(255,255,255,0.78);
      color: var(--dark-blue);
    }

    .screen-kicker {
      font-size: 12px;
      line-height: 1.5;
      opacity: 0.82;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      position: relative;
      z-index: 1;
    }

    .screen-title {
      margin: 8px 0 0;
      font-size: 36px;
      line-height: 1.22;
      font-weight: 900;
      letter-spacing: -0.04em;
      position: relative;
      z-index: 1;
    }

    .screen-sub {
      margin: 12px 0 0;
      font-size: 14px;
      line-height: 1.72;
      opacity: 0.9;
      position: relative;
      z-index: 1;
    }

    .metric-card {
      margin-top: 18px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 24px;
      padding: 14px;
      position: relative;
      z-index: 1;
      backdrop-filter: blur(8px);
    }

    .screen-b .metric-card {
      background: rgba(255,255,255,0.9);
      border-color: rgba(28,38,99,0.06);
      box-shadow: 0 12px 26px rgba(28,38,99,0.08);
    }

    .metric-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 10px;
      margin-bottom: 10px;
    }

    .metric-label {
      font-size: 12px;
      opacity: 0.76;
    }

    .metric-value {
      font-family: var(--font-number);
      font-size: 38px;
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .metric-trend {
      font-size: 12px;
      font-weight: 800;
      color: #9effc9;
    }

    .screen-b .metric-trend {
      color: #0f8f5e;
    }

    .bar-chart {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      height: 116px;
      margin-top: 8px;
    }

    .bar {
      flex: 1;
      border-radius: 14px 14px 6px 6px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(111,194,255,0.34));
      position: relative;
      overflow: hidden;
      min-width: 0;
    }

    .screen-b .bar {
      background: linear-gradient(180deg, rgba(29,220,255,0.95), rgba(77,180,255,0.4));
    }

    .bar::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 24%;
      background: rgba(248,76,162,0.18);
    }

    .bar span {
      position: absolute;
      left: 50%;
      bottom: -22px;
      transform: translateX(-50%);
      font-size: 10px;
      white-space: nowrap;
      opacity: 0.84;
    }

    .bar .bar-value {
      top: 8px;
      bottom: auto;
      font-size: 10px;
      font-weight: 800;
      color: inherit;
      opacity: 1;
    }

    .pill-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
      position: relative;
      z-index: 1;
    }

    .pill {
      padding: 10px 12px;
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 700;
      background: rgba(255,255,255,0.14);
      border: 1px solid rgba(255,255,255,0.16);
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .screen-b .pill {
      background: #fff;
      border-color: rgba(28,38,99,0.08);
      color: var(--dark-blue);
    }

    .carte {
      margin-top: 18px;
      background: #fff;
      border-radius: 20px;
      padding: 14px;
      color: var(--dark-blue);
      box-shadow: 0 12px 26px rgba(28,38,99,0.12);
      position: relative;
      z-index: 1;
    }

    .carte-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .car-name {
      font-size: 16px;
      font-weight: 800;
      line-height: 1.5;
    }

    .chip-mini {
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 11px;
      font-weight: 800;
    }

    .price-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .price-main strong {
      font-family: var(--font-number);
      display: block;
      font-size: 32px;
      line-height: 1.1;
      color: var(--dark-blue);
    }

    .price-main span {
      display: block;
      color: var(--text-gray);
      font-size: 12px;
      margin-top: 3px;
    }

    .phone-mock {
      width: 94px;
      height: 178px;
      border-radius: 22px;
      background: linear-gradient(180deg, #f5fbff, #edf1f4);
      border: 3px solid #fff;
      position: relative;
      overflow: hidden;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.06);
    }

    .phone-mock::before {
      content: "";
      position: absolute;
      width: 38px;
      height: 4px;
      border-radius: 999px;
      background: rgba(28,38,99,0.16);
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
    }

    .phone-screen {
      position: absolute;
      inset: 18px 8px 8px;
      border-radius: 16px;
      background: linear-gradient(180deg, #091355 0%, #1c2663 100%);
      padding: 10px 8px;
      color: #fff;
    }

    .line-graph {
      height: 56px;
      margin-top: 10px;
      position: relative;
    }

    .line-graph svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .cta-card {
      margin-top: 18px;
      position: relative;
      z-index: 1;
      display: flex;
      gap: 10px;
      align-items: stretch;
    }

    .cta-left {
      flex: 1;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 22px;
      padding: 14px;
      backdrop-filter: blur(8px);
    }

    .screen-b .cta-left {
      background: rgba(255,255,255,0.9);
      border-color: rgba(28,38,99,0.06);
    }

    .cta-left strong {
      display: block;
      font-size: 14px;
      line-height: 1.5;
    }

    .cta-left span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      line-height: 1.6;
      opacity: 0.88;
    }

    .floating-badge {
      width: 96px;
      border-radius: 24px;
      background: #fff;
      color: var(--dark-blue);
      box-shadow: 0 14px 28px rgba(28,38,99,0.14);
      display: grid;
      place-items: center;
      text-align: center;
      font-weight: 900;
      font-size: 13px;
      padding: 10px;
      animation: bob 2.2s ease-in-out infinite;
    }

    .compare-board {
      margin-top: 20px;
      background: rgba(255,255,255,0.12);
      border-radius: 24px;
      padding: 14px;
      backdrop-filter: blur(10px);
      position: relative;
      z-index: 1;
    }

    .compare-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .compare-head strong {
      font-size: 15px;
      line-height: 1.5;
    }

    .compare-list {
      display: grid;
      gap: 10px;
    }

    .compare-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .compare-item.highlight {
      background: linear-gradient(90deg, rgba(29,220,255,0.2), rgba(248,76,162,0.2));
      border-color: rgba(255,255,255,0.18);
    }

    .compare-brand {
      font-size: 14px;
      font-weight: 800;
    }

    .compare-copy {
      margin-top: 3px;
      font-size: 11px;
      opacity: 0.82;
      line-height: 1.5;
    }

    .compare-value {
      min-width: 76px;
      text-align: center;
      padding: 10px 10px;
      border-radius: 999px;
      font-family: var(--font-number);
      font-size: 24px;
      background: rgba(255,255,255,0.16);
    }

    .compare-item.highlight .compare-value {
      background: #fff;
      color: var(--pink);
    }

    .controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      padding: 0 18px 18px;
    }

    .dots {
      display: flex;
      gap: 8px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: none;
      background: #d6ddf7;
      cursor: pointer;
      padding: 0;
      transition: transform var(--transition), background var(--transition), width var(--transition);
    }

    .dot.active {
      width: 28px;
      border-radius: 999px;
      background: var(--dark-blue);
    }

    .navs {
      display: flex;
      gap: 10px;
    }

    .nav-btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: none;
      background: #fff;
      color: var(--dark-blue);
      font-size: 20px;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(28,38,99,0.1);
      transition: transform var(--transition), background var(--transition);
    }

    .nav-btn:active {
      transform: scale(0.96);
    }

    .lab {
      padding: 0 18px 18px;
    }

    .lab-card {
      background: linear-gradient(180deg, #fff 0%, #f8fbff 100%);
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 12px 24px rgba(28,38,99,0.07);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .lab-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }

    .lab-head strong {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
    }

    .lab-toggle {
      display: inline-flex;
      background: var(--back-gray);
      border-radius: 999px;
      padding: 4px;
      gap: 4px;
    }

    .lab-toggle button {
      appearance: none;
      border: none;
      border-radius: 999px;
      padding: 8px 12px;
      font: inherit;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-gray);
      background: transparent;
      cursor: pointer;
      transition: background var(--transition), color var(--transition);
    }

    .lab-toggle button.active {
      background: #fff;
      color: var(--dark-blue);
      box-shadow: 0 5px 12px rgba(28,38,99,0.08);
    }

    .result-board {
      display: grid;
      gap: 12px;
    }

    .result {
      padding: 14px;
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(28,38,99,0.06);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    }

    .result.active {
      transform: translateY(-2px);
      box-shadow: 0 12px 24px rgba(28,38,99,0.08);
      border-color: rgba(64,153,255,0.22);
    }

    .result strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
    }

    .result span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.6;
    }

    .result-score {
      font-family: var(--font-number);
      font-size: 28px;
      color: var(--pink);
      white-space: nowrap;
    }

    .footer-note {
      padding: 0 18px 22px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
    }

    .spark {
      display: inline-block;
      animation: spark 1.2s ease-in-out infinite alternate;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 0.9; }
      50% { transform: scale(1.2); opacity: 0.65; }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(12px); }
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0) rotate(-4deg); }
      50% { transform: translateY(-7px) rotate(2deg); }
    }

    @keyframes spark {
      from { transform: translateY(0) scale(1); }
      to { transform: translateY(-2px) scale(1.08); }
    }

    @media (min-width: 768px) {
      body {
        padding-top: 28px;
      }

      .app {
        max-width: 460px;
      }

      .screen {
        min-height: 660px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <div class="brand">
        <div class="brand-mark"></div>
        <div class="brand-copy">
          <strong>UcarPAC App</strong>
          <span>ストアCVR改善プロトタイプ</span>
        </div>
      </div>
      <button class="kpi-chip" id="kpiChip" aria-label="KPIを表示">
        <span class="kpi-dot"></span>
        <span><strong>17.3%</strong> → 25%</span>
      </button>
    </div>

    <main class="shell">
      <section class="hero">
        <div class="hero-top">
