  <script>
    (function () {
      var chips = Array.prototype.slice.call(document.querySelectorAll(".chip[data-view]"));
      var phones = Array.prototype.slice.call(document.querySelectorAll(".phone"));
      var animateBtn = document.getElementById("animateBtn");
      var chartA = document.getElementById("chartA");
      var chartBValue = document.getElementById("chartBValue");
      var chartBCost = document.getElementById("chartBCost");
      var toggled = false;

      chips.forEach(function (chip) {
        chip.addEventListener("click", function () {
          chips.forEach(function (c) { c.classList.remove("active"); });
          chip.classList.add("active");
          var mode = chip.getAttribute("data-view");
          phones.forEach(function (phone) {
            phone.setAttribute("data-mode", mode);
          });
        });
      });

      animateBtn.addEventListener("click", function () {
        toggled = !toggled;

        if (toggled) {
          chartA.setAttribute("d", "M20 118 C55 110, 92 106, 120 102 S190 88, 215 68 S268 41, 300 36");
          chartBValue.setAttribute("d", "M24 56 C70 62, 92 74, 126 90 S190 108, 220 121 S274 132, 304 140");
          chartBCost.setAttribute("d", "M24 132 C62 124, 92 118, 126 100 S192 84, 220 66 S274 52, 304 40");
          animateBtn.textContent = "初期グラフに戻す";
        } else {
          chartA.setAttribute("d", "M20 118 C55 106, 92 102, 120 96 S190 82, 215 74 S268 53, 300 46");
          chartBValue.setAttribute("d", "M24 52 C70 58, 92 70, 126 82 S190 98, 220 114 S274 125, 304 132");
          chartBCost.setAttribute("d", "M24 130 C62 122, 92 118, 126 108 S192 96, 220 84 S274 66, 304 50");
          animateBtn.textContent = "グラフを更新";
        }
      });

      Array.prototype.forEach.call(document.querySelectorAll(".btn"), function (btn) {
        btn.addEventListener("click", function () {
          var original = btn.textContent;
          btn.textContent = "検証メモに保存済み";
          btn.style.opacity = "0.82";
          setTimeout(function () {
            btn.textContent = original;
            btn.style.opacity = "1";
          }, 1400);
        });
      });
    })();
  </script>
