      min-height: 43px;
      border-radius: var(--radius-button);
      border: none;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.5;
      font-weight: 900;
      cursor: pointer;
      transition: transform 0.18s ease, filter 0.2s ease;
    }

    .btn-primary:hover {
