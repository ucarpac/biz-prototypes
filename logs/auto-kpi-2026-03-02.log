      margin: 8px 0 0;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      line-height: 1.4;
      color: var(--text-gray);
      font-weight: 700;
    }

    .toggle-line input {
      accent-color: var(--dark-blue);
    }

    .active-scenarios {
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.6;
      color: var(--dark-blue);
      font-weight: 700;
      min-height: 20px;
    }

    .reveal {
      opacity: 0;
      transform: translateY(12px);
    }

    .reveal.show {
      animation: floatUp 0.55s ease forwards;
    }

    @keyframes floatUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.35);
      }
      70% {
        box-shadow: 0 0 0 10px rgba(248, 76, 162, 0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(248, 76, 162, 0);
      }
    }

    @media (min-width: 720px) {
      .tabs {
        grid-template-columns: repeat(3, 1fr);
      }

      .kpi-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .history-grid {
        grid-template-columns: 1.2fr 1fr;
      }
    }

    @media (min-width: 920px) {
      .panel {
        grid-template-columns: minmax(340px, 380px) 1fr;
        align-items: start;
      }

      .analysis {
        padding: 14px;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="card hero reveal">
      <div class="badge-row">
        <span class="badge hot">ASO日次差分 2026-03-02</span>
        <span class="badge">対象KPI: ストアPV→DL率</span>
        <span class="badge">現状 17.3% / 目標 25%</span>
      </div>
      <h1 class="title">UcarPAC ストアスクショ改善ダッシュボード</h1>
      <p class="subtitle">
        ストア詳細ページ閲覧からDLへのCVR改善を目的に、スクショA/B/Cをデータドリブンで比較。
        AI査定・出費管理・競合比較の3軸で仮説を検証し、DL率25%到達の打ち手を更新します。
      </p>
    </header>

    <section class="card kpi-block reveal">
      <div class="kpi-grid">
        <article class="kpi-item">
          <p class="kpi-label">現在CVR</p>
          <p class="kpi-number">17.3%</p>
        </article>
        <article class="kpi-item">
          <p class="kpi-label">目標CVR</p>
          <p class="kpi-number">25.0%</p>
        </article>
        <article class="kpi-item">
          <p class="kpi-label">不足差分</p>
          <p class="kpi-number small" id="gapValue">7.7pt</p>
        </article>
        <article class="kpi-item">
          <p class="kpi-label">試算CVR</p>
          <p class="kpi-number" id="expectedValue">17.3%</p>
        </article>
      </div>

      <div class="meter-wrap">
        <div class="meter-item">
          <div class="meter-head">
            <p class="meter-title">現在値の達成率（目標25%基準）</p>
            <p class="meter-value" id="currentRatioLabel">69.2%</p>
          </div>
          <div class="track">
            <span class="fill current" id="currentFill"></span>
          </div>
        </div>
        <div class="meter-item">
          <div class="meter-head">
            <p class="meter-title">スクショ施策適用後の達成率（試算）</p>
            <p class="meter-value" id="expectedRatioLabel">69.2%</p>
          </div>
          <div class="track">
            <span class="fill expected" id="expectedFill"></span>
          </div>
        </div>
      </div>

      <div class="status-row">
        <span class="status" id="statusBadge">目標まで +7.7pt</span>
        <button class="btn-reset" id="resetBtn" type="button">試算をリセット</button>
      </div>
      <div class="active-scenarios" id="activeScenarios">適用中: なし</div>
    </section>

    <section class="card tab-card reveal">
      <div class="tabs" role="tablist" aria-label="スクリーンショット案の切替">
        <button class="tab is-active" type="button" data-tab="a" role="tab" aria-selected="true">スクショA（iOS）AI査定</button>
        <button class="tab" type="button" data-tab="b" role="tab" aria-selected="false">スクショB（Android）出費+予測</button>
        <button class="tab" type="button" data-tab="c" role="tab" aria-selected="false">スクショC 競合比較「電話0本」</button>
      </div>
      <p class="hypothesis" id="hypothesisText">
        仮説A: 「AI査定 + 6ヶ月予測」を1画面目で見せることで、価値理解を高速化しDL率を押し上げる。
      </p>
    </section>

    <section class="card panel reveal" id="panel-a" data-panel="a">
      <div class="phone-box">
        <div class="phone ios">
          <div class="notch"></div>
          <div class="topbar">
            <span>9:41</span>
            <span>5G 100%</span>
          </div>
          <div class="screen">
