  <script>
    (function () {
      const shots = Array.from(document.querySelectorAll(".shot"));
      const dots = Array.from(document.querySelectorAll(".dot"));
      const counter = document.getElementById("shotCounter");
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const feedback = document.getElementById("feedback");
      const simulateBtn = document.getElementById("simulateBtn");
      const rateNow = document.getElementById("rateNow");
      const kpiFill = document.getElementById("kpiFill");
      const remainLabel = document.getElementById("remainLabel");
      const pills = Array.from(document.querySelectorAll(".pill"));
      const copyPreview = document.getElementById("copyPreview");

      let current = 0;
      let timer = null;
      let improved = false;

      function renderShot(nextIndex) {
        current = (nextIndex + shots.length) % shots.length;
        shots.forEach((shot, i) => {
          shot.classList.toggle("active", i === current);
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle("active", i === current);
        });
        counter.textContent = (current + 1) + " / " + shots.length;
      }

      function runAutoPlay() {
        clearInterval(timer);
        timer = setInterval(function () {
          renderShot(current + 1);
        }, 7000);
      }

      prevBtn.addEventListener("click", function () {
        renderShot(current - 1);
        runAutoPlay();
      });

      nextBtn.addEventListener("click", function () {
        renderShot(current + 1);
        runAutoPlay();
      });

      dots.forEach(function (dot, i) {
        dot.addEventListener("click", function () {
          renderShot(i);
          runAutoPlay();
        });
      });

      const actionLabel = {
        A: "A案を選択: 「AI査定の安心感」をファーストビューで強調しました。",
        B: "B案を選択: 「出費管理 + 将来予測」の実益を明確化しました。",
        C: "C案を選択: 「電話0本」比較訴求を強く表示しました。"
      };

      document.querySelectorAll(".cta").forEach(function (button) {
        button.addEventListener("click", function () {
          const key = button.getAttribute("data-action");
          feedback.textContent = actionLabel[key] || "訴求を更新しました。";
          feedback.classList.add("show");
          button.classList.add("pressed");
          setTimeout(function () {
            button.classList.remove("pressed");
          }, 220);
          setTimeout(function () {
            feedback.classList.remove("show");
          }, 1800);
        });
      });

      function animateRate(from, to, duration) {
        const start = performance.now();
        function tick(now) {
          const t = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          const value = from + (to - from) * eased;
          rateNow.textContent = value.toFixed(1) + "%";
          if (t < 1) {
            requestAnimationFrame(tick);
          }
        }
        requestAnimationFrame(tick);
      }

      simulateBtn.addEventListener("click", function () {
        const currentValue = parseFloat(rateNow.textContent.replace("%", "")) || 17.3;
        const nextValue = improved ? 17.3 : 24.8;

        animateRate(currentValue, nextValue, 800);
        kpiFill.style.width = improved ? "69.2%" : "99.2%";
        remainLabel.textContent = improved ? "目標まで 7.7pt" : "目標まで 0.2pt";
        simulateBtn.textContent = improved ? "改善シミュレーションを見る" : "現状値に戻す";
        improved = !improved;
      });

      pills.forEach(function (pill) {
        pill.addEventListener("click", function () {
          pills.forEach(function (p) {
            p.classList.remove("is-active");
          });
          pill.classList.add("is-active");
          copyPreview.textContent = pill.getAttribute("data-message");
        });
      });

      renderShot(0);
      runAutoPlay();
    })();
  </script>
</body>
