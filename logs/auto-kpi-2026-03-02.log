  <script>
    const platformData = {
      all: {
        pv: 42180,
        dl: 7297,
        cvr: 17.3,
        target: 25.0,
        trend: [16.5, 16.9, 17.1, 17.3],
        score: 88
      },
      ios: {
        pv: 22110,
        dl: 4046,
        cvr: 18.3,
        target: 25.0,
        trend: [17.2, 17.8, 18.0, 18.3],
        score: 90
      },
      android: {
        pv: 20070,
        dl: 3251,
        cvr: 16.2,
        target: 25.0,
        trend: [15.5, 15.9, 16.0, 16.2],
        score: 84
      }
    };

    const impacts = {
      A: { all: 2.1, ios: 2.8, android: 1.4 },
      B: { all: 1.9, ios: 1.2, android: 2.7 },
      C: { all: 1.3, ios: 1.1, android: 1.5 }
    };

    let currentPlatform = "all";
    let activeShots = { A: true, B: true, C: true };

    const heroCvr = document.getElementById("heroCvr");
    const goalMeter = document.getElementById("goalMeter");
    const pvVal = document.getElementById("pvVal");
    const dlVal = document.getElementById("dlVal");
    const gapVal = document.getElementById("gapVal");
    const upliftVal = document.getElementById("upliftVal");
    const forecastCvr = document.getElementById("forecastCvr");
    const rollout = document.getElementById("rollout");
    const rolloutLabel = document.getElementById("rolloutLabel");
    const trendLine = document.getElementById("trendLine");
    const forecastLine = document.getElementById("forecastLine");
    const scoreUcar = document.getElementById("scoreUcar");

    function formatInt(n) {
      return n.toLocaleString("ja-JP");
    }

    function getEnabledUplift(platformKey) {
      let value = 0;
      Object.keys(activeShots).forEach((k) => {
        if (activeShots[k]) value += impacts[k][platformKey];
      });
      return value;
    }

    function mapPoint(index, val) {
      const x = 26 + index * 70;
      const y = 95 - val * 2.5;
      return `${x},${Math.max(12, Math.min(95, y))}`;
    }

    function updateChart(baseCvr, projected) {
      const t = platformData[currentPlatform].trend;
      const basePoints = t.map((v, i) => mapPoint(i, v)).join(" ");
      trendLine.setAttribute("points", basePoints);

      const forecastPoints = [mapPoint(3, t[3]), mapPoint(4, projected)].join(" ");
      forecastLine.setAttribute("points", forecastPoints);
      forecastLine.classList.add("pulse");
      setTimeout(() => forecastLine.classList.remove("pulse"), 450);
    }

    function updateUI(animate = false) {
      const d = platformData[currentPlatform];
      const rolloutRate = Number(rollout.value) / 100;
      const uplift = getEnabledUplift(currentPlatform);
      const projected = +(d.cvr + uplift * rolloutRate).toFixed(1);

      pvVal.textContent = formatInt(d.pv);
      dlVal.textContent = formatInt(d.dl);
      heroCvr.textContent = `${d.cvr.toFixed(1)}%`;
      gapVal.textContent = `${(d.cvr - d.target).toFixed(1)}pt`;
      upliftVal.textContent = `+${uplift.toFixed(1)}pt`;
      forecastCvr.textContent = `${projected.toFixed(1)}%`;
      rolloutLabel.textContent = `${rollout.value}%`;

      const meterPercent = Math.min(100, (d.cvr / d.target) * 100);
      goalMeter.style.width = `${meterPercent}%`;
      scoreUcar.style.width = `${d.score}%`;

      updateChart(d.cvr, projected);

      if (animate) {
        forecastCvr.classList.add("pulse");
        setTimeout(() => forecastCvr.classList.remove("pulse"), 550);
      }
    }

    document.querySelectorAll(".chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
        btn.classList.add("active");
        currentPlatform = btn.dataset.platform;
        updateUI(true);
      });
    });

    document.querySelectorAll(".tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".tab").forEach((t) => t.classList.remove("active"));
        document.querySelectorAll(".shot").forEach((s) => s.classList.remove("active"));
        tab.classList.add("active");
        document.getElementById(tab.dataset.shot).classList.add("active");
      });
    });

    document.querySelectorAll(".shot-toggle").forEach((toggle) => {
      toggle.addEventListener("change", (e) => {
        activeShots[e.target.dataset.key] = e.target.checked;
        updateUI(true);
      });
    });

    rollout.addEventListener("input", () => updateUI(false));

    document.getElementById("simulateBtn").addEventListener("click", () => {
      updateUI(true);
      const v = parseFloat(forecastCvr.textContent);
      const base = platformData[currentPlatform].cvr;
      const ratio = Math.min(100, (v / platformData[currentPlatform].target) * 100);
      goalMeter.style.width = `${ratio}%`;
      heroCvr.textContent = `${v.toFixed(1)}%`;
      setTimeout(() => {
        heroCvr.textContent = `${base.toFixed(1)}%`;
        goalMeter.style.width = `${Math.min(100, (base / platformData[currentPlatform].target) * 100)}%`;
      }, 1200);
    });

    updateUI();
  </script>
</body>
</html>
