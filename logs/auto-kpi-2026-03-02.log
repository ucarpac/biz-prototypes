  <script>
    const tabs = document.querySelectorAll(".tab-btn");
    const shots = document.querySelectorAll(".shot");

    tabs.forEach((btn) => {
      btn.addEventListener("click", () => {
        tabs.forEach((b) => b.classList.remove("active"));
        shots.forEach((s) => s.classList.remove("active"));
        btn.classList.add("active");
        const target = document.getElementById(btn.dataset.target);
        if (target) target.classList.add("active");
      });
    });

    const simulateBtn = document.getElementById("simulateBtn");
    const aiPrice = document.getElementById("aiPrice");
    let simulated = false;

    simulateBtn.addEventListener("click", () => {
      if (simulateBtn.classList.contains("loading")) return;
      simulateBtn.classList.add("loading");
      simulateBtn.textContent = "AIが市場データを解析中...";
      setTimeout(() => {
        simulated = !simulated;
        aiPrice.innerHTML = simulated ? "168.5<small>万円</small>" : "162.0<small>万円</small>";
        simulateBtn.textContent = simulated ? "もう一度シミュレーションする" : "10秒で査定を更新する";
        simulateBtn.classList.remove("loading");
      }, 1400);
    });

    const monthData = {
      "1月": { fuel: 12800, parking: 18000, insurance: 8500, total: 39300, future: "168.5万", range: "158〜172万", diff: "-4,100円" },
      "2月": { fuel: 14100, parking: 18000, insurance: 8500, total: 40600, future: "167.8万", range: "157〜171万", diff: "-2,800円" },
      "3月": { fuel: 11900, parking: 18000, insurance: 8500, total: 38400, future: "169.1万", range: "159〜173万", diff: "-5,000円" },
      "4月": { fuel: 13500, parking: 18000, insurance: 12300, total: 43800, future: "170.2万", range: "160〜175万", diff: "+400円" }
    };

    const monthChips = document.querySelectorAll(".month-chip");
    const monthlyCost = document.getElementById("monthlyCost");
    const futurePrice = document.getElementById("futurePrice");
    const rangeVal = document.getElementById("rangeVal");
    const fuelBar = document.getElementById("fuelBar");
    const parkingBar = document.getElementById("parkingBar");
    const insuranceBar = document.getElementById("insuranceBar");
    const fuelVal = document.getElementById("fuelVal");
    const parkingVal = document.getElementById("parkingVal");
    const insuranceVal = document.getElementById("insuranceVal");

    function applyMonth(month) {
      const data = monthData[month];
      if (!data) return;
      const max = 22000;
      fuelBar.style.width = Math.min((data.fuel / max) * 100, 100) + "%";
      parkingBar.style.width = Math.min((data.parking / max) * 100, 100) + "%";
      insuranceBar.style.width = Math.min((data.insurance / max) * 100, 100) + "%";
      fuelVal.textContent = data.fuel.toLocaleString("ja-JP") + "円";
      parkingVal.textContent = data.parking.toLocaleString("ja-JP") + "円";
      insuranceVal.textContent = data.insurance.toLocaleString("ja-JP") + "円";
      monthlyCost.textContent = data.total.toLocaleString("ja-JP") + "円";
      futurePrice.textContent = data.future;
      rangeVal.textContent = data.range;
      document.querySelector("#shotB .kpi .sub").textContent = "先月比 " + data.diff;
    }

    monthChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        monthChips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        applyMonth(chip.dataset.month);
      });
    });

    const modeButtons = document.querySelectorAll(".mode-btn");
    const callClaim = document.getElementById("callClaim");
    const callSub = document.getElementById("callSub");
    const tablePhone = document.getElementById("tablePhone");

    const modeData = {
      check: {
        claim: "電話0本",
        sub: "個人情報不要で、相場を見てから判断できる",
        phone: "0本"
      },
      sell: {
        claim: "電話1社のみ",
        sub: "売却相談に進んでも、やりとり窓口は1社だけ",
        phone: "1社"
      }
    };

    modeButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        modeButtons.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const mode = modeData[btn.dataset.mode];
        if (!mode) return;
        callClaim.textContent = mode.claim;
        callSub.textContent = mode.sub;
        tablePhone.textContent = mode.phone;
      });
    });
  </script>
</body>
