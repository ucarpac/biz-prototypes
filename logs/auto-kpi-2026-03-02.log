  <script>
    (function () {
      const tabs = document.querySelectorAll(".tab-btn");
      const screens = document.querySelectorAll(".screen");

      tabs.forEach((btn) => {
        btn.addEventListener("click", function () {
          const target = this.getAttribute("data-target");
          tabs.forEach((b) => b.classList.remove("active"));
          this.classList.add("active");
          screens.forEach((s) => s.classList.remove("active"));
          const panel = document.getElementById(target);
          if (panel) panel.classList.add("active");
        });
      });

      const aPrice = document.getElementById("aPrice");
      const aConfidence = document.getElementById("aConfidence");
      const aRefresh = document.getElementById("aRefresh");
      const aSeries = [
        { price: 2184000, confidence: "予測信頼度 88%（前日比 +1.3%）" },
        { price: 2231000, confidence: "予測信頼度 90%（前日比 +1.9%）" },
        { price: 2149000, confidence: "予測信頼度 86%（前日比 -0.8%）" },
        { price: 2207000, confidence: "予測信頼度 89%（前日比 +1.5%）" }
      ];
      let aIndex = 0;

      function formatYen(num) {
        return "¥" + Number(num).toLocaleString("ja-JP");
      }

      if (aRefresh) {
        aRefresh.addEventListener("click", function () {
          aIndex = (aIndex + 1) % aSeries.length;
          aPrice.textContent = formatYen(aSeries[aIndex].price);
          aConfidence.textContent = aSeries[aIndex].confidence;
          aRefresh.classList.add("pressed");
          setTimeout(() => aRefresh.classList.remove("pressed"), 420);
        });
      }

      const bData = {
        total: {
          title: "2026年2月の維持費（総額）",
          total: "¥45,800",
          amounts: ["¥12,600", "¥9,400", "¥5,800", "¥18,000"],
          widths: [63, 47, 29, 90],
          now: "¥1,780,000",
          m3: "¥1,735,000",
          m6: "¥1,690,000"
        },
        fuel: {
          title: "2026年2月の維持費（ガソリン重視）",
          total: "¥12,600",
          amounts: ["¥12,600", "¥6,200", "¥3,400", "¥5,100"],
          widths: [90, 44, 24, 36],
          now: "¥1,780,000",
          m3: "¥1,746,000",
          m6: "¥1,703,000"
        },
        insurance: {
          title: "2026年2月の維持費（保険重視）",
          total: "¥9,400",
          amounts: ["¥5,100", "¥9,400", "¥2,900", "¥4,200"],
          widths: [49, 90, 28, 40],
          now: "¥1,780,000",
          m3: "¥1,739,000",
          m6: "¥1,695,000"
        },
        maintenance: {
          title: "2026年2月の維持費（整備重視）",
          total: "¥5,800",
          amounts: ["¥3,000", "¥3,500", "¥5,800", "¥2,600"],
          widths: [46, 53, 90, 40],
          now: "¥1,780,000",
          m3: "¥1,752,000",
          m6: "¥1,721,000"
        }
      };

      const bTitle = document.getElementById("bTitle");
      const bTotal = document.getElementById("bTotalExpense");
      const bNow = document.getElementById("bNow");
      const b3m = document.getElementById("b3m");
      const b6m = document.getElementById("b6m");
      const bBars = [
        document.getElementById("bBar0"),
        document.getElementById("bBar1"),
        document.getElementById("bBar2"),
        document.getElementById("bBar3")
      ];
      const bAmts = [
        document.getElementById("bAmt0"),
        document.getElementById("bAmt1"),
        document.getElementById("bAmt2"),
        document.getElementById("bAmt3")
      ];
      const bChips = document.querySelectorAll(".chip-filter");
      const bCycle = document.getElementById("bCycle");
      const modes = ["total", "fuel", "insurance", "maintenance"];
      let currentMode = "total";
      let autoIndex = 0;
      let autoTimer = null;

      function renderB(mode) {
        const item = bData[mode];
        if (!item) return;
        currentMode = mode;
        bTitle.textContent = item.title;
        bTotal.textContent = item.total;
        bNow.textContent = item.now;
        b3m.textContent = item.m3;
        b6m.textContent = item.m6;
        item.widths.forEach((w, i) => {
          if (bBars[i]) bBars[i].style.width = w + "%";
        });
        item.amounts.forEach((amt, i) => {
          if (bAmts[i]) bAmts[i].textContent = amt;
        });
        bChips.forEach((chip) => {
          chip.classList.toggle("active", chip.getAttribute("data-mode") === mode);
        });
      }

      bChips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const mode = chip.getAttribute("data-mode");
          renderB(mode);
        });
      });

      if (bCycle) {
        bCycle.addEventListener("click", () => {
          if (autoTimer) {
            clearInterval(autoTimer);
            autoTimer = null;
            bCycle.textContent = "カテゴリを自動切替する";
            return;
          }
          bCycle.textContent = "自動切替を停止する";
          autoTimer = setInterval(() => {
            autoIndex = (autoIndex + 1) % modes.length;
            renderB(modes[autoIndex]);
          }, 1400);
        });
      }

      renderB("total");

      const cPlay = document.getElementById("cPlay");
      const cBarU = document.getElementById("cBarU");
      const cBarM = document.getElementById("cBarM");
      const cBarB = document.getElementById("cBarB");
      const cValU = document.getElementById("cValU");
      const cValM = document.getElementById("cValM");
      const cValB = document.getElementById("cValB");

      function animateCount(el, target) {
        const totalFrames = 22;
        let frame = 0;
        const start = 0;
        const step = (target - start) / totalFrames;
        const timer = setInterval(() => {
          frame += 1;
          const value = Math.round(start + step * frame);
          el.textContent = value + "本";
          if (frame >= totalFrames) {
            el.textContent = target + "本";
            clearInterval(timer);
          }
        }, 24);
      }

      function playCompare() {
        cBarU.style.width = "0%";
        cBarM.style.width = "0%";
        cBarB.style.width = "0%";
        cValU.textContent = "0本";
        cValM.textContent = "0本";
        cValB.textContent = "0本";

        setTimeout(() => {
          cBarU.style.width = "2%";
          cBarM.style.width = "30%";
          cBarB.style.width = "100%";
          animateCount(cValU, 0);
          animateCount(cValM, 3);
          animateCount(cValB, 10);
        }, 120);
      }

      if (cPlay) {
        cPlay.addEventListener("click", playCompare);
      }

      playCompare();
    })();
  </script>
