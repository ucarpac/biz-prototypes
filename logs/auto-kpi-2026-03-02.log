      color: var(--text-black);
      font-size: 13px;
      line-height: 1.5;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      padding: 0 12px;
    }

    .tab.is-active {
      border-color: rgba(28, 38, 99, 0.05);
      background: var(--dark-blue);
