      letter-spacing: 0.01em;
    }

    .kpi-number.small {
      font-size: 24px;
    }

    .meter-wrap {
      display: grid;
      gap: 10px;
    }

    .meter-item {
      border-radius: 12px;
      border: 1px solid #edf2f7;
      padding: 10px;
      background: #fcfeff;
    }

    .meter-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
