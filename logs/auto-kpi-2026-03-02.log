        <li id="stepPill2">STEP 3</li>
      </ol>
      <h2 id="questionTitle">Q1. 売却の検討タイミングは？</h2>
      <div class="option-grid" id="options"></div>
      <p class="quest-result" id="questResult">3問に答えると、刺さる訴求スクショへ自動スワイプします。</p>
    </section>

    <section class="carousel-panel">
      <div class="panel-head">
        <h3>ストアスクショ・プロトタイプ</h3>
        <p>左右スワイプで切替</p>
      </div>
      <div class="viewport" id="viewport">
        <div class="track" id="track">
          <article class="slide">
            <div class="phone">
              <div class="phone-shell">
                <div class="notch"></div>
                <div class="phone-top">
                  <span>9:41</span>
                  <span>5G</span>
                  <span>100%</span>
                </div>
                <div class="shot-content ai">
                  <span class="platform-label">スクショA / iOS向け</span>
                  <h3 class="shot-title">AIがあなたの愛車を<br>10秒で査定</h3>
                  <div class="badge-row">
                    <span class="badge pink">個人情報入力なし</span>
                    <span class="badge">最短3ステップ</span>
                  </div>
                  <div class="price-card">
                    <p class="car-name">トヨタ プリウス S (2019)</p>
                    <p class="car-sub">走行 43,200km / パールホワイト / 千葉県</p>
                    <p class="price">¥1,642,000</p>
                    <p class="price-note">前週比 +¥22,000 / 需要上昇中</p>
                  </div>
                  <div class="mini-steps">
                    <span class="mini-step active">1 車種</span>
                    <span class="mini-step">2 写真</span>
                    <span class="mini-step">3 完了</span>
                  </div>
                  <button class="shot-cta" type="button">いますぐ相場をチェック</button>
                </div>
              </div>
            </div>
          </article>

          <article class="slide">
            <div class="phone">
              <div class="phone-shell">
                <div class="phone-top android">
                  <span>10:28</span>
                  <span>5G</span>
                  <span>88%</span>
                </div>
                <div class="shot-content expense">
                  <span class="platform-label light">スクショB / Android向け</span>
                  <h3 class="shot-title dark">出費管理 + 将来予測で<br>売り時を逃さない</h3>
                  <div class="badge-row">
                    <span class="badge dark">維持費の見える化</span>
                    <span class="badge dark">3か月先を予測</span>
                  </div>

                  <div class="expense-list">
                    <div class="expense-item">
                      <span>ガソリン</span>
                      <strong>¥18,400</strong>
                      <div class="bar"><i style="width:82%"></i></div>
                    </div>
                    <div class="expense-item">
                      <span>保険</span>
                      <strong>¥7,800</strong>
                      <div class="bar"><i style="width:46%"></i></div>
                    </div>
                    <div class="expense-item">
                      <span>整備・洗車</span>
                      <strong>¥6,200</strong>
                      <div class="bar"><i style="width:39%"></i></div>
                    </div>
                  </div>

                  <div class="forecast">
                    <h4>査定予測（ホンダ ヴェゼル e:HEV Z 2021）</h4>
                    <div class="forecast-grid">
                      <div class="forecast-col"><i style="height:48px"></i>今月<br>¥2.31M</div>
                      <div class="forecast-col"><i style="height:44px"></i>1か月後<br>¥2.27M</div>
                      <div class="forecast-col"><i style="height:40px"></i>3か月後<br>¥2.21M</div>
                      <div class="forecast-col"><i style="height:35px"></i>6か月後<br>¥2.14M</div>
                    </div>
                  </div>

                  <button class="shot-cta" type="button">売り時アラートを受け取る</button>
                </div>
              </div>
            </div>
          </article>

          <article class="slide">
            <div class="phone">
              <div class="phone-shell">
                <div class="phone-top">
                  <span>9:41</span>
                  <span>5G</span>
                  <span>96%</span>
                </div>
                <div class="shot-content compare">
                  <span class="platform-label light">スクショC / 比較訴求</span>
                  <h3 class="shot-title dark">競合比較で一目瞭然<br>相場チェックは電話0本</h3>
                  <div class="badge-row">
                    <span class="badge dark">8,000社オークション</span>
                    <span class="badge dark">手数料0円</span>
                  </div>

                  <div class="compare-table">
                    <div class="compare-row header">
                      <span>サービス</span>
                      <span>連絡本数</span>
                      <span>DL意向</span>
                    </div>
                    <div class="compare-row ucarpac">
                      <strong>UcarPAC</strong>
                      <strong>0本</strong>
                      <span class="cvr-pill good">+4.6pt</span>
                    </div>
                    <div class="compare-row">
                      <span>MOTA</span>
                      <span>最大3本</span>
                      <span class="cvr-pill">+1.5pt</span>
                    </div>
                    <div class="compare-row">
                      <span>ズバット</span>
                      <span>最大10本</span>
                      <span class="cvr-pill">+0.8pt</span>
                    </div>
                  </div>

                  <div class="price-card">
                    <p class="car-name">補足: 売却相談フェーズでは連絡1社のみ</p>
                    <p class="car-sub">「まず相場を知りたい」ユーザー向けに初期接触を最小化</p>
                  </div>

                  <button class="shot-cta" type="button">比較して無料で始める</button>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="carousel-controls">
        <button class="arrow-btn" id="prevBtn" type="button" aria-label="前へ">‹</button>
        <div class="dots">
          <button class="dot active" data-index="0" aria-label="スクショA"></button>
          <button class="dot" data-index="1" aria-label="スクショB"></button>
          <button class="dot" data-index="2" aria-label="スクショC"></button>
        </div>
        <button class="arrow-btn" id="nextBtn" type="button" aria-label="次へ">›</button>
      </div>
    </section>

    <section class="impact-lab">
      <h4>CVRインパクト・シミュレーター</h4>
      <p class="desc">訴求要素をON/OFFして、ストアPV→DL率への影響を即時確認。</p>
      <div class="toggle-row">
        <button class="toggle active" type="button" data-key="ai">AI査定を全面訴求（スクショA）</button>
        <button class="toggle active" type="button" data-key="expense">出費管理 + 将来予測（スクショB）</button>
        <button class="toggle active" type="button" data-key="nocall">競合比較「電話0本」（スクショC）</button>
      </div>
      <div class="meter-track"><span class="meter-fill" id="meterFill"></span></div>
      <div class="meter-values">
        <strong id="predictedRate">17.3%</strong>
        <span class="goal" id="goalBadge">目標まで +7.7%pt</span>
      </div>
    </section>

    <p class="notes">
      ベースCVR: 17.3%。目標CVR: 25%。このプロトタイプはASO検証用の操作デモです。ボタン・スワイプ・ステップ進行で訴求順序の最適化を確認できます。
    </p>
  </main>

  <script>
    const questions = [
      {
        title: "Q1. 売却の検討タイミングは？",
        options: [
          { label: "今すぐ売りたい（価格重視）", point: 20 },
          { label: "3か月以内に検討中", point: 14 },
          { label: "半年以上先。まず相場だけ知りたい", point: 10 }
        ]
      },
      {
        title: "Q2. いちばん不安な点は？",
        options: [
          { label: "いまの相場が高いか分からない", point: 18, bias: "ai" },
          { label: "維持費が増えて家計を圧迫する", point: 16, bias: "expense" },
          { label: "営業連絡が多いのは避けたい", point: 20, bias: "nocall" }
        ]
      },
      {
        title: "Q3. ストアで最初に見たいのは？",
        options: [
          { label: "AI査定の即時価格", point: 22, recommend: 0 },
          { label: "出費管理と将来予測", point: 20, recommend: 1 },
          { label: "競合比較と電話0本訴求", point: 24, recommend: 2 }
        ]
      }
    ];

    const state = {
      step: 0,
      answers: [],
      slide: 0,
      startX: 0,
      toggles: { ai: true, expense: true, nocall: true }
    };

    const track = document.getElementById("track");
    const viewport = document.getElementById("viewport");
    const dots = Array.from(document.querySelectorAll(".dot"));
    const questBar = document.getElementById("questBar");
    const questionTitle = document.getElementById("questionTitle");
    const options = document.getElementById("options");
    const questResult = document.getElementById("questResult");
    const questPoint = document.getElementById("questPoint");
    const questCard = document.getElementById("questCard");
    const predictedRate = document.getElementById("predictedRate");
    const meterFill = document.getElementById("meterFill");
    const goalBadge = document.getElementById("goalBadge");

    function setSlide(index) {
      const total = 3;
      state.slide = (index + total) % total;
      track.style.transform = "translateX(-" + (state.slide * 100) + "%)";
      dots.forEach((dot, i) => dot.classList.toggle("active", i === state.slide));
    }

    function updateStepPills() {
      for (let i = 0; i < 3; i++) {
        const el = document.getElementById("stepPill" + i);
        el.classList.remove("current", "done");
        if (i < state.step) el.classList.add("done");
        if (i === state.step) el.classList.add("current");
      }
      if (state.step >= 3) {
        document.getElementById("stepPill2").classList.add("done");
      }
    }

    function renderQuestion() {
      if (state.step >= questions.length) {
        finishQuest();
        return;
      }
      const q = questions[state.step];
      questionTitle.textContent = q.title;
      options.innerHTML = "";
      q.options.forEach((opt) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "option-btn";
        btn.textContent = opt.label;
        btn.addEventListener("click", () => chooseOption(opt));
        options.appendChild(btn);
      });
      const progress = (state.step / questions.length) * 100;
      questBar.style.width = progress + "%";
      updateStepPills();
    }

    function chooseOption(opt) {
      state.answers[state.step] = opt;
      state.step += 1;
      const score = state.answers.reduce((sum, a) => sum + (a ? a.point : 0), 0);
      questPoint.textContent = score + "pt";
      renderQuestion();
    }

    function finishQuest() {
      questBar.style.width = "100%";
      updateStepPills();
      questCard.classList.add("completed");
      options.innerHTML = "";

      const final = state.answers[2];
      const second = state.answers[1];
      let recommend = 0;

      if (final && typeof final.recommend === "number") {
        recommend = final.recommend;
      } else if (second && second.bias === "expense") {
        recommend = 1;
      } else if (second && second.bias === "nocall") {
        recommend = 2;
      }

      setSlide(recommend);

      const labels = [
        "スクショA（AI査定訴求）",
        "スクショB（出費管理+将来予測）",
        "スクショC（電話0本の競合比較）"
      ];

      questResult.textContent = "診断完了: あなたの反応が高いのは " + labels[recommend] + "。この順序でストア掲載するとCVR改善余地が大きいです。";
    }

    function updateKpi() {
      const base = 17.3;
      const uplift = { ai: 3.4, expense: 2.8, nocall: 4.6 };
      let predicted = base;
      Object.keys(state.toggles).forEach((key) => {
        if (state.toggles[key]) predicted += uplift[key];
      });

      const rounded = predicted.toFixed(1);
      predictedRate.textContent = rounded + "%";
      meterFill.style.width = Math.min((predicted / 30) * 100, 100) + "%";

      if (predicted >= 25) {
        goalBadge.textContent = "KPI達成圏内";
        goalBadge.classList.add("on");
      } else {
        goalBadge.textContent = "目標まで +" + (25 - predicted).toFixed(1) + "%pt";
        goalBadge.classList.remove("on");
      }
    }

    document.getElementById("prevBtn").addEventListener("click", () => setSlide(state.slide - 1));
    document.getElementById("nextBtn").addEventListener("click", () => setSlide(state.slide + 1));

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = Number(dot.getAttribute("data-index"));
        setSlide(idx);
      });
    });

    viewport.addEventListener("touchstart", (e) => {
      state.startX = e.changedTouches[0].clientX;
    }, { passive: true });

    viewport.addEventListener("touchend", (e) => {
      const diff = e.changedTouches[0].clientX - state.startX;
      if (Math.abs(diff) > 36) {
        if (diff < 0) setSlide(state.slide + 1);
        if (diff > 0) setSlide(state.slide - 1);
      }
    }, { passive: true });

    document.querySelectorAll(".toggle").forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.getAttribute("data-key");
        state.toggles[key] = !state.toggles[key];
        btn.classList.toggle("active", state.toggles[key]);

        if (state.toggles[key]) {
          if (key === "ai") setSlide(0);
          if (key === "expense") setSlide(1);
          if (key === "nocall") setSlide(2);
        }

        updateKpi();
      });
    });

    setSlide(0);
    renderQuestion();
    updateKpi();
  </script>
</body>
</html>
