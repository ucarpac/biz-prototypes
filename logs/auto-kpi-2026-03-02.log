      left: 50%;
      transform: translateX(-50%);
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #1e1e1e;
      z-index: 2;
    }

    .phone-inner {
      border-radius: 22px;
      background: var(--gradient-warm);
      border: 1px solid #ffe1ec;
      padding: 24px 14px 14px;
      min-height: 610px;
      overflow: hidden;
      position: relative;
    }

    .platform {
      margin: 0 0 8px;
      font-size: 11px;
      font-weight: 700;
      color: #b15a7d;
      text-align: center;
    }

    .hero-copy {
      margin: 0;
      color: var(--dark-blue);
      font-size: 23px;
      line-height: 1.45;
      font-weight: 800;
      text-align: center;
      letter-spacing: 0.2px;
    }

    .hero-sub {
      margin: 8px 0 0;
      text-align: center;
      font-size: 13px;
      line-height: 1.5;
      color: #5f6486;
    }

    .chip-row {
      margin-top: 10px;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      justify-content: center;
    }

    .chip {
      font-size: 11px;
      font-weight: 700;
      padding: 6px 10px;
      border-radius: var(--radius-chip);
      border: 1px solid #ffd0e4;
      background: #fff;
      color: var(--dark-blue);
    }

    .chip.blue {
      border-color: #b7e8ff;
      background: #eff9ff;
      color: #0e5fa8;
    }

    .illustration {
      margin: 12px auto 0;
      width: 240px;
      height: 96px;
      position: relative;
    }

    .car-body {
      position: absolute;
      left: 12px;
      bottom: 18px;
      width: 182px;
      height: 42px;
      background: #ff8ebe;
      border-radius: 26px 28px 16px 16px;
      border: 2px solid #f84ca2;
    }

    .car-roof {
      position: absolute;
      left: 46px;
      bottom: 50px;
      width: 94px;
      height: 28px;
      background: #ffd2e6;
      border-radius: 18px 18px 8px 8px;
      border: 2px solid #f84ca2;
      border-bottom: none;
    }

    .wheel {
      position: absolute;
      bottom: 10px;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: #2f2f2f;
      border: 3px solid #fff;
    }

    .wheel.left {
      left: 32px;
    }

    .wheel.right {
      left: 138px;
    }

    .ai-cloud {
      position: absolute;
      right: 2px;
      top: 8px;
      width: 74px;
      height: 56px;
      border-radius: 36px;
      background: #fff;
      border: 2px dashed #7bd5ff;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1d7ec7;
      font-weight: 800;
      font-size: 16px;
      animation: float 3.3s ease-in-out infinite;
    }

    .price-card {
      margin-top: 12px;
      background: #fff;
      border: 1px solid #ffe0ec;
      border-radius: 14px;
      padding: 12px;
      box-shadow: 0 3px 10px var(--shadow);
    }

    .car-name {
      margin: 0;
      font-size: 14px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .car-info {
      margin: 2px 0 8px;
      font-size: 12px;
      color: #666;
    }

    .price-main {
      margin: 0;
      text-align: center;
      color: var(--pink);
      font-size: 36px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: 0.5px;
      font-family: "Righteous", var(--font-sans);
    }

    .price-main small {
      font-size: 18px;
      color: #d15c95;
      font-family: var(--font-sans);
      font-weight: 700;
    }

    .price-label {
      margin: 6px 0 0;
      text-align: center;
      font-size: 12px;
      color: #666b88;
    }

    .toggle-row {
      margin-top: 8px;
      display: flex;
      gap: 6px;
    }

    .toggle-btn {
      flex: 1;
      border: 1px solid #dfe5ff;
      background: #f9fbff;
      border-radius: 999px;
      padding: 8px 0;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      cursor: pointer;
      transition: all 140ms ease;
    }

    .toggle-btn.active {
      border-color: #6cd0ff;
      background: var(--gradient-primary);
      color: #073e72;
    }

    .cta {
      margin-top: 12px;
      width: 100%;
      min-height: 43px;
      border: none;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: #08345d;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 7px 14px rgba(32, 180, 255, 0.26);
      animation: pulse 2.4s ease infinite;
    }

    .mini-btn {
      margin-top: 8px;
      width: 100%;
      border: 1px dashed #ff9ec5;
      border-radius: 22px;
      background: #fff7fb;
      color: #a2406b;
      font-size: 12px;
      font-weight: 700;
      padding: 8px 10px;
      cursor: pointer;
    }

    .comfort {
      margin-top: 8px;
      background: #fff;
      border: 1px solid #ffe0ec;
      border-radius: 12px;
      font-size: 12px;
      color: #6a6683;
      padding: 10px;
      line-height: 1.6;
    }

    .comfort.hidden {
      display: none;
    }

    .expense-header {
      margin-top: 12px;
      background: #fff;
      border-radius: 14px;
      border: 1px solid #ffdceb;
      padding: 12px;
    }

    .expense-total {
      margin: 6px 0 2px;
      text-align: center;
      font-family: "Righteous", var(--font-sans);
      color: var(--dark-blue);
      font-size: 33px;
      line-height: 1;
      font-weight: 700;
    }

    .expense-total small {
      font-size: 16px;
      color: #567;
      font-family: var(--font-sans);
    }

    .month-select {
      display: flex;
      gap: 6px;
      margin-top: 8px;
    }

    .month-btn {
      flex: 1;
      border: 1px solid #d4dbf3;
      background: #fff;
      border-radius: 999px;
      padding: 7px 0;
      font-size: 11px;
      color: var(--dark-blue);
      font-weight: 700;
      cursor: pointer;
    }

    .month-btn.active {
      background: var(--dark-blue);
      border-color: var(--dark-blue);
      color: #fff;
    }

    .bar-grid {
      margin-top: 10px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .bar-item {
      text-align: center;
    }

    .bar-track {
      height: 82px;
      border-radius: 8px;
      background: #f5f7ff;
      border: 1px solid #e5ebff;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
    }

    .bar-fill {
      width: 100%;
      display: block;
      border-radius: 6px 6px 0 0;
      background: linear-gradient(180deg, #9be4ff, #40bfff);
      transition: height 260ms ease;
    }

    .bar-item strong {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      color: var(--dark-blue);
    }

    .bar-item p {
      margin: 2px 0 0;
      font-size: 10px;
      color: #667;
    }

    .forecast {
      margin-top: 10px;
      background: #fff;
      border: 1px solid #e2ecff;
      border-radius: 12px;
      padding: 10px;
    }

    .forecast svg {
      width: 100%;
      height: 95px;
      display: block;
    }

    #forecastLine {
      fill: none;
      stroke: #1d8fda;
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1.2s ease forwards;
    }

    #forecastText {
      margin: 6px 0 0;
      text-align: center;
      font-size: 12px;
      color: #445;
      font-weight: 700;
    }

    .compare-head {
      margin-top: 12px;
      background: #fff;
      border-radius: 14px;
      border: 1px solid #ffd7e8;
      padding: 12px;
      text-align: center;
    }

    .big-zero {
      margin: 6px 0 0;
      font-family: "Righteous", var(--font-sans);
      color: var(--pink);
      font-size: 44px;
      line-height: 1.2;
      letter-spacing: 0.5px;
    }

    .big-zero small {
      font-size: 14px;
      color: #9c5e7e;
      font-family: var(--font-sans);
      font-weight: 700;
      margin-left: 6px;
    }

    .mode-select {
      margin-top: 8px;
      display: flex;
      gap: 6px;
    }

    .mode-btn {
      flex: 1;
      border: 1px solid #d5dffb;
      border-radius: 999px;
      background: #fff;
      color: var(--dark-blue);
      padding: 8px 4px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .mode-btn.active {
      background: var(--gradient-pink);
      border-color: #f84ca2;
      color: #fff;
    }

    .compare-table {
      margin-top: 10px;
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      background: #fff;
      border: 1px solid #e8ecf7;
      border-radius: 12px;
      overflow: hidden;
      font-size: 11px;
    }

    .compare-table th,
    .compare-table td {
      padding: 8px 6px;
      text-align: center;
      border-bottom: 1px solid #eef2fb;
    }

    .compare-table th {
      font-size: 10px;
      color: #6f7692;
      background: #f8faff;
      font-weight: 700;
    }

    .compare-table tr:last-child td {
      border-bottom: none;
    }

    .compare-table td:first-child {
      text-align: left;
      font-weight: 700;
      color: #364173;
    }

    .u-row td {
      background: #fff7fc;
    }

    .trust-note {
      margin-top: 8px;
      padding: 10px;
      font-size: 12px;
      color: #5d5e77;
      background: #fff;
      border: 1px dashed #ffc3df;
      border-radius: 12px;
      line-height: 1.6;
    }

    .footer {
      margin-top: 14px;
      font-size: 11px;
      color: #666;
      text-align: center;
      line-height: 1.6;
    }

    @media (min-width: 768px) {
      .page {
        max-width: 980px;
        padding: 24px;
      }

      .tabs {
        max-width: 820px;
        margin-left: auto;
        margin-right: auto;
      }

      .shots-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
      }

      .shot {
        display: block !important;
        margin-top: 16px;
      }

      .tab-button {
        min-height: 46px;
      }
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.02);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-6px);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }
  </style>
</head>
<body>
  <div class="doodle one"></div>
  <div class="doodle two"></div>
  <div class="doodle three"></div>

  <div class="page">
    <header class="header">
      <span class="stamp">ASO検証 / 2026-03-02</span>
      <h1>ストアPV → DL率を17.3%から25%へ</h1>
      <p>不安を減らし、期待を育てるストアスクショA/B/Cを1画面で比較検証できるプロトタイプです。</p>
      <div class="kpi-box">
        <div class="kpi-row">
          <span class="left">現状DL率</span>
          <span class="right"><strong id="kpiCurrent">0.0%</strong> / 目標 25%</span>
        </div>
        <div class="kpi-track">
          <span id="kpiBar"></span>
        </div>
      </div>
    </header>

    <div class="tabs">
      <button class="tab-button active" data-tab="a">スクショA<br>iOS / AI査定</button>
      <button class="tab-button" data-tab="b">スクショB<br>Android / 出費管理</button>
      <button class="tab-button" data-tab="c">スクショC<br>競合比較 / 電話0本</button>
    </div>

    <main class="shots-grid">
      <section class="shot active" id="shot-a">
        <article class="phone ios">
          <div class="phone-inner">
            <p class="platform">ストアスクショA（iOS向け）</p>
            <h2 class="hero-copy">AIがあなたの愛車を<br>やさしく見守る</h2>
            <p class="hero-sub">今の相場も、これからの変化も。売り時の不安を数字で安心へ。</p>

            <div class="chip-row">
              <span class="chip">個人情報なしで開始</span>
              <span class="chip blue">最短45秒で概算</span>
            </div>

            <div class="illustration" aria-hidden="true">
              <div class="car-body"></div>
              <div class="car-roof"></div>
              <div class="wheel left"></div>
              <div class="wheel right"></div>
              <div class="ai-cloud">AI</div>
            </div>

            <div class="price-card">
              <p class="car-name">2020 トヨタ ハリアー Z</p>
              <p class="car-info">走行距離 36,200km / ブラック / 2WD</p>
              <p class="price-main"><span id="aPrice">248</span><small>万円</small></p>
              <p class="price-label" id="aPriceLabel">現在の予測相場</p>

              <div class="toggle-row">
                <button class="toggle-btn active" data-time="now">今</button>
                <button class="toggle-btn" data-time="m3">3か月後</button>
                <button class="toggle-btn" data-time="m6">6か月後</button>
              </div>
            </div>

            <button class="cta" type="button">今すぐ価格をチェック</button>
            <button class="mini-btn" id="comfortToggle" type="button">不安をやわらげる一言を見る</button>
            <div class="comfort hidden" id="comfortText">
              初回は相場を見るだけでもOK。営業電話なしで、あなたのペースで次の一歩を決められます。
            </div>
          </div>
        </article>
      </section>

      <section class="shot" id="shot-b">
        <article class="phone android">
          <div class="phone-inner">
            <p class="platform">ストアスクショB（Android向け）</p>
            <h2 class="hero-copy">出費も価値も、<br>ひと目でつながる</h2>
            <p class="hero-sub">維持費を記録しながら、将来の売却タイミングまで見える化。</p>

            <div class="chip-row">
              <span class="chip">家計にやさしい判断</span>
              <span class="chip blue">将来予測グラフつき</span>
            </div>

            <div class="expense-header">
              <p class="car-name">2019 ホンダ N-BOX G・L</p>
              <p class="expense-total"><span id="bTotal">3.8</span><small>万円 / 月</small></p>

              <div class="month-select">
                <button class="month-btn active" data-month="jan">1月</button>
                <button class="month-btn" data-month="feb">2月</button>
                <button class="month-btn" data-month="mar">3月</button>
              </div>

              <div class="bar-grid">
                <div class="bar-item">
                  <div class="bar-track"><span class="bar-fill" id="barFuel" style="height:72%"></span></div>
                  <strong id="fuelVal">1.4万</strong>
                  <p>ガソリン</p>
                </div>
                <div class="bar-item">
                  <div class="bar-track"><span class="bar-fill" id="barIns" style="height:58%"></span></div>
                  <strong id="insVal">1.1万</strong>
                  <p>保険</p>
                </div>
                <div class="bar-item">
                  <div class="bar-track"><span class="bar-fill" id="barPark" style="height:44%"></span></div>
                  <strong id="parkVal">0.8万</strong>
                  <p>駐車場</p>
                </div>
                <div class="bar-item">
                  <div class="bar-track"><span class="bar-fill" id="barMain" style="height:32%"></span></div>
                  <strong id="mainVal">0.5万</strong>
                  <p>整備</p>
                </div>
              </div>
            </div>

            <div class="forecast">
              <svg viewBox="0 0 260 95" preserveAspectRatio="none">
                <polyline id="forecastLine" points="8,84 52,76 96,69 140,58 184,43 252,26"></polyline>
              </svg>
              <p id="forecastText">6か月後の予測売却差益 +12万円</p>
            </div>

            <button class="cta" type="button">出費を記録して売り時を見る</button>
          </div>
        </article>
      </section>

      <section class="shot" id="shot-c">
        <article class="phone ios">
          <div class="phone-inner">
            <p class="platform">ストアスクショC（競合比較）</p>
            <h2 class="hero-copy">まずは相場確認、<br>電話0本でOK</h2>
            <p class="hero-sub">比較でわかる。気軽さと高額売却の両立がUcarPACの強みです。</p>

            <div class="compare-head">
              <p class="car-name" id="cHeadline">相場チェック時の電話対応</p>
              <p class="big-zero"><span id="cPhoneCount">0本</span><small id="cPhoneSub">営業電話なし</small></p>

              <div class="mode-select">
                <button class="mode-btn active" data-mode="check">相場チェック</button>
                <button class="mode-btn" data-mode="sell">売却申込</button>
              </div>
            </div>

            <table class="compare-table">
              <thead>
                <tr>
                  <th>サービス</th>
                  <th>電話本数</th>
                  <th>入札社数</th>
                  <th>将来予測</th>
                </tr>
              </thead>
              <tbody>
                <tr class="u-row">
                  <td>UcarPAC</td>
                  <td id="cellUcar">0本</td>
                  <td>8,000社</td>
                  <td>対応</td>
                </tr>
                <tr>
                  <td>MOTA</td>
                  <td id="cellMota">3社</td>
                  <td>上位入札</td>
                  <td>非対応</td>
                </tr>
                <tr>
                  <td>ズバット</td>
                  <td id="cellZubat">最大10社</td>
                  <td>比較型</td>
                  <td>非対応</td>
                </tr>
              </tbody>
            </table>

            <div class="trust-note" id="cNote">
              相場チェック段階では個人情報不要。売却を決めるまで、気軽に何度でも確認できます。
            </div>

            <div class="chip-row">
              <span class="chip">電話ストレスを軽減</span>
              <span class="chip blue">8,000社オークション</span>
            </div>

            <button class="cta" type="button">比較せずに、ここで完結</button>
          </div>
        </article>
      </section>
    </main>

    <footer class="footer">
      375pxモバイル基準 / Noto Sans JP / インライン完結プロトタイプ<br>
      A: AI査定、B: 出費管理+将来予測、C: 競合比較「電話0本」
    </footer>
  </div>

  <script>
    const tabButtons = document.querySelectorAll(".tab-button");
    const shots = document.querySelectorAll(".shot");
    const desktopQuery = window.matchMedia("(min-width: 768px)");

    function activateTab(tabId) {
      if (desktopQuery.matches) {
        return;
      }
      tabButtons.forEach((btn) => {
        btn.classList.toggle("active", btn.dataset.tab === tabId);
      });
      shots.forEach((shot) => {
        shot.classList.toggle("active", shot.id === "shot-" + tabId);
      });
    }

    tabButtons.forEach((btn) => {
      btn.addEventListener("click", () => activateTab(btn.dataset.tab));
    });

    function animateNumber(el, from, to, duration, digits, suffix) {
      const start = performance.now();
      function frame(now) {
        const p = Math.min((now - start) / duration, 1);
        const val = from + (to - from) * p;
        el.textContent = val.toFixed(digits) + (suffix || "");
        if (p < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    const kpiCurrent = document.getElementById("kpiCurrent");
    const kpiBar = document.getElementById("kpiBar");
    const currentRate = 17.3;
    const goalRate = 25;
    animateNumber(kpiCurrent, 0, currentRate, 900, 1, "%");
    setTimeout(() => {
      kpiBar.style.width = ((currentRate / goalRate) * 100).toFixed(1) + "%";
    }, 120);

    const aData = {
      now: { price: 248, label: "現在の予測相場" },
      m3: { price: 239, label: "3か月後の予測相場" },
      m6: { price: 228, label: "6か月後の予測相場" }
    };
    let currentAPrice = 248;
    const aPrice = document.getElementById("aPrice");
    const aLabel = document.getElementById("aPriceLabel");
    const aTimeBtns = document.querySelectorAll(".toggle-btn[data-time]");

    function animateInt(el, from, to, duration) {
      const start = performance.now();
      function frame(now) {
        const p = Math.min((now - start) / duration, 1);
        const val = Math.round(from + (to - from) * p);
        el.textContent = val.toLocaleString("ja-JP");
        if (p < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    aTimeBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.dataset.time;
        const next = aData[key];
        aTimeBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        animateInt(aPrice, currentAPrice, next.price, 380);
        currentAPrice = next.price;
        aLabel.textContent = next.label;
      });
    });

    const comfortToggle = document.getElementById("comfortToggle");
    const comfortText = document.getElementById("comfortText");
    comfortToggle.addEventListener("click", () => {
      comfortText.classList.toggle("hidden");
      comfortToggle.textContent = comfortText.classList.contains("hidden")
        ? "不安をやわらげる一言を見る"
        : "メッセージを閉じる";
    });

    const bData = {
      jan: {
        total: 3.8,
        fuel: 1.4,
        ins: 1.1,
        park: 0.8,
        main: 0.5,
