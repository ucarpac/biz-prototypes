    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      color: var(--text-black);
      font-family: var(--font-sans);
      background:
        radial-gradient(1200px 420px at 90% -20%, #ccefff 0%, rgba(204, 239, 255, 0) 70%),
        radial-gradient(1000px 320px at -10% 20%, #ffe1f0 0%, rgba(255, 225, 240, 0) 65%),
        var(--back-white);
      min-height: 100vh;
    }

    .shell {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 16px 14px 64px;
    }

    .card {
      background: var(--white);
