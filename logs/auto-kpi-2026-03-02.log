      background: var(--gradient-primary);
      box-shadow: 0 7px 16px rgba(29, 220, 255, 0.3);
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .cta:active {
      transform: translateY(1px) scale(0.99);
      box-shadow: 0 3px 8px rgba(29, 220, 255, 0.22);
    }

    .swipe-hint {
      text-align: center;
      margin: 10px 0 8px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      letter-spacing: 0.04em;
    }

    .nav {
      display: grid;
      grid-template-columns: 72px 1fr 72px;
      align-items: center;
      gap: 8px;
    }

    .nav-btn {
      height: 32px;
      border: 1px solid #cfddf2;
      border-radius: 16px;
      background: #ffffff;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
    }

    .dots {
      display: flex;
      justify-content: center;
      gap: 6px;
    }

    .dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: #c6d5ef;
      transition: transform 0.2s ease, background-color 0.2s ease;
    }

    .dot.active {
      background: var(--pink);
      transform: scale(1.25);
    }

    .flow-card {
      margin: 10px 12px;
      padding: 14px;
      border-radius: var(--radius-md);
      border: 1px solid #d8e4f6;
      background: #ffffff;
      box-shadow: 0 3px 12px var(--shadow);
    }

    .flow-title {
      margin: 0 0 8px;
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .flow-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .flow-progress {
      width: 100%;
      height: 8px;
      border-radius: 999px;
      background: #edf2fb;
      overflow: hidden;
      margin-bottom: 12px;
    }

    .flow-progress .bar {
      width: 0%;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-pink);
      transition: width 0.35s ease;
    }

    .question {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .chip-grid {
      display: grid;
      gap: 8px;
      margin-bottom: 8px;
    }

    .chip {
      min-height: 43px;
      border-radius: var(--radius-chip);
      border: 1px solid var(--ruled-line);
      background: #ffffff;
      color: var(--text-black);
      padding: 10px 14px;
      text-align: left;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
    }

    .chip:hover {
      border-color: #d8e4f8;
    }

    .chip.selected {
      background: var(--dark-blue);
      border-color: var(--dark-blue);
      color: #ffffff;
      transform: scale(1.01);
    }

    .result {
      border-radius: 12px;
      border: 1px solid #ffe0ef;
      background: #fff4fa;
      padding: 12px;
      color: #7b2f5e;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      margin: 8px 0 0;
      animation: pop 0.28s ease;
    }

    .hidden {
      display: none;
    }

    .ghost {
      margin-top: 10px;
      width: 100%;
      min-height: 40px;
      border-radius: var(--radius-button);
      border: 1px solid #d2deef;
      background: #ffffff;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
    }

    .action-panel {
      margin: 10px 12px 16px;
      padding: 12px;
      border-radius: var(--radius-md);
      border: 1px solid #d8e4f6;
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .sim-title {
      margin: 0 0 8px;
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .sim-output {
      margin-top: 10px;
      padding: 10px;
      border-radius: 10px;
      background: #f2f8ff;
      border: 1px solid #d8e8ff;
      font-size: 12px;
      line-height: 18px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .footer {
      padding: 0 16px 16px;
      text-align: center;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.95; }
      50% { transform: scale(1.04); opacity: 1; }
      100% { transform: scale(1); opacity: 0.95; }
    }

    @keyframes shimmer {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(220%); }
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pop {
      0% { opacity: 0; transform: scale(0.94); }
      100% { opacity: 1; transform: scale(1); }
    }

    @media (min-width: 768px) {
      body {
        padding: 28px;
      }
      .phone-shell {
        width: min(100%, 430px);
      }
      .slide {
        min-height: 430px;
      }
    }
  </style>
</head>
<body>
  <main class="phone-shell">
    <header class="header">
      <div class="title-row">
        <h1 class="title">UcarPAC ストア訴求プロトタイプ</h1>
        <span class="date-badge">検証日 2026-03-02</span>
      </div>
      <div class="kpi-strip">
        <div class="kpi-head">
          <strong>ストアPV→DL率</strong>
          <span id="kpiValue">17.3% → 25%</span>
        </div>
        <div class="kpi-meter">
          <div class="kpi-fill" id="kpiFill"></div>
        </div>
      </div>
    </header>

    <section class="carousel-wrap">
      <div class="carousel" id="carousel">
        <div class="track" id="track">
          <article class="slide">
            <div class="slide-top">
              <span class="platform ios">iOS向けスクショA</span>
              <span class="badge pulse">個人情報入力なし</span>
            </div>
            <h2>AIが愛車を10秒査定</h2>
            <p>トヨタ ハリアー Z 2021年式 / 31,500km の想定。価格レンジと売り時を一画面で訴求。</p>
            <div class="car-card">
              <div class="car-name">トヨタ ハリアー Z / パールホワイト</div>
              <div class="car-meta">査定ロジック更新: 2026-03-02 09:10 / 全国オークション実績反映</div>
              <div class="price-main">¥2,486,000</div>
              <div class="future-bars">
                <div class="future-row">
                  <span>現在相場</span>
                  <div class="bar-track"><div class="bar-fill" style="width: 87%;"></div></div>
                  <strong>248.6万円</strong>
                </div>
                <div class="future-row">
                  <span>3ヶ月後</span>
                  <div class="bar-track"><div class="bar-fill alt" style="width: 83%;"></div></div>
                  <strong>236.8万円</strong>
                </div>
                <div class="future-row">
                  <span>6ヶ月後</span>
                  <div class="bar-track"><div class="bar-fill alt" style="width: 78%;"></div></div>
                  <strong>224.1万円</strong>
                </div>
              </div>
            </div>
            <button class="cta" type="button">30秒でAI査定を開始</button>
          </article>

          <article class="slide">
            <div class="slide-top">
              <span class="platform android">Android向けスクショB</span>
              <span class="badge pulse">出費管理+将来予測</span>
            </div>
            <h2>維持費と売り時を同時に可視化</h2>
            <p>ホンダ フリード G 2018年式 / 62,200km。月次出費と価格予測をワンタップ比較。</p>
            <div class="expense-card">
              <div class="expense-grid">
                <div class="expense-item">
                  <div class="label">ガソリン代 (2月)</div>
                  <div class="value">¥13,840</div>
                </div>
                <div class="expense-item">
                  <div class="label">保険(月割)</div>
                  <div class="value">¥6,300</div>
                </div>
                <div class="expense-item">
                  <div class="label">整備・修理</div>
                  <div class="value">¥4,600</div>
                </div>
                <div class="expense-item">
                  <div class="label">駐車場</div>
                  <div class="value">¥11,000</div>
                </div>
              </div>
              <div class="car-meta">予測査定額推移 (万円): 3月→8月</div>
              <div class="mini-chart">
                <div style="height: 62%;" data-v="171"></div>
                <div style="height: 58%;" data-v="168"></div>
                <div style="height: 55%;" data-v="165"></div>
                <div style="height: 52%;" data-v="163"></div>
                <div style="height: 49%;" data-v="160"></div>
                <div style="height: 45%;" data-v="157"></div>
              </div>
            </div>
            <button class="cta" type="button">出費管理をはじめる</button>
          </article>

          <article class="slide">
            <div class="slide-top">
              <span class="platform all">スクショC 競合比較</span>
              <span class="badge pulse">電話0本で相場チェック</span>
            </div>
            <h2>比較してわかる負担の少なさ</h2>
            <p>相場確認フェーズでは電話0本。売却申込後も電話は1社のみで完結。</p>
            <div class="compare-card">
              <table class="compare-table">
                <thead>
                  <tr>
                    <th>サービス</th>
                    <th>相場確認時の電話</th>
                    <th>入札規模</th>
                    <th>手数料</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="highlight-row">
                    <td>UcarPAC</td>
                    <td>0本</td>
                    <td>8,000社</td>
                    <td>無料</td>
                  </tr>
                  <tr>
                    <td>MOTA</td>
                    <td>最大3社</td>
                    <td>数百社</td>
                    <td>無料</td>
                  </tr>
                  <tr>
                    <td>ズバット</td>
                    <td>最大10社</td>
                    <td>比較見積</td>
                    <td>無料</td>
                  </tr>
                </tbody>
              </table>
              <div class="phone-zero">「まずは価格だけ知りたい」なら、電話0本で開始</div>
            </div>
            <button class="cta" type="button">電話なしで相場をチェック</button>
          </article>
        </div>
      </div>

      <div class="swipe-hint">← スワイプして訴求案を切り替え →</div>

      <div class="nav">
        <button class="nav-btn" id="prevBtn" type="button">戻る</button>
        <div class="dots" id="dots"></div>
        <button class="nav-btn" id="nextBtn" type="button">次へ</button>
      </div>
    </section>

    <section class="flow-card">
      <h2 class="flow-title">売り時診断フロー</h2>
      <div class="flow-meta">
        <span id="stepLabel">STEP 1/3</span>
        <span id="xpLabel">XP 0</span>
      </div>
      <div class="flow-progress">
        <div class="bar" id="flowBar"></div>
      </div>
      <p class="question" id="question"></p>
      <div class="chip-grid" id="options"></div>
      <div class="result hidden" id="result"></div>
      <button class="ghost hidden" id="restartBtn" type="button">診断をやり直す</button>
    </section>

    <section class="action-panel">
      <h3 class="sim-title">CVRシミュレーション</h3>
      <button class="cta" id="simulateBtn" type="button">この構成でPV→DL率を試算</button>
      <div class="sim-output" id="simOutput">現在値: 17.3% / 目標: 25.0%</div>
    </section>

    <footer class="footer">
      スワイプ + 診断ステップ + マイクロアニメーションで、ストア詳細ページの体験価値を検証
    </footer>
  </main>

  <script>
    const track = document.getElementById("track");
    const dotsRoot = document.getElementById("dots");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const kpiFill = document.getElementById("kpiFill");
    const kpiValue = document.getElementById("kpiValue");

    const questionEl = document.getElementById("question");
    const optionsEl = document.getElementById("options");
    const stepLabel = document.getElementById("stepLabel");
    const xpLabel = document.getElementById("xpLabel");
    const flowBar = document.getElementById("flowBar");
    const resultEl = document.getElementById("result");
    const restartBtn = document.getElementById("restartBtn");
    const simulateBtn = document.getElementById("simulateBtn");
    const simOutput = document.getElementById("simOutput");

    const slides = 3;
    let currentSlide = 0;
    let startX = 0;

    const steps = [
      {
        q: "売却予定のタイミングは？",
        options: [
          { label: "3ヶ月以内に売る予定", point: 4 },
          { label: "半年〜1年で検討", point: 3 },
          { label: "まだ未定", point: 1 }
        ]
      },
      {
        q: "月間の走行距離は？",
        options: [
          { label: "1,000km以上", point: 3 },
          { label: "500〜1,000km", point: 2 },
          { label: "500km未満", point: 1 }
        ]
      },
      {
        q: "いちばん重視したいことは？",
        options: [
          { label: "できるだけ高く売る", point: 4 },
          { label: "電話対応の少なさ", point: 3 },
          { label: "今は維持費の管理", point: 2 }
        ]
      }
    ];

    const flowState = {
      step: 0,
      score: 0,
      xp: 0,
      picks: []
    };

    function createDots() {
      dotsRoot.innerHTML = "";
      for (let i = 0; i < slides; i += 1) {
        const dot = document.createElement("span");
        dot.className = "dot" + (i === 0 ? " active" : "");
        dotsRoot.appendChild(dot);
      }
    }

    function renderCarousel() {
      track.style.transform = `translateX(-${currentSlide * (100 / slides)}%)`;
      [...dotsRoot.children].forEach((dot, idx) => {
        dot.classList.toggle("active", idx === currentSlide);
      });
    }

    function nextSlide() {
      currentSlide = (currentSlide + 1) % slides;
      renderCarousel();
    }

    function prevSlide() {
      currentSlide = (currentSlide - 1 + slides) % slides;
      renderCarousel();
    }

    function renderFlow() {
      const total = steps.length;
      const done = flowState.step >= total;
      stepLabel.textContent = done ? "診断完了" : `STEP ${flowState.step + 1}/${total}`;
      xpLabel.textContent = `XP ${flowState.xp}`;
      flowBar.style.width = `${(Math.min(flowState.step, total) / total) * 100}%`;

      if (done) {
        questionEl.textContent = "あなた向けの訴求セットが確定しました。";
        optionsEl.innerHTML = "";
        resultEl.classList.remove("hidden");
        restartBtn.classList.remove("hidden");

        let recommend = "スクショB（出費管理）";
        if (flowState.score >= 10) recommend = "スクショA + スクショC";
        if (flowState.score >= 7 && flowState.score < 10) recommend = "スクショA + スクショB";

        resultEl.innerHTML =
          `推奨訴求: ${recommend}<br>` +
          `診断スコア: ${flowState.score} / 11<br>` +
          `提案: AI査定の価格根拠と「電話0本」導線を上部に固定し、CVR上振れを狙う。`;
        return;
      }

      resultEl.classList.add("hidden");
      restartBtn.classList.add("hidden");
      questionEl.textContent = steps[flowState.step].q;
      optionsEl.innerHTML = "";

      steps[flowState.step].options.forEach((opt) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "chip";
        btn.textContent = opt.label;
        btn.addEventListener("click", () => {
          btn.classList.add("selected");
          flowState.picks.push(opt.label);
          flowState.score += opt.point;
          flowState.xp += 40 + opt.point * 10;
          setTimeout(() => {
            flowState.step += 1;
            renderFlow();
          }, 160);
        });
        optionsEl.appendChild(btn);
      });
    }

    function simulateCVR() {
      const base = 17.3;
      const slideBoosts = [3.5, 2.9, 4.2];
      const slideBoost = slideBoosts[currentSlide];
      const flowBoost = flowState.step >= steps.length ? Math.min(2.3, flowState.score * 0.22) : 0.8;
      const estimate = Math.min(25.0, base + slideBoost + flowBoost);

      const percentTowardGoal = Math.min(100, (estimate / 25.0) * 100);
      kpiFill.style.width = `${percentTowardGoal}%`;
      kpiValue.textContent = `${base.toFixed(1)}% → ${estimate.toFixed(1)}%`;

      simOutput.textContent =
        `選択中: スクショ${String.fromCharCode(65 + currentSlide)} / ` +
        `診断スコア: ${flowState.score} / ` +
        `試算CVR: ${estimate.toFixed(1)}%`;
    }

    prevBtn.addEventListener("click", prevSlide);
    nextBtn.addEventListener("click", nextSlide);
    simulateBtn.addEventListener("click", simulateCVR);

    restartBtn.addEventListener("click", () => {
      flowState.step = 0;
      flowState.score = 0;
      flowState.xp = 0;
      flowState.picks = [];
      renderFlow();
    });

    track.addEventListener("touchstart", (e) => {
      startX = e.touches[0].clientX;
    });

    track.addEventListener("touchend", (e) => {
      const endX = e.changedTouches[0].clientX;
      const diff = endX - startX;
      if (Math.abs(diff) < 40) return;
      if (diff < 0) nextSlide();
      if (diff > 0) prevSlide();
    });

    createDots();
    renderCarousel();
    renderFlow();
  </script>
</body>
</html>
