      font-weight: 700;
    }

    .meter-value {
      margin: 0;
      color: var(--dark-blue);
      font-weight: 800;
      font-size: 13px;
      line-height: 1.5;
    }

    .track {
      height: 10px;
      width: 100%;
      border-radius: 999px;
      background: #eef4f8;
      overflow: hidden;
    }

    .fill {
      display: block;
      height: 100%;
      width: 0;
      border-radius: inherit;
      transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .fill.current {
      background: linear-gradient(90deg, #9fcbff, #6ea8ff);
    }

    .fill.expected {
      background: var(--gradient-primary);
    }

    .status-row {
      margin-top: 10px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
    }

    .status {
      font-size: 12px;
      line-height: 1.5;
      color: var(--dark-blue);
      background: #ecf6ff;
      border: 1px solid #cfe7ff;
      padding: 6px 10px;
      border-radius: 999px;
      font-weight: 700;
    }

    .status.ok {
      color: #006247;
      border-color: #bde8d8;
      background: #edfcf5;
    }

    .btn-reset {
      border: 1px solid #d2dced;
