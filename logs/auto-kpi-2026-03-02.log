      transition: transform 0.15s ease;
    }

    .btn-reset:active {
      transform: scale(0.98);
    }

    .tab-card {
      margin-top: 14px;
      padding: 12px;
    }

    .tabs {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .tab {
      width: 100%;
      min-height: 44px;
