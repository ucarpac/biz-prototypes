      height: 8px;
      border-radius: 50%;
      border: 0;
      background: #c4d2f3;
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .dot.active {
      background: var(--dark-blue);
      transform: scale(1.3);
    }

    .impact-lab {
      position: relative;
      z-index: 2;
      border-radius: var(--radius-md);
      background: #fff;
      border: 1px solid #e6eefb;
      padding: var(--space-4);
    }

    .impact-lab h4 {
      margin: 0 0 6px;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
    }

    .impact-lab .desc {
      margin: 0 0 var(--space-3);
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .toggle-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-2);
      margin-bottom: var(--space-4);
    }

    .toggle {
      width: 100%;
      border: 1px solid #cedcf9;
      border-radius: var(--radius-chip);
      background: #fff;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19px;
      font-weight: 700;
      padding: 10px 12px;
      text-align: left;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .toggle.active {
      color: #fff;
      border-color: var(--dark-blue);
      background: linear-gradient(90deg, #091355, #1d2e93);
      box-shadow: 0 8px 15px rgba(9, 19, 85, 0.25);
    }

    .meter-track {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #e2ebfb;
      overflow: hidden;
    }

    .meter-fill {
      display: block;
      width: 0%;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #f84ca2, #1ddcff);
      transition: width 0.35s ease;
    }

    .meter-values {
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-2);
    }

    .meter-values strong {
      font-family: var(--font-number);
      font-size: 32px;
      line-height: 48px;
      color: var(--dark-blue);
      letter-spacing: 0.01em;
    }

    .goal {
      font-size: 11px;
      line-height: 17px;
      font-weight: 700;
      color: #7b8cb9;
      padding: 5px 8px;
      border-radius: var(--radius-chip);
      border: 1px solid #d5e1fc;
      background: #f7faff;
    }

    .goal.on {
      color: #fff;
      background: linear-gradient(90deg, #f84ca2, #ff7ebd);
      border-color: transparent;
      animation: pulse 1.5s ease infinite;
    }

    .notes {
      margin-top: var(--space-4);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      position: relative;
      z-index: 2;
    }

    @keyframes shimmer {
      0% { left: -48%; }
      100% { left: 120%; }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-2px); }
    }

    @keyframes rise {
      from { transform: scaleY(0.2); transform-origin: bottom; opacity: 0.4; }
      to { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
    }

    @keyframes fill {
      from { width: 0; }
    }

    @media (min-width: 760px) {
      body {
        padding: 30px;
      }

      .prototype {
        width: min(100%, 840px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
      }

      .hero,
      .quest,
      .notes {
        grid-column: 1 / 2;
      }

      .carousel-panel,
      .impact-lab {
        grid-column: 2 / 3;
      }

      .carousel-panel {
        margin-top: 0;
      }
    }
  </style>
</head>
<body>
  <main class="prototype">
    <header class="hero">
      <h1>ストアPV→DL率を17.3%から25%へ</h1>
      <p class="meta">検証日: 2026-03-02 / ASO日次差分モード / 3スクショの訴求強度を対話的に検証</p>
      <div class="score-chip">CVR Quest Score <strong id="questPoint">0pt</strong></div>
    </header>

    <section class="quest" id="questCard">
      <div class="quest-progress"><span id="questBar"></span></div>
      <ol class="quest-steps">
        <li id="stepPill0" class="current">STEP 1</li>
