    </section>
  </main>

  <script>
    (function () {
      const baseline = 17.3;
      const target = 25.0;

      const scenarios = {
        a: { label: "スクショA", uplift: 4.2, hypothesis: "仮説A: 「AI査定 + 6ヶ月予測」を1画面目で見せることで、価値理解を高速化しDL率を押し上げる。" },
        b: { label: "スクショB", uplift: 2.8, hypothesis: "仮説B: 「出費管理 + 将来予測」を示すことで、非売却層にも利用理由が生まれDL率を改善する。" },
        c: { label: "スクショC", uplift: 5.1, hypothesis: "仮説C: 「電話0本」比較で不安を除去し、検討離脱を抑えてDL率を改善する。" }
      };

      const applied = new Set();

      const expectedValue = document.getElementById("expectedValue");
      const gapValue = document.getElementById("gapValue");
      const currentFill = document.getElementById("currentFill");
      const expectedFill = document.getElementById("expectedFill");
      const currentRatioLabel = document.getElementById("currentRatioLabel");
      const expectedRatioLabel = document.getElementById("expectedRatioLabel");
      const statusBadge = document.getElementById("statusBadge");
      const activeScenarios = document.getElementById("activeScenarios");
      const latestLog = document.getElementById("latestLog");
      const hypothesisText = document.getElementById("hypothesisText");
      const historyLine = document.getElementById("historyLine");
      const historyDot = document.getElementById("historyDot");

      const tabs = Array.from(document.querySelectorAll(".tab"));
      const panels = Array.from(document.querySelectorAll(".panel"));

      const applyButtons = Array.from(document.querySelectorAll("[data-apply]"));
      const resetBtn = document.getElementById("resetBtn");

      const rangeButtons = Array.from(document.querySelectorAll("[data-range]"));
      const aForecastLine = document.getElementById("aForecastLine");
      const aWindowLabel = document.getElementById("aWindowLabel");
      const aPredictionText = document.getElementById("aPredictionText");

      const costButtons = Array.from(document.querySelectorAll("[data-cost-cat]"));
      const expenseRows = Array.from(document.querySelectorAll("[data-row-cat]"));
      const expenseFills = Array.from(document.querySelectorAll("[data-fill-cat]"));
      const bSelectedCost = document.getElementById("bSelectedCost");
      const bFutureImpact = document.getElementById("bFutureImpact");
      const bHintText = document.getElementById("bHintText");

      const includeFixed = document.getElementById("includeFixed");
      const globalFixedRow = document.getElementById("globalFixedRow");
      const callBars = Array.from(document.querySelectorAll("[data-call-width]"));

      const forecastSeries = {
        3: {
          values: [184.2, 185.3, 186.1, 188.4],
          targetLabel: "3ヶ月後",
          diff: "+46,000円"
        },
        6: {
          values: [184.2, 183.8, 182.4, 181.5, 183.2, 186.8, 190.1],
          targetLabel: "6ヶ月後",
          diff: "+59,000円"
        }
      };

      const expenseData = {
        fuel: { label: "ガソリン", annual: 148800, impact: 17800, hint: "ガソリン最適化で年間 +17,800円の可処分価値改善余地。", share: 38 },
        insurance: { label: "保険", annual: 92000, impact: 13600, hint: "保険見直しで年間 +13,600円の固定費圧縮余地。", share: 24 },
        inspection: { label: "車検積立", annual: 86000, impact: 9800, hint: "車検積立の平準化で年間 +9,800円の負担軽減余地。", share: 22 },
        maintenance: { label: "修理・整備", annual: 64000, impact: 5700, hint: "定期整備の先回り管理で年間 +5,700円の節約余地。", share: 16 }
      };

      function formatPct(value) {
        return value.toFixed(1) + "%";
      }

      function formatPt(value) {
        return value.toFixed(1) + "pt";
      }

      function formatYen(value) {
        return value.toLocaleString("ja-JP") + "円";
      }

      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }

      function updateHistory(expected) {
        const values = [16.4, 16.9, 17.1, 17.3, expected];
        const min = 15.8;
        const max = 25.0;
        const x0 = 20;
        const xStep = 73;
        const yBottom = 126;
        const yRange = 96;

        const points = values
          .map(function (v, i) {
            const x = x0 + i * xStep;
            const y = yBottom - ((v - min) / (max - min)) * yRange;
            return x + "," + y;
          })
          .join(" ");

        historyLine.setAttribute("points", points);

        const lastX = x0 + (values.length - 1) * xStep;
        const lastY = yBottom - ((values[values.length - 1] - min) / (max - min)) * yRange;
        historyDot.setAttribute("cx", String(lastX));
        historyDot.setAttribute("cy", String(lastY));
      }

      function updateMeters() {
        let uplift = 0;
        applied.forEach(function (key) {
          uplift += scenarios[key].uplift;
        });

        const expected = clamp(baseline + uplift, 0, 35);
        const currentRatio = (baseline / target) * 100;
        const expectedRatio = (expected / target) * 100;
        const gap = Math.max(target - expected, 0);

        expectedValue.textContent = formatPct(expected);
        gapValue.textContent = formatPt(Math.max(target - expected, 0));
        currentRatioLabel.textContent = formatPct(currentRatio);
        expectedRatioLabel.textContent = formatPct(expectedRatio);

        currentFill.style.width = clamp(currentRatio, 0, 100).toFixed(1) + "%";
        expectedFill.style.width = clamp(expectedRatio, 0, 100).toFixed(1) + "%";

        if (gap <= 0) {
          statusBadge.textContent = "目標達成見込み（+0.0pt）";
          statusBadge.classList.add("ok");
        } else {
          statusBadge.textContent = "目標まで +" + formatPt(gap);
          statusBadge.classList.remove("ok");
        }

        if (applied.size === 0) {
          activeScenarios.textContent = "適用中: なし";
          latestLog.textContent = "2026-03-02: スクショA/B/C試算未適用（17.3%）";
        } else {
          const labels = Array.from(applied).map(function (key) {
            return scenarios[key].label;
          });
          activeScenarios.textContent = "適用中: " + labels.join(" + ");
          latestLog.textContent = "2026-03-02: " + labels.join(" + ") + " を反映（試算 " + formatPct(expected) + "）";
        }

        updateHistory(expected);
      }

      function switchTab(key) {
        tabs.forEach(function (tab) {
          const on = tab.dataset.tab === key;
          tab.classList.toggle("is-active", on);
          tab.setAttribute("aria-selected", on ? "true" : "false");
        });

        panels.forEach(function (panel) {
          panel.hidden = panel.dataset.panel !== key;
        });

        hypothesisText.textContent = scenarios[key].hypothesis;
      }

      function setForecast(windowMonth) {
        const data = forecastSeries[windowMonth];
        const series = data.values;
        const min = Math.min.apply(null, series) - 1;
        const max = Math.max.apply(null, series) + 1;
        const width = 264;
        const height = 90;
        const x0 = 28;
        const y0 = 136;

        const points = series
          .map(function (value, index) {
            const x = x0 + (width / (series.length - 1)) * index;
            const y = y0 - ((value - min) / (max - min)) * height;
            return x + "," + y;
          })
          .join(" ");

        aForecastLine.setAttribute("points", points);

        const first = series[0] * 10000;
        const last = series[series.length - 1] * 10000;
        aWindowLabel.textContent = data.targetLabel;
        aPredictionText.textContent = data.targetLabel + "予測: " + formatYen(last) + "（" + data.diff + "）";

        rangeButtons.forEach(function (btn) {
          btn.classList.toggle("is-on", Number(btn.dataset.range) === windowMonth);
        });
      }

      function setCostCategory(key) {
        const d = expenseData[key];
        bSelectedCost.textContent = formatYen(d.annual);
        bFutureImpact.textContent = "+" + formatYen(d.impact);
        bHintText.textContent = d.hint;

        costButtons.forEach(function (btn) {
          btn.classList.toggle("is-on", btn.dataset.costCat === key);
        });

        expenseRows.forEach(function (row) {
          row.classList.toggle("is-on", row.dataset.rowCat === key);
        });
      }

      function initBars() {
        expenseFills.forEach(function (fill) {
          const key = fill.dataset.fillCat;
          fill.style.width = expenseData[key].share + "%";
        });

        callBars.forEach(function (bar) {
          const width = Number(bar.dataset.callWidth);
          bar.style.width = width + "%";
        });
      }

      tabs.forEach(function (tab) {
        tab.addEventListener("click", function () {
          switchTab(tab.dataset.tab);
        });
      });

      applyButtons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          const key = btn.dataset.apply;
          if (applied.has(key)) {
            applied.delete(key);
          } else {
            applied.add(key);
          }

          applyButtons.forEach(function (b) {
            const on = applied.has(b.dataset.apply);
            b.classList.toggle("is-on", on);
            b.textContent = on ? scenarios[b.dataset.apply].label + " 適用中" : b.dataset.apply.toUpperCase() + "案を試算に反映";
          });

          updateMeters();
        });
      });

      resetBtn.addEventListener("click", function () {
        applied.clear();
        applyButtons.forEach(function (btn) {
          btn.classList.remove("is-on");
          btn.textContent = btn.dataset.apply.toUpperCase() + "案を試算に反映";
        });
        updateMeters();
      });

      rangeButtons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          const month = Number(btn.dataset.range);
          setForecast(month);
        });
      });

      costButtons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          setCostCategory(btn.dataset.costCat);
        });
      });

      includeFixed.addEventListener("change", function () {
        globalFixedRow.hidden = !includeFixed.checked;
      });

      function reveal() {
        const nodes = Array.from(document.querySelectorAll(".reveal"));
        nodes.forEach(function (node, index) {
          setTimeout(function () {
            node.classList.add("show");
          }, 70 * index);
        });
      }

      reveal();
      initBars();
      switchTab("a");
      setForecast(6);
      setCostCategory("fuel");
      updateMeters();
    })();
  </script>
</body>
