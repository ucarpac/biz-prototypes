  <script>
    const tabButtons = document.querySelectorAll(".tab-btn");
    const shots = document.querySelectorAll(".shot");

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const target = button.dataset.target;
        tabButtons.forEach((b) => b.classList.toggle("active", b === button));
        shots.forEach((shot) => shot.classList.toggle("active", shot.id === target));
      });
    });

    const formatYen = (value) => `${Math.round(value).toLocaleString("ja-JP")}円`;
    const aiBase = 2184000;
    const aiPriceEl = document.getElementById("aiPrice");
    const future1El = document.getElementById("future1");
    const future3El = document.getElementById("future3");
    const future6El = document.getElementById("future6");
    const priceHintEl = document.getElementById("priceHint");
    const recalcBtn = document.getElementById("recalcBtn");

    recalcBtn.addEventListener("click", () => {
      const diff = Math.round((Math.random() * 90000) - 45000);
      const current = aiBase + diff;
      aiPriceEl.textContent = formatYen(current);
      future1El.textContent = formatYen(current - 24000);
      future3El.textContent = formatYen(current - 74000);
      future6El.textContent = formatYen(current - 144000);
      priceHintEl.textContent = diff >= 0 ? `先週比 +${diff.toLocaleString("ja-JP")}円` : `先週比 ${diff.toLocaleString("ja-JP")}円`;
      aiPriceEl.classList.remove("up", "down");
      void aiPriceEl.offsetWidth;
      aiPriceEl.classList.add(diff >= 0 ? "up" : "down");
    });

    const expenseData = {
      month: {
        fuel: 12000,
        insurance: 7200,
        maintenance: 8800,
        parking: 6600,
        total: 34600,
        caption: "前月比 -2,100円 / 節約できています"
      },
      year: {
        fuel: 148000,
        insurance: 86400,
        maintenance: 109000,
        parking: 79200,
        total: 422600,
        caption: "前年より -18,400円 / 家計への負担を圧縮"
      }
    };

    const modeButtons = document.querySelectorAll(".mode-btn");
    const bars = document.querySelectorAll(".bar");
    const totalValueEl = document.getElementById("totalValue");
    const totalCaptionEl = document.getElementById("totalCaption");

    const renderExpense = (mode) => {
      const data = expenseData[mode];
      const values = [data.fuel, data.insurance, data.maintenance, data.parking];
      const max = Math.max(...values);

      bars.forEach((bar) => {
        const key = bar.dataset.cat;
        const value = data[key];
        const height = Math.max(30, Math.round((value / max) * 120));
        bar.style.height = `${height}px`;
        bar.querySelector("span").textContent = mode === "month"
          ? `${(value / 1000).toFixed(1)}k`
          : `${(value / 10000).toFixed(1)}万`;
      });

      totalValueEl.textContent = formatYen(data.total);
      totalCaptionEl.textContent = data.caption;
    };

    modeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.dataset.mode;
        modeButtons.forEach((b) => b.classList.toggle("active", b === button));
        renderExpense(mode);
      });
    });

    renderExpense("month");

    const compareModes = {
      check: {
        title: "相場チェック時の電話本数",
        num: 0,
        sub: "個人情報なしで使えるから、営業電話の心配なし。",
        point: "個人情報なしでAI査定"
      },
      sell: {
        title: "売却相談時の電話本数",
        num: 1,
        sub: "売却手続き時も連絡先は1社だけ。やり取りがシンプル。",
        point: "連絡先は1社のみ"
      }
    };

    const compareButtons = document.querySelectorAll(".compare-mode-btn");
    const promiseTitleEl = document.getElementById("promiseTitle");
    const promiseNumEl = document.getElementById("promiseNum");
    const promiseSubEl = document.getElementById("promiseSub");
    const ucarpacCallEl = document.getElementById("ucarpacCall");
    const ucarpacPointEl = document.getElementById("ucarpacPoint");

    const renderCompare = (mode) => {
      const model = compareModes[mode];
      promiseTitleEl.textContent = model.title;
      promiseNumEl.textContent = model.num;
      promiseSubEl.textContent = model.sub;
      ucarpacCallEl.textContent = `${model.num}本`;
      ucarpacCallEl.className = model.num === 0 ? "zero" : "";
      ucarpacPointEl.textContent = model.point;
    };

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => {
        compareButtons.forEach((b) => b.classList.toggle("active", b === button));
        renderCompare(button.dataset.compare);
      });
    });

    renderCompare("check");

    const compareRows = document.querySelectorAll(".compare-row[data-name]");
    compareRows.forEach((row) => {
      row.addEventListener("click", () => {
        compareRows.forEach((r) => r.classList.remove("highlight"));
        row.classList.add("highlight");
      });
    });
  </script>
</body>
</html>
