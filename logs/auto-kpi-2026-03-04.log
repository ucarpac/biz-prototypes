      border-radius: 20px;
      background: #10152f;
      z-index: 3;
    }

    .slides {
      display: flex;
      width: 300%;
      height: 100%;
      transition: transform 450ms cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
    }

    .slide {
      width: 100%;
      flex-shrink: 0;
      padding: 42px 14px 18px;
      overflow-y: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .slide::-webkit-scrollbar {
      display: none;
    }

    .slide-a {
      background: linear-gradient(180deg, #f5fdff 0%, #fdfcff 52%, #f9f0ff 100%);
    }

    .slide-b {
      background: linear-gradient(180deg, #f8f9ff 0%, #f1f7ff 58%, #f7fdff 100%);
    }

    .slide-c {
      background: linear-gradient(180deg, #fff9fc 0%, #f8fbff 68%, #eff4ff 100%);
    }

    .platform-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .badge {
      font-size: 11px;
      font-weight: 700;
      border-radius: 999px;
      padding: 5px 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      letter-spacing: 0.02em;
    }

    .badge.ios {
      color: var(--dark-blue);
      background: #d9f5ff;
    }

    .badge.android {
      color: var(--dark-blue);
      background: #ddf8e8;
    }

    .badge.compare {
      color: #fff;
      background: var(--gradient-auction);
    }

    .badge.pink {
      color: #fff;
      background: var(--gradient-pink);
    }

    .slide h2 {
      margin: 0;
      font-size: 22px;
      line-height: 33px;
      color: var(--dark-blue);
      letter-spacing: 0.01em;
    }

    .slide .lead {
      margin: 8px 0 12px;
      font-size: 13px;
      line-height: 20px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .card {
      border-radius: var(--radius-card);
      background: #fff;
      box-shadow: 0 0 0 1px #d6e8f8, 0 6px 14px var(--shadow);
      padding: 12px;
      margin-bottom: 12px;
    }

    .price-card {
      position: relative;
      overflow: hidden;
      background: linear-gradient(120deg, #ffffff, #f2fbff);
    }

    .price-card::before {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      background: rgba(31, 219, 255, 0.22);
      border-radius: 50%;
      right: -35px;
      top: -45px;
    }

    .price-label {
      margin: 0;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .price-number {
      margin: 4px 0;
      font-size: 32px;
      line-height: 48px;
      color: var(--dark-blue);
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    .trend {
      margin: 0;
      font-size: 13px;
      line-height: 20px;
      font-weight: 700;
      color: #0b8d4e;
    }

    .steps {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 12px;
    }

    .step {
      border-radius: 10px;
      border: 1px solid #d6e2ed;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      text-align: center;
      padding: 8px 6px;
      background: #fff;
      transition: all 240ms ease;
    }

    .step.active {
      background: var(--dark-blue);
      color: #fff;
      border-color: var(--dark-blue);
      transform: translateY(-1px);
      box-shadow: 0 4px 10px rgba(28, 38, 99, 0.25);
    }

    .mission-title {
      margin: 0 0 10px;
      font-size: 13px;
      line-height: 20px;
      color: var(--text-black);
      font-weight: 700;
    }

    .chip-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 10px;
    }

    .chip {
      min-height: 40px;
      border-radius: var(--radius-chip);
      border: 1px solid var(--ruled-line);
      background: #fff;
      color: var(--text-black);
      font-weight: 700;
      font-size: 12px;
      line-height: 18px;
      padding: 0 14px;
      transition: all 220ms ease;
    }

    .chip.selected {
      background: var(--dark-blue);
      color: #fff;
      border-color: var(--dark-blue);
      transform: scale(1.02);
    }

    .meter-row {
      display: grid;
      grid-template-columns: 52px 1fr 40px;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
    }

    .meter-row span,
    .meter-row strong {
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      color: var(--text-black);
    }

    .meter {
      height: 10px;
      background: #e2ebf5;
      border-radius: 99px;
      overflow: hidden;
      position: relative;
    }

    .meter > span {
      display: block;
      height: 100%;
      width: 72%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 280ms ease;
    }

    .btn {
      appearance: none;
      border: none;
      cursor: pointer;
      width: 100%;
      min-height: 43px;
      border-radius: var(--radius-button);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      letter-spacing: 0.01em;
      transition: transform 140ms ease, filter 180ms ease;
    }

    .btn:active {
      transform: scale(0.985);
    }

    .btn.primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .btn.pink {
      background: var(--gradient-pink);
      color: #fff;
    }

    .btn.white {
      background: #fff;
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.2);
    }

    .expense-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 6px;
    }

    .expense-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #fff;
      border: 1px solid #e8eef5;
      border-radius: 10px;
      padding: 8px 10px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      color: var(--text-black);
    }

    .expense-item strong {
      color: var(--dark-blue);
      font-size: 13px;
    }

    .forecast-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
    }

    .tab {
      flex: 1;
      min-height: 38px;
      border: 1px solid #deebf8;
      border-radius: 999px;
      background: #fff;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      transition: all 220ms ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: #fff;
      border-color: var(--dark-blue);
      box-shadow: 0 4px 10px rgba(28, 38, 99, 0.25);
    }

    .forecast-graph {
      height: 110px;
      display: flex;
      align-items: flex-end;
      gap: 6px;
      margin-bottom: 10px;
      padding: 0 2px;
    }

    .bar {
      flex: 1;
      border-radius: 8px 8px 4px 4px;
      background: linear-gradient(180deg, #9cecff 0%, #4db4ff 100%);
      height: 30%;
      transition: height 360ms cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
    }

    .bar::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      height: 35%;
      border-radius: inherit;
      background: rgba(255, 255, 255, 0.28);
    }

    .forecast-result {
      margin: 0;
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .hint {
      margin-top: 4px;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .gauge-row {
      margin-top: 10px;
      display: grid;
      gap: 6px;
    }

    .gauge-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .gauge-track {
      height: 12px;
      border-radius: 99px;
      background: #e4eaf3;
      overflow: hidden;
      position: relative;
    }

    .gauge-fill {
      height: 100%;
      width: 34%;
      border-radius: inherit;
      background: var(--gradient-pink);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 8px;
      transition: width 280ms ease;
    }

    .mode-toggle {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 10px;
    }

    .mode-btn {
      min-height: 40px;
      border-radius: 999px;
      border: 1px solid #dfe9f6;
      background: #fff;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      transition: all 220ms ease;
    }

    .mode-btn.active {
      background: var(--pink);
      color: #fff;
      border-color: var(--pink);
      box-shadow: 0 4px 10px rgba(248, 76, 162, 0.27);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 88px 1fr 40px;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .compare-name {
      font-size: 12px;
      color: var(--text-black);
      font-weight: 700;
    }

    .compare-track {
      height: 12px;
      border-radius: 99px;
      background: #e5edf5;
      overflow: hidden;
      position: relative;
    }

    .compare-fill {
      height: 100%;
      width: 4%;
      min-width: 4px;
      border-radius: inherit;
      background: linear-gradient(90deg, #ffd2e8, #f84ca2);
      transition: width 350ms ease;
    }

    .compare-row.ucarpac .compare-fill {
      background: var(--gradient-primary);
    }

    .compare-count {
      font-size: 12px;
      color: var(--dark-blue);
      font-weight: 700;
      text-align: right;
    }

    .pill-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin: 12px 0;
    }

    .pill {
      min-height: 48px;
      border-radius: 12px;
      background: #fff;
      border: 1px solid #e3ecf8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      line-height: 18px;
      text-align: center;
      padding: 6px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .claim {
      margin: 0 0 12px;
      padding: 10px 12px;
      border-radius: 12px;
      background: #fff;
      border-left: 4px solid var(--pink);
      font-size: 13px;
      line-height: 20px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .slider-nav {
      margin-top: 10px;
      display: grid;
      grid-template-columns: 44px 1fr 44px;
      align-items: center;
      gap: 8px;
    }

    .nav-btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: none;
      background: #fff;
      box-shadow: 0 2px 10px var(--shadow);
      color: var(--dark-blue);
      font-weight: 700;
      font-size: 18px;
      cursor: pointer;
    }

    .dots {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: none;
      background: #c7d5e7;
      cursor: pointer;
      transition: transform 200ms ease, background-color 200ms ease;
    }

    .dot.active {
      background: var(--pink);
      transform: scale(1.2);
    }

    .proto-note {
      margin-top: 12px;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 12px;
      padding: 10px 12px;
      box-shadow: 0 4px 12px var(--shadow);
    }

    .proto-note p {
      margin: 0;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .flash {
      animation: flashPulse 320ms ease;
    }

    @keyframes flashPulse {
      0% { transform: scale(1); filter: brightness(1); }
      50% { transform: scale(1.02); filter: brightness(1.08); }
      100% { transform: scale(1); filter: brightness(1); }
    }

    @media (min-width: 720px) {
      .app {
        width: min(100%, 940px);
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 18px;
        align-items: start;
      }

      .hero {
        position: sticky;
        top: 16px;
      }

      .carousel-zone {
        margin-top: 0;
      }

      .phone-shell {
        margin: 0 auto;
      }

      .proto-note {
        grid-column: 1 / -1;
      }
    }
  </style>
</head>
<body>
  <div class="bg-shape shape-a"></div>
  <div class="bg-shape shape-b"></div>

  <main class="app">
    <header class="hero">
      <div class="hero-top">
        <span class="label">日次差分 / ASO検証</span>
        <span class="date">2026-03-04</span>
      </div>
      <h1>ストアPV→DL率を<br>17.3%から25%へ</h1>
      <div class="kpi-card">
        <div class="kpi-row">
          <span>現状 CVR</span>
          <strong id="kpiText">17.3% / 25%</strong>
        </div>
        <div class="kpi-track">
          <div class="kpi-fill" id="kpiFill"></div>
        </div>
      </div>
    </header>

    <section class="carousel-zone">
      <div class="swipe-hint">左右スワイプでスクショ案A/B/Cを切替</div>

      <div class="phone-shell" id="phoneShell">
        <div class="slides" id="slides">
          <article class="slide slide-a">
            <div class="platform-row">
              <span class="badge ios">iOS向け</span>
              <span class="badge pink">個人情報不要</span>
            </div>
            <h2>AIがあなたの愛車を<br>3秒で査定</h2>
            <p class="lead">2019 トヨタ プリウス S / 42,300km / パールホワイト</p>

            <section class="card price-card" id="priceCard">
              <p class="price-label">現在の想定価格</p>
              <p class="price-number" id="aiPrice">1,742,000円</p>
              <p class="trend" id="aiTrend">先月比 +48,000円</p>
            </section>

            <section class="steps" id="stepsA">
              <div class="step active">1. 車種</div>
              <div class="step">2. 年式</div>
              <div class="step">3. 装備</div>
              <div class="step">4. 写真</div>
            </section>

            <section class="card">
              <p class="mission-title">診断ミッション: 装備を選んで査定精度をアップ</p>
              <div class="chip-wrap" id="equipChips">
                <button class="chip" data-bonus="1">サンルーフ</button>
                <button class="chip" data-bonus="1">純正ナビ</button>
                <button class="chip" data-bonus="1">レザーシート</button>
                <button class="chip" data-bonus="1">禁煙車</button>
              </div>
              <div class="meter-row">
                <span>査定精度</span>
                <div class="meter"><span id="accuracyFill"></span></div>
                <strong id="accuracyText">72%</strong>
              </div>
              <button class="btn primary" id="advanceA">診断を進める</button>
            </section>
          </article>

          <article class="slide slide-b">
            <div class="platform-row">
              <span class="badge android">Android向け</span>
              <span class="badge ios">出費管理 + 将来予測</span>
            </div>
            <h2>出費と価格推移を同時管理<br>売り時を可視化</h2>
            <p class="lead">2020 ホンダ N-BOX Custom L / 31,100km</p>

            <section class="card">
              <ul class="expense-list">
                <li class="expense-item"><span>ガソリン（2月）</span><strong>¥11,800</strong></li>
                <li class="expense-item"><span>任意保険（月割）</span><strong>¥7,200</strong></li>
                <li class="expense-item"><span>駐車場</span><strong>¥12,000</strong></li>
                <li class="expense-item"><span>整備積立</span><strong>¥3,800</strong></li>
              </ul>
            </section>

            <section class="card" id="forecastCard">
              <div class="forecast-tabs" id="forecastTabs">
                <button class="tab active" data-month="3">3ヶ月</button>
                <button class="tab" data-month="6">6ヶ月</button>
                <button class="tab" data-month="12">12ヶ月</button>
              </div>
              <div class="forecast-graph" id="forecastBars">
                <div class="bar" style="height: 54%"></div>
                <div class="bar" style="height: 60%"></div>
                <div class="bar" style="height: 66%"></div>
                <div class="bar" style="height: 72%"></div>
                <div class="bar" style="height: 75%"></div>
                <div class="bar" style="height: 80%"></div>
              </div>
              <p class="forecast-result" id="forecastValue">3ヶ月後の予測査定額: 1,580,000円</p>
              <p class="hint" id="forecastHint">春需要で上昇予測。今は「待ち」優位です。</p>
            </section>

            <section class="card">
              <button class="btn white" id="addExpense">+ 出費を1件記録して節約ゲージUP</button>
              <div class="gauge-row">
                <div class="gauge-head">
                  <span>維持費最適化スコア</span>
                  <span id="savingScore">34pt</span>
                </div>
                <div class="gauge-track">
                  <div class="gauge-fill" id="savingFill">34</div>
                </div>
              </div>
            </section>
          </article>

          <article class="slide slide-c">
            <div class="platform-row">
              <span class="badge compare">競合比較</span>
              <span class="badge pink">電話0本を訴求</span>
            </div>
            <h2>相場チェックは電話0本<br>売却時も負担最小</h2>
            <p class="lead">「まず価格だけ知りたい」ユーザー離脱を防ぐメッセージ設計</p>

            <section class="mode-toggle" id="modeToggle">
              <button class="mode-btn active" data-mode="check">相場チェック時</button>
              <button class="mode-btn" data-mode="sell">売却相談時</button>
            </section>

            <section class="card" id="compareCard">
              <div class="compare-row ucarpac" data-check="0" data-sell="1">
                <div class="compare-name">UcarPAC</div>
                <div class="compare-track"><div class="compare-fill"></div></div>
                <div class="compare-count">0本</div>
              </div>
              <div class="compare-row" data-check="5" data-sell="10">
                <div class="compare-name">一括査定</div>
                <div class="compare-track"><div class="compare-fill"></div></div>
                <div class="compare-count">5本</div>
              </div>
              <div class="compare-row" data-check="2" data-sell="3">
                <div class="compare-name">MOTA</div>
                <div class="compare-track"><div class="compare-fill"></div></div>
                <div class="compare-count">2本</div>
              </div>
              <div class="compare-row" data-check="1" data-sell="1">
                <div class="compare-name">セルカ</div>
                <div class="compare-track"><div class="compare-fill"></div></div>
                <div class="compare-count">1本</div>
              </div>
            </section>

            <p class="claim" id="modeClaim">UcarPACなら、個人情報なしの相場チェックは営業電話0本。DL前不安を最小化。</p>

            <section class="pill-grid">
              <div class="pill">AI査定<br>将来予測つき</div>
              <div class="pill">8,000社<br>オークション</div>
              <div class="pill">電話対応<br>最小1社</div>
              <div class="pill">出費管理で<br>売り時判断</div>
            </section>

            <button class="btn pink">今すぐ無料でAI査定を試す</button>
          </article>
        </div>
      </div>

      <div class="slider-nav">
        <button class="nav-btn" id="prevBtn" aria-label="前へ">‹</button>
        <div class="dots">
          <button class="dot active" data-index="0" aria-label="A"></button>
          <button class="dot" data-index="1" aria-label="B"></button>
          <button class="dot" data-index="2" aria-label="C"></button>
        </div>
        <button class="nav-btn" id="nextBtn" aria-label="次へ">›</button>
      </div>
    </section>

    <footer class="proto-note">
      <p>検証用プロトタイプ: A=AI査定全面訴求 / B=出費管理+将来予測 / C=競合比較「電話0本」訴求（データ更新日: 2026-03-04）</p>
    </footer>
  </main>

  <script>
    (function () {
      var slides = document.getElementById("slides");
      var phoneShell = document.getElementById("phoneShell");
      var dots = Array.prototype.slice.call(document.querySelectorAll(".dot"));
      var prevBtn = document.getElementById("prevBtn");
      var nextBtn = document.getElementById("nextBtn");
      var current = 0;
      var maxIndex = 2;

      function renderSlider() {
        slides.style.transform = "translateX(-" + (current * 100) + "%)";
        dots.forEach(function (dot, idx) {
          dot.classList.toggle("active", idx === current);
        });
      }

      function goTo(index) {
        if (index < 0) index = 0;
        if (index > maxIndex) index = maxIndex;
        current = index;
        renderSlider();
      }

      prevBtn.addEventListener("click", function () { goTo(current - 1); });
      nextBtn.addEventListener("click", function () { goTo(current + 1); });

      dots.forEach(function (dot) {
        dot.addEventListener("click", function () {
          goTo(Number(dot.dataset.index));
        });
      });

      var startX = 0;
      var endX = 0;

      phoneShell.addEventListener("touchstart", function (e) {
        startX = e.touches[0].clientX;
      }, { passive: true });

      phoneShell.addEventListener("touchmove", function (e) {
        endX = e.touches[0].clientX;
      }, { passive: true });

      phoneShell.addEventListener("touchend", function () {
        var diff = endX - startX;
        if (Math.abs(diff) > 42) {
          if (diff < 0) goTo(current + 1);
          if (diff > 0) goTo(current - 1);
        }
        startX = 0;
        endX = 0;
      });

      var kpiFill = document.getElementById("kpiFill");
      setTimeout(function () {
        kpiFill.style.width = "69.2%";
      }, 260);

      var aiPrice = document.getElementById("aiPrice");
      var aiTrend = document.getElementById("aiTrend");
      var priceCard = document.getElementById("priceCard");
      var equipChips = Array.prototype.slice.call(document.querySelectorAll("#equipChips .chip"));
      var accuracyFill = document.getElementById("accuracyFill");
      var accuracyText = document.getElementById("accuracyText");
      var advanceA = document.getElementById("advanceA");
      var stepsA = Array.prototype.slice.call(document.querySelectorAll("#stepsA .step"));
      var stepIndex = 0;
      var basePrice = 1742000;

      function formatYen(value) {
        return value.toLocaleString("ja-JP") + "円";
      }

      function updateA() {
        var selectedCount = equipChips.filter(function (c) {
          return c.classList.contains("selected");
        }).length;

        var accuracy = Math.min(72 + selectedCount * 6, 96);
        var updatedPrice = basePrice + selectedCount * 22000;
        var trendValue = 48000 + selectedCount * 6000;

        accuracyFill.style.width = accuracy + "%";
        accuracyText.textContent = accuracy + "%";
        aiPrice.textContent = formatYen(updatedPrice);
        aiTrend.textContent = "先月比 +" + trendValue.toLocaleString("ja-JP") + "円";

        priceCard.classList.remove("flash");
        void priceCard.offsetWidth;
        priceCard.classList.add("flash");
      }

      equipChips.forEach(function (chip) {
        chip.addEventListener("click", function () {
          chip.classList.toggle("selected");
          updateA();
        });
      });

      function updateSteps() {
        stepsA.forEach(function (step, idx) {
          step.classList.toggle("active", idx <= stepIndex);
        });
        if (stepIndex < 3) {
          advanceA.textContent = "診断を進める";
        } else {
          advanceA.textContent = "AI査定結果を表示";
        }
      }

      advanceA.addEventListener("click", function () {
        stepIndex = Math.min(stepIndex + 1, 3);
        updateSteps();
        updateA();
      });

      var forecastTabs = Array.prototype.slice.call(document.querySelectorAll("#forecastTabs .tab"));
      var forecastBars = Array.prototype.slice.call(document.querySelectorAll("#forecastBars .bar"));
      var forecastValue = document.getElementById("forecastValue");
      var forecastHint = document.getElementById("forecastHint");

      var forecastData = {
        "3": {
          price: 1580000,
          hint: "春需要で上昇予測。今は「待ち」優位です。",
          bars: [54, 60, 66, 72, 75, 80]
        },
        "6": {
          price: 1490000,
          hint: "夏以降は横ばい。出費次第で早売りも選択肢です。",
          bars: [58, 59, 58, 56, 55, 54]
        },
        "12": {
          price: 1310000,
          hint: "1年後は減価が進行。高値狙いなら年内売却が有利です。",
          bars: [70, 65, 60, 55, 49, 43]
        }
      };

      function updateForecast(month) {
        var data = forecastData[month];
        forecastTabs.forEach(function (tab) {
          tab.classList.toggle("active", tab.dataset.month === month);
        });
        forecastBars.forEach(function (bar, idx) {
          bar.style.height = data.bars[idx] + "%";
        });
        forecastValue.textContent = month + "ヶ月後の予測査定額: " + formatYen(data.price);
        forecastHint.textContent = data.hint;
      }

      forecastTabs.forEach(function (tab) {
        tab.addEventListener("click", function () {
          updateForecast(tab.dataset.month);
        });
      });

      var addExpenseBtn = document.getElementById("addExpense");
      var savingFill = document.getElementById("savingFill");
      var savingScore = document.getElementById("savingScore");
      var score = 34;

      function renderScore() {
        savingFill.style.width = score + "%";
        savingFill.textContent = score;
        savingScore.textContent = score + "pt";
      }

      addExpenseBtn.addEventListener("click", function () {
        score = Math.min(score + 11, 100);
        renderScore();
        addExpenseBtn.classList.remove("flash");
        void addExpenseBtn.offsetWidth;
        addExpenseBtn.classList.add("flash");
      });

      var modeButtons = Array.prototype.slice.call(document.querySelectorAll("#modeToggle .mode-btn"));
      var compareRows = Array.prototype.slice.call(document.querySelectorAll("#compareCard .compare-row"));
      var modeClaim = document.getElementById("modeClaim");

      function updateCompare(mode) {
        modeButtons.forEach(function (btn) {
          btn.classList.toggle("active", btn.dataset.mode === mode);
        });

        compareRows.forEach(function (row) {
          var fill = row.querySelector(".compare-fill");
          var count = row.querySelector(".compare-count");
          var value = Number(row.dataset[mode]);
          var width = value === 0 ? 4 : Math.min((value / 10) * 100, 100);
          fill.style.width = width + "%";
          count.textContent = value + "本";
        });

        if (mode === "check") {
          modeClaim.textContent = "UcarPACなら、個人情報なしの相場チェックは営業電話0本。DL前不安を最小化。";
        } else {
          modeClaim.textContent = "売却相談に進んでも、UcarPACはやりとり最小1社。電話ストレスを抑えて高額売却へ。";
        }
      }

      modeButtons.forEach(function (btn) {
        btn.addEventListener("click", function () {
          updateCompare(btn.dataset.mode);
        });
      });

      renderSlider();
      updateA();
      updateSteps();
      updateForecast("3");
      renderScore();
      updateCompare("check");
    })();
  </script>
</body>
</html>
