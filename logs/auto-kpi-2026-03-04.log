  <script>
    const kpiData = {
      baseline: {
        pv: 12480,
        dl: 2159,
        cvr: 17.3,
        target: 25.0,
        a: 18.4,
        b: 17.9,
        c: 19.1,
        insight: "現在はベースライン表示です。スクリーン別訴求の寄与率を確認できます。"
      },
      improved: {
        pv: 12480,
        dl: 3120,
        cvr: 25.0,
        target: 25.0,
        a: 24.1,
        b: 25.4,
        c: 26.0,
        insight: "改善モードです。比較訴求（スクショC）とAI査定訴求（スクショA）がDL増分を牽引しています。"
      }
    };

    const pvValue = document.getElementById("pvValue");
    const dlValue = document.getElementById("dlValue");
    const cvrValue = document.getElementById("cvrValue");
    const gapValue = document.getElementById("gapValue");
    const progressLabel = document.getElementById("progressLabel");
    const goalBar = document.getElementById("goalBar");
    const cvrA = document.getElementById("cvrA");
    const cvrB = document.getElementById("cvrB");
    const cvrC = document.getElementById("cvrC");
    const insightText = document.getElementById("insightText");
    const scenarioSwitch = document.getElementById("scenarioSwitch");
    const scenarioSwitchWrap = document.getElementById("scenarioSwitchWrap");
    const simulateBtn = document.getElementById("simulateBtn");
    const cvrBars = document.querySelectorAll(".cvr-bar");

    const tabs = document.querySelectorAll(".tab-btn");
    const screens = document.querySelectorAll(".store-screen");

    let mode = "baseline";

    function num(n) {
      return n.toLocaleString("ja-JP");
    }

    function renderDashboard() {
      const d = kpiData[mode];
      const gap = +(d.cvr - d.target).toFixed(1);
      const gapSign = gap > 0 ? "+" : "";

      pvValue.textContent = num(d.pv);
      dlValue.textContent = num(d.dl);
      cvrValue.innerHTML = d.cvr.toFixed(1) + "<small>%</small>";
      gapValue.innerHTML = gapSign + gap.toFixed(1) + "<small>pt</small>";
      progressLabel.textContent = d.cvr.toFixed(1) + "% / " + d.target.toFixed(1) + "%";
      goalBar.style.width = Math.min(100, (d.cvr / d.target) * 100) + "%";

      cvrA.textContent = d.a.toFixed(1) + "%";
      cvrB.textContent = d.b.toFixed(1) + "%";
      cvrC.textContent = d.c.toFixed(1) + "%";
      insightText.textContent = d.insight;

      cvrBars.forEach((bar) => {
        const key = bar.dataset.key;
        const value = d[key];
        bar.style.width = Math.min(100, (value / 30) * 100) + "%";
      });

      scenarioSwitch.checked = mode === "improved";
      scenarioSwitchWrap.classList.toggle("on", mode === "improved");
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((btn) => btn.classList.remove("active"));
        tab.classList.add("active");
        const id = tab.dataset.screen;
        screens.forEach((screen) => {
          screen.classList.toggle("active", screen.id === "screen-" + id);
        });
      });
    });

    scenarioSwitch.addEventListener("change", () => {
      mode = scenarioSwitch.checked ? "improved" : "baseline";
      renderDashboard();
    });

    simulateBtn.addEventListener("click", () => {
      mode = mode === "baseline" ? "improved" : "baseline";
      renderDashboard();
    });

    const toggleEvidence = document.getElementById("toggleEvidence");
    const evidenceNote = document.getElementById("evidenceNote");
    toggleEvidence.addEventListener("click", () => {
      evidenceNote.classList.toggle("show");
      toggleEvidence.textContent = evidenceNote.classList.contains("show")
        ? "「電話0本」の注記を閉じる"
        : "「電話0本」の注記を表示";
    });

    renderDashboard();
  </script>
</body>
