  <script>
    const previewGrid = document.getElementById('previewGrid');
    const tabs = Array.from(document.querySelectorAll('.tab'));
    const shotCards = Array.from(document.querySelectorAll('.shot-card'));
    const moodToggle = document.getElementById('moodToggle');
    const allViewToggle = document.getElementById('allViewToggle');
    const heroLead = document.getElementById('heroLead');
    const heroBadge = document.getElementById('heroBadge');

    function activateShot(target) {
      tabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.shotTarget === target);
      });

      shotCards.forEach((card) => {
        card.classList.toggle('is-active', card.dataset.shot === target);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        previewGrid.classList.remove('show-all');
        allViewToggle.textContent = '3枚をまとめて見る';
        activateShot(tab.dataset.shotTarget);
      });
    });

    allViewToggle.addEventListener('click', () => {
      const willShowAll = !previewGrid.classList.contains('show-all');
      previewGrid.classList.toggle('show-all', willShowAll);
      allViewToggle.textContent = willShowAll ? '1枚ずつ見る' : '3枚をまとめて見る';
    });

    moodToggle.addEventListener('click', () => {
      const warmMode = document.body.classList.toggle('warm-mode');
      moodToggle.textContent = warmMode ? '標準コピーに戻す' : '安心コピーを強める';
      heroLead.textContent = warmMode
        ? '「まだ売るかわからない」「連絡が増えそうで怖い」という迷いを、やわらかい言葉と見える化で受け止める構成です。'
        : '「相場だけ知りたい」「営業電話が心配」「維持費まで見たい」という迷いに、安心感のある言葉と暖色系の画面で先回りする構成です。';
      heroBadge.textContent = warmMode ? '不安軽減を強調中' : '感情訴求A案';
      document.getElementById('screenACopy').textContent = warmMode
        ? '「まだ売るか決めていない」人でも大丈夫。いまの相場と3か月先の売り時を、やさしい言葉で落ち着いて確認できます。'
        : '「いくらで売れそう？」の不安に、いまの相場と3か月先の売り時をひと目で。まずは気軽に、電話なしで始められます。';
      document.getElementById('screenBCopy').textContent = warmMode
        ? '家計のようにやさしく見える化。持ち続ける安心と、売るタイミングの納得感を同時につくります。'
        : '毎月のガソリン代や保険を記録しながら、愛車の将来価値もチェック。持ち続けるか、売るかを感覚ではなく数字で考えられます。';
      document.getElementById('screenCCopy').textContent = warmMode
        ? 'まずは知るだけでOK。比較の一歩目で電話が来ないから、焦らず自分のペースで決められます。'
        : '比較したいだけなのに連絡が増えるのはつらい。UcarPACは相場チェック時に個人情報不要だから、落ち着いて判断できます。';
    });

    const reassureButton = document.getElementById('reassureButton');
    const comfortNote = document.getElementById('comfortNote');

    reassureButton.addEventListener('click', () => {
      const isOpen = comfortNote.classList.toggle('is-open');
      reassureButton.textContent = isOpen ? '安心ポイントを閉じる' : '安心ポイントを見る';
    });

    const forecastData = [
      {
        monthLabel: '1か月後',
        price: '132万円',
        text: '1か月後なら、想定出費は約3.1万円。現在価格との差が小さいうちに判断できます。',
        gap: '-1万円',
        timing: '今〜1か月',
        caption: '1か月後の売却予測'
      },
      {
        monthLabel: '3か月後',
        price: '128万円',
        text: 'このまま維持すると3か月で想定出費は約9.3万円。売却タイミングの比較材料をやさしく提示します。',
        gap: '-5万円',
        timing: '今〜3か月',
        caption: '3か月後の売却予測'
      },
      {
        monthLabel: '6か月後',
        price: '121万円',
        text: '6か月後は維持費の積み上がりと価格変動が大きくなりやすく、判断の後悔が増える前に検討しやすくします。',
        gap: '-12万円',
        timing: '今〜6か月',
        caption: '6か月後の売却予測'
      }
    ];

    const monthRange = document.getElementById('monthRange');
    const monthLabel = document.getElementById('monthLabel');
    const forecastPrice = document.getElementById('forecastPrice');
    const forecastText = document.getElementById('forecastText');
    const futureGap = document.getElementById('futureGap');
    const sellTiming = document.getElementById('sellTiming');
    const forecastCaption = document.getElementById('forecastCaption');
    const storyToneButton = document.getElementById('storyToneButton');
    const expenseTotal = document.getElementById('expenseTotal');
    const keepCost = document.getElementById('keepCost');

    function updateForecast(index) {
      const item = forecastData[index];
      monthLabel.textContent = item.monthLabel;
      forecastPrice.textContent = item.price;
      forecastText.textContent = item.text;
      futureGap.textContent = item.gap;
      sellTiming.textContent = item.timing;
      forecastCaption.textContent = item.caption;
    }

    monthRange.addEventListener('input', (event) => {
      updateForecast(Number(event.target.value));
    });

    storyToneButton.addEventListener('click', () => {
      const changed = storyToneButton.dataset.changed === 'true';
      if (changed) {
        expenseTotal.textContent = '31,200円';
        keepCost.textContent = '3.1万円';
        storyToneButton.dataset.changed = 'false';
        storyToneButton.textContent = 'やさしい説明を切替';
      } else {
        expenseTotal.textContent = '31,200円 + 将来価値差';
        keepCost.textContent = '毎月の負担見える化';
        storyToneButton.dataset.changed = 'true';
        storyToneButton.textContent = '数値表示に戻す';
      }
    });

    const compareData = {
      estimate: {
        big: '0',
        label: '電話本数',
        lead: '相場チェック時は個人情報不要。査定の検討段階で営業電話が来ないので、はじめての比較でも身構えにくい見せ方です。',
        captionLabel: '相場チェック時の電話本数',
        caption: '注記: ここでは「相場チェック時の心理負担」を伝えるために、査定前段階のコミュニケーション負荷を強調しています。売却相談に進むとUcarPACは1社対応です。',
        rows: [
          { name: 'UcarPAC', sub: 'AI査定までは個人情報不要。落ち着いて相場確認', value: '0本', primary: true },
          { name: 'MOTA', sub: '売却比較のための接点が発生しやすい設計', value: '3社' },
          { name: 'ズバット車買取比較', sub: '一括査定のため複数社対応が前提', value: '最大10社' },
          { name: 'セルカ', sub: '売却時は1社対応だが、AI査定導線はなし', value: '1社' }
        ]
      },
      sell: {
        big: '1',
        label: '電話先',
        lead: '売却相談に進んでも、UcarPACは基本1社対応。最高額を目指しながら、やりとりの負担を増やしすぎない見せ方に切り替えます。',
        captionLabel: '売却相談時のやりとり数',
        caption: '注記: 実際の売却相談フェーズでは各社の運用条件により接点数は変わります。ここでは「UcarPACは1社対応で進めやすい」印象を伝える構成です。',
        rows: [
          { name: 'UcarPAC', sub: 'オークション後の案内は1社対応で進めやすい', value: '1社', primary: true },
          { name: 'MOTA', sub: '上位3社のみ連絡可能', value: '3社' },
          { name: 'ズバット車買取比較', sub: '一括査定のため複数社との調整が発生', value: '最大10社' },
          { name: 'セルカ', sub: '売却時は1社対応', value: '1社' }
        ]
      }
    };

    const stageButtons = Array.from(document.querySelectorAll('.stage-button'));
    const bigCallCount = document.getElementById('bigCallCount');
    const bigCallLabel = document.getElementById('bigCallLabel');
    const compareLead = document.getElementById('compareLead');
    const compareCaptionLabel = document.getElementById('compareCaptionLabel');
    const compareCaption = document.getElementById('compareCaption');
    const compareTable = document.getElementById('compareTable');
    const compareHighlightButton = document.getElementById('compareHighlightButton');

    function renderCompareRows(stage) {
      const config = compareData[stage];
      bigCallCount.textContent = config.big;
      bigCallLabel.textContent = config.label;
      compareLead.textContent = config.lead;
      compareCaptionLabel.textContent = config.captionLabel;
      compareCaption.textContent = config.caption;

      compareTable.innerHTML = config.rows.map((row) => {
        return `
          <div class="compare-row${row.primary ? ' primary' : ''}">
            <div class="compare-name">
              <strong>${row.name}</strong>
              <span>${row.sub}</span>
            </div>
            <div class="compare-value">${row.value}</div>
          </div>
        `;
      }).join('');
    }

    stageButtons.forEach((button) => {
      button.addEventListener('click', () => {
        stageButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        renderCompareRows(button.dataset.stage);
      });
    });

    compareHighlightButton.addEventListener('click', () => {
      const activeStage = stageButtons.find((button) => button.classList.contains('is-active'))?.dataset.stage || 'estimate';
      const nextStage = activeStage === 'estimate' ? 'sell' : 'estimate';
      stageButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.stage === nextStage));
      renderCompareRows(nextStage);
    });

    updateForecast(Number(monthRange.value));
    renderCompareRows('estimate');
  </script>
