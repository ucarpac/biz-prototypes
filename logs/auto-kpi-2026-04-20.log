                  <p>比較アプリ文脈では「何ができるか」より「嫌なことが起きないか」が重要な場合があります。</p>
                </div>
                <div class="insight-item">
                  <strong>数値入り比較表は保存記憶に残りやすい</strong>
                  <p>0本、1社、8,000社のような強い数字を縦に並べることで、他サービスとの違いを明確化します。</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="sticky-cta">
      <div class="sticky-top">
        <div>
          <strong>どの訴求を先頭に置くかを、その場で比較できます。</strong>
          <span>タブ切替とグラフ状態変更で、スクショごとの見え方を確認。</span>
        </div>
        <div class="platform-pill">B案 / 1ファイル構成</div>
      </div>
      <div class="sticky-actions">
        <button class="primary" data-focus="all">全スクショを並べて確認</button>
        <button class="secondary" id="preview-note">検証メモを表示</button>
      </div>
    </section>
  </main>

  <div class="toast" id="toast"></div>

  <script>
    const tabButtons = Array.from(document.querySelectorAll(".tab-button"));
    const focusButtons = Array.from(document.querySelectorAll("[data-focus]"));
    const sections = Array.from(document.querySelectorAll(".screen-section"));
    const compareButtons = Array.from(document.querySelectorAll("[data-compare]"));
    const aiButtons = Array.from(document.querySelectorAll("[data-ai-filter]"));
    const forecastButtons = Array.from(document.querySelectorAll("[data-forecast]"));
    const toast = document.getElementById("toast");
    const previewNote = document.getElementById("preview-note");

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove("show");
      }, 2200);
    }

    function activateBars() {
      document.querySelectorAll(".metric-bar span, .progress-fill").forEach((el) => {
        requestAnimationFrame(() => {
          el.classList.add("ready");
        });
      });
    }

    function setFocus(target) {
      tabButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.focus === target);
      });

      sections.forEach((section) => {
        const active = target === "all" || section.dataset.shot === target;
        section.classList.toggle("is-muted", !active);
      });

      if (target !== "all") {
        const targetSection = document.getElementById(target);
        if (targetSection) {
          targetSection.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }
    }

    focusButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setFocus(button.dataset.focus);
        const labels = {
          "all": "3枚の役割を並列で比較できます。",
          "shot-a": "AI査定を先頭に置く構成へフォーカスしました。",
          "shot-b": "出費管理と将来予測の継続価値にフォーカスしました。",
          "shot-c": "電話0本の比較訴求にフォーカスしました。"
        };
        showToast(labels[button.dataset.focus] || "表示を切り替えました。");
      });
    });

    const aiMetrics = {
      market: [
        { label: "全国相場との一致度", value: "92%" },
        { label: "写真なしでも推定可能", value: "84%" },
        { label: "売り時の納得感", value: "88%" }
      ],
      mileage: [
        { label: "走行距離の反映精度", value: "90%" },
        { label: "10,000km差の検知", value: "81%" },
        { label: "価格変動の見やすさ", value: "86%" }
      ],
      grade: [
        { label: "グレード差の反映", value: "94%" },
        { label: "人気装備の影響", value: "79%" },
        { label: "比較のわかりやすさ", value: "85%" }
      ]
    };

    const aiLabels = Array.from(document.querySelectorAll("#shot-a .metric-label"));
    const aiFills = Array.from(document.querySelectorAll("#shot-a .metric-bar span"));

    aiButtons.forEach((button) => {
      button.addEventListener("click", () => {
        aiButtons.forEach((item) => item.classList.toggle("is-active", item === button));
        const rows = aiMetrics[button.dataset.aiFilter];
        rows.forEach((row, index) => {
          const spans = aiLabels[index].querySelectorAll("span");
          spans[0].textContent = row.label;
          spans[1].textContent = row.value;
          aiFills[index].style.setProperty("--fill-width", row.value);
          aiFills[index].classList.remove("ready");
          requestAnimationFrame(() => aiFills[index].classList.add("ready"));
        });
        showToast("AI査定の根拠表示を切り替えました。");
      });
    });

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => {
        compareButtons.forEach((item) => {
          item.classList.toggle("is-active", item === button);
          item.classList.toggle("alt-active", item === button);
        });
        const head = document.querySelector("#shot-c .section-head h5");
        const rows = Array.from(document.querySelectorAll("#shot-c .table-row"));
        if (button.dataset.compare === "auction") {
          head.textContent = "入札規模と売却体験の比較";
          rows[0].children[1].textContent = "8,000社";
          rows[0].children[1].className = "table-score win";
          rows[0].children[2].textContent = "電話1社";
          rows[0].children[2].className = "table-score win";
          rows[1].children[1].textContent = "数社〜最大10社";
          rows[1].children[1].className = "table-score warn";
          rows[1].children[2].textContent = "交渉負荷あり";
          rows[1].children[2].className = "table-score warn";
          rows[2].children[1].textContent = "自社基準";
          rows[2].children[1].className = "table-score gray";
          rows[2].children[2].textContent = "価格上限あり";
          rows[2].children[2].className = "table-score gray";
          showToast("競合比較を入札規模ベースに切り替えました。");
        } else {
          head.textContent = "主要サービスとの比較";
          rows[0].children[1].textContent = "電話0本";
          rows[0].children[1].className = "table-score win";
          rows[0].children[2].textContent = "やりとり1社";
          rows[0].children[2].className = "table-score win";
          rows[1].children[1].textContent = "複数社から連絡";
          rows[1].children[1].className = "table-score warn";
          rows[1].children[2].textContent = "比較交渉が必要";
          rows[1].children[2].className = "table-score warn";
          rows[2].children[1].textContent = "相場比較しづらい";
          rows[2].children[1].className = "table-score gray";
          rows[2].children[2].textContent = "価格上限が見えにくい";
          rows[2].children[2].className = "table-score gray";
          showToast("競合比較を電話負担ベースに切り替えました。");
        }
      });
    });

    const forecastPath = document.getElementById("forecast-path");
    const forecastDot1 = document.getElementById("forecast-dot-1");
    const forecastDot2 = document.getElementById("forecast-dot-2");
    const forecastDot3 = document.getElementById("forecast-dot-3");
    const forecastNote = document.getElementById("forecast-note");
    const forecastValues = Array.from(document.querySelectorAll("#shot-b .forecast-point strong"));

    forecastButtons.forEach((button) => {
      button.addEventListener("click", () => {
        forecastButtons.forEach((item) => item.classList.toggle("is-active", item === button));
        if (button.dataset.forecast === "down") {
          forecastPath.setAttribute("d", "M12 40 C52 42, 92 48, 118 56 C160 68, 198 74, 226 72 C252 70, 282 62, 308 58");
          forecastDot1.setAttribute("cy", "56");
          forecastDot2.setAttribute("cy", "72");
          forecastDot3.setAttribute("cy", "58");
          forecastValues[0].textContent = "289万円";
          forecastValues[1].textContent = "281万円";
          forecastValues[2].textContent = "268万円";
          forecastNote.textContent = "中古車在庫の増加を想定した下落シナリオです。早めの売却判断を促します。";
          showToast("下落シナリオに切り替えました。");
        } else {
          forecastPath.setAttribute("d", "M12 54 C54 50, 96 42, 118 36 C160 26, 194 18, 226 24 C256 30, 280 42, 308 48");
          forecastDot1.setAttribute("cy", "36");
          forecastDot2.setAttribute("cy", "24");
          forecastDot3.setAttribute("cy", "48");
          forecastValues[0].textContent = "289万円";
          forecastValues[1].textContent = "300万円";
          forecastValues[2].textContent = "282万円";
          forecastNote.textContent = "新型切替前の需要が強く、6月にかけて上振れしやすい推定です。";
          showToast("上昇シナリオに切り替えました。");
        }
      });
    });

    previewNote.addEventListener("click", () => {
      showToast("検証観点: 1枚目はAI査定の独自性、2枚目は継続価値、3枚目は不安解消を担当。");
    });

    activateBars();
  </script>
</body>
