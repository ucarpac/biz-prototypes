      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(248, 76, 162, 0.10);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
    }

    .screen-meta h2 {
      margin: 0;
      font-size: 24px;
      line-height: 1.35;
      letter-spacing: -0.03em;
      color: var(--back-dark-blue);
    }

    .screen-meta p {
      margin: 0;
      font-size: 14px;
      line-height: 1.8;
      color: #647193;
    }

    .screen-summary {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .summary-chip {
      padding: 12px;
      border-radius: 16px;
      background: rgba(9, 19, 85, 0.05);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .summary-chip span {
      display: block;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
      letter-spacing: 0.04em;
    }

    .summary-chip strong {
      display: block;
      margin-top: 6px;
      font-size: 20px;
      line-height: 1.1;
      color: var(--dark-blue);
    }

    .screen-layout {
      display: grid;
      gap: 18px;
      align-items: start;
    }

    .device-wrap {
      display: flex;
      justify-content: center;
    }

    .phone {
      position: relative;
      width: min(100%, var(--phone-width));
      max-width: 375px;
      min-height: var(--phone-height);
      border-radius: var(--radius-phone);
      padding: 12px;
      background: linear-gradient(145deg, #161b2f 0%, #090d19 100%);
      box-shadow: var(--shadow-heavy);
    }

    .phone::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 10px;
      transform: translateX(-50%);
      width: 118px;
      height: 24px;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.78);
      z-index: 3;
    }

    .phone.android::before {
      width: 84px;
      height: 18px;
      top: 12px;
    }

    .phone-screen {
      position: relative;
      overflow: hidden;
      min-height: calc(var(--phone-height) - 24px);
      border-radius: 26px;
      background: linear-gradient(180deg, #f9fbff 0%, #edf3ff 100%);
    }

    .phone-screen.ios-a {
      background:
        radial-gradient(circle at 88% 10%, rgba(248, 76, 162, 0.16), transparent 20%),
        radial-gradient(circle at 10% 2%, rgba(29, 220, 255, 0.25), transparent 22%),
        linear-gradient(180deg, #ffffff 0%, #edf4ff 44%, #fdf7fb 100%);
    }

    .phone-screen.android-b {
      background:
        radial-gradient(circle at 15% 8%, rgba(29, 220, 255, 0.18), transparent 22%),
        radial-gradient(circle at 86% 0%, rgba(248, 76, 162, 0.18), transparent 18%),
        linear-gradient(180deg, #0f1a63 0%, #162472 40%, #f4f8ff 40%, #ffffff 100%);
    }

    .phone-screen.compare-c {
      background:
        radial-gradient(circle at 90% 8%, rgba(248, 76, 162, 0.18), transparent 18%),
        radial-gradient(circle at 8% 14%, rgba(29, 220, 255, 0.22), transparent 24%),
        linear-gradient(180deg, #ffffff 0%, #fff7fb 52%, #eef7ff 100%);
    }

    .status-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px 0;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .status-icons {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .dot-icon,
    .bar-icon {
      display: inline-block;
      background: var(--dark-blue);
      border-radius: 999px;
    }

    .dot-icon {
      width: 6px;
      height: 6px;
    }

    .bar-icon {
      width: 18px;
      height: 8px;
      border-radius: 3px;
    }

    .screen-content {
      display: grid;
      gap: 14px;
      padding: 18px 18px 20px;
    }

    .brand-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .brand-box {
      display: grid;
      gap: 6px;
    }

    .brand-box .brand {
      font-size: 12px;
      font-weight: 900;
      color: var(--pink);
      letter-spacing: 0.08em;
    }

    .brand-box h3 {
      margin: 0;
      font-size: 26px;
      line-height: 1.25;
      letter-spacing: -0.04em;
      color: var(--back-dark-blue);
    }

    .platform-pill {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.08);
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .value-badge {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .value-badge.primary {
      background: rgba(9, 19, 85, 0.08);
      color: var(--dark-blue);
    }

    .value-badge.pink {
      background: rgba(248, 76, 162, 0.14);
      color: #c1176b;
    }

    .value-badge.sky {
      background: rgba(29, 220, 255, 0.18);
      color: #00579d;
    }

    .hero-card {
      padding: 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(9, 19, 85, 0.96), rgba(28, 38, 99, 0.94));
      color: var(--white);
      box-shadow: 0 18px 34px rgba(10, 19, 72, 0.22);
    }

    .hero-card.alt {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 247, 255, 0.94));
      color: var(--dark-blue);
      box-shadow: 0 18px 34px rgba(28, 38, 99, 0.1);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .hero-card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .hero-card h4 {
      margin: 0;
      font-size: 18px;
      line-height: 1.45;
      letter-spacing: -0.03em;
    }

    .hero-card p {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 1.75;
      color: inherit;
      opacity: 0.84;
    }

    .estimate-box {
      display: grid;
      gap: 8px;
      margin-top: 16px;
    }

    .estimate-label {
      font-size: 11px;
      letter-spacing: 0.04em;
      opacity: 0.76;
    }

    .estimate-price {
      display: flex;
      align-items: baseline;
      gap: 6px;
      font-family: var(--font-number);
      font-size: 44px;
      line-height: 1;
      letter-spacing: -0.05em;
      color: var(--white);
    }

    .hero-card.alt .estimate-price {
      color: var(--dark-blue);
    }

    .estimate-price small {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0;
    }

    .mini-chart {
      width: 100%;
      height: 92px;
      margin-top: 10px;
      display: block;
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .mini-stat {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-card.alt .mini-stat {
      background: rgba(9, 19, 85, 0.05);
      border-color: rgba(28, 38, 99, 0.06);
    }

    .mini-stat span {
      display: block;
      font-size: 10px;
      opacity: 0.78;
    }

    .mini-stat strong {
      display: block;
      margin-top: 6px;
      font-size: 18px;
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    .section-card {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 12px 24px rgba(28, 38, 99, 0.07);
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }

    .section-head h5 {
      margin: 0;
      font-size: 15px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .section-head .hint {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-under-blue);
    }

    .chip-group {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .chip-button {
      min-height: 36px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      font-size: 12px;
      font-weight: 700;
      color: var(--text-black);
      transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
    }

    .chip-button.is-active {
      background: var(--dark-blue);
      border-color: var(--dark-blue);
      color: var(--white);
    }

    .chip-button.alt-active {
      background: var(--pink);
      border-color: var(--pink);
      color: var(--white);
    }

    .dual-columns {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .metric-line {
      display: grid;
      gap: 8px;
      margin-top: 10px;
    }

    .metric-line:first-child {
      margin-top: 0;
    }

    .metric-label {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .metric-bar {
      height: 10px;
      border-radius: 999px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .metric-bar span {
      display: block;
      height: 100%;
      width: 0;
      border-radius: 999px;
      transition: width 800ms cubic-bezier(.2, .85, .2, 1);
    }

    .metric-bar .fill-cyan {
      background: var(--gradient-primary);
    }

    .metric-bar .fill-pink {
      background: var(--gradient-pink);
    }

    .metric-bar .fill-navy {
      background: linear-gradient(90deg, #091355 0%, #1d2e93 100%);
    }

    .metric-bar span.ready {
      width: var(--fill-width);
    }

    .caption-note {
      margin-top: 8px;
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 132px minmax(0, 1fr);
      gap: 14px;
      align-items: center;
    }

    .donut-wrap {
      position: relative;
      width: 132px;
      height: 132px;
      margin: 0 auto;
    }

    .donut-center {
      position: absolute;
      inset: 24px;
      display: grid;
      place-items: center;
      text-align: center;
      border-radius: 50%;
      background: #ffffff;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.04);
    }

    .donut-center span {
      display: block;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .donut-center strong {
      display: block;
      margin-top: 4px;
      font-size: 20px;
      color: var(--dark-blue);
      line-height: 1.1;
    }

    .legend-list {
      display: grid;
      gap: 10px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 12px;
      color: var(--dark-blue);
    }

    .legend-left {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex: 0 0 auto;
    }

    .future-toggle {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
    }

    .mini-toggle {
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(9, 19, 85, 0.05);
      border: 1px solid rgba(28, 38, 99, 0.06);
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
      transition: background 0.18s ease, color 0.18s ease;
    }

    .mini-toggle.is-active {
      background: var(--gradient-primary);
    }

    .forecast-points {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .forecast-point {
      padding: 12px;
      border-radius: 16px;
      background: rgba(9, 19, 85, 0.04);
    }

    .forecast-point span {
      display: block;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .forecast-point strong {
      display: block;
      margin-top: 6px;
      font-size: 17px;
      line-height: 1.2;
      color: var(--dark-blue);
    }

    .compare-top {
      display: grid;
      gap: 12px;
    }

    .compare-banner {
      display: grid;
      gap: 10px;
      padding: 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.95), rgba(28, 38, 99, 0.96));
      color: var(--white);
      box-shadow: 0 20px 38px rgba(102, 29, 91, 0.22);
    }

    .compare-banner small {
      font-size: 11px;
      font-weight: 700;
      opacity: 0.82;
      letter-spacing: 0.04em;
    }

    .compare-banner strong {
      font-size: 38px;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .compare-banner p {
      margin: 0;
      font-size: 12px;
      line-height: 1.7;
      opacity: 0.9;
    }

    .comparison-table {
      display: grid;
      gap: 10px;
    }

    .table-head,
    .table-row {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 10px;
      align-items: center;
    }

    .table-head {
      font-size: 10px;
      font-weight: 800;
      color: var(--text-gray);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .table-row {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 10px 22px rgba(28, 38, 99, 0.06);
      font-size: 12px;
    }

    .table-row strong {
      color: var(--dark-blue);
      font-size: 13px;
    }

    .table-score {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 10px;
      border-radius: 999px;
      font-weight: 800;
    }

    .table-score.win {
      background: rgba(29, 220, 255, 0.16);
      color: #00579d;
    }

    .table-score.warn {
      background: rgba(255, 216, 232, 0.9);
      color: #b51d69;
    }

    .table-score.gray {
      background: rgba(9, 19, 85, 0.06);
      color: #5c6788;
    }

    .footnote-card {
      padding: 14px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.05);
      font-size: 11px;
      line-height: 1.8;
      color: #5c6788;
    }

    .insight-panel {
      display: grid;
      gap: 12px;
    }

    .insight-box {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 12px 22px rgba(28, 38, 99, 0.06);
    }

    .insight-box h6 {
      margin: 0 0 10px;
      font-size: 14px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .insight-list {
      display: grid;
      gap: 10px;
    }

    .insight-item {
      display: grid;
      gap: 6px;
      padding-top: 10px;
      border-top: 1px solid var(--ruled-line);
    }

    .insight-item:first-child {
      padding-top: 0;
      border-top: 0;
    }

    .insight-item strong {
      font-size: 13px;
      color: var(--dark-blue);
      line-height: 1.5;
    }

    .insight-item p {
      margin: 0;
      font-size: 12px;
      line-height: 1.75;
      color: #647193;
    }

    .sticky-cta {
      position: sticky;
      bottom: 14px;
      z-index: 5;
      display: grid;
      gap: 10px;
      margin-top: 24px;
      padding: 14px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(255, 255, 255, 0.9);
      box-shadow: var(--shadow-heavy);
      backdrop-filter: blur(20px);
    }

    .sticky-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .sticky-top strong {
      font-size: 16px;
      line-height: 1.45;
      color: var(--dark-blue);
    }

    .sticky-top span {
      font-size: 12px;
      color: var(--text-gray);
    }

    .sticky-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .sticky-actions button {
      min-height: 43px;
      padding: 0 18px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 800;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .sticky-actions .primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 12px 28px rgba(64, 191, 255, 0.26);
    }

    .sticky-actions .secondary {
      background: rgba(9, 19, 85, 0.06);
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .sticky-actions button:hover {
      transform: translateY(-1px);
    }

    .toast {
      position: fixed;
      right: 16px;
      bottom: 16px;
      z-index: 20;
      min-width: 220px;
      max-width: calc(100% - 32px);
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.94);
      color: var(--white);
      box-shadow: var(--shadow-heavy);
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition: opacity 0.24s ease, transform 0.24s ease;
      font-size: 13px;
      line-height: 1.7;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    .hidden {
      display: none;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.76; }
    }

    @media (min-width: 768px) {
      .page {
        width: min(1240px, calc(100% - 40px));
        padding-top: 22px;
      }

      .hero {
        padding: 24px;
      }

      .hero-grid {
        grid-template-columns: 1.25fr 0.95fr;
        align-items: start;
      }

      .screen-layout {
        grid-template-columns: minmax(340px, 400px) minmax(0, 1fr);
      }

      .screen-section.reverse .screen-layout {
        grid-template-columns: minmax(0, 1fr) minmax(340px, 400px);
      }

      .screen-section.reverse .device-wrap {
        order: 2;
      }

      .screen-section.reverse .insight-panel {
        order: 1;
      }
    }

    @media (max-width: 767px) {
      .screen-summary {
        grid-template-columns: 1fr;
      }

      .dual-columns {
        grid-template-columns: 1fr;
      }

      .expense-grid {
        grid-template-columns: 1fr;
      }

      .hero-stats,
      .goal-values {
        grid-template-columns: 1fr;
      }

      .table-head,
      .table-row {
        grid-template-columns: 1.2fr 1fr 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div class="eyebrow">ASO検証 | ストアPV→DL率 改善テーマ</div>
      <h1>数字で刺さる3枚構成で、<br>ストア詳細CVRを <span style="color: var(--pink);">17.3%</span> から <span style="color: #0095d9;">25%</span> へ。</h1>
      <p class="hero-copy">
        B案は、<strong>「何が得か」「他社と何が違うか」「今見る価値があるか」</strong>を一目で理解させる構成です。
        1枚目でAI査定、2枚目で出費管理と将来予測、3枚目で競合比較を並べ、
        ストアスクショを見た瞬間に <strong>独自価値</strong> と <strong>DL後の利用イメージ</strong> を数字で伝えます。
      </p>
      <div class="hero-grid">
        <div class="hero-stats">
          <article class="stat-card">
            <span>現状CVR</span>
            <strong>17.3%</strong>
            <small>ストア詳細ページ閲覧からDLまでの現在値。まずは訴求の認知負荷を下げる。</small>
          </article>
          <article class="stat-card">
            <span>目標CVR</span>
            <strong>25.0%</strong>
            <small>差分は +7.7pt。独自機能の明示と競合比較で検証余地が大きい。</small>
          </article>
          <article class="stat-card">
            <span>独自訴求</span>
            <strong>3本柱</strong>
            <small>AI査定 / 出費管理 / 電話0本で、比較軸を迷わせない。</small>
          </article>
          <article class="stat-card">
            <span>競合優位</span>
            <strong>8,000社</strong>
            <small>売却段階では電話1社、相場チェック段階では個人情報不要で進められる。</small>
          </article>
        </div>
