      line-height: 1.8;
      color: var(--text-gray);
    }

    .floating-tag {
      position: absolute;
      right: 18px;
      top: 112px;
      display: inline-flex;
      align-items: center;
      min-height: 38px;
      padding: 0 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      border: 2px dashed rgba(255, 155, 106, 0.42);
      box-shadow: 0 14px 26px rgba(28, 38, 99, 0.08);
      transform: rotate(3deg);
      animation: floaty 4.2s ease-in-out infinite;
    }

    .floating-tag.secondary {
      top: 98px;
      right: 12px;
      background: rgba(248, 76, 162, 0.94);
      color: var(--white);
      border-color: rgba(255, 255, 255, 0.58);
    }

    .floating-tag.bottom {
      top: auto;
      bottom: 150px;
      right: auto;
      left: 14px;
      transform: rotate(-4deg);
    }

    @keyframes floaty {
      0%,
      100% {
        transform: translateY(0) rotate(3deg);
      }
      50% {
        transform: translateY(-6px) rotate(1deg);
      }
    }

    .car-hero {
      position: relative;
      margin-top: 10px;
      padding: 18px 16px 16px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 246, 239, 0.95));
      box-shadow: 0 18px 34px rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .illustration-wrap {
      position: relative;
      width: 100%;
      height: 188px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(111, 194, 255, 0.18), rgba(255, 255, 255, 0)),
        linear-gradient(180deg, rgba(255, 240, 228, 0.95), rgba(255, 250, 245, 0.9));
      overflow: hidden;
    }

    .illustration-wrap svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .price-cloud {
      margin-top: -18px;
      margin-left: auto;
      width: min(90%, 240px);
      padding: 14px 16px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 16px 28px rgba(28, 38, 99, 0.08);
      border: 1px solid rgba(255, 216, 120, 0.26);
    }

    .price-cloud span {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      margin-bottom: 4px;
    }

    .price-cloud strong {
      display: block;
      font-size: 33px;
      line-height: 1.2;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .price-cloud small {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.6;
    }

    .chip-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 16px 0;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      min-height: 38px;
      padding: 0 14px;
      border-radius: var(--radius-chip);
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(28, 38, 99, 0.08);
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.05);
    }

    .chip.dark {
      background: var(--dark-blue);
      color: var(--white);
      border-color: transparent;
    }

    .graph-card,
    .expense-card,
    .compare-card,
    .story-card {
      margin-top: 14px;
      padding: 18px 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 18px 34px rgba(28, 38, 99, 0.08);
    }

    .card-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }

    .card-title strong {
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .card-title span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .graph-svg {
      width: 100%;
      height: 136px;
      display: block;
    }

    .graph-legend {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 10px;
    }

    .graph-legend-item {
      padding: 10px 8px;
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(247, 251, 255, 0.92), rgba(255, 248, 243, 0.92));
      text-align: center;
    }

    .graph-legend-item strong {
      display: block;
      font-size: 15px;
      color: var(--dark-blue);
    }

    .graph-legend-item span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .comfort-note {
      margin-top: 14px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255, 231, 216, 0.58);
      border: 1px dashed rgba(255, 155, 106, 0.44);
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-black);
      display: none;
    }

    .comfort-note.is-open {
      display: block;
    }

    .cta-row {
      display: flex;
      gap: 10px;
      margin-top: 16px;
    }

    .cta-button {
      flex: 1;
      min-height: 43px;
      border: none;
      border-radius: var(--radius-button);
      padding: 0 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .cta-button.primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 14px 24px rgba(77, 180, 255, 0.24);
    }

    .cta-button.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 14px 24px rgba(248, 76, 162, 0.22);
    }

    .mini-button {
      min-width: 96px;
      min-height: 38px;
      border-radius: 22px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: rgba(255, 255, 255, 0.94);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease;
    }

    .stack {
      display: grid;
      gap: 12px;
    }

    .story-card {
      background: linear-gradient(180deg, rgba(255, 248, 240, 0.96), rgba(255, 255, 255, 0.94));
    }

    .story-card p {
      margin: 0;
      font-size: 13px;
      line-height: 1.85;
      color: var(--text-gray);
    }

    .forecast-layout {
      display: grid;
      gap: 14px;
    }

    .forecast-top {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 12px;
      align-items: stretch;
    }

    .expense-card.soft {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 246, 239, 0.98));
    }

    .expense-total {
      display: flex;
      align-items: end;
      gap: 8px;
      margin-bottom: 12px;
    }

    .expense-total strong {
      font-size: 30px;
      line-height: 1.2;
      color: var(--dark-blue);
    }

    .expense-total span {
      font-size: 12px;
      color: var(--text-gray);
      padding-bottom: 4px;
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      color: var(--text-black);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .expense-bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .expense-bar span {
      position: absolute;
      inset: 0 auto 0 0;
      border-radius: inherit;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.9), rgba(255, 155, 106, 0.82));
    }

    .forecast-bubble {
      position: relative;
      padding: 18px 16px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(28, 38, 99, 0.96), rgba(38, 59, 153, 0.92));
      color: var(--white);
      overflow: hidden;
    }

    .forecast-bubble::after {
      content: "";
      position: absolute;
      right: -18px;
      top: -20px;
      width: 110px;
      height: 110px;
      border-radius: 999px;
      background: rgba(111, 194, 255, 0.22);
    }

    .forecast-bubble small {
      display: block;
      font-size: 11px;
      color: rgba(255, 255, 255, 0.72);
      margin-bottom: 6px;
    }

    .forecast-bubble strong {
      display: block;
      font-size: 30px;
      line-height: 1.2;
      letter-spacing: -0.03em;
      margin-bottom: 6px;
    }

    .forecast-bubble p {
      position: relative;
      z-index: 1;
      margin: 0;
      font-size: 12px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.82);
    }

    .range-wrap {
      margin-top: 12px;
      padding: 14px 14px 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .range-wrap label {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .range-wrap input[type="range"] {
      width: 100%;
      accent-color: var(--pink);
    }

    .range-scale {
      display: flex;
      justify-content: space-between;
      margin-top: 4px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .mini-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 12px;
    }

    .mini-stat {
      padding: 12px 10px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.92);
      text-align: center;
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .mini-stat strong {
      display: block;
      font-size: 18px;
      color: var(--dark-blue);
      line-height: 1.4;
    }

    .mini-stat span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .compare-hero {
      position: relative;
      padding: 20px 16px 16px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 246, 239, 0.96));
      box-shadow: 0 18px 34px rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .compare-hero .big-zero {
      display: flex;
      align-items: end;
      gap: 10px;
      margin: 10px 0 10px;
    }

    .compare-hero .big-zero strong {
      font-size: 72px;
      line-height: 0.92;
      color: var(--pink);
      letter-spacing: -0.05em;
    }

    .compare-hero .big-zero span {
      font-size: 20px;
      font-weight: 700;
      color: var(--dark-blue);
      padding-bottom: 8px;
    }

    .compare-hero p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .stage-toggle {
      display: flex;
      gap: 8px;
      margin-top: 16px;
    }

    .stage-button {
      flex: 1;
      min-height: 43px;
      border-radius: 22px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: rgba(255, 255, 255, 0.94);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .stage-button.is-active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: transparent;
    }

    .compare-table {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(28, 38, 99, 0.06);
      align-items: center;
    }

    .compare-row.primary {
      background: linear-gradient(90deg, rgba(255, 216, 232, 0.9), rgba(255, 255, 255, 0.98));
      border-color: rgba(248, 76, 162, 0.18);
    }

    .compare-name {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .compare-name strong {
      font-size: 14px;
      color: var(--dark-blue);
    }

    .compare-name span {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.5;
    }

    .compare-value {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 78px;
      height: 38px;
      padding: 0 14px;
      border-radius: 999px;
      background: var(--back-gray);
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .compare-row.primary .compare-value {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .compare-caption {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255, 248, 240, 0.88);
      border: 1px dashed rgba(255, 155, 106, 0.36);
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-black);
    }

    .footnote {
      max-width: 860px;
      margin: 18px auto 0;
      padding: 14px 18px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(255, 255, 255, 0.92);
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
      text-align: center;
      box-shadow: 0 14px 28px rgba(28, 38, 99, 0.06);
    }

    body.warm-mode .screen-title,
    body.warm-mode .hero h1,
    body.warm-mode .hero-summary-title {
      text-shadow: 0 6px 18px rgba(255, 155, 106, 0.12);
    }

    body.warm-mode .floating-tag,
    body.warm-mode .hero-summary-badge {
      animation-duration: 3.2s;
    }

    body.warm-mode .compare-hero .big-zero strong {
      color: #ff5f92;
    }

    @media (min-width: 980px) {
      .page {
        padding: 28px 20px 64px;
      }

      .preview-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .shot-card {
        display: block;
      }

      .tabs {
        display: none;
      }
    }

    @media (max-width: 979px) {
      .hero-summary-grid {
        grid-template-columns: 1fr;
      }

      .phone-frame {
        min-height: 744px;
      }

      .screen {
        min-height: 716px;
      }
    }

    @media (max-width: 420px) {
      .page {
        padding-inline: 10px;
      }

      .shot-card {
        padding: 12px;
      }

      .phone-frame {
        width: 100%;
        border-radius: 30px;
        padding: 14px 12px 12px;
      }

      .screen-title {
        font-size: 28px;
      }

      .floating-tag {
        right: 10px;
        top: 106px;
      }

      .forecast-top {
        grid-template-columns: 1fr;
      }

      .hero-summary-top {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="ambient one"></div>
  <div class="ambient two"></div>
  <div class="ambient three"></div>

  <main class="page">
    <header class="hero">
      <div class="eyebrow">ASO検証 / ストアPV→DL率 17.3% → 25%</div>
      <h1>不安をほどいて、<span class="underline">DLの背中を押す</span><br>ストアスクショ3枚</h1>
      <p id="heroLead">「相場だけ知りたい」「営業電話が心配」「維持費まで見たい」という迷いに、安心感のある言葉と暖色系の画面で先回りする構成です。</p>
      <div class="hero-actions">
        <button class="mode-toggle" id="moodToggle" type="button">安心コピーを強める</button>
        <button class="mode-toggle secondary" id="allViewToggle" type="button">3枚をまとめて見る</button>
      </div>
      <div class="hero-summary">
        <div class="hero-summary-top">
          <div class="hero-summary-title">今回の見せ方で先に伝える3要素</div>
          <div class="hero-summary-badge" id="heroBadge">感情訴求A案</div>
        </div>
        <div class="hero-summary-grid">
          <div class="hero-summary-item">
            <strong>AI査定</strong>
            <span>はじめてでも価格のイメージが持てる。相場と将来予測を1画面で理解。</span>
          </div>
          <div class="hero-summary-item">
            <strong>出費管理</strong>
            <span>維持費と売り時を一緒に見る。車を持つ不安を見える化でやわらげる。</span>
          </div>
          <div class="hero-summary-item">
            <strong>電話0本</strong>
            <span>相場チェック時は個人情報不要。比較検討の心理負担をストア上で先に解消。</span>
          </div>
        </div>
      </div>
    </header>

    <nav class="tabs" aria-label="スクリーン切り替え">
      <button class="tab is-active" type="button" data-shot-target="a">スクショA / AI査定</button>
      <button class="tab" type="button" data-shot-target="b">スクショB / 出費管理</button>
      <button class="tab" type="button" data-shot-target="c">スクショC / 電話0本</button>
    </nav>

    <section class="preview-grid" id="previewGrid">
      <article class="shot-card is-active" data-shot="a">
        <div class="shot-meta">
          <div class="shot-kicker">
            <span class="platform-pill">iOS向け</span>
            <span>ストアスクショA / AI査定を全面訴求</span>
          </div>
          <div class="shot-copy">迷いの入口で「大丈夫」を先に伝える</div>
        </div>
        <div class="phone-frame">
          <div class="phone-notch"></div>
          <div class="screen screen-a">
            <div class="status-row">
              <span>9:41</span>
              <span class="store-tag">個人情報なしで相場チェック</span>
            </div>

            <div class="floating-tag">最短30秒で目安価格</div>

            <h2 class="screen-title">AIがあなたの愛車を<br>やさしく査定</h2>
            <p class="screen-subtitle" id="screenACopy">「いくらで売れそう？」の不安に、いまの相場と3か月先の売り時をひと目で。まずは気軽に、電話なしで始められます。</p>

            <section class="car-hero">
              <div class="illustration-wrap" aria-hidden="true">
                <svg viewBox="0 0 320 188" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="carBody" x1="0" y1="0" x2="1" y2="1">
                      <stop offset="0%" stop-color="#F84CA2"/>
                      <stop offset="100%" stop-color="#FF9B6A"/>
                    </linearGradient>
                    <linearGradient id="hill" x1="0" y1="0" x2="1" y2="1">
                      <stop offset="0%" stop-color="#BEE8FF"/>
                      <stop offset="100%" stop-color="#EAF8FF"/>
                    </linearGradient>
                  </defs>
                  <ellipse cx="75" cy="26" rx="22" ry="12" fill="#FFD878" opacity="0.7"/>
                  <ellipse cx="245" cy="34" rx="18" ry="10" fill="#FFD8E8" opacity="0.9"/>
                  <path d="M10 152C44 136 74 132 118 136C161 140 186 154 236 151C274 149 296 140 320 130V188H0V163C6 160 8 156 10 152Z" fill="url(#hill)"/>
                  <path d="M78 101C82 75 100 58 130 58H184C210 58 228 71 237 94L249 99C259 103 266 112 266 123V126C266 132 261 137 255 137H250C248 150 237 160 223 160C210 160 198 150 196 137H124C122 150 111 160 97 160C84 160 72 150 70 137H60C52 137 46 131 46 123V118C46 110 52 104 60 102L78 101Z" fill="url(#carBody)"/>
                  <path d="M102 70H140C151 70 160 74 166 82L174 92H90C92 80 96 74 102 70Z" fill="#FFF6FB"/>
                  <path d="M173 70H184C198 70 208 76 218 92H184L173 70Z" fill="#FFF6FB"/>
                  <circle cx="97" cy="136" r="18" fill="#22306F"/>
                  <circle cx="97" cy="136" r="9" fill="#FFFFFF"/>
                  <circle cx="223" cy="136" r="18" fill="#22306F"/>
                  <circle cx="223" cy="136" r="9" fill="#FFFFFF"/>
                  <path d="M237 100H251C258 100 264 106 264 113V118H240L237 100Z" fill="#FFC0A5"/>
                  <path d="M56 111H71V118H56C53 118 50 116 50 113C50 111 53 111 56 111Z" fill="#FFC0A5"/>
                  <path d="M265 44C272 39 282 41 287 48C282 54 272 56 265 52C260 49 260 45 265 44Z" fill="#F84CA2"/>
                  <path d="M280 36C286 32 294 34 298 41C294 45 286 46 281 43C277 41 276 38 280 36Z" fill="#FFD878"/>
                  <path d="M60 62C67 56 78 57 84 64C78 71 68 72 61 67C56 64 56 60 60 62Z" fill="#FFD8E8"/>
                </svg>
              </div>

              <div class="price-cloud">
                <span>いまの目安価格</span>
                <strong>184万円</strong>
                <small>トヨタ プリウス S 2019年 / 48,200km</small>
              </div>
            </section>

            <div class="chip-row">
              <div class="chip dark">査定スタートまで個人情報不要</div>
              <div class="chip">3か月後予測 179万円</div>
              <div class="chip">8,000社の相場データ反映</div>
            </div>

            <section class="graph-card">
              <div class="card-title">
                <strong>いま売る？待つ？をやさしく可視化</strong>
                <span>AI予測グラフ</span>
              </div>
              <svg class="graph-svg" viewBox="0 0 320 136" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                  <linearGradient id="lineA" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#F84CA2"/>
                    <stop offset="100%" stop-color="#4DB4FF"/>
