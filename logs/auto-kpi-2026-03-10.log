            <div class="device ios">
              <div class="device-screen">
                <div class="notch" aria-hidden="true"></div>
                <div class="status-bar">
                  <span>9:41</span>
                  <span class="status-icons">
                    <i class="status-dot"></i>
                    <i class="status-dot"></i>
                    <i class="status-dot"></i>
                  </span>
                </div>
