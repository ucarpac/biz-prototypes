                      </div>
                    </div>

                    <div class="switcher" aria-label="価格モード切替">
                      <button class="active" type="button" data-mode="now">いまの相場</button>
                      <button type="button" data-mode="future">3か月後予測</button>
                    </div>

                    <div class="car-card">
