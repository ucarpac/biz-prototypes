  <script>
    (function () {
      const tabs = Array.from(document.querySelectorAll(".tab"));
      const screens = Array.from(document.querySelectorAll(".screen"));
      let activeIndex = 0;
      let autoRotate = null;

      function activateTab(index) {
        activeIndex = index;
        const target = tabs[index].dataset.target;

        tabs.forEach((tab, i) => {
          const selected = i === index;
          tab.classList.toggle("active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        screens.forEach((screen) => {
          screen.classList.toggle("active", screen.id === target);
        });
      }

      function startRotation() {
        stopRotation();
        autoRotate = window.setInterval(function () {
          activateTab((activeIndex + 1) % tabs.length);
        }, 5200);
      }

      function stopRotation() {
        if (autoRotate) {
          clearInterval(autoRotate);
          autoRotate = null;
        }
      }

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", function () {
          activateTab(index);
          startRotation();
        });
      });

      document.querySelectorAll(".detail-toggle").forEach((button) => {
        button.addEventListener("click", function () {
          const panel = document.getElementById(button.dataset.toggle);
          panel.classList.toggle("show");
          button.textContent = panel.classList.contains("show")
            ? "訴求ポイントを閉じる"
            : "この安心感の訴求ポイントを見る";
        });
      });

      const chartData = {
        "3m": {
          d: "M10,64 C58,56 88,42 126,44 C162,45 194,26 234,22 C270,18 292,22 310,14",
          axis: ["今月", "4月", "5月", "6月"],
          high: "151.2万円",
          timing: "今月が候補"
        },
        "6m": {
          d: "M10,66 C54,61 86,54 126,47 C158,41 196,32 236,34 C272,36 292,44 310,52",
          axis: ["今月", "5月", "7月", "9月"],
          high: "149.3万円",
          timing: "初夏までに比較"
        }
      };

      const forecastPath = document.getElementById("forecast-path");
      const forecastShadow = document.getElementById("forecast-shadow");
      const forecastAxis = document.getElementById("forecast-axis");
      const priceHigh = document.getElementById("price-high");
      const sellTiming = document.getElementById("sell-timing");
      const chartButtons = Array.from(document.querySelectorAll("[data-chart-switcher] button"));

      function renderChart(mode) {
        const data = chartData[mode];
        forecastPath.setAttribute("d", data.d);
        forecastShadow.setAttribute("d", data.d);
        forecastPath.style.animation = "none";
        void forecastPath.offsetWidth;
        forecastPath.style.animation = "drawLine 1.2s ease forwards";
        forecastAxis.innerHTML = data.axis.map(function (label) {
          return "<span>" + label + "</span>";
        }).join("");
        priceHigh.textContent = data.high;
        sellTiming.textContent = data.timing;

        chartButtons.forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.mode === mode);
        });
      }

      chartButtons.forEach((button) => {
        button.addEventListener("click", function () {
          renderChart(button.dataset.mode);
        });
      });

      const stageButtons = Array.from(document.querySelectorAll(".stage-toggle button"));
      const compareBadge = document.getElementById("compare-badge");
      const brandCount = document.querySelector("[data-brand-count]");
      const brandNote = document.querySelector("[data-brand-note]");

      function renderStage(stage) {
        stageButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.stage === stage);
        });

        if (stage === "sell") {
          compareBadge.textContent = "売却相談に進んだ後も、基本は1社とのやりとり";
          brandCount.textContent = "1社";
          brandNote.textContent = "申込後の連絡負担を最小化";
        } else {
          compareBadge.textContent = "個人情報なしで確認できるから、電話は0本";
          brandCount.textContent = "0本";
          brandNote.textContent = "AI査定は個人情報不要";
        }
      }

      stageButtons.forEach((button) => {
        button.addEventListener("click", function () {
          renderStage(button.dataset.stage);
        });
      });

      renderChart("3m");
      renderStage("check");
      activateTab(0);
      startRotation();

      document.addEventListener("visibilitychange", function () {
        if (document.hidden) {
          stopRotation();
        } else {
          startRotation();
        }
      });
    })();
  </script>
</body>
</html>
