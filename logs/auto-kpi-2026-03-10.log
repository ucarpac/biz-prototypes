                          <defs>
                            <linearGradient id="lineA" x1="0%" y1="0%" x2="100%" y2="0%">
                              <stop offset="0%" stop-color="#F84CA2"></stop>
                              <stop offset="100%" stop-color="#1ddcff"></stop>
                            </linearGradient>
                          </defs>
                          <path d="M10,76 C60,44 88,42 120,62 S190,108 228,120 S270,126 292,138" fill="none" stroke="url(#lineA)" stroke-width="6" stroke-linecap="round"></path>
                          <circle cx="10" cy="76" r="7" fill="#F84CA2"></circle>
                          <circle cx="120" cy="62" r="7" fill="#ff9cc7"></circle>
