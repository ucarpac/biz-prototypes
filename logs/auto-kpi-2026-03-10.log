    function setActiveScreen(index) {
      activeScreen = index;
      tabs.forEach((tab, i) => tab.classList.toggle("active", i === index));
      phones.forEach((phone, i) => {
        phone.classList.toggle("active", i === index);
        if (i === index) {
          phone.classList.remove("pulse");
          void phone.offsetWidth;
          phone.classList.add("pulse");
        }
      });
    }

    function cycleScreens() {
      if (!autoplay) return;
      activeScreen = (activeScreen + 1) % phones.length;
      setActiveScreen(activeScreen);
    }

    function startAutoplay() {
      clearInterval(timer);
      timer = setInterval(cycleScreens, 3800);
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        autoplay = false;
        autoplayToggle.classList.remove("active");
        autoplayToggle.textContent = "自動切替 OFF";
        setActiveScreen(Number(tab.dataset.target));
