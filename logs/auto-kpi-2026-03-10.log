      inset: 0;
    }

    .graph-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .expense-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.86);
      transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
      cursor: pointer;
    }

    .expense-item.active {
      transform: translateX(4px);
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.08), rgba(255,255,255,0.96));
      box-shadow: 0 10px 24px rgba(17, 27, 78, 0.08);
    }

    .expense-item strong {
      display: block;
      font-size: 13px;
      color: var(--dark-blue);
    }

    .expense-item span {
      display: block;
      margin-top: 2px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .expense-item b {
      font-size: 16px;
      color: var(--text-black);
    }

    .ring-row {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 14px;
      align-items: center;
      margin-top: 16px;
    }

    .ring {
      position: relative;
      width: 120px;
      height: 120px;
      border-radius: 999px;
      background: conic-gradient(var(--pink) 0 38%, #1ddcff 38% 70%, #ffd378 70% 100%);
    }

    .ring::before {
      content: "月平均\A 29,600円";
      white-space: pre;
      position: absolute;
      inset: 14px;
      display: grid;
      place-items: center;
      border-radius: inherit;
      background: #fff;
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
      color: var(--dark-blue);
      text-align: center;
    }

    .ring-copy {
      font-size: 13px;
      line-height: 1.75;
      color: var(--text-gray);
    }

    .compare-card {
      margin-top: 16px;
      padding: 16px;
      border-radius: 22px;
      background: #fff;
      box-shadow: 0 14px 30px rgba(17, 27, 78, 0.08);
    }

    .compare-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 10px;
    }

    .compare-head strong {
      font-size: 30px;
      line-height: 1;
      color: var(--pink-deep);
      letter-spacing: -0.06em;
    }

    .compare-table {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 8px;
      align-items: stretch;
    }

    .compare-row > div {
      padding: 12px 10px;
      border-radius: 16px;
      font-size: 12px;
      line-height: 1.55;
      background: #f8fafc;
    }

    .compare-row .label {
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(28, 38, 99, 0.06);
    }

    .compare-row .mine {
      font-weight: 800;
      color: var(--dark-blue);
      background: linear-gradient(180deg, rgba(255, 216, 232, 0.55), rgba(255,255,255,0.96));
    }

    .compare-row .other {
      color: var(--text-gray);
    }

    .call-meter {
      margin-top: 16px;
      padding: 16px;
      border-radius: 22px;
      background: linear-gradient(180deg, #fff7fb, #fff);
      border: 1px solid rgba(248, 76, 162, 0.12);
    }

    .call-bar {
      position: relative;
      height: 16px;
      margin-top: 12px;
      border-radius: 999px;
      background: #edf1f4;
      overflow: hidden;
    }

    .call-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0%;
      border-radius: inherit;
      background: linear-gradient(90deg, #ff8abf, var(--pink));
      transition: width 500ms ease;
    }

    .call-scale {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .footer-note {
      margin-top: 18px;
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
      text-align: center;
    }

    .sparkles {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .sparkles i {
      position: absolute;
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.7);
      animation: float 4.2s linear infinite;
    }

    .sparkles i:nth-child(1) { top: 12%; left: 16%; animation-delay: 0s; }
    .sparkles i:nth-child(2) { top: 22%; right: 12%; animation-delay: 1.2s; }
    .sparkles i:nth-child(3) { bottom: 26%; left: 8%; animation-delay: 2.1s; }
    .sparkles i:nth-child(4) { bottom: 18%; right: 16%; animation-delay: 2.8s; }

    @keyframes float {
      0% { transform: translateY(10px) scale(0.6); opacity: 0; }
      25% { opacity: 1; }
      75% { opacity: 1; }
      100% { transform: translateY(-16px) scale(1.2); opacity: 0; }
    }

    @media (min-width: 900px) {
      .page {
        padding: 28px 20px 56px;
      }

      .hero {
        padding: 30px 28px 28px;
      }

      .layout {
        grid-template-columns: minmax(360px, 390px) minmax(0, 1fr);
        gap: 24px;
      }

      .layout.reverse {
        grid-template-columns: minmax(0, 1fr) minmax(360px, 390px);
      }

      .layout.reverse .phone-wrap {
        order: 2;
      }

      .layout.reverse .info-panel {
        order: 1;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="hero">
      <div class="sparkles" aria-hidden="true">
        <i></i>
        <i></i>
        <i></i>
        <i></i>
      </div>
      <div class="eyebrow"><span>ほっ</span> 不安な売却前に、まずは安心して相場を見る</div>
      <h1>ストアPVからDLへ。<br />やさしく背中を押す3枚。</h1>
      <p class="lead">
        UcarPAC Appの強みであるAI査定、出費管理、将来予測、そして「相場チェックまで電話0本」の安心感を、
        ストアスクリーンショット想定で一画面に統合しました。タップで切り替え、動きと状態変化を確認できます。
      </p>
      <div class="hero-actions">
        <button class="pill primary" type="button" data-jump="screen-a">スクショAを見る</button>
        <button class="pill" type="button" data-jump="screen-b">スクショBを見る</button>
        <button class="pill" type="button" data-jump="screen-c">スクショCを見る</button>
