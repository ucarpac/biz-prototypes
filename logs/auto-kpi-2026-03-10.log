  <script>
    const tabs = document.querySelectorAll('.tab');
    const screens = document.querySelectorAll('.screen');
    const jumpButtons = document.querySelectorAll('[data-jump]');
    const switchButtons = document.querySelectorAll('.switcher button');
    const heroPrice = document.getElementById('hero-price');
    const heroDelta = document.getElementById('hero-delta');
    const forecastPrice = document.getElementById('forecast-price');
    const forecastTag = document.getElementById('forecast-tag');
    const expenseItems = document.querySelectorAll('.expense-item');
    const expenseNote = document.getElementById('expense-note');
    const callFill = document.getElementById('call-fill');
    const stressDemo = document.getElementById('stress-demo');

    function activateScreen(targetId) {
      tabs.forEach(tab => {
        const active = tab.dataset.target === targetId;
        tab.classList.toggle('active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      screens.forEach(screen => {
        screen.classList.toggle('active', screen.id === targetId);
      });

      if (targetId === 'screen-c') {
        runCallMeter();
      }
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => activateScreen(tab.dataset.target));
    });

    jumpButtons.forEach(button => {
      button.addEventListener('click', () => activateScreen(button.dataset.jump));
    });

    function setMode(mode) {
      const current = mode === 'now';
      heroPrice.innerHTML = current ? '187<small>万円</small>' : '191<small>万円</small>';
      heroDelta.textContent = current ? '3か月後 +4万円予測' : '夏需要で上振れ見込み';
      switchButtons.forEach(button => {
        button.classList.toggle('active', button.dataset.mode === mode);
      });
    }

    switchButtons.forEach(button => {
      button.addEventListener('click', () => setMode(button.dataset.mode));
    });

    document.querySelectorAll('[data-mode-toggle]').forEach(button => {
      button.addEventListener('click', () => setMode('future'));
    });

    expenseItems.forEach(item => {
      item.addEventListener('click', () => {
        expenseItems.forEach(entry => entry.classList.remove('active'));
        item.classList.add('active');
        expenseNote.textContent = item.dataset.note;
      });
    });

    const forecastSamples = [
      { price: '183<small>万円</small>', tag: '半年後 -6万円予測' },
      { price: '186<small>万円</small>', tag: '春需要で +2万円予測' },
      { price: '179<small>万円</small>', tag: '走行距離増で -10万円予測' }
    ];

    document.querySelectorAll('[data-randomize="forecast"]').forEach(button => {
      button.addEventListener('click', () => {
        const sample = forecastSamples[Math.floor(Math.random() * forecastSamples.length)];
        forecastPrice.innerHTML = sample.price;
        forecastTag.textContent = sample.tag;
      });
    });

    function runCallMeter() {
      callFill.style.width = '0%';
      requestAnimationFrame(() => {
        setTimeout(() => {
          callFill.style.width = '100%';
        }, 60);
      });
    }

    if (stressDemo) {
      stressDemo.addEventListener('click', runCallMeter);
    }

    let autoIndex = 0;
    const order = ['screen-a', 'screen-b', 'screen-c'];
    setInterval(() => {
      const visible = document.querySelector('.screen.active');
      if (!visible) return;
      autoIndex = (order.indexOf(visible.id) + 1) % order.length;
      activateScreen(order[autoIndex]);
    }, 9000);
  </script>
</body>
