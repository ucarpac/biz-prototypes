      display: block;
      font-size: 24px;
      line-height: 1.1;
      font-family: var(--font-number);
      margin-top: 4px;
    }

    .table {
      margin-top: 16px;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: var(--white);
    }

    .row {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr 0.9fr;
      align-items: center;
      font-size: 12px;
    }

    .row > div {
      padding: 12px 10px;
      border-bottom: 1px solid var(--ruled-line);
    }

    .row.header {
      background: rgba(9, 19, 85, 0.05);
      font-weight: 800;
      color: var(--dark-blue);
    }

    .row:last-child > div {
      border-bottom: 0;
    }

    .ok {
      color: #12845f;
      font-weight: 900;
    }

    .no {
      color: var(--error);
      font-weight: 900;
    }

    .neutral {
      color: #c27a00;
      font-weight: 900;
    }

    .insight {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .insight-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.04);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
    }

    .insight-item small {
      color: var(--text-gray);
      font-weight: 700;
    }

    .floating-kpi {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.88));
      box-shadow: 0 14px 26px rgba(28, 38, 99, 0.08);
      display: flex;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
    }

    .floating-kpi strong {
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 1.5;
    }

    .floating-kpi span {
      font-family: var(--font-number);
      color: var(--pink);
      font-size: 26px;
      line-height: 1;
    }

    .footer-note {
      margin-top: 20px;
      text-align: center;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .pulse {
      animation: pulse 1.2s ease;
    }

    @keyframes fillRail {
      from {
        transform: scaleX(0);
      }
      to {
        transform: scaleX(1);
      }
    }

    @keyframes pulse {
      0% {
        transform: scale(0.985);
      }
      50% {
        transform: scale(1.015);
      }
      100% {
        transform: scale(1);
      }
    }

    @media (min-width: 760px) {
      body {
        padding: 26px 20px 60px;
      }

      .hero {
        padding: 26px 24px 22px;
      }

      .kpi-row {
        grid-template-columns: 1.2fr 0.8fr;
      }

      .controls {
        grid-template-columns: 1fr auto;
        align-items: center;
      }

      .screens {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (min-width: 1080px) {
      .hero {
        padding: 28px;
      }

      h1 {
        font-size: 40px;
      }

      .lead {
        font-size: 14px;
      }
    }
  </style>
