    .future-graph svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .future-legend {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .future-legend .rise {
      color: #009a58;
    }

    .cta {
      width: 100%;
      min-height: 52px;
      margin-top: 14px;
      border: 0;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.02em;
      cursor: pointer;
      box-shadow: 0 14px 22px rgba(29,220,255,0.24);
      transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
    }

    .cta.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 14px 22px rgba(248,76,162,0.22);
    }

    .cta:hover,
    .cta:active {
      transform: translateY(-1px) scale(1.01);
      filter: saturate(1.04);
    }

    .cta:focus-visible,
    .chip:focus-visible,
    .arrow:focus-visible {
      outline: 3px solid rgba(64,153,255,0.35);
      outline-offset: 2px;
    }

    .micro-note {
      margin-top: 10px;
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .swipe-hint {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.9);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      box-shadow: 0 10px 18px rgba(28,38,99,0.08);
    }

    .swipe-hint .dots {
      display: inline-flex;
      gap: 4px;
    }

    .swipe-hint .dots i {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--pink);
      animation: drift 1.6s infinite;
    }

    .swipe-hint .dots i:nth-child(2) { animation-delay: 0.2s; }
    .swipe-hint .dots i:nth-child(3) { animation-delay: 0.4s; }

    .footer-panel {
      display: grid;
      gap: 14px;
      border-radius: 24px;
      padding: 16px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(28,38,99,0.06);
      box-shadow: 0 16px 34px rgba(28,38,99,0.08);
    }

    .footer-panel h2 {
      margin: 0;
      font-size: 20px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .footer-panel p {
      margin: 0;
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .mini-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .mini-step {
      padding: 12px;
      border-radius: 18px;
      background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%);
      border: 1px solid rgba(28,38,99,0.06);
      text-align: center;
    }

    .mini-step b {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      margin-bottom: 8px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 14px;
    }

    .mini-step strong {
      display: block;
      font-size: 12px;
      color: var(--dark-blue);
      line-height: 1.5;
    }

    .mini-step span {
      display: block;
      margin-top: 5px;
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .controls {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      margin-top: 4px;
    }

    .arrow {
      width: 46px;
      height: 46px;
      border: 0;
      border-radius: 50%;
      background: var(--white);
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 900;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(28,38,99,0.08);
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .arrow:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 24px rgba(28,38,99,0.12);
    }

    .dots-nav {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(28,38,99,0.18);
      transition: transform 180ms ease, background 180ms ease, width 180ms ease;
    }

    .dot.is-active {
      width: 28px;
      border-radius: 999px;
      background: linear-gradient(90deg, #f84ca2, #1ddcff);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 14px;
    }

    .vs-card {
      border-radius: 18px;
      padding: 14px;
      min-height: 132px;
      background: linear-gradient(180deg, #fff 0%, #f7f9ff 100%);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .vs-card h4 {
      margin: 0;
      font-size: 14px;
      color: var(--dark-blue);
      line-height: 1.5;
    }

    .vs-number {
      margin-top: 14px;
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 1;
      color: var(--dark-blue);
    }

    .vs-number.hot {
      color: var(--pink);
    }

    .stat-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 14px;
    }

    .stat-card {
      padding: 14px 12px;
      border-radius: 18px;
      background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
      border: 1px solid rgba(28,38,99,0.06);
      text-align: center;
    }

    .versus-line {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 10px;
      margin-top: 14px;
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(248,76,162,0.08), rgba(29,220,255,0.08));
      border: 1px solid rgba(248,76,162,0.12);
    }

    .versus-icon {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #1c2663, #f84ca2);
      color: var(--white);
      font-size: 24px;
      font-weight: 900;
    }

    .bullet-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .bullet {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      align-items: start;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.96);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .bullet i {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--dark-blue);
      color: var(--white);
      font-style: normal;
      font-size: 12px;
      font-weight: 800;
    }

    .screen-footer {
      margin-top: 14px;
      display: flex;
      justify-content: center;
      gap: 8px;
    }

    .screen-footer span {
      width: 46px;
      height: 5px;
      border-radius: 999px;
      background: rgba(28,38,99,0.12);
    }

    .screen-footer span.active {
      background: linear-gradient(90deg, #1ddcff, #f84ca2);
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.18); opacity: 0.6; }
    }

    @keyframes drift {
      0%, 100% { transform: translateX(0); opacity: 0.4; }
      50% { transform: translateX(4px); opacity: 1; }
    }

    @keyframes growBar {
      from { transform: scaleX(0.12); }
      to { transform: scaleX(1); }
    }

    @media (min-width: 960px) {
      body {
        padding: 32px 22px 54px;
      }

      .stage {
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 20px;
      }

      .footer-panel {
        position: sticky;
        top: 24px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation: none !important;
        transition: none !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <section class="hero">
