      <button class="tab" type="button" role="tab" aria-selected="false" data-target="screen-b">B. 出費管理+将来予測</button>
      <button class="tab" type="button" role="tab" aria-selected="false" data-target="screen-c">C. 競合比較と電話0本</button>
    </div>

    <section class="screens">
      <article class="screen active" id="screen-a">
        <div class="layout">
