                  <span class="status-icons">
                    <i class="status-dot"></i>
                    <i class="status-dot"></i>
                    <i class="status-dot"></i>
                  </span>
                </div>
                <div class="shot">
                  <div class="warm-card">
                    <div class="shot-top">
                      <div>
