      document.getElementById("screenCStress").textContent = values.stress;
      document.getElementById("screenCInsight").textContent = values.insight;
    }

    document.querySelectorAll("[data-c]").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll("[data-c]").forEach((b) => b.classList.remove("active"));
        button.classList.add("active");
        updateCompare(button.dataset.c);
      });
    });

    document.getElementById("screenAButton").addEventListener("click", () => {
      document.getElementById("screenARecommend").textContent = "入力開始: 車種・年式だけで相場チェックを開始";
      setActiveScreen(0);
    });

    document.getElementById("screenBButton").addEventListener("click", () => {
      document.querySelector('[data-b="year"]').click();
      setActiveScreen(1);
    });

    document.getElementById("screenCButton").addEventListener("click", () => {
      document.querySelector('[data-c="bulk"]').click();
      setActiveScreen(2);
    });

    setActiveScreen(0);
    updateBars("month");
    updateCompare("bulk");
    startAutoplay();
