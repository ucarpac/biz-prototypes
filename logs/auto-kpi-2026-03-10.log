      font-size: 24px;
      line-height: 1.2;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .soft-card span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-black);
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .expense-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.05);
    }

    .expense-label {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 800;
      color: var(--text-black);
    }

    .expense-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
    }

    .expense-value {
      font-size: 14px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-wrap {
      display: grid;
      gap: 14px;
      margin-top: 10px;
    }

    .compare-top {
      display: grid;
      gap: 10px;
    }

    .compare-card {
      padding: 16px;
    }

    .compare-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(248, 76, 162, 0.12);
      color: var(--pink);
      font-size: 11px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .call-grid {
      display: grid;
      gap: 10px;
    }

    .call-row {
      display: grid;
      grid-template-columns: 1.2fr 0.9fr 1fr;
      align-items: center;
      gap: 10px;
      padding: 12px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .call-row.is-brand {
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.12), rgba(248, 76, 162, 0.12));
      border: 1px solid rgba(77, 180, 255, 0.22);
    }

    .call-name {
      font-size: 13px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .call-count {
      font-size: 26px;
      line-height: 1.1;
      font-weight: 900;
      color: var(--dark-blue);
      text-align: center;
    }

    .call-count.hot {
      color: var(--pink);
    }

    .call-note {
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
      text-align: right;
      font-weight: 700;
    }

    .stage-toggle {
      display: flex;
      gap: 8px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .stage-toggle button {
      appearance: none;
      border: 0;
      min-height: 43px;
      padding: 10px 16px;
      border-radius: 22px;
      background: #fff;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 900;
      cursor: pointer;
      box-shadow: 0 10px 18px rgba(28, 38, 99, 0.08);
      transition: 0.2s ease;
    }

    .stage-toggle button.active {
      background: var(--pink);
      color: #fff;
    }

    .caption {
      max-width: 375px;
      padding: 14px 16px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-soft);
      border: 1px solid rgba(255, 255, 255, 0.85);
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-black);
    }

    .caption strong {
      color: var(--dark-blue);
    }

    .sparkle {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      opacity: 0.4;
      filter: blur(2px);
      animation: floatY 5s ease-in-out infinite;
    }

    .sparkle.s1 {
      top: 96px;
      left: 24px;
      width: 18px;
      height: 18px;
      background: rgba(255, 158, 103, 0.7);
    }

    .sparkle.s2 {
      top: 152px;
      right: 30px;
      width: 12px;
      height: 12px;
      background: rgba(111, 194, 255, 0.8);
      animation-delay: 1s;
    }

    .sparkle.s3 {
      bottom: 120px;
      left: 28px;
      width: 16px;
      height: 16px;
      background: rgba(248, 76, 162, 0.35);
      animation-delay: 1.8s;
    }

    .heart {
      position: absolute;
      right: 26px;
      bottom: 164px;
      width: 18px;
      height: 18px;
      background: rgba(248, 76, 162, 0.22);
      transform: rotate(45deg);
      border-radius: 4px;
      animation: floatY 4.2s ease-in-out infinite;
    }

    .heart::before,
    .heart::after {
      content: "";
      position: absolute;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: rgba(248, 76, 162, 0.22);
    }

    .heart::before {
      left: -8px;
      top: 0;
    }

    .heart::after {
      left: 0;
      top: -8px;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes floatY {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    @keyframes pulse {
      0%,
      100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.08);
      }
    }

    @media (min-width: 880px) {
      body {
        padding: 28px 24px 56px;
      }

      h1 {
        font-size: 40px;
      }

      .stage {
        gap: 26px;
      }

      .screen {
        grid-template-columns: 1fr auto;
        align-items: center;
        justify-content: center;
        gap: 26px;
      }

      .caption {
        max-width: 420px;
      }
    }
  </style>
</head>
