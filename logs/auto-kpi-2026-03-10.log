  <script>
    (function () {
      const carousel = document.getElementById("carousel");
      const chips = Array.from(document.querySelectorAll("#modeChips .chip"));
      const dots = Array.from(document.querySelectorAll("#dotsNav .dot"));
      const progressBar = document.getElementById("progressBar");
      const progressTitle = document.getElementById("progressTitle");
      const progressCount = document.getElementById("progressCount");
      const sideDescription = document.getElementById("sideDescription");
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const swipeArea = document.getElementById("swipeArea");
      const aiMessage = document.getElementById("aiMessage");
      const futureMessage = document.getElementById("futureMessage");
      const compareMessage = document.getElementById("compareMessage");
      const total = 3;

      const descriptions = [
        "Aは「個人情報なし」「最短20秒」「AI査定価格」の3点を上から順に視認させ、DL理由を即決させる構成です。",
        "Bは資産管理アプリに近い視覚言語で、価格変動と維持費を同時に見せ、継続利用のイメージまで作ります。",
        "Cは比較不安を先回りし、電話ストレスを0本と明言して、競合検討中ユーザーの離脱を抑える訴求です。"
      ];

      const titles = [
        "現在の検証画面: スクショA",
        "現在の検証画面: スクショB",
        "現在の検証画面: スクショC"
      ];

      let index = 0;
      let startX = 0;
      let currentX = 0;
      let dragging = false;

      function render() {
        carousel.style.transform = "translateX(" + (-index * 100) + "%)";
        progressBar.style.width = (((index + 1) / total) * 100) + "%";
        progressTitle.textContent = titles[index];
        progressCount.textContent = (index + 1) + " / " + total;
        sideDescription.textContent = descriptions[index];

        chips.forEach(function (chip, i) {
          chip.classList.toggle("is-active", i === index);
        });

        dots.forEach(function (dot, i) {
          dot.classList.toggle("is-active", i === index);
        });
      }

      function go(nextIndex) {
        index = (nextIndex + total) % total;
        render();
      }

      chips.forEach(function (chip) {
        chip.addEventListener("click", function () {
          go(Number(chip.dataset.index));
        });
      });

      prevBtn.addEventListener("click", function () {
        go(index - 1);
      });

      nextBtn.addEventListener("click", function () {
        go(index + 1);
      });

      dots.forEach(function (dot, i) {
        dot.addEventListener("click", function () {
          go(i);
        });
      });

      swipeArea.addEventListener("pointerdown", function (event) {
        dragging = true;
        startX = event.clientX;
        currentX = event.clientX;
      });

      swipeArea.addEventListener("pointermove", function (event) {
        if (!dragging) return;
        currentX = event.clientX;
      });

      function endSwipe() {
        if (!dragging) return;
        const delta = currentX - startX;
        dragging = false;
        if (Math.abs(delta) > 50) {
          if (delta < 0) go(index + 1);
          else go(index - 1);
        }
      }

      swipeArea.addEventListener("pointerup", endSwipe);
      swipeArea.addEventListener("pointercancel", endSwipe);
      swipeArea.addEventListener("pointerleave", endSwipe);

      document.querySelector('[data-cta="ai"]').addEventListener("click", function () {
        aiMessage.textContent = "装備を2つ追加: AI査定レンジが 412万円 → 418万円 に更新";
      });

      document.querySelector('[data-cta="future"]').addEventListener("click", function () {
        futureMessage.textContent = "過去3か月の出費を反映: 売却推奨タイミングが 6か月以内 → 4か月以内 に更新";
      });

      document.querySelector('[data-cta="compare"]').addEventListener("click", function () {
        compareMessage.textContent = "訴求切替: 「電話0本」から「まずは相場だけ」にコピーを調整しました";
      });

      render();
    }());
  </script>
</body>
