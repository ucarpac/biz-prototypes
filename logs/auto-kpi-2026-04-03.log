    function formatYen(value) {
      return value.toLocaleString("ja-JP") + "円";
    }

    function formatMan(value) {
      return (value / 10000).toFixed(1).replace(/\.0$/, "") + "万";
    }

    function makePoints(values, width, height, paddingX, paddingY) {
      const min = Math.min(...values) * 0.96;
      const max = Math.max(...values) * 1.02;
      return values.map((value, index) => {
        const x = paddingX + index * ((width - paddingX * 2) / (values.length - 1));
        const y = height - paddingY - ((value - min) / (max - min || 1)) * (height - paddingY * 2);
        return { x, y };
      });
    }

    function linePath(points) {
      return points.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`).join(" ");
    }

    function areaPath(points, width, height, paddingX, paddingY) {
      const start = points[0];
      const end = points[points.length - 1];
      return `${linePath(points)} L ${end.x} ${height - paddingY} L ${start.x} ${height - paddingY} Z`;
    }

    function renderGraph(areaEl, lineEl, dotEls, values, width, height, paddingX, paddingY) {
      const points = makePoints(values, width, height, paddingX, paddingY);
      areaEl.setAttribute("d", areaPath(points, width, height, paddingX, paddingY));
      lineEl.setAttribute("d", linePath(points));
      dotEls.forEach((dot, index) => {
        dot.setAttribute("cx", points[index].x);
        dot.setAttribute("cy", points[index].y);
      });
      lineEl.style.animation = "none";
      requestAnimationFrame(() => {
        lineEl.style.animation = "";
      });
    }

