      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .car-info strong {
      display: block;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .car-info span {
      display: block;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .price-orb {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(180deg, #ffffff, #eef8ff);
      display: grid;
      place-items: center;
      box-shadow: inset 0 0 0 8px rgba(29, 220, 255, 0.18), 0 14px 30px rgba(28, 38, 99, 0.12);
      animation: bob 3.2s ease-in-out infinite;
    }

    .price-orb strong {
      display: block;
      font-family: var(--font-number);
      font-size: 28px;
      line-height: 1;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
      text-align: center;
    }

    .price-orb span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      font-weight: 800;
      color: var(--text-gray);
      text-align: center;
    }

    .chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .chip {
      min-height: 43px;
      padding: 0 14px;
      border-radius: var(--radius-chip);
      background: rgba(255, 255, 255, 0.92);
      color: var(--text-black);
      border: 1px solid rgba(28, 38, 99, 0.08);
      font-size: 13px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .chip.active {
      color: var(--white);
      background: var(--gradient-night);
      border-color: transparent;
    }

    .step-board {
      display: grid;
      gap: 10px;
    }

    .step-item {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(9, 19, 85, 0.04);
      transition: transform var(--transition), background var(--transition), opacity var(--transition);
      opacity: 0.55;
    }

    .step-item.active {
      background: rgba(29, 220, 255, 0.12);
      opacity: 1;
      transform: translateX(2px);
    }

    .step-item.done {
      background: rgba(248, 76, 162, 0.12);
      opacity: 1;
    }

    .step-index {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.88);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
    }

    .step-copy strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .step-copy span {
      display: block;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .step-state {
      font-size: 11px;
      font-weight: 800;
      color: var(--text-gray);
    }

    .progress-block {
      position: relative;
      z-index: 1;
      padding: 16px;
      border-radius: 22px;
      background: var(--gradient-night);
      color: var(--white);
      box-shadow: var(--shadow-medium);
      display: grid;
      gap: 10px;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .progress-head strong {
      font-size: 14px;
      line-height: 1.5;
      font-weight: 800;
    }

    .progress-head span {
      font-size: 11px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.72);
    }

    .progress-bar {
      height: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      overflow: hidden;
    }

    .progress-bar > span {
      display: block;
      height: 100%;
      width: 33%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width var(--transition);
    }

    .cta-panel {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
    }

    .primary-button {
      min-height: 52px;
      padding: 0 18px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 900;
      box-shadow: 0 14px 30px rgba(64, 191, 255, 0.30);
    }

    .sub-note {
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
      text-align: center;
    }

    .aside {
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .insight,
    .score-card,
    .mini-panel {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
    }

    .insight strong,
    .score-card strong,
    .mini-panel strong {
      display: block;
      font-size: 15px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .insight p,
    .score-card p,
    .mini-panel p {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .score-grid {
      margin-top: 12px;
      display: grid;
      gap: 10px;
    }

    .score-line {
      display: grid;
      grid-template-columns: 68px minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .score-line span:last-child {
      color: var(--dark-blue);
      font-weight: 900;
    }

    .bar {
      height: 8px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(28, 38, 99, 0.08);
    }

    .bar > i {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
    }

    .forecast-chart {
      display: grid;
      gap: 12px;
    }

    .chart-card {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
      display: grid;
      gap: 14px;
    }

    .chart-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .chart-head strong {
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .chart-head span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .chart-svg {
      width: 100%;
      height: 180px;
      display: block;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .cost-card {
      padding: 14px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.04);
      display: grid;
      gap: 6px;
    }

    .cost-card span {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 700;
    }

    .cost-card strong {
      font-size: 20px;
      line-height: 1.2;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .versus-card {
      position: relative;
      z-index: 1;
      padding: 18px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.96), rgba(28, 38, 99, 0.94));
      color: var(--white);
      box-shadow: var(--shadow-medium);
      display: grid;
      gap: 12px;
      overflow: hidden;
    }

    .versus-card::before {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      right: -70px;
      bottom: -70px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(29, 220, 255, 0.22), transparent 72%);
    }

    .versus-head strong {
      display: block;
      font-size: 15px;
      line-height: 1.5;
    }

    .versus-head span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.72);
    }

    .compare-list {
      display: grid;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

    .compare-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 58px 90px;
      gap: 10px;
      align-items: center;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform var(--transition), background var(--transition), border-color var(--transition);
    }

    .compare-row.active {
      transform: translateX(3px);
      background: rgba(29, 220, 255, 0.16);
      border-color: rgba(29, 220, 255, 0.28);
    }

    .compare-name strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      color: var(--white);
    }

    .compare-name span {
      display: block;
      font-size: 10px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.68);
    }

    .compare-calls {
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 1;
      text-align: center;
      color: var(--white);
    }

    .compare-state {
      text-align: right;
      font-size: 11px;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.78);
    }

    .pill-note {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.92);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .bullet-list {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .bullet-list div {
      display: grid;
      grid-template-columns: 20px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .bullet-list div::before {
      content: "✓";
      display: grid;
      place-items: center;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(29, 220, 255, 0.14);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 900;
    }

    .footer-note {
      margin-top: 16px;
      padding: 16px 18px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
      display: flex;
      flex-wrap: wrap;
      gap: 12px 16px;
      align-items: center;
      justify-content: space-between;
    }

    .footer-note strong {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.6;
    }

    .footer-note span {
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.78; }
    }

    @keyframes float {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(0, 12px, 0); }
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    @media (max-width: 1120px) {
      .summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .phone-scene {
        grid-template-columns: 1fr;
      }

      .aside {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .page {
        padding-inline: 10px;
      }

      .masthead,
      .controls,
      .screen-frame {
        border-radius: 24px;
      }

      .screen-top {
        flex-direction: column;
        align-items: flex-start;
      }

      .control-row {
        justify-content: flex-start;
      }

      .summary {
        grid-template-columns: 1fr;
      }

      .aside {
        grid-template-columns: 1fr;
      }

      .phone {
        width: 100%;
        min-height: 760px;
      }

      .headline strong {
        font-size: 30px;
      }
    }

    @media (max-width: 420px) {
      h1 {
        font-size: 34px;
      }

      .headline strong {
        font-size: 28px;
      }

      .phone {
        min-height: 734px;
        padding: 12px;
      }

      .screenshot {
        padding-inline: 16px;
      }

      .cost-grid {
        grid-template-columns: 1fr;
      }

      .compare-row {
        grid-template-columns: minmax(0, 1fr) 50px 72px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="masthead">
      <div class="eyebrow">ASO日次差分 / ストアPV→DL率 改善仮説</div>
      <h1>1ファイルで3スクショを体験する<br>スワイプ型ストアクリエイティブ</h1>
      <p class="lead">
        <strong>目的は ストア詳細ページの閲覧→DL のCVR改善です。</strong>
        現状 <span class="marker">17.3%</span> から KPI <span class="marker">25%</span> へ上げる前提で、
        <strong>AI査定</strong>、<strong>出費管理+将来予測</strong>、<strong>電話0本で相場チェック</strong> を
        1枚ずつ強く切り出しました。各スクショはボタンで切替、左右スワイプでも移動できます。
      </p>
      <div class="summary">
        <article class="summary-card">
          <div class="summary-label">対象KPI</div>
          <div class="summary-value">17.3<span>% 現状</span></div>
          <div class="summary-note">ストア詳細ページ閲覧からDLまでのCVR。訴求の初速改善が必要。</div>
        </article>
        <article class="summary-card">
          <div class="summary-label">目標</div>
          <div class="summary-value">25<span>% KPI</span></div>
          <div class="summary-note">ファーストビューの理解負荷を下げ、差別化訴求を先頭化。</div>
        </article>
        <article class="summary-card">
          <div class="summary-label">主訴求</div>
          <div class="summary-value">3<span>画面</span></div>
          <div class="summary-note">AI査定、維持費と売り時、電話0本比較を分担して見せる。</div>
        </article>
        <article class="summary-card">
          <div class="summary-label">アプローチ</div>
          <div class="summary-value">C<span>体験型</span></div>
          <div class="summary-note">スワイプ、ステップ進行、マイクロアニメーションで記憶に残す。</div>
        </article>
      </div>
    </section>

    <section class="controls">
      <div class="control-row">
        <div class="control-group">
          <span class="control-label">スクショ切替</span>
          <button class="shot-tab active" type="button" data-slide="0">A / iOS AI査定</button>
          <button class="shot-tab" type="button" data-slide="1">B / Android 出費管理</button>
          <button class="shot-tab" type="button" data-slide="2">C / 電話0本 比較</button>
        </div>
        <div class="control-group">
          <button class="ghost-button" type="button" id="prevButton">← 前へ</button>
          <button class="ghost-button" type="button" id="nextButton">次へ →</button>
        </div>
      </div>
      <div class="control-row">
        <div class="control-group">
          <span class="control-label">ステップ演出</span>
          <button class="mode-button active" type="button" data-step="1">入力開始</button>
          <button class="mode-button" type="button" data-step="2">AI解析中</button>
          <button class="mode-button" type="button" data-step="3">結果表示</button>
        </div>
        <div class="control-group">
          <button class="ghost-button" type="button" id="autoplayButton">自動再生: OFF</button>
        </div>
      </div>
    </section>

    <section class="screens">
      <div class="screen-frame">
        <div class="screen-top">
          <div class="screen-title">
            <strong id="screenHeading">A. iOS向け: AI査定を全面に出したスクショ</strong>
            <span id="screenSubheading">「AIがあなたの愛車を査定」を最初の1枚で理解させる構成。個人情報なしと30秒導線を同時に見せる。</span>
          </div>
          <div class="shot-tabs" aria-hidden="true">
            <button class="shot-tab active" type="button">Swipe</button>
            <button class="shot-tab" type="button">Step</button>
            <button class="shot-tab" type="button">Micro</button>
          </div>
        </div>

        <div class="carousel-shell" id="carousel">
          <div class="track" id="track">
            <section class="slide">
              <div class="phone-scene">
                <article class="phone">
                  <div class="phone-screen">
                    <div class="status-bar">
                      <span>9:41</span>
                      <div class="status-icons">
                        <span>5G</span>
                        <span>100%</span>
                      </div>
                    </div>
                    <div class="screenshot" style="background: var(--gradient-aurora);">
                      <div class="label-row">
                        <span class="badge blue">iOS向け 1枚目</span>
                        <span class="badge pink">AI査定</span>
                        <span class="badge cyan">個人情報なし</span>
                      </div>
                      <div class="headline">
                        <strong>AIがあなたの愛車を査定。<br>30秒で、今の相場が見える。</strong>
                        <p>トヨタ ハリアー Z Leather Package 2021年式 / 33,800km のような具体車両でも、登録前に概算を把握できます。</p>
                      </div>
                      <div class="hero-card">
                        <div class="car-line">
                          <div class="car-info">
                            <strong>トヨタ ハリアー Z Leather Package</strong>
                            <span>2021年 / 33,800km / ブラック / 2WD</span>
                          </div>
                          <div class="price-orb">
                            <div>
                              <strong>312</strong>
                              <span>万円 AI予測</span>
                            </div>
                          </div>
                        </div>
                        <div class="chips">
                          <span class="chip active">今すぐ相場を見る</span>
                          <span class="chip">3か月後 301万円</span>
                          <span class="chip">6か月後 289万円</span>
                        </div>
                        <div class="step-board" id="stepBoard">
                          <div class="step-item active" data-step-card="1">
                            <div class="step-index">1</div>
                            <div class="step-copy">
                              <strong>メーカー・車種を選ぶ</strong>
                              <span>入力負荷は最初に最小化。最短30秒の期待値をつくる。</span>
                            </div>
                            <div class="step-state">進行中</div>
                          </div>
                          <div class="step-item" data-step-card="2">
                            <div class="step-index">2</div>
                            <div class="step-copy">
                              <strong>AIが相場と将来予測を解析</strong>
                              <span>現在価格だけでなく、売り時判断まで一気に見せる。</span>
                            </div>
                            <div class="step-state">待機</div>
                          </div>
                          <div class="step-item" data-step-card="3">
                            <div class="step-index">3</div>
                            <div class="step-copy">
                              <strong>結果を保存してあとで比較</strong>
                              <span>今すぐ売らない人も、アプリを残す理由を先に提示。</span>
                            </div>
                            <div class="step-state">待機</div>
                          </div>
                        </div>
                      </div>
                      <div class="progress-block">
                        <div class="progress-head">
                          <strong id="progressTitle">ステップ 1 / 3: 入力開始</strong>
                          <span id="progressMeta">3タップで相場の入口へ</span>
                        </div>
                        <div class="progress-bar"><span id="progressFill"></span></div>
                      </div>
                      <div class="cta-panel">
                        <button class="primary-button" type="button" id="stepAdvanceButton">次のステップへ進む</button>
                        <div class="sub-note">営業電話なしで相場だけ確認。売る時期が来たらアプリ内で続きへ。</div>
                      </div>
                    </div>
                  </div>
                </article>

                <aside class="aside">
                  <section class="insight">
                    <strong>狙い</strong>
                    <p>App Store の先頭スクショで「何ができるアプリか」を即理解させるため、最初の1枚は AI査定に集中。価格と将来予測を同じ面で見せて、競合にない機能差を一発で伝えます。</p>
                    <div class="bullet-list">
                      <div>「AI」「30秒」「個人情報なし」を上部に圧縮して、読み順を固定。</div>
                      <div>車名と価格を具体化して、ダミー感より現実感を優先。</div>
                      <div>ステップ進行で、入力が軽いことを視覚的に伝える。</div>
                    </div>
                  </section>
                  <section class="score-card">
                    <strong>想定ヒット層</strong>
                    <div class="score-grid">
                      <div class="score-line">
                        <span>今すぐ売る</span>
                        <div class="bar"><i style="width: 90%;"></i></div>
                        <span>90</span>
                      </div>
                      <div class="score-line">
                        <span>まず相場だけ</span>
                        <div class="bar"><i style="width: 96%;"></i></div>
                        <span>96</span>
                      </div>
                      <div class="score-line">
                        <span>比較疲れ回避</span>
                        <div class="bar"><i style="width: 82%;"></i></div>
                        <span>82</span>
                      </div>
                    </div>
                  </section>
                  <section class="mini-panel">
