                    <line class="grid-line" x1="24" y1="136" x2="296" y2="136"></line>
                    <polyline class="forecast-line" id="a-line" points="36,46 136,72 236,98 284,118"></polyline>
                    <circle class="point pink delay-1" cx="36" cy="46" r="6"></circle>
