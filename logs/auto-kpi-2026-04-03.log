                      </div>
                      <div class="score-number" id="score-ucp-number">0本</div>
                    </div>
                    <div class="score-item">
                      <div>
                        <div class="score-label" id="score-rival-1-label">MOTA</div>
                        <div class="score-track"><div class="score-fill pink" id="score-rival-1" style="--target:30%;"></div></div>
                      </div>
                      <div class="score-number" id="score-rival-1-number">3本</div>
                    </div>
                    <div class="score-item">
                      <div>
                        <div class="score-label" id="score-rival-2-label">ズバット</div>
                        <div class="score-track"><div class="score-fill pink" id="score-rival-2" style="--target:100%;"></div></div>
                      </div>
                      <div class="score-number" id="score-rival-2-number">10本</div>
                    </div>
                  </div>
                </div>

                <div class="table" id="compare-table">
                  <div class="table-row">
                    <div class="cell head">比較項目</div>
                    <div class="cell head">UcarPAC</div>
                    <div class="cell head">MOTA</div>
                    <div class="cell head">ズバット</div>
                  </div>
                  <div class="table-row">
                    <div class="cell">相場確認時の電話</div>
                    <div class="cell main win">0本</div>
                    <div class="cell loss">3社</div>
                    <div class="cell loss">最大10社</div>
                  </div>
                  <div class="table-row">
                    <div class="cell">AI査定</div>
                    <div class="cell main win">あり</div>
                    <div class="cell loss">なし</div>
                    <div class="cell loss">なし</div>
                  </div>
                  <div class="table-row">
                    <div class="cell">将来予測</div>
                    <div class="cell main win">あり</div>
                    <div class="cell loss">なし</div>
