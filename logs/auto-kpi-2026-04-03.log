      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
    }

    .control-group {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .control-label {
      font-size: 11px;
      font-weight: 900;
      color: var(--text-gray);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      min-width: 108px;
    }

    .mode-button,
    .ghost-button,
    .shot-tab {
      min-height: 43px;
      padding: 0 16px;
      border-radius: var(--radius-button);
      transition: transform var(--transition), box-shadow var(--transition), background var(--transition), color var(--transition);
    }

    .mode-button {
      background: rgba(255, 255, 255, 0.92);
      color: var(--dark-blue);
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(28, 38, 99, 0.08);
      font-size: 13px;
      font-weight: 800;
    }

    .mode-button.active {
      background: var(--gradient-night);
      color: var(--white);
      transform: translateY(-1px);
    }

    .ghost-button {
      background: rgba(9, 19, 85, 0.06);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
    }

    .ghost-button:hover,
    .mode-button:hover,
    .shot-tab:hover {
      transform: translateY(-1px);
    }

    .screens {
      margin-top: 22px;
      display: grid;
      gap: 16px;
    }

    .screen-frame {
      position: relative;
      overflow: hidden;
      padding: 18px;
      border-radius: 34px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-heavy);
      backdrop-filter: blur(18px);
    }

    .screen-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .screen-title {
      display: grid;
      gap: 4px;
    }

    .screen-title strong {
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 1.4;
    }

    .screen-title span {
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .shot-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .shot-tab {
      background: rgba(255, 255, 255, 0.9);
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: var(--shadow-light);
      font-size: 13px;
      font-weight: 800;
    }

    .shot-tab.active {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .carousel-shell {
      overflow: hidden;
      border-radius: 32px;
      touch-action: pan-y;
    }

    .track {
      display: flex;
      transition: transform 420ms cubic-bezier(.2, .8, .2, 1);
      will-change: transform;
    }

    .slide {
      min-width: 100%;
      display: grid;
      align-items: start;
      gap: 18px;
    }

    .phone-scene {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 320px);
      gap: 18px;
      align-items: stretch;
    }

    .phone {
      position: relative;
      width: min(100%, var(--phone-width));
      min-height: var(--phone-height);
      margin: 0 auto;
      padding: 14px;
      border-radius: var(--radius-phone);
      background: linear-gradient(160deg, rgba(9, 19, 85, 0.96), rgba(28, 38, 99, 0.92));
      box-shadow: 0 30px 90px rgba(10, 19, 72, 0.30);
      isolation: isolate;
    }

    .phone::before {
      content: "";
      position: absolute;
      inset: 8px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.08);
      pointer-events: none;
    }

    .phone::after {
      content: "";
      position: absolute;
      top: 10px;
      left: 50%;
      width: 138px;
      height: 28px;
      transform: translateX(-50%);
      border-radius: 0 0 16px 16px;
      background: rgba(5, 10, 35, 0.88);
      z-index: 3;
    }

    .phone-screen {
      position: relative;
      z-index: 2;
      min-height: calc(var(--phone-height) - 28px);
      border-radius: 26px;
      overflow: hidden;
      background: var(--gradient-phone);
      display: flex;
      flex-direction: column;
    }

    .status-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 18px 10px;
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .status-icons {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .status-icons span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 18px;
      height: 18px;
      padding: 0 4px;
      border-radius: 9px;
      background: rgba(28, 38, 99, 0.08);
      font-size: 10px;
    }

    .screenshot {
      flex: 1;
      padding: 10px 18px 18px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      position: relative;
      overflow: hidden;
    }

    .screenshot::before {
      content: "";
      position: absolute;
      inset: auto -30px -60px auto;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.16), transparent 68%);
      pointer-events: none;
      animation: float 7s ease-in-out infinite;
    }

    .screenshot::after {
      content: "";
      position: absolute;
      inset: 70px auto auto -60px;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(29, 220, 255, 0.16), transparent 68%);
      pointer-events: none;
      animation: float 6s ease-in-out infinite reverse;
    }

    .label-row,
    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .badge.blue {
      color: var(--dark-blue);
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(64, 153, 255, 0.20);
    }

    .badge.pink {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 10px 20px rgba(248, 76, 162, 0.22);
    }

    .badge.cyan {
      color: var(--dark-blue);
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.16), rgba(77, 180, 255, 0.20));
    }

    .headline {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
    }

    .headline strong {
      font-size: 34px;
      line-height: 1.22;
      letter-spacing: -0.05em;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .headline p {
      margin: 0;
      font-size: 14px;
      line-height: 1.8;
      color: #68728e;
    }

    .hero-card {
      position: relative;
      z-index: 1;
      padding: 18px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
      display: grid;
      gap: 14px;
      overflow: hidden;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      right: -24px;
      top: -34px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(29, 220, 255, 0.20), transparent 70%);
    }

    .car-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .car-info strong {
      display: block;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .car-info span {
      display: block;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .price-orb {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(180deg, #ffffff, #eef8ff);
      display: grid;
      place-items: center;
      box-shadow: inset 0 0 0 8px rgba(29, 220, 255, 0.18), 0 14px 30px rgba(28, 38, 99, 0.12);
      animation: bob 3.2s ease-in-out infinite;
    }

    .price-orb strong {
      display: block;
      font-family: var(--font-number);
      font-size: 28px;
      line-height: 1;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
      text-align: center;
    }

    .price-orb span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      font-weight: 800;
      color: var(--text-gray);
      text-align: center;
    }

    .chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .chip {
      min-height: 43px;
      padding: 0 14px;
      border-radius: var(--radius-chip);
      background: rgba(255, 255, 255, 0.92);
      color: var(--text-black);
      border: 1px solid rgba(28, 38, 99, 0.08);
      font-size: 13px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .chip.active {
      color: var(--white);
      background: var(--gradient-night);
      border-color: transparent;
    }

    .step-board {
      display: grid;
      gap: 10px;
    }

    .step-item {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(9, 19, 85, 0.04);
      transition: transform var(--transition), background var(--transition), opacity var(--transition);
      opacity: 0.55;
    }

    .step-item.active {
      background: rgba(29, 220, 255, 0.12);
      opacity: 1;
      transform: translateX(2px);
    }

    .step-item.done {
      background: rgba(248, 76, 162, 0.12);
      opacity: 1;
    }

    .step-index {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.88);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
    }

    .step-copy strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .step-copy span {
      display: block;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .step-state {
      font-size: 11px;
      font-weight: 800;
      color: var(--text-gray);
    }

    .progress-block {
      position: relative;
      z-index: 1;
      padding: 16px;
      border-radius: 22px;
      background: var(--gradient-night);
      color: var(--white);
      box-shadow: var(--shadow-medium);
      display: grid;
      gap: 10px;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .progress-head strong {
      font-size: 14px;
      line-height: 1.5;
      font-weight: 800;
    }

    .progress-head span {
      font-size: 11px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.72);
    }

    .progress-bar {
      height: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      overflow: hidden;
    }

    .progress-bar > span {
      display: block;
      height: 100%;
      width: 33%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width var(--transition);
    }

    .cta-panel {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
    }

    .primary-button {
      min-height: 52px;
      padding: 0 18px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 900;
      box-shadow: 0 14px 30px rgba(64, 191, 255, 0.30);
    }

    .sub-note {
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
      text-align: center;
    }

    .aside {
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .insight,
    .score-card,
    .mini-panel {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
    }

    .insight strong,
    .score-card strong,
    .mini-panel strong {
      display: block;
      font-size: 15px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .insight p,
    .score-card p,
    .mini-panel p {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .score-grid {
      margin-top: 12px;
      display: grid;
      gap: 10px;
    }

    .score-line {
      display: grid;
      grid-template-columns: 68px minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .score-line span:last-child {
      color: var(--dark-blue);
      font-weight: 900;
    }

    .bar {
      height: 8px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(28, 38, 99, 0.08);
    }

    .bar > i {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
    }

    .forecast-chart {
      display: grid;
      gap: 12px;
    }

    .chart-card {
      padding: 16px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
      display: grid;
      gap: 14px;
    }

    .chart-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .chart-head strong {
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .chart-head span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .chart-svg {
      width: 100%;
      height: 180px;
      display: block;
    }

    .cost-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .cost-card {
      padding: 14px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.04);
      display: grid;
      gap: 6px;
    }

    .cost-card span {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 700;
    }

    .cost-card strong {
      font-size: 20px;
      line-height: 1.2;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .versus-card {
      position: relative;
      z-index: 1;
      padding: 18px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.96), rgba(28, 38, 99, 0.94));
      color: var(--white);
      box-shadow: var(--shadow-medium);
      display: grid;
      gap: 12px;
      overflow: hidden;
    }

    .versus-card::before {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      right: -70px;
      bottom: -70px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(29, 220, 255, 0.22), transparent 72%);
    }

    .versus-head strong {
      display: block;
      font-size: 15px;
      line-height: 1.5;
    }

    .versus-head span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.72);
    }

    .compare-list {
      display: grid;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

    .compare-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 58px 90px;
      gap: 10px;
      align-items: center;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: transform var(--transition), background var(--transition), border-color var(--transition);
    }

    .compare-row.active {
      transform: translateX(3px);
      background: rgba(29, 220, 255, 0.16);
      border-color: rgba(29, 220, 255, 0.28);
    }

    .compare-name strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
      color: var(--white);
    }

    .compare-name span {
      display: block;
      font-size: 10px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.68);
    }

    .compare-calls {
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 1;
      text-align: center;
      color: var(--white);
    }

    .compare-state {
      text-align: right;
      font-size: 11px;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.78);
    }

    .pill-note {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.92);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .bullet-list {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .bullet-list div {
      display: grid;
      grid-template-columns: 20px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .bullet-list div::before {
      content: "✓";
      display: grid;
      place-items: center;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(29, 220, 255, 0.14);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 900;
    }

    .footer-note {
      margin-top: 16px;
      padding: 16px 18px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.84);
      box-shadow: var(--shadow-light);
      display: flex;
      flex-wrap: wrap;
      gap: 12px 16px;
      align-items: center;
      justify-content: space-between;
    }

    .footer-note strong {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.6;
    }

    .footer-note span {
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.78; }
    }

    @keyframes float {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(0, 12px, 0); }
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    @media (max-width: 1120px) {
      .summary {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .phone-scene {
        grid-template-columns: 1fr;
      }

      .aside {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .page {
        padding-inline: 10px;
      }

      .masthead,
      .controls,
      .screen-frame {
        border-radius: 24px;
      }

      .screen-top {
        flex-direction: column;
        align-items: flex-start;
      }

      .control-row {
        justify-content: flex-start;
      }

      .summary {
        grid-template-columns: 1fr;
      }

      .aside {
        grid-template-columns: 1fr;
      }

      .phone {
        width: 100%;
        min-height: 760px;
      }

      .headline strong {
        font-size: 30px;
      }
    }

    @media (max-width: 420px) {
      h1 {
        font-size: 34px;
      }

      .headline strong {
        font-size: 28px;
      }

      .phone {
        min-height: 734px;
        padding: 12px;
      }

      .screenshot {
        padding-inline: 16px;
      }

      .cost-grid {
        grid-template-columns: 1fr;
      }

      .compare-row {
        grid-template-columns: minmax(0, 1fr) 50px 72px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="masthead">
      <div class="eyebrow">ASO日次差分 / ストアPV→DL率 改善仮説</div>
      <h1>1ファイルで3スクショを体験する<br>スワイプ型ストアクリエイティブ</h1>
      <p class="lead">
        <strong>目的は ストア詳細ページの閲覧→DL のCVR改善です。</strong>
        現状 <span class="marker">17.3%</span> から KPI <span class="marker">25%</span> へ上げる前提で、
        <strong>AI査定</strong>、<strong>出費管理+将来予測</strong>、<strong>電話0本で相場チェック</strong> を
        1枚ずつ強く切り出しました。各スクショはボタンで切替、左右スワイプでも移動できます。
      </p>
      <div class="summary">
        <article class="summary-card">
          <div class="summary-label">対象KPI</div>
          <div class="summary-value">17.3<span>% 現状</span></div>
          <div class="summary-note">ストア詳細ページ閲覧からDLまでのCVR。訴求の初速改善が必要。</div>
        </article>
        <article class="summary-card">
