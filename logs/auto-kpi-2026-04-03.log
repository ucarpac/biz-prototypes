+
+  <script>
+    (() => {
+      const track = document.getElementById("track");
+      const carousel = document.getElementById("carousel");
+      const tabs = Array.from(document.querySelectorAll(".shot-tab[data-slide]"));
+      const prevButton = document.getElementById("prevButton");
+      const nextButton = document.getElementById("nextButton");
+      const autoplayButton = document.getElementById("autoplayButton");
+      const heading = document.getElementById("screenHeading");
+      const subheading = document.getElementById("screenSubheading");
+      const stepButtons = Array.from(document.querySelectorAll(".mode-button[data-step]"));
+      const stepCards = Array.from(document.querySelectorAll("[data-step-card]"));
+      const progressFill = document.getElementById("progressFill");
+      const progressTitle = document.getElementById("progressTitle");
+      const progressMeta = document.getElementById("progressMeta");
+      const stepAdvanceButton = document.getElementById("stepAdvanceButton");
+      const compareRows = Array.from(document.querySelectorAll(".compare-row"));
+
+      const slideMeta = [
+        {
+          title: "A. iOS向け: AI査定を全面に出したスクショ",
+          sub: "「AIがあなたの愛車を査定」を最初の1枚で理解させる構成。個人情報なしと30秒導線を同時に見せる。"
+        },
+        {
+          title: "B. Android向け: 出費管理+将来予測を訴求したスクショ",
+          sub: "継続利用の理由を先に提示し、査定アプリではなく愛車管理アプリとして想起させる。"
+        },
+        {
+          title: "C. 競合比較: 電話0本を訴求したスクショ",
+          sub: "「相場だけ知りたいのに電話が来る」不安を比較表現で切り、DL前の心理障壁を小さくする。"
+        }
+      ];
+
+      const stepMeta = {
+        1: {
+          width: "33%",
+          title: "ステップ 1 / 3: 入力開始",
+          note: "3タップで相場の入口へ"
+        },
+        2: {
+          width: "68%",
+          title: "ステップ 2 / 3: AI解析中",
+          note: "相場と将来予測を自動で算出"
+        },
+        3: {
+          width: "100%",
+          title: "ステップ 3 / 3: 結果表示",
+          note: "保存してあとから売り時を比較"
+        }
+      };
+
+      let currentSlide = 0;
+      let currentStep = 1;
+      let autoplay = null;
+      let startX = 0;
+      let currentX = 0;
+      let isTouching = false;
+
+      const updateSlide = (index) => {
+        currentSlide = (index + slideMeta.length) % slideMeta.length;
+        track.style.transform = `translateX(-${currentSlide * 100}%)`;
+        tabs.forEach((tab, tabIndex) => {
+          tab.classList.toggle("active", tabIndex === currentSlide);
+        });
+        heading.textContent = slideMeta[currentSlide].title;
+        subheading.textContent = slideMeta[currentSlide].sub;
+
+        compareRows.forEach((row, rowIndex) => {
+          const shouldHighlight = currentSlide === 2 && rowIndex === 3;
+          row.classList.toggle("active", shouldHighlight);
+        });
+      };
+
+      const updateStep = (step) => {
+        currentStep = step;
+        stepButtons.forEach((button) => {
+          button.classList.toggle("active", Number(button.dataset.step) === step);
+        });
+
+        stepCards.forEach((card) => {
+          const cardStep = Number(card.dataset.stepCard);
+          card.classList.remove("active", "done");
+          if (cardStep < step) {
+            card.classList.add("done");
+            card.querySelector(".step-state").textContent = "完了";
+          } else if (cardStep === step) {
+            card.classList.add("active");
+            card.querySelector(".step-state").textContent = "進行中";
+          } else {
+            card.querySelector(".step-state").textContent = "待機";
+          }
+        });
+
+        progressFill.style.width = stepMeta[step].width;
+        progressTitle.textContent = stepMeta[step].title;
+        progressMeta.textContent = stepMeta[step].note;
+      };
+
+      const toggleAutoplay = () => {
+        if (autoplay) {
+          window.clearInterval(autoplay);
+          autoplay = null;
+          autoplayButton.textContent = "自動再生: OFF";
+          return;
+        }
+        autoplay = window.setInterval(() => {
+          updateSlide(currentSlide + 1);
+        }, 3600);
+        autoplayButton.textContent = "自動再生: ON";
+      };
+
+      tabs.forEach((tab) => {
+        tab.addEventListener("click", () => {
+          updateSlide(Number(tab.dataset.slide));
+        });
+      });
+
+      stepButtons.forEach((button) => {
+        button.addEventListener("click", () => {
+          updateStep(Number(button.dataset.step));
+        });
+      });
+
+      stepAdvanceButton.addEventListener("click", () => {
+        const nextStep = currentStep === 3 ? 1 : currentStep + 1;
+        updateStep(nextStep);
+      });
+
+      prevButton.addEventListener("click", () => updateSlide(currentSlide - 1));
+      nextButton.addEventListener("click", () => updateSlide(currentSlide + 1));
+      autoplayButton.addEventListener("click", toggleAutoplay);
+
+      carousel.addEventListener("touchstart", (event) => {
+        isTouching = true;
+        startX = event.touches[0].clientX;
+        currentX = startX;
+      }, { passive: true });
+
+      carousel.addEventListener("touchmove", (event) => {
+        if (!isTouching) {
+          return;
+        }
+        currentX = event.touches[0].clientX;
+      }, { passive: true });
+
+      carousel.addEventListener("touchend", () => {
+        if (!isTouching) {
+          return;
+        }
+        const delta = currentX - startX;
+        if (Math.abs(delta) > 42) {
+          updateSlide(currentSlide + (delta < 0 ? 1 : -1));
+        }
+        isTouching = false;
+      });
+
+      window.addEventListener("keydown", (event) => {
+        if (event.key === "ArrowLeft") {
+          updateSlide(currentSlide - 1);
+        }
+        if (event.key === "ArrowRight") {
+          updateSlide(currentSlide + 1);
+        }
+      });
+
+      updateSlide(0);
+      updateStep(1);
+    })();
+  </script>
+</body>
+</html>
