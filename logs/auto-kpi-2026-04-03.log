        aGap: '-3.1万',
        aBadge: '下落圏',
        aTag: '早め推奨',
        aLine: '36,62 136,90 236,118 284,138',
        bTotal: '31.8',
        bCaption: '半年保有では維持費も積み上がり、売却判断に効く数字が明確になります。',
        bHold: '14.7万',
        bDelta: '-39.4万',
        bSignal: '売り時 63',
        bAssetLine: '34,66 124,92 214,118 286,140',
        bCostLine: '34,130 124,116 214,100 286,84'
      }
