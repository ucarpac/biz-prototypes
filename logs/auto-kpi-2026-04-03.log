        mainCopy: '相場確認の段階では電話なし。迷っている人でも試しやすい。',
        rival1Label: 'MOTA',
        rival1Number: '3本',
        rival1Width: '30%',
        rival2Label: 'ズバット',
        rival2Number: '100%',
        rival2Display: '10本',
        table: [
          ['相場確認時の電話', '0本', '3社', '最大10社'],
          ['AI査定', 'あり', 'なし', 'なし'],
          ['将来予測', 'あり', 'なし', 'なし'],
          ['アプリ体験', 'あり', 'なし', 'なし']
        ]
      },
      contact: {
        headline: '売ると決めた後も、<br>電話は1社だけ。',
        subline: 'オークションで8,000社が入札しても、ユーザーのやりとりは1社に絞られます。',
        mainNumber: '1',
        mainCopy: '売却相談に進んでも、対応負荷を最小化したまま最高額を狙える設計。',
        rival1Label: 'MOTA',
        rival1Number: '3本',
        rival1Width: '30%',
        rival2Label: 'ズバット',
        rival2Number: '100%',
        rival2Display: '10本',
        table: [
          ['売却相談後の電話', '1社', '3社', '最大10社'],
          ['入札規模', '8,000社', '数百社', '最大10社'],
          ['手数料', '無料', '無料', '無料'],
          ['将来予測', 'あり', 'なし', 'なし']
        ]
      }
    };

    function updatePeriod(period) {
      const data = periodState[period];
      document.getElementById('a-price').textContent = data.aPrice;
      document.getElementById('a-caption').textContent = data.aCaption;
      document.getElementById('a-gap').textContent = data.aGap;
      document.getElementById('a-badge').textContent = data.aBadge;
      document.getElementById('a-tag').textContent = data.aTag;
      document.getElementById('a-line').setAttribute('points', data.aLine);

      document.getElementById('b-total').textContent = data.bTotal;
      document.getElementById('b-caption').textContent = data.bCaption;
      document.getElementById('b-hold').textContent = data.bHold;
      document.getElementById('b-delta').textContent = data.bDelta;
      document.getElementById('b-signal').textContent = data.bSignal;
      document.getElementById('b-asset-line').setAttribute('points', data.bAssetLine);
      document.getElementById('b-cost-line').setAttribute('points', data.bCostLine);
    }

    function buildTableRows(rows) {
      const table = document.getElementById('compare-table');
      table.innerHTML = `
        <div class="table-row">
          <div class="cell head">比較項目</div>
          <div class="cell head">UcarPAC</div>
          <div class="cell head">MOTA</div>
          <div class="cell head">ズバット</div>
        </div>
      `;

      rows.forEach((row) => {
        const line = document.createElement('div');
        line.className = 'table-row';
        line.innerHTML = `
          <div class="cell">${row[0]}</div>
          <div class="cell main win">${row[1]}</div>
          <div class="cell loss">${row[2]}</div>
          <div class="cell loss">${row[3]}</div>
        `;
        table.appendChild(line);
      });
    }

    function updateCompare(mode) {
      const data = compareState[mode];
      document.getElementById('c-headline').innerHTML = data.headline;
      document.getElementById('c-subline').textContent = data.subline;
      document.getElementById('c-main-number').textContent = data.mainNumber;
      document.getElementById('c-main-copy').textContent = data.mainCopy;
      document.getElementById('score-rival-1-label').textContent = data.rival1Label;
      document.getElementById('score-rival-1-number').textContent = data.rival1Number;
      document.getElementById('score-rival-1').style.setProperty('--target', data.rival1Width);
      document.getElementById('score-rival-2-label').textContent = data.rival2Label;
      document.getElementById('score-rival-2-number').textContent = data.rival2Display;
      document.getElementById('score-rival-2').style.setProperty('--target', data.rival2Number);
      document.getElementById('score-ucp-number').textContent = mode === 'estimate' ? '0本' : '1社';
      document.getElementById('score-ucp').style.setProperty('--target', mode === 'estimate' ? '0%' : '10%');
      buildTableRows(data.table);
    }

    periodButtons.forEach((button) => {
      button.addEventListener('click', () => {
        periodButtons.forEach((item) => {
          if (item.dataset.period) {
            item.classList.remove('active');
          }
        });
        button.classList.add('active');
        updatePeriod(button.dataset.period);
      });
    });

    compareButtons.forEach((button) => {
      button.addEventListener('click', () => {
        compareButtons.forEach((item) => {
          if (item.dataset.compare) {
            item.classList.remove('active');
          }
        });
        compareTabs.forEach((tab) => {
          tab.classList.toggle('active', tab.dataset.compare === button.dataset.compare);
        });
        button.classList.add('active');
        updateCompare(button.dataset.compare);
      });
    });

    compareTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        compareTabs.forEach((item) => item.classList.remove('active'));
        compareButtons.forEach((item) => {
          if (item.dataset.compare) {
            item.classList.toggle('active', item.dataset.compare === tab.dataset.compare);
          }
        });
        tab.classList.add('active');
        updateCompare(tab.dataset.compare);
      });
    });

    updatePeriod('now');
    updateCompare('estimate');
  </script>
</body>
