      color: var(--dark-blue);
      font-size: 24px;
      line-height: 1.45;
      font-weight: 900;
    }

    .shot-desc {
      margin: 8px 0 0;
      max-width: 580px;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.8;
    }

    .shot-note {
      max-width: 200px;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-light);
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
    }

    .shot-note strong {
      color: var(--dark-blue);
    }

    .phone {
      position: relative;
      width: 100%;
      max-width: var(--phone-width);
      margin: 0 auto;
      padding: 14px;
      border-radius: var(--radius-phone);
      background: #20253f;
      box-shadow: 0 26px 56px rgba(9, 19, 85, 0.30);
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 128px;
      height: 26px;
      border-radius: 0 0 16px 16px;
      background: #11152a;
      z-index: 5;
    }

    .phone.android::before {
      width: 16px;
      height: 16px;
      border-radius: 999px;
      top: 10px;
    }

    .screen {
      position: relative;
      min-height: 760px;
      border-radius: 24px;
      overflow: hidden;
      background: var(--gradient-sunrise);
    }

    .screen::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 18% 14%, rgba(255,255,255,0.78), transparent 18%),
        radial-gradient(circle at 82% 12%, rgba(255,255,255,0.62), transparent 16%);
      pointer-events: none;
    }

    .screen.ai {
      background:
        radial-gradient(circle at 84% 12%, rgba(255,255,255,0.86), transparent 18%),
        linear-gradient(180deg, #fff8f2 0%, #ffe7ef 46%, #ecf8ff 100%);
    }

    .screen.life {
      background:
        radial-gradient(circle at 86% 16%, rgba(255,255,255,0.80), transparent 16%),
        linear-gradient(180deg, #fff7ef 0%, #fff0dd 24%, #eef8ff 100%);
    }

    .screen.compare {
      background:
        radial-gradient(circle at 14% 10%, rgba(255,255,255,0.78), transparent 18%),
        linear-gradient(180deg, #fffaf3 0%, #ffe8ef 50%, #eef7ff 100%);
    }

    .status-bar {
      position: relative;
      z-index: 2;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 18px 8px;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .hero {
      position: relative;
      z-index: 2;
      padding: 8px 18px 0;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 126px;
      gap: 10px;
      align-items: center;
    }

    .hero h2 {
      margin: 8px 0 8px;
      color: var(--dark-blue);
      font-size: 33px;
      line-height: 1.28;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .hero p {
      margin: 0;
      color: #666b88;
      font-size: 13px;
      line-height: 1.8;
    }

    .hero .line-mark {
      display: inline;
      background: linear-gradient(transparent 60%, rgba(255, 224, 116, 0.8) 60%);
      padding: 0 2px;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
    }

    .mini-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-light);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .mini-badge.pink {
      background: rgba(248, 76, 162, 0.14);
      color: #ba246e;
    }

    .mini-badge.yellow {
      background: rgba(255, 239, 182, 0.85);
    }

    .mini-badge.blue {
      background: rgba(109, 194, 255, 0.16);
    }

    .doodle {
      position: relative;
      width: 124px;
      height: 134px;
      margin-left: auto;
    }

    .doodle .blob {
      position: absolute;
      inset: 12px 10px 10px 12px;
      border-radius: 28px;
      background: linear-gradient(180deg, #fffefa 0%, #fff0f6 100%);
      border: 1px solid rgba(248, 76, 162, 0.12);
      box-shadow: var(--shadow-light);
    }

    .doodle .car {
      position: absolute;
      left: 18px;
      bottom: 20px;
      width: 86px;
      height: 38px;
      border-radius: 22px 24px 14px 14px;
      background: linear-gradient(180deg, #ff98ba 0%, #f84ca2 100%);
    }

    .doodle .car::before,
    .doodle .car::after {
      content: "";
      position: absolute;
      bottom: -8px;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      background: var(--dark-blue);
      box-shadow: inset 0 0 0 4px #fff;
    }

    .doodle .car::before {
      left: 12px;
    }

    .doodle .car::after {
      right: 12px;
    }

    .doodle .face {
      position: absolute;
      right: 12px;
      top: 18px;
      width: 48px;
      height: 48px;
      border-radius: 999px;
      background: #fff7d8;
      box-shadow: var(--shadow-light);
    }

    .doodle .face::before,
    .doodle .face::after {
      content: "";
      position: absolute;
      top: 18px;
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: var(--dark-blue);
    }

    .doodle .face::before {
      left: 14px;
    }

    .doodle .face::after {
      right: 14px;
    }

    .doodle .smile {
      position: absolute;
      left: 15px;
      bottom: 12px;
      width: 18px;
      height: 9px;
      border-bottom: 3px solid var(--dark-blue);
      border-radius: 0 0 18px 18px;
    }

    .sticky,
    .sticky-small {
      position: absolute;
      z-index: 3;
      box-shadow: var(--shadow-light);
      color: var(--dark-blue);
      font-weight: 900;
      transform-origin: center;
      animation: floatNote 5.6s ease-in-out infinite;
    }

    .sticky {
      padding: 10px 12px;
      border-radius: 16px;
      font-size: 11px;
      line-height: 1.55;
      font-family: var(--font-note);
    }

    .sticky-small {
      padding: 7px 10px;
      border-radius: 14px;
      font-size: 10px;
      line-height: 1.45;
      font-family: var(--font-note);
    }

    .note-a1 {
      top: 126px;
      left: 18px;
      background: #fff4bf;
      transform: rotate(-7deg);
    }

    .note-a2 {
      top: 176px;
      right: 18px;
      background: #ffffff;
      color: #ff7d63;
      transform: rotate(6deg);
      animation-delay: 1.1s;
    }

    .note-b1 {
      top: 134px;
      right: 18px;
      background: #fff8d9;
      transform: rotate(-6deg);
    }

    .note-c1 {
      top: 120px;
      left: 20px;
      background: #fff4bf;
      transform: rotate(-6deg);
    }

    .note-c2 {
      top: 170px;
      right: 22px;
      background: #ffffff;
      color: #ff7d63;
      transform: rotate(5deg);
      animation-delay: 1.4s;
    }

    .card {
      position: relative;
      z-index: 2;
      margin: 16px 16px 0;
      padding: 16px;
      border-radius: var(--radius-card);
      background: var(--gradient-card);
      box-shadow: var(--shadow-light);
      overflow: hidden;
    }

    .card.dark {
      background: var(--gradient-night);
      color: var(--white);
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 10px;
    }

    .card-title {
      margin: 0;
      font-size: 18px;
      line-height: 1.45;
      font-weight: 900;
    }

    .card-caption {
      margin: 4px 0 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .card.dark .card-caption {
      color: rgba(255, 255, 255, 0.80);
    }

    .price {
      color: var(--dark-blue);
      font-size: 40px;
      line-height: 1.1;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .card.dark .price {
      color: var(--white);
    }

    .yen {
      margin-left: 4px;
      font-size: 18px;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 30px;
      padding: 0 10px;
      border-radius: 999px;
      background: #f3f8ff;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .card.dark .pill {
      background: rgba(255, 255, 255, 0.14);
      color: var(--white);
    }

    .graph {
      margin-top: 14px;
      padding: 14px 14px 10px;
      border-radius: 12px;
      background:
        repeating-linear-gradient(to top, rgba(28, 38, 99, 0.06) 0 1px, transparent 1px 25px),
        linear-gradient(180deg, #ffffff, #fbfdff);
      overflow: hidden;
    }

    .graph svg {
      width: 100%;
      height: 120px;
      display: block;
    }

    .graph-area {
      fill: rgba(248, 76, 162, 0.12);
    }

    .graph-line {
      fill: none;
      stroke: var(--pink);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1.6s ease forwards;
    }

    .graph-dot {
      fill: var(--pink);
      stroke: #fff;
      stroke-width: 3;
      animation: pulseDot 2.6s ease-in-out infinite;
    }

    .graph-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      color: #7b7f97;
      font-size: 11px;
      font-weight: 700;
    }

    .three-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .mini-stat {
      padding: 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.05);
      text-align: center;
    }

    .mini-stat strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.4;
      font-weight: 900;
    }

    .mini-stat span {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
    }

    .primary-button,
    .secondary-button,
    .ghost-button {
      width: 100%;
      min-height: 43px;
      border: 0;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.01em;
      cursor: pointer;
      transition: transform 180ms ease, filter 180ms ease;
    }

    .primary-button {
      margin-top: 14px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: var(--shadow-light);
    }

    .secondary-button {
      margin-top: 10px;
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: var(--shadow-light);
    }

    .ghost-button {
      margin-top: 10px;
      background: rgba(255, 255, 255, 0.92);
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: var(--shadow-light);
    }

    .primary-button:hover,
    .secondary-button:hover,
    .ghost-button:hover {
      transform: translateY(-1px);
      filter: saturate(1.03);
    }

    .expense-total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .expense-amount {
      color: var(--dark-blue);
      font-size: 34px;
      line-height: 1.15;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .expense-meta {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
      font-weight: 700;
      text-align: right;
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .expense-bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: #eef3f8;
    }

    .expense-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 50%;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.85), rgba(77, 180, 255, 0.85));
      transition: width 280ms ease;
    }

    .forecast-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .forecast-box {
      padding: 12px;
      border-radius: 12px;
      text-align: center;
      background: rgba(255, 255, 255, 0.92);
    }

    .forecast-box strong {
      display: block;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 1.35;
      font-weight: 900;
    }

    .forecast-box span {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
      font-weight: 700;
    }

    .mini-graph {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 12px;
      background: #fffdfb;
      border: 1px solid rgba(28, 38, 99, 0.05);
    }

    .mini-graph svg {
      display: block;
      width: 100%;
      height: 92px;
    }

    .mini-graph .graph-line {
      stroke-width: 3.5;
    }

    .memory-strip {
      margin: 16px 16px 0;
      display: grid;
      gap: 10px;
    }

    .memory-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-light);
      color: var(--dark-blue);
    }

    .memory-icon {
      flex: 0 0 34px;
      width: 34px;
      height: 34px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: #fff0c7;
      font-size: 16px;
    }

    .memory-text strong {
      display: block;
      font-size: 13px;
      line-height: 1.5;
    }

    .memory-text span {
      display: block;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
      font-weight: 700;
    }

    .compare-hero {
      position: relative;
      z-index: 2;
      padding: 14px 18px 0;
    }

    .compare-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .compare-top h2 {
      margin: 10px 0 8px;
      color: var(--dark-blue);
      font-size: 32px;
      line-height: 1.28;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .compare-top p {
      margin: 0;
      color: #666b88;
      font-size: 13px;
      line-height: 1.8;
    }

    .compare-badge {
      min-height: 58px;
      padding: 10px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-light);
      text-align: center;
      min-width: 112px;
    }

    .compare-badge strong {
      display: block;
      color: var(--pink);
      font-size: 28px;
      line-height: 1.1;
      font-weight: 900;
    }

    .compare-badge span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
    }

    .compare-toggle {
      position: relative;
      z-index: 2;
      display: flex;
      gap: 8px;
      margin: 14px 18px 0;
      padding: 6px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.86);
      box-shadow: var(--shadow-light);
    }

    .compare-switch {
      flex: 1;
      min-height: 39px;
      box-shadow: none;
      background: transparent;
      border: 0;
      padding: 0 10px;
      font-size: 13px;
    }

    .compare-table {
      position: relative;
      z-index: 2;
      margin: 16px 16px 0;
      padding: 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: var(--shadow-light);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1.15fr repeat(4, 1fr);
      gap: 8px;
      align-items: stretch;
    }

    .compare-head,
    .compare-cell {
      padding: 12px 8px;
      border-radius: 14px;
      text-align: center;
    }

    .compare-head {
      background: #f6f9ff;
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 1.5;
      font-weight: 900;
    }

    .compare-head.ucarpac {
      background: rgba(248, 76, 162, 0.12);
    }

    .compare-cell {
      background: #fffdfa;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.6;
      font-weight: 700;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 82px;
    }

    .compare-cell strong {
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 1.2;
      font-weight: 900;
      margin-bottom: 4px;
    }

    .compare-cell.ucarpac {
      background: linear-gradient(180deg, rgba(248, 76, 162, 0.12), rgba(255, 255, 255, 0.96));
      box-shadow: inset 0 0 0 1px rgba(248, 76, 162, 0.12);
    }

    .compare-quote {
      margin: 12px 16px 0;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255, 248, 219, 0.92);
      box-shadow: var(--shadow-light);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.7;
      font-family: var(--font-note);
      position: relative;
      z-index: 2;
    }

    .screen-footer {
      position: relative;
      z-index: 2;
      margin: 14px 18px 0;
      padding: 10px 0 18px;
      color: #7a819c;
      font-size: 10px;
      line-height: 1.6;
      text-align: center;
      font-weight: 700;
    }

    .bottom-notes {
      margin-top: 24px;
      padding: 18px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-medium);
      display: grid;
      gap: 12px;
    }

    .bottom-notes h3 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 1.5;
      font-weight: 900;
    }

    .notes-grid {
      display: grid;
      gap: 12px;
    }

    .note-card {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: var(--shadow-light);
    }

    .note-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
    }

    .note-card span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
      font-weight: 700;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%) translateY(18px);
      min-width: 240px;
      max-width: calc(100vw - 32px);
      padding: 12px 16px;
      border-radius: 16px;
      background: rgba(9, 19, 85, 0.92);
      color: var(--white);
      font-size: 12px;
      line-height: 1.6;
      text-align: center;
      box-shadow: var(--shadow-heavy);
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease, transform 220ms ease;
      z-index: 50;
    }

    .toast.is-visible {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.08);
      }
    }

    @keyframes floatNote {
      0%, 100% {
        transform: translateY(0) rotate(var(--r, 0deg));
      }
      50% {
        transform: translateY(-6px) rotate(var(--r, 0deg));
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes pulseDot {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.15);
      }
    }

    @media (min-width: 860px) {
      .deck {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        align-items: start;
      }

      .bottom-notes .notes-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 859px) {
      .control-label {
        min-width: auto;
        width: 100%;
      }

      .hero-grid {
        grid-template-columns: 1fr 110px;
      }

      .compare-grid {
        grid-template-columns: 1fr repeat(4, 1fr);
      }
    }

    @media (max-width: 430px) {
      .page {
        padding: 14px 10px 42px;
      }

      .masthead,
      .control-panel,
      .shot,
      .bottom-notes {
        border-radius: 22px;
      }

      .shot {
        padding: 14px;
      }

      .hero h2,
      .compare-top h2 {
        font-size: 29px;
      }

      .price {
        font-size: 34px;
      }

      .expense-amount {
