    .masthead,
    .controls,
    .screens,
    .evidence {
      position: relative;
      z-index: 1;
    }

    .masthead {
      padding: 24px 18px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-medium);
      backdrop-filter: blur(18px);
      overflow: hidden;
    }

    .masthead::after {
      content: "";
      position: absolute;
      right: -36px;
      bottom: -48px;
      width: 220px;
      height: 220px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.22), transparent 70%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(9, 19, 85, 0.08);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .eyebrow .dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--pink);
      box-shadow: 0 0 0 8px rgba(248, 76, 162, 0.12);
      animation: pulse 2.2s ease-in-out infinite;
    }

    h1 {
      margin: 18px 0 10px;
      max-width: 820px;
      color: var(--dark-blue);
      font-size: clamp(32px, 5vw, 54px);
      line-height: 1.16;
      letter-spacing: -0.05em;
      font-weight: 900;
    }

    .lead {
      max-width: 860px;
      margin: 0;
      color: #66708c;
      font-size: 14px;
      line-height: 1.9;
    }

    .lead strong {
      color: var(--dark-blue);
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-top: 20px;
    }

    .kpi-card {
      padding: 16px;
      border-radius: 18px;
      background: var(--gradient-panel);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: var(--shadow-light);
    }

    .kpi-label {
      font-size: 11px;
      font-weight: 800;
      line-height: 1.5;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-gray);
    }

    .kpi-value {
      margin-top: 8px;
      display: flex;
      align-items: flex-end;
      gap: 8px;
      color: var(--dark-blue);
      font-size: 34px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .kpi-value span {
      font-size: 12px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 700;
      letter-spacing: 0;
    }

    .kpi-meta {
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .kpi-bar {
      margin-top: 10px;
      height: 8px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .kpi-bar > span {
      display: block;
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      animation: growBar 1.2s 0.1s ease forwards;
    }

    .controls {
      margin-top: 18px;
      padding: 16px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-medium);
      backdrop-filter: blur(16px);
      display: grid;
      gap: 12px;
    }

    .control-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .control-title {
      min-width: 108px;
      text-align: center;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .toggle {
      min-height: 43px;
      padding: 0 16px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      border-radius: var(--radius-button);
      background: rgba(255, 255, 255, 0.94);
      color: var(--dark-blue);
      box-shadow: var(--shadow-light);
      font-size: 13px;
      font-weight: 800;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease, border-color 180ms ease;
    }

    .toggle:hover {
      transform: translateY(-1px);
    }

    .toggle.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: transparent;
    }

    .toggle.accent.active {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .screens {
      margin-top: 22px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
      align-items: start;
    }

    .device-column {
      display: grid;
      gap: 12px;
    }

    .device-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 0 6px;
    }

    .device-title {
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.5;
      font-weight: 900;
    }

    .device-subtitle {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .device-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(9, 19, 85, 0.08);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .phone {
      position: relative;
      width: 100%;
      max-width: 420px;
      margin: 0 auto;
      padding: 14px;
      border-radius: 42px;
      background: linear-gradient(180deg, #fefefe 0%, #eef3ff 100%);
      box-shadow: var(--shadow-heavy);
    }

    .phone::before {
      content: "";
      position: absolute;
      inset: 10px;
      border-radius: 34px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      pointer-events: none;
    }

    .screen {
      position: relative;
      min-height: var(--phone-height);
      border-radius: var(--radius-phone);
      overflow: hidden;
      background:
        radial-gradient(circle at 12% 12%, rgba(248, 76, 162, 0.22), transparent 24%),
        radial-gradient(circle at 100% 0%, rgba(29, 220, 255, 0.18), transparent 20%),
        linear-gradient(180deg, #fbfdff 0%, #f5f9ff 42%, #fff5fb 100%);
      color: var(--text-black);
    }

    .screen.dark {
      background:
        radial-gradient(circle at 18% 12%, rgba(248, 76, 162, 0.28), transparent 22%),
        radial-gradient(circle at 100% 0%, rgba(29, 220, 255, 0.22), transparent 18%),
        linear-gradient(180deg, #0b165e 0%, #0f1e7a 52%, #081146 100%);
      color: var(--white);
    }

    .status-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 18px 0;
      font-size: 11px;
      line-height: 1.5;
      font-weight: 800;
      color: inherit;
    }

    .status-icons {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .notch {
      width: 124px;
      height: 30px;
      border-radius: 0 0 18px 18px;
      margin: 0 auto;
      background: rgba(10, 19, 72, 0.94);
    }

    .screen-inner {
      padding: 18px 18px 22px;
      display: grid;
      gap: 14px;
    }

    .hero-card,
    .panel,
    .info-card,
    .mini-panel,
    .compare-card {
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .screen.dark .hero-card,
    .screen.dark .panel,
    .screen.dark .info-card,
    .screen.dark .mini-panel,
    .screen.dark .compare-card {
      background: rgba(255, 255, 255, 0.10);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: none;
      backdrop-filter: blur(12px);
    }

    .hero-card {
      padding: 18px;
      position: relative;
      overflow: hidden;
    }

    .hero-card::after {
      content: "";
      position: absolute;
      top: -40px;
      right: -26px;
      width: 130px;
      height: 130px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.18), transparent 70%);
      pointer-events: none;
    }

    .screen.dark .hero-card::after {
      background: radial-gradient(circle, rgba(29, 220, 255, 0.22), transparent 70%);
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 10px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      line-height: 1.5;
      font-weight: 800;
      letter-spacing: 0.04em;
      background: rgba(9, 19, 85, 0.08);
      color: var(--dark-blue);
    }

    .screen.dark .chip {
      background: rgba(255, 255, 255, 0.12);
      color: var(--white);
    }

    .chip.pink {
      background: rgba(248, 76, 162, 0.14);
      color: var(--pink);
    }

    .hero-title {
      margin: 0;
      font-size: 13px;
      line-height: 1.6;
      font-weight: 800;
      color: var(--text-gray);
    }

    .screen.dark .hero-title {
      color: rgba(255, 255, 255, 0.72);
    }

    .car-name {
      margin: 6px 0 0;
      font-size: 24px;
      line-height: 1.35;
      font-weight: 900;
      letter-spacing: -0.03em;
      color: var(--dark-blue);
    }

    .screen.dark .car-name {
      color: var(--white);
    }

    .car-meta {
      margin-top: 4px;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .screen.dark .car-meta {
      color: rgba(255, 255, 255, 0.72);
    }

    .hero-metric {
      margin-top: 16px;
      display: flex;
      align-items: flex-end;
      gap: 8px;
    }

    .hero-metric .value {
      font-size: 52px;
      line-height: 0.9;
      font-weight: 900;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
    }

    .screen.dark .hero-metric .value {
      color: var(--white);
    }

    .hero-metric .unit {
      padding-bottom: 8px;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 800;
    }

    .screen.dark .hero-metric .unit {
      color: rgba(255, 255, 255, 0.72);
    }

    .hero-caption {
      margin-top: 8px;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .screen.dark .hero-caption {
      color: rgba(255, 255, 255, 0.8);
    }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .info-card {
      padding: 12px;
    }

    .info-label {
      font-size: 10px;
      line-height: 1.5;
      font-weight: 800;
      color: var(--text-gray);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .screen.dark .info-label {
      color: rgba(255, 255, 255, 0.64);
    }

    .info-value {
      margin-top: 6px;
      font-size: 20px;
      line-height: 1.3;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .screen.dark .info-value {
      color: var(--white);
    }

    .info-note {
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .screen.dark .info-note {
      color: rgba(255, 255, 255, 0.62);
    }

    .panel {
      padding: 16px;
    }

    .panel-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .panel-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
      font-weight: 900;
    }

    .screen.dark .panel-title {
      color: var(--white);
    }

    .panel-desc {
      margin: 2px 0 0;
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .screen.dark .panel-desc {
      color: rgba(255, 255, 255, 0.68);
    }

    .panel-tag {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(248, 76, 162, 0.12);
      color: var(--pink);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .screen.dark .panel-tag {
      background: rgba(29, 220, 255, 0.16);
      color: #8fe9ff;
    }

    .chart-box {
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.04);
      padding: 14px 12px 10px;
    }

    .screen.dark .chart-box {
      background: rgba(255, 255, 255, 0.08);
    }

    svg {
      display: block;
      width: 100%;
      height: auto;
    }

    .axis-label {
      font-size: 10px;
      line-height: 1.5;
      fill: #7b849e;
      font-weight: 700;
    }

    .screen.dark .axis-label {
      fill: rgba(255, 255, 255, 0.62);
    }

    .grid-line {
      stroke: rgba(28, 38, 99, 0.10);
      stroke-width: 1;
      stroke-dasharray: 4 4;
    }

    .screen.dark .grid-line {
      stroke: rgba(255, 255, 255, 0.12);
    }

    .forecast-line,
    .expense-line {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 4;
      stroke-dasharray: 360;
      stroke-dashoffset: 360;
      animation: drawLine 1.2s ease forwards;
    }

    .forecast-line {
      stroke: var(--pink);
    }

    .expense-line {
      stroke: #1ddcff;
    }

    .point {
      fill: var(--white);
      stroke-width: 4;
      transform-origin: center;
      animation: pointPop 420ms ease forwards;
      opacity: 0;
    }

    .point.pink {
      stroke: var(--pink);
    }

    .point.cyan {
      stroke: #1ddcff;
    }

    .point.delay-1 {
      animation-delay: 0.2s;
    }

    .point.delay-2 {
      animation-delay: 0.35s;
    }

    .point.delay-3 {
      animation-delay: 0.5s;
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 10px;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 700;
    }

    .screen.dark .legend-item {
      color: rgba(255, 255, 255, 0.72);
    }

    .legend-swatch {
      width: 12px;
      height: 12px;
      border-radius: 999px;
    }

    .bars {
      display: grid;
      gap: 10px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 76px minmax(0, 1fr) 54px;
      align-items: center;
      gap: 10px;
    }

    .bar-label,
    .bar-value {
      font-size: 11px;
      line-height: 1.6;
      font-weight: 800;
      color: var(--text-gray);
    }

    .screen.dark .bar-label,
    .screen.dark .bar-value {
      color: rgba(255, 255, 255, 0.72);
    }

    .bar-track {
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .screen.dark .bar-track {
      background: rgba(255, 255, 255, 0.12);
    }

    .bar-fill {
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      animation: growBar 1.1s ease forwards;
    }

    .bar-fill.pink {
      background: var(--gradient-pink);
    }

    .summary-strip {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .mini-panel {
      padding: 12px;
    }

    .mini-label {
      font-size: 10px;
      line-height: 1.5;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-gray);
    }

    .screen.dark .mini-label {
      color: rgba(255, 255, 255, 0.64);
    }

    .mini-number {
      margin-top: 6px;
      color: var(--dark-blue);
      font-size: 28px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .screen.dark .mini-number {
      color: var(--white);
    }

    .mini-copy {
      margin-top: 6px;
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .screen.dark .mini-copy {
      color: rgba(255, 255, 255, 0.68);
    }

    .cta {
      min-height: 54px;
      border: none;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
      letter-spacing: 0.01em;
      box-shadow: 0 16px 28px rgba(29, 220, 255, 0.28);
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 18px 34px rgba(29, 220, 255, 0.36);
    }

    .cta.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 16px 28px rgba(248, 76, 162, 0.28);
    }

    .caption-foot {
      text-align: center;
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
      padding: 2px 8px 0;
    }

    .compare-card {
      padding: 14px;
    }

    .compare-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
    }

    .compare-tab {
      flex: 1;
      min-height: 38px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.76);
      font-size: 12px;
      font-weight: 800;
    }

    .compare-tab.active {
      background: var(--white);
      color: var(--dark-blue);
      border-color: transparent;
    }

    .compare-headline {
      margin: 0;
      font-size: 28px;
      line-height: 1.15;
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .compare-subline {
      margin-top: 8px;
      font-size: 13px;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.78);
    }

    .zero-call {
      margin-top: 14px;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 10px;
    }

    .burden-box {
      border-radius: 22px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.10);
    }

    .burden-label {
      font-size: 11px;
      line-height: 1.6;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.64);
    }

    .burden-value {
      margin-top: 8px;
      font-size: 54px;
      line-height: 0.9;
      font-weight: 900;
      letter-spacing: -0.05em;
      color: var(--white);
    }

    .burden-copy {
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.82);
    }

    .scoreboard {
      display: grid;
      gap: 10px;
    }

    .score-item {
      display: grid;
      grid-template-columns: 1fr 78px;
      gap: 10px;
      align-items: center;
    }

    .score-label {
      font-size: 11px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.72);
      font-weight: 800;
    }

    .score-track {
      position: relative;
      height: 12px;
      margin-top: 6px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.10);
      overflow: hidden;
    }

    .score-fill {
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      animation: growBar 1s ease forwards;
    }

    .score-fill.pink {
      background: var(--gradient-pink);
    }

    .score-number {
      text-align: right;
      font-size: 18px;
      line-height: 1.3;
      font-weight: 900;
      color: var(--white);
    }

    .table {
      margin-top: 14px;
      border-radius: 22px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.10);
    }

    .table-row {
      display: grid;
      grid-template-columns: 1.15fr 0.95fr 0.8fr 0.8fr;
      gap: 1px;
      background: rgba(255, 255, 255, 0.08);
    }

    .table-row + .table-row {
      margin-top: 1px;
    }

    .cell {
      min-height: 46px;
      padding: 10px 10px;
      display: flex;
      align-items: center;
      font-size: 11px;
      line-height: 1.6;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.86);
      background: rgba(255, 255, 255, 0.06);
    }

    .cell.head {
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 900;
      color: rgba(255, 255, 255, 0.64);
      background: rgba(255, 255, 255, 0.10);
    }

    .cell.main {
      background: rgba(29, 220, 255, 0.16);
      color: var(--white);
      font-weight: 900;
    }

    .cell.win {
      color: #9ff0ff;
      font-weight: 900;
    }

    .cell.loss {
      color: rgba(255, 255, 255, 0.72);
    }

    .insight-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .insight-badge {
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.10);
      color: var(--white);
      font-size: 11px;
      line-height: 1.5;
      font-weight: 800;
    }

    .evidence {
      margin-top: 22px;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 18px;
    }

    .evidence-card {
      padding: 18px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.80);
      border: 1px solid rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-medium);
      backdrop-filter: blur(16px);
    }

    .evidence-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.5;
      font-weight: 900;
    }

    .evidence-copy {
      margin: 6px 0 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.8;
    }

    .evidence-grid {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .evidence-tile {
      padding: 14px;
      border-radius: 18px;
      background: rgba(9, 19, 85, 0.04);
    }

    .evidence-tile strong {
      display: block;
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 1.2;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .evidence-tile span {
      display: block;
      margin-top: 6px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
      font-weight: 700;
    }

    .timeline {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .timeline-row {
      display: grid;
      grid-template-columns: 84px minmax(0, 1fr);
      gap: 12px;
      align-items: center;
    }

    .timeline-label {
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 1.6;
      font-weight: 800;
    }

    .timeline-track {
      position: relative;
      height: 14px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .timeline-fill {
      position: relative;
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: var(--gradient-primary);
      animation: growBar 1.1s ease forwards;
    }

    .timeline-fill.pink {
      background: var(--gradient-pink);
    }

    .timeline-note {
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.18);
      }
      50% {
        transform: scale(1.08);
        box-shadow: 0 0 0 10px rgba(248, 76, 162, 0);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes pointPop {
      0% {
        opacity: 0;
        transform: scale(0.3);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes growBar {
      to {
        width: var(--target, 100%);
      }
    }

    @media (max-width: 1180px) {
      .screens,
      .evidence {
        grid-template-columns: 1fr;
      }

      .kpi-strip {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .page {
        padding-inline: 10px;
      }

      .masthead,
      .controls,
      .evidence-card {
        border-radius: 24px;
      }

      .kpi-strip,
      .metric-grid,
      .summary-strip,
      .evidence-grid {
        grid-template-columns: 1fr;
      }

      .control-title {
        min-width: auto;
        width: 100%;
      }

      .phone {
        padding: 10px;
        border-radius: 30px;
      }

      .screen {
        min-height: auto;
      }

      .hero-metric .value,
      .burden-value {
        font-size: 44px;
      }

      .zero-call {
        grid-template-columns: 1fr;
      }

      .table-row {
        grid-template-columns: 1.1fr 0.9fr 0.8fr 0.8fr;
      }

      .timeline-row {
        grid-template-columns: 72px minmax(0, 1fr);
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="masthead">
      <div class="eyebrow"><span class="dot"></span>ASO検証 / ストアPV→DL率 改善プロトタイプ</div>
      <h1>数字で納得させる3枚構成。<br>17.3%の詳細閲覧CVRを、25%へ寄せる。</h1>
      <p class="lead">
        ストア詳細ページでは、<strong>一目で価値がわかる数字</strong>と、<strong>競合より迷わない比較軸</strong>が必要です。
        このプロトタイプは、<strong>AI査定</strong>、<strong>出費管理＋将来予測</strong>、<strong>電話0本比較</strong>を
        それぞれ1枚で完結させ、閲覧直後の理解負荷を下げながらDL動機を強める前提で設計しています。
      </p>
      <div class="kpi-strip">
        <article class="kpi-card">
          <div class="kpi-label">現在CVR</div>
          <div class="kpi-value">17.3<span>%</span></div>
          <div class="kpi-meta">ストア詳細ページ閲覧からDLまでの現状値</div>
          <div class="kpi-bar"><span style="--target:17.3%;"></span></div>
        </article>
        <article class="kpi-card">
          <div class="kpi-label">目標CVR</div>
          <div class="kpi-value">25.0<span>%</span></div>
          <div class="kpi-meta">差分は+7.7pt。3枚で訴求軸を分担する</div>
          <div class="kpi-bar"><span style="--target:25%;"></span></div>
        </article>
        <article class="kpi-card">
          <div class="kpi-label">主要独自性</div>
          <div class="kpi-value">3<span>項目</span></div>
          <div class="kpi-meta">AI査定 / 将来予測 / 出費管理を分解訴求</div>
          <div class="kpi-bar"><span style="--target:78%;"></span></div>
        </article>
        <article class="kpi-card">
          <div class="kpi-label">比較訴求</div>
          <div class="kpi-value">0<span>本</span></div>
          <div class="kpi-meta">相場確認時の電話負担を大きく可視化</div>
          <div class="kpi-bar"><span style="--target:92%;"></span></div>
        </article>
      </div>
    </section>

    <section class="controls">
      <div class="control-row">
        <div class="control-title">査定期間</div>
        <button class="toggle active" data-period="now">いま売る</button>
        <button class="toggle" data-period="3m">3か月後</button>
        <button class="toggle" data-period="6m">6か月後</button>
      </div>
      <div class="control-row">
        <div class="control-title">比較軸</div>
        <button class="toggle accent active" data-compare="estimate">相場確認時</button>
        <button class="toggle accent" data-compare="contact">売却相談時</button>
      </div>
    </section>

    <section class="screens">
      <article class="device-column">
        <div class="device-header">
          <div>
            <div class="device-title">スクショA</div>
            <div class="device-subtitle">iOS向け / AI査定を最短理解させる1枚</div>
          </div>
          <div class="device-badge">iOS</div>
        </div>
        <div class="phone">
          <div class="screen" id="screen-a">
            <div class="status-bar">
              <span>9:41</span>
              <div class="notch"></div>
              <div class="status-icons"><span>5G</span><span>100%</span></div>
            </div>
            <div class="screen-inner">
              <section class="hero-card">
                <div class="chip-row">
                  <span class="chip pink">AI査定</span>
                  <span class="chip">個人情報不要</span>
                  <span class="chip">予測更新 毎日</span>
                </div>
                <p class="hero-title">今の相場と、次の売り時を同時に表示</p>
                <h2 class="car-name">トヨタ ハリアー Z Leather</h2>
                <div class="car-meta">2021年 / 31,800km / パール / 2WD</div>
                <div class="hero-metric">
                  <div class="value" id="a-price">312.4</div>
                  <div class="unit">万円</div>
                </div>
                <div class="hero-caption" id="a-caption">いま売ると想定最高レンジ。AI更新から24時間以内の予測です。</div>
              </section>

              <div class="metric-grid">
                <article class="info-card">
                  <div class="info-label">予測精度</div>
                  <div class="info-value">92%</div>
                  <div class="info-note">概算価格より入力後に精度上昇</div>
                </article>
                <article class="info-card">
                  <div class="info-label">相場差</div>
                  <div class="info-value" id="a-gap">+18.2万</div>
