      margin: 0 auto;
      padding: 24px 16px 56px;
    }

    .page::before,
    .page::after {
      content: "";
      position: fixed;
      width: 220px;
      height: 220px;
      border-radius: 999px;
      filter: blur(32px);
      opacity: 0.55;
      pointer-events: none;
      z-index: 0;
    }

    .page::before {
      left: -40px;
      top: 80px;
      background: rgba(255, 182, 142, 0.24);
    }

    .page::after {
      right: -50px;
      bottom: 60px;
      background: rgba(111, 194, 255, 0.2);
    }

    .intro,
    .controls,
    .deck,
    .notes {
      position: relative;
      z-index: 1;
    }

    .intro {
      max-width: 920px;
      margin: 0 auto 28px;
      text-align: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.8);
      color: var(--dark-blue);
      border: 1px solid rgba(248, 76, 162, 0.18);
      box-shadow: var(--shadow-light);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.03em;
    }

    .eyebrow .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--pink);
      box-shadow: 0 0 0 6px rgba(248, 76, 162, 0.12);
    }

    h1 {
      margin: 18px 0 12px;
      font-size: clamp(32px, 6vw, 52px);
      line-height: 1.22;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
      font-weight: 900;
    }

    .intro-copy {
      margin: 0 auto;
      max-width: 760px;
      font-size: 15px;
      line-height: 1.9;
      color: #666884;
    }

    .intro-copy .marker {
      background: linear-gradient(transparent 60%, rgba(255, 214, 126, 0.7) 60%);
      padding: 0 2px;
    }

    .stat-strip {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin-top: 18px;
    }

    .stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.82);
      box-shadow: var(--shadow-light);
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .stat-pill strong {
      color: var(--pink);
      font-size: 13px;
    }

    .controls {
      display: grid;
      gap: 14px;
      max-width: 1120px;
      margin: 0 auto 26px;
      padding: 18px;
      background: rgba(255,255,255,0.74);
      backdrop-filter: blur(14px);
      border-radius: 24px;
      box-shadow: var(--shadow-medium);
      border: 1px solid rgba(255,255,255,0.7);
    }

    .control-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: center;
    }

    .control-label {
      font-size: 12px;
      font-weight: 800;
      color: var(--text-gray);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .segmented,
    .vehicle-switch,
    .mode-switch {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .tab-button,
    .vehicle-button,
    .mode-button {
      appearance: none;
      border: 1px solid rgba(28,38,99,0.1);
      background: rgba(255,255,255,0.92);
      color: var(--dark-blue);
      min-height: 43px;
      padding: 0 16px;
      border-radius: 30px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease, border-color 180ms ease;
      box-shadow: var(--shadow-light);
    }

    .tab-button:hover,
    .vehicle-button:hover,
    .mode-button:hover {
      transform: translateY(-1px);
    }

    .tab-button.is-active,
    .vehicle-button.is-active,
    .mode-button.is-active {
      background: var(--gradient-pink);
      border-color: rgba(248, 76, 162, 0.2);
      color: var(--white);
    }

    .mode-switch {
      margin-top: 2px;
    }

    .deck {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      align-items: start;
    }

    .shot {
      position: relative;
      padding: 18px;
      border-radius: 28px;
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(255,255,255,0.78);
      box-shadow: var(--shadow-medium);
      backdrop-filter: blur(12px);
      transition: transform 220ms ease, box-shadow 220ms ease, opacity 220ms ease;
    }

    .shot.is-focused {
      transform: translateY(-4px);
      box-shadow: var(--shadow-heavy);
    }

    .shot-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .shot-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: #fff3f7;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
    }

    .shot-tag.android {
      background: #eef8ff;
    }

    .shot-tag.compare {
      background: #fff7e7;
    }

    .shot-title {
      margin: 4px 0 0;
      font-size: 23px;
      line-height: 1.45;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .shot-desc {
      margin: 8px 0 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
      max-width: 520px;
    }

    .shot-side-note {
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.9);
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
      box-shadow: var(--shadow-light);
      max-width: 188px;
    }

    .phone {
      width: 100%;
      max-width: var(--phone-width);
      margin: 0 auto;
      padding: 14px;
      border-radius: 36px;
      background: #20253f;
      position: relative;
      box-shadow: 0 26px 56px rgba(9, 19, 85, 0.32);
    }

    .phone::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 8px;
      transform: translateX(-50%);
      width: 128px;
      height: 26px;
      border-radius: 0 0 16px 16px;
      background: #11152a;
      z-index: 5;
    }

    .phone.android::before {
      width: 16px;
      height: 16px;
      top: 10px;
      border-radius: 999px;
      background: #11152a;
    }

    .screen {
      position: relative;
      min-height: 760px;
      overflow: hidden;
      border-radius: 24px;
      background: var(--gradient-soft);
    }

    .screen::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 18% 18%, rgba(255,255,255,0.72), transparent 16%),
        radial-gradient(circle at 82% 14%, rgba(255,255,255,0.56), transparent 16%);
      pointer-events: none;
    }

    .screen-ios {
      background:
        radial-gradient(circle at 82% 14%, rgba(255,255,255,0.86), transparent 18%),
        linear-gradient(180deg, #fff8f2 0%, #ffe6ee 44%, #ecf8ff 100%);
    }

    .screen-android {
      background:
        radial-gradient(circle at 88% 18%, rgba(255,255,255,0.76), transparent 15%),
        linear-gradient(180deg, #fff7f1 0%, #fff0e3 25%, #eef8ff 100%);
    }

    .screen-compare {
      background:
        radial-gradient(circle at 16% 12%, rgba(255,255,255,0.76), transparent 18%),
        linear-gradient(180deg, #fff9f3 0%, #ffe7ef 54%, #edf7ff 100%);
    }

    .status-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 18px 8px;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      position: relative;
      z-index: 2;
    }

    .hero {
      position: relative;
      padding: 6px 18px 0;
      z-index: 2;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 128px;
      gap: 10px;
      align-items: center;
    }

    .hero h2 {
      margin: 10px 0 8px;
      color: var(--dark-blue);
      font-size: 33px;
      line-height: 1.28;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .hero p {
      margin: 0;
      font-size: 13px;
      line-height: 1.75;
      color: #656989;
    }

    .hero .line-mark {
      display: inline;
      background: linear-gradient(transparent 58%, rgba(255, 218, 120, 0.72) 58%);
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
    }

    .mini-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.9);
      box-shadow: var(--shadow-light);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .mini-badge.pink {
      background: rgba(248, 76, 162, 0.14);
      color: #b81c6a;
    }

    .mini-badge.yellow {
      background: rgba(255, 236, 177, 0.78);
    }

    .doodle-figure {
      position: relative;
      width: 124px;
      height: 134px;
      margin-left: auto;
    }

    .doodle-figure .blob {
      position: absolute;
      inset: 12px 10px 10px 12px;
      border-radius: 28px;
      background: linear-gradient(180deg, #fffefa 0%, #ffeef5 100%);
      border: 1px solid rgba(248,76,162,0.12);
      box-shadow: var(--shadow-light);
    }

    .doodle-figure .car {
      position: absolute;
      left: 20px;
      bottom: 18px;
      width: 82px;
      height: 36px;
      border-radius: 20px 22px 14px 14px;
      background: linear-gradient(180deg, #ff8fb4 0%, #f84ca2 100%);
    }

    .doodle-figure .car::before,
    .doodle-figure .car::after {
      content: "";
      position: absolute;
      bottom: -7px;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      background: #1c2663;
      box-shadow: inset 0 0 0 4px #fff;
    }

    .doodle-figure .car::before {
      left: 10px;
    }

    .doodle-figure .car::after {
      right: 10px;
    }

    .doodle-figure .ai-face {
      position: absolute;
      right: 12px;
      top: 18px;
      width: 48px;
      height: 48px;
      border-radius: 999px;
      background: #fff7d9;
      box-shadow: var(--shadow-light);
    }

    .doodle-figure .ai-face::before,
    .doodle-figure .ai-face::after {
      content: "";
      position: absolute;
      top: 18px;
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: var(--dark-blue);
    }

    .doodle-figure .ai-face::before {
      left: 14px;
    }

    .doodle-figure .ai-face::after {
      right: 14px;
    }

    .doodle-figure .smile {
      position: absolute;
      left: 15px;
      bottom: 12px;
      width: 18px;
      height: 9px;
      border-bottom: 3px solid var(--dark-blue);
      border-radius: 0 0 18px 18px;
    }

    .sticky,
    .sticky-small {
      position: absolute;
      border-radius: 16px;
      background: rgba(255,255,255,0.94);
      box-shadow: var(--shadow-light);
      font-weight: 800;
      color: var(--dark-blue);
      transform-origin: center;
      animation: floatNote 5.8s ease-in-out infinite;
    }

    .sticky {
      padding: 10px 12px;
      font-size: 11px;
      line-height: 1.5;
    }

    .sticky-small {
      padding: 7px 10px;
      font-size: 10px;
      line-height: 1.4;
    }

    .sticky.note-a1 {
      left: 18px;
      top: 120px;
      background: #fff4bf;
      transform: rotate(-7deg);
    }

    .sticky.note-a2 {
      right: 18px;
      top: 174px;
      background: #ffffff;
      color: #ff7a61;
      transform: rotate(7deg);
      animation-delay: 1s;
    }

    .sticky.note-b1 {
      right: 18px;
      top: 134px;
      background: #fff7d9;
      transform: rotate(-5deg);
    }

    .sticky.note-c1 {
      left: 20px;
      top: 122px;
      background: #fff4bf;
      transform: rotate(-6deg);
    }

    .sticky-small.note-c2 {
      right: 22px;
      top: 172px;
      background: #fff;
      color: #ff7a61;
      transform: rotate(5deg);
      animation-delay: 1.4s;
    }

    .card {
      position: relative;
      margin: 16px 16px 0;
      padding: 16px;
      border-radius: var(--radius-card);
      background: var(--gradient-card);
      box-shadow: var(--shadow-light);
      overflow: hidden;
      z-index: 2;
    }

    .card.dark {
      background: var(--gradient-night);
      color: var(--white);
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 10px;
    }

    .card-title {
      margin: 0;
      font-size: 18px;
      line-height: 1.5;
      font-weight: 900;
    }

    .card-caption {
      margin: 4px 0 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .card.dark .card-caption {
      color: rgba(255,255,255,0.78);
    }

    .price {
      font-size: 40px;
      line-height: 1.1;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .card.dark .price {
      color: #fff;
    }

    .yen {
      font-size: 18px;
      margin-left: 4px;
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 30px;
      padding: 0 10px;
      border-radius: 999px;
      background: #f3f8ff;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .card.dark .pill {
      background: rgba(255,255,255,0.14);
      color: #fff;
    }

    .graph {
      margin-top: 14px;
      padding: 14px 14px 10px;
      border-radius: 12px;
      background:
        repeating-linear-gradient(to top, rgba(28,38,99,0.06) 0 1px, transparent 1px 25px),
        linear-gradient(180deg, #ffffff, #fbfdff);
      overflow: hidden;
    }

    .graph-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 11px;
      color: #7b7f97;
      font-weight: 700;
    }

    .graph svg {
      width: 100%;
      height: 120px;
      display: block;
    }

    .graph-line {
      fill: none;
      stroke: var(--pink);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1.6s ease forwards;
    }

    .graph-area {
      fill: rgba(248, 76, 162, 0.12);
    }

    .graph-dot {
      fill: var(--pink);
      stroke: #fff;
      stroke-width: 3;
      animation: pulseDot 2.4s ease-in-out infinite;
    }

    .three-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .mini-stat {
      padding: 10px;
      border-radius: 12px;
      background: rgba(255,255,255,0.92);
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.05);
      text-align: center;
    }

    .mini-stat strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 900;
      line-height: 1.4;
    }

    .mini-stat span {
      font-size: 10px;
      color: var(--text-gray);
      line-height: 1.5;
      font-weight: 700;
    }

    .primary-button {
      width: 100%;
      min-height: 43px;
      margin-top: 14px;
      border: 0;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.01em;
      box-shadow: var(--shadow-light);
      cursor: pointer;
      transition: transform 180ms ease, filter 180ms ease;
    }

    .primary-button:hover {
      transform: translateY(-1px);
      filter: saturate(1.06);
    }

    .secondary-button {
      width: 100%;
      min-height: 43px;
      margin-top: 10px;
      border: 0;
      border-radius: var(--radius-button);
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow: var(--shadow-light);
    }

    .expense-total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .expense-amount {
      font-size: 34px;
      line-height: 1.2;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .expense-bar {
      height: 10px;
      border-radius: 999px;
      background: #eef3f8;
      overflow: hidden;
      position: relative;
    }

    .expense-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: var(--fill, 50%);
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(248,76,162,0.8), rgba(77,180,255,0.8));
      transition: width 280ms ease;
    }

    .forecast-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .forecast-box {
      padding: 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.9);
      text-align: center;
    }

    .forecast-box strong {
      display: block;
      font-size: 20px;
      line-height: 1.35;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .forecast-box span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .compare-top {
      padding: 12px 18px 0;
      position: relative;
      z-index: 2;
    }

    .compare-toggle {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 12px;
      padding: 4px;
      border-radius: 999px;
      background: rgba(255,255,255,0.76);
      box-shadow: var(--shadow-light);
    }

    .compare-switch {
      appearance: none;
      border: 0;
      min-height: 38px;
      border-radius: 999px;
      background: transparent;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease;
    }

    .compare-switch.is-active {
      background: var(--gradient-pink);
      color: #fff;
    }

    .compare-highlight {
      margin-top: 14px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.9);
      box-shadow: var(--shadow-light);
      text-align: center;
    }

    .compare-highlight .big {
      display: block;
      font-size: 34px;
      line-height: 1.12;
      font-weight: 900;
      color: var(--pink);
      letter-spacing: -0.04em;
    }

    .compare-highlight .sub {
      margin-top: 4px;
      display: block;
      font-size: 12px;
      color: var(--text-gray);
      font-weight: 700;
      line-height: 1.6;
    }

    .compare-table {
      margin: 16px 16px 0;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: var(--shadow-light);
      background: rgba(255,255,255,0.96);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 92px 1fr 1fr;
    }

    .compare-head,
    .compare-cell {
      padding: 12px 10px;
      border-bottom: 1px solid var(--ruled-line);
      font-size: 12px;
      line-height: 1.6;
    }

    .compare-head {
      font-weight: 900;
      color: var(--dark-blue);
      background: #f8fbff;
    }

    .compare-head.ucarpac {
      background: #fff1f7;
      color: #bc216f;
    }

    .compare-head.other {
      background: #f3f6fa;
      color: #6d728d;
    }

    .compare-label {
      background: #fffaf2;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .compare-cell strong {
      display: block;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-cell span {
      color: var(--text-gray);
      font-weight: 700;
      font-size: 11px;
    }

    .compare-cell.ucarpac strong {
      color: #b81c6a;
    }

    .auction-card {
      margin: 14px 16px 0;
      padding: 16px;
      border-radius: 16px;
      background: var(--gradient-night);
      color: #fff;
      box-shadow: var(--shadow-light);
    }

    .auction-card h3 {
      margin: 0;
      font-size: 18px;
      line-height: 1.5;
      font-weight: 900;
    }

    .auction-card p {
      margin: 6px 0 0;
      font-size: 12px;
      line-height: 1.8;
      color: rgba(255,255,255,0.82);
    }

    .auction-band {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .auction-pill {
      min-height: 30px;
      padding: 0 10px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      font-size: 11px;
      font-weight: 800;
      background: rgba(255,255,255,0.14);
    }

    .screen-footer {
      padding: 18px 18px 22px;
      color: #6d728d;
      font-size: 11px;
      line-height: 1.7;
      font-weight: 700;
    }

    .progress-dots {
      display: flex;
      gap: 8px;
      justify-content: center;
      margin-top: 10px;
    }

    .progress-dots span {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: rgba(28,38,99,0.16);
    }

    .progress-dots span.is-active {
      background: var(--pink);
      box-shadow: 0 0 0 6px rgba(248, 76, 162, 0.12);
    }

    .notes {
      display: grid;
      gap: 12px;
      max-width: 1120px;
      margin: 26px auto 0;
    }

    .note-card {
      padding: 16px 18px;
      border-radius: 18px;
      background: rgba(255,255,255,0.74);
      box-shadow: var(--shadow-light);
      backdrop-filter: blur(10px);
    }

    .note-card h3 {
      margin: 0 0 8px;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .note-card p {
      margin: 0;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes pulseDot {
      0%, 100% {
        transform: scale(1);
        opacity: 1;
      }
      50% {
        transform: scale(1.08);
        opacity: 0.84;
      }
    }

    @keyframes floatNote {
      0%, 100% {
        transform: translateY(0) rotate(-5deg);
      }
      50% {
        transform: translateY(-5px) rotate(-3deg);
      }
    }

    @media (min-width: 760px) {
      .controls {
        padding: 20px 22px;
      }

      .notes {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (min-width: 1120px) {
      .deck {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .shot {
        min-height: 100%;
      }
    }

    @media (max-width: 420px) {
      .page {
        padding-inline: 10px;
      }

      .shot {
        padding: 14px;
      }

      .phone {
        padding: 12px;
      }

      .hero-grid {
        grid-template-columns: 1fr 112px;
      }

      .hero h2 {
        font-size: 29px;
      }

      .price {
        font-size: 36px;
      }

      .expense-amount {
        font-size: 31px;
      }

      .compare-grid {
        grid-template-columns: 80px 1fr 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="page">
