+      const currentCvr = document.getElementById("currentCvr");
+      const gapValue = document.getElementById("gapValue");
+      const currentBar = document.getElementById("currentBar");
+      const gapBar = document.getElementById("gapBar");
+      const statusCopy = document.getElementById("statusCopy");
+
+      const forecastDelta = document.getElementById("forecastDelta");
+      const forecastPrice = document.getElementById("forecastPrice");
+      const forecastLabel = document.getElementById("forecastLabel");
+      const forecastAction = document.getElementById("forecastAction");
+      const forecastActionLabel = document.getElementById("forecastActionLabel");
+      const timingScore = document.getElementById("timingScore");
