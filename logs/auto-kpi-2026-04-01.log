      dom.cSell.textContent = isCheck ? "売る時だけ1社" : "オークションでも負担が少ない";
    }

    function setActiveButton(selector, value, attr) {
      document.querySelectorAll(selector).forEach((button) => {
        button.classList.toggle("is-active", button.getAttribute(attr) === value);
      });
    }

    document.querySelectorAll(".vehicle-button").forEach((button) => {
