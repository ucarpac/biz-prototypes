      dom.bOwnerNote.textContent = data.ownerNote;
      dom.bRetention.textContent = data.retention;
      updateGraph(dom.aGraphLine, dom.aGraphArea, data.aPath, data.aDots);
      updateGraph(dom.bGraphLine, dom.bGraphArea, data.bPath, data.bDots);
    }

    function applyMode(mode) {
      const isCheck = mode === "check";
      dom.cHighlightMain.textContent = isCheck ? "電話0本" : "売る時だけ1社";
