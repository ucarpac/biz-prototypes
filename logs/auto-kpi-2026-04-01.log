        </article>
        <article class="kpi-card">
          <div class="kpi-label">必要改善幅</div>
          <div class="kpi-value" id="gapValue">+7.7<span>pt</span></div>
          <div class="progress-rail"><div class="progress-fill" id="gapBar" style="--fill:30.8%;"></div></div>
        </article>
        <article class="kpi-card">
          <div class="kpi-label">検証パターン</div>
          <div class="kpi-value" id="variantValue">3<span>screens</span></div>
          <div class="progress-rail"><div class="progress-fill" style="--fill:84%;"></div></div>
        </article>
      </div>
    </section>

    <section class="control-panel">
      <div class="control-row">
        <div class="control-title">KPIシナリオ</div>
