  <script>
    const vehicles = {
      prius: {
        name: "トヨタ プリウス Z",
        meta: "2021年 / 32,400km / パールホワイト",
        priceNow: "184.6",
        price3: "179.2",
        price6: "173.8",
        marketNote: "春の需要で、しばらく堅調です",
        trend: "3か月後 179.2万円",
        confidence: "AI一致度 92%",
        expenseTotal: "23,500",
        gas: "12,400円",
        insurance: "6,800円",
        maintenance: "4,300円",
        gasFill: "64%",
