      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 0 2px;
    }

    .screen-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.06);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
    }

    .screen-label .index {
      display: inline-grid;
      place-items: center;
      width: 22px;
      height: 22px;
      border-radius: 999px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 11px;
    }

    .screen-platform {
      font-size: 12px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 800;
    }

    .screen-caption {
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.8;
      margin: 0;
    }

    .phone {
      position: relative;
      width: min(100%, var(--phone-width));
      min-height: var(--phone-height);
      margin: 0 auto;
      padding: 14px;
      border-radius: 42px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.82), rgba(255,255,255,0.58)),
        linear-gradient(135deg, #edf3fb, #fff7fc);
      box-shadow: var(--shadow-heavy);
      border: 1px solid rgba(255, 255, 255, 0.82);
      overflow: hidden;
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 10px;
      left: 50%;
      width: 120px;
      height: 30px;
      margin-left: -60px;
      border-radius: 0 0 18px 18px;
      background: #16215e;
      z-index: 4;
    }

    .phone-screen {
      position: relative;
      min-height: calc(var(--phone-height) - 28px);
      padding: 18px 16px 20px;
      border-radius: 30px;
      background: linear-gradient(180deg, #f7fbff 0%, #eef5ff 48%, #fff5fa 100%);
      overflow: hidden;
    }

    .phone-screen::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 80% 10%, rgba(248, 76, 162, 0.16), transparent 18%),
        radial-gradient(circle at 12% 22%, rgba(29, 220, 255, 0.18), transparent 20%);
      pointer-events: none;
    }

    .status-bar {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 16px;
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 1;
      font-weight: 800;
    }

    .status-icons {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-icons span {
      display: block;
      height: 8px;
      border-radius: 999px;
      background: var(--dark-blue);
      opacity: 0.86;
    }

    .status-icons span:nth-child(1) {
      width: 11px;
    }

    .status-icons span:nth-child(2) {
      width: 18px;
    }

    .status-icons span:nth-child(3) {
      width: 24px;
    }

    .shot-header,
    .shot-body,
    .shot-footer {
      position: relative;
      z-index: 2;
    }

    .shot-header {
      margin-top: 18px;
      display: grid;
      gap: 12px;
    }

    .stack-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      line-height: 1.5;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .pill.dark {
      background: rgba(9, 19, 85, 0.92);
      color: var(--white);
    }

    .pill.soft {
      background: rgba(255, 255, 255, 0.88);
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .pill.pink {
      background: var(--pink);
      color: var(--white);
    }

    .pill.blue {
      background: rgba(29, 220, 255, 0.16);
      color: var(--dark-blue);
    }

    .shot-title {
      margin: 0;
      font-size: 30px;
      line-height: 1.22;
      font-weight: 900;
      letter-spacing: -0.04em;
      color: var(--dark-blue);
    }

    .shot-lead {
      margin: 0;
      color: #64708d;
      font-size: 13px;
      line-height: 1.8;
      font-weight: 700;
    }

    .hero-card {
      padding: 16px;
      border-radius: 24px;
      background: var(--gradient-dark);
      color: var(--white);
      box-shadow: 0 18px 40px rgba(9, 19, 85, 0.18);
      display: grid;
      gap: 12px;
    }

    .car-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .car-thumb {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background:
        linear-gradient(145deg, rgba(255,255,255,0.18), rgba(255,255,255,0.04)),
        linear-gradient(135deg, #3648bf, #0a1348);
      display: grid;
      place-items: center;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
    }

    .car-thumb svg {
      width: 44px;
      height: 28px;
    }

    .car-name {
      margin: 0;
      font-size: 16px;
      line-height: 1.5;
      font-weight: 900;
      color: var(--white);
    }

    .car-spec {
      margin: 2px 0 0;
      font-size: 11px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.72);
      font-weight: 700;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 12px;
      align-items: end;
    }

    .price-panel {
      display: grid;
      gap: 6px;
    }

    .price-label {
      font-size: 11px;
      line-height: 1.5;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.72);
      font-weight: 800;
    }

    .price-value {
      font-size: 42px;
      line-height: 1;
      letter-spacing: -0.04em;
      font-weight: 900;
      color: var(--white);
    }

    .price-foot {
      font-size: 11px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.7);
      font-weight: 700;
    }

    .mini-kpi-box {
      padding: 12px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.1);
      text-align: center;
    }

    .mini-kpi-box strong {
      display: block;
      font-size: 24px;
      line-height: 1.2;
      font-weight: 900;
      color: var(--white);
    }

    .mini-kpi-box span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.72);
      font-weight: 700;
    }

    .content-card {
      margin-top: 14px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 16px 32px rgba(28, 38, 99, 0.08);
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .section-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 12px;
    }

    .section-heading h3 {
      margin: 0;
      font-size: 14px;
      line-height: 1.5;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .section-heading p {
      margin: 0;
      font-size: 10px;
      line-height: 1.6;
      color: var(--text-gray);
      font-weight: 700;
    }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 12px;
    }

    .metric-box {
      padding: 10px;
      border-radius: 16px;
      background: #f4f8ff;
      text-align: center;
    }

    .metric-box strong {
      display: block;
      color: var(--dark-blue);
      font-size: 17px;
      line-height: 1.3;
      font-weight: 900;
    }

    .metric-box span {
      display: block;
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
    }

    .axis {
      display: flex;
      justify-content: space-between;
      margin-top: 6px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
    }

    .primary-button,
    .secondary-button {
      width: 100%;
      min-height: 43px;
      border: 0;
      border-radius: var(--radius-button);
      font-size: 14px;
      line-height: 1.4;
      font-weight: 900;
      cursor: pointer;
      transition: transform 180ms ease, filter 180ms ease, box-shadow 180ms ease;
    }

    .primary-button {
      margin-top: 14px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 14px 28px rgba(64, 153, 255, 0.22);
    }

    .secondary-button {
      margin-top: 10px;
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 14px 28px rgba(248, 76, 162, 0.2);
    }

    .primary-button:hover,
    .secondary-button:hover {
      transform: translateY(-1px);
      filter: saturate(1.06);
    }

    .hint-line {
      margin-top: 10px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.7;
      font-weight: 700;
      text-align: center;
    }

    .forecast-badges {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .forecast-badge {
      padding: 8px 10px;
      border-radius: 14px;
      background: rgba(248, 76, 162, 0.08);
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 1.5;
      font-weight: 800;
    }

    .expense-total {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .expense-value {
      font-size: 40px;
      line-height: 1;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .expense-sub {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
      font-weight: 700;
      text-align: right;
    }

    .ring-wrap {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: center;
    }

    .ring {
      position: relative;
      width: 92px;
      height: 92px;
    }

    .ring svg {
      width: 100%;
      height: 100%;
      transform: rotate(-90deg);
    }

    .ring-center {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      text-align: center;
      font-size: 10px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 800;
    }

    .ring-center strong {
      display: block;
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 1.1;
      font-weight: 900;
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      font-size: 11px;
      line-height: 1.6;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .expense-bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: #ebf1f8;
      overflow: hidden;
    }

    .expense-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: var(--width, 40%);
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.9), rgba(77, 180, 255, 0.9));
      transition: width 280ms ease;
    }

    .forecast-switch {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 14px;
      padding: 4px;
      border-radius: 18px;
      background: #eef4ff;
    }

    .forecast-switch button {
      appearance: none;
      min-height: 38px;
      border: 0;
      border-radius: 14px;
      background: transparent;
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.5;
      font-weight: 900;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease;
    }

    .forecast-switch button.is-active {
      background: var(--white);
      color: var(--pink);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.08);
    }

    .forecast-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .forecast-box {
      padding: 12px;
      border-radius: 16px;
      background: #f6f9ff;
      text-align: center;
    }

    .forecast-box strong {
      display: block;
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 1.3;
      font-weight: 900;
    }

    .forecast-box span {
      display: block;
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
    }

    .timing-score {
      margin-top: 14px;
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.08), rgba(64, 153, 255, 0.08));
    }

    .timing-score .score-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
    }

    .timing-score .score-top strong {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
    }

    .timing-score .score-top span {
      color: var(--pink);
      font-size: 18px;
      line-height: 1.4;
      font-weight: 900;
    }

    .timing-score p {
      margin: 8px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.8;
      font-weight: 700;
    }

    .compare-hero {
      padding: 16px;
      border-radius: 24px;
      background: linear-gradient(140deg, #091355 0%, #14206d 52%, #f84ca2 180%);
      color: var(--white);
      box-shadow: 0 18px 40px rgba(9, 19, 85, 0.18);
    }

    .compare-hero strong {
      display: block;
      font-size: 54px;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 900;
      margin-top: 8px;
    }

    .compare-hero small {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.76);
      font-weight: 700;
    }

    .compare-hero p {
      margin: 10px 0 0;
      font-size: 12px;
      line-height: 1.8;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.88);
    }

    .compare-stage {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 12px;
      padding: 4px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.1);
    }

    .compare-stage button {
      appearance: none;
      min-height: 36px;
      border: 0;
      border-radius: 14px;
      background: transparent;
      color: rgba(255, 255, 255, 0.74);
      font-size: 12px;
      line-height: 1.5;
      font-weight: 900;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease;
    }

    .compare-stage button.is-active {
      background: rgba(255, 255, 255, 0.18);
      color: var(--white);
    }

    .compare-table {
      width: 100%;
      margin-top: 14px;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.92);
      font-size: 11px;
      line-height: 1.6;
      color: var(--dark-blue);
    }

    .compare-table th,
    .compare-table td {
      padding: 10px 10px;
      border-bottom: 1px solid #e6ecf7;
      text-align: left;
      vertical-align: top;
    }

    .compare-table th {
      background: #f2f6ff;
      font-weight: 900;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #59708e;
    }

    .compare-table tr:last-child td {
      border-bottom: 0;
    }

    .compare-table .brand {
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-table .ucarpac {
      background: rgba(248, 76, 162, 0.07);
    }

    .compare-table .accent {
      color: var(--pink);
      font-weight: 900;
    }

    .compare-note {
      margin-top: 12px;
      padding: 12px;
      border-radius: 16px;
      background: rgba(9, 19, 85, 0.06);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.8;
      font-weight: 700;
    }

    .shot-footer {
      margin-top: 16px;
    }

    .footer-caption {
      margin-top: 10px;
      font-size: 10px;
      line-height: 1.7;
      color: var(--text-gray);
      font-weight: 700;
      text-align: center;
    }

    .insight-grid {
      margin-top: 24px;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 18px;
    }

    .panel {
      padding: 20px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-medium);
      backdrop-filter: blur(16px);
    }

    .panel h2 {
      margin: 0 0 10px;
      font-size: 22px;
      line-height: 1.4;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .panel p {
      margin: 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.9;
      font-weight: 700;
    }

    .hypothesis-list {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .hypothesis-item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 12px;
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(9, 19, 85, 0.05), rgba(248, 76, 162, 0.05));
    }

    .hypothesis-index {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 12px;
      font-weight: 900;
    }

    .hypothesis-item strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.6;
      font-weight: 900;
    }

    .hypothesis-item span {
      display: block;
      margin-top: 3px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.8;
      font-weight: 700;
    }

    .mini-board {
      margin-top: 16px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .mini-board .tile {
      padding: 14px;
      border-radius: 18px;
      background: #f4f8ff;
    }

    .mini-board strong {
      display: block;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.3;
      font-weight: 900;
    }

    .mini-board span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
      font-weight: 700;
    }

    .source-board {
      margin-top: 24px;
      padding: 22px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow-medium);
      backdrop-filter: blur(18px);
    }

    .source-head {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 16px;
    }

    .source-head h2 {
      margin: 0;
      font-size: 24px;
      line-height: 1.4;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .source-head p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.8;
      font-weight: 700;
    }

    .source-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .source-card {
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(244, 248, 255, 0.92), rgba(255, 255, 255, 0.9));
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 12px 24px rgba(28, 38, 99, 0.06);
    }

    .source-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.7;
      font-weight: 900;
    }

    .source-card p {
      margin: 6px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.8;
      font-weight: 700;
    }

    .source-card a {
      color: var(--text-under-blue);
      font-weight: 900;
      text-decoration: none;
      word-break: break-all;
    }

    .source-card a:hover {
      text-decoration: underline;
    }

    .policy-note {
      margin-top: 14px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255, 242, 232, 0.9);
      border: 1px solid rgba(240, 198, 173, 0.8);
      color: #9f3c0b;
      font-size: 12px;
      line-height: 1.8;
      font-weight: 800;
    }

    .shot-svg {
      width: 100%;
      display: block;
    }

    .line-path {
      fill: none;
      stroke: var(--pink);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: dash 1.6s ease forwards;
    }

    .area-path {
      fill: rgba(248, 76, 162, 0.12);
    }

    .dot {
      fill: var(--pink);
      stroke: var(--white);
      stroke-width: 3;
      animation: pulse 2.4s ease-in-out infinite;
    }

    .bar-bg {
      fill: #e8eff9;
    }

    .bar-fill {
      fill: url(#expenseGradient);
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 1;
      }
      50% {
        transform: scale(1.08);
        opacity: 0.84;
      }
    }

    @keyframes dash {
      to {
        stroke-dashoffset: 0;
      }
    }

    @media (max-width: 1180px) {
      .screen-deck,
      .insight-grid,
      .source-grid {
        grid-template-columns: 1fr;
      }

      .kpi-strip {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .page {
        padding: 14px 12px 48px;
      }

      .masthead,
      .control-panel,
      .panel,
      .source-board {
        border-radius: 22px;
      }

      .kpi-strip {
        grid-template-columns: 1fr 1fr;
      }

      .control-title {
        min-width: auto;
        width: 100%;
      }

      .hero-grid,
      .ring-wrap,
      .forecast-grid {
        grid-template-columns: 1fr;
      }

      .phone {
        border-radius: 34px;
      }

      .phone-screen {
        min-height: auto;
      }

      .source-grid,
      .mini-board {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .kpi-strip {
        grid-template-columns: 1fr;
      }

      .metric-grid {
        grid-template-columns: 1fr 1fr 1fr;
      }

      .shot-title {
        font-size: 28px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="masthead">
      <div class="eyebrow"><span class="pulse"></span>Store PV→DL率 改善テーマ / 2026-04-01</div>
      <h1>数字が先に刺さる。<br>UcarPACの強みを3枚で伝えるASOスクショ。</h1>
      <p class="lead">
        B案は<strong>現状CVR 17.3% → KPI 25%</strong>の差分を埋めるためのデータドリブン構成です。
        1枚目で<strong>AI査定の独自価値</strong>、2枚目で<strong>出費管理と売り時判断</strong>、3枚目で<strong>「相場を見るだけなら電話0本」</strong>を比較で理解させます。
        AppleのProduct Page OptimizationとGoogle Playのストア差し替え前提で、見出しと数値の理解速度を優先しています。
      </p>

      <div class="kpi-strip">
        <article class="kpi-card">
          <div class="kpi-label">現在のストアCVR</div>
          <div class="kpi-value" id="currentCvr">17.3<span>%</span></div>
