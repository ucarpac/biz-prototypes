    function updateGraph(lineEl, areaEl, path, dots) {
      lineEl.setAttribute("d", path);
      areaEl.setAttribute("d", path + " L300 120 L20 120 Z");
      const [d1, d2, d3] = dots;
      if (lineEl.id === "a-graph-line") {
        dom.aDot1.setAttribute("cy", d1);
        dom.aDot2.setAttribute("cy", d2);
        dom.aDot3.setAttribute("cy", d3);
      } else {
        dom.bDot1.setAttribute("cy", d1);
        dom.bDot2.setAttribute("cy", d2);
        dom.bDot3.setAttribute("cy", d3);
      }
      lineEl.style.animation = "none";
      requestAnimationFrame(() => {
        lineEl.style.animation = "";
      });
    }

