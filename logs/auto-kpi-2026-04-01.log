                    <svg viewBox="0 0 88 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M18 30L28 18H57L70 23L77 30V38H74C73 42 70 45 65 45C60 45 57 42 56 38H32C31 42 28 45 23 45C18 45 15 42 14 38H11V30H18Z" fill="white" opacity="0.92"/>
