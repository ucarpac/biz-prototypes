+        </article>
+        <article class="kpi-card">
+          <div class="kpi-label">必要改善幅</div>
+          <div class="kpi-value" id="gapValue">+7.7<span>pt</span></div>
+          <div class="progress-rail"><div class="progress-fill" id="gapBar" style="--fill:30.8%;"></div></div>
+        </article>
+        <article class="kpi-card">
