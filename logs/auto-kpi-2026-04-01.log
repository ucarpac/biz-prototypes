          <button class="chip is-active" data-filter="all">3枚まとめて表示</button>
          <button class="chip" data-filter="a">スクショAのみ</button>
          <button class="chip" data-filter="b">スクショBのみ</button>
          <button class="chip" data-filter="c">スクショCのみ</button>
