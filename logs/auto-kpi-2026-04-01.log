  <script>
    (() => {
      const scenarios = {
        baseline: {
          current: "17.3",
          target: "25.0",
          gap: "+7.7",
          currentFill: "69.2%",
          gapFill: "30.8%",
          copy: "現状想定では、独自機能の理解不足がCVRの目詰まり。まずは「AI査定」「将来予測」「電話0本の入口」を最短で読ませる構成を優先。"
        },
        mid: {
          current: "21.8",
          target: "25.0",
          gap: "+3.2",
          currentFill: "87.2%",
          gapFill: "12.8%",
          copy: "仮説値21.8%では1枚目のAI訴求が効いている状態。次のボトルネックは「継続利用の理由」と「営業不安の払拭」に移る。"
        },
        goal: {
          current: "25.0",
          target: "25.0",
          gap: "達成",
          currentFill: "100%",
          gapFill: "100%",
          copy: "25%到達時は、Aで独自価値を理解させ、Bで継続理由を作り、Cで不安を潰す3枚の役割分担が成立している想定。"
        }
      };

      const forecast = {
        "3m": {
          delta: "-7万円見込み",
          price: "279万円",
          label: "3か月後の予測価格",
          action: "待ちすぎ注意",
          actionLabel: "売り時アドバイス",
          score: "78 / 100",
          fill: "78%",
          copy: "SUV需要が強い一方、夏以降は新型流入の影響で下落しやすい想定。今季のうちに価格確認を促すコピーと相性が良い。"
        },
        "6m": {
          delta: "-15万円見込み",
          price: "271万円",
          label: "6か月後の予測価格",
          action: "下落幅が拡大",
          actionLabel: "早めの確認を推奨",
          score: "61 / 100",
          fill: "61%",
          copy: "半年スパンでは価格下落の説明責任が強くなるため、「今見る理由」をグラフとセットで示す設計が必要。"
        }
      };

      const compareCopy = {
        view: {
          hero: "0本",
          sub: "UcarPACアプリは個人情報なしで相場確認から開始",
          copy: "比較される前に、「いきなり申込ではない」ことを見出しで明示。電話ラッシュ不安をストア段階で外します。"
        },
        sell: {
          hero: "1社",
          sub: "売却相談に進んでも、やりとりは1社だけ",
          copy: "相場確認から売却相談までの心理的ハードル差を、電話本数でそのまま伝える比較訴求に切り替えます。"
        }
      };

      const scenarioButtons = Array.from(document.querySelectorAll("#scenarioControls .chip"));
      const filterButtons = Array.from(document.querySelectorAll("#filterControls .chip"));
      const forecastButtons = Array.from(document.querySelectorAll("#forecastControls button"));
      const compareButtons = Array.from(document.querySelectorAll("#compareStageControls button"));
      const screenCards = Array.from(document.querySelectorAll(".screen-card"));

      const currentCvr = document.getElementById("currentCvr");
      const gapValue = document.getElementById("gapValue");
      const currentBar = document.getElementById("currentBar");
      const gapBar = document.getElementById("gapBar");
      const statusCopy = document.getElementById("statusCopy");

      const forecastDelta = document.getElementById("forecastDelta");
      const forecastPrice = document.getElementById("forecastPrice");
      const forecastLabel = document.getElementById("forecastLabel");
      const forecastAction = document.getElementById("forecastAction");
      const forecastActionLabel = document.getElementById("forecastActionLabel");
      const timingScore = document.getElementById("timingScore");
      const timingBar = document.getElementById("timingBar");
      const timingCopy = document.getElementById("timingCopy");

      const compareHeroValue = document.getElementById("compareHeroValue");
      const compareHeroSub = document.getElementById("compareHeroSub");
      const compareHeroCopy = document.getElementById("compareHeroCopy");
      const compareCells = Array.from(document.querySelectorAll(".compare-table [data-view]"));

      const setScenario = (key) => {
        const item = scenarios[key];
        scenarioButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.scenario === key);
        });
        currentCvr.innerHTML = `${item.current}<span>%</span>`;
        gapValue.innerHTML = key === "goal" ? `${item.gap}<span>CVR</span>` : `${item.gap}<span>pt</span>`;
        currentBar.style.setProperty("--fill", item.currentFill);
        gapBar.style.setProperty("--fill", item.gapFill);
        statusCopy.innerHTML = item.copy.replace("AI査定", "<strong>AI査定</strong>").replace("将来予測", "<strong>将来予測</strong>").replace("電話0本の入口", "<strong>電話0本の入口</strong>");
      };

      const setFilter = (key) => {
        filterButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.filter === key);
        });
        screenCards.forEach((card) => {
          const show = key === "all" || card.dataset.screen === key;
          card.classList.toggle("is-hidden", !show);
        });
      };

      const setForecast = (key) => {
        const item = forecast[key];
        forecastButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.range === key);
        });
        forecastDelta.textContent = item.delta;
        forecastPrice.textContent = item.price;
        forecastLabel.textContent = item.label;
        forecastAction.textContent = item.action;
        forecastActionLabel.textContent = item.actionLabel;
        timingScore.textContent = item.score;
        timingBar.style.setProperty("--fill", item.fill);
        timingCopy.textContent = item.copy;
      };

      const setCompare = (key) => {
        const item = compareCopy[key];
        compareButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.stage === key);
        });
        compareHeroValue.textContent = item.hero;
        compareHeroSub.textContent = item.sub;
        compareHeroCopy.textContent = item.copy;
        compareCells.forEach((cell) => {
          cell.textContent = cell.dataset[key];
          cell.classList.toggle("accent", cell.closest("tr") && cell.closest("tr").classList.contains("ucarpac"));
        });
      };

      scenarioButtons.forEach((button) => {
        button.addEventListener("click", () => setScenario(button.dataset.scenario));
      });

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => setFilter(button.dataset.filter));
      });

      forecastButtons.forEach((button) => {
        button.addEventListener("click", () => setForecast(button.dataset.range));
      });

      compareButtons.forEach((button) => {
        button.addEventListener("click", () => setCompare(button.dataset.stage));
      });

      setScenario("baseline");
      setFilter("all");
      setForecast("3m");
      setCompare("view");
    })();
  </script>
</body>
