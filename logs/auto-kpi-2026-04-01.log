+
+      const setFilter = (key) => {
+        filterButtons.forEach((button) => {
+          button.classList.toggle("is-active", button.dataset.filter === key);
+        });
+        screenCards.forEach((card) => {
+          const show = key === "all" || card.dataset.screen === key;
+          card.classList.toggle("is-hidden", !show);
+        });
+      };
+
+      const setForecast = (key) => {
+        const item = forecast[key];
+        forecastButtons.forEach((button) => {
+          button.classList.toggle("is-active", button.dataset.range === key);
