+        },
+        mid: {
+          current: "21.8",
+          target: "25.0",
+          gap: "+3.2",
+          currentFill: "87.2%",
+          gapFill: "12.8%",
+          copy: "仮説値21.8%では1枚目のAI訴求が効いている状態。次のボトルネックは「継続利用の理由」と「営業不安の払拭」に移る。"
+        },
+        goal: {
+          current: "25.0",
+          target: "25.0",
+          gap: "達成",
+          currentFill: "100%",
+          gapFill: "100%",
+          copy: "25%到達時は、Aで独自価値を理解させ、Bで継続理由を作り、Cで不安を潰す3枚の役割分担が成立している想定。"
+        }
+      };
+
+      const forecast = {
+        "3m": {
+          delta: "-7万円見込み",
+          price: "279万円",
+          label: "3か月後の予測価格",
+          action: "待ちすぎ注意",
+          actionLabel: "売り時アドバイス",
+          score: "78 / 100",
+          fill: "78%",
+          copy: "SUV需要が強い一方、夏以降は新型流入の影響で下落しやすい想定。今季のうちに価格確認を促すコピーと相性が良い。"
+        },
+        "6m": {
+          delta: "-15万円見込み",
+          price: "271万円",
+          label: "6か月後の予測価格",
+          action: "下落幅が拡大",
+          actionLabel: "早めの確認を推奨",
+          score: "61 / 100",
+          fill: "61%",
+          copy: "半年スパンでは価格下落の説明責任が強くなるため、「今見る理由」をグラフとセットで示す設計が必要。"
+        }
+      };
+
+      const compareCopy = {
+        view: {
+          hero: "0本",
+          sub: "UcarPACアプリは個人情報なしで相場確認から開始",
