  <script>
    const tabs = document.querySelectorAll('.tab');
    const screens = document.querySelectorAll('.screen');
    const chips = document.querySelectorAll('.chip');
    const timingItems = document.querySelectorAll('.timing-item');
    const similarRows = document.querySelectorAll('.similar-row');
    const modal = document.getElementById('modal');
    const toast = document.getElementById('toast');
    const applyMain = document.getElementById('applyMain');
    const bottomApply = document.getElementById('bottomApply');
    const closeModal = document.getElementById('closeModal');
    const saveMain = document.getElementById('saveMain');

    function switchScreen(targetId) {
      tabs.forEach((tab) => {
        tab.classList.toggle('active', tab.dataset.target === targetId);
      });

      screens.forEach((screen) => {
        screen.classList.toggle('active', screen.id === targetId);
      });
    }

    function openModal() {
      modal.classList.add('show');
    }

    function closeApplyModal() {
      modal.classList.remove('show');
    }

    function showToast() {
      toast.classList.add('show');
      window.setTimeout(() => {
        toast.classList.remove('show');
      }, 2400);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        switchScreen(tab.dataset.target);
      });
    });

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((item) => item.classList.remove('selected'));
        chip.classList.add('selected');
      });
    });

    timingItems.forEach((item) => {
      item.addEventListener('click', () => {
        timingItems.forEach((button) => button.classList.remove('selected'));
        item.classList.add('selected');
      });
    });

    similarRows.forEach((row) => {
      row.addEventListener('click', () => {
        similarRows.forEach((item) => item.classList.remove('highlight'));
        row.classList.add('highlight');
      });
    });

    applyMain.addEventListener('click', openModal);
    bottomApply.addEventListener('click', openModal);
    closeModal.addEventListener('click', closeApplyModal);
    saveMain.addEventListener('click', showToast);

    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        closeApplyModal();
      }
    });

    window.setInterval(() => {
      const activeTab = document.querySelector('.tab.active');
      if (!activeTab) {
        return;
      }

      const currentIndex = Array.from(tabs).indexOf(activeTab);
      const nextIndex = (currentIndex + 1) % tabs.length;
      const nextTarget = tabs[nextIndex].dataset.target;

      if (!modal.classList.contains('show')) {
        switchScreen(nextTarget);
      }
    }, 9000);
  </script>
</body>
