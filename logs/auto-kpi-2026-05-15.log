      touch-action: pan-y;
    }

    .slides {
      display: flex;
      width: 300%;
      transition: transform 360ms cubic-bezier(.2,.8,.2,1);
    }

    .screen {
      width: 33.333%;
      padding: 0 20px 24px;
    }

    .card {
      width: 100%;
      max-width: 351px;
      margin: 0 auto;
      border-radius: 13px;
      background: var(--white);
      box-shadow: var(--shadow);
      border: 1px solid #e8eef6;
      overflow: hidden;
    }

    .card-header {
      padding: 16px 16px 12px;
      border-bottom: 1px solid var(--ruled-line);
    }

    .mini-label {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 4px 10px;
      border-radius: var(--radius-chip);
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
    }

    .card-title {
      margin: 10px 0 0;
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
      color: var(--dark-blue);
    }

    .car-name {
      margin: 4px 0 0;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .price-panel {
      padding: 18px 16px 14px;
      text-align: center;
      background: linear-gradient(180deg, #ffffff 0%, #f5fbff 100%);
    }

    .price-caption {
      margin: 0 0 4px;
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      color: var(--text-gray);
    }

    .price-main {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 4px;
      color: var(--dark-blue);
    }

    .price-number {
      font-family: var(--font-number);
      font-size: 44px;
      font-weight: 700;
      line-height: 66px;
      letter-spacing: 0;
      animation: rise 500ms ease both;
    }

    .price-unit {
      font-size: 18px;
      font-weight: 700;
      line-height: 27px;
    }

    .price-range {
      margin-top: -2px;
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      color: var(--pink);
    }

    .chart-card {
      padding: 16px;
    }

    .chart-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      color: var(--dark-blue);
    }

    .chart-badge {
      padding: 3px 8px;
      border-radius: var(--radius-chip);
      background: var(--dark-blue);
      color: var(--white);
      font-size: 10px;
      line-height: 15px;
    }

    .chart {
      height: 150px;
      position: relative;
      border-radius: var(--radius-md);
      background:
        linear-gradient(to bottom, transparent 24%, #eef2f8 24%, #eef2f8 25%, transparent 25%),
        linear-gradient(to bottom, transparent 49%, #eef2f8 49%, #eef2f8 50%, transparent 50%),
        linear-gradient(to bottom, transparent 74%, #eef2f8 74%, #eef2f8 75%, transparent 75%),
        #fbfdff;
      overflow: hidden;
    }

    .chart svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .chart-line {
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: drawLine 900ms 160ms ease forwards;
    }

    .chart-point {
      opacity: 0;
      transform-origin: center;
      animation: pop 300ms ease forwards;
    }

    .chart-point:nth-of-type(2) {
      animation-delay: 360ms;
    }

    .chart-point:nth-of-type(3) {
      animation-delay: 480ms;
    }

    .chart-point:nth-of-type(4) {
      animation-delay: 600ms;
    }

    .chart-point:nth-of-type(5) {
      animation-delay: 720ms;
    }

    .chart-labels {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      margin-top: 8px;
      font-size: 10px;
      line-height: 15px;
      color: var(--text-gray);
      text-align: center;
    }

    .timing-box {
      margin-top: 16px;
      padding: 14px;
      border-radius: var(--radius-md);
      background: #fff6fb;
      border: 1px solid #ffd2e6;
    }

    .timing-title {
      margin: 0 0 6px;
      font-size: 16px;
      font-weight: 700;
      line-height: 24px;
      color: var(--pink);
    }

    .timing-text {
      margin: 0;
      font-size: 13px;
      line-height: 19.5px;
      color: var(--text-black);
    }

    .chips {
      display: flex;
      gap: 8px;
      margin-top: 14px;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .chip {
      flex: 0 0 auto;
      min-width: 88px;
      min-height: 43px;
      padding: 8px 14px;
      border-radius: var(--radius-chip);
      background: var(--white);
      border: 1px solid #e2e8f0;
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .chip.selected {
      background: var(--dark-blue);
      color: var(--white);
      transform: scale(1.03);
    }

    .compare-list {
      padding: 16px;
      display: grid;
      gap: 12px;
    }

    .compare-item {
      min-height: 78px;
      padding: 12px;
      border-radius: var(--radius-md);
      background: #fbfdff;
      border: 1px solid #e6edf7;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
      transition: transform 180ms ease, border-color 180ms ease;
    }

    .compare-item.active {
      border-color: var(--pink);
      transform: translateX(4px);
      background: #fff8fc;
    }

    .compare-name {
      margin: 0;
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      color: var(--dark-blue);
    }

    .compare-meta {
      margin: 3px 0 0;
      font-size: 11px;
      line-height: 16.5px;
      color: var(--text-gray);
    }

    .compare-price {
      text-align: right;
      color: var(--dark-blue);
      font-weight: 700;
      white-space: nowrap;
    }

    .compare-price strong {
      font-size: 22px;
      line-height: 33px;
      font-family: var(--font-number);
    }

    .score-panel {
      margin: 0 16px 16px;
      padding: 16px;
      border-radius: var(--radius-md);
      background: var(--back-blue);
      color: var(--white);
    }

    .score-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .score-title {
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .score-number {
      font-size: 32px;
      font-weight: 700;
      line-height: 48px;
      color: #73ddff;
      font-family: var(--font-number);
    }

    .score-bar {
      height: 8px;
      margin-top: 10px;
      border-radius: 99px;
      background: rgba(255,255,255,0.18);
      overflow: hidden;
    }

    .score-fill {
      height: 100%;
      width: 92%;
      border-radius: 99px;
      background: var(--gradient-primary);
      animation: fillScore 800ms ease both;
    }

    .score-note {
      margin: 8px 0 0;
      font-size: 12px;
      line-height: 18px;
      color: #dbeafe;
    }

    .quest-box {
      padding: 16px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .quest-title {
      margin: 0;
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
      color: var(--dark-blue);
    }

    .quest-copy {
      margin: 6px 0 0;
      font-size: 13px;
      line-height: 19.5px;
      color: var(--text-gray);
    }

    .quest-path {
      margin-top: 18px;
      display: grid;
      gap: 12px;
    }

    .quest-step {
      display: grid;
      grid-template-columns: 34px 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid #e8eef6;
      transition: border-color 180ms ease, transform 180ms ease, background 180ms ease;
    }

    .quest-step.done {
      background: #f0fbff;
      border-color: #79d8ff;
    }

    .quest-step.current {
      background: #fff7fb;
      border-color: var(--pink);
      transform: translateY(-2px);
    }

    .quest-icon {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--back-gray);
      color: var(--dark-blue);
      font-weight: 700;
      font-size: 14px;
      line-height: 21px;
    }

    .quest-step.done .quest-icon {
      background: var(--gradient-primary);
    }

    .quest-step.current .quest-icon {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .quest-name {
      margin: 0;
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      color: var(--dark-blue);
    }

    .quest-desc {
      margin: 1px 0 0;
      font-size: 11px;
      line-height: 16.5px;
      color: var(--text-gray);
    }

    .quest-status {
      min-width: 54px;
      text-align: right;
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
      color: var(--pink);
    }

    .cta-panel {
      padding: 16px;
      text-align: center;
    }

    .trust-badges {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 16px;
    }

    .trust-badge {
      min-height: 54px;
      padding: 8px 6px;
      border-radius: var(--radius-md);
      background: #f7faff;
      border: 1px solid #e6edf7;
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
    }

    .app-button {
      width: 240px;
      max-width: 100%;
      min-height: 43px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      box-shadow: 0 8px 18px rgba(64,153,255,0.28);
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .app-button:active {
      transform: scale(0.97);
      box-shadow: 0 4px 12px rgba(64,153,255,0.22);
    }

    .pink-button {
      margin-top: 12px;
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 8px 18px rgba(248,76,162,0.28);
    }

    .sub-action {
      display: block;
      margin: 14px auto 0;
      background: transparent;
      color: var(--button-link);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      text-decoration: underline;
    }

    .bottom-nav {
      position: sticky;
      bottom: 0;
      z-index: 4;
      background: rgba(250,250,250,0.95);
      backdrop-filter: blur(10px);
      border-top: 1px solid #e8eef6;
      padding: 10px 18px 12px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .nav-btn {
      min-height: 38px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      line-height: 16.5px;
      border: 1px solid #e8eef6;
    }

    .nav-btn.active {
      background: var(--dark-blue);
      color: var(--white);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 78px;
      width: min(323px, calc(100vw - 40px));
      transform: translateX(-50%) translateY(28px);
      padding: 14px 16px;
      border-radius: var(--radius-md);
      background: var(--back-blue);
      color: var(--white);
      box-shadow: 0 10px 30px rgba(9,19,85,0.28);
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease, transform 220ms ease;
      z-index: 10;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .toast-title {
      margin: 0 0 3px;
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    .toast-text {
      margin: 0;
      font-size: 12px;
      line-height: 18px;
      color: #dbeafe;
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 20;
      padding: 20px;
    }

    .modal-backdrop.show {
      display: flex;
      animation: fadeIn 180ms ease;
    }

    .modal {
      width: 82%;
      max-width: 323px;
      border-radius: var(--radius-md);
      background: var(--white);
      padding: 32px 28px;
      text-align: center;
      box-shadow: 0 16px 48px rgba(0,0,0,0.22);
      animation: modalPop 220ms ease;
    }

    .modal-mark {
      width: 54px;
      height: 54px;
      margin: 0 auto 14px;
      border-radius: 50%;
      background: var(--gradient-primary);
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      font-size: 24px;
      font-weight: 700;
    }

    .modal h2 {
      margin: 0 0 8px;
      font-size: 20px;
      font-weight: 700;
      line-height: 30px;
      color: var(--dark-blue);
    }

    .modal p {
      margin: 0 0 18px;
      font-size: 14px;
      line-height: 21px;
      color: var(--text-gray);
    }

    .close-button {
      width: 140px;
      min-height: 43px;
      border-radius: var(--radius-button);
      background: var(--dark-blue);
      color: var(--white);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 0.55;
      }
      50% {
        transform: scale(1.45);
        opacity: 1;
      }
    }

    @keyframes rise {
      from {
        transform: translateY(12px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes pop {
      from {
        opacity: 0;
        transform: scale(0.4);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes fillScore {
      from {
        width: 0;
      }
      to {
        width: 92%;
      }
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes modalPop {
      from {
        transform: translateY(16px) scale(0.96);
        opacity: 0;
      }
      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    @media (min-width: 431px) {
      body {
        padding: 28px 0;
      }

      .app {
        min-height: 812px;
        border-radius: 28px;
        box-shadow: 0 18px 54px rgba(28,38,99,0.22);
      }

      .toast {
        bottom: 106px;
      }
    }
  </style>
</head>
<body>
  <main class="app" aria-label="UcarPAC AI査定結果プロトタイプ">
    <div class="status-bar"></div>

    <section class="hero">
      <div class="top-row">
        <div class="brand">UcarPAC</div>
        <div class="badge">個人情報なしで表示中</div>
      </div>
      <h1>AI査定の結果を、売り時まで体感する</h1>
      <p>金額・相場・実績比較をスワイプで確認して、納得したらワンタップで申込へ進めます。</p>
    </section>

    <section class="progress-area" aria-label="進行状況">
      <div class="progress-labels">
        <span>査定結果A</span>
        <span>実績比較B</span>
        <span>申込導線</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="progressFill"></div>
      </div>
    </section>

    <nav class="steps" aria-label="画面切り替え">
      <button class="step active" data-slide="0">相場予測</button>
      <button class="step" data-slide="1">実績比較</button>
      <button class="step" data-slide="2">売却申込</button>
    </nav>

    <div class="swipe-hint">
      <span class="swipe-dot"></span>
      <span>左右にスワイプして結果を確認</span>
    </div>

    <section class="slider" id="slider">
      <div class="slides" id="slides">
        <article class="screen">
          <div class="card">
            <div class="card-header">
              <span class="mini-label">査定結果画面A</span>
              <h2 class="card-title">いまの推定売却額</h2>
              <p class="car-name">トヨタ ハリアー Z Leather Package / 2021年式 / 28,400km</p>
            </div>

            <div class="price-panel">
              <p class="price-caption">AI査定価格</p>
              <div class="price-main">
                <span class="price-number" id="mainPrice">312</span>
                <span class="price-unit">万円</span>
              </div>
              <div class="price-range" id="priceRange">相場レンジ 298〜326万円</div>
            </div>

            <div class="chart-card">
              <div class="chart-title">
                <span>6ヶ月の相場予測</span>
                <span class="chart-badge" id="timingBadge">今月が高値</span>
              </div>

              <div class="chart" aria-label="相場予測グラフ">
                <svg viewBox="0 0 310 150" role="img">
                  <defs>
                    <linearGradient id="lineGradient" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="0%" stop-color="#1ddcff"></stop>
                      <stop offset="100%" stop-color="#F84CA2"></stop>
                    </linearGradient>
                  </defs>
                  <path d="M18 72 C62 54, 93 40, 126 48 S190 74, 220 88 S264 102, 292 112" fill="none" stroke="url(#lineGradient)" stroke-width="5" stroke-linecap="round" class="chart-line"></path>
                  <circle cx="18" cy="72" r="6" fill="#1ddcff" class="chart-point"></circle>
                  <circle cx="126" cy="48" r="7" fill="#F84CA2" class="chart-point"></circle>
                  <circle cx="220" cy="88" r="6" fill="#4db4ff" class="chart-point"></circle>
                  <circle cx="292" cy="112" r="6" fill="#4db4ff" class="chart-point"></circle>
                </svg>
              </div>

              <div class="chart-labels">
                <span>今日</span>
                <span>1ヶ月後</span>
                <span>3ヶ月後</span>
                <span>6ヶ月後</span>
              </div>

              <div class="timing-box">
                <p class="timing-title" id="timingTitle">高く売れるタイミング: 1ヶ月以内</p>
                <p class="timing-text" id="timingText">同条件の相場は夏前に下がりやすく、今月から来月の売却で約12万円高く残せる見込みです。</p>
              </div>

              <div class="chips" aria-label="売却タイミング診断">
                <button class="chip selected" data-price="312" data-range="298〜326万円" data-title="高く売れるタイミング: 1ヶ月以内" data-text="同条件の相場は夏前に下がりやすく、今月から来月の売却で約12万円高く残せる見込みです。" data-badge="今月が高値">今すぐ</button>
                <button class="chip" data-price="307" data-range="292〜321万円" data-title="高く売れるタイミング: 3ヶ月以内" data-text="3ヶ月後も大きな下落はありませんが、車検前に動くと維持費を抑えながら売却できます。" data-badge="車検前が目安">3ヶ月</button>
                <button class="chip" data-price="294" data-range="278〜309万円" data-title="高く売れるタイミング: 早めの相談がおすすめ" data-text="6ヶ月後は年式評価が一段下がる可能性があります。売却予定だけ先に登録して通知を受け取れます。" data-badge="下落通知あり">6ヶ月</button>
              </div>
            </div>
          </div>
        </article>

        <article class="screen">
          <div class="card">
            <div class="card-header">
              <span class="mini-label">査定結果画面B</span>
              <h2 class="card-title">似ている車の成約実績</h2>
              <p class="car-name">実績価格との差で、AI査定の納得感を確認</p>
            </div>

            <div class="compare-list">
              <button class="compare-item active" data-score="92" data-note="あなたの車は装備評価が高く、類似実績の上位帯に近い査定です。">
                <div>
                  <p class="compare-name">ハリアー Z / 2021年式</p>
                  <p class="compare-meta">31,200km・パール・JBL・4WD</p>
                </div>
                <div class="compare-price"><strong>318</strong>万円</div>
              </button>

              <button class="compare-item" data-score="88" data-note="走行距離が近い実績では、外装状態と純正ナビの有無で約10万円の差が出ています。">
                <div>
                  <p class="compare-name">ハリアー G / 2021年式</p>
                  <p class="compare-meta">27,900km・ブラック・2WD</p>
                </div>
                <div class="compare-price"><strong>304</strong>万円</div>
              </button>

              <button class="compare-item" data-score="84" data-note="年式が同じでもグレード差が大きく、Z Leather Package は上振れしやすい傾向です。">
                <div>
                  <p class="compare-name">ハリアー S / 2021年式</p>
                  <p class="compare-meta">29,600km・グレー・修復歴なし</p>
                </div>
                <div class="compare-price"><strong>286</strong>万円</div>
              </button>
            </div>

            <div class="score-panel">
              <div class="score-row">
