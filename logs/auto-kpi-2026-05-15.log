  <div class="toast" id="toast" role="status" aria-live="polite">
    <p class="toast-title" id="toastTitle">売り時通知を設定しました</p>
    <p class="toast-text" id="toastText">相場が310万円を超えたらプッシュ通知でお知らせします。</p>
  </div>

  <div class="modal-backdrop" id="modalBackdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-mark">✓</div>
      <h2 id="modalTitle">申込準備ができました</h2>
      <p>AI査定価格312万円をもとに、UcarPAC担当から次の手続きを案内します。</p>
      <button class="close-button" id="closeModal">閉じる</button>
    </div>
  </div>

  <script>
    const slides = document.getElementById('slides');
    const slider = document.getElementById('slider');
    const progressFill = document.getElementById('progressFill');
    const stepButtons = Array.from(document.querySelectorAll('.step'));
    const navButtons = Array.from(document.querySelectorAll('.nav-btn'));
    const chips = Array.from(document.querySelectorAll('.chip'));
    const compareItems = Array.from(document.querySelectorAll('.compare-item'));
    const mainPrice = document.getElementById('mainPrice');
    const priceRange = document.getElementById('priceRange');
    const timingTitle = document.getElementById('timingTitle');
    const timingText = document.getElementById('timingText');
    const timingBadge = document.getElementById('timingBadge');
    const scoreNumber = document.getElementById('scoreNumber');
    const scoreFill = document.getElementById('scoreFill');
    const scoreNote = document.getElementById('scoreNote');
    const toast = document.getElementById('toast');
    const toastTitle = document.getElementById('toastTitle');
    const toastText = document.getElementById('toastText');
    const applyButton = document.getElementById('applyButton');
    const savePlanButton = document.getElementById('savePlanButton');
    const backToResult = document.getElementById('backToResult');
    const modalBackdrop = document.getElementById('modalBackdrop');
    const closeModal = document.getElementById('closeModal');

    let currentSlide = 0;
    let startX = 0;
    let dragging = false;
    let toastTimer = null;

    function goToSlide(index) {
      currentSlide = Math.max(0, Math.min(2, index));
      slides.style.transform = `translateX(-${currentSlide * 33.3333}%)`;
      progressFill.style.width = `${(currentSlide + 1) * 33.3333}%`;

      stepButtons.forEach((button, buttonIndex) => {
        button.classList.toggle('active', buttonIndex === currentSlide);
      });

      navButtons.forEach((button, buttonIndex) => {
        button.classList.toggle('active', buttonIndex === currentSlide);
      });
    }

    function showToast(title, text) {
      toastTitle.textContent = title;
      toastText.textContent = text;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.remove('show');
      }, 2600);
    }

    function animateNumber(target, value) {
      const start = Number(target.textContent);
      const end = Number(value);
      const duration = 420;
      const startTime = performance.now();

      function tick(now) {
        const progress = Math.min(1, (now - startTime) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        target.textContent = Math.round(start + (end - start) * eased);
        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      }

      requestAnimationFrame(tick);
    }

    stepButtons.forEach((button) => {
      button.addEventListener('click', () => {
        goToSlide(Number(button.dataset.slide));
      });
    });

    navButtons.forEach((button) => {
      button.addEventListener('click', () => {
        goToSlide(Number(button.dataset.slide));
      });
    });

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((item) => item.classList.remove('selected'));
        chip.classList.add('selected');
        animateNumber(mainPrice, chip.dataset.price);
        priceRange.textContent = `相場レンジ ${chip.dataset.range}`;
        timingTitle.textContent = chip.dataset.title;
        timingText.textContent = chip.dataset.text;
        timingBadge.textContent = chip.dataset.badge;
        showToast('売り時診断を更新しました', `${chip.textContent}の予測価格に切り替えました。`);
      });
    });

    compareItems.forEach((item) => {
      item.addEventListener('click', () => {
        compareItems.forEach((compare) => compare.classList.remove('active'));
        item.classList.add('active');
        const score = Number(item.dataset.score);
        animateNumber(scoreNumber, score);
        scoreFill.style.width = `${score}%`;
        scoreNote.textContent = item.dataset.note;
      });
    });

    savePlanButton.addEventListener('click', () => {
      showToast('売り時通知を設定しました', '相場が310万円を超えたらプッシュ通知でお知らせします。');
      savePlanButton.textContent = '通知設定済み';
      savePlanButton.style.background = 'var(--gradient-disabled)';
      savePlanButton.style.color = 'var(--text-gray)';
    });

    applyButton.addEventListener('click', () => {
      modalBackdrop.classList.add('show');
      modalBackdrop.setAttribute('aria-hidden', 'false');
    });

    closeModal.addEventListener('click', () => {
      modalBackdrop.classList.remove('show');
      modalBackdrop.setAttribute('aria-hidden', 'true');
      showToast('申込ステップを保存しました', 'マイページからいつでも再開できます。');
    });

    modalBackdrop.addEventListener('click', (event) => {
      if (event.target === modalBackdrop) {
        modalBackdrop.classList.remove('show');
        modalBackdrop.setAttribute('aria-hidden', 'true');
      }
    });

    backToResult.addEventListener('click', () => {
      goToSlide(0);
    });

    slider.addEventListener('pointerdown', (event) => {
      startX = event.clientX;
      dragging = true;
    });

    slider.addEventListener('pointerup', (event) => {
      if (!dragging) return;
      dragging = false;
      const diff = event.clientX - startX;
      if (Math.abs(diff) > 48) {
        if (diff < 0) {
          goToSlide(currentSlide + 1);
        } else {
          goToSlide(currentSlide - 1);
        }
      }
    });

    slider.addEventListener('pointercancel', () => {
      dragging = false;
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowRight') {
        goToSlide(currentSlide + 1);
      }
      if (event.key === 'ArrowLeft') {
        goToSlide(currentSlide - 1);
      }
      if (event.key === 'Escape') {
        modalBackdrop.classList.remove('show');
        modalBackdrop.setAttribute('aria-hidden', 'true');
      }
    });

    goToSlide(0);
  </script>
</body>
</html>
