  <script>
    const tabs = document.querySelectorAll('.tabButton');
    const screens = document.querySelectorAll('.screen');
    const bars = document.querySelectorAll('.barFill');
    const toast = document.getElementById('toast');
    const applyButton = document.getElementById('applyButton');
    const saveButton = document.getElementById('saveButton');
    const priceCounter = document.getElementById('priceCounter');

    let currentPrice = 0;
    const targetPrice = 292;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function animateBars() {
      bars.forEach((bar) => {
        const width = bar.dataset.width || 0;
        bar.style.width = '0%';
        window.setTimeout(() => {
          bar.style.width = width + '%';
        }, 80);
      });
    }

    function animatePrice() {
      currentPrice = 0;
      priceCounter.textContent = currentPrice;
      const timer = window.setInterval(() => {
        currentPrice += 8;
        if (currentPrice >= targetPrice) {
          currentPrice = targetPrice;
          window.clearInterval(timer);
        }
        priceCounter.textContent = currentPrice;
      }, 18);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.target;
        tabs.forEach((item) => item.classList.remove('active'));
        screens.forEach((screen) => screen.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(target).classList.add('active');
        animateBars();
        if (target === 'screenA') {
          animatePrice();
        }
      });
    });

    applyButton.addEventListener('click', () => {
      applyButton.textContent = '申込準備を開始しました';
      applyButton.style.background = 'var(--gradient-primary)';
      applyButton.style.color = 'var(--dark-blue)';
      showToast('292万円を目安に売却申込へ進みます');
    });

    saveButton.addEventListener('click', () => {
      saveButton.textContent = '通知設定済み';
      saveButton.style.borderColor = '#F84CA2';
      saveButton.style.color = '#F84CA2';
      showToast('高く売れるタイミングを通知します');
    });

    window.addEventListener('load', () => {
      animateBars();
      animatePrice();
    });
  </script>
