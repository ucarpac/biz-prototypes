      left: 50%;
      top: 40px;
      transform: translateX(-50%);
      width: 26px;
      height: 12px;
      border-bottom: 3px solid #f57b68;
      border-radius: 0 0 16px 16px;
    }

    .hero-badges {
      margin-top: 10px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .tag {
      border-radius: 20px;
      padding: 6px 10px;
      font-size: 11px;
      font-weight: 700;
      background: #fff;
      border: 1px solid #ffe4d5;
      color: var(--dark-blue);
    }

    .tag.pink {
      background: #fff0f8;
      border-color: #ffc9e8;
      color: #cb2d7e;
    }

    .tabs {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      margin-bottom: 12px;
    }

    .tab {
      border: 1px solid #e8edf9;
      background: #fff;
      color: var(--dark-blue);
      border-radius: 14px;
      padding: 10px 12px;
      text-align: left;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: .2s;
    }

    .tab.active {
      background: linear-gradient(90deg, rgba(248,76,162,0.12), rgba(253,166,107,0.14));
      border-color: #ffc8e7;
      box-shadow: 0 4px 16px rgba(248,76,162,0.16);
    }

    .panel {
      display: none;
      animation: fade .25s ease;
    }

    .panel.active {
      display: block;
    }

    @keyframes fade {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .card {
      background: #fff;
      border-radius: 14px;
      border: 1px solid #e9eef8;
      box-shadow: var(--shadow-light);
      padding: 14px;
      margin-bottom: 12px;
    }

    .card h2 {
      margin: 0 0 8px;
      font-size: 18px;
      color: var(--dark-blue);
    }

    .desc {
      font-size: 12px;
      color: var(--text-gray);
      margin: 0 0 10px;
    }

    .metric-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 10px;
    }

    .metric {
      border-radius: 12px;
      background: #fff8f2;
      border: 1px solid #ffe5d4;
      padding: 8px;
    }

    .metric .k {
      font-size: 11px;
      color: #a86a53;
      margin-bottom: 2px;
    }

    .metric .v {
      font-size: 18px;
      font-weight: 800;
      color: var(--dark-blue);
      line-height: 1.3;
    }

    .focus-buttons {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .focus-btn {
      border: 1px solid #d7dfef;
      border-radius: 22px;
      padding: 8px 12px;
      background: #fff;
      color: var(--text-black);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
    }

    .focus-btn.active {
      background: var(--dark-blue);
      color: #fff;
      border-color: var(--dark-blue);
    }

    .table-wrap {
      overflow: auto;
      border-radius: 10px;
      border: 1px solid #e4eaf6;
      background: #fff;
    }

    table {
      width: 100%;
      min-width: 700px;
      border-collapse: collapse;
      font-size: 12px;
    }

    th,
    td {
      padding: 10px 8px;
      border-bottom: 1px solid #eef2fb;
      text-align: right;
      white-space: nowrap;
    }

    th:first-child,
    td:first-child {
      text-align: left;
      position: sticky;
      left: 0;
      background: #fff;
      z-index: 1;
    }

    th {
      font-size: 11px;
      color: #5f6787;
      background: #f6f8ff;
      cursor: pointer;
      user-select: none;
    }

    tr.best {
      background: #fff4fb;
    }

    tr.best td:first-child {
      background: #fff4fb;
    }

    .delta.up {
      color: #0b8f55;
      font-weight: 700;
    }

    .delta.down {
      color: var(--error);
      font-weight: 700;
    }

    .car-list {
      display: grid;
      gap: 8px;
      margin-top: 8px;
    }

    .car-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      padding: 8px;
      border-radius: 10px;
      background: #f9fbff;
      border: 1px solid #e9edf8;
      font-size: 12px;
    }

    .car-row strong {
      display: block;
      color: var(--dark-blue);
      margin-bottom: 2px;
      font-size: 12px;
    }

    .sim-controls {
      display: grid;
      gap: 10px;
      margin-bottom: 12px;
    }

    .range-box {
      background: #fff8f1;
      border: 1px solid #ffe7d7;
      border-radius: 12px;
      padding: 10px;
    }

    .range-box label {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      font-weight: 700;
      color: #8b5a45;
    }

    input[type="range"] {
      width: 100%;
      accent-color: var(--pink);
      margin-top: 8px;
    }

    .check-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .check-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid #d9e1f1;
      border-radius: 20px;
      padding: 6px 10px;
      background: #fff;
      font-size: 12px;
      color: var(--text-black);
      cursor: pointer;
    }

    .sim-results {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 10px;
    }

    .result {
      border-radius: 12px;
      background: #f6f9ff;
      border: 1px solid #dfe8fb;
      padding: 8px;
    }

    .result .k {
      font-size: 11px;
      color: #60729e;
    }

    .result .v {
      margin-top: 2px;
      font-size: 17px;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .bars {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      align-items: end;
      height: 120px;
      margin-top: 6px;
    }

    .bar-col {
      text-align: center;
    }

    .bar {
      border-radius: 10px 10px 6px 6px;
      width: 100%;
      min-height: 14px;
      transition: height .25s ease;
      background: var(--gradient-primary);
    }

    .bar.apple {
      background: linear-gradient(180deg, #47b6ff, #1f8ef6);
    }

    .bar.sim {
      background: linear-gradient(180deg, #ff8cb8, #f84ca2);
    }

    .bar.diff {
      background: linear-gradient(180deg, #ffcb7e, #ff9c5b);
    }

    .bar-label {
      margin-top: 6px;
      font-size: 11px;
      color: #55638c;
    }

    .recommend {
      margin-top: 10px;
      border-radius: 12px;
      background: #fff5f8;
      border: 1px solid #ffd7e8;
      padding: 10px;
      font-size: 12px;
      color: #77324f;
    }

    .creative-grid {
      display: grid;
      gap: 10px;
      margin-bottom: 10px;
    }

    .creative {
      border: 1px solid #e4eaf7;
      border-radius: 12px;
      padding: 10px;
      background: #fff;
      transition: .2s;
    }

    .creative.active {
      border-color: #ffb8de;
      box-shadow: 0 6px 18px rgba(248,76,162,0.16);
      transform: translateY(-1px);
    }

    .creative h3 {
      margin: 0 0 4px;
      color: var(--dark-blue);
      font-size: 15px;
    }

    .creative p {
      margin: 0 0 8px;
      color: #676f8c;
      font-size: 12px;
    }

    .row-end {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
    }

    .chip-mini {
      background: #f3f7ff;
      border: 1px solid #d8e3fb;
      color: #3556a7;
      border-radius: 12px;
      font-size: 11px;
      padding: 4px 8px;
      font-weight: 700;
    }

    .btn-select {
      border: none;
      border-radius: 18px;
      padding: 7px 10px;
      color: var(--dark-blue);
      background: linear-gradient(90deg, #ffe5f3, #ffe9d8);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
    }

    .preview {
      border: 1px solid #cddaf4;
      background: #f8fbff;
      border-radius: 16px;
      padding: 10px;
      margin-top: 8px;
    }

    .phone {
      width: 100%;
      border-radius: 18px;
      border: 2px solid #d5def3;
      background: linear-gradient(160deg, #fff5e8, #fff);
      padding: 12px;
      min-height: 158px;
      position: relative;
      overflow: hidden;
    }

    .phone:before {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      right: -35px;
      top: -40px;
      background: rgba(248,76,162,0.15);
    }

    .pv-channel {
      margin: 0;
      color: #7b4a6b;
      font-size: 11px;
      font-weight: 700;
    }

    .pv-title {
      margin: 4px 0;
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 800;
      line-height: 1.4;
    }

    .pv-sub {
      margin: 0;
      font-size: 12px;
      color: #526282;
    }

    .pv-cta {
      margin-top: 10px;
      display: inline-block;
      padding: 8px 12px;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
    }

    .abtest {
      margin-top: 10px;
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .run-btn {
      border: none;
      border-radius: 30px;
      padding: 9px 14px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      background: var(--gradient-pink);
      color: #fff;
      box-shadow: 0 6px 14px rgba(248,76,162,0.25);
    }

    .status-badge {
      font-size: 12px;
      font-weight: 700;
      color: #5f678b;
      background: #f3f6ff;
      border: 1px solid #dce3f6;
      border-radius: 12px;
      padding: 7px 10px;
    }

    .sources h2 {
      margin: 4px 0 8px;
      font-size: 16px;
      color: var(--dark-blue);
    }

    .sources ol {
      margin: 0;
      padding-left: 18px;
      color: #5b627d;
      font-size: 12px;
      line-height: 1.6;
    }

    .sources a {
      color: #0056BA;
      text-decoration: underline;
      word-break: break-all;
    }

    .foot-note {
      margin-top: 8px;
      font-size: 11px;
      color: #727d99;
    }

    .log-box {
      margin-top: 10px;
      padding: 10px;
      border-radius: 10px;
      background: #fffdf6;
      border: 1px solid #f3e4bc;
      font-size: 11px;
      color: #74643f;
      line-height: 1.6;
    }

    @media (min-width: 860px) {
      .app {
        max-width: 980px;
        padding: 20px;
      }

      .tabs {
        grid-template-columns: repeat(3, 1fr);
      }

      .metric-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .sim-results {
        grid-template-columns: repeat(4, 1fr);
      }

      .creative-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .layout-2col {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="blob a"></div>
  <div class="blob b"></div>
  <div class="blob c"></div>

  <main class="app">
    <section class="hero">
      <div class="hero-top">
        <div>
          <p class="hand-note">売るか迷う気持ちに、やさしい数字を。</p>
          <h1>UcarPAC<br>広告チャネル最適化ラボ</h1>
          <p>日次差分モード: 2026-03-03（比較: 2026-03-02）</p>
        </div>
        <div class="mascot" aria-hidden="true">
          <span class="mouth"></span>
        </div>
      </div>
      <div class="hero-badges">
        <span class="tag pink">目標: 限られた予算で最大DL</span>
        <span class="tag">対象KPI: 有効CPI / 申込CPA</span>
        <span class="tag">重点: AppleAds予算再配分</span>
      </div>
    </section>

    <nav class="tabs">
      <button class="tab active" data-tab="dashboard">1. チャネル別ダッシュボード</button>
      <button class="tab" data-tab="apple">2. AppleAds強化提案</button>
      <button class="tab" data-tab="creative">3. クリエイティブ案</button>
    </nav>

    <section id="dashboard" class="panel active">
      <article class="card">
        <h2>チャネル別 KPI 一覧</h2>
        <p class="desc">社内実績（ダミー）に日次差分を反映。クリックでソート可能です。</p>

        <div class="metric-grid">
          <div class="metric">
            <div class="k">広告費合計</div>
            <div class="v" id="sumBudget">¥0</div>
          </div>
          <div class="metric">
            <div class="k">総DL</div>
            <div class="v" id="sumDl">0</div>
          </div>
          <div class="metric">
            <div class="k">平均 有効CPI</div>
            <div class="v" id="avgEcpi">¥0</div>
          </div>
          <div class="metric">
            <div class="k">平均 申込CPA</div>
            <div class="v" id="avgCpa">¥0</div>
          </div>
        </div>

        <div class="focus-buttons">
          <button class="focus-btn active" data-focus="effectiveCpi">有効CPI重視</button>
          <button class="focus-btn" data-focus="applicationCpa">申込CPA重視</button>
          <button class="focus-btn" data-focus="roas">ROAS重視</button>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th data-sort="channel">チャネル</th>
                <th data-sort="budget">予算(円)</th>
                <th data-sort="downloads">DL</th>
                <th data-sort="effectiveCpi">有効CPI</th>
                <th data-sort="applicationCpa">申込CPA</th>
                <th data-sort="roas">ROAS</th>
                <th data-sort="diff">前日比DL</th>
              </tr>
            </thead>
            <tbody id="channelBody"></tbody>
          </table>
        </div>
      </article>

      <div class="layout-2col">
        <article class="card">
          <h2>高CV車種サンプル</h2>
          <p class="desc">DL後30日で申込に至ったユーザーの車両傾向（ダミー）。</p>
          <div class="car-list">
            <div class="car-row">
              <div>
                <strong>トヨタ プリウス S（2019年 / 4.2万km）</strong>
                相場推定: 128万〜142万円
              </div>
              <div>申込率 10.8%</div>
            </div>
            <div class="car-row">
              <div>
                <strong>ホンダ N-BOX G（2020年 / 3.1万km）</strong>
                相場推定: 86万〜96万円
              </div>
              <div>申込率 9.9%</div>
            </div>
            <div class="car-row">
              <div>
                <strong>日産 セレナ e-POWER（2018年 / 5.6万km）</strong>
                相場推定: 151万〜168万円
              </div>
              <div>申込率 9.3%</div>
            </div>
          </div>
        </article>

        <article class="card">
          <h2>今日の打ち手</h2>
          <p class="desc">有効CPI最適化の即日アクション。</p>
          <div class="recommend">
            1) AppleAdsへ予算を段階的に+20%配分<br>
            2) Metaはリマーケ寄せで申込CPA改善<br>
            3) TikTokはDL効率維持しつつ動画尺を6秒中心に統一
          </div>
          <div class="log-box">
            [反映ログ]<br>
            - index 更新: 2026-03-03 09:20<br>
            - generation-log 追記: app-ad-channel-optimization v2<br>
            - kpi-history 反映: 有効CPI/申込CPA 日次差分
          </div>
        </article>
      </div>
    </section>

    <section id="apple" class="panel">
      <article class="card">
        <h2>AppleAds 予算増額シミュレーション</h2>
        <p class="desc">有効CPI最安チャネルを前提に、予算再配分時のDL増分を推計（推定モデル）。</p>

        <div class="sim-controls">
          <div class="range-box">
            <label>
              <span>AppleAds 予算増額率</span>
              <strong id="budgetRateLabel">+20%</strong>
            </label>
            <input id="budgetRange" type="range" min="0" max="80" value="20" step="5">
          </div>
          <div class="check-row">
            <label class="check-chip"><input type="checkbox" id="useCpp" checked> CPP最適化を適用</label>
            <label class="check-chip"><input type="checkbox" id="useMultiPlacement" checked> 複数プレースメント配信</label>
          </div>
        </div>

        <div class="sim-results">
          <div class="result">
            <div class="k">想定予算</div>
            <div class="v" id="simBudget">¥0</div>
          </div>
          <div class="result">
            <div class="k">想定有効DL</div>
            <div class="v" id="simInstalls">0</div>
          </div>
          <div class="result">
            <div class="k">想定有効CPI</div>
            <div class="v" id="simEcpi">¥0</div>
          </div>
          <div class="result">
            <div class="k">想定申込CPA</div>
            <div class="v" id="simCpa">¥0</div>
          </div>
        </div>

        <div class="bars">
          <div class="bar-col">
            <div class="bar apple" id="barBase" style="height:44px;"></div>
            <div class="bar-label">現状DL</div>
          </div>
          <div class="bar-col">
            <div class="bar sim" id="barSim" style="height:56px;"></div>
            <div class="bar-label">増額後DL</div>
          </div>
          <div class="bar-col">
            <div class="bar diff" id="barDiff" style="height:18px;"></div>
            <div class="bar-label">増分DL</div>
          </div>
        </div>

        <div class="recommend" id="simAdvice">
          推奨: +20%増額時は有効DL純増が最も効率的。+40%を超えるとCPI悪化が加速するため段階実行を推奨。
        </div>
      </article>
    </section>

    <section id="creative" class="panel">
      <article class="card">
        <h2>DL率上位チャネル向け クリエイティブ案</h2>
        <p class="desc">感情に寄り添う訴求で不安を下げ、DLと申込意向を同時に高める構成。</p>

        <div class="creative-grid">
          <div class="creative active" data-id="apple">
            <h3>AppleAds: 安心の相場チェック型</h3>
            <p>「個人情報なし」を先頭で表示。検索意図に合う短文コピー。</p>
            <div class="row-end">
              <span class="chip-mini">想定DLR +14%</span>
              <button class="btn-select" data-select="apple">プレビュー反映</button>
            </div>
          </div>

          <div class="creative" data-id="tiktok">
            <h3>TikTok: 体験ストーリー型UGC</h3>
            <p>“売るか迷う”気持ちの共感導線。6秒で価値が伝わる編集。</p>
            <div class="row-end">
              <span class="chip-mini">想定DLR +11%</span>
              <button class="btn-select" data-select="tiktok">プレビュー反映</button>
            </div>
          </div>

          <div class="creative" data-id="meta">
            <h3>Meta: 再検討ユーザー回収型</h3>
            <p>車種と未来相場を静止画カルーセルで再提示し、申込へ。</p>
            <div class="row-end">
              <span class="chip-mini">想定DLR +8%</span>
              <button class="btn-select" data-select="meta">プレビュー反映</button>
            </div>
          </div>
        </div>

        <div class="preview">
          <div class="phone" id="previewPhone">
            <p class="pv-channel" id="pvChannel">Apple Search Ads向け</p>
            <p class="pv-title" id="pvTitle">今すぐ売らなくてもOK。<br>あなたの愛車、いま何円？</p>
            <p class="pv-sub" id="pvSub">例: トヨタ プリウス 2019年 予想 138万円。個人情報入力なし。</p>
            <span class="pv-cta" id="pvCta">30秒でAI査定を見る</span>
          </div>
          <div class="abtest">
            <button class="run-btn" id="runAb">A/Bテスト開始</button>
            <span class="status-badge" id="abStatus">状態: 未開始</span>
          </div>
        </div>
      </article>
    </section>

    <section class="card sources">
      <h2>主要主張の出典（URL / 日付）</h2>
      <ol>
        <li>AppTweak「Apple Ads benchmarks 2025」(2025-10-09): 国別CPI（米国4.06ドル、日本2.57ドル）とグローバル中央値CPIの記載。<br><a href="https://www.apptweak.com/en/aso-blog/apple-ads-benchmarks" target="_blank" rel="noopener noreferrer">https://www.apptweak.com/en/aso-blog/apple-ads-benchmarks</a></li>
        <li>AppsFlyer「Performance Index 2025」PR (2025-12-03): Apple AdsがiOS非ゲームで上位、分析母数16.2B installs。<br><a href="https://www.appsflyer.com/company/newsroom/pr/performance-index-2025/" target="_blank" rel="noopener noreferrer">https://www.appsflyer.com/company/newsroom/pr/performance-index-2025/</a></li>
