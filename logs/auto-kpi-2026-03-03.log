        trend: [840, 815, 790, 770, 755, 742, 729],
        memo: "ボリューム確保向き。質のばらつきが課題。"
      },
      {
        id: "tiktok",
        name: "TikTok Ads",
        spend: 2000000,
        installs: 5100,
        validRate: 0.55,
        applications: 92,
        revenue: 2600000,
        prevEffCpi: 730,
        prevApplyCpi: 24200,
        trend: [790, 775, 760, 742, 725, 712, 702],
        memo: "DL単価は中位、申込までの歩留まりが弱い。"
      },
      {
        id: "x",
        name: "X Ads",
        spend: 1200000,
        installs: 2200,
        validRate: 0.58,
        applications: 41,
        revenue: 1000000,
        prevEffCpi: 980,
        prevApplyCpi: 29600,
        trend: [1090, 1060, 1025, 1002, 985, 972, 960],
        memo: "速報性訴求は強いが、現状効率は要改善。"
      }
    ];

    const creatives = [
      {
        id: "cr1",
        channel: "Apple Search Ads",
        concept: "個人情報不要訴求",
        title: "30秒AI査定 / 電話なしで相場確認",
        copy: "「アルファード 2021年式」など具体車名検索に合わせて、即時査定額と3か月予測を提示。",
        ctr: 6.4,
        cvr: 28.1,
        cpiGain: 11,
        installLift: 420,
        applyLift: 15,
        cost: 180000
      },
      {
        id: "cr2",
        channel: "Apple Search Ads",
        concept: "電話1社訴求",
        title: "8,000社入札でも電話は1社のみ",
        copy: "比較系キーワード面で電話ラッシュ不安を解消。申込前の不安離脱を抑える。",
        ctr: 5.8,
        cvr: 26.4,
        cpiGain: 9,
        installLift: 310,
        applyLift: 12,
        cost: 150000
      },
      {
        id: "cr3",
        channel: "Meta Reels",
        concept: "売り時予測グラフ訴求",
        title: "今売る？3か月後？AIが売り時を可視化",
        copy: "N-BOX / CX-5 の価格推移を3秒で見せるショート動画。出費管理連携で保存価値を作る。",
        ctr: 3.6,
        cvr: 19.2,
        cpiGain: 14,
        installLift: 580,
        applyLift: 18,
        cost: 240000
      },
      {
        id: "cr4",
        channel: "Meta Feed",
        concept: "出費管理フック",
        title: "ガソリン・保険・車検費、全部アプリで管理",
        copy: "出費管理ニーズから流入させ、後追いで査定導線へ。検討層の再訪率を強化。",
        ctr: 2.9,
        cvr: 17.8,
        cpiGain: 8,
        installLift: 260,
        applyLift: 9,
        cost: 130000
      }
    ];

    const yen = (v) => "¥" + Math.round(v).toLocaleString("ja-JP");
    const pct = (v) => (v >= 0 ? "+" : "") + v.toFixed(1) + "%";
    const num = (v) => Math.round(v).toLocaleString("ja-JP");

    let activeTab = "dashboard";
    let sortKey = "eff";
    let selectedChannel = channels[0].id;
    const selectedCreative = new Set();

    function metrics(channel) {
      const effectiveInstalls = channel.installs * channel.validRate;
      const effCpi = channel.spend / effectiveInstalls;
      const applyCpi = channel.spend / channel.applications;
      const roas = (channel.revenue / channel.spend) * 100;
      return { effectiveInstalls, effCpi, applyCpi, roas };
    }

    function renderTopKpi() {
      const totalSpend = channels.reduce((s, c) => s + c.spend, 0);
      const totalInstall = channels.reduce((s, c) => s + c.installs, 0);
      const totalEffInstall = channels.reduce((s, c) => s + (c.installs * c.validRate), 0);
      const totalApps = channels.reduce((s, c) => s + c.applications, 0);

      document.getElementById("sumSpend").textContent = yen(totalSpend);
      document.getElementById("sumInstall").textContent = num(totalInstall);
      document.getElementById("blendEffCpi").textContent = yen(totalSpend / totalEffInstall);
      document.getElementById("blendApplyCpi").textContent = yen(totalSpend / totalApps);
    }

    function sortedChannels() {
      const arr = [...channels];
      if (sortKey === "eff") {
        arr.sort((a, b) => metrics(a).effCpi - metrics(b).effCpi);
      } else if (sortKey === "apply") {
        arr.sort((a, b) => metrics(a).applyCpi - metrics(b).applyCpi);
      } else {
        arr.sort((a, b) => metrics(b).roas - metrics(a).roas);
      }
      return arr;
    }

    function renderRows() {
      const rows = document.getElementById("channelRows");
      rows.innerHTML = "";
      const data = sortedChannels();
      data.forEach((c) => {
        const m = metrics(c);
        const diffEff = ((m.effCpi - c.prevEffCpi) / c.prevEffCpi) * 100;
        const diffApply = ((m.applyCpi - c.prevApplyCpi) / c.prevApplyCpi) * 100;
        const tr = document.createElement("tr");
        tr.className = "channel-row" + (c.id === selectedChannel ? " selected" : "");
        tr.innerHTML = `
          <td><strong>${c.name}</strong></td>
          <td>${yen(c.spend)}</td>
          <td>${num(c.installs)}</td>
          <td>${(c.validRate * 100).toFixed(1)}%</td>
          <td>${yen(m.effCpi)}</td>
          <td>${yen(m.applyCpi)}</td>
          <td>${m.roas.toFixed(0)}%</td>
          <td>
            有効CPI <span class="${diffEff <= 0 ? "good" : "bad"}">${pct(diffEff)}</span><br/>
            申込CPI <span class="${diffApply <= 0 ? "good" : "bad"}">${pct(diffApply)}</span>
          </td>
        `;
        tr.addEventListener("click", () => {
          selectedChannel = c.id;
          renderRows();
          renderDetails();
          renderTrend();
        });
        rows.appendChild(tr);
      });
      renderRoasChart();
    }

    function renderDetails() {
      const c = channels.find((x) => x.id === selectedChannel);
      const m = metrics(c);
      document.getElementById("detailName").textContent = c.name;
      document.getElementById("detailMemo").textContent = c.memo;
      document.getElementById("detailEffCpi").textContent = yen(m.effCpi);
      document.getElementById("detailApplyCpi").textContent = yen(m.applyCpi);

      const effScore = Math.max(0, Math.min(100, (700 - m.effCpi) / 4));
      const applyScore = Math.max(0, Math.min(100, (24000 - m.applyCpi) / 120));
      document.getElementById("effBar").style.width = effScore + "%";
      document.getElementById("applyBar").style.width = applyScore + "%";
    }

    function renderTrend() {
      const c = channels.find((x) => x.id === selectedChannel);
      const svg = document.getElementById("trendChart");
      const w = 360;
      const h = 180;
      const pad = 24;

      const values = c.trend;
      const max = Math.max(...values, 760);
      const min = Math.min(...values, 330);
      const sx = (i) => pad + (i * ((w - pad * 2) / (values.length - 1)));
      const sy = (v) => h - pad - ((v - min) / (max - min)) * (h - pad * 2);

      let points = values.map((v, i) => `${sx(i)},${sy(v)}`).join(" ");

      const targetY = sy(380);
      let labels = "";
      values.forEach((v, i) => {
        labels += `<text x="${sx(i)}" y="${h - 7}" font-size="9" fill="#7b879d" text-anchor="middle">D${i+1}</text>`;
      });

      svg.innerHTML = `
        <rect x="0" y="0" width="${w}" height="${h}" fill="#ffffff"/>
        <line x1="${pad}" y1="${targetY}" x2="${w-pad}" y2="${targetY}" stroke="#6fc2ff" stroke-dasharray="4 3"/>
        <polyline fill="none" stroke="#F84CA2" stroke-width="3" points="${points}" />
        ${values.map((v, i) => `<circle cx="${sx(i)}" cy="${sy(v)}" r="3.5" fill="#F84CA2"/>`).join("")}
        <text x="${w-pad}" y="${targetY-5}" fill="#6fc2ff" font-size="10" text-anchor="end">目標 ¥380</text>
        ${labels}
      `;
    }

    function renderRoasChart() {
      const svg = document.getElementById("roasChart");
      const sorted = [...channels].sort((a, b) => metrics(b).roas - metrics(a).roas);
      const w = 360;
      const h = 180;
      const pad = 30;
      const barW = 46;
      const gap = 18;
      const max = Math.max(...sorted.map(c => metrics(c).roas), 220);

      let bars = "";
      let labels = "";
      sorted.forEach((c, i) => {
        const roas = metrics(c).roas;
        const x = pad + i * (barW + gap);
        const bh = (roas / max) * 112;
        const y = h - 28 - bh;
        bars += `<rect x="${x}" y="${y}" width="${barW}" height="${bh}" rx="6" fill="url(#gradBar)"></rect>`;
        bars += `<text x="${x + barW/2}" y="${y-4}" font-size="10" fill="#1c2663" text-anchor="middle">${roas.toFixed(0)}%</text>`;
        labels += `<text x="${x + barW/2}" y="${h-12}" font-size="9" fill="#6f7d95" text-anchor="middle">${c.name.split(" ")[0]}</text>`;
      });

      svg.innerHTML = `
        <defs>
          <linearGradient id="gradBar" x1="0%" x2="100%">
            <stop offset="0%" stop-color="#1ddcff"/>
            <stop offset="100%" stop-color="#4db4ff"/>
          </linearGradient>
        </defs>
        <rect x="0" y="0" width="${w}" height="${h}" fill="#ffffff"></rect>
        <line x1="18" y1="${h-28}" x2="${w-10}" y2="${h-28}" stroke="#e4ebf6"/>
        <line x1="18" y1="${h-28-((100/max)*112)}" x2="${w-10}" y2="${h-28-((100/max)*112)}" stroke="#c9d9f8" stroke-dasharray="4 3"/>
        <text x="${w-12}" y="${h-28-((100/max)*112)-4}" font-size="10" fill="#6f7d95" text-anchor="end">100%</text>
        ${bars}
        ${labels}
      `;
    }

    function runSimulation() {
      const base = channels.find(c => c.id === "apple");
      const baseM = metrics(base);

      const budget = Number(document.getElementById("budgetRange").value);
      const elastic = Number(document.getElementById("elasticRange").value) / 100;
      const boost = document.getElementById("creativeBoost").checked;
      const expand = document.getElementById("keywordExpand").checked;

      document.getElementById("budgetValue").textContent = yen(budget);
      document.getElementById("elasticValue").textContent = Math.round(elastic * 100) + "%（推奨: 20-28%）";

      const budgetRatio = budget / base.spend;
      const increase = Math.max(0, budgetRatio - 1);
      const saturation = 1 + (increase * elastic);
      let simEffCpi = baseM.effCpi * saturation;

      if (boost) simEffCpi *= 0.9;
      if (expand) simEffCpi *= 1.06;

      const qualityAdj = (expand ? 0.95 : 1) * (boost ? 1.03 : 1);
      const simEffInstalls = budget / simEffCpi;
      const baseApplyRate = base.applications / baseM.effectiveInstalls;
      const simApplyRate = Math.max(0.02, baseApplyRate * qualityAdj);
      const simApps = simEffInstalls * simApplyRate;
      const simApplyCpi = budget / simApps;
      const profitPerApp = 29000;
      const simRoas = (simApps * profitPerApp / budget) * 100;

      const deltaInst = ((simEffInstalls - baseM.effectiveInstalls) / baseM.effectiveInstalls) * 100;
      const deltaEff = ((simEffCpi - baseM.effCpi) / baseM.effCpi) * 100;
      const deltaApply = ((simApplyCpi - baseM.applyCpi) / baseM.applyCpi) * 100;
      const deltaRoas = ((simRoas - baseM.roas) / baseM.roas) * 100;

      document.getElementById("simInstalls").textContent = num(simEffInstalls);
      document.getElementById("simEffCpi").textContent = yen(simEffCpi);
      document.getElementById("simApplyCpi").textContent = yen(simApplyCpi);
      document.getElementById("simRoas").textContent = simRoas.toFixed(0) + "%";

      document.getElementById("deltaInstalls").innerHTML = `現状比 <span class="${deltaInst >= 0 ? "good" : "bad"}">${pct(deltaInst)}</span>`;
      document.getElementById("deltaEffCpi").innerHTML = `現状比 <span class="${deltaEff <= 0 ? "good" : "bad"}">${pct(deltaEff)}</span>`;
      document.getElementById("deltaApplyCpi").innerHTML = `現状比 <span class="${deltaApply <= 0 ? "good" : "bad"}">${pct(deltaApply)}</span>`;
      document.getElementById("deltaRoas").innerHTML = `現状比 <span class="${deltaRoas >= 0 ? "good" : "bad"}">${pct(deltaRoas)}</span>`;

      const budgetProgress = Math.max(0, Math.min(100, (budget - 3000000) / (8500000 - 3000000) * 100));
      const installProgress = Math.max(0, Math.min(100, ((simEffInstalls - baseM.effectiveInstalls) / 2500) * 100));
      const roasProgress = Math.max(0, Math.min(100, (simRoas / 170) * 100));

      document.getElementById("budgetBar").style.width = budgetProgress + "%";
      document.getElementById("installBar").style.width = installProgress + "%";
      document.getElementById("roasBar").style.width = roasProgress + "%";

      const hint = [];
      if (simEffCpi <= 500) {
        hint.push("有効CPIは健全。増額余地あり。");
      } else {
        hint.push("有効CPI悪化傾向。配信拡張を抑制。");
      }
      if (simApplyCpi <= 13000) {
        hint.push("申込CPIは目標内。売却相談導線を強化。");
      } else {
        hint.push("申込CPIが重い。LPと査定フォーム改善を優先。");
      }
      if (simRoas >= 180) {
        hint.push("ROAS高水準。AppleAds比率を上げる価値あり。");
      } else {
        hint.push("ROAS改善余地あり。クリエイティブ同時改善が必要。");
      }
      document.getElementById("simHint").textContent = "提案: " + hint.join(" ");

      document.getElementById("action1").textContent =
        simRoas >= 170 ? "AppleAdsを総予算の35〜42%へ増額。" : "AppleAds増額は30%以内に制限し学習を安定化。";
      document.getElementById("action2").textContent =
        boost ? "刷新クリエイティブを2週間ごとにA/B更新。" : "クリエイティブ刷新をONにしCPIを下げる。";
      document.getElementById("action3").textContent =
        expand ? "一般KW拡張時は除外KWを週次更新して品質維持。" : "指名+比較意図KW中心で申込率を守る。";
    }

    function renderCreatives() {
      const root = document.getElementById("creativeGrid");
      root.innerHTML = "";
      creatives.forEach((c) => {
        const active = selectedCreative.has(c.id);
        const card = document.createElement("article");
        card.className = "creative-card" + (active ? " active" : "");
        card.innerHTML = `
          <span class="creative-tag">${c.channel}</span>
          <span class="creative-tag">${c.concept}</span>
          <h3 class="creative-title">${c.title}</h3>
          <p class="creative-copy">${c.copy}</p>
          <div class="creative-metrics">
            <div class="metric-chip">予測CTR<strong>${c.ctr}%</strong></div>
            <div class="metric-chip">予測CVR<strong>${c.cvr}%</strong></div>
            <div class="metric-chip">CPI改善<strong>-${c.cpiGain}%</strong></div>
          </div>
          <button class="action-btn ${active ? "selected" : ""}" data-id="${c.id}">
            ${active ? "採用中（解除する）" : "この案を採用する"}
          </button>
        `;
        root.appendChild(card);
      });

      root.querySelectorAll(".action-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-id");
          if (selectedCreative.has(id)) {
            selectedCreative.delete(id);
          } else {
            selectedCreative.add(id);
          }
          renderCreatives();
          renderCreativeSummary();
        });
      });
    }

    function renderCreativeSummary() {
      let installLift = 0;
      let applyLift = 0;
      let cost = 0;
      selectedCreative.forEach((id) => {
        const c = creatives.find((x) => x.id === id);
        installLift += c.installLift;
        applyLift += c.applyLift;
        cost += c.cost;
      });
      document.getElementById("selectedCount").textContent = `採用数: ${selectedCreative.size}案`;
      document.getElementById("selectedLift").textContent = `想定DL純増: +${num(installLift)} / 月`;
      document.getElementById("selectedApplyLift").textContent = `想定申込純増: +${num(applyLift)} / 月`;
      document.getElementById("selectedCost").textContent = `制作費: ${yen(cost)}`;
    }

    function wireTabs() {
      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          activeTab = btn.getAttribute("data-tab");
          document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");

          document.querySelectorAll(".panel").forEach(p => {
            if (p.id === "dashboard" || p.id === "apple" || p.id === "creative") {
              p.classList.remove("active");
            }
          });
          document.getElementById(activeTab).classList.add("active");
        });
      });
    }

    function wireSort() {
      const eff = document.getElementById("sortEff");
      const app = document.getElementById("sortApply");
      const roas = document.getElementById("sortRoas");

      const clear = () => [eff, app, roas].forEach(b => b.classList.remove("active"));

      eff.addEventListener("click", () => {
        sortKey = "eff";
        clear();
        eff.classList.add("active");
        renderRows();
      });

      app.addEventListener("click", () => {
        sortKey = "apply";
        clear();
        app.classList.add("active");
        renderRows();
      });

      roas.addEventListener("click", () => {
        sortKey = "roas";
        clear();
        roas.classList.add("active");
        renderRows();
      });
    }

    function initSimulationWires() {
      ["budgetRange", "elasticRange", "creativeBoost", "keywordExpand"].forEach(id => {
        document.getElementById(id).addEventListener("input", runSimulation);
        document.getElementById(id).addEventListener("change", runSimulation);
      });
    }

    function init() {
      wireTabs();
      wireSort();
      initSimulationWires();

      renderTopKpi();
      renderRows();
      renderDetails();
      renderTrend();
      runSimulation();

      renderCreatives();
      renderCreativeSummary();
    }

    init();
  </script>
</body>
</html>
