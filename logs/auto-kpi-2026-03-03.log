  <script>
    const channels = [
      { channel: "Apple Search Ads", budget: 1800000, downloads: 4080, validRate: 0.93, applications: 347, roas: 186, diff: 12.4 },
      { channel: "TikTok for Business", budget: 900000, downloads: 1960, validRate: 0.90, applications: 130, roas: 154, diff: 8.1 },
      { channel: "Meta Ads", budget: 1400000, downloads: 2620, validRate: 0.86, applications: 166, roas: 141, diff: -3.2 },
      { channel: "Google App Campaign", budget: 1200000, downloads: 2180, validRate: 0.83, applications: 135, roas: 137, diff: -1.1 },
      { channel: "Moloco", budget: 500000, downloads: 940, validRate: 0.88, applications: 62, roas: 147, diff: 4.8 },
      { channel: "X Ads", budget: 300000, downloads: 470, validRate: 0.82, applications: 20, roas: 92, diff: -9.6 }
    ];

    let sortKey = "effectiveCpi";
    let sortAsc = true;
    let focusMetric = "effectiveCpi";

    const yen = (n) => "¥" + Math.round(n).toLocaleString("ja-JP");
    const num = (n) => Math.round(n).toLocaleString("ja-JP");

    function computedRow(row) {
      const validInstalls = row.downloads * row.validRate;
      return {
        ...row,
        effectiveCpi: row.budget / validInstalls,
        applicationCpa: row.budget / row.applications
      };
    }

    function renderSummary(rows) {
      const sumBudget = rows.reduce((a, b) => a + b.budget, 0);
      const sumDl = rows.reduce((a, b) => a + b.downloads, 0);
      const totalValid = rows.reduce((a, b) => a + (b.downloads * b.validRate), 0);
      const sumApps = rows.reduce((a, b) => a + b.applications, 0);
      document.getElementById("sumBudget").textContent = yen(sumBudget);
      document.getElementById("sumDl").textContent = num(sumDl);
      document.getElementById("avgEcpi").textContent = yen(sumBudget / totalValid);
      document.getElementById("avgCpa").textContent = yen(sumBudget / sumApps);
    }

    function renderTable() {
      let rows = channels.map(computedRow);

      rows.sort((a, b) => {
        const va = a[sortKey];
        const vb = b[sortKey];
        if (typeof va === "string") return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      const bestVal = focusMetric === "roas"
        ? Math.max(...rows.map(r => r[focusMetric]))
        : Math.min(...rows.map(r => r[focusMetric]));

      const body = document.getElementById("channelBody");
      body.innerHTML = rows.map(r => {
        const isBest = r[focusMetric] === bestVal;
        const deltaClass = r.diff >= 0 ? "up" : "down";
        const deltaText = (r.diff >= 0 ? "+" : "") + r.diff.toFixed(1) + "%";
        return `
          <tr class="${isBest ? "best" : ""}">
            <td>${r.channel}</td>
            <td>${num(r.budget)}</td>
            <td>${num(r.downloads)}</td>
            <td>${yen(r.effectiveCpi)}</td>
            <td>${yen(r.applicationCpa)}</td>
            <td>${r.roas.toFixed(0)}%</td>
            <td class="delta ${deltaClass}">${deltaText}</td>
          </tr>
        `;
      }).join("");
      renderSummary(rows);
    }

    document.querySelectorAll(".focus-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".focus-btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        focusMetric = btn.dataset.focus;
        if (focusMetric === "roas") {
          sortKey = "roas";
          sortAsc = false;
        } else {
          sortKey = focusMetric;
          sortAsc = true;
        }
        renderTable();
      });
    });

    document.querySelectorAll("th[data-sort]").forEach(th => {
      th.addEventListener("click", () => {
        const key = th.dataset.sort;
        if (sortKey === key) sortAsc = !sortAsc;
        else {
          sortKey = key;
          sortAsc = key === "channel";
        }
        renderTable();
      });
    });

    document.querySelectorAll(".tab").forEach(tab => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".tab").forEach(b => b.classList.remove("active"));
        tab.classList.add("active");
        document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
        document.getElementById(tab.dataset.tab).classList.add("active");
      });
    });

    const baseApple = computedRow(channels[0]);
    const budgetRange = document.getElementById("budgetRange");
    const budgetRateLabel = document.getElementById("budgetRateLabel");
    const useCpp = document.getElementById("useCpp");
    const useMultiPlacement = document.getElementById("useMultiPlacement");

    function simulateApple() {
      const p = Number(budgetRange.value) / 100;
      budgetRateLabel.textContent = "+" + budgetRange.value + "%";

      let newBudget = baseApple.budget * (1 + p);
      let ecpi = baseApple.effectiveCpi;
      ecpi *= 1 + Math.max(0, p - 0.25) * 0.38;
      if (useCpp.checked) ecpi *= 0.94;
      if (useMultiPlacement.checked) ecpi *= 0.96;

      const validInstalls = newBudget / ecpi;
      const appRateBase = baseApple.applications / (baseApple.downloads * baseApple.validRate);
      let appRate = appRateBase;
      if (useCpp.checked) appRate *= 1.05;
      if (useMultiPlacement.checked) appRate *= 1.03;

      const apps = validInstalls * appRate;
      let simCpa = newBudget / apps;

      document.getElementById("simBudget").textContent = yen(newBudget);
      document.getElementById("simInstalls").textContent = num(validInstalls);
      document.getElementById("simEcpi").textContent = yen(ecpi);
      document.getElementById("simCpa").textContent = yen(simCpa);

      const baseValid = baseApple.downloads * baseApple.validRate;
      const inc = Math.max(0, validInstalls - baseValid);
      const baseH = Math.min(108, Math.round(baseValid / 46));
      const simH = Math.min(108, Math.round(validInstalls / 46));
      const incH = Math.min(108, Math.max(12, Math.round(inc / 30)));

      document.getElementById("barBase").style.height = baseH + "px";
      document.getElementById("barSim").style.height = simH + "px";
      document.getElementById("barDiff").style.height = incH + "px";

      const advice = document.getElementById("simAdvice");
      if (p <= 0.25) {
        advice.textContent = "推奨: 現在の設定では増額効率が高いゾーンです。+20%前後で段階的に配分し、48時間ごとに有効CPIを再評価。";
      } else if (p <= 0.5) {
        advice.textContent = "注意: +30%以降はCPI上振れリスク。CPP・キーワード除外を同時適用し、申込CPA悪化を抑制してください。";
      } else {
        advice.textContent = "警戒: +55%以上は効率低下の可能性が高い推定。AppleAds単独拡張より、TikTok/Meta再配分との併用を推奨。";
      }
    }

    [budgetRange, useCpp, useMultiPlacement].forEach(el => el.addEventListener("input", simulateApple));
    [useCpp, useMultiPlacement].forEach(el => el.addEventListener("change", simulateApple));

    const creativeMap = {
      apple: {
        channel: "Apple Search Ads向け",
        title: "今すぐ売らなくてもOK。<br>あなたの愛車、いま何円？",
        sub: "例: トヨタ プリウス 2019年 予想 138万円。個人情報入力なし。",
        cta: "30秒でAI査定を見る",
        bg: "linear-gradient(160deg,#fff5e8,#ffffff)"
      },
      tiktok: {
        channel: "TikTok向けUGC",
        title: "「電話いっぱい来るの怖い…」<br>その不安、ここで終わり。",
        sub: "電話1社のみ。8,000社オークションで最高額を狙える。",
        cta: "相場だけ先にチェック",
        bg: "linear-gradient(160deg,#fff0f7,#fff8ef)"
      },
      meta: {
        channel: "Meta再検討向け",
        title: "3か月後の予想まで見える。<br>売りどきを、後悔なく。",
        sub: "ホンダ N-BOX 2020年 予測: 91万円 → 88万円（3か月後）",
        cta: "将来予測グラフを見る",
        bg: "linear-gradient(160deg,#edf4ff,#fff8f2)"
      }
    };

    document.querySelectorAll(".btn-select").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.select;
        document.querySelectorAll(".creative").forEach(c => c.classList.remove("active"));
        btn.closest(".creative").classList.add("active");
        const v = creativeMap[id];
        document.getElementById("pvChannel").textContent = v.channel;
        document.getElementById("pvTitle").innerHTML = v.title;
        document.getElementById("pvSub").textContent = v.sub;
        document.getElementById("pvCta").textContent = v.cta;
        document.getElementById("previewPhone").style.background = v.bg;
      });
    });

    const runAb = document.getElementById("runAb");
    const abStatus = document.getElementById("abStatus");
    const statuses = ["状態: 未開始", "状態: 配信準備中", "状態: テスト配信中", "状態: 学習完了（次アクション待ち）"];
    let st = 0;
    runAb.addEventListener("click", () => {
      st = (st + 1) % statuses.length;
      abStatus.textContent = statuses[st];
    });

    renderTable();
    simulateApple();
  </script>
</body>
</html>
