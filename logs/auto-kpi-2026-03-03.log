    }

    .creative-title {
      margin: 6px 0 4px;
      font-size: 15px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .creative-copy {
      margin: 0;
      font-size: 13px;
      color: var(--text-black);
    }

    .creative-metrics {
      margin-top: 8px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 6px;
    }

    .metric-chip {
      border-radius: 10px;
      background: #f6f9ff;
      border: 1px solid #e1e8f5;
      padding: 6px;
      font-size: 11px;
      text-align: center;
    }

    .metric-chip strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      margin-top: 2px;
    }

    .action-btn {
      margin-top: 10px;
      min-height: 43px;
      width: 100%;
      border: 0;
      border-radius: 30px;
      font-weight: 700;
      font-size: 14px;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      cursor: pointer;
      transition: 180ms ease;
    }

    .action-btn.selected {
      background: var(--gradient-pink);
      color: #fff;
    }

    .summary {
      margin-top: 12px;
      border-radius: 12px;
      border: 1px solid #dbe3f0;
      background: #fbfdff;
      padding: 12px;
    }

    .summary p {
      margin: 0 0 6px;
      font-size: 12px;
    }

    .source-table {
      width: 100%;
      min-width: 680px;
      margin-top: 8px;
    }

    .source-table td a {
      color: var(--dark-blue);
      text-decoration: underline;
      word-break: break-all;
    }

    .muted {
      color: var(--text-gray);
      font-size: 11px;
    }

    .footer-note {
      margin-top: 14px;
      text-align: center;
      color: var(--text-gray);
      font-size: 11px;
      padding-bottom: 24px;
    }

    @media (min-width: 720px) {
      .shell {
        padding: 20px;
      }

      .top-kpis {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .toolbar {
        grid-template-columns: 1fr auto;
      }

      .detail-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .charts {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .simulation-grid {
        grid-template-columns: 1.2fr 1fr;
      }

      .creative-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @keyframes fade-in {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pop {
      from { opacity: 0; transform: scale(0.98); }
      to { opacity: 1; transform: scale(1); }
    }

    @keyframes grow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
  </style>
</head>
<body>
