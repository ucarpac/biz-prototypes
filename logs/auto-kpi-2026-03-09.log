      color: var(--dark-blue);
      letter-spacing: -0.04em;
      font-weight: 900;
    }

    .hero-sub {
      margin: 10px 0 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.7;
    }

    .glass-card,
    .info-card,
    .chart-card,
    .compare-card,
    .proof-card {
      position: relative;
      z-index: 1;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.8);
      box-shadow: 0 18px 38px rgba(28, 38, 99, 0.09);
      border-radius: 24px;
      backdrop-filter: blur(14px);
    }

    .glass-card {
      margin-top: 18px;
      padding: 16px;
    }

    .car-meta {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .car-thumb {
      width: 72px;
      height: 72px;
      border-radius: 22px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(237, 241, 244, 0.88));
      display: grid;
      place-items: center;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.05);
      font-size: 36px;
    }

    .car-copy strong {
      display: block;
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 1.5;
    }

    .car-copy span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
    }

    .value-card {
      margin-top: 14px;
      padding: 16px;
      border-radius: 22px;
      background: linear-gradient(135deg, rgba(9, 19, 85, 1), rgba(29, 46, 147, 0.96));
      color: var(--white);
      box-shadow: 0 20px 36px rgba(9, 19, 85, 0.24);
      overflow: hidden;
      position: relative;
    }

    .value-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 20%, rgba(255, 255, 255, 0.16) 50%, transparent 80%);
      transform: translateX(-100%);
      animation: shimmer 3.8s ease-in-out infinite;
      pointer-events: none;
    }

    .value-label {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.72);
      letter-spacing: 0.04em;
    }

    .value-main {
      margin-top: 10px;
      display: flex;
      align-items: flex-end;
      gap: 4px;
      font-family: var(--font-number);
      font-size: clamp(36px, 10vw, 52px);
      line-height: 0.95;
      letter-spacing: -0.04em;
    }

    .value-main small {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .value-row {
      margin-top: 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .trend-chip {
      min-height: 28px;
      padding: 0 12px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
      animation: pulseSoft 2.2s ease-in-out infinite;
    }

    .value-note {
      font-size: 11px;
      color: rgba(255, 255, 255, 0.72);
    }

    .chart-card {
      margin-top: 14px;
      padding: 16px;
    }

    .chart-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 14px;
    }

    .chart-head strong,
    .section-title {
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 1.5;
    }

    .mini-badge {
      min-height: 26px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.06);
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
    }

    .forecast-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 6px;
    }

    .forecast-point {
      padding: 12px 10px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(250, 250, 250, 1), rgba(237, 241, 244, 1));
      text-align: center;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.04);
      animation: rise 0.7s ease both;
    }

    .forecast-point:nth-child(2) {
      animation-delay: 0.08s;
    }

    .forecast-point:nth-child(3) {
      animation-delay: 0.16s;
    }

    .forecast-point strong {
      display: block;
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: 20px;
      line-height: 1;
      margin-top: 8px;
    }

    .forecast-point span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .curve {
      margin-top: 12px;
      width: 100%;
      height: 78px;
      display: block;
    }

    .curve path.track {
      stroke: rgba(28, 38, 99, 0.12);
      stroke-width: 3;
      fill: none;
    }

    .curve path.live {
      stroke: url(#lineGradient);
      stroke-width: 4;
      fill: none;
      stroke-linecap: round;
      stroke-dasharray: 280;
      stroke-dashoffset: 280;
      animation: drawLine 1.6s ease forwards;
    }

    .curve circle {
      fill: var(--white);
      stroke-width: 4;
      stroke: var(--pink);
    }

    .chip-row-inline {
      margin-top: 14px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tiny-chip {
      min-height: 31px;
      padding: 0 12px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(28, 38, 99, 0.05);
    }

    .primary-cta {
      margin-top: 16px;
      width: 100%;
      min-height: 52px;
      border-radius: var(--radius-button-tall);
      padding: 0 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
      box-shadow: 0 16px 28px rgba(64, 191, 255, 0.28);
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .primary-cta:hover {
      transform: translateY(-2px) scale(1.01);
      box-shadow: 0 22px 32px rgba(64, 191, 255, 0.32);
    }

    .primary-cta.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 16px 28px rgba(248, 76, 162, 0.26);
    }

    .month-switch {
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .month-chip {
      min-height: 44px;
      border-radius: var(--radius-chip);
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(28, 38, 99, 0.06);
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease;
    }

    .month-chip.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .dashboard-grid {
      margin-top: 14px;
      display: grid;
      gap: 12px;
    }

    .info-card {
      padding: 16px;
    }

    .expense-main {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
    }

    .expense-value {
      font-family: var(--font-number);
      font-size: clamp(34px, 10vw, 48px);
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: var(--dark-blue);
    }

    .expense-value small {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 700;
      margin-left: 4px;
    }

    .expense-caption {
      min-height: 30px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(248, 76, 162, 0.08);
      color: var(--pink);
      font-size: 11px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      white-space: nowrap;
    }

    .bars {
      margin-top: 14px;
      display: grid;
      gap: 12px;
    }

    .bar-row {
      display: grid;
      gap: 6px;
    }

    .bar-row-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .bar-track {
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      width: 0;
      transition: width 420ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .bar-fill.fuel {
      background: linear-gradient(90deg, #4db4ff, #1ddcff);
    }

    .bar-fill.insurance {
      background: linear-gradient(90deg, #f84ca2, #ff8cc7);
    }

    .bar-fill.maintenance {
      background: linear-gradient(90deg, #091355, #1d2e93);
    }

    .value-sync {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .value-tile {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(250, 250, 250, 1), rgba(237, 241, 244, 1));
    }

    .value-tile span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .value-tile strong {
      display: block;
      margin-top: 8px;
      font-family: var(--font-number);
      color: var(--dark-blue);
      font-size: 24px;
      line-height: 1;
    }

    .insight-card {
      margin-top: 12px;
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(255, 216, 232, 0.6), rgba(255, 255, 255, 0.92));
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.7;
    }

    .compare-switch {
      margin-top: 18px;
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    .compare-switch::-webkit-scrollbar {
      display: none;
    }

    .compare-chip {
      flex: 0 0 auto;
      min-height: 42px;
      padding: 0 16px;
      border-radius: var(--radius-chip);
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(28, 38, 99, 0.05);
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease;
    }

    .compare-chip.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .compare-card {
      margin-top: 14px;
      padding: 16px;
    }

    .meter {
      margin-top: 16px;
      position: relative;
      height: 16px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.2), rgba(248, 76, 162, 0.18));
      overflow: hidden;
    }

    .meter-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0;
      border-radius: 999px;
      background: linear-gradient(90deg, #09c36d, #1ddcff, #f84ca2);
      transition: width 420ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .meter-labels {
      margin-top: 8px;
      display: flex;
      justify-content: space-between;
      gap: 8px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
    }

    .call-stat {
      margin-top: 16px;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
    }

    .call-count {
      color: var(--dark-blue);
      font-family: var(--font-number);
      font-size: clamp(44px, 12vw, 62px);
      line-height: 0.9;
      letter-spacing: -0.05em;
    }

    .call-count small {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 700;
      margin-left: 4px;
    }

    .stress-badge {
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(29, 220, 255, 0.1);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
    }

    .versus-grid {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .versus-row {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 10px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(250, 250, 250, 0.86);
      border: 1px solid rgba(28, 38, 99, 0.05);
      transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
    }

    .versus-row.active {
      transform: translateY(-2px);
      border-color: rgba(64, 153, 255, 0.35);
      box-shadow: 0 14px 30px rgba(28, 38, 99, 0.08);
    }

    .versus-left strong,
    .versus-right strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.5;
    }

    .versus-left span,
    .versus-right span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
    }

    .proof-card {
      margin-top: 12px;
      padding: 15px 16px;
      background: linear-gradient(135deg, rgba(9, 19, 85, 0.98), rgba(29, 46, 147, 0.94));
      color: var(--white);
    }

    .proof-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .proof-chip {
      min-height: 30px;
      padding: 0 12px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.12);
      color: var(--white);
      font-size: 11px;
      font-weight: 700;
    }

    .proof-note {
      margin-top: 12px;
      color: rgba(255, 255, 255, 0.72);
      font-size: 11px;
      line-height: 1.7;
    }

    .dots {
      margin-top: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.16);
      transition: width 200ms ease, background 200ms ease;
    }

    .dot.active {
      width: 30px;
      background: linear-gradient(90deg, #1ddcff, #f84ca2);
    }

    .caption-card {
      margin-top: 14px;
      padding: 14px 16px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(237, 241, 244, 0.94));
      box-shadow: 0 12px 30px rgba(28, 38, 99, 0.08);
    }

    .caption-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 1.5;
    }

    .caption-card span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .swipe-hint {
      margin-top: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      text-align: center;
    }

    .swipe-line {
      width: 56px;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, transparent, rgba(28, 38, 99, 0.28), transparent);
      position: relative;
      overflow: hidden;
    }

    .swipe-line::after {
      content: "";
      position: absolute;
      top: 0;
      left: -14px;
      width: 14px;
      height: 2px;
      background: linear-gradient(90deg, #1ddcff, #f84ca2);
      animation: swipeGhost 1.9s ease-in-out infinite;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translate(-50%, 120%);
      z-index: 20;
      min-width: 220px;
      max-width: calc(100vw - 32px);
      padding: 12px 16px;
      border-radius: 999px;
      background: rgba(9, 19, 85, 0.92);
      color: var(--white);
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 18px 34px rgba(9, 19, 85, 0.32);
      transition: transform 240ms ease;
    }

    .toast.show {
      transform: translate(-50%, 0);
    }

    .footnote {
      margin-top: 10px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.6;
      text-align: center;
    }

    @keyframes shimmer {
      0% { transform: translateX(-120%); }
      55% { transform: translateX(120%); }
      100% { transform: translateX(120%); }
    }

    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }

    @keyframes rise {
      from {
        transform: translateY(10px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-10px) scale(1.04); }
    }

    @keyframes breathe {
      0%, 100% { transform: scale(0.98); opacity: 0.72; }
      50% { transform: scale(1.03); opacity: 1; }
    }

    @keyframes pulseSoft {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }

    @keyframes swipeGhost {
      0% { transform: translateX(0); opacity: 0; }
      20% { opacity: 1; }
      80% { opacity: 1; }
      100% { transform: translateX(70px); opacity: 0; }
    }

    @keyframes drift {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(18px, 16px); }
    }

    @media (min-width: 760px) {
      .page {
        padding: 28px 24px 56px;
      }

      .chip-grid,
      .mode-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1080px) {
      .page {
        grid-template-columns: minmax(360px, 420px) minmax(0, 1fr);
        align-items: start;
      }

      .summary-panel {
        position: sticky;
        top: 20px;
      }

      .preview-panel {
        padding: 22px 24px 22px;
      }

      .preview-head {
        margin-bottom: 18px;
      }

      .phone-stage {
        min-height: 860px;
      }

      .caption-card {
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation: none !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="summary-panel">
      <span class="eyebrow">ASO Daily Diff / 2026-03-09</span>
      <h1 class="title">ストアPV→DL率を<br>17.3%から25%へ。</h1>
      <p class="lead">最初の3枚で何を一番先に伝えるかを検証する、UcarPAC向けインタラクティブ・ストアスクショ試作です。AI査定、出費管理+将来予測、競合比較「電話0本」をそれぞれ独立テーマで切り替えられます。</p>

      <div class="kpi-board">
        <div class="kpi-card">
          <span class="kpi-label">現状CVR</span>
          <div class="kpi-value"><span data-count="17.3" data-decimals="1">0.0</span><small>%</small></div>
          <div class="kpi-note">ストア詳細ページ閲覧からのDL率</div>
        </div>
        <div class="kpi-card">
          <span class="kpi-label">目標CVR</span>
          <div class="kpi-value"><span data-count="25.0" data-decimals="1">0.0</span><small>%</small></div>
          <div class="kpi-note">先頭3枚の訴求最適化で引き上げ</div>
        </div>
        <div class="kpi-card">
          <span class="kpi-label">必要改善幅</span>
          <div class="kpi-value"><span data-count="7.7" data-decimals="1">0.0</span><small>pt</small></div>
          <div class="kpi-note">A/B/Cの3テーマで価値訴求を分離</div>
        </div>
      </div>

      <div class="quest-card">
        <div class="step-head">
          <span class="step-label">Diagnostic Flow</span>
          <div class="steps" aria-hidden="true">
            <div class="steps-progress" id="stepsProgress"></div>
            <div class="step-dot active">1</div>
            <div class="step-dot">2</div>
            <div class="step-dot">3</div>
          </div>
        </div>
        <p class="quest-title">どの価値から見せると、<br>いちばんDLしたくなるか。</p>
        <p class="quest-copy">まずはユーザーの動機に近い切り口を選択してください。選択にあわせてスクショ案が切り替わります。</p>

        <div class="chip-grid">
          <button class="choice-chip active" type="button" data-jump="0">
            <span class="chip-copy">
              <strong>まず相場だけ知りたい</strong>
              <span>AI査定を先頭に置く iOS向け A案</span>
            </span>
            <span class="chip-icon">AI</span>
          </button>
          <button class="choice-chip" type="button" data-jump="1">
            <span class="chip-copy">
              <strong>維持費もまとめて見たい</strong>
              <span>出費管理+将来予測を見せる Android向け B案</span>
            </span>
            <span class="chip-icon">¥</span>
          </button>
          <button class="choice-chip" type="button" data-jump="2">
            <span class="chip-copy">
