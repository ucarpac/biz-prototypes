      padding: 12px 16px;
      background: #fff;
      color: var(--text-black);
      font-size: 13px;
      font-weight: 700;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.08);
      cursor: pointer;
      transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 10px 22px rgba(28,38,99,0.18);
      transform: translateY(-1px);
    }

    .layout {
      display: grid;
      gap: 20px;
    }

    .stage {
      display: grid;
      gap: 18px;
      align-items: start;
    }

    .phone-frame {
      width: min(100%, var(--screen-width));
      margin: 0 auto;
      background: linear-gradient(180deg, #11141b 0%, #1c1f2b 100%);
      padding: 10px;
      border-radius: 38px;
      box-shadow:
        0 22px 60px rgba(28,38,99,0.2),
        0 3px 0 rgba(255,255,255,0.35) inset;
      position: relative;
    }

    .phone-frame::before {
      content: "";
      position: absolute;
      width: 132px;
      height: 28px;
      border-radius: 0 0 18px 18px;
      background: #0d1018;
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 4;
    }

    .screen {
      display: none;
      position: relative;
      width: 100%;
      min-height: calc(var(--screen-height) * 0.86);
      border-radius: 30px;
      overflow: hidden;
      background: linear-gradient(180deg, #ffffff 0%, #f7faff 46%, #edf4ff 100%);
      color: var(--text-black);
      padding: 44px 18px 22px;
    }

    .screen.active {
      display: block;
      animation: fadeUp 0.5s ease;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px) scale(0.985); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .status-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 11px;
      color: var(--dark-blue);
      margin-bottom: 16px;
      font-weight: 700;
    }

    .platform-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(28,38,99,0.06);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .hero-card {
      background: linear-gradient(160deg, #091355 0%, #1c2663 58%, #2d43a1 100%);
      border-radius: 26px;
      padding: 18px;
      color: var(--white);
      position: relative;
      overflow: hidden;
      box-shadow: 0 16px 34px rgba(28,38,99,0.22);
    }

    .hero-card::before {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      right: -40px;
      top: -70px;
      background: radial-gradient(circle, rgba(29,220,255,0.33), transparent 70%);
    }

    .hero-card::after {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      left: -80px;
      bottom: -90px;
      background: radial-gradient(circle, rgba(248,76,162,0.25), transparent 70%);
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.05em;
      color: var(--text-light-blue);
    }

    .hero-title {
      margin: 12px 0 8px;
      position: relative;
      z-index: 1;
      font-size: 31px;
      line-height: 1.25;
      font-weight: 900;
      letter-spacing: -0.02em;
    }

    .hero-sub {
      position: relative;
      z-index: 1;
      margin: 0;
      font-size: 13px;
      line-height: 1.7;
      color: rgba(255,255,255,0.86);
    }

    .price-row {
      margin-top: 18px;
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .price-card,
    .metric-card,
    .soft-card {
      background: rgba(255,255,255,0.94);
      border-radius: 18px;
      padding: 14px;
      box-shadow: 0 10px 22px rgba(28,38,99,0.08);
    }

    .price-card .tiny,
    .metric-card .tiny,
    .soft-card .tiny {
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .yen {
      color: var(--dark-blue);
      font-size: 33px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.03em;
      font-family: var(--font-number);
    }

    .yen small {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 800;
      margin-left: 3px;
    }

    .range-note {
      margin-top: 8px;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.5;
    }

    .metric-grid {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .metric-card strong {
      display: block;
      font-size: 18px;
      line-height: 1.3;
      color: var(--dark-blue);
      font-weight: 900;
    }

    .metric-card span {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.5;
      margin-top: 4px;
    }

    .section-card {
      margin-top: 14px;
      background: rgba(255,255,255,0.92);
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 10px 26px rgba(28,38,99,0.07);
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
    }

    .section-header h2 {
      margin: 0;
      font-size: 18px;
      color: var(--dark-blue);
      line-height: 1.5;
      font-weight: 800;
    }

    .section-header span {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
    }

    .progress-list {
      display: grid;
      gap: 12px;
      margin-top: 14px;
    }

    .progress-item {
      display: grid;
      gap: 7px;
    }

    .progress-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 12px;
      color: var(--text-black);
      font-weight: 700;
    }

    .bar {
      width: 100%;
      height: 10px;
      background: var(--back-gray);
      border-radius: 999px;
      overflow: hidden;
      position: relative;
    }

    .bar > span {
      display: block;
      height: 100%;
      width: 0;
      border-radius: 999px;
      transition: width 0.9s ease;
    }

    .bar.primary > span {
      background: var(--gradient-primary);
    }

    .bar.pink > span {
      background: var(--gradient-pink);
    }

    .bar.deep > span {
      background: linear-gradient(90deg, #091355, #2e46af);
    }

    .cta {
      margin-top: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .cta button,
    .ghost-btn,
    .toggle-btn {
      appearance: none;
      border: 0;
      cursor: pointer;
      font-family: inherit;
    }

    .primary-btn {
      flex: 1;
      min-height: 48px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 900;
      box-shadow: 0 12px 24px rgba(64,191,255,0.25);
    }

    .ghost-btn {
      min-width: 48px;
      min-height: 48px;
      border-radius: 50%;
      background: rgba(28,38,99,0.06);
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 800;
    }

    .spec-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .spec-chip {
      padding: 8px 10px;
      border-radius: 999px;
      background: var(--back-gray);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 0.96fr 1.04fr;
      gap: 12px;
      align-items: center;
    }

    .donut-wrap {
      position: relative;
      width: 148px;
      height: 148px;
      margin: 0 auto;
    }

    .donut-center {
      position: absolute;
      inset: 32px;
      border-radius: 999px;
      background: #fff;
      display: grid;
      place-items: center;
      text-align: center;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.04);
    }

    .donut-center strong {
      display: block;
      font-size: 26px;
      line-height: 1;
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .donut-center span {
      display: block;
      font-size: 11px;
      color: var(--text-gray);
      margin-top: 4px;
      font-weight: 700;
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      gap: 4px;
    }

    .expense-item .row {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-black);
    }

    .expense-item .row span:last-child {
      color: var(--dark-blue);
    }

    .toggle-row {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .toggle-btn {
      flex: 1;
      min-height: 40px;
      border-radius: 999px;
      background: #fff;
      color: var(--text-black);
      font-size: 12px;
      font-weight: 800;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.08);
      transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
    }

    .toggle-btn.active {
      background: var(--pink);
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 10px 20px rgba(248,76,162,0.18);
    }

    .mini-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
      font-size: 12px;
    }

    .mini-table th,
    .mini-table td {
      padding: 10px 8px;
      text-align: center;
      border-bottom: 1px solid var(--ruled-line);
    }

    .mini-table th {
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 800;
    }

    .mini-table td {
      font-weight: 700;
      color: var(--text-black);
    }

    .mini-table td.highlight {
      color: var(--dark-blue);
      background: linear-gradient(180deg, rgba(29,220,255,0.1), rgba(77,180,255,0.03));
      border-radius: 10px;
    }

    .compare-panel {
      display: grid;
      gap: 14px;
    }

    .compare-state {
      display: flex;
      gap: 8px;
      background: var(--back-gray);
      padding: 6px;
      border-radius: 999px;
    }

    .compare-state button {
      flex: 1;
      border: 0;
      background: transparent;
      min-height: 38px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      color: var(--text-gray);
      cursor: pointer;
      transition: background 0.25s ease, color 0.25s ease;
    }

    .compare-state button.active {
      background: #fff;
      color: var(--dark-blue);
      box-shadow: 0 8px 18px rgba(28,38,99,0.08);
    }

    .compare-grid {
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr 0.7fr 0.85fr;
      gap: 8px;
      align-items: center;
      background: #fff;
      border-radius: 16px;
      padding: 12px 10px;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.06);
    }

    .compare-row.highlight {
      background: linear-gradient(90deg, rgba(29,220,255,0.12), rgba(248,76,162,0.08));
      box-shadow: inset 0 0 0 1px rgba(64,153,255,0.14), 0 12px 24px rgba(28,38,99,0.06);
    }

    .compare-row strong {
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.4;
      font-weight: 900;
    }

    .compare-row span {
      font-size: 11px;
      line-height: 1.5;
      text-align: center;
      font-weight: 800;
      color: var(--text-black);
    }

    .compare-row .sub {
      color: var(--text-gray);
      font-weight: 700;
      text-align: left;
    }

    .insight-card {
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(64,153,255,0.14);
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 10px 30px rgba(28,38,99,0.08);
      backdrop-filter: blur(10px);
    }

    .insight-card h3 {
      margin: 0 0 10px;
      font-size: 18px;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .insight-card p {
      margin: 0 0 12px;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.7;
    }

    .quote {
      background: linear-gradient(180deg, rgba(9,19,85,0.04), rgba(64,153,255,0.05));
      border-radius: 16px;
      padding: 14px;
      font-size: 13px;
      line-height: 1.7;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .quote small {
      display: block;
      margin-top: 8px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .footer-note {
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
    }

    .pulse {
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); box-shadow: 0 12px 24px rgba(64,191,255,0.25); }
      50% { transform: scale(1.02); box-shadow: 0 16px 30px rgba(64,191,255,0.34); }
    }

    .floating-kpi {
      margin-top: 14px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .floating-kpi .soft-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.4;
      font-weight: 900;
    }

    .floating-kpi .soft-card span {
      display: block;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
      margin-top: 2px;
      font-weight: 700;
    }

    .screen-footer {
      margin-top: 14px;
      padding-top: 12px;
      border-top: 1px solid rgba(28,38,99,0.08);
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    .screen-footer strong {
      color: var(--dark-blue);
    }

    .hidden {
      display: none !important;
    }

    @media (min-width: 900px) {
      body {
        padding: 28px 28px 56px;
      }

      .workspace {
        grid-template-columns: minmax(0, 360px) minmax(0, 1fr);
        align-items: start;
      }

      .stage {
        grid-template-columns: minmax(0, 420px) minmax(0, 1fr);
      }

      .phone-frame {
        margin: 0;
      }

      .insight-stack {
        display: grid;
        gap: 16px;
      }
    }

    @media (max-width: 420px) {
      .kpi-strip {
        grid-template-columns: 1fr;
      }

      .price-row,
      .expense-grid {
        grid-template-columns: 1fr;
      }

      .metric-grid,
      .floating-kpi {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .compare-row {
        grid-template-columns: 1.15fr 0.85fr 0.7fr 0.85fr;
        padding: 10px 8px;
      }

      .hero-title {
        font-size: 28px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="topbar">
      <div class="brand-row">
        <div class="brand">
          <div class="brand-mark" aria-hidden="true"></div>
          <div class="brand-text">
            <strong>UcarPAC App Store Screens</strong>
            <span>ASO検証用 / ストアPV→DL率を17.3%から25%へ</span>
          </div>
        </div>
        <div class="platform-pill">2026-03-09 / Data-driven Creative</div>
      </div>

      <div class="kpi-strip">
        <div class="kpi-card">
          <div class="label">現状CVR</div>
          <div class="value"><span class="count" data-target="17.3">0</span><small>%</small></div>
          <div class="meta">ストア詳細ページ閲覧→DL</div>
        </div>
        <div class="kpi-card">
          <div class="label">目標CVR</div>
          <div class="value"><span class="count" data-target="25.0">0</span><small>%</small></div>
          <div class="meta">訴求軸をAI査定に再集中</div>
        </div>
        <div class="kpi-card">
          <div class="label">必要改善幅</div>
          <div class="value"><span class="count" data-target="7.7">0</span><small>pt</small></div>
          <div class="meta">比較表・未来予測・進捗表示で説得</div>
        </div>
      </div>
    </section>

    <div class="workspace">
      <section class="control-panel">
        <h1>数字で伝える、<br>売る前に使いたくなる訴求。</h1>
        <p>AI査定、将来予測、出費管理、競合比較を1枚ごとに役割分担。App Store / Google Play 向けの視線設計を、ダッシュボードUIで強化します。</p>

        <div class="badge-row">
          <span class="badge hot">個人情報なしで相場チェック</span>
          <span class="badge blue">8,000社が入札</span>
          <span class="badge">売却相談でも電話1社のみ</span>
          <span class="badge">出費管理で継続利用を促進</span>
        </div>

        <div class="tab-row" role="tablist" aria-label="Store screenshots">
          <button class="tab active" data-screen="screen-a" role="tab" aria-selected="true">A / iOS AI査定</button>
          <button class="tab" data-screen="screen-b" role="tab" aria-selected="false">B / Android 出費管理</button>
          <button class="tab" data-screen="screen-c" role="tab" aria-selected="false">C / 電話0本 比較表</button>
        </div>

        <div class="floating-kpi">
          <div class="soft-card">
            <div class="tiny">主役コピー</div>
            <strong>AIがあなたの愛車を査定</strong>
            <span>競合ゼロの機能を最上段で固定</span>
          </div>
          <div class="soft-card">
            <div class="tiny">継続利用フック</div>
            <strong>価値と維持費を同時管理</strong>
            <span>売る時期までアプリを残す理由を作る</span>
          </div>
        </div>

        <div class="footer-note">
          3枚とも375px基準。Aは即時価値、Bは日常的価値、Cは競合比較で不安解消を担当します。
        </div>
      </section>

      <section class="layout">
        <div class="stage">
          <div class="phone-frame">
            <article class="screen active" id="screen-a" aria-label="ストアスクショA">
              <div class="status-bar">
                <span>9:41</span>
                <span>5G / 100%</span>
              </div>

              <div class="hero-card">
                <div class="hero-top">
                  <div class="hero-label">● APP STORE / iOS向け</div>
                  <div class="platform-pill">個人情報不要</div>
                </div>
                <h2 class="hero-title">AIがあなたの<br>愛車を査定。</h2>
                <p class="hero-sub">トヨタ プリウス S Touring / 2019年 / 48,200km の想定データ。現在相場と3か月後の推移を同時に表示します。</p>

                <div class="price-row">
                  <div class="price-card">
                    <div class="tiny">最新AI査定額</div>
                    <div class="yen">184.2<small>万円</small></div>
                    <div class="range-note">概算レンジ 176.0万〜190.0万円<br>最短45秒で相場チェック</div>
                  </div>
                  <div class="price-card">
                    <div class="tiny">3か月後予測</div>
                    <div class="yen">178.6<small>万円</small></div>
                    <div class="range-note">今より -5.6万円<br>売り時の判断材料に</div>
                  </div>
                </div>

                <div class="metric-grid">
                  <div class="metric-card">
                    <div class="tiny">比較対象</div>
                    <strong>8,000社</strong>
                    <span>オークション入札ネットワーク</span>
                  </div>
                  <div class="metric-card">
                    <div class="tiny">連絡負担</div>
                    <strong>0本</strong>
                    <span>相場確認だけなら営業電話なし</span>
                  </div>
                  <div class="metric-card">
                    <div class="tiny">次アクション</div>
                    <strong>1社</strong>
                    <span>売却相談に進んでも窓口は1社のみ</span>
                  </div>
                </div>
              </div>

              <section class="section-card">
                <div class="section-header">
                  <h2>価格トレンドと売り時</h2>
                  <span>AI査定 / 90日予測</span>
                </div>

