  <script>
    const tabs = document.querySelectorAll('.tab');
    const screens = document.querySelectorAll('.screen');
    const barSpans = document.querySelectorAll('.bar > span');
    const countEls = document.querySelectorAll('.count');
    const forecastButtons = document.querySelectorAll('.toggle-btn');
    const forecastCaption = document.getElementById('forecast-caption');
    const forecastLineValue = document.getElementById('forecastLineValue');
    const forecastLineCost = document.getElementById('forecastLineCost');
    const valueEndDot = document.getElementById('valueEndDot');
    const costEndDot = document.getElementById('costEndDot');
    const compareButtons = document.querySelectorAll('.compare-state button');
    const comparePhoneMap = {
      quote: {
        ucarpac: '0本',
        mota: '3社',
        zubat: '最大10社',
        selca: '1社'
      },
      sell: {
        ucarpac: '1社',
        mota: '3社',
        zubat: '最大10社',
        selca: '1社'
      }
    };

    const forecastStates = {
      '3m': {
        caption: '売却タイミングの目安 / 3か月',
        value: 'M38 42 C86 44, 114 54, 146 72 S214 92, 282 108',
        cost: 'M38 132 C90 128, 116 124, 146 120 S214 112, 282 102',
        valueDot: 108,
        costDot: 102
      },
      '6m': {
        caption: '売却タイミングの目安 / 6か月',
        value: 'M38 42 C86 46, 114 62, 146 84 S214 106, 282 132',
        cost: 'M38 132 C90 124, 116 118, 146 108 S214 94, 282 78',
        valueDot: 132,
        costDot: 78
      }
    };

    function animateBars() {
      barSpans.forEach((span, index) => {
        const width = span.dataset.width || '0%';
        setTimeout(() => {
          span.style.width = width;
        }, 100 + index * 60);
      });
    }

    function animateCounts() {
      countEls.forEach((el) => {
        const target = parseFloat(el.dataset.target);
        const duration = 1200;
        const start = performance.now();

        function tick(now) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = (target * eased).toFixed(1);
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
      });
    }

    function activateScreen(id) {
      tabs.forEach((tab) => {
        const active = tab.dataset.screen === id;
        tab.classList.toggle('active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      screens.forEach((screen) => {
        screen.classList.toggle('active', screen.id === id);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateScreen(tab.dataset.screen));
    });

    forecastButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        forecastButtons.forEach((b) => b.classList.toggle('active', b === btn));
        const state = forecastStates[btn.dataset.forecast];
        forecastCaption.textContent = state.caption;
        forecastLineValue.setAttribute('d', state.value);
        forecastLineCost.setAttribute('d', state.cost);
        valueEndDot.setAttribute('cy', state.valueDot);
        costEndDot.setAttribute('cy', state.costDot);
      });
    });

    compareButtons.forEach((button) => {
      button.addEventListener('click', () => {
        compareButtons.forEach((btn) => btn.classList.toggle('active', btn === button));
        const stateKey = button.dataset.compare;
        document.querySelectorAll('[data-phone]').forEach((cell) => {
          const key = cell.dataset.phone;
          cell.textContent = comparePhoneMap[stateKey][key];
        });
      });
    });

    let autoIndex = 0;
    const tabOrder = ['screen-a', 'screen-b', 'screen-c'];
    setInterval(() => {
      autoIndex = (autoIndex + 1) % tabOrder.length;
      activateScreen(tabOrder[autoIndex]);
    }, 6500);

    animateBars();
    animateCounts();
  </script>
</body>
