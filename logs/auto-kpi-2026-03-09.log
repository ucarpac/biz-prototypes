      padding: 12px;
      min-height: 92px;
    }

    .little-card strong {
      display: block;
      font-size: 13px;
      line-height: 20px;
      color: var(--dark-blue);
      margin-bottom: 4px;
    }

    .little-card span {
      display: block;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .little-card .emoji {
      display: inline-grid;
      place-items: center;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      margin-bottom: 8px;
      background: linear-gradient(180deg, rgba(255,211,106,0.38), rgba(248,76,162,0.12));
      color: var(--pink);
      font-size: 16px;
    }

    .cta-panel {
      margin-top: 18px;
      padding: 16px;
      position: relative;
      overflow: hidden;
    }

    .cta-panel::after {
      content: "";
      position: absolute;
      inset: auto -60px -70px auto;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,211,106,0.26), transparent 68%);
      pointer-events: none;
    }

    .cta-panel h3 {
      margin: 0 0 6px;
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
    }

    .cta-panel p {
      margin: 0 0 14px;
      font-size: 13px;
      line-height: 20px;
      color: var(--text-gray);
      max-width: 90%;
    }

    .primary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-width: 182px;
      min-height: 43px;
      padding: 10px 18px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
      box-shadow: 0 14px 26px rgba(77, 180, 255, 0.24);
      animation: pulse 2.8s infinite;
    }

    .secondary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 43px;
      padding: 10px 16px;
      border-radius: var(--radius-button);
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
      box-shadow: 0 14px 26px rgba(248, 76, 162, 0.22);
    }

    .floating-note {
      position: absolute;
      right: 18px;
      top: 176px;
      width: 118px;
      padding: 12px 12px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.86);
      box-shadow: 0 14px 28px rgba(28, 38, 99, 0.09);
      transform: rotate(5deg);
      font-size: 12px;
      line-height: 18px;
      color: var(--ink);
    }

    .floating-note strong {
      display: block;
      color: var(--pink);
      font-size: 18px;
      line-height: 24px;
      margin-bottom: 4px;
    }

    .doodle {
      position: absolute;
      pointer-events: none;
      z-index: 1;
      opacity: 0.66;
    }

    .doodle path {
      stroke: rgba(248, 76, 162, 0.48);
      stroke-width: 5;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 10 14;
    }

    .doodle-a {
      width: 132px;
      left: 18px;
      top: 188px;
      transform: rotate(-12deg);
    }

    .doodle-b {
      width: 124px;
      right: 18px;
      bottom: 168px;
      transform: rotate(22deg);
    }

    .expense-summary {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 10px;
      margin-bottom: 14px;
    }

    .expense-card {
      padding: 14px;
      min-height: 120px;
    }

    .expense-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      margin-bottom: 4px;
    }

    .expense-total {
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 1;
      color: var(--dark-blue);
      margin: 6px 0 8px;
    }

    .expense-total small {
      font-family: var(--font-sans);
      font-size: 15px;
      margin-left: 1px;
      font-weight: 700;
    }

    .mini-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 8px;
    }

    .mini-list li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .mini-list b {
      color: var(--dark-blue);
      font-weight: 800;
    }

    .bar-group {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 8px;
      height: 112px;
      margin-top: 12px;
    }

    .bar-item {
      width: 22%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      font-size: 10px;
      line-height: 15px;
      color: var(--text-gray);
    }

    .bar {
      width: 100%;
      border-radius: 14px 14px 6px 6px;
      background: linear-gradient(180deg, rgba(29,220,255,0.95), rgba(77,180,255,0.65));
      box-shadow: inset 0 -8px 16px rgba(255,255,255,0.2);
      transition: height 0.35s ease;
      min-height: 18px;
    }

    .forecast-note {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 14px;
      background: linear-gradient(90deg, rgba(255, 211, 106, 0.24), rgba(255,255,255,0.82));
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .compare-wrap {
      margin-top: 16px;
      display: grid;
      gap: 12px;
    }

    .stage-toggle {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .headline-callout {
      margin-top: 14px;
      padding: 16px;
      border-radius: 20px;
      background: rgba(255,255,255,0.86);
      box-shadow: 0 14px 28px rgba(28, 38, 99, 0.08);
      text-align: center;
    }

    .headline-callout strong {
      display: block;
      font-size: 42px;
      line-height: 1;
      color: var(--pink);
      margin-bottom: 6px;
      letter-spacing: -0.04em;
    }

    .headline-callout span {
      display: block;
      font-size: 13px;
      line-height: 20px;
      color: var(--text-gray);
    }

    .compare-card {
      padding: 14px;
    }

    .compare-head {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr 0.8fr;
      gap: 8px;
      align-items: center;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--ruled-line);
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
      font-weight: 800;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 0.8fr 0.8fr;
      gap: 8px;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--ruled-line);
      font-size: 12px;
      line-height: 18px;
    }

    .compare-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .service {
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--dark-blue);
      font-weight: 800;
    }

    .service-mark {
      width: 30px;
      height: 30px;
      border-radius: 10px;
      display: grid;
      place-items: center;
      flex-shrink: 0;
      font-size: 13px;
      font-weight: 900;
    }

    .service.ucp .service-mark {
      background: rgba(248,76,162,0.16);
      color: var(--pink);
    }

    .service.bulk .service-mark {
      background: rgba(255,211,106,0.22);
      color: #b96a00;
    }

    .service.mota .service-mark {
      background: rgba(111,194,255,0.18);
      color: #0b72c8;
    }

    .compare-cell {
      text-align: center;
      color: var(--text-black);
      font-weight: 700;
    }

    .compare-cell.good {
      color: var(--pink);
    }

    .compare-cell.bad {
      color: var(--error);
    }

    .footnote {
      margin-top: 10px;
      font-size: 11px;
      line-height: 17px;
      color: var(--text-gray);
    }

    .bottom-rail {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .bottom-chip {
      min-height: 40px;
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.8);
      border: 1px solid rgba(28, 38, 99, 0.06);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.06);
    }

    .visually-hidden {
      position: absolute !important;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      border: 0;
      overflow: hidden;
      white-space: nowrap;
      clip-path: inset(50%);
      clip: rect(0 0 0 0);
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 14px 26px rgba(77, 180, 255, 0.24);
      }
      50% {
        transform: scale(1.03);
        box-shadow: 0 18px 32px rgba(77, 180, 255, 0.34);
      }
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (min-width: 760px) {
      .prototype {
        padding: 24px 24px 54px;
      }

      .shots {
        gap: 24px;
      }

      .shot {
        padding: 26px 26px 30px;
      }

      .mock-phone {
        max-width: 382px;
      }

      .cta-panel {
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }
    }

    @media (min-width: 1080px) {
      .shots {
        grid-template-columns: repeat(3, 1fr);
        align-items: start;
      }

      .shot {
        display: block;
      }

      .shot:not(.active) {
        opacity: 1;
      }

      .scene-tabs {
        display: none;
      }

      .toolbar {
        position: relative;
        border-radius: 28px;
      }
    }
  </style>
</head>
<body>
  <main class="prototype">
    <header class="toolbar">
      <p class="eyebrow">UcarPAC / App Store Screenshot Prototype / 375px基準</p>
      <h1>売る前の不安を、やさしい言葉と数字でほどく。</h1>
      <p class="note">A案のトーンで、AI査定・出費管理・比較訴求を3枚のストアスクショとして設計。暖色の安心感、手描き風の装飾、やわらかい余白で「まず見てみよう」と思える流れを作っています。</p>
      <div class="scene-tabs" role="tablist" aria-label="スクリーン切り替え">
        <button class="scene-tab active" type="button" data-scene="a" role="tab" aria-selected="true">
          スクショA
          <small>iOS / AI査定</small>
        </button>
        <button class="scene-tab" type="button" data-scene="b" role="tab" aria-selected="false">
          スクショB
          <small>Android / 出費管理</small>
        </button>
        <button class="scene-tab" type="button" data-scene="c" role="tab" aria-selected="false">
          スクショC
          <small>比較 / 電話0本</small>
        </button>
      </div>
    </header>

    <section class="shots" aria-live="polite">
      <article class="shot shot-a active" data-shot="a">
        <div class="device-row">
          <div class="device-pill">iOS向けメインスクショ</div>
          <div class="store-pill"><span class="dot"></span> 個人情報なしで相場チェック</div>
        </div>

        <div class="soft-badge">
          <span class="spark">★</span>
          売るか迷っていても、まずは大丈夫。
        </div>

        <div class="hero-copy">
          <h2>まずは、<br>相場だけ知りたい。</h2>
          <p>AIがあなたの愛車をやさしく査定。入力は最短3分、営業電話なし。いまの相場も、売りどきのヒントも、ひと目でわかります。</p>
          <div class="hero-tags">
            <span class="tag">トヨタ ハリアー / 2021年 / 31,240km</span>
            <span class="tag">全国相場データからAI算出</span>
            <span class="tag">将来予測つき</span>
          </div>
        </div>

        <svg class="doodle doodle-a" viewBox="0 0 120 48" aria-hidden="true">
          <path d="M8 29 C24 9, 42 8, 56 22 S90 42, 112 18"></path>
        </svg>

        <div class="mock-phone" aria-label="AI査定のアプリ画面モック">
          <div class="phone-screen">
            <div class="notch"></div>
            <div class="mini-top">
              <div>
                <div class="mini-title">UcarPAC AI査定</div>
                <strong style="font-size:18px;line-height:27px;color:var(--dark-blue);">あなたの愛車の今の価値</strong>
              </div>
              <div class="mini-avatar" aria-hidden="true"></div>
            </div>

            <div class="segmented" role="tablist" aria-label="査定モード">
              <button class="segment-btn active" type="button" data-estimate="quick">いまの相場</button>
              <button class="segment-btn" type="button" data-estimate="photo">写真追加後</button>
            </div>

            <section class="est-card">
              <div class="car-name">
                愛車
                <strong id="estimateCarName">ハリアー Z Leather Package</strong>
                東京都 / パール / 2WD / 修復歴なし
              </div>

              <div class="amount-row">
                <div class="amount" id="estimateAmount">286.4<small>万円</small></div>
                <div class="est-sub" id="estimateRange">想定レンジ<br>274.0〜297.8万円</div>
              </div>

              <div class="confidence">
                <span>AI信頼度 <strong id="estimateConfidence">87%</strong></span>
                <span id="estimateHint">写真追加でさらに精度アップ</span>
              </div>
            </section>

            <section class="graph-card">
              <div class="graph-head">
                <strong>売りどきの目安</strong>
                <span id="forecastSummary">3か月後予測 279.2万円</span>
              </div>
              <svg class="chart" viewBox="0 0 300 110" role="img" aria-labelledby="chartTitleA chartDescA">
                <title id="chartTitleA">AI査定の将来予測</title>
                <desc id="chartDescA">現在から6か月後までの価格変動予測を示す線グラフ</desc>
                <defs>
                  <linearGradient id="lineGradientA" x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0%" stop-color="#f84ca2"></stop>
                    <stop offset="100%" stop-color="#4db4ff"></stop>
                  </linearGradient>
                </defs>
                <g stroke="rgba(28,38,99,0.10)" stroke-width="1">
                  <line x1="10" y1="20" x2="290" y2="20"></line>
                  <line x1="10" y1="52" x2="290" y2="52"></line>
                  <line x1="10" y1="84" x2="290" y2="84"></line>
                </g>
                <polyline id="forecastLineA" points="18,28 102,40 186,52 282,66" fill="none" stroke="url(#lineGradientA)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"></polyline>
                <g fill="#ffffff" stroke="#f84ca2" stroke-width="4">
                  <circle cx="18" cy="28" r="6"></circle>
                  <circle cx="102" cy="40" r="6"></circle>
                  <circle cx="186" cy="52" r="6"></circle>
                  <circle cx="282" cy="66" r="6"></circle>
                </g>
                <g fill="var(--text-gray)" font-size="10" font-family="var(--font-sans)">
                  <text x="10" y="104">今</text>
                  <text x="88" y="104">1か月</text>
                  <text x="168" y="104">3か月</text>
                  <text x="248" y="104">6か月</text>
                </g>
              </svg>
              <div class="legend">
                <span><i style="background:#f84ca2;"></i>現在価格</span>
                <span><i style="background:#4db4ff;"></i>AI将来予測</span>
              </div>
            </section>

            <div class="little-grid">
              <div class="little-card">
                <div class="emoji">⏱</div>
                <strong>最短3分で入力</strong>
                <span>メーカー・年式・走行距離から、すぐ概算を表示。</span>
              </div>
              <div class="little-card">
                <div class="emoji">☎</div>
                <strong>相場チェックは電話なし</strong>
                <span>いきなり営業電話が来ないから、気軽に試せます。</span>
              </div>
            </div>
          </div>
        </div>

        <div class="floating-note" id="estimateSticker">
          <strong>3分</strong>
          まずは相場だけ。<br>売る決断はそのあとでOK。
        </div>

        <div class="cta-panel">
          <h3>今の相場を見て、次の一歩を決める。</h3>
          <p>価格だけ知りたい人にも、あとで売りたい人にも。気持ちに合わせて使い始められる見せ方です。</p>
          <button class="primary-btn" type="button" id="estimateAction">写真を追加して、もっと安心</button>
        </div>
      </article>

      <article class="shot shot-b" data-shot="b">
        <div class="device-row">
          <div class="device-pill">Android向けサブスクショ</div>
          <div class="store-pill"><span class="dot"></span> 出費管理 + 将来予測</div>
        </div>

        <div class="soft-badge">
          <span class="spark">✎</span>
          家計簿みたいに、クルマのお金も見える化。
        </div>

        <div class="hero-copy">
          <h2>出費も、<br>売りどきも。<br>これひとつで。</h2>
          <p>ガソリン代、保険、車検。毎月の維持費と、これからの査定予測をひとつの画面に。もやっとした不安を、具体的な数字に変えます。</p>
          <div class="hero-tags">
            <span class="tag">日産 セレナ e-POWER / 2020年 / 42,180km</span>
            <span class="tag">月ごとの維持費が見える</span>
            <span class="tag">3か月後・6か月後も予測</span>
          </div>
        </div>

        <div class="mock-phone" aria-label="出費管理と将来予測のアプリ画面モック">
          <div class="phone-screen">
            <div class="notch"></div>
            <div class="mini-top">
              <div>
                <div class="mini-title">UcarPAC 出費管理</div>
                <strong style="font-size:18px;line-height:27px;color:var(--dark-blue);">愛車のコストと価値</strong>
              </div>
              <div class="mini-avatar" aria-hidden="true"></div>
            </div>

            <div class="segmented" role="tablist" aria-label="月別出費の切り替え">
              <button class="month-btn active" type="button" data-month="jan">1月</button>
              <button class="month-btn" type="button" data-month="feb">2月</button>
              <button class="month-btn" type="button" data-month="mar">3月</button>
            </div>

            <div class="expense-summary">
              <section class="expense-card">
                <strong>今月の維持費</strong>
                <div class="expense-total" id="monthTotal">2.6<small>万円</small></div>
                <ul class="mini-list">
                  <li><span>ガソリン</span><b id="fuelCost">11,800円</b></li>
                  <li><span>保険</span><b id="insuranceCost">8,400円</b></li>
                  <li><span>駐車場</span><b id="parkingCost">6,000円</b></li>
                </ul>
              </section>

              <section class="expense-card">
                <strong>年間見込み</strong>
                <div class="expense-total" id="yearTotal">38.6<small>万円</small></div>
                <ul class="mini-list">
                  <li><span>次回車検まで</span><b id="inspectionDays">74日</b></li>
                  <li><span>AI推奨</span><b id="timingAdvice">今が高め</b></li>
                  <li><span>査定予測</span><b id="futurePrice">6か月後 219.8万</b></li>
                </ul>
              </section>
            </div>

            <section class="graph-card">
              <div class="graph-head">
                <strong>出費の内訳</strong>
                <span id="expenseCaption">日々のコストを月ごとに整理</span>
              </div>
              <div class="bar-group" aria-label="カテゴリ別出費グラフ">
                <div class="bar-item">
                  <div class="bar" id="barFuel" style="height: 74px;"></div>
                  <span>ガソリン</span>
                </div>
                <div class="bar-item">
                  <div class="bar" id="barInsurance" style="height: 52px;"></div>
                  <span>保険</span>
                </div>
                <div class="bar-item">
                  <div class="bar" id="barParking" style="height: 40px;"></div>
                  <span>駐車場</span>
                </div>
                <div class="bar-item">
                  <div class="bar" id="barOther" style="height: 28px;"></div>
                  <span>その他</span>
                </div>
              </div>
              <div class="forecast-note" id="forecastNoteB">AIメモ: 3か月後は 228.6万円。高めの相場が続く予測です。</div>
            </section>

            <section class="graph-card" style="margin-top:14px;">
              <div class="graph-head">
                <strong>査定予測の推移</strong>
                <span id="assetCaption">現在 231.4万円 → 6か月後 219.8万円</span>
              </div>
              <svg class="chart" viewBox="0 0 300 110" role="img" aria-labelledby="chartTitleB chartDescB">
                <title id="chartTitleB">車の価値推移グラフ</title>
                <desc id="chartDescB">現在から6か月後までのAI査定推移を示す折れ線グラフ</desc>
                <defs>
                  <linearGradient id="lineGradientB" x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0%" stop-color="#1ddcff"></stop>
                    <stop offset="100%" stop-color="#f84ca2"></stop>
