      align-items: center;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .badge.pink {
      background: rgba(248, 76, 162, 0.18);
      color: #ffe6f3;
      border: 1px solid rgba(255, 255, 255, 0.16);
    }

    .hero-card.light .badge.pink {
      color: #c4327c;
      background: rgba(248, 76, 162, 0.16);
      border-color: transparent;
    }

    .badge.dark {
      color: var(--white);
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .hero-card.light .badge.dark {
      color: var(--dark-blue);
      background: rgba(28, 38, 99, 0.08);
      border-color: transparent;
    }

    .vehicle-card {
      margin-top: 16px;
      align-items: flex-end;
      padding: 14px;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(14px);
    }

    .hero-card.light .vehicle-card {
      background: #f1f7fd;
    }

    .vehicle-label {
      margin: 0 0 5px;
      font-size: 15px;
      line-height: 1.4;
      font-weight: 700;
    }

    .vehicle-sub {
      margin: 0;
      font-size: 12px;
      line-height: 1.5;
      opacity: 0.82;
    }

    .price-block {
      text-align: right;
      white-space: nowrap;
    }

    .price-block .label {
      display: block;
      font-size: 10px;
      opacity: 0.78;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .price-number {
      font-family: var(--font-number);
      font-size: 42px;
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .price-unit {
      font-size: 16px;
      font-weight: 700;
      margin-left: 4px;
    }

    .delta-note {
      margin: 6px 0 0;
      font-size: 11px;
      line-height: 1.4;
      color: #d7f7ff;
    }

    .hero-card.light .delta-note {
      color: var(--text-under-blue);
    }

    .metric-strip {
      margin-top: 14px;
      gap: 8px;
    }

    .metric-pill {
      flex: 1;
      min-width: 0;
      padding: 10px 8px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.14);
      text-align: center;
    }

    .hero-card.light .metric-pill {
      background: rgba(28, 38, 99, 0.06);
    }

    .metric-pill strong {
      display: block;
      font-family: var(--font-number);
      font-size: 22px;
      line-height: 1;
      margin-bottom: 4px;
    }

    .metric-pill span {
      display: block;
      font-size: 10px;
      line-height: 1.4;
      opacity: 0.88;
    }

    .chart-card,
    .data-card,
    .compare-card {
      padding: 14px;
    }

    .card-title {
      margin: 0;
      font-size: 16px;
      line-height: 1.5;
      color: var(--back-blue);
      font-weight: 700;
    }

    .card-sub {
      margin: 2px 0 0;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .segmented {
      display: inline-flex;
      gap: 6px;
      padding: 4px;
      border-radius: 999px;
      background: var(--back-gray);
    }

    .toggle-button {
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      background: transparent;
      color: var(--text-gray);
      font-weight: 700;
      font-size: 12px;
    }

    .toggle-button.active {
      background: var(--white);
      color: var(--dark-blue);
      box-shadow: 0 4px 10px rgba(9, 19, 85, 0.08);
    }

    .chart-wrap {
      margin-top: 14px;
      border-radius: 12px;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(237, 241, 244, 0.52) 0%, rgba(255, 255, 255, 0.96) 100%);
    }

    .chart-wrap svg {
      display: block;
      width: 100%;
      height: auto;
    }

    .chart-summary {
      padding-top: 8px;
      align-items: flex-start;
    }

    .legend-row {
      gap: 14px;
      justify-content: flex-start;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .legend {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: currentColor;
    }

    .legend.current {
      color: #1ddcff;
    }

    .legend.future {
      color: #f84ca2;
    }

    .legend.cost {
      color: #1c2663;
    }

    .insight-box {
      margin-top: 10px;
      padding: 12px;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(9, 19, 85, 0.04), rgba(77, 180, 255, 0.12));
      font-size: 12px;
      line-height: 1.7;
      color: var(--back-blue);
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .mini-card {
      padding: 12px 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 8px 20px rgba(9, 19, 85, 0.08);
      border: 1px solid rgba(28, 38, 99, 0.05);
    }

    .mini-card .eyeline {
      display: block;
      font-size: 10px;
      color: var(--text-gray);
      margin-bottom: 4px;
    }

    .mini-card strong {
      display: block;
      font-family: var(--font-number);
      font-size: 24px;
      line-height: 1;
      color: var(--back-blue);
      margin-bottom: 6px;
    }

    .mini-card p {
      margin: 0;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 10px;
      margin-top: 14px;
    }

    .doughnut-card,
    .bar-card {
      padding: 12px;
      border-radius: 12px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      border: 1px solid rgba(28, 38, 99, 0.05);
    }

    .doughnut-row {
      align-items: center;
    }

    .doughnut-meta {
      flex: 1;
    }

    .big-kpi {
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 1;
      color: var(--back-blue);
    }

    .big-kpi span {
      font-size: 14px;
      font-family: var(--font-sans);
      font-weight: 700;
      margin-left: 4px;
    }

    .expense-detail {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .expense-row {
      display: grid;
      grid-template-columns: 72px 1fr auto;
      gap: 8px;
      align-items: center;
    }

    .expense-row label {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .bar-track {
      position: relative;
      height: 10px;
      border-radius: 999px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .bar-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 50%;
      border-radius: 999px;
      background: var(--gradient-primary);
      transition: width 0.4s ease;
    }

    .bar-fill.alt {
      background: linear-gradient(90deg, #f84ca2, #ff7bbf);
    }

    .bar-fill.deep {
      background: linear-gradient(90deg, #091355, #1d2e93);
    }

    .expense-row strong {
      font-size: 11px;
      color: var(--back-blue);
    }

    .expense-note {
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(248, 76, 162, 0.08);
      color: #a82f70;
      font-size: 11px;
      line-height: 1.6;
      font-weight: 700;
    }

    .compare-card {
      background:
        radial-gradient(circle at top right, rgba(248, 76, 162, 0.12), transparent 25%),
        linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .big-stat {
      display: grid;
      place-items: center;
      width: 132px;
      height: 132px;
      border-radius: 50%;
      margin: 14px auto 10px;
      background:
        conic-gradient(from 180deg, #1ddcff 0 38%, #4db4ff 38% 70%, #f84ca2 70% 100%);
      box-shadow: inset 0 0 0 11px rgba(255, 255, 255, 0.96);
      position: relative;
    }

    .big-stat::after {
      content: "";
      position: absolute;
      inset: 11px;
      border-radius: 50%;
      background: #ffffff;
    }

    .big-stat-inner {
      position: relative;
      z-index: 1;
      text-align: center;
      color: var(--back-blue);
    }

    .big-stat-inner strong {
      display: block;
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 1;
    }

    .big-stat-inner span {
      display: block;
      margin-top: 4px;
      font-size: 12px;
      font-weight: 700;
    }

    .compare-table {
      margin-top: 12px;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .compare-head,
    .compare-row {
      display: grid;
      grid-template-columns: 1.15fr 0.8fr 0.8fr 0.8fr;
      gap: 0;
    }

    .compare-head {
      background: var(--back-blue);
      color: var(--white);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .compare-row {
      background: rgba(255, 255, 255, 0.92);
      border-top: 1px solid var(--ruled-line);
      font-size: 11px;
      color: var(--text-gray);
    }

    .compare-head > div,
    .compare-row > div {
      padding: 11px 10px;
      text-align: center;
    }

    .compare-head > div:first-child,
    .compare-row > div:first-child {
      text-align: left;
    }

    .compare-row .winner {
      color: var(--back-blue);
      font-weight: 700;
      background: rgba(109, 204, 255, 0.12);
    }

    .network-bars {
      margin-top: 12px;
      padding: 12px;
      border-radius: 12px;
      background: rgba(28, 38, 99, 0.04);
    }

    .network-row {
      display: grid;
      grid-template-columns: 70px 1fr auto;
      gap: 8px;
      align-items: center;
      margin-top: 9px;
    }

    .network-row:first-child {
      margin-top: 0;
    }

    .network-row span {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .network-row strong {
      font-size: 11px;
      color: var(--back-blue);
    }

    .bottom-cta {
      margin-top: auto;
      padding-top: 6px;
      align-items: stretch;
      gap: 10px;
    }

    .cta-button {
      flex: 1;
      min-height: 52px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.02em;
      box-shadow: 0 12px 24px rgba(77, 180, 255, 0.28);
    }

    .cta-button.primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .cta-button.secondary {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 12px 24px rgba(248, 76, 162, 0.22);
    }

    .cta-button:active,
    .tab-button:active,
    .ghost-button:active,
    .toggle-button:active {
      transform: scale(0.98);
    }

    .pulse {
      animation: pulse 2.2s infinite;
    }

    @keyframes pulse {
      0%,
      100% {
        transform: translateY(0);
        box-shadow: 0 12px 24px rgba(77, 180, 255, 0.24);
      }
      50% {
        transform: translateY(-2px);
        box-shadow: 0 16px 30px rgba(77, 180, 255, 0.34);
      }
    }

    .info-rack {
      display: grid;
      gap: 14px;
    }

    .kpi-card {
      padding: 16px;
    }

    .kpi-card h3 {
      margin: 0;
      font-size: 18px;
      line-height: 1.5;
      color: var(--back-blue);
    }

    .kpi-card p {
      margin: 8px 0 0;
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .progress-box {
      margin-top: 14px;
      display: grid;
      gap: 10px;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      font-size: 12px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .progress-track {
      height: 14px;
      border-radius: 999px;
      background: var(--back-gray);
      overflow: hidden;
      position: relative;
    }

    .progress-current,
    .progress-target {
      position: absolute;
      inset: 0 auto 0 0;
      border-radius: 999px;
    }

    .progress-current {
      width: 17.3%;
      background: linear-gradient(90deg, #1c2663, #4db4ff);
    }

    .progress-target {
      width: 25%;
      background: rgba(248, 76, 162, 0.2);
      border-right: 2px dashed var(--pink);
    }

    .note-list {
      margin: 14px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 8px;
    }

    .note-list li {
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-gray);
      padding-left: 14px;
      position: relative;
    }

    .note-list li::before {
      content: "";
      position: absolute;
      top: 9px;
      left: 0;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--pink);
    }

    .screen-label {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      color: var(--dark-blue);
      font-weight: 700;
      font-size: 11px;
      width: fit-content;
      margin-top: 12px;
    }

    .footnote {
      margin-top: 10px;
      font-size: 10px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .safe-space {
      height: 8px;
      flex-shrink: 0;
    }

    @media (min-width: 900px) {
      body {
        padding: 28px 22px 50px;
      }

      .prototype-layout {
        grid-template-columns: minmax(0, 420px) minmax(0, 1fr);
      }

      .info-rack {
        position: sticky;
        top: 24px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="intro">
      <p class="eyebrow">UcarPAC / Store Creative / 2026-03-09</p>
      <h1>ストアPVからDLへ、数字で価値を伝える3枚</h1>
      <p>
        AI査定の価格根拠、出費管理と将来予測の統合体験、そして競合比較の「電話0本」を
        ダッシュボード風のレイアウトで見せるストアスクショプロトタイプです。
      </p>
    </section>

    <div class="control-row">
      <button class="tab-button active" data-screen-target="screen-a">A. AI査定全面</button>
      <button class="tab-button" data-screen-target="screen-b">B. 出費管理 + 将来予測</button>
      <button class="tab-button" data-screen-target="screen-c">C. 競合比較「電話0本」</button>
      <button class="ghost-button" id="autoPlayToggle">自動再生: ON</button>
    </div>

    <div class="prototype-layout">
      <section class="device-stage">
        <div class="device-frame">
          <div class="device-notch"></div>

          <div class="screen-stack">
            <section class="screen active" id="screen-a">
              <div class="screen-header">
                <span class="platform ios">iOS向け App Store</span>
                <span class="stamp">Screenshot A</span>
              </div>

              <div class="hero-card">
                <div class="hero-top">
                  <div class="hero-copy">
                    <p class="micro-copy">AIがあなたの愛車を査定</p>
                    <h2>価格の根拠まで<br />ひと目でわかる</h2>
                  </div>
                  <div class="badge-stack">
                    <span class="badge pink">個人情報不要</span>
                    <span class="badge dark">最短45秒入力</span>
                  </div>
                </div>

                <div class="vehicle-card">
                  <div>
                    <p class="vehicle-label">2021 トヨタ アルファード Z</p>
                    <p class="vehicle-sub">38,200km / パール / 2WD / 純正ナビ</p>
                  </div>
                  <div class="price-block">
                    <span class="label">AI査定価格</span>
                    <span class="price-number" id="forecastPrice">418.2</span><span class="price-unit">万円</span>
                    <p class="delta-note" id="forecastDelta">6ヶ月後より +16.1万円高い見込み</p>
                  </div>
                </div>

                <div class="metric-strip">
                  <div class="metric-pill">
                    <strong id="timingScore">86</strong>
                    <span>売り時スコア</span>
                  </div>
                  <div class="metric-pill">
                    <strong>0</strong>
                    <span>相場チェック時の電話</span>
                  </div>
                  <div class="metric-pill">
                    <strong>8,000</strong>
                    <span>入札ネットワーク</span>
                  </div>
                </div>
              </div>

              <div class="chart-card">
                <div class="card-head">
                  <div>
                    <h3 class="card-title">将来予測チャート</h3>
                    <p class="card-sub">現在相場と6ヶ月先までの下落予測を可視化</p>
                  </div>
                  <div class="segmented">
                    <button class="toggle-button active" data-forecast="now">現在</button>
                    <button class="toggle-button" data-forecast="3m">3ヶ月</button>
                    <button class="toggle-button" data-forecast="6m">6ヶ月</button>
                  </div>
                </div>

                <div class="chart-wrap">
                  <svg viewBox="0 0 340 180" aria-hidden="true">
                    <defs>
                      <linearGradient id="forecastArea" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#4db4ff" stop-opacity="0.35"></stop>
                        <stop offset="100%" stop-color="#4db4ff" stop-opacity="0.02"></stop>
                      </linearGradient>
                    </defs>
                    <g transform="translate(18 16)">
                      <line x1="0" y1="125" x2="304" y2="125" stroke="#dbe3ef" stroke-width="1"></line>
                      <line x1="0" y1="84" x2="304" y2="84" stroke="#edf1f4" stroke-width="1"></line>
                      <line x1="0" y1="43" x2="304" y2="43" stroke="#edf1f4" stroke-width="1"></line>
                      <path d="M 10 36 C 68 40, 106 52, 112 56 C 160 66, 194 82, 214 90 C 250 102, 276 112, 294 120 L 294 125 L 10 125 Z" fill="url(#forecastArea)"></path>
                      <path d="M 10 36 C 68 40, 106 52, 112 56 C 160 66, 194 82, 214 90 C 250 102, 276 112, 294 120" fill="none" stroke="#1ddcff" stroke-width="4" stroke-linecap="round"></path>
                      <g font-size="11" fill="#737373">
                        <text x="0" y="140">今週</text>
                        <text x="92" y="140">1ヶ月</text>
                        <text x="188" y="140">3ヶ月</text>
                        <text x="278" y="140">6ヶ月</text>
                        <text x="-2" y="46">425万</text>
                        <text x="-2" y="87">412万</text>
                        <text x="-2" y="128">399万</text>
                      </g>
                      <circle class="forecast-point" data-index="0" cx="10" cy="36" r="7" fill="#f84ca2" stroke="#ffffff" stroke-width="3"></circle>
                      <circle class="forecast-point" data-index="1" cx="112" cy="56" r="5" fill="#1c2663" opacity="0.55"></circle>
                      <circle class="forecast-point" data-index="2" cx="214" cy="90" r="5" fill="#1c2663" opacity="0.55"></circle>
                      <circle class="forecast-point" data-index="3" cx="294" cy="120" r="5" fill="#1c2663" opacity="0.55"></circle>
                    </g>
                  </svg>
                </div>

                <div class="legend-row">
                  <span class="legend current">現在相場</span>
                  <span class="legend future">AI予測</span>
                </div>

                <div class="insight-box" id="forecastInsight">
                  今が高値圏です。アルファード Z は春商戦の需要が強く、6ヶ月待つと
                  約16.1万円の下落予測。価格を見るだけなら個人情報入力なしで完了します。
                </div>
              </div>

              <div class="mini-grid">
                <div class="mini-card">
                  <span class="eyeline">下取り平均との差</span>
                  <strong>+23.4</strong>
                  <p>万円高く売れる余地を表示</p>
                </div>
                <div class="mini-card">
                  <span class="eyeline">売却相談</span>
                  <strong>1社</strong>
                  <p>連絡先は進んだ時だけ</p>
                </div>
                <div class="mini-card">
                  <span class="eyeline">価格精度</span>
                  <strong>87%</strong>
                  <p>写真追加でさらに精度向上</p>
                </div>
              </div>

              <div class="bottom-cta">
                <button class="cta-button primary pulse">無料でAI査定を始める</button>
                <button class="cta-button secondary">入力項目を見る</button>
              </div>
              <div class="safe-space"></div>
            </section>

            <section class="screen" id="screen-b">
              <div class="screen-header">
                <span class="platform android">Android向け Google Play</span>
                <span class="stamp">Screenshot B</span>
              </div>

              <div class="hero-card light">
                <div class="hero-top">
                  <div class="hero-copy">
                    <p class="micro-copy">出費管理 + 将来予測</p>
                    <h2>維持費と価値変動を<br />1画面で管理</h2>
                  </div>
                  <div class="badge-stack">
                    <span class="badge pink">家計簿いらず</span>
                    <span class="badge dark">将来価格も表示</span>
                  </div>
