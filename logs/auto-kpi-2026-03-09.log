    function showScreen(targetId) {
      screens.forEach((screen, index) => {
        const active = screen.id === targetId;
        screen.classList.toggle("active", active);
        if (active) currentIndex = index;
      });

      screenButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.screen === targetId);
      });

      const isAndroid = targetId === "screen-b";
      phoneFrame.classList.toggle("android", isAndroid);
      phoneFrame.classList.toggle("ios", !isAndroid);
    }

    function nextScreen() {
      const nextIndex = (currentIndex + 1) % screens.length;
      showScreen(screens[nextIndex].id);
    }

    function startAutoPlay() {
      clearInterval(autoTimer);
      if (!autoPlay) return;
      autoTimer = setInterval(nextScreen, 4500);
