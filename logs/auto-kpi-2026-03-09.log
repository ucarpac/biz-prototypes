      gap: 10px;
      height: 148px;
      margin-top: 14px;
    }

    .bar-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .bar-column {
      width: 100%;
      max-width: 42px;
      height: 110px;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(28, 38, 99, 0.08), rgba(28, 38, 99, 0.02));
      overflow: hidden;
    }

    .bar-fill {
      width: 100%;
      border-radius: inherit;
      background: linear-gradient(180deg, #1ddcff 0%, #4db4ff 55%, #1c2663 100%);
      transition: height 0.35s ease;
      box-shadow: 0 0 20px rgba(77, 180, 255, 0.18);
    }

    .bar-label {
      text-align: center;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
    }

    .bar-value {
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .expense-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(237, 241, 244, 0.65);
    }

    .expense-name {
      color: var(--text-black);
      font-size: 13px;
      font-weight: 700;
    }

    .expense-note {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
    }

    .expense-amount {
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 900;
      white-space: nowrap;
    }

    .forecast-svg {
      width: 100%;
      height: 140px;
      margin-top: 12px;
      display: block;
    }

    .forecast-line {
      fill: none;
      stroke: var(--dark-blue);
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 400;
      stroke-dashoffset: 0;
      transition: stroke-dashoffset 0.5s ease;
    }

    .forecast-area {
      fill: rgba(29, 220, 255, 0.12);
    }

    .forecast-point {
      fill: #fff;
      stroke: var(--pink);
      stroke-width: 4;
      transition: cx 0.25s ease, cy 0.25s ease;
    }

    .forecast-axis {
      stroke: rgba(28, 38, 99, 0.14);
      stroke-width: 1;
    }

    .forecast-caption {
      margin-top: 12px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.65;
    }

    .score-layout {
      display: grid;
      grid-template-columns: 110px minmax(0, 1fr);
      gap: 14px;
      align-items: center;
    }

    .score-ring {
      --score-angle: 240deg;
      width: 110px;
      height: 110px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at center, #fff 0 52%, transparent 53%),
        conic-gradient(var(--pink) 0 var(--score-angle), rgba(248, 76, 162, 0.16) var(--score-angle) 360deg);
      box-shadow: inset 0 0 0 10px rgba(248, 76, 162, 0.05);
      transition: background 0.25s ease;
    }

    .score-center {
      text-align: center;
      color: var(--dark-blue);
    }

    .score-number {
      display: block;
      font-family: var(--font-number);
      font-size: 30px;
      font-weight: 900;
      line-height: 1.1;
    }

    .score-label {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.4;
    }

    .score-copy {
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.5;
      font-weight: 800;
    }

    .score-note {
      margin-top: 6px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .month-slider {
      width: 100%;
      margin-top: 16px;
      appearance: none;
      height: 6px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.35), rgba(248, 76, 162, 0.35));
      outline: none;
    }

    .month-slider::-webkit-slider-thumb {
      appearance: none;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--dark-blue);
      border: 4px solid #fff;
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.24);
      cursor: pointer;
    }

    .month-slider::-moz-range-thumb {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--dark-blue);
      border: 4px solid #fff;
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.24);
      cursor: pointer;
    }

    .slider-meta {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
    }

    .compare-toggle {
      position: relative;
      z-index: 1;
      display: inline-flex;
      gap: 8px;
      margin-top: 16px;
      padding: 6px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.08);
    }

    .compare-hero {
      overflow: hidden;
      background:
        radial-gradient(circle at 90% 10%, rgba(248, 76, 162, 0.14), transparent 30%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 251, 255, 0.96));
    }

    .hero-phone-value {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      color: var(--dark-blue);
    }

    .hero-phone-number {
      font-family: var(--font-number);
      font-size: 72px;
      line-height: 0.95;
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .hero-phone-unit {
      padding-bottom: 8px;
      color: var(--pink);
      font-size: 18px;
      line-height: 1;
      font-weight: 900;
    }

    .hero-phone-copy {
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.7;
    }

    .compare-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .compare-card.brand-ucarpac {
      border: 1px solid rgba(248, 76, 162, 0.28);
      background: linear-gradient(180deg, rgba(255, 230, 242, 0.7), rgba(255, 255, 255, 0.96));
    }

    .compare-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .compare-brand {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
      font-weight: 900;
    }

    .compare-tag {
      display: inline-flex;
      min-height: 26px;
      align-items: center;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
      color: var(--dark-blue);
      font-size: 10px;
      font-weight: 800;
      white-space: nowrap;
    }

    .compare-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 14px;
    }

    .metric-cell {
      padding: 10px 8px;
      border-radius: 16px;
      background: rgba(237, 241, 244, 0.7);
      text-align: center;
    }

    .metric-label {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
    }

    .metric-value {
      margin-top: 4px;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 1.3;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .metric-value.small {
      font-size: 12px;
      line-height: 1.55;
      letter-spacing: 0;
    }

    .compare-note {
      margin-top: 10px;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.7;
    }

    .timeline-steps {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .timeline-step {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 12px;
      align-items: start;
    }

    .timeline-badge {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(29, 220, 255, 0.14);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
    }

    .timeline-step.active .timeline-badge {
      background: var(--pink);
      color: #fff;
    }

    .timeline-title {
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
    }

    .timeline-copy {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.65;
    }

    .controls {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr) 56px;
      gap: 12px;
      align-items: center;
      width: min(100%, 375px);
      margin: 14px auto 0;
    }

    .nav-button {
      height: 48px;
      border: 0;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.86);
      color: var(--dark-blue);
      font-size: 20px;
      font-weight: 900;
      box-shadow: 0 12px 22px rgba(28, 38, 99, 0.08);
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .nav-button:hover,
    .nav-button:focus-visible {
      transform: translateY(-1px);
      background: #fff;
      outline: none;
    }

    .dots {
      display: flex;
      justify-content: center;
      gap: 10px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      border: 0;
      background: rgba(28, 38, 99, 0.18);
      cursor: pointer;
      transition: width 0.25s ease, background 0.25s ease;
    }

    .dot.active {
      width: 28px;
      background: linear-gradient(90deg, #f84ca2 0%, #1ddcff 100%);
    }

    .insight-panel {
      width: min(100%, 375px);
      margin: 14px auto 0;
      padding: 16px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: 0 14px 24px rgba(28, 38, 99, 0.08);
    }

    .insight-title {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    .insight-copy {
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.7;
    }

    .swipe-hint {
      width: min(100%, 375px);
      margin: 10px auto 0;
      text-align: center;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
    }

    .pulse {
      animation: pulseGlow 2.2s ease-in-out infinite;
    }

    @keyframes pulseGlow {
      0%, 100% {
        box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.18);
      }
      50% {
        box-shadow: 0 0 0 10px rgba(248, 76, 162, 0);
      }
    }

    .spark {
      position: absolute;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: linear-gradient(180deg, rgba(248, 76, 162, 0.9), rgba(29, 220, 255, 0.9));
      opacity: 0.55;
      filter: blur(0.5px);
      animation: sparkle 5s linear infinite;
    }

    .spark.s1 {
      top: 118px;
      right: 28px;
    }

    .spark.s2 {
      top: 248px;
      left: 24px;
      animation-delay: -1.4s;
    }

    .spark.s3 {
      top: 430px;
      right: 48px;
      animation-delay: -2.8s;
    }

    @keyframes sparkle {
      0% {
        transform: translateY(0) scale(0.8);
        opacity: 0;
      }
      20% {
        opacity: 0.55;
      }
      80% {
        opacity: 0.55;
      }
      100% {
        transform: translateY(-36px) scale(1.25);
        opacity: 0;
      }
    }

    @media (min-width: 768px) {
      .app-shell {
        width: min(100%, 980px);
        padding: 28px 24px 56px;
      }

      .hero-title {
        font-size: 34px;
      }

      .phone-stage {
        margin-top: 22px;
      }
    }
  </style>
</head>
<body>
  <div class="ambient a1"></div>
  <div class="ambient a2"></div>
  <div class="ambient a3"></div>

  <main class="app-shell">
    <section class="hero-panel">
      <div class="eyebrow">ASO / ストアPV→DL率 仮説更新</div>
      <h1 class="hero-title">ストアスクショを「読む」から「触りたくなる」へ</h1>
      <p class="hero-copy">
        AI査定、出費管理、電話0本訴求を3枚で分担。
        スワイプと状態変化で、App Store / Google Play の閲覧中にベネフィットを即理解させる構成です。
      </p>
      <div class="kpi-row">
        <div class="kpi-card">
          <div class="kpi-label">現状CVR</div>
          <div class="kpi-value">17.3%</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">目標CVR</div>
          <div class="kpi-value kpi-accent">25%</div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">主訴求</div>
          <div class="kpi-value">3枚</div>
        </div>
      </div>
    </section>

    <section class="mission-panel">
      <div class="mission-copy-wrap">
        <div class="mission-title">検証シナリオ</div>
        <div class="mission-copy">A: AI査定 / B: 出費管理+将来予測 / C: 電話0本比較</div>
      </div>
      <div class="mission-steps">
        <div class="mission-step active" data-mission="0">A</div>
        <div class="mission-step" data-mission="1">B</div>
        <div class="mission-step" data-mission="2">C</div>
      </div>
    </section>

    <section class="phone-stage">
      <div class="phone-frame">
        <div class="phone-notch"></div>
        <div class="viewport" id="viewport">
          <div class="track" id="track">
            <section class="slide">
              <article class="shot shot-ai">
                <div class="spark s1"></div>
                <div class="spark s2"></div>
                <div class="spark s3"></div>

                <div class="statusbar">
                  <div>9:41</div>
                  <div class="status-icons">
                    <span class="status-pill">iOS向け</span>
                    <span>5G</span>
                    <span>100%</span>
                  </div>
                </div>

                <div class="screen-label">ストアスクショA / AI査定を全面訴求</div>
                <h2 class="screen-title">AIが今の相場を<br>10秒で予測</h2>
                <p class="screen-subtitle">
                  3タップで価格レンジが動く。個人情報なしで「今いくら」を体感できるスクリーン。
                </p>

                <div class="badge-row">
                  <div class="badge hot">個人情報不要</div>
                  <div class="badge">将来予測つき</div>
                  <div class="badge">8000社データ反映</div>
                </div>

                <div class="glass-card car-summary">
                  <div class="car-thumb"></div>
                  <div>
                    <div class="car-title">トヨタ ハリアー Z Leather Package</div>
                    <div class="car-meta">2021年式 / パール / 2WD / ナビ・全周囲カメラ</div>
                  </div>
                </div>

                <div class="section-label">3タップ診断フロー</div>

                <div class="question-block">
                  <div class="question-title">1. 車種を選ぶ</div>
                  <div class="option-row">
                    <button class="option-chip valuation-option active" data-group="car" data-value="ハリアー">ハリアー</button>
                    <button class="option-chip valuation-option" data-group="car" data-value="CX-5">CX-5</button>
                    <button class="option-chip valuation-option" data-group="car" data-value="セレナ">セレナ</button>
                  </div>
                </div>

                <div class="question-block">
                  <div class="question-title">2. 年式を選ぶ</div>
                  <div class="option-row">
                    <button class="option-chip valuation-option" data-group="year" data-value="2023">2023年</button>
                    <button class="option-chip valuation-option active" data-group="year" data-value="2021">2021年</button>
                    <button class="option-chip valuation-option" data-group="year" data-value="2019">2019年</button>
                  </div>
                </div>

                <div class="question-block">
                  <div class="question-title">3. 走行距離を選ぶ</div>
                  <div class="option-row">
                    <button class="option-chip valuation-option" data-group="mileage" data-value="1万km">1万km</button>
                    <button class="option-chip valuation-option active" data-group="mileage" data-value="3万km">3万km</button>
                    <button class="option-chip valuation-option" data-group="mileage" data-value="6万km">6万km</button>
                  </div>
                </div>

                <div class="progress-card pulse">
                  <div class="progress-top">
                    <div class="progress-title">査定精度チャージ</div>
                    <div class="progress-count" id="valuationProgressCount">3 / 3 入力済み</div>
                  </div>
                  <div class="progress-bar">
                    <span id="valuationProgressBar"></span>
                  </div>
                  <div class="progress-copy" id="valuationHint">
                    ここまでで概算価格を表示。カラー・装備・写真を足すとAI査定の精度がさらに上がります。
                  </div>
                </div>

                <div class="price-card">
                  <div class="price-label">現在のAI概算</div>
                  <div class="price-value" id="valuationPrice">3,280,000円</div>
                  <div class="price-meta">
                    <span id="valuationRange">相場レンジ 318万〜339万円</span>
                    <span id="valuationAccuracy">一致度 87%</span>
                  </div>
                </div>

                <div class="future-grid">
                  <div class="mini-stat">
                    <span>3か月後予測</span>
                    <strong id="future3m">319万円</strong>
                  </div>
                  <div class="mini-stat">
                    <span>6か月後予測</span>
                    <strong id="future6m">307万円</strong>
                  </div>
                </div>

                <button class="cta-button next-slide" data-next="1">出費管理スクショを見る</button>
              </article>
            </section>

            <section class="slide">
              <article class="shot shot-expense">
                <div class="statusbar">
                  <div>9:41</div>
                  <div class="status-icons">
                    <span class="status-pill">Android向け</span>
                    <span>VoLTE</span>
                    <span>96%</span>
                  </div>
                </div>

                <div class="screen-label">ストアスクショB / 出費管理 + 将来予測</div>
                <h2 class="screen-title">出費と売りどき、<br>同じ画面でわかる</h2>
                <p class="screen-subtitle">
                  維持費の見える化と価格の先読みを合体。売る理由を毎月つくる、継続利用型の訴求。
                </p>

                <div class="badge-row">
                  <div class="badge hot">出費管理つき</div>
                  <div class="badge">将来予測グラフ</div>
                  <div class="badge">売りどきスコア</div>
                </div>

                <div class="expense-summary">
                  <div class="summary-card">
                    <div class="summary-label">今月の維持費</div>
                    <div class="summary-value" id="monthlyCostValue">40,900円</div>
                  </div>
                  <div class="summary-card">
                    <div class="summary-label">現在の予測価格</div>
                    <div class="summary-value" id="currentForecastValue">328万円</div>
                  </div>
                </div>

                <div class="tabs">
                  <button class="tab-button active" data-tab="expenses">維持費</button>
                  <button class="tab-button" data-tab="forecast">将来予測</button>
                </div>

                <div class="panel active" id="panel-expenses">
                  <div class="bars-card">
                    <div class="question-title">カテゴリ別の出費</div>
                    <div class="bars-wrap">
                      <div class="bar-item">
                        <div class="bar-column"><div class="bar-fill" id="barGas" style="height: 74%;"></div></div>
                        <div class="bar-value">12,400円</div>
                        <div class="bar-label">ガソリン</div>
                      </div>
                      <div class="bar-item">
                        <div class="bar-column"><div class="bar-fill" id="barParking" style="height: 85%;"></div></div>
                        <div class="bar-value">14,200円</div>
                        <div class="bar-label">駐車場</div>
                      </div>
                      <div class="bar-item">
                        <div class="bar-column"><div class="bar-fill" id="barInsurance" style="height: 50%;"></div></div>
                        <div class="bar-value">8,300円</div>
                        <div class="bar-label">保険</div>
                      </div>
                      <div class="bar-item">
                        <div class="bar-column"><div class="bar-fill" id="barCare" style="height: 37%;"></div></div>
                        <div class="bar-value">6,000円</div>
                        <div class="bar-label">整備</div>
                      </div>
                    </div>
                  </div>

                  <div class="bars-card">
                    <div class="question-title">今月の出費ログ</div>
                    <div class="expense-list">
                      <div class="expense-row">
                        <div>
                          <div class="expense-name">給油 / ENEOS 中野坂上</div>
                          <div class="expense-note">レギュラー 42.3L ・ 2026/03/05</div>
                        </div>
                        <div class="expense-amount">7,940円</div>
                      </div>
                      <div class="expense-row">
                        <div>
                          <div class="expense-name">月極駐車場</div>
                          <div class="expense-note">杉並区 / 2026年3月分</div>
                        </div>
                        <div class="expense-amount">14,200円</div>
                      </div>
                      <div class="expense-row">
                        <div>
                          <div class="expense-name">任意保険</div>
                          <div class="expense-note">月払い / 走行距離特約込み</div>
                        </div>
                        <div class="expense-amount">8,300円</div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="panel" id="panel-forecast">
