    const expenseData = {
      jan: {
        total: 28600,
        fuel: 16800,
        insurance: 6400,
        maintenance: 5400,
        caption: "軽めの維持費。価格確認の習慣化向き",
        saleNow: 186.1,
        saleNext: 181.9,
        insight: "1月は出費合計が28,600円。市場価格はまだ高位なので、すぐに売らなくても相場ウォッチを始める価値があります。"
      },
      feb: {
        total: 41800,
        fuel: 14900,
        insurance: 9200,
        maintenance: 17700,
        caption: "整備費が増加。売却判断の比較月",
        saleNow: 185.0,
        saleNext: 180.1,
        insight: "2月は整備費が膨らみ41,800円。維持費の増加幅が価格下落幅に近づくため、AI査定の再確認タイミングです。"
      },
      mar: {
        total: 32400,
        fuel: 14800,
        insurance: 9600,
        maintenance: 8000,
        caption: "売り時の再確認を推奨",
        saleNow: 184.2,
        saleNext: 178.4,
        insight: "3月は出費合計が32,400円。価格下落予測より先に維持費負担が積み上がるため、今月中のAI査定チェックが最も効率的です。"
      }
    };

    const compareData = {
      bulk: {
        title: "一括査定は最大10社から電話",
        calls: 10,
        stress: 92,
        meter: 100
      },
      mota: {
        title: "上位3社型でも複数社対応が残る",
        calls: 3,
        stress: 47,
        meter: 45
      },
      ucarpac: {
        title: "AI相場チェックは電話0本",
