    const slides = document.getElementById("slides");
    const previewTitle = document.getElementById("previewTitle");
    const previewDesc = document.getElementById("previewDesc");
    const captionTitle = document.getElementById("captionTitle");
    const captionText = document.getElementById("captionText");
    const dots = document.getElementById("dots");
    const stepsProgress = document.getElementById("stepsProgress");
    const toast = document.getElementById("toast");
    const phoneStage = document.getElementById("phoneStage");
    const phoneShell = document.getElementById("phoneShell");
    const stepDots = Array.from(document.querySelectorAll(".step-dot"));
    const jumpButtons = Array.from(document.querySelectorAll("[data-jump]"));
    const monthButtons = Array.from(document.querySelectorAll("[data-month]"));
    const compareButtons = Array.from(document.querySelectorAll("[data-compare]"));
    const versusRows = Array.from(document.querySelectorAll(".versus-row"));
    const ctaButtons = Array.from(document.querySelectorAll(".cta-action"));

    let activeIndex = 0;
    let pointerStartX = null;
    let toastTimer = null;

    slideMeta.forEach((item, index) => {
      const dot = document.createElement("button");
      dot.type = "button";
      dot.className = index === 0 ? "dot active" : "dot";
      dot.setAttribute("aria-label", `${index + 1}枚目へ`);
      dot.addEventListener("click", () => setActive(index));
      dots.appendChild(dot);
    });

    const dotButtons = Array.from(dots.querySelectorAll(".dot"));

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.remove("show");
      }, 1500);
    }

    function setActive(index, notify = true) {
      activeIndex = (index + slideMeta.length) % slideMeta.length;
      slides.style.transform = `translateX(-${activeIndex * 100}%)`;

      previewTitle.textContent = slideMeta[activeIndex].title;
      previewDesc.textContent = slideMeta[activeIndex].desc;
      captionTitle.textContent = slideMeta[activeIndex].captionTitle;
      captionText.textContent = slideMeta[activeIndex].captionText;

      dotButtons.forEach((dot, i) => dot.classList.toggle("active", i === activeIndex));

      stepDots.forEach((dot, i) => dot.classList.toggle("active", i <= activeIndex));
      stepsProgress.style.width = `${activeIndex * 54}px`;

      jumpButtons.forEach((button) => {
        const isActive = Number(button.dataset.jump) === activeIndex;
        button.classList.toggle("active", isActive);
      });

      if (notify) {
        showToast(slideMeta[activeIndex].toast);
      }
    }

    function animateNumber(el, to, decimals = 0, suffix = "") {
      const startValue = parseFloat((el.textContent || "0").replace(/[^\d.-]/g, "")) || 0;
      const duration = 520;
      const startTime = performance.now();

      function frame(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = startValue + (to - startValue) * eased;
        el.textContent = current.toLocaleString("ja-JP", {
          minimumFractionDigits: decimals,
          maximumFractionDigits: decimals
        }) + suffix;
        if (progress < 1) requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
    }

    function updateMonth(month) {
      const data = expenseData[month];
      const total = data.total || 1;
      const totalEl = document.getElementById("expenseTotal");
      const fuelValue = document.getElementById("fuelValue");
      const insuranceValue = document.getElementById("insuranceValue");
      const maintenanceValue = document.getElementById("maintenanceValue");
      const expenseCaption = document.getElementById("expenseCaption");
      const saleNow = document.getElementById("saleNow");
      const saleNext = document.getElementById("saleNext");
      const monthInsight = document.getElementById("monthInsight");

      animateNumber(totalEl, data.total, 0);
      fuelValue.textContent = `${data.fuel.toLocaleString("ja-JP")}円`;
      insuranceValue.textContent = `${data.insurance.toLocaleString("ja-JP")}円`;
      maintenanceValue.textContent = `${data.maintenance.toLocaleString("ja-JP")}円`;

      document.getElementById("fuelBar").style.width = `${(data.fuel / total) * 100}%`;
      document.getElementById("insuranceBar").style.width = `${(data.insurance / total) * 100}%`;
      document.getElementById("maintenanceBar").style.width = `${(data.maintenance / total) * 100}%`;

      expenseCaption.textContent = data.caption;
      animateNumber(saleNow, data.saleNow, 1);
      animateNumber(saleNext, data.saleNext, 1);
      monthInsight.textContent = data.insight;

      monthButtons.forEach((button) => {
        const active = button.dataset.month === month;
        button.classList.toggle("active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function updateCompare(key) {
      const data = compareData[key];
      document.getElementById("compareTitle").textContent = data.title;
      animateNumber(document.getElementById("callCount"), data.calls, 0);
      document.getElementById("stressBadge").textContent = `ストレス想定 ${data.stress} / 100`;
      document.getElementById("meterFill").style.width = `${data.meter}%`;

      compareButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.compare === key);
      });

      versusRows.forEach((row) => {
        row.classList.toggle("active", row.dataset.row === key);
      });
    }

    document.querySelectorAll("[data-count]").forEach((el) => {
      animateNumber(el, Number(el.dataset.count), Number(el.dataset.decimals || 0));
    });

    jumpButtons.forEach((button) => {
      button.addEventListener("click", () => setActive(Number(button.dataset.jump)));
    });

    monthButtons.forEach((button) => {
      button.addEventListener("click", () => {
        updateMonth(button.dataset.month);
        showToast(`${button.textContent}の出費データに切り替えました`);
      });
    });

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => {
        updateCompare(button.dataset.compare);
        showToast(`${button.textContent}との比較に切り替えました`);
      });
    });

    ctaButtons.forEach((button) => {
      button.addEventListener("click", () => {
        showToast(button.dataset.toast || "操作を実行しました");
      });
    });

    document.getElementById("prevBtn").addEventListener("click", () => setActive(activeIndex - 1));
    document.getElementById("nextBtn").addEventListener("click", () => setActive(activeIndex + 1));

    phoneStage.addEventListener("pointerdown", (event) => {
      pointerStartX = event.clientX;
    });

    phoneStage.addEventListener("pointerup", (event) => {
      if (pointerStartX === null) return;
      const diff = event.clientX - pointerStartX;
      if (Math.abs(diff) > 40) {
        setActive(activeIndex + (diff < 0 ? 1 : -1));
      }
      pointerStartX = null;
    });

    phoneStage.addEventListener("pointermove", (event) => {
      const rect = phoneStage.getBoundingClientRect();
      const relX = (event.clientX - rect.left) / rect.width - 0.5;
      const relY = (event.clientY - rect.top) / rect.height - 0.5;
      phoneShell.style.transform = `rotateY(${relX * 8}deg) rotateX(${relY * -8}deg)`;
    });

    phoneStage.addEventListener("pointerleave", () => {
      pointerStartX = null;
      phoneShell.style.transform = "rotateY(0deg) rotateX(0deg)";
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "ArrowRight") setActive(activeIndex + 1, false);
      if (event.key === "ArrowLeft") setActive(activeIndex - 1, false);
    });

    updateMonth("mar");
    updateCompare("ucarpac");
    setActive(0, false);
  </script>
</body>
</html>
