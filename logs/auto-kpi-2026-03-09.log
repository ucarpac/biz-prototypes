      backdrop-filter: blur(18px);
      box-shadow: 0 24px 48px rgba(28,38,99,0.09);
      border: 1px solid rgba(255,255,255,0.7);
    }

    .shot.active {
      display: grid;
      animation: fadeUp 0.45s ease;
    }

    .show-all .shot {
      display: grid;
    }

    .phone {
      position: relative;
      width: min(100%, 375px);
      margin: 0 auto;
      border-radius: 38px;
      background: #111;
      padding: 10px;
      box-shadow: 0 30px 60px rgba(28,38,99,0.18);
    }

    .phone::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 10px;
      width: 126px;
      height: 26px;
      transform: translateX(-50%);
      border-radius: 999px;
      background: #0b0b0b;
      z-index: 2;
    }

    .phone.android::before {
      width: 18px;
      height: 18px;
      top: 15px;
      background: #0b0b0b;
      box-shadow: 0 0 0 6px #1b1b1b;
    }

    .phone-inner {
      overflow: hidden;
      position: relative;
      min-height: 760px;
      border-radius: 30px;
      background: var(--gradient-warm);
    }

    .phone-inner::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 15% 14%, rgba(255,183,102,0.34), transparent 24%),
        radial-gradient(circle at 88% 16%, rgba(248,76,162,0.18), transparent 19%),
        radial-gradient(circle at 50% 90%, rgba(111,194,255,0.22), transparent 25%);
      pointer-events: none;
    }

    .statusbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 18px 10px;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      position: relative;
      z-index: 1;
    }

    .status-icons {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .dot, .bar, .pill-dot {
      display: inline-block;
      background: var(--dark-blue);
      border-radius: 999px;
    }

    .dot {
      width: 7px;
      height: 7px;
      opacity: 0.8;
    }

    .bar {
      width: 18px;
      height: 8px;
      opacity: 0.86;
    }

    .pill-dot {
      width: 26px;
      height: 10px;
      opacity: 0.9;
    }

    .screen {
      position: relative;
      z-index: 1;
      padding: 8px 18px 28px;
    }

    .shot-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.84);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      box-shadow: 0 12px 22px rgba(28,38,99,0.08);
    }

    .shot-label .circle {
      width: 20px;
      height: 20px;
      border-radius: 999px;
      display: inline-grid;
      place-items: center;
      background: var(--gradient-pink);
      color: #fff;
      font-size: 10px;
    }

    .main-copy {
      margin: 16px 0 6px;
      color: var(--dark-blue);
      font-size: 34px;
      line-height: 1.22;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .sub-copy {
      margin: 0 0 18px;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 1.75;
    }

    .speech {
      max-width: 235px;
      padding: 12px 14px;
      margin-left: auto;
      margin-bottom: 14px;
      border-radius: 22px 22px 8px 22px;
      background: #fff;
      color: #c36b4f;
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 16px 22px rgba(195,107,79,0.08);
      transform: rotate(2deg);
    }

    .badge-row,
    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .badge.good {
      background: rgba(223,250,242,0.98);
      color: var(--good);
    }

    .badge.hot {
      background: rgba(255,240,231,0.98);
      color: #d7664c;
    }

    .app-card {
      position: relative;
      background: var(--gradient-card);
      border-radius: 24px;
      padding: 18px;
      border: 1px solid rgba(255,255,255,0.92);
      box-shadow: 0 22px 32px rgba(28,38,99,0.09);
      overflow: hidden;
    }

    .app-card + .app-card {
      margin-top: 14px;
    }

    .app-card::after {
      content: "";
      position: absolute;
      right: -28px;
      bottom: -28px;
      width: 116px;
      height: 116px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(248,76,162,0.12), rgba(248,76,162,0));
    }

    .car-panel {
      display: grid;
      grid-template-columns: 106px minmax(0, 1fr);
      gap: 14px;
      align-items: center;
    }

    .car-illu {
      width: 106px;
      height: 88px;
      border-radius: 20px;
      background: linear-gradient(145deg, #fff, #ffe4ee);
      display: grid;
      place-items: center;
      box-shadow: inset 0 -10px 22px rgba(248,76,162,0.08);
    }

    .car-name {
      margin: 0 0 4px;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.5;
      font-weight: 900;
    }

    .car-spec {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
      margin: 0 0 12px;
    }

    .price-box {
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(180deg, #fff, #fff7fb);
      border: 1px solid rgba(248,76,162,0.16);
    }

    .price-caption {
      margin: 0;
      color: #b85f42;
      font-size: 12px;
      font-weight: 800;
    }

    .price-main {
      margin: 4px 0 6px;
      color: var(--dark-blue);
      font-size: 40px;
      line-height: 1.05;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .price-main span {
      font-size: 22px;
    }

    .price-foot {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .primary-btn,
    .ghost-btn,
    .outline-btn {
      width: 100%;
      border: 0;
      border-radius: 30px;
      padding: 14px 18px;
      font: inherit;
      font-size: 14px;
      font-weight: 900;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .primary-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 18px 24px rgba(77,180,255,0.24);
      animation: pulseGlow 2.4s infinite;
    }

    .ghost-btn {
      background: #fff;
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.12);
    }

    .outline-btn {
      background: rgba(255,255,255,0.76);
      color: var(--dark-blue);
      border: 1px dashed rgba(184,95,66,0.32);
    }

    .primary-btn:active,
    .ghost-btn:active,
    .outline-btn:active {
      transform: scale(0.98);
    }

    .support-line {
      margin-top: 10px;
      text-align: center;
      color: var(--text-gray);
      font-size: 11px;
    }

    .mini-graph {
      margin-top: 12px;
      padding: 12px 12px 8px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(236,246,255,0.8), rgba(255,255,255,0.92));
      border: 1px solid rgba(64,153,255,0.12);
    }

    .mini-graph-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
    }

    .mini-graph-header small {
      color: var(--text-gray);
      font-weight: 600;
    }

    .caption-side {
      display: grid;
      gap: 14px;
    }

    .note-card {
      background: rgba(255,255,255,0.82);
      border-radius: 22px;
      padding: 18px;
      box-shadow: 0 18px 28px rgba(28,38,99,0.08);
      border: 1px solid rgba(255,255,255,0.84);
    }

    .note-card h2 {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 24px;
      line-height: 1.4;
    }

    .note-card p {
      margin: 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 1.8;
    }

    .checklist {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .checklist div {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-black);
    }

    .check {
      width: 22px;
      height: 22px;
      flex: 0 0 22px;
      border-radius: 999px;
      background: rgba(248,76,162,0.12);
      color: var(--pink);
      display: inline-grid;
      place-items: center;
      font-weight: 900;
    }

    .forecast-board {
      display: grid;
      gap: 14px;
    }

    .filter-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .toggle-chip {
      border: 0;
      border-radius: var(--radius-chip);
      min-height: 43px;
      padding: 10px 16px;
      background: #fff;
      color: var(--text-black);
      font: inherit;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      border: 1px solid var(--ruled-line);
      transition: 0.2s ease;
    }

    .toggle-chip.active {
      background: var(--dark-blue);
      color: #fff;
      box-shadow: 0 14px 22px rgba(28,38,99,0.18);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 10px;
    }

    .expense-item {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .expense-item strong {
      display: block;
      color: var(--dark-blue);
      font-size: 18px;
      margin-top: 6px;
    }

    .expense-item span {
      color: var(--text-gray);
      font-size: 12px;
    }

    .graph-panel {
      padding: 14px;
      border-radius: 22px;
      background: linear-gradient(180deg, #ffffff, #f7fbff);
      border: 1px solid rgba(64,153,255,0.12);
    }

    .graph-meta {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      margin-bottom: 10px;
    }

    .graph-meta h3 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
    }

    .graph-meta p {
      margin: 0;
      color: var(--text-gray);
      font-size: 11px;
    }

    .value-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 12px;
    }

    .value-box {
      padding: 10px;
      border-radius: 16px;
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(28,38,99,0.06);
      text-align: center;
    }

    .value-box em {
      display: block;
      font-style: normal;
      font-size: 10px;
      color: var(--text-gray);
      margin-bottom: 4px;
    }

    .value-box strong {
      color: var(--dark-blue);
      font-size: 16px;
      letter-spacing: -0.03em;
    }

    .compare-title {
      margin: 18px 0 10px;
      color: var(--dark-blue);
      font-size: 32px;
      line-height: 1.22;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .compare-sub {
      margin: 0 0 14px;
      font-size: 14px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    .comfort-banner {
      padding: 14px 16px;
      border-radius: 22px;
      background: linear-gradient(135deg, #fff1e7, #fffaf6);
      color: #c5664a;
      font-size: 14px;
      font-weight: 800;
      box-shadow: 0 14px 26px rgba(197,102,74,0.08);
      transform: rotate(-1.5deg);
      margin-bottom: 12px;
    }

    .comparison {
      display: grid;
      gap: 10px;
      margin-top: 10px;
    }

    .compare-card {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr 1fr;
      align-items: center;
      gap: 12px;
      padding: 14px;
      border-radius: 20px;
      background: rgba(255,255,255,0.9);
      border: 1px solid rgba(28,38,99,0.06);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .compare-card.highlight {
      background: linear-gradient(135deg, rgba(248,76,162,0.14), rgba(255,255,255,0.95) 50%, rgba(111,194,255,0.14));
      border: 1px solid rgba(248,76,162,0.22);
    }

    .compare-card.stress {
      animation: nudge 0.55s ease;
    }

    .compare-brand strong {
      display: block;
      color: var(--dark-blue);
      font-size: 15px;
      margin-bottom: 4px;
    }

    .compare-brand span {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.55;
    }

    .call-meter {
      display: flex;
      align-items: center;
      gap: 6px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .call-pill {
      min-width: 52px;
      padding: 8px 10px;
      border-radius: 999px;
      text-align: center;
      font-size: 11px;
      font-weight: 900;
      background: #fff5f2;
      color: #d0664d;
      border: 1px solid rgba(208,102,77,0.14);
    }

    .call-pill.zero {
      background: #e9fbf5;
      color: var(--good);
      border-color: rgba(23,161,111,0.14);
    }

    .call-count {
      text-align: right;
    }

    .call-count strong {
      display: block;
      color: var(--dark-blue);
      font-size: 22px;
      letter-spacing: -0.04em;
    }

    .call-count span {
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .legend {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .legend-dot.pink {
      background: var(--pink);
    }

    .legend-dot.blue {
      background: #4db4ff;
    }

    .legend-dot.orange {
      background: #ff9a6e;
    }

    .meta-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .dock {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 20px;
    }

    .dock button {
      border: 0;
      border-radius: 999px;
      padding: 12px 16px;
      font: inherit;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      background: rgba(255,255,255,0.88);
      color: var(--dark-blue);
      box-shadow: 0 14px 22px rgba(28,38,99,0.07);
    }

    .floating-sticker {
      position: absolute;
      right: 18px;
      top: 92px;
      padding: 10px 12px;
      border-radius: 16px 16px 4px 16px;
      background: #fff;
      color: #c36b4f;
      font-size: 11px;
      font-weight: 900;
      box-shadow: 0 18px 24px rgba(195,107,79,0.1);
      transform: rotate(8deg);
      animation: floaty 3.2s ease-in-out infinite;
    }

    .home-indicator {
      width: 120px;
      height: 5px;
      margin: 16px auto 4px;
      border-radius: 999px;
      background: rgba(28,38,99,0.16);
    }

    .android-nav {
      display: flex;
      justify-content: center;
      gap: 24px;
      padding: 12px 0 2px;
      color: rgba(28,38,99,0.5);
      font-size: 18px;
      font-weight: 800;
    }

    .muted {
      color: var(--text-gray);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes pulseGlow {
      0%, 100% {
        box-shadow: 0 18px 24px rgba(77,180,255,0.24);
      }
      50% {
        box-shadow: 0 22px 30px rgba(77,180,255,0.34);
      }
    }

    @keyframes floaty {
      0%, 100% {
        transform: translateY(0) rotate(8deg);
      }
      50% {
        transform: translateY(-6px) rotate(6deg);
      }
    }

    @keyframes nudge {
      0%, 100% {
        transform: translateX(0);
      }
      20% {
        transform: translateX(-4px);
      }
      40% {
        transform: translateX(5px);
      }
      60% {
        transform: translateX(-3px);
      }
      80% {
        transform: translateX(2px);
      }
    }

    @media (max-width: 980px) {
      .shot,
      .show-all .shot {
        grid-template-columns: 1fr;
      }

      .caption-side {
        order: -1;
      }

      .note-card h2 {
        font-size: 22px;
      }
    }

    @media (max-width: 640px) {
      .page-shell {
        padding: 18px 12px 72px;
      }

      .tabbar {
        gap: 8px;
      }

      .tab {
        padding: 12px 8px;
        font-size: 12px;
      }

      .shot {
        padding: 12px;
        border-radius: 24px;
      }

      .phone {
        width: 100%;
      }

      .phone-inner {
        min-height: 736px;
      }

      .main-copy,
      .compare-title {
        font-size: 30px;
      }

      .compare-card {
        grid-template-columns: 1fr;
        align-items: flex-start;
      }

      .call-count {
        text-align: left;
      }
    }
  </style>
</head>
<body>
  <div class="page-shell">
    <div class="content">
      <div class="top-copy">
        <span class="eyebrow">UcarPAC ストアスクショ検証 / A・B・C / 375px基準</span>
        <h1 class="title">「今すぐ売らなくても大丈夫」と伝えながら、<br>DLの不安をやわらげるストア訴求。</h1>
        <p class="lead">AI査定・出費管理・電話ストレスの回避を、暖色の安心感とやさしい手書き風メモで表現したHTMLプロトタイプです。タブ切替、比較アニメーション、将来予測の状態変更を入れ、静止画検証の前段として触れる形にしています。</p>
        <div class="hand-note" id="rotatingNote">まずは相場を見るだけ。個人情報なしで試せる安心感を先に伝える。</div>
      </div>

      <div class="tabbar" role="tablist" aria-label="ストアスクショ切替">
        <button class="tab active" data-target="shot-a" role="tab" aria-selected="true">
          スクショA
          <small>iOS / AI査定</small>
        </button>
        <button class="tab" data-target="shot-b" role="tab" aria-selected="false">
          スクショB
          <small>Android / 出費管理</small>
        </button>
        <button class="tab" data-target="shot-c" role="tab" aria-selected="false">
          スクショC
          <small>比較 / 電話0本</small>
        </button>
      </div>

      <main class="stage" id="stage">
        <section class="shot active" id="shot-a">
          <div class="phone ios">
            <div class="phone-inner">
              <div class="statusbar">
                <span>9:41</span>
                <div class="status-icons">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="bar"></span>
                </div>
              </div>

              <div class="screen">
                <div class="floating-sticker">不安を先にほどくUI</div>
                <div class="shot-label"><span class="circle">A</span> iOS向け / AI査定を全面に</div>
                <div class="speech">「いきなり営業電話が来そう…」そんな不安から始めない。</div>
                <h2 class="main-copy">AIがあなたの愛車を査定。<br>まずは価格だけ見てみよう。</h2>
                <p class="sub-copy">トヨタ ハリアーの今の相場と、少し先の売り時まで。まだ売るか迷っていても、やさしく判断材料がそろいます。</p>

                <div class="badge-row">
                  <div class="badge hot">個人情報なし</div>
                  <div class="badge good">最短30秒で相場チェック</div>
                  <div class="badge">将来予測つきAI査定</div>
                </div>

                <div class="app-card">
                  <div class="car-panel">
                    <div class="car-illu" aria-hidden="true">
                      <svg width="88" height="58" viewBox="0 0 88 58" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="12" y="24" width="62" height="18" rx="8" fill="#F84CA2"/>
                        <path d="M26 20C29 13 35 10 45 10H58C63.5 10 66.5 13 69 20L74 24H17L26 20Z" fill="#1C2663"/>
                        <circle cx="28" cy="43" r="8" fill="#1C2663"/>
                        <circle cx="61" cy="43" r="8" fill="#1C2663"/>
                        <circle cx="28" cy="43" r="3" fill="#fff"/>
                        <circle cx="61" cy="43" r="3" fill="#fff"/>
                        <rect x="36" y="14" width="20" height="7" rx="3.5" fill="#6FC2FF"/>
                        <rect x="71" y="26" width="7" height="6" rx="3" fill="#FFD8E8"/>
                      </svg>
                    </div>
                    <div>
