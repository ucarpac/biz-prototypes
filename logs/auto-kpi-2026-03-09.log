        radial-gradient(circle at 15% 15%, rgba(255, 211, 122, 0.5), transparent 28%),
        radial-gradient(circle at 85% 8%, rgba(248, 76, 162, 0.18), transparent 24%),
        radial-gradient(circle at 90% 90%, rgba(109, 194, 255, 0.22), transparent 26%),
        linear-gradient(180deg, #fffaf7 0%, #fff2eb 52%, #fdfbff 100%);
      color: var(--text-black);
      font-family: var(--font-sans);
    }

    body {
      overflow-x: hidden;
    }

    .ambient {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
    }

    .ambient span {
      position: absolute;
      display: block;
      border-radius: 999px;
      opacity: 0.75;
      filter: blur(1px);
      animation: float 10s ease-in-out infinite;
    }

    .ambient .blob-1 {
      width: 180px;
      height: 180px;
      background: rgba(255, 211, 122, 0.33);
      top: 5%;
      left: -40px;
    }

    .ambient .blob-2 {
      width: 220px;
      height: 220px;
      background: rgba(248, 76, 162, 0.12);
      top: 18%;
      right: -70px;
      animation-delay: -3s;
    }

    .ambient .blob-3 {
      width: 180px;
      height: 180px;
      background: rgba(109, 194, 255, 0.18);
      bottom: 2%;
      left: -20px;
      animation-delay: -5s;
    }

    .ambient .blob-4 {
      width: 120px;
      height: 120px;
      background: rgba(255, 142, 122, 0.18);
      bottom: 24%;
      right: 6%;
      animation-delay: -2s;
    }

    @keyframes float {
      0%,
      100% {
        transform: translateY(0px) translateX(0px) rotate(0deg);
      }
      50% {
        transform: translateY(-14px) translateX(8px) rotate(4deg);
      }
    }

    .app-shell {
      position: relative;
      z-index: 1;
      max-width: 1120px;
      margin: 0 auto;
      padding: 24px 16px 56px;
    }

    .top-copy {
      max-width: 720px;
      margin: 0 auto 20px;
      text-align: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(248, 76, 162, 0.14);
      box-shadow: 0 10px 30px rgba(28, 38, 99, 0.05);
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      letter-spacing: 0.02em;
    }

    .eyebrow::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--warm-sun), var(--pink));
      box-shadow: 0 0 0 4px rgba(248, 76, 162, 0.08);
    }

    h1 {
      margin: 16px 0 10px;
      font-size: clamp(28px, 7vw, 44px);
      line-height: 1.24;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .top-copy p {
      margin: 0 auto;
      max-width: 640px;
      font-size: 14px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .kpi-strip {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin: 18px auto 0;
    }

    .kpi-chip {
      padding: 10px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px dashed rgba(28, 38, 99, 0.12);
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      box-shadow: 0 8px 24px rgba(28, 38, 99, 0.05);
      transform: rotate(-1deg);
    }

    .kpi-chip:nth-child(2) {
      transform: rotate(1deg);
    }

    .kpi-chip:nth-child(3) {
      transform: rotate(-2deg);
    }

    .controls {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin: 28px auto 24px;
      max-width: 960px;
    }

    .control-card {
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(28, 38, 99, 0.08);
      border-radius: 22px;
      padding: 14px;
      box-shadow: 0 16px 42px rgba(28, 38, 99, 0.08);
      backdrop-filter: blur(14px);
    }

    .control-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 700;
    }

    .control-title .hint {
      color: var(--text-gray);
      font-weight: 500;
      font-size: 11px;
    }

    .tab-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .tab-btn,
    .micro-btn,
    .cta-btn {
      border: 0;
      font-family: inherit;
      cursor: pointer;
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, color 0.25s ease;
    }

    .tab-btn {
      min-height: 54px;
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(28, 38, 99, 0.08);
      padding: 12px;
      text-align: left;
      color: var(--text-black);
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.05);
    }

    .tab-btn strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      margin-bottom: 2px;
    }

    .tab-btn span {
      display: block;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
    }

    .tab-btn.active {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 240, 232, 0.94));
      border-color: rgba(248, 76, 162, 0.28);
      box-shadow: 0 14px 28px rgba(248, 76, 162, 0.15);
      transform: translateY(-1px);
    }

    .preview-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .micro-btn {
      min-height: 42px;
      padding: 0 16px;
      border-radius: 999px;
      background: #fff;
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 10px 22px rgba(28, 38, 99, 0.06);
      font-size: 13px;
      font-weight: 700;
    }

    .micro-btn.active {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 12px 26px rgba(248, 76, 162, 0.22);
    }

    .phone-stage {
      display: grid;
      gap: 20px;
      align-items: start;
    }

    .stage-main {
      position: relative;
      margin: 0 auto;
      width: min(100%, 420px);
    }

    .phone-frame {
      position: relative;
      width: 100%;
      aspect-ratio: 375 / 812;
      border-radius: 42px;
      padding: 12px;
      background: linear-gradient(160deg, #2b346f 0%, #121a46 100%);
      box-shadow:
        0 30px 80px rgba(9, 19, 85, 0.32),
        inset 0 0 0 1px rgba(255, 255, 255, 0.16);
    }

    .phone-bezel {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 34px;
      overflow: hidden;
      background: #fff;
    }

    .ios-notch,
    .android-topbar {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
    }

    .ios-notch {
      top: 10px;
      width: 132px;
      height: 28px;
      border-radius: 20px;
      background: #121212;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .android-topbar {
      top: 10px;
      width: calc(100% - 28px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .android-icons {
      display: flex;
      gap: 6px;
      align-items: center;
    }

    .android-icons span {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--dark-blue);
      opacity: 0.78;
    }

    .phone-frame.ios .ios-notch {
      opacity: 1;
    }

    .phone-frame.android .android-topbar {
      opacity: 1;
    }

    .screens {
      position: relative;
      width: 100%;
      height: 100%;
    }

    .screen {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      transform: translateX(22px) scale(0.98);
      transition: opacity 0.45s ease, transform 0.45s ease;
      overflow: hidden;
      background: var(--warm-cream);
    }

    .screen.active {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0) scale(1);
    }

    .screen-inner {
      height: 100%;
      padding: 58px 18px 18px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      position: relative;
    }

    .paper-lines {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(to bottom, transparent 0, transparent 31px, var(--paper-line) 32px);
      background-size: 100% 32px;
      opacity: 0.12;
      pointer-events: none;
    }

    .sticker {
      position: absolute;
      top: 72px;
      right: 16px;
      z-index: 3;
      padding: 10px 12px;
      border-radius: 18px 18px 18px 4px;
      background: var(--warm-note);
      box-shadow: 0 10px 20px rgba(255, 211, 122, 0.28);
      transform: rotate(5deg);
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
      line-height: 1.45;
      border: 1px dashed rgba(28, 38, 99, 0.14);
    }

    .sticker small {
      display: block;
      margin-top: 2px;
      font-size: 10px;
      font-weight: 600;
      color: var(--text-gray);
    }

    .hero-card {
      position: relative;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 245, 240, 0.92)),
        linear-gradient(135deg, rgba(255, 211, 122, 0.2), transparent 40%);
      border-radius: 26px;
      padding: 18px;
      box-shadow: 0 18px 36px rgba(28, 38, 99, 0.08);
      overflow: hidden;
      border: 1px solid rgba(248, 76, 162, 0.08);
    }

    .hero-card::after {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(248, 76, 162, 0.12), transparent 70%);
      top: -40px;
      right: -44px;
      pointer-events: none;
    }

    .caption-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      align-self: flex-start;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(28, 38, 99, 0.08);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.04);
    }

    .caption-pill::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--warm-coral), var(--pink));
    }

    .headline {
      margin: 12px 0 8px;
      font-size: 30px;
      line-height: 1.28;
      font-weight: 800;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
    }

    .headline .accent {
      color: var(--pink);
      position: relative;
    }

    .headline .accent::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 2px;
      width: 100%;
      height: 10px;
      background: rgba(255, 211, 122, 0.65);
      z-index: -1;
      border-radius: 999px;
    }

    .support-copy {
      margin: 0;
      font-size: 13px;
      line-height: 1.75;
      color: var(--text-gray);
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .badge {
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      color: var(--dark-blue);
      background: #fff;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 8px 14px rgba(28, 38, 99, 0.04);
    }

    .badge.pink {
      background: rgba(248, 76, 162, 0.1);
      color: var(--pink);
      border-color: rgba(248, 76, 162, 0.16);
    }

    .badge.mint {
      background: var(--soft-mint);
      border-color: rgba(30, 122, 86, 0.08);
    }

    .car-illustration {
      position: relative;
      height: 170px;
      margin: 6px 0 0;
      display: flex;
      align-items: end;
      justify-content: center;
    }

    .car-shadow {
      position: absolute;
      bottom: 12px;
      width: 210px;
      height: 24px;
      border-radius: 50%;
      background: rgba(28, 38, 99, 0.12);
      filter: blur(8px);
    }

    .car-body {
      position: relative;
      width: 248px;
      height: 106px;
      background: linear-gradient(180deg, #ff93b5 0%, #f84ca2 55%, #e8398c 100%);
      border-radius: 46px 52px 32px 30px;
      box-shadow: inset 0 -6px 0 rgba(255, 255, 255, 0.16);
      animation: bob 3.2s ease-in-out infinite;
    }

    .car-roof {
      position: absolute;
      top: -28px;
      left: 50px;
      width: 116px;
      height: 42px;
      background: linear-gradient(180deg, #ffe2ec, #ffd0e2);
      border-radius: 30px 36px 10px 12px;
      border: 4px solid rgba(28, 38, 99, 0.08);
    }

    .car-window {
      position: absolute;
      top: -19px;
      left: 64px;
      width: 40px;
      height: 24px;
      border-radius: 10px;
      background: rgba(28, 38, 99, 0.16);
    }

    .car-window.w2 {
      left: 107px;
      width: 46px;
    }

    .wheel {
      position: absolute;
      bottom: -13px;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: #2d2d38;
      border: 8px solid #4c4f5a;
    }

    .wheel::after {
      content: "";
      position: absolute;
      inset: 10px;
      border-radius: 50%;
      background: #c9cdda;
    }

    .wheel.left {
      left: 28px;
    }

    .wheel.right {
      right: 28px;
    }

    .headlight {
      position: absolute;
      top: 40px;
      width: 22px;
      height: 16px;
      border-radius: 20px;
      background: #fff9d7;
      box-shadow: 0 0 18px rgba(255, 234, 144, 0.9);
    }

    .headlight.left {
      left: 12px;
      transform: rotate(-8deg);
    }

    .headlight.right {
      right: 12px;
      transform: rotate(8deg);
    }

    .smile {
      position: absolute;
      left: 50%;
      bottom: 20px;
      width: 92px;
      height: 30px;
      border-bottom: 4px solid rgba(28, 38, 99, 0.2);
      border-radius: 0 0 120px 120px;
      transform: translateX(-50%);
    }

    @keyframes bob {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-6px);
      }
    }

    .value-card {
      background: linear-gradient(145deg, #ffffff, #fff4ef);
      border-radius: 24px;
      padding: 16px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 16px 34px rgba(28, 38, 99, 0.08);
    }

    .car-name {
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-gray);
      margin-bottom: 10px;
      font-weight: 600;
    }

    .yen {
      display: flex;
      align-items: baseline;
      gap: 8px;
      color: var(--dark-blue);
    }

    .yen .label {
      font-size: 12px;
      font-weight: 800;
      color: var(--pink);
    }

    .yen .price {
      font-size: 38px;
      line-height: 1;
      font-family: var(--font-number);
      letter-spacing: -0.04em;
    }

    .yen .unit {
      font-size: 16px;
      font-weight: 800;
    }

    .sub-flex {
      display: flex;
      gap: 12px;
      margin-top: 14px;
    }

    .mini-panel {
      flex: 1;
      min-width: 0;
      background: #fff;
      border-radius: 16px;
      padding: 12px;
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .mini-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 6px;
    }

    .mini-value {
      font-size: 18px;
      line-height: 1.3;
      font-weight: 800;
      color: var(--dark-blue);
      letter-spacing: -0.02em;
    }

    .mini-value.positive {
      color: #17835f;
    }

    .mini-value.warn {
      color: #d05d2e;
    }

    .segment-row {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .segment-row button {
      flex: 1;
      min-height: 36px;
      border-radius: 999px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      background: #fff;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .segment-row button.active {
      background: var(--dark-blue);
      color: #fff;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.18);
    }

    .chart-card {
      background: linear-gradient(180deg, #fff 0%, #fffaf6 100%);
      border-radius: 24px;
      padding: 16px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 14px 30px rgba(28, 38, 99, 0.06);
    }

    .chart-top {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .chart-title {
      font-size: 15px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .chart-note {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
      max-width: 150px;
      text-align: right;
    }

    .bars {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 10px;
      height: 150px;
      padding: 8px 0 4px;
    }

    .bar-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .bar {
      width: 100%;
      max-width: 64px;
      min-height: 24px;
      border-radius: 18px 18px 8px 8px;
      background: linear-gradient(180deg, rgba(248, 76, 162, 0.92), rgba(255, 142, 122, 0.88));
      box-shadow: 0 12px 22px rgba(248, 76, 162, 0.18);
      transition: height 0.35s ease, opacity 0.35s ease;
      position: relative;
      overflow: hidden;
    }

    .bar::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 40%);
    }

    .bar.b2 {
      background: linear-gradient(180deg, rgba(109, 194, 255, 0.95), rgba(77, 180, 255, 0.88));
    }

    .bar.b3 {
      background: linear-gradient(180deg, rgba(255, 211, 122, 0.96), rgba(255, 142, 122, 0.88));
    }

    .bar-caption {
      font-size: 10px;
      font-weight: 800;
      color: var(--dark-blue);
      text-align: center;
      line-height: 1.45;
    }

    .bar-price {
      font-size: 10px;
      font-weight: 700;
      color: var(--text-gray);
      text-align: center;
      line-height: 1.4;
      min-height: 28px;
    }

    .notebook-card {
      position: relative;
      background: linear-gradient(180deg, #fffdf8, #fff6ef);
      border-radius: 24px;
      padding: 18px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 16px 36px rgba(28, 38, 99, 0.07);
      overflow: hidden;
    }

    .notebook-card::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 26px;
      width: 3px;
      background: rgba(248, 76, 162, 0.12);
    }

    .list-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 10px 0 10px 18px;
      border-bottom: 1px dashed rgba(28, 38, 99, 0.08);
    }

    .list-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .list-row strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      margin-bottom: 2px;
    }

    .list-row span {
      display: block;
      color: var(--text-gray);
      font-size: 11px;
    }

    .pill-total {
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(223, 247, 234, 0.8);
      color: #15704f;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }

    .forecast-curve {
      position: relative;
      height: 130px;
      margin-top: 12px;
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(109, 194, 255, 0.06), transparent 60%),
        #fff;
      border: 1px solid rgba(28, 38, 99, 0.06);
      overflow: hidden;
    }

    .forecast-curve svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .forecast-legend {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      margin-top: 10px;
    }

    .legend-pill {
      flex: 1;
      padding: 9px 10px;
      border-radius: 16px;
      background: #fff;
      border: 1px solid rgba(28, 38, 99, 0.06);
      text-align: center;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      line-height: 1.5;
    }

    .legend-pill small {
      display: block;
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 600;
    }

    .compare-wrap {
      display: grid;
      gap: 12px;
    }

    .compare-card {
      background: linear-gradient(180deg, #fff 0%, #fff7f1 100%);
      border-radius: 24px;
      padding: 16px;
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 15px 34px rgba(28, 38, 99, 0.06);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1.18fr 0.82fr 0.82fr;
      gap: 8px;
      margin-top: 12px;
    }

    .compare-head,
    .compare-cell {
      border-radius: 16px;
      padding: 12px 10px;
      text-align: center;
      font-size: 11px;
      line-height: 1.5;
    }

    .compare-head {
      background: rgba(28, 38, 99, 0.06);
      color: var(--dark-blue);
      font-weight: 800;
    }

    .compare-head.highlight {
      background: linear-gradient(135deg, rgba(248, 76, 162, 0.14), rgba(255, 211, 122, 0.22));
      border: 1px solid rgba(248, 76, 162, 0.18);
    }

    .compare-cell {
      background: #fff;
      border: 1px solid rgba(28, 38, 99, 0.06);
      color: var(--text-black);
      font-weight: 700;
    }

    .compare-cell.good {
      background: rgba(223, 247, 234, 0.7);
      color: #15704f;
      border-color: rgba(21, 112, 79, 0.1);
    }

    .compare-cell.warn {
      background: rgba(255, 239, 230, 0.76);
      color: #ba5e30;
      border-color: rgba(186, 94, 48, 0.1);
    }

    .compare-cell.bad {
      background: rgba(248, 76, 162, 0.08);
      color: #b83f7b;
      border-color: rgba(248, 76, 162, 0.14);
    }

    .callout {
      margin-top: 12px;
      padding: 14px 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(255, 211, 122, 0.26), rgba(255, 255, 255, 0.96));
      border: 1px dashed rgba(28, 38, 99, 0.12);
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.8;
      font-weight: 700;
    }

    .cta-btn {
      width: 100%;
      min-height: 52px;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
      box-shadow: 0 16px 28px rgba(77, 180, 255, 0.26);
    }

    .cta-btn.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 16px 28px rgba(248, 76, 162, 0.24);
    }

    .cta-btn:active,
    .tab-btn:active,
    .micro-btn:active {
      transform: scale(0.98);
    }

    .floating-note {
      position: absolute;
      bottom: 22px;
      left: 50%;
      transform: translateX(-50%) translateY(18px);
      width: calc(100% - 40px);
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(28, 38, 99, 0.9);
      color: #fff;
      font-size: 12px;
      line-height: 1.6;
      text-align: center;
      box-shadow: 0 16px 30px rgba(9, 19, 85, 0.26);
      opacity: 0;
      transition: opacity 0.3s ease, transform 0.3s ease;
      z-index: 30;
    }

    .floating-note.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .meta-column {
      display: grid;
      gap: 12px;
      max-width: 420px;
      margin: 0 auto;
    }

    .meta-card {
      padding: 14px 16px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 12px 30px rgba(28, 38, 99, 0.06);
    }

    .meta-card h2 {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 1.5;
    }

    .meta-card p {
      margin: 0;
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-gray);
    }

    .meta-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .meta-tags span {
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(28, 38, 99, 0.08);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
    }

    .scribble {
      position: absolute;
      border: 2px solid rgba(248, 76, 162, 0.18);
      border-radius: 50%;
      pointer-events: none;
      animation: wobble 7s ease-in-out infinite;
    }

    .scribble.s1 {
      width: 90px;
      height: 28px;
      top: 176px;
      left: 12px;
      transform: rotate(-12deg);
    }

    .scribble.s2 {
      width: 120px;
      height: 38px;
      top: 480px;
      right: 14px;
      transform: rotate(11deg);
      animation-delay: -2s;
    }

    @keyframes wobble {
      0%,
      100% {
        transform: rotate(-5deg) scale(1);
      }
      50% {
        transform: rotate(5deg) scale(1.03);
      }
    }

    .desktop-footer {
      margin-top: 20px;
      text-align: center;
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    @media (min-width: 900px) {
      .phone-stage {
        grid-template-columns: minmax(320px, 430px) minmax(320px, 420px);
      }

      .controls {
        margin-bottom: 28px;
      }

      .stage-main {
        margin: 0;
      }

      .meta-column {
        margin: 0;
        align-self: center;
      }
    }

    @media (max-width: 374px) {
      .headline {
        font-size: 27px;
      }

      .screen-inner {
        padding-left: 14px;
        padding-right: 14px;
      }

      .sub-flex {
        flex-direction: column;
      }
    }

    .motion-paused * {
      animation-play-state: paused !important;
    }
  </style>
</head>
<body>
  <div class="ambient" aria-hidden="true">
    <span class="blob-1"></span>
    <span class="blob-2"></span>
    <span class="blob-3"></span>
    <span class="blob-4"></span>
  </div>

  <main class="app-shell">
    <section class="top-copy">
      <div class="eyebrow">A案 / 感情に訴えるASOスクショ検証</div>
      <h1>不安をやわらげて、<br>「まず見てみる」を増やすストア訴求</h1>
      <p>
        ストア詳細ページで感じる「売るのって面倒そう」「電話が来そう」という抵抗を、
        やさしい体験の見せ方で先回りして解消するプロトタイプです。
        AI査定、出費管理、競合比較をそれぞれ1枚ずつ、温度感のあるビジュアルで表現します。
      </p>
      <div class="kpi-strip">
        <div class="kpi-chip">対象KPI: ストアPV→DL率 17.3% → 25%</div>
        <div class="kpi-chip">主訴求: 個人情報なし / AI査定 / 電話0本</div>
        <div class="kpi-chip">用途: iOS・Android ストアスクショ比較検証</div>
      </div>
    </section>

    <section class="controls">
      <div class="control-card">
        <div class="control-title">
          <span>スクリーン切替</span>
          <span class="hint">タップでA/B/Cを切り替え</span>
        </div>
        <div class="tab-row">
          <button class="tab-btn active" data-screen="screen-a">
            <strong>スクショA</strong>
            <span>iOS向け / AI査定を全面訴求</span>
          </button>
          <button class="tab-btn" data-screen="screen-b">
            <strong>スクショB</strong>
            <span>Android向け / 出費管理+将来予測</span>
          </button>
          <button class="tab-btn" data-screen="screen-c">
            <strong>スクショC</strong>
            <span>競合比較 / 電話0本を明確化</span>
          </button>
        </div>
      </div>

      <div class="control-card">
        <div class="control-title">
          <span>プレビュー演出</span>
          <span class="hint">自動再生とモーションのON/OFF</span>
        </div>
        <div class="preview-actions">
          <button class="micro-btn active" id="autoPlayToggle">自動で切り替える</button>
          <button class="micro-btn active" id="motionToggle">やさしい動きを有効</button>
          <button class="micro-btn" id="toastButton">訴求メモを見る</button>
        </div>
      </div>
    </section>

    <section class="phone-stage">
      <div class="stage-main">
        <div class="phone-frame ios" id="phoneFrame">
          <div class="phone-bezel">
            <div class="ios-notch"></div>
            <div class="android-topbar">
              <span>9:41</span>
              <div class="android-icons">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>

            <div class="screens">
              <section class="screen active" id="screen-a">
                <div class="paper-lines"></div>
                <div class="scribble s1"></div>
                <div class="scribble s2"></div>
                <div class="sticker">
                  今日のモヤモヤを<br>3分で軽くする
                  <small>個人情報なし</small>
                </div>

                <div class="screen-inner">
                  <div class="hero-card">
                    <div class="caption-pill">iOS向けストアスクショ A</div>
                    <h2 class="headline">
                      AIが愛車の価格を<br><span class="accent">やさしく先読み</span>
                    </h2>
                    <p class="support-copy">
                      2019年式のプリウスでも、今の相場と3か月後の見込みをまとめて確認。
                      いきなり申し込みではなく、まずは安心して「見るだけ」から始められます。
                    </p>
                    <div class="badge-row">
                      <span class="badge pink">個人情報なし</span>
                      <span class="badge">最短3分でAI査定</span>
                      <span class="badge mint">売り時のヒント表示</span>
                    </div>

                    <div class="car-illustration" aria-hidden="true">
                      <div class="car-shadow"></div>
                      <div class="car-body">
                        <div class="car-roof"></div>
                        <div class="car-window"></div>
                        <div class="car-window w2"></div>
                        <div class="headlight left"></div>
                        <div class="headlight right"></div>
                        <div class="smile"></div>
                        <div class="wheel left"></div>
                        <div class="wheel right"></div>
                      </div>
                    </div>
                  </div>

                  <div class="value-card">
                    <div class="car-name">トヨタ プリウス Sツーリングセレクション / 2019年式 / 63,400km</div>
                    <div class="yen">
                      <span class="label">AI査定額</span>
                      <span class="price" id="a-price">1,486,000</span>
                      <span class="unit">円</span>
                    </div>
                    <div class="sub-flex">
                      <div class="mini-panel">
                        <div class="mini-label">今すぐ売るなら</div>
                        <div class="mini-value" id="a-now">1,480,000円前後</div>
                      </div>
                      <div class="mini-panel">
                        <div class="mini-label">おすすめタイミング</div>
                        <div class="mini-value positive" id="a-timing">今月中が安心</div>
                      </div>
                    </div>
                    <div class="segment-row" id="a-periods">
                      <button class="active" data-period="1">今月</button>
                      <button data-period="3">3か月後</button>
                      <button data-period="6">6か月後</button>
                    </div>
                  </div>

                  <div class="chart-card">
                    <div class="chart-top">
                      <div class="chart-title">将来予測グラフ</div>
                      <div class="chart-note" id="a-note">
                        値落ち前の今月に確認しておくと、
                        気持ちにも余裕がつくれます。
                      </div>
                    </div>

                    <div class="bars">
                      <div class="bar-wrap">
                        <div class="bar" id="a-bar-1" style="height: 132px;"></div>
                        <div class="bar-caption">現在</div>
                        <div class="bar-price" id="a-bar-label-1">148.6万円</div>
                      </div>
                      <div class="bar-wrap">
                        <div class="bar b2" id="a-bar-2" style="height: 118px;"></div>
                        <div class="bar-caption" id="a-caption-2">3か月後</div>
                        <div class="bar-price" id="a-bar-label-2">143.2万円</div>
                      </div>
                      <div class="bar-wrap">
                        <div class="bar b3" id="a-bar-3" style="height: 96px;"></div>
                        <div class="bar-caption" id="a-caption-3">6か月後</div>
                        <div class="bar-price" id="a-bar-label-3">136.1万円</div>
                      </div>
                    </div>
                  </div>

                  <button class="cta-btn" data-toast="査定の心理的ハードルを下げるため、CTA文言は『今の価格をみる』に抑えています。">
                    今の価格をみる
                  </button>
                </div>
              </section>

              <section class="screen" id="screen-b">
                <div class="paper-lines"></div>
                <div class="sticker" style="background: #ffe9d7; transform: rotate(-4deg); right: 18px;">
                  家計簿っぽく見せて<br>価値変動も自然に
                  <small>Android向け</small>
                </div>

                <div class="screen-inner">
                  <div class="hero-card" style="background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(245,249,255,0.92));">
                    <div class="caption-pill">Android向けストアスクショ B</div>
                    <h2 class="headline">
                      出費も価値も、<br><span class="accent">まとめて安心</span>
                    </h2>
                    <p class="support-copy">
                      ガソリン代、保険、車検。毎月の出費と愛車の将来価値をひとつの画面で確認。
                      「持ち続けるか、売るか」を感覚ではなく、納得感で決められます。
                    </p>
                    <div class="badge-row">
                      <span class="badge mint">出費管理つき</span>
                      <span class="badge">6か月後まで予測</span>
                      <span class="badge pink">家計にやさしい判断</span>
                    </div>
                  </div>

                  <div class="notebook-card">
                    <div class="car-name">ホンダ フリード G Honda SENSING / 2018年式 / 51,200km</div>

                    <div class="segment-row" id="b-periods">
                      <button class="active" data-range="month">今月</button>
                      <button data-range="half">半年</button>
                      <button data-range="year">1年</button>
                    </div>

                    <div class="list-row">
                      <div>
                        <strong>ガソリン</strong>
                        <span>レギュラー 46.2L / 月4回</span>
                      </div>
                      <div class="pill-total" id="b-gas">11,800円</div>
                    </div>

                    <div class="list-row">
                      <div>
                        <strong>保険・税金</strong>
                        <span>任意保険 / 自動車税の月割り</span>
                      </div>
                      <div class="pill-total" id="b-insurance">9,400円</div>
                    </div>

                    <div class="list-row">
                      <div>
                        <strong>メンテナンス</strong>
                        <span>オイル・点検積立 / タイヤ積立</span>
                      </div>
                      <div class="pill-total" id="b-maintenance">6,500円</div>
                    </div>

                    <div class="list-row">
                      <div>
                        <strong>合計維持費</strong>
                        <span id="b-total-sub">今月の平均ペース</span>
                      </div>
                      <div class="pill-total" id="b-total">27,700円</div>
                    </div>
                  </div>

                  <div class="chart-card">
                    <div class="chart-top">
                      <div class="chart-title">価値の見通し</div>
                      <div class="chart-note" id="b-note">
                        半年後までに乗り換え予定なら、
                        今のうちに相場を把握しておくと安心です。
                      </div>
                    </div>

                    <div class="forecast-curve">
                      <svg viewBox="0 0 320 130" preserveAspectRatio="none" aria-hidden="true">
                        <defs>
                          <linearGradient id="curveFill" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="rgba(77,180,255,0.32)"></stop>
                            <stop offset="100%" stop-color="rgba(77,180,255,0.03)"></stop>
                          </linearGradient>
                          <linearGradient id="curveStroke" x1="0" x2="1" y1="0" y2="0">
                            <stop offset="0%" stop-color="#f84ca2"></stop>
                            <stop offset="100%" stop-color="#4db4ff"></stop>
                          </linearGradient>
                        </defs>
                        <path d="M0,126 L0,86 C52,78 96,70 145,62 C195,54 240,42 320,16 L320,126 Z" fill="url(#curveFill)"></path>
                        <path id="b-curve" d="M0,86 C52,78 96,70 145,62 C195,54 240,42 320,16" fill="none" stroke="url(#curveStroke)" stroke-width="4" stroke-linecap="round"></path>
                        <circle id="b-dot-1" cx="26" cy="82" r="5" fill="#F84CA2"></circle>
                        <circle id="b-dot-2" cx="154" cy="60" r="5" fill="#4DB4FF"></circle>
                        <circle id="b-dot-3" cx="292" cy="24" r="5" fill="#FFD37A"></circle>
                      </svg>
                    </div>

                    <div class="forecast-legend">
                      <div class="legend-pill">
                        今の査定
                        <small id="b-legend-1">112.4万円</small>
                      </div>
                      <div class="legend-pill">
                        6か月後
                        <small id="b-legend-2">106.8万円</small>
                      </div>
                      <div class="legend-pill">
                        売りどきメモ
                        <small id="b-legend-3">春商戦前が有利</small>
                      </div>
                    </div>
                  </div>

                  <button class="cta-btn pink" data-toast="家計簿アプリに近い文脈で見せ、売却検討前の潜在層にも入りやすくしています。">
                    出費と価値をまとめて管理
                  </button>
                </div>
              </section>

              <section class="screen" id="screen-c">
                <div class="paper-lines"></div>
                <div class="sticker" style="right: auto; left: 14px; transform: rotate(-6deg);">
                  まず比較だけでOK
                  <small>電話0本の安心感</small>
                </div>

                <div class="screen-inner">
                  <div class="hero-card">
                    <div class="caption-pill">ストアスクショ C / 競合比較</div>
                    <h2 class="headline">
                      相場チェック中は<br><span class="accent">電話0本</span>でいい
                    </h2>
                    <p class="support-copy" id="c-copy">
                      一括査定の「何社からも連絡が来そう」を避けたい人へ。
                      UcarPACなら、まずは個人情報なしで価格確認。比べるだけの段階では、気持ちを急かしません。
                    </p>
                    <div class="badge-row">
                      <span class="badge pink">比較するだけなら電話0本</span>
                      <span class="badge">8,000社オークション</span>
                      <span class="badge mint">売却時もやりとり最小限</span>
                    </div>
                  </div>

                  <div class="compare-wrap">
                    <div class="compare-card">
                      <div class="segment-row" id="c-modes">
                        <button class="active" data-mode="calm">やさしさ重視</button>
                        <button data-mode="price">価格重視</button>
                        <button data-mode="speed">スピード重視</button>
                      </div>

                      <div class="compare-grid">
                        <div class="compare-head">比較ポイント</div>
                        <div class="compare-head highlight">UcarPAC</div>
                        <div class="compare-head">一般的な一括査定</div>

                        <div class="compare-cell">相場チェック開始時</div>
                        <div class="compare-cell good" id="c-cell-1a">電話0本</div>
                        <div class="compare-cell bad" id="c-cell-1b">複数社から連絡</div>

                        <div class="compare-cell">入力の気軽さ</div>
                        <div class="compare-cell good" id="c-cell-2a">個人情報なしで確認</div>
                        <div class="compare-cell warn" id="c-cell-2b">申込前提になりやすい</div>

                        <div class="compare-cell">高値の狙いやすさ</div>
                        <div class="compare-cell good" id="c-cell-3a">8,000社が競う</div>
                        <div class="compare-cell warn" id="c-cell-3b">比較はできるが交渉負担</div>
                      </div>

                      <div class="callout" id="c-callout">
                        「まだ売るか決めていない」人の不安に対して、
                        最初の一歩をとにかく軽く見せる構成です。
                      </div>
                    </div>

                    <div class="value-card">
                      <div class="car-name">比較例: 2020年式 日産 ノート e-POWER / 42,100km</div>
                      <div class="yen">
                        <span class="label">想定最高落札</span>
                        <span class="price">1,238,000</span>
                        <span class="unit">円</span>
                      </div>
                      <div class="sub-flex">
                        <div class="mini-panel">
                          <div class="mini-label">電話の心理負担</div>
                          <div class="mini-value positive">0本で開始</div>
                        </div>
                        <div class="mini-panel">
                          <div class="mini-label">交渉のしやすさ</div>
                          <div class="mini-value">必要最小限</div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <button class="cta-btn" data-toast="競合比較はネガティブ訴求になりすぎないよう、『安心して始められる』文脈に寄せています。">
                    電話なしで相場チェック
                  </button>
                </div>
              </section>
            </div>

            <div class="floating-note" id="toast"></div>
          </div>
        </div>
      </div>

      <aside class="meta-column">
        <div class="meta-card">
          <h2>プロトタイプの狙い</h2>
          <p>
            ストアPV→DL率の改善に向けて、機能の説明より先に心理障壁の低減を見せます。
            暖色のアクセント、付箋や手描き風の囲みで、冷たくないAI体験に寄せています。
          </p>
          <div class="meta-tags">
            <span>暖色系アクセント</span>
            <span>親しみやすいイラスト</span>
            <span>売却不安の先回り</span>
          </div>
        </div>

        <div class="meta-card">
          <h2>スクショごとの役割</h2>
          <p>
            AはAI査定の価値をひと目で理解させる主砲、Bは継続利用価値の補強、
            Cは競合比較で「UcarPACを選ぶ理由」を言語化する役割です。
          </p>
          <div class="meta-tags">
