  <script>
    const screenButtons = document.querySelectorAll("[data-screen-target]");
    const screens = document.querySelectorAll(".screen");
    const activeLabel = document.getElementById("activeLabel");
    const activeNotes = document.getElementById("activeNotes");
    const autoPlayToggle = document.getElementById("autoPlayToggle");

    const notesMap = {
      "screen-a": [
        "AI査定価格と下落予測を同時に見せて、価格を見る理由を作る。",
        "個人情報不要・電話0本を数字で添えて離脱不安を下げる。",
        "8,000社ネットワークを補助指標として入れ、売却時の期待値を補強する。"
      ],
      "screen-b": [
        "出費管理と資産価値を同一画面で見せ、アプリを残す理由を作る。",
        "月次 / 年間切り替えで、継続利用時の可視化価値を具体化する。",
        "売り時通知に接続して、将来の申し込み導線を自然に埋め込む。"
      ],
      "screen-c": [
        "電話0本を大きく見せ、ストア訪問時点の心理ハードルを最小化する。",
        "競合比較を表で即読化し、UcarPACの差別化を数秒で理解させる。",
        "売る時でも1社のみという補足で、誇張ではなく安心感として成立させる。"
      ]
    };

    let autoPlay = true;
    let autoTimer = null;
    let currentIndex = 0;

    function setActiveScreen(screenId) {
      screens.forEach((screen) => {
        screen.classList.toggle("active", screen.id === screenId);
      });

      screenButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.screenTarget === screenId);
      });

      currentIndex = Array.from(screens).findIndex((screen) => screen.id === screenId);
      activeLabel.textContent = "現在表示: " + screenButtons[currentIndex].textContent;

      activeNotes.innerHTML = "";
      notesMap[screenId].forEach((note) => {
        const li = document.createElement("li");
        li.textContent = note;
        activeNotes.appendChild(li);
      });
    }

    function startAutoPlay() {
      clearInterval(autoTimer);
      if (!autoPlay) return;
      autoTimer = setInterval(() => {
        currentIndex = (currentIndex + 1) % screens.length;
        setActiveScreen(screens[currentIndex].id);
      }, 5200);
    }

    screenButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setActiveScreen(button.dataset.screenTarget);
        startAutoPlay();
      });
    });

    autoPlayToggle.addEventListener("click", () => {
      autoPlay = !autoPlay;
      autoPlayToggle.textContent = "自動再生: " + (autoPlay ? "ON" : "OFF");
      startAutoPlay();
    });

    const forecastButtons = document.querySelectorAll("[data-forecast]");
    const forecastPrice = document.getElementById("forecastPrice");
    const forecastDelta = document.getElementById("forecastDelta");
    const forecastInsight = document.getElementById("forecastInsight");
    const timingScore = document.getElementById("timingScore");
    const forecastPoints = document.querySelectorAll(".forecast-point");

    const forecastMap = {
      now: {
        price: "418.2",
        delta: "6ヶ月後より +16.1万円高い見込み",
        score: "86",
        insight: "今が高値圏です。アルファード Z は春商戦の需要が強く、6ヶ月待つと約16.1万円の下落予測。価格を見るだけなら個人情報入力なしで完了します。",
        point: 0
      },
      "3m": {
        price: "409.6",
        delta: "現在より -8.6万円の予測",
        score: "67",
        insight: "3ヶ月後は夏前の需要で一定水準を維持しますが、現在より約8.6万円低い見込み。写真を追加すると精度をさらに上げられます。",
        point: 2
      },
      "6m": {
        price: "402.1",
        delta: "現在より -16.1万円の予測",
        score: "49",
        insight: "6ヶ月後は相場下落が進む見込みです。売却を検討中なら、今の価格を押さえておく意味が大きい状態です。",
        point: 3
      }
    };

    forecastButtons.forEach((button) => {
      button.addEventListener("click", () => {
        forecastButtons.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");

        const data = forecastMap[button.dataset.forecast];
        forecastPrice.textContent = data.price;
        forecastDelta.textContent = data.delta;
        forecastInsight.textContent = data.insight;
        timingScore.textContent = data.score;

        forecastPoints.forEach((point, index) => {
          if (index === data.point) {
            point.setAttribute("r", "7");
            point.setAttribute("fill", "#f84ca2");
            point.setAttribute("stroke", "#ffffff");
            point.setAttribute("stroke-width", "3");
            point.setAttribute("opacity", "1");
          } else {
            point.setAttribute("r", "5");
            point.setAttribute("fill", "#1c2663");
            point.setAttribute("stroke", "none");
            point.setAttribute("opacity", "0.55");
          }
        });
      });
    });

    const expenseButtons = document.querySelectorAll("[data-expense]");
    const expenseTotal = document.getElementById("expenseTotal");
    const annualCost = document.getElementById("annualCost");
    const dropAmount = document.getElementById("dropAmount");
    const expenseForecast = document.getElementById("expenseForecast");
    const expenseDelta = document.getElementById("expenseDelta");
    const downCost = document.getElementById("downCost");
    const expenseNote = document.getElementById("expenseNote");

    const fuelBar = document.getElementById("fuelBar");
    const parkingBar = document.getElementById("parkingBar");
    const insuranceBar = document.getElementById("insuranceBar");
    const serviceBar = document.getElementById("serviceBar");

    const fuelValue = document.getElementById("fuelValue");
    const parkingValue = document.getElementById("parkingValue");
    const insuranceValue = document.getElementById("insuranceValue");
    const serviceValue = document.getElementById("serviceValue");

    const expenseMap = {
      monthly: {
        total: "2.84",
        annual: "34.1",
        drop: "12.8",
        forecast: "184.6",
        delta: "今より -12.8万円。売り時通知を設定できます",
        note: "半年維持すると、維持費16.9万円 + 査定下落12.8万円。売り時判断を数字で支援します。",
        down: "-12.8",
        bars: ["34%", "39%", "17%", "10%"],
        values: ["¥9,800", "¥11,000", "¥4,800", "¥2,800"]
      },
      yearly: {
        total: "34.1",
        annual: "34.1",
        drop: "25.6",
        forecast: "171.8",
        delta: "年間では -25.6万円。維持費と合わせて見直しやすい",
        note: "年間維持費34.1万円 + 査定下落25.6万円。保有コスト全体を把握して売却判断へつなげます。",
        down: "-25.6",
        bars: ["36%", "39%", "15%", "10%"],
        values: ["¥117,600", "¥132,000", "¥50,400", "¥34,000"]
      }
    };

    expenseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        expenseButtons.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");

        const data = expenseMap[button.dataset.expense];
        expenseTotal.textContent = data.total;
        annualCost.textContent = data.annual;
        dropAmount.textContent = data.drop;
        expenseForecast.textContent = data.forecast;
        expenseDelta.textContent = data.delta;
        expenseNote.textContent = data.note;
        downCost.textContent = data.down;

        fuelBar.style.width = data.bars[0];
        parkingBar.style.width = data.bars[1];
        insuranceBar.style.width = data.bars[2];
        serviceBar.style.width = data.bars[3];

        fuelValue.textContent = data.values[0];
        parkingValue.textContent = data.values[1];
        insuranceValue.textContent = data.values[2];
        serviceValue.textContent = data.values[3];
      });
    });

    const stageButtons = document.querySelectorAll("[data-stage]");
    const phoneCount = document.getElementById("phoneCount");
    const phoneLabel = document.getElementById("phoneLabel");
    const ucPhoneCell = document.getElementById("ucPhoneCell");
    const motaPhoneCell = document.getElementById("motaPhoneCell");
    const batchPhoneCell = document.getElementById("batchPhoneCell");
    const compareSub = document.getElementById("compareSub");
    const compareFootnote = document.getElementById("compareFootnote");
    const stressValue = document.getElementById("stressValue");
    const stressNote = document.getElementById("stressNote");

    const stageMap = {
      browse: {
        count: "0",
        label: "電話本数",
        uc: "0本",
        mota: "3社",
        batch: "最大10社",
        sub: "価格を見る段階では、営業電話なしでAI査定だけ完了",
        foot: "* 相場チェック段階の比較。売却相談に進んだ後も、UcarPACの電話対応は1社のみです。",
        stress: "0",
        stressNote: "今は情報収集だけでOK。売る時だけ次へ進めます"
      },
      sell: {
        count: "1",
        label: "電話本数",
        uc: "1社",
        mota: "3社",
        batch: "最大10社",
        sub: "売却相談に進んでも、UcarPACの連絡先は1社のみ",
        foot: "* 売却相談時の比較。UcarPACはオークション進行中もアプリで進捗確認できます。",
        stress: "1",
        stressNote: "本気で売る時だけ1社とやり取り。複数社対応は不要です"
      }
    };

    stageButtons.forEach((button) => {
      button.addEventListener("click", () => {
        stageButtons.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");

        const data = stageMap[button.dataset.stage];
        phoneCount.textContent = data.count;
        phoneLabel.textContent = data.label;
        ucPhoneCell.textContent = data.uc;
        motaPhoneCell.textContent = data.mota;
        batchPhoneCell.textContent = data.batch;
        compareSub.textContent = data.sub;
        compareFootnote.textContent = data.foot;
        stressValue.textContent = data.stress;
        stressNote.textContent = data.stressNote;
      });
    });

    setActiveScreen("screen-a");
    startAutoPlay();
  </script>
