  <script>
    const tabs = document.querySelectorAll('.tab');
    const shots = document.querySelectorAll('.shot');
    const stage = document.getElementById('stage');
    const noteEl = document.getElementById('rotatingNote');
    const toggleAllBtn = document.getElementById('toggleAll');
    const cycleNoteBtn = document.getElementById('cycleNote');

    const messages = [
      'まずは相場を見るだけ。個人情報なしで試せる安心感を先に伝える。',
      '今すぐ売らない人にも、DLする理由をつくるのが今回の軸。',
      '価格だけでなく「気持ちがラクか」を伝えると、ストアCVRは改善しやすい。'
    ];
    let messageIndex = 0;

    function activateShot(targetId) {
      tabs.forEach((tab) => {
        const active = tab.dataset.target === targetId;
        tab.classList.toggle('active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      shots.forEach((shot) => {
        shot.classList.toggle('active', shot.id === targetId);
      });

      stage.classList.remove('show-all');
      toggleAllBtn.textContent = '3案を並べて見る';
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateShot(tab.dataset.target));
    });

    toggleAllBtn.addEventListener('click', () => {
      const showAll = stage.classList.toggle('show-all');
      if (showAll) {
        shots.forEach((shot) => shot.classList.add('active'));
        tabs.forEach((tab) => {
          tab.classList.remove('active');
          tab.setAttribute('aria-selected', 'false');
        });
        toggleAllBtn.textContent = '1案ずつ見る';
      } else {
        activateShot('shot-a');
      }
    });

    cycleNoteBtn.addEventListener('click', () => {
      messageIndex = (messageIndex + 1) % messages.length;
      noteEl.textContent = messages[messageIndex];
    });

    const forecastStates = {
      now: {
        title: '売り時予測: 今なら 184.2万円',
        sub: '需要が高く、今月は査定が伸びやすい傾向',
        tag: '今月が売り時',
        vNow: '184.2万円',
        vCost: '3.7万円',
        vHint: '今月',
        points: '24,60 110,54 198,62 286,72',
        dots: [60, 54, 62, 72]
      },
      '3m': {
        title: '売り時予測: 3か月後は 179.6万円',
        sub: '夏前の相場を想定。価格はやや穏やかに推移',
        tag: '今〜3か月以内',
        vNow: '179.6万円',
        vCost: '3.9万円',
        vHint: '3か月以内',
        points: '24,64 110,68 198,72 286,80',
        dots: [64, 68, 72, 80]
      },
      '6m': {
        title: '売り時予測: 6か月後は 174.2万円',
        sub: '走行距離増加の影響で、価値はゆるやかに低下',
        tag: '早めがおすすめ',
        vNow: '174.2万円',
        vCost: '4.1万円',
        vHint: '早め',
        points: '24,70 110,76 198,85 286,94',
        dots: [70, 76, 85, 94]
      }
    };

    const periodChips = document.querySelectorAll('.period-chip');
    const forecastPath = document.getElementById('forecastPath');
    const forecastTitle = document.getElementById('forecastTitle');
    const forecastSub = document.getElementById('forecastSub');
    const forecastTag = document.getElementById('forecastTag');
    const vNow = document.getElementById('vNow');
    const vCost = document.getElementById('vCost');
    const vHint = document.getElementById('vHint');
    const dots = [
      document.getElementById('dot1'),
      document.getElementById('dot2'),
      document.getElementById('dot3'),
      document.getElementById('dot4')
    ];

    periodChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        periodChips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        const state = forecastStates[chip.dataset.mode];
        forecastPath.setAttribute('points', state.points);
        forecastTitle.textContent = state.title;
        forecastSub.textContent = state.sub;
        forecastTag.textContent = state.tag;
        vNow.textContent = state.vNow;
        vCost.textContent = state.vCost;
        vHint.textContent = state.vHint;
        dots.forEach((dot, index) => {
          dot.setAttribute('cy', state.dots[index]);
        });
      });
    });

    const comparePulse = document.getElementById('comparePulse');
    const stressCards = document.querySelectorAll('.stress-card');

    comparePulse.addEventListener('click', () => {
      stressCards.forEach((card, index) => {
        card.classList.remove('stress');
        window.setTimeout(() => {
          card.classList.add('stress');
        }, index * 140);
      });
    });
  </script>
</body>
