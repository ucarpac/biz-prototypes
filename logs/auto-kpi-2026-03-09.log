    <div class="controls">
      <button class="nav-button" id="prevButton" aria-label="前のスクリーン">‹</button>
      <div class="dots" id="dots">
        <button class="dot active" data-index="0" aria-label="スクリーンAへ"></button>
        <button class="dot" data-index="1" aria-label="スクリーンBへ"></button>
        <button class="dot" data-index="2" aria-label="スクリーンCへ"></button>
      </div>
      <button class="nav-button" id="nextButton" aria-label="次のスクリーン">›</button>
    </div>

    <section class="insight-panel">
      <div class="insight-title">このスクショの狙い</div>
      <div class="insight-copy" id="insightCopy">
        Aは「個人情報なしで価格が見える」安心感を最短で伝え、ストア離脱を防ぐ入口訴求です。
      </div>
    </section>

    <div class="swipe-hint">左右スワイプまたは下のボタンで切り替え。各スクショ内のボタンやスライダーも操作できます。</div>
  </main>

  <script>
    const track = document.getElementById("track");
    const dots = Array.from(document.querySelectorAll(".dot"));
    const missionSteps = Array.from(document.querySelectorAll(".mission-step"));
    const insightCopy = document.getElementById("insightCopy");
    const prevButton = document.getElementById("prevButton");
    const nextButton = document.getElementById("nextButton");
    const viewport = document.getElementById("viewport");

    const insights = [
      "Aは「個人情報なしで価格が見える」安心感を最短で伝え、ストア離脱を防ぐ入口訴求です。",
      "Bは「日常で使える」価値を強め、売る予定が遠いユーザーにもアプリ保持理由をつくります。",
      "Cは競合比較で不安を言語化し、「電話が面倒」という阻害要因に直接カウンターを当てます。"
    ];

    let currentIndex = 0;
    let touchStartX = 0;
    let touchEndX = 0;

    function updateCarousel(index) {
      currentIndex = Math.max(0, Math.min(2, index));
      track.style.transform = "translateX(-" + (currentIndex * 100) + "%)";
      dots.forEach((dot, idx) => dot.classList.toggle("active", idx === currentIndex));
      missionSteps.forEach((step, idx) => {
        step.classList.toggle("active", idx === currentIndex);
        step.classList.toggle("done", idx < currentIndex);
      });
      insightCopy.textContent = insights[currentIndex];
      prevButton.disabled = currentIndex === 0;
      nextButton.disabled = currentIndex === 2;
      prevButton.style.opacity = currentIndex === 0 ? "0.45" : "1";
      nextButton.style.opacity = currentIndex === 2 ? "0.45" : "1";
    }

    prevButton.addEventListener("click", () => updateCarousel(currentIndex - 1));
    nextButton.addEventListener("click", () => updateCarousel(currentIndex + 1));
    dots.forEach((dot) => {
      dot.addEventListener("click", () => updateCarousel(Number(dot.dataset.index)));
    });
    document.querySelectorAll(".next-slide").forEach((button) => {
      button.addEventListener("click", () => updateCarousel(Number(button.dataset.next)));
    });
    document.getElementById("restartButton").addEventListener("click", () => updateCarousel(0));

    viewport.addEventListener("touchstart", (event) => {
      touchStartX = event.changedTouches[0].screenX;
    }, { passive: true });

    viewport.addEventListener("touchend", (event) => {
      touchEndX = event.changedTouches[0].screenX;
      const delta = touchEndX - touchStartX;
      if (Math.abs(delta) < 48) return;
      if (delta < 0) updateCarousel(currentIndex + 1);
      if (delta > 0) updateCarousel(currentIndex - 1);
    }, { passive: true });

    function animateNumber(el, target, formatter) {
      const start = Number(el.dataset.current || 0);
      const duration = 420;
      const startTime = performance.now();

      function tick(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(start + (target - start) * eased);
        el.textContent = formatter(value);
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          el.dataset.current = String(target);
        }
      }

      requestAnimationFrame(tick);
    }

    const valuationState = {
      car: "ハリアー",
      year: "2021",
      mileage: "3万km"
    };

    const valuationTables = {
      car: {
        "ハリアー": 2960000,
        "CX-5": 2210000,
        "セレナ": 1980000
      },
      year: {
        "2023": 240000,
        "2021": 0,
        "2019": -280000
      },
      mileage: {
        "1万km": 180000,
        "3万km": 0,
        "6万km": -210000
      }
    };

    const valuationPriceEl = document.getElementById("valuationPrice");
    const future3mEl = document.getElementById("future3m");
    const future6mEl = document.getElementById("future6m");
    const valuationRangeEl = document.getElementById("valuationRange");
    const valuationAccuracyEl = document.getElementById("valuationAccuracy");
    const valuationProgressBar = document.getElementById("valuationProgressBar");
    const valuationProgressCount = document.getElementById("valuationProgressCount");
    const valuationHint = document.getElementById("valuationHint");

    function formatYen(value) {
      return new Intl.NumberFormat("ja-JP").format(value) + "円";
    }

    function formatMan(value) {
      return Math.round(value / 10000) + "万円";
    }

    function renderValuation() {
      const base = valuationTables.car[valuationState.car];
      const yearDiff = valuationTables.year[valuationState.year];
      const mileageDiff = valuationTables.mileage[valuationState.mileage];
      const total = base + yearDiff + mileageDiff;
      const future3 = total - 90000;
      const future6 = total - 210000;
      const rangeMin = total - 100000;
      const rangeMax = total + 110000;
      const accuracy = valuationState.mileage === "1万km" ? 90 : valuationState.mileage === "3万km" ? 87 : 82;
      const progress = valuationState.car && valuationState.year && valuationState.mileage ? 100 : 66;

      animateNumber(valuationPriceEl, total, formatYen);
      animateNumber(future3mEl, future3, formatMan);
      animateNumber(future6mEl, future6, formatMan);
      valuationRangeEl.textContent = "相場レンジ " + formatMan(rangeMin) + "〜" + formatMan(rangeMax);
      valuationAccuracyEl.textContent = "一致度 " + accuracy + "%";
      valuationProgressBar.style.width = progress + "%";
      valuationProgressCount.textContent = "3 / 3 入力済み";

      if (valuationState.car === "ハリアー") {
        valuationHint.textContent = "SUV需要が強く、今の相場は堅め。写真を追加すると装備差までAIが反映します。";
      } else if (valuationState.car === "CX-5") {
        valuationHint.textContent = "ディーゼル・4WDの条件で差が出やすい車種です。色と装備入力で精度アップ。";
      } else {
        valuationHint.textContent = "ファミリー需要は維持。年式と走行距離の組み合わせで価格差が出やすい傾向です。";
      }
    }

    document.querySelectorAll(".valuation-option").forEach((button) => {
      button.addEventListener("click", () => {
        const group = button.dataset.group;
        const value = button.dataset.value;
        valuationState[group] = value;
        document.querySelectorAll('.valuation-option[data-group="' + group + '"]').forEach((chip) => {
          chip.classList.toggle("active", chip === button);
        });
        renderValuation();
      });
    });

    const tabButtons = Array.from(document.querySelectorAll(".tab-button[data-tab]"));
    const panels = {
      expenses: document.getElementById("panel-expenses"),
      forecast: document.getElementById("panel-forecast")
    };

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const key = button.dataset.tab;
        tabButtons.forEach((btn) => btn.classList.toggle("active", btn === button));
        Object.entries(panels).forEach(([name, panel]) => {
          panel.classList.toggle("active", name === key);
        });
      });
    });

    const monthSlider = document.getElementById("monthSlider");
    const selectedMonthLabel = document.getElementById("selectedMonthLabel");
    const scoreRing = document.getElementById("scoreRing");
    const scoreNumber = document.getElementById("scoreNumber");
    const scoreCopy = document.getElementById("scoreCopy");
    const scoreNote = document.getElementById("scoreNote");
    const currentForecastValue = document.getElementById("currentForecastValue");
    const forecastCaption = document.getElementById("forecastCaption");
    const forecastPoint = document.getElementById("forecastPoint");

    const forecastData = [328, 325, 322, 319, 316, 311, 307];
    const scoreData = [64, 69, 74, 79, 82, 76, 70];
    const monthNotes = [
      "今すぐなら約328万円。最短で現金化できる一方、次の需要波は取り切れません。",
      "1か月後は約325万円。大きな下落前で、比較的バランスがよい水準です。",
      "2か月後は約322万円。維持費を考えると、早めの判断がまだ有利です。",
      "3か月後は約319万円。相場はまだ強く、需要期の余韻が残る見込みです。",
      "4か月後は約316万円。維持費 163,600円が積み上がる前で、売りどきスコアが最大です。",
      "5か月後は約311万円。価格下落ペースが見え始め、出費とのバランスが悪化します。",
      "6か月後は約307万円。次の車検や税金が近いなら、待ちすぎリスクが大きめです。"
    ];

    function updateForecastPoint(month) {
      const points = [
        [0, 56], [53, 62], [106, 70], [160, 80], [213, 91], [266, 102], [320, 110]
      ];
      const [x, y] = points[month];
      forecastPoint.setAttribute("cx", String(x));
      forecastPoint.setAttribute("cy", String(y));
    }

    function renderExpense() {
      const month = Number(monthSlider.value);
      const monthlyCost = 40900;
      const carriedCost = monthlyCost * month;
      const forecastValue = forecastData[month];
      const score = scoreData[month];
      const totalYen = forecastValue * 10000;
      const ringAngle = Math.round(score * 3.6);

      selectedMonthLabel.textContent = month === 0 ? "今すぐ" : month + "か月後";
      currentForecastValue.textContent = forecastValue + "万円";
      animateNumber(scoreNumber, score, (value) => String(value));

      scoreRing.style.setProperty("--score-angle", ringAngle + "deg");
      scoreCopy.textContent = month === 0 ? "今すぐ売却も可能" : month + "か月後が基準";
      scoreNote.textContent = "維持費 " + new Intl.NumberFormat("ja-JP").format(carriedCost) + "円が積み上がる想定。";
      forecastCaption.textContent = monthNotes[month];
      updateForecastPoint(month);

      if (score >= 80) {
        scoreCopy.textContent = month + "か月後が狙い目";
      } else if (score >= 72) {
        scoreCopy.textContent = "早めの判断が有利";
      } else {
        scoreCopy.textContent = "待ちすぎ注意";
      }

      document.getElementById("barGas").style.height = (72 + month * 1.5) + "%";
      document.getElementById("barParking").style.height = "85%";
      document.getElementById("barInsurance").style.height = (50 + month * 0.8) + "%";
      document.getElementById("barCare").style.height = (35 + month * 2.2) + "%";
    }

    monthSlider.addEventListener("input", renderExpense);

    const compareButtons = Array.from(document.querySelectorAll(".compare-mode"));
    const compareSubtitle = document.getElementById("compareSubtitle");
    const heroPhoneNumber = document.getElementById("heroPhoneNumber");
    const heroPhoneCopy = document.getElementById("heroPhoneCopy");

    const compareModes = {
      check: {
        subtitle: "UcarPACだけ、個人情報なしで先にAI査定。まず相場を見る段階なら、電話対応は発生しません。",
        heroNumber: 0,
        heroCopy: "相場チェック中の想定電話本数。相場だけ知りたい人の離脱要因を一気に減らせます。",
        ucarpacPhone: "0本",
        ikkatsuPhone: "5本前後",
        motaPhone: "3本",
        celcaPhone: "1本",
        tagUcarpac: "査定だけなら登録不要",
        tagIkkatsu: "最大10社比較",
        tagMota: "上位3社のみ",
        tagCelca: "1社のみ進行",
        noteUcarpac: "いきなり個人情報入力なし。まず相場確認から始められる。",
        noteIkkatsu: "複数社から連絡が来やすく、比較はできるが手間が大きい。",
        noteMota: "連絡先は絞られるが、結果待ちと個人情報入力が前提。",
        noteCelca: "やりとり先は少ないが、先に相場だけ見る体験は弱い。"
      },
      sell: {
        subtitle: "本気で売る段階でも、UcarPACは電話1社のみ。比較しやすさと負荷の低さを両立できます。",
        heroNumber: 1,
        heroCopy: "売却相談に進んだ後の想定電話本数。検討フェーズから申込フェーズへ移っても負荷が低い設計です。",
        ucarpacPhone: "1本",
        ikkatsuPhone: "5本前後",
        motaPhone: "3本",
        celcaPhone: "1本",
        tagUcarpac: "売却相談は1社のみ",
        tagIkkatsu: "一括で連絡",
        tagMota: "上位3社のみ",
        tagCelca: "1社のみ進行",
        noteUcarpac: "オークション出品後のやりとりは1社のみ。価格の見極めもAIで先回り。",
        noteIkkatsu: "複数連絡が続きやすく、日程調整や比較の手間が残る。",
        noteMota: "相手は絞られるが、連絡は3社まで発生する。",
        noteCelca: "やりとりは1社だが、AI査定や将来予測での事前判断はできない。"
      }
    };

    function applyCompareMode(mode) {
      const config = compareModes[mode];
      compareSubtitle.textContent = config.subtitle;
      animateNumber(heroPhoneNumber, config.heroNumber, (value) => String(value));
      heroPhoneCopy.textContent = config.heroCopy;
      document.getElementById("metricUcarpacPhone").textContent = config.ucarpacPhone;
      document.getElementById("metricIkkatsuPhone").textContent = config.ikkatsuPhone;
      document.getElementById("metricMotaPhone").textContent = config.motaPhone;
      document.getElementById("metricCelcaPhone").textContent = config.celcaPhone;
      document.getElementById("tagUcarpac").textContent = config.tagUcarpac;
      document.getElementById("tagIkkatsu").textContent = config.tagIkkatsu;
      document.getElementById("tagMota").textContent = config.tagMota;
      document.getElementById("tagCelca").textContent = config.tagCelca;
      document.getElementById("noteUcarpac").textContent = config.noteUcarpac;
      document.getElementById("noteIkkatsu").textContent = config.noteIkkatsu;
      document.getElementById("noteMota").textContent = config.noteMota;
      document.getElementById("noteCelca").textContent = config.noteCelca;
    }

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.dataset.mode;
        compareButtons.forEach((btn) => btn.classList.toggle("active", btn === button));
        applyCompareMode(mode);
      });
    });

    renderValuation();
    renderExpense();
    applyCompareMode("check");
    updateCarousel(0);
  </script>
</body>
</html>
