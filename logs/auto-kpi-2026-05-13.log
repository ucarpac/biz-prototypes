  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App オンボーディング改善プロトタイプ',
      description: '新規DLから売却申込率改善の検証用プロトタイプ',
      storageHours: 24
    };

    const state = {
      index: 0,
      car: 'トヨタ アルファード',
      basePrice: 328,
      year: '2020年式',
      factor: 1,
      taps: 0,
      missions: [true, false, false]
    };

    const track = document.getElementById('track');
    const progressFill = document.getElementById('progressFill');
    const tabs = Array.from(document.querySelectorAll('.tab'));
    const dots = Array.from(document.querySelectorAll('.dot'));
    const viewport = document.getElementById('viewport');
    const toast = document.getElementById('toast');
    const mainAction = document.getElementById('mainAction');

    function setIndex(nextIndex) {
      state.index = Math.max(0, Math.min(2, nextIndex));
      track.style.transform = `translateX(-${state.index * 33.3333}%)`;
      progressFill.style.width = `${(state.index + 1) * 33.3333}%`;

      tabs.forEach((tab, index) => {
        tab.classList.toggle('active', index === state.index);
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === state.index);
      });

      const labels = [
        'この案でAI査定導線を見る',
        'この案で申込導線を見る',
        'この案で登録導線を見る'
      ];
      mainAction.textContent = labels[state.index];
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function updateQuickResult() {
      const price = Math.round(state.basePrice * state.factor);
      document.getElementById('resultCar').textContent = state.car;
      document.getElementById('resultMeta').textContent = `${state.year} / 走行距離 38,000km想定`;
      document.getElementById('resultPrice').textContent = price;
      document.getElementById('tapCount').textContent = `${state.taps}タップ`;
      document.getElementById('quickStep').textContent = state.taps >= 2 ? 'AI査定表示' : `STEP ${Math.min(state.taps + 1, 2)} / 2`;
      document.getElementById('resultNote').textContent = `${state.car}は直近相場で${price - 18}〜${price + 24}万円レンジ。写真追加で精度を上げられます。`;

      const result = document.getElementById('quickResult');
      result.classList.remove('show');
      window.setTimeout(() => result.classList.add('show'), 40);
    }

    document.getElementById('carChoices').addEventListener('click', (event) => {
      const button = event.target.closest('.choice-chip');
      if (!button) return;

      document.querySelectorAll('#carChoices .choice-chip').forEach((item) => item.classList.remove('selected'));
      button.classList.add('selected');

      state.car = button.dataset.car;
      state.basePrice = Number(button.dataset.price);
      state.taps += 1;
      updateQuickResult();
      showToast('車種を選択しました');
    });

    document.getElementById('yearChoices').addEventListener('click', (event) => {
      const button = event.target.closest('.choice-chip');
      if (!button) return;

      document.querySelectorAll('#yearChoices .choice-chip').forEach((item) => item.classList.remove('selected'));
      button.classList.add('selected');

      state.year = button.dataset.year;
      state.factor = Number(button.dataset.factor);
      state.taps += 1;
      updateQuickResult();
      showToast('年式を反映しました');
    });

    document.getElementById('quickAssess').addEventListener('click', () => {
      state.taps = Math.max(state.taps, 2);
      updateQuickResult();
      showToast('AI査定結果を表示しました');
    });

    document.getElementById('introStart').addEventListener('click', () => {
      showToast('個人情報なしで相場チェックを開始');
    });

    document.getElementById('futureRange').addEventListener('input', (event) => {
      const month = Number(event.target.value);
      const current = 328;
      const price = Math.round(current - month * 5.4);
      document.getElementById('futurePrice').textContent = `${price}万円`;

      const note = month === 0
        ? '今月の推定価格。売却相談へ進むと電話窓口は1社のみです。'
        : `${month}ヶ月後の予測価格。価格変動を見ながら売り時を判断できます。`;
      document.getElementById('futureNote').textContent = note;
    });

    document.querySelector('.game-missions').addEventListener('click', (event) => {
      const mission = event.target.closest('.mission');
      if (!mission) return;

      const index = Number(mission.dataset.mission);
      state.missions[index] = true;
      mission.classList.add('done');
      mission.querySelector('.check').textContent = '✓';

      const doneCount = state.missions.filter(Boolean).length;
      if (doneCount === 3) {
        showToast('3つの体験が完了。自分の車の登録へ進めます');
      } else {
        showToast(`体験ミッション ${doneCount}/3 完了`);
      }
    });

    document.getElementById('registerOwn').addEventListener('click', () => {
      showToast('車両登録フォームへ進む想定です');
    });

    document.getElementById('prevBtn').addEventListener('click', () => {
      setIndex(state.index - 1);
    });

    document.getElementById('nextBtn').addEventListener('click', () => {
      setIndex(state.index + 1);
    });

    mainAction.addEventListener('click', () => {
      const messages = [
        'AI査定から売却相談へのCTAを表示',
        '今の価値確認から車両登録へ遷移',
        'サンプル体験完了後に自分の車を登録'
      ];
      showToast(messages[state.index]);
    });

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        setIndex(Number(tab.dataset.index));
      });
    });

    let startX = 0;
    let currentX = 0;
    let touching = false;

    viewport.addEventListener('touchstart', (event) => {
      startX = event.touches[0].clientX;
      currentX = startX;
      touching = true;
    }, { passive: true });

    viewport.addEventListener('touchmove', (event) => {
      if (!touching) return;
      currentX = event.touches[0].clientX;
    }, { passive: true });

    viewport.addEventListener('touchend', () => {
      if (!touching) return;
      const diff = currentX - startX;
      if (Math.abs(diff) > 48) {
        setIndex(state.index + (diff < 0 ? 1 : -1));
      }
      touching = false;
    });

    setIndex(0);
    updateQuickResult();
  </script>
</body>
