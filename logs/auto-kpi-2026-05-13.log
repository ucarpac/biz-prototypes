  <script>
    const tabs = document.querySelectorAll(".tab-button");
    const panels = document.querySelectorAll(".screen-panel");
    const toast = document.getElementById("toast");

    const carData = {
      prius: {
        price: "162万円",
        range: "相場レンジ 145万〜178万円"
      },
      nbox: {
        price: "112万円",
        range: "相場レンジ 96万〜126万円"
      },
      harrier: {
        price: "286万円",
        range: "相場レンジ 258万〜312万円"
      }
    };

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("is-visible");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove("is-visible");
      }, 1800);
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const targetId = tab.dataset.screen;

        tabs.forEach((item) => {
          item.setAttribute("aria-selected", String(item === tab));
        });

        panels.forEach((panel) => {
          panel.classList.toggle("is-active", panel.id === targetId);
        });

        const label = tab.textContent.trim();
        showToast(label + "に切り替えました");
      });
    });

    document.querySelectorAll("[data-scroll-target]").forEach((button) => {
      button.addEventListener("click", () => {
        const target = document.getElementById(button.dataset.scrollTarget);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    document.querySelectorAll("[data-select-car]").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll("[data-select-car]").forEach((item) => {
          item.classList.remove("is-selected");
          item.querySelector("span:last-child").textContent = "変更";
        });

        button.classList.add("is-selected");
        button.querySelector("span:last-child").textContent = "選択中";

        const data = carData[button.dataset.selectCar];
        document.getElementById("quickPrice").textContent = data.price;
        document.getElementById("quickRange").textContent = data.range;
        showToast(button.querySelector("span:first-child").textContent + "の概算を更新しました");
      });
    });

    document.querySelectorAll("[data-simulate]").forEach((button) => {
      button.addEventListener("click", () => {
        const type = button.dataset.simulate;
        if (type === "a") {
          showToast("2タップでAI概算価格に到達しました");
        }
        if (type === "b") {
          showToast("価格変動グラフから査定開始へ進みます");
        }
        if (type === "c") {
          showToast("サンプル体験から自分の車の登録へ進みます");
        }

        button.animate(
          [
            { transform: "scale(1)" },
            { transform: "scale(0.97)" },
            { transform: "scale(1)" }
          ],
          {
            duration: 260,
            easing: "ease-out"
          }
        );
      });
    });
  </script>
