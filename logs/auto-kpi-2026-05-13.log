      --back-light-blue: #6fc2ff;
      --error: #EB4646;
      --shadow: rgba(0,0,0,0.11);
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --font-sans: 'Noto Sans JP', 'Hiragino Sans', system-ui, sans-serif;
      --font-number: 'Righteous', 'Noto Sans JP', sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html {
      min-height: 100%;
      background: var(--back-gray);
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--font-sans);
      color: var(--text-black);
      background:
        radial-gradient(circle at 18% 0%, rgba(248, 76, 162, 0.16), transparent 28%),
        radial-gradient(circle at 82% 8%, rgba(29, 220, 255, 0.22), transparent 26%),
        var(--back-gray);
      line-height: 1.5;
      letter-spacing: 0;
    }

    button,
    input,
    select {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
    }

    .page {
      width: 100%;
      min-height: 100vh;
      padding: 16px 12px 28px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .phone {
      width: 100%;
      max-width: 390px;
      min-height: 760px;
      background: var(--back-white);
      border-radius: 28px;
      box-shadow: 0 20px 70px rgba(28, 38, 99, 0.22);
      overflow: hidden;
      position: relative;
      border: 1px solid rgba(255,255,255,0.9);
    }

    .status {
      height: 36px;
      padding: 8px 20px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
    }

    .status-icons {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .signal,
    .wifi,
    .battery {
      display: block;
      height: 8px;
      border-radius: 8px;
      background: var(--dark-blue);
    }

    .signal {
      width: 18px;
    }

    .wifi {
      width: 14px;
      opacity: 0.8;
    }

    .battery {
      width: 22px;
      height: 10px;
      border: 1px solid var(--dark-blue);
      background: transparent;
      position: relative;
    }

    .battery::before {
      content: "";
      position: absolute;
      left: 2px;
      top: 2px;
      width: 14px;
      height: 4px;
      background: var(--dark-blue);
      border-radius: 4px;
    }

    .app-header {
      padding: 8px 20px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark-blue);
      font-weight: 800;
      font-size: 18px;
      line-height: 27px;
    }

    .brand-mark {
      width: 31px;
      height: 31px;
      border-radius: 10px;
      background: var(--gradient-pink);
      color: var(--white);
      display: grid;
      place-items: center;
      font-weight: 900;
      box-shadow: 0 8px 22px rgba(248, 76, 162, 0.28);
    }

    .metric-pill {
      min-height: 32px;
      padding: 6px 10px;
      border-radius: 22px;
      background: var(--white);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
      box-shadow: 0 0 0 1px var(--ruled-line), 0 4px 14px var(--shadow);
    }

    .tabs {
      margin: 0 20px 12px;
      padding: 4px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 4px;
      background: var(--back-gray);
      border-radius: 24px;
    }

    .tab {
      min-height: 38px;
      border-radius: 22px;
      background: transparent;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 800;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(28, 38, 99, 0.24);
    }

    .progress-wrap {
      padding: 0 20px 12px;
    }

    .progress-line {
      height: 8px;
      border-radius: 10px;
      background: #e6e6e6;
      overflow: hidden;
    }

    .progress-fill {
      width: 33.33%;
      height: 100%;
      background: var(--gradient-primary);
      border-radius: 10px;
      transition: width 260ms ease;
    }

    .screen-viewport {
      overflow: hidden;
      width: 100%;
      position: relative;
      touch-action: pan-y;
    }

    .screen-track {
      display: flex;
      width: 300%;
      transition: transform 320ms cubic-bezier(.2,.8,.2,1);
    }

    .screen {
      width: 33.333%;
      padding: 0 20px 96px;
      min-height: 610px;
    }

    .hero {
      margin-top: 2px;
      padding: 18px 0 16px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 29px;
      padding: 5px 12px;
      border-radius: 22px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 12px;
      font-weight: 800;
    }

    .eyebrow.blue {
      background: rgba(29, 220, 255, 0.18);
      color: var(--text-under-blue);
    }

    .hero-title {
      margin: 12px 0 8px;
      color: var(--dark-blue);
      font-size: 28px;
      line-height: 42px;
      font-weight: 900;
      letter-spacing: 0;
    }

    .hero-copy {
      margin: 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 21px;
      font-weight: 500;
    }

    .quick-card,
    .result-card,
    .sample-card,
    .expense-card,
    .auction-card {
      width: 100%;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 0 0 1px rgba(205, 220, 237, 0.84), 0 8px 28px var(--shadow);
    }

    .quick-card {
      padding: 18px 16px 16px;
      position: relative;
      overflow: hidden;
    }

    .quick-card::after {
      content: "";
      position: absolute;
      right: -30px;
      top: -42px;
      width: 118px;
      height: 118px;
      border-radius: 999px;
      background: rgba(29, 220, 255, 0.16);
    }

    .step-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 14px;
      position: relative;
      z-index: 1;
    }

    .step-chip {
      min-height: 28px;
      padding: 5px 10px;
      border-radius: 18px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 11px;
      font-weight: 800;
    }

    .tap-count {
      color: var(--pink);
      font-size: 12px;
      font-weight: 900;
    }

    .selector-label {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
    }

    .chip-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      margin-bottom: 16px;
    }

    .choice-chip {
      min-height: 43px;
      padding: 8px 10px;
      border-radius: 22px;
      background: var(--white);
      border: 1px solid var(--ruled-line);
      color: var(--text-black);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 800;
      transition: transform 160ms ease, background 160ms ease, color 160ms ease, box-shadow 160ms ease;
    }

    .choice-chip.selected {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.22);
      transform: translateY(-1px);
    }

    .primary-button,
    .pink-button,
    .white-button {
      min-height: 43px;
      border-radius: 30px;
      padding: 10px 20px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
      transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
    }

    .primary-button {
      width: 100%;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 9px 22px rgba(77, 180, 255, 0.28);
    }

    .pink-button {
      width: 100%;
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 9px 22px rgba(248, 76, 162, 0.25);
    }

    .white-button {
      width: 100%;
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.18);
    }

    .primary-button:active,
    .pink-button:active,
    .white-button:active,
    .choice-chip:active {
      transform: scale(0.98);
    }

    .result-card {
      margin-top: 14px;
      padding: 18px 16px 16px;
      opacity: 0;
      transform: translateY(12px) scale(0.98);
      transition: opacity 260ms ease, transform 260ms ease;
    }

    .result-card.show {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    .result-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .car-name {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 900;
    }

    .car-meta {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 600;
    }

    .badge {
      flex: 0 0 auto;
      min-height: 26px;
      padding: 4px 9px;
      border-radius: 18px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 900;
    }

    .price-label {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .price {
      display: flex;
      align-items: baseline;
      gap: 4px;
      margin: 2px 0 8px;
      color: var(--pink);
    }

    .price-number {
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 54px;
      font-weight: 900;
    }

    .price-unit {
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
    }

    .micro-note {
      min-height: 34px;
      padding: 8px 10px;
      border-radius: 10px;
      background: rgba(29, 220, 255, 0.12);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
    }

    .intro-card {
      border-radius: 16px;
      padding: 20px 16px;
      background: linear-gradient(180deg, var(--back-blue), var(--back-dark-blue));
      color: var(--white);
      box-shadow: 0 12px 30px rgba(9, 19, 85, 0.28);
      overflow: hidden;
      position: relative;
    }

    .intro-card::before {
      content: "";
      position: absolute;
      right: -42px;
      top: 32px;
      width: 142px;
      height: 142px;
      border-radius: 999px;
      border: 18px solid rgba(255,255,255,0.08);
    }

    .question-mark {
      width: 68px;
      height: 68px;
      border-radius: 24px;
      display: grid;
      place-items: center;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 38px;
      line-height: 57px;
      font-weight: 900;
      box-shadow: 0 12px 26px rgba(29, 220, 255, 0.24);
      animation: float 2.4s ease-in-out infinite;
    }

    .intro-title {
      margin: 18px 0 8px;
      font-size: 26px;
      line-height: 39px;
      font-weight: 900;
      position: relative;
      z-index: 1;
    }

    .intro-copy {
      margin: 0 0 16px;
      color: var(--text-light-blue, #bfdbfe);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      position: relative;
      z-index: 1;
    }

    .benefit-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 18px 0;
      position: relative;
      z-index: 1;
    }

    .benefit {
      min-height: 78px;
      padding: 10px 6px;
      border-radius: 12px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.12);
      text-align: center;
    }

    .benefit-num {
      display: block;
      color: var(--white);
      font-family: var(--font-number);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
    }

    .benefit-text {
      display: block;
      color: #bfdbfe;
      font-size: 10px;
      line-height: 15px;
      font-weight: 800;
    }

    .slider-card {
      margin-top: 14px;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 0 0 1px rgba(205, 220, 237, 0.84), 0 8px 28px var(--shadow);
    }

    .slider-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 900;
    }

    .range-price {
      color: var(--pink);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
    }

    .range {
      width: 100%;
      accent-color: var(--pink);
    }

    .range-labels {
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      margin-top: 4px;
    }

    .sample-card {
      padding: 16px;
    }

    .sample-head {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 14px;
    }

    .car-visual {
      width: 88px;
      height: 58px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.32), transparent 54%),
        linear-gradient(135deg, #1ddcff, #4db4ff);
      position: relative;
      flex: 0 0 auto;
      box-shadow: inset 0 -12px 0 rgba(28,38,99,0.12);
    }

    .car-visual::before {
      content: "";
      position: absolute;
      left: 12px;
      right: 10px;
      top: 16px;
      height: 21px;
      border-radius: 18px 18px 8px 8px;
      background: var(--dark-blue);
      opacity: 0.92;
    }

    .car-visual::after {
      content: "";
      position: absolute;
      left: 16px;
      bottom: 6px;
      width: 56px;
      height: 12px;
      border-radius: 10px;
      background:
        radial-gradient(circle at 8px 6px, #091355 0 5px, transparent 5px),
        radial-gradient(circle at 48px 6px, #091355 0 5px, transparent 5px),
        var(--white);
    }

    .sample-name {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 900;
    }

    .sample-meta {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 600;
    }

    .game-missions {
      display: grid;
      gap: 8px;
      margin: 14px 0;
    }

    .mission {
      min-height: 52px;
      padding: 10px 12px;
      border-radius: 12px;
      background: var(--back-gray);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      transition: background 180ms ease, transform 180ms ease;
    }

    .mission.done {
      background: rgba(248, 76, 162, 0.12);
      transform: translateX(2px);
    }

    .mission-text {
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 900;
    }

    .mission-sub {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .check {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: var(--white);
      color: var(--text-disabled);
      font-size: 15px;
      font-weight: 900;
      box-shadow: 0 0 0 1px var(--ruled-line);
    }

    .mission.done .check {
      background: var(--pink);
      color: var(--white);
      box-shadow: 0 7px 18px rgba(248, 76, 162, 0.24);
    }

    .graph {
      height: 122px;
      margin-top: 14px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(29,220,255,0.12), transparent),
        var(--white);
      border: 1px solid var(--ruled-line);
      padding: 12px;
      position: relative;
      overflow: hidden;
    }

    .graph-grid {
      position: absolute;
      inset: 12px;
      background:
        linear-gradient(to bottom, transparent 24%, rgba(28,38,99,0.08) 25%, transparent 26%),
        linear-gradient(to bottom, transparent 49%, rgba(28,38,99,0.08) 50%, transparent 51%),
        linear-gradient(to bottom, transparent 74%, rgba(28,38,99,0.08) 75%, transparent 76%);
    }

    .graph-line {
      position: absolute;
      left: 18px;
      right: 18px;
      top: 26px;
      height: 70px;
    }

    .graph-line svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .graph-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--pink);
      position: absolute;
      box-shadow: 0 0 0 5px rgba(248,76,162,0.14);
      animation: pulse 1.8s ease-in-out infinite;
    }

    .dot-a { left: 17%; top: 51px; }
    .dot-b { left: 48%; top: 42px; animation-delay: .3s; }
    .dot-c { left: 79%; top: 31px; animation-delay: .6s; }

    .graph-labels {
      position: absolute;
      left: 14px;
      right: 14px;
      bottom: 8px;
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 800;
    }

    .bottom-nav {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 12px 20px 18px;
      background: linear-gradient(180deg, rgba(250,250,250,0), var(--back-white) 24%);
    }

    .nav-actions {
      display: grid;
      grid-template-columns: 43px 1fr 43px;
      gap: 10px;
      align-items: center;
    }

    .icon-button {
      width: 43px;
      height: 43px;
      border-radius: 999px;
      background: var(--white);
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 900;
      box-shadow: 0 0 0 1px var(--ruled-line), 0 6px 18px var(--shadow);
    }

    .dots {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      margin-top: 10px;
    }

    .dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--text-disabled);
      transition: width 180ms ease, background 180ms ease;
    }

    .dot.active {
      width: 24px;
      background: var(--pink);
    }

    .toast {
      position: absolute;
      left: 20px;
      right: 20px;
      bottom: 86px;
      min-height: 42px;
      padding: 10px 14px;
      border-radius: 22px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
      box-shadow: 0 10px 28px rgba(28,38,99,0.28);
      transform: translateY(18px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease, transform 220ms ease;
      text-align: center;
      z-index: 4;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    .source-note {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 12px;
      background: var(--back-gray);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 600;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(-3deg); }
      50% { transform: translateY(-8px) rotate(3deg); }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.26); opacity: .82; }
    }

    @media (min-width: 720px) {
      .page {
        padding: 32px;
        align-items: center;
      }

      .phone {
        max-width: 420px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="phone" aria-label="UcarPACアプリ オンボーディングプロトタイプ">
      <div class="status">
        <span>9:41</span>
        <div class="status-icons" aria-hidden="true">
          <span class="signal"></span>
          <span class="wifi"></span>
          <span class="battery"></span>
        </div>
      </div>

      <header class="app-header">
        <div class="brand">
          <span class="brand-mark">U</span>
          <span>UcarPAC</span>
        </div>
        <div class="metric-pill">新規DL→申込率 2.29%</div>
      </header>

      <nav class="tabs" aria-label="オンボーディング案">
        <button class="tab active" data-index="0">オンボA</button>
        <button class="tab" data-index="1">オンボB</button>
        <button class="tab" data-index="2">オンボC</button>
      </nav>

      <div class="progress-wrap">
        <div class="progress-line" aria-hidden="true">
          <div class="progress-fill" id="progressFill"></div>
        </div>
      </div>

      <div class="screen-viewport" id="viewport">
