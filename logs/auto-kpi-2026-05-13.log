      <nav class="tabs" aria-label="オンボーディング案">
        <button class="tab active" type="button" data-screen="screen-a">オンボA</button>
        <button class="tab" type="button" data-screen="screen-b">オンボB</button>
        <button class="tab" type="button" data-screen="screen-c">オンボC</button>
      </nav>

      <section class="screen active" id="screen-a">
        <div class="hero">
          <div class="hero-kicker">最短2タップでAI査定体験</div>
          <h1 class="hero-title">まずは、あなたの車の目安だけ。</h1>
          <p class="hero-copy">車種と年式を選ぶだけで、売るか迷っている今の不安を少し軽くします。</p>
          <div class="hand-note">名前も電話番号も、まだ不要です</div>
          <div class="mini-illust" aria-hidden="true">
            <div class="heart">♥</div>
            <div class="car-roof"></div>
            <div class="car-body"></div>
            <div class="wheel left"></div>
            <div class="wheel right"></div>
          </div>
        </div>

        <div class="card">
          <h2 class="section-title">1. 車種を選択</h2>
          <p class="section-copy">よく見られている車種を先に表示します。</p>
          <div class="chip-grid" data-group="car">
            <button class="choice-chip selected" type="button" data-value="トヨタ プリウス" data-price="138">トヨタ プリウス</button>
            <button class="choice-chip" type="button" data-value="ホンダ N-BOX" data-price="96">ホンダ N-BOX</button>
            <button class="choice-chip" type="button" data-value="日産 セレナ" data-price="172">日産 セレナ</button>
            <button class="choice-chip" type="button" data-value="スバル フォレスター" data-price="214">スバル フォレスター</button>
          </div>
        </div>

        <div class="card">
          <h2 class="section-title">2. 年式を選択</h2>
          <p class="section-copy">迷ったら車検証に書かれている初度登録年でOKです。</p>
          <div class="chip-grid" data-group="year">
            <button class="choice-chip warm" type="button" data-year="2018" data-adjust="-18">2018年</button>
            <button class="choice-chip warm selected" type="button" data-year="2020" data-adjust="0">2020年</button>
            <button class="choice-chip warm" type="button" data-year="2022" data-adjust="27">2022年</button>
            <button class="choice-chip warm" type="button" data-year="2024" data-adjust="54">2024年</button>
          </div>
        </div>

        <div class="estimate-card">
          <div class="estimate-label">概算AI査定額</div>
          <p class="price"><span id="priceA">138</span><span>万円</span></p>
          <p class="range" id="rangeA">想定レンジ 124〜152万円</p>
          <button class="pink-button" type="button" data-toast="AI査定の追加入力へ進む導線です。写真・カラー・装備で精度を上げます。">このままAI査定へ</button>
        </div>

        <div class="trust-row">
          <div class="trust-badge pink">個人情報不要</div>
          <div class="trust-badge">営業電話なし</div>
          <div class="trust-badge">将来予測つき</div>
        </div>

        <div class="source-box">
          主張メモ: 「個人情報不要」「AI査定」「将来予測」はUcarPAC App要件定義（2026-05-13）に基づく。競合比較は提供資料 competitors.md（2026-05-13）を参照。
        </div>
      </section>

      <section class="screen" id="screen-b">
        <div class="question-card">
          <h1 class="question-title">あなたの車、今いくら？</h1>
          <p class="question-copy">売ると決めていなくても大丈夫。相場を知っておくことが、あとで後悔しない準備になります。</p>
        </div>

        <div class="hero">
          <div class="hero-kicker">不安を先にほどく導入</div>
          <h2 class="hero-title">電話が増える心配なく、まず相場だけ。</h2>
          <p class="hero-copy">UcarPACは、査定前の確認体験をアプリ内で完結。申し込み前に価格の目安を見られます。</p>
          <div class="hand-note">「今じゃないかも」でも使えます</div>
        </div>

        <div class="prediction">
          <h2 class="section-title">将来予測で売り時を相談</h2>
          <p class="section-copy">現在価格だけでなく、3ヶ月後・6ヶ月後の見通しも一緒に表示します。</p>
          <div class="chart" aria-label="査定価格の将来予測グラフ">
            <svg class="chart-line" viewBox="0 0 250 64" aria-hidden="true">
              <path d="M2 15 C42 8 62 6 78 8 C116 12 122 38 154 34 C198 29 206 50 248 55" fill="none" stroke="#F84CA2" stroke-width="4" stroke-linecap="round"/>
              <path d="M2 15 C42 8 62 6 78 8 C116 12 122 38 154 34 C198 29 206 50 248 55" fill="none" stroke="rgba(248,76,162,0.18)" stroke-width="12" stroke-linecap="round"/>
            </svg>
            <span class="chart-point p1"></span>
            <span class="chart-point p2"></span>
            <span class="chart-point p3"></span>
            <span class="chart-point p4"></span>
          </div>
          <div class="chart-labels">
            <span>今日<br>168万</span>
            <span>1ヶ月<br>171万</span>
            <span>3ヶ月<br>158万</span>
            <span>6ヶ月<br>146万</span>
          </div>
          <p class="insight">次の車検前に相場が下がりやすい見込みです。早めの相談で選択肢を残せます。</p>
        </div>

        <div class="card">
          <h2 class="section-title">申し込み前の安心材料</h2>
          <div class="flow-list">
            <div class="flow-item">
              <div class="flow-number">1</div>
              <p class="flow-text">相場だけ見られる<span class="flow-sub">個人情報入力はまだ不要</span></p>
            </div>
            <div class="flow-item">
              <div class="flow-number">2</div>
              <p class="flow-text">電話対応は1社のみ<span class="flow-sub">複数社からの電話ラッシュを避ける訴求</span></p>
            </div>
            <div class="flow-item">
              <div class="flow-number">3</div>
              <p class="flow-text">8,000店が競る<span class="flow-sub">オークション形式で最高額を狙う</span></p>
            </div>
          </div>
          <button class="primary-button" type="button" data-toast="導入画面から車種選択へ遷移する想定です。">相場チェックを始める</button>
        </div>

        <div class="source-box">
          出典ラベル: 入札業者数・電話1社・個人情報不要訴求はUcarPAC App提供資料（2026-05-13）。競合の電話社数比較は competitors.md（2026-05-13）。
        </div>
      </section>

      <section class="screen" id="screen-c">
        <div class="hero">
          <div class="hero-kicker">登録前にサンプルで体験</div>
          <h1 class="hero-title">入力する前に、使い心地を見てください。</h1>
          <p class="hero-copy">自分の車を登録する前に、サンプル車両でAI査定・出費管理・オークション進捗を確認できます。</p>
          <div class="hand-note">触ってから決められる安心感</div>
        </div>

        <div class="card">
          <div class="sample-car">
            <div class="sample-image" aria-hidden="true">
              <div class="car-roof"></div>
              <div class="car-body"></div>
              <div class="wheel left"></div>
              <div class="wheel right"></div>
            </div>
            <div>
              <h2 class="sample-title">サンプル: トヨタ ハリアー</h2>
              <p class="sample-meta">2021年式 / 走行 32,000km / パールホワイト</p>
            </div>
          </div>
        </div>

        <div class="demo-grid">
          <button class="demo-tile active" type="button" data-demo="auction">
            <div class="tile-icon">競</div>
            <p class="tile-title">オークション進捗</p>
            <p class="tile-copy">入札状況と最高額をアプリで確認</p>
          </button>
          <button class="demo-tile" type="button" data-demo="cost">
            <div class="tile-icon">費</div>
            <p class="tile-title">出費管理</p>
            <p class="tile-copy">ガソリン・保険・車検を見える化</p>
          </button>
          <button class="demo-tile" type="button" data-demo="ai">
            <div class="tile-icon">AI</div>
            <p class="tile-title">AI査定</p>
            <p class="tile-copy">現在価格と将来予測をチェック</p>
          </button>
          <button class="demo-tile" type="button" data-demo="sell">
            <div class="tile-icon">申</div>
            <p class="tile-title">売却相談</p>
            <p class="tile-copy">タイミングが来たら申し込みへ</p>
          </button>
        </div>

        <div class="preview-panel">
          <div class="preview-top">
            <h2 class="preview-title" id="previewTitle">オークション進捗</h2>
            <p class="preview-copy" id="previewCopy">8,000店の入札ネットワークで、最高額の更新を確認できます。</p>
          </div>
          <div class="preview-body" id="previewBody">
            <div class="bid-row">
              <span>現在の最高額</span>
              <span class="bid-price">286万円</span>
            </div>
            <div class="bid-row">
              <span>入札参加</span>
              <span>42店</span>
            </div>
            <div class="bid-row">
              <span>終了まで</span>
              <span>あと18時間</span>
            </div>
            <div class="progress-track">
              <div class="progress-fill"></div>
            </div>
          </div>
        </div>

        <div class="card">
          <h2 class="section-title">登録前体験の狙い</h2>
          <p class="section-copy">新規DL後の不安を下げ、車両登録から売却申込までの心理的な距離を短くします。</p>
          <button class="pink-button" type="button" data-toast="サンプル体験後に実車登録へ進む導線です。">自分の車で試す</button>
          <button class="ghost-button" type="button" data-toast="サンプル車両を続けて触れる導線です。">もう少し見てみる</button>
        </div>

        <div class="source-box">
          KPIメモ: 新規DL→申込率の現状2.29%、KPI 1.90%達成済みという条件は依頼文（2026-05-13）に基づく。改善仮説は車両登録前の体験提供による離脱低減。
        </div>
      </section>

      <div class="bottom-bar">
        <button class="ghost-button compact" type="button" id="prevBtn">戻る</button>
        <button class="primary-button compact" type="button" id="nextBtn">次の案へ</button>
      </div>

      <div class="toast" id="toast" role="status" aria-live="polite"></div>
    </div>
  </main>

  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App Onboarding Prototype A',
      description: '新規DLから売却申込率改善の検証プロトタイプ',
      ttlHours: 24
    };

    const tabs = Array.from(document.querySelectorAll('.tab'));
    const screens = Array.from(document.querySelectorAll('.screen'));
    const toast = document.getElementById('toast');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const priceA = document.getElementById('priceA');
    const rangeA = document.getElementById('rangeA');

    let activeIndex = 0;
    let selectedBase = 138;
    let selectedAdjust = 0;
    let toastTimer = null;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toast.classList.remove('show');
      }, 2600);
    }

    function setScreen(index) {
      activeIndex = (index + screens.length) % screens.length;
      tabs.forEach((tab, tabIndex) => {
        tab.classList.toggle('active', tabIndex === activeIndex);
      });
      screens.forEach((screen, screenIndex) => {
        screen.classList.toggle('active', screenIndex === activeIndex);
      });
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        setScreen(index);
      });
    });

    prevBtn.addEventListener('click', () => {
      setScreen(activeIndex - 1);
    });

    nextBtn.addEventListener('click', () => {
      setScreen(activeIndex + 1);
    });

    document.querySelectorAll('[data-toast]').forEach((button) => {
      button.addEventListener('click', () => {
        showToast(button.dataset.toast);
      });
    });

    function updateEstimate() {
      const current = selectedBase + selectedAdjust;
      const low = Math.max(20, current - 14);
      const high = current + 14;
      animateNumber(priceA, Number(priceA.textContent), current);
      rangeA.textContent = `想定レンジ ${low}〜${high}万円`;
    }

    function animateNumber(element, from, to) {
      const start = performance.now();
      const duration = 360;
      function tick(now) {
        const progress = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        element.textContent = Math.round(from + (to - from) * eased);
        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      }
      requestAnimationFrame(tick);
    }

    document.querySelectorAll('[data-group="car"] .choice-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('[data-group="car"] .choice-chip').forEach((item) => {
          item.classList.remove('selected');
        });
        chip.classList.add('selected');
        selectedBase = Number(chip.dataset.price);
        updateEstimate();
      });
    });

    document.querySelectorAll('[data-group="year"] .choice-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('[data-group="year"] .choice-chip').forEach((item) => {
          item.classList.remove('selected');
        });
