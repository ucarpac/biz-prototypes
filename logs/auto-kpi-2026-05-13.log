      align-items: center;
      justify-content: center;
      margin: 16px auto 0;
      cursor: pointer;
      box-shadow: 0 8px 18px rgba(248,76,162,0.24);
    }

    .ghost-button {
      width: 240px;
      min-height: 43px;
      border: 1px solid var(--text-black);
      border-radius: var(--radius-button);
      background: var(--white);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 10px auto 0;
      cursor: pointer;
    }

    .prediction {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 8px 20px var(--shadow);
    }

    .chart {
      height: 142px;
      position: relative;
      border-left: 2px solid var(--ruled-line);
      border-bottom: 2px solid var(--ruled-line);
      margin: 18px 8px 10px;
    }

    .chart-line {
      position: absolute;
      left: 16px;
      top: 48px;
      width: 250px;
      height: 64px;
    }

    .chart-point {
      position: absolute;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--pink);
      border: 3px solid var(--white);
      box-shadow: 0 0 0 2px rgba(248,76,162,0.18);
    }

    .p1 {
      left: 18px;
      top: 50px;
    }

    .p2 {
      left: 94px;
      top: 42px;
    }

    .p3 {
      left: 170px;
      top: 68px;
    }

    .p4 {
      left: 246px;
      top: 88px;
    }

    .chart-labels {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      text-align: center;
    }

    .insight {
      margin: 14px 0 0;
      padding: 12px;
      border-radius: var(--radius-md);
      background: #fff7ef;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
    }

    .sample-car {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 14px;
      align-items: center;
    }

    .sample-image {
      height: 68px;
      border-radius: var(--radius-md);
      background: linear-gradient(135deg, #eaf7ff, #fff5fa);
      position: relative;
      overflow: hidden;
    }

    .sample-image .car-body {
      left: 9px;
      top: 32px;
      width: 68px;
      height: 24px;
    }

    .sample-image .car-roof {
      left: 25px;
      top: 19px;
      width: 30px;
      height: 18px;
    }

    .sample-image .wheel {
      top: 52px;
    }

    .sample-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .sample-meta {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .demo-grid {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .demo-tile {
      border: 0;
      border-radius: 13px;
      background: var(--white);
      padding: 14px 12px;
      min-height: 112px;
      text-align: left;
      box-shadow: 0 0 0 1px #CDDCED, 0 8px 20px var(--shadow);
      cursor: pointer;
    }

    .demo-tile.active {
      box-shadow: 0 0 0 2px var(--pink), 0 10px 24px rgba(248,76,162,0.15);
      background: #fff8fb;
    }

    .tile-icon {
      width: 34px;
      height: 34px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: var(--back-light-pink);
      color: var(--pink);
      font-weight: 700;
      margin-bottom: 10px;
    }

    .tile-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .tile-copy {
      margin: 4px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .preview-panel {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      border-radius: 18px;
      background: var(--white);
      overflow: hidden;
      box-shadow: 0 8px 22px rgba(0,0,0,0.1);
    }

    .preview-top {
      padding: 16px;
      background: linear-gradient(135deg, #091355, #1d2e93);
      color: var(--white);
    }

    .preview-title {
      margin: 0;
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
    }

    .preview-copy {
      margin: 4px 0 0;
      color: #bfdbfe;
      font-size: 12px;
      line-height: 18px;
    }

    .preview-body {
      padding: 16px;
    }

    .progress-track {
      height: 8px;
      background: var(--back-gray);
      border-radius: 999px;
      overflow: hidden;
      margin: 12px 0;
    }

    .progress-fill {
      width: 62%;
      height: 100%;
      background: var(--gradient-primary);
      border-radius: 999px;
      transition: width 280ms ease;
    }

    .bid-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--ruled-line);
      padding: 10px 0;
      font-size: 13px;
      line-height: 19.5px;
    }

    .bid-row:last-child {
      border-bottom: 0;
    }

    .bid-price {
      color: var(--pink);
      font-weight: 700;
    }

    .source-box {
      width: 90%;
      max-width: 351px;
      margin: 0 auto 16px;
      padding: 12px;
      border-radius: var(--radius-md);
      background: #ffffff;
      border: 1px dashed rgba(28,38,99,0.22);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .bottom-bar {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 12px 18px 18px;
      background: rgba(250,250,250,0.94);
      border-top: 1px solid var(--ruled-line);
      backdrop-filter: blur(12px);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      z-index: 12;
    }

    .bottom-bar button {
      margin: 0;
      width: 100%;
      min-width: 0;
    }

    .compact {
      min-height: 43px;
    }

    .toast {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 92px;
      padding: 13px 14px;
      border-radius: var(--radius-md);
      background: var(--dark-blue);
      color: var(--white);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
      opacity: 0;
      transform: translateY(10px);
      pointer-events: none;
      transition: 220ms ease;
      z-index: 20;
      box-shadow: 0 10px 24px rgba(28,38,99,0.22);
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    @media (max-width: 360px) {
      .phone {
        border-radius: 0;
      }

      .hero-title {
        font-size: 24px;
        line-height: 36px;
      }

      .price {
        font-size: 36px;
        line-height: 54px;
      }

      .demo-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (min-width: 700px) {
      .page {
        padding: 32px 0;
      }

      .phone {
        max-width: 420px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="phone">
      <header class="app-header">
        <div class="status-row">
          <span>9:41</span>
          <span>安心して相場チェック</span>
        </div>
        <div class="brand-row">
          <div class="brand">
            <div class="brand-mark">U</div>
