<body>
  <div class="page">
    <header class="topbar">
      <div class="topbar-inner">
        <div class="brand">
          <div class="brand-mark">U</div>
          <div class="brand-text">
            <p class="brand-title">UcarPAC App Growth Lab</p>
            <p class="brand-subtitle">新規DL → 売却申込率 改善検証</p>
          </div>
        </div>
        <div class="date-pill">更新日 2026-05-13</div>
      </div>
