  <div class="toast" id="toast">通知からAI査定結果へ遷移しました</div>

  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App 通知最適化ダッシュボード',
      description: 'プッシュ通知の開封率と通知経由申込数を改善するためのHTMLプロトタイプ'
    };

    const variantCards = document.querySelectorAll('.variant-card');
    const notificationBubble = document.getElementById('notificationBubble');
    const openRate = document.getElementById('openRate');
    const applyCount = document.getElementById('applyCount');
    const toast = document.getElementById('toast');
    const tabs = document.querySelectorAll('.tab');
    const panels = document.querySelectorAll('.setting-panel');
    const chips = document.querySelectorAll('.chip');
    const routeSteps = document.querySelectorAll('.route-step');
    const advanceRoute = document.getElementById('advanceRoute');
    const simulateNotice = document.getElementById('simulateNotice');

    let currentStep = 0;

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    variantCards.forEach((card) => {
      card.addEventListener('click', () => {
        variantCards.forEach((item) => item.classList.remove('active'));
        card.classList.add('active');

        const title = card.querySelector('.push-title').textContent;
        const body = card.querySelector('.push-body').textContent;
        const rate = card.dataset.rate;
        const apply = card.dataset.apply;

        notificationBubble.innerHTML = '<span class="push-title">' + title + '</span><span class="push-body">' + body + '</span>';
        notificationBubble.style.animation = 'none';
        notificationBubble.offsetHeight;
        notificationBubble.style.animation = 'slideNotice 0.55s ease both';

        openRate.textContent = rate + '%';
        applyCount.textContent = apply + '件';
        showToast('通知文言を「' + title + '」に切り替えました');
      });
    });

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((item) => item.classList.remove('active'));
        panels.forEach((panel) => panel.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('panel-' + tab.dataset.tab).classList.add('active');
      });
    });

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const group = chip.parentElement.querySelectorAll('.chip');
        group.forEach((item) => item.classList.remove('active'));
        chip.classList.add('active');
        showToast('通知頻度を「' + chip.textContent + '」に設定しました');
      });
    });

    advanceRoute.addEventListener('click', () => {
      currentStep = (currentStep + 1) % routeSteps.length;
      routeSteps.forEach((step, index) => {
        step.classList.toggle('current', index === currentStep);
      });

      const labels = ['通知タップを確認しました', 'AI査定結果を表示しました', '売却相談CTAを表示しました'];
      showToast(labels[currentStep]);
    });

    simulateNotice.addEventListener('click', () => {
      currentStep = 1;
      routeSteps.forEach((step, index) => {
        step.classList.toggle('current', index === currentStep);
      });
      notificationBubble.style.animation = 'none';
      notificationBubble.offsetHeight;
      notificationBubble.style.animation = 'slideNotice 0.55s ease both';
      showToast('通知タップからAI査定画面へ遷移しました');
    });

    document.querySelectorAll('.switch input').forEach((input) => {
      input.addEventListener('change', () => {
        const label = input.closest('.setting-row').querySelector('.setting-label').textContent;
        showToast(label + 'を' + (input.checked ? 'ON' : 'OFF') + 'にしました');
      });
    });
  </script>
</body>
</html>
