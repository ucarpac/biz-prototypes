  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC 通知最適化プロトタイプ',
      description: 'プッシュ通知の開封率と通知経由申込数を検証するHTMLプロトタイプ',
      storageHours: 24
    };

    const tabs = document.querySelectorAll('.tab');
    const screens = document.querySelectorAll('.screen');
    const mainAction = document.getElementById('mainAction');
    const toast = document.getElementById('toast');

    const actionLabels = {
      copy: '選択中の通知をテスト配信',
      settings: '通知設定の保存を検証',
      journey: '通知タップ導線を再生'
    };

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.screen;

        tabs.forEach((item) => item.classList.remove('active'));
        tab.classList.add('active');

        screens.forEach((screen) => {
          screen.classList.toggle('active', screen.id === `screen-${target}`);
        });

        mainAction.textContent = actionLabels[target];
      });
    });

    const variantButtons = document.querySelectorAll('.variant-button');
    const notificationPreview = document.getElementById('notificationPreview');
    const notifyTitle = document.getElementById('notifyTitle');
    const notifyBody = document.getElementById('notifyBody');
    const openRate = document.getElementById('openRate');
    const openLift = document.getElementById('openLift');
    const applyCount = document.getElementById('applyCount');
    const applyLift = document.getElementById('applyLift');

    variantButtons.forEach((button) => {
      button.addEventListener('click', () => {
        variantButtons.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');

        notifyTitle.textContent = button.dataset.title;
        notifyBody.textContent = button.dataset.body;
        openRate.textContent = button.dataset.rate;
        openLift.textContent = `前回比 ${button.dataset.open}`;
        applyCount.textContent = button.dataset.count;
        applyLift.textContent = `前回比 ${button.dataset.apply}`;

        notificationPreview.classList.remove('pulse');
        void notificationPreview.offsetWidth;
        notificationPreview.classList.add('pulse');

        showToast('通知文言のプレビューを更新しました');
      });
    });

    const switches = document.querySelectorAll('.switch');
    const comfortScore = document.getElementById('comfortScore');
    const comfortFill = document.getElementById('comfortFill');

    function updateComfort() {
      const enabledCount = document.querySelectorAll('.switch.on').length;
      const activeFrequency = document.querySelector('#frequencyChips .chip.active').textContent;
      let score = 48 + enabledCount * 12;

      if (activeFrequency === '大きな変化だけ') {
        score += 12;
      }

      if (activeFrequency === '月1回') {
        score += 8;
      }

      score = Math.min(score, 96);
      comfortScore.textContent = `${score}%`;
      comfortFill.style.width = `${score}%`;
    }

    switches.forEach((item) => {
      item.addEventListener('click', () => {
        item.classList.toggle('on');
        updateComfort();
        showToast('通知の受け取り設定を変更しました');
      });
    });

    const frequencyChips = document.querySelectorAll('#frequencyChips .chip');

    frequencyChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        frequencyChips.forEach((item) => item.classList.remove('active'));
        chip.classList.add('active');
        updateComfort();
        showToast('通知頻度を変更しました');
      });
    });

    document.getElementById('saveSettings').addEventListener('click', () => {
      showToast('通知設定を保存しました');
    });

    const updateAssessment = document.getElementById('updateAssessment');
    const applySale = document.getElementById('applySale');
    const step2 = document.getElementById('step2');
    const step3 = document.getElementById('step3');
    const forecastPrice = document.getElementById('forecastPrice');

    updateAssessment.addEventListener('click', () => {
      step2.classList.remove('current');
      step2.classList.add('done');
      step3.classList.add('current');
      forecastPrice.textContent = '298万円';
      showToast('AI査定を最新相場で更新しました');
    });

    applySale.addEventListener('click', () => {
      step3.classList.remove('current');
      step3.classList.add('done');
      showToast('売却相談の申込導線に進みました');
    });

    mainAction.addEventListener('click', () => {
      const activeTab = document.querySelector('.tab.active').dataset.screen;

      if (activeTab === 'copy') {
        notificationPreview.classList.remove('pulse');
        void notificationPreview.offsetWidth;
        notificationPreview.classList.add('pulse');
        showToast('テスト通知を配信しました');
      }

      if (activeTab === 'settings') {
        showToast('generation-logとkpi-historyへの反映対象です');
      }

      if (activeTab === 'journey') {
        step2.classList.add('current');
        showToast('通知タップからAI査定への導線を再生しました');
      }
    });
  </script>
</body>
</html>
