<!-- A案: 感情に訴えるアプローチ。ユーザーの不安や期待に寄り添い、安心感を与えるデザイン。暖色系のアクセント、手書き風要素、親しみやすいイラスト的表現 -->
<!DOCTYPE html>
<html lang="ja">
<script src="../auth.js"></script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UcarPAC 通知最適化プロトタイプ</title>
  <style>
    :root {
      --pink: #F84CA2;
      --dark-blue: #1c2663;
      --white: #FFFFFF;
      --text-black: #404040;
      --text-gray: #737373;
      --text-disabled: #B3B3B3;
      --text-placeholder: rgba(28,38,99,0.3);
      --button-gray: #CACEE2;
      --button-link: #4099FF;
      --back-white: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-blue: #091355;
      --back-light-pink: #ffd8e8;
      --error: #EB4646;
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-disabled: linear-gradient(90deg, #e5e5e5, #e5e5e5);
      --font-sans: 'Noto Sans JP', 'Hiragino Sans', system-ui, sans-serif;
      --font-number: 'Righteous', 'Noto Sans JP', sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
      --shadow-light: 0 0 14px rgba(0,0,0,0.11);
      --shadow-medium: 0 8px 24px rgba(28,38,99,0.13);
      --warm: #fff3e8;
      --warm-deep: #ffb26d;
      --warm-line: #ffd0aa;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background: var(--back-gray);
      color: var(--text-black);
      font-family: var(--font-sans);
      line-height: 1.5;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 18% 4%, rgba(255,216,232,0.78), transparent 34%),
        radial-gradient(circle at 86% 8%, rgba(255,178,109,0.28), transparent 30%),
        linear-gradient(180deg, #fffaf7 0%, #FAFAFA 42%, #EDF1F4 100%);
    }

    button,
    input,
    select {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
    }

    .page {
      width: 100%;
      max-width: 430px;
      margin: 0 auto;
      min-height: 100vh;
      background: var(--back-white);
      position: relative;
      overflow: hidden;
      box-shadow: 0 0 40px rgba(28,38,99,0.10);
    }

    .status-bar {
      height: 24px;
      background: #fffaf7;
    }

    .header {
      padding: 12px 20px 16px;
      background: #fffaf7;
      position: sticky;
      top: 0;
      z-index: 10;
      border-bottom: 1px solid rgba(242,242,242,0.9);
    }

    .header-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .brand {
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
      letter-spacing: 0;
    }

    .date-chip {
      color: var(--pink);
      background: var(--back-light-pink);
      border-radius: var(--radius-chip);
      padding: 6px 12px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      white-space: nowrap;
    }

    .hero {
      padding: 12px 20px 22px;
      background: linear-gradient(180deg, #fffaf7 0%, #ffffff 100%);
      position: relative;
    }

    .hero-card {
      width: 100%;
      min-height: 210px;
      border-radius: 16px;
      background:
        linear-gradient(135deg, rgba(255,255,255,0.96), rgba(255,243,232,0.96)),
        repeating-linear-gradient(-8deg, rgba(248,76,162,0.06), rgba(248,76,162,0.06) 1px, transparent 1px, transparent 9px);
      box-shadow: var(--shadow-medium);
      padding: 20px 18px;
      border: 1px solid rgba(255,208,170,0.7);
      position: relative;
      overflow: hidden;
    }

    .hero-card::after {
      content: "";
      position: absolute;
      right: -28px;
      top: -28px;
      width: 116px;
      height: 116px;
      border-radius: 50%;
      background: rgba(248,76,162,0.10);
    }

    .hand-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--dark-blue);
      background: var(--white);
      border: 1px dashed var(--warm-deep);
      border-radius: var(--radius-chip);
      padding: 6px 12px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      transform: rotate(-2deg);
      position: relative;
      z-index: 1;
    }

    .hand-label-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--pink);
    }

    .hero-title {
      margin: 16px 0 8px;
      color: var(--dark-blue);
      font-size: 28px;
      line-height: 42px;
      font-weight: 700;
      letter-spacing: 0;
      position: relative;
      z-index: 1;
    }

    .hero-copy {
      margin: 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 21px;
      position: relative;
      z-index: 1;
    }

    .hero-illustration {
      margin-top: 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .mini-car {
      width: 118px;
      height: 62px;
      position: relative;
      flex: 0 0 auto;
      animation: softDrive 3.4s ease-in-out infinite;
    }

    .mini-car-body {
      position: absolute;
      left: 8px;
      bottom: 12px;
      width: 98px;
      height: 34px;
      border-radius: 24px 28px 14px 14px;
      background: linear-gradient(135deg, #ffffff, #ffe9d7);
      border: 2px solid var(--warm-deep);
    }

    .mini-car-top {
      position: absolute;
      left: 34px;
      bottom: 39px;
      width: 46px;
      height: 22px;
      border-radius: 22px 22px 5px 5px;
      background: linear-gradient(135deg, #ffffff, #ffd8e8);
      border: 2px solid var(--warm-deep);
      border-bottom: 0;
    }

    .mini-wheel {
      position: absolute;
      bottom: 5px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--dark-blue);
      border: 4px solid #ffffff;
      box-shadow: 0 0 0 1px var(--warm-deep);
    }

    .mini-wheel.left {
      left: 25px;
    }

    .mini-wheel.right {
      right: 21px;
    }

    .price-bubble {
      min-width: 130px;
      border-radius: 12px;
      background: var(--white);
      box-shadow: var(--shadow-light);
      padding: 10px 12px;
      border: 1px solid var(--ruled-line);
    }

    .price-bubble-label {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .price-bubble-main {
      margin-top: 2px;
      color: var(--pink);
      font-size: 22px;
      line-height: 33px;
      font-weight: 700;
    }

    .tabs {
      display: flex;
      gap: 8px;
      padding: 0 20px 16px;
      overflow-x: auto;
      scrollbar-width: none;
      background: var(--back-white);
    }

    .tabs::-webkit-scrollbar {
      display: none;
    }

    .tab {
      min-height: 43px;
      padding: 0 16px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      white-space: nowrap;
      transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
      transform: translateY(-1px);
    }

    .content {
      padding: 0 20px 96px;
    }

    .screen {
      display: none;
      animation: fadeUp 0.28s ease both;
    }

    .screen.active {
      display: block;
    }

    .section-title {
      margin: 6px 0 12px;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 30px;
      font-weight: 700;
    }

    .section-note {
      margin: 0 0 16px;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 21px;
    }

    .metric-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }

    .metric-card {
      background: var(--white);
      border-radius: 13px;
      padding: 16px;
      box-shadow: var(--shadow-light);
      border: 1px solid #CDDCED;
      min-height: 102px;
    }

    .metric-label {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .metric-value {
      margin-top: 6px;
      color: var(--dark-blue);
      font-size: 26px;
      line-height: 39px;
      font-weight: 700;
    }

    .metric-sub {
      color: var(--pink);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .phone-preview {
      background: var(--back-blue);
      border-radius: 28px;
      padding: 16px 12px 22px;
      box-shadow: 0 12px 26px rgba(9,19,85,0.24);
      margin-bottom: 20px;
    }

    .phone-top {
      width: 64px;
      height: 5px;
      border-radius: 99px;
      background: rgba(255,255,255,0.25);
      margin: 0 auto 14px;
    }

    .notification-card {
      background: var(--white);
      border-radius: 16px;
      padding: 14px;
      box-shadow: var(--shadow-light);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .notification-card.pulse {
      animation: notifyPulse 0.55s ease;
    }

    .notification-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 8px;
    }

    .app-mark {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .app-icon {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: var(--gradient-pink);
      color: var(--white);
      display: grid;
      place-items: center;
      font-size: 13px;
      font-weight: 700;
    }

    .notify-time {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .notification-title {
      color: var(--text-black);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .notification-body {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      margin: 0;
    }

    .variant-list {
      display: grid;
      gap: 12px;
    }

    .variant-button {
      width: 100%;
      text-align: left;
      background: var(--white);
      border: 1px solid var(--ruled-line);
      border-radius: 13px;
      padding: 14px 16px;
      box-shadow: var(--shadow-light);
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .variant-button.active {
      border-color: var(--pink);
      transform: translateY(-1px);
    }

    .variant-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .variant-name {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .variant-rate {
      color: var(--pink);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
      white-space: nowrap;
    }

    .variant-copy {
      margin: 8px 0 0;
      color: var(--text-black);
      font-size: 13px;
      line-height: 19.5px;
    }

    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      border-radius: var(--radius-chip);
      padding: 0 10px;
      background: var(--back-light-pink);
      color: var(--pink);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .settings-card {
      background: var(--white);
      border-radius: 13px;
      padding: 16px;
      box-shadow: var(--shadow-light);
      border: 1px solid #CDDCED;
      margin-bottom: 16px;
    }

    .setting-block {
      padding: 16px 0;
      border-bottom: 1px solid var(--ruled-line);
    }

    .setting-block:first-child {
      padding-top: 0;
    }

    .setting-block:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .setting-head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
    }

    .setting-title {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .setting-desc {
      margin: 4px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .switch {
      width: 54px;
      height: 30px;
      border-radius: 30px;
      background: var(--button-gray);
      padding: 3px;
      transition: background 0.2s ease;
      flex: 0 0 auto;
    }

    .switch.on {
      background: var(--pink);
    }

    .switch-knob {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: var(--white);
      box-shadow: 0 2px 6px rgba(0,0,0,0.18);
      transition: transform 0.2s ease;
    }

    .switch.on .switch-knob {
      transform: translateX(24px);
    }

    .chip-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .chip {
      min-height: 43px;
      border-radius: var(--radius-chip);
      padding: 0 14px;
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
    }

    .comfort-meter {
      margin-top: 16px;
      background: #fff7f0;
      border-radius: 12px;
      padding: 14px;
      border: 1px solid var(--warm-line);
    }

    .comfort-label {
      display: flex;
      justify-content: space-between;
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .meter-track {
      width: 100%;
      height: 10px;
      border-radius: 99px;
      background: #ffe0c4;
      overflow: hidden;
    }

    .meter-fill {
      height: 100%;
      width: 72%;
      border-radius: 99px;
      background: linear-gradient(90deg, var(--warm-deep), var(--pink));
      transition: width 0.25s ease;
    }

    .journey-card {
      background: var(--white);
      border-radius: 13px;
      padding: 16px;
      box-shadow: var(--shadow-light);
      border: 1px solid #CDDCED;
      margin-bottom: 16px;
    }

    .car-summary {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 16px;
    }

    .car-thumb {
      width: 78px;
      height: 56px;
      border-radius: 12px;
      background:
        linear-gradient(135deg, rgba(255,216,232,0.75), rgba(255,243,232,0.9));
      position: relative;
      border: 1px solid var(--warm-line);
      flex: 0 0 auto;
    }

    .car-thumb::before {
      content: "";
      position: absolute;
      left: 13px;
      right: 12px;
      bottom: 14px;
      height: 20px;
      border-radius: 18px 20px 8px 8px;
      background: var(--white);
      border: 2px solid var(--pink);
    }

    .car-thumb::after {
      content: "";
      position: absolute;
      left: 27px;
      top: 14px;
      width: 24px;
      height: 14px;
      border-radius: 14px 14px 3px 3px;
      background: #fff7f0;
      border: 2px solid var(--pink);
      border-bottom: 0;
    }

    .car-name {
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .car-meta {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .timeline {
      position: relative;
      display: grid;
      gap: 12px;
      margin: 18px 0;
    }

    .timeline::before {
      content: "";
      position: absolute;
      left: 14px;
      top: 16px;
      bottom: 16px;
      width: 2px;
      background: var(--ruled-line);
    }

    .step {
      display: grid;
      grid-template-columns: 30px 1fr;
      gap: 12px;
      align-items: start;
      position: relative;
    }

    .step-dot {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: var(--button-gray);
      color: var(--white);
      display: grid;
      place-items: center;
      font-size: 12px;
      font-weight: 700;
      z-index: 1;
      transition: background 0.2s ease;
    }

    .step.done .step-dot {
      background: var(--pink);
    }

    .step.current .step-dot {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      animation: dotBeat 1.4s ease-in-out infinite;
    }

    .step-title {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .step-desc {
      margin-top: 2px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .forecast {
      margin-top: 16px;
      background: #fff7f0;
      border-radius: 12px;
      padding: 16px;
      border: 1px solid var(--warm-line);
    }

    .forecast-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
    }

    .forecast-title {
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .forecast-price {
      color: var(--pink);
      font-size: 22px;
      line-height: 33px;
      font-weight: 700;
      white-space: nowrap;
    }

    .chart {
      height: 132px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      align-items: end;
      padding-top: 10px;
    }

    .bar-wrap {
      display: grid;
      gap: 6px;
      justify-items: center;
      align-items: end;
      height: 100%;
    }

    .bar {
      width: 28px;
      border-radius: 14px 14px 4px 4px;
      background: linear-gradient(180deg, var(--pink), var(--warm-deep));
      min-height: 34px;
      transition: height 0.35s ease;
    }

    .bar-label {
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .cta-panel {
      position: fixed;
      left: 50%;
      bottom: 0;
      width: 100%;
      max-width: 430px;
      transform: translateX(-50%);
      background: rgba(250,250,250,0.96);
      border-top: 1px solid var(--ruled-line);
      padding: 12px 20px 18px;
      z-index: 20;
      backdrop-filter: blur(12px);
    }

    .primary-button {
      width: 100%;
      min-height: 43px;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      box-shadow: 0 8px 18px rgba(77,180,255,0.28);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .primary-button:active {
      transform: scale(0.98);
      box-shadow: 0 4px 10px rgba(77,180,255,0.24);
    }

    .pink-button {
      width: 100%;
      min-height: 43px;
      border-radius: var(--radius-button);
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      box-shadow: 0 8px 18px rgba(248,76,162,0.22);
      margin-top: 10px;
    }

    .source-card {
      margin-top: 16px;
      padding: 14px;
      border-radius: 12px;
      background: var(--white);
      border: 1px dashed var(--warm-deep);
    }

    .source-title {
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .source-text {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      margin: 0;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 88px;
      width: calc(100% - 40px);
      max-width: 390px;
      transform: translateX(-50%) translateY(20px);
      opacity: 0;
      pointer-events: none;
      background: var(--dark-blue);
      color: var(--white);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
      box-shadow: 0 10px 24px rgba(28,38,99,0.26);
      transition: opacity 0.22s ease, transform 0.22s ease;
