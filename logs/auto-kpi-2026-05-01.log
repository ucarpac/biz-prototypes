    .hero-title {
      margin: 0;
      font-size: 22px;
      line-height: 33px;
      font-weight: 700;
    }

    .hero-text {
      margin: 8px 0 0;
      color: #bfdbfe;
      font-size: 14px;
      line-height: 21px;
    }

    .hero-score {
      margin-top: 18px;
      padding: 14px;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.16);
      border-radius: 13px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .score-item {
      min-width: 0;
    }

    .score-label {
      font-size: 10px;
      line-height: 15px;
      color: #bfdbfe;
      font-weight: 700;
    }

    .score-value {
      margin-top: 2px;
      font-size: 24px;
      line-height: 36px;
      color: var(--white);
      font-weight: 700;
    }

    .score-value span {
      color: var(--pink);
    }

    .tabs {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      padding: 16px 16px 0;
    }

    .tab {
      height: 43px;
      border-radius: 22px;
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      transition: transform .2s ease, background .2s ease, color .2s ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .screen {
      display: none;
      padding: 18px 16px 96px;
      animation: fadeIn .28s ease;
    }

    .screen.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .section-title {
      margin: 0 0 12px;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
    }

    .section-note {
      margin: -4px 0 16px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .car-card {
      width: 100%;
      min-height: 128px;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: 0 0 12px rgba(0,0,0,0.11);
      border: 1px solid #CDDCED;
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 16px;
    }

    .car-image {
      width: 92px;
      height: 92px;
      border-radius: 12px;
      background:
        radial-gradient(circle at 74% 22%, rgba(255,255,255,0.8) 0 8px, transparent 9px),
        linear-gradient(135deg, #dfe8f4, #8fb2d8);
      position: relative;
      flex: 0 0 auto;
      overflow: hidden;
    }

    .car-image:before {
      content: "";
      position: absolute;
      left: 13px;
      right: 13px;
      top: 38px;
      height: 26px;
      border-radius: 18px 18px 8px 8px;
      background: var(--dark-blue);
    }

    .car-image:after {
      content: "";
      position: absolute;
      left: 25px;
      right: 25px;
      bottom: 20px;
      height: 9px;
      border-radius: 10px;
      background: var(--pink);
      box-shadow: -20px 0 0 #222, 20px 0 0 #222;
    }

    .car-info {
      min-width: 0;
      flex: 1;
    }

    .car-name {
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
      color: var(--dark-blue);
      margin-bottom: 4px;
    }

    .car-meta {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      margin-bottom: 10px;
    }

    .price-line {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .price {
      font-size: 26px;
      line-height: 39px;
      font-weight: 700;
      color: var(--pink);
    }

    .yen {
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
    }

    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .badge {
      padding: 5px 9px;
      border-radius: 22px;
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      background: var(--back-light-pink);
      color: var(--pink);
    }

    .badge.blue {
      background: #dceeff;
      color: var(--button-link);
    }

    .notification-stage {
      height: 320px;
      position: relative;
      margin-bottom: 18px;
    }

    .notif-card {
      position: absolute;
      inset: 0;
      padding: 18px;
      background: var(--white);
      border-radius: 13px;
      box-shadow: 0 0 16px rgba(0,0,0,0.11);
      border: 1px solid #CDDCED;
      touch-action: pan-y;
      transition: transform .28s ease, opacity .28s ease;
    }

    .notif-card:nth-child(2) {
      transform: scale(.96) translateY(14px);
      opacity: .7;
      z-index: 2;
    }

    .notif-card:nth-child(3) {
      transform: scale(.92) translateY(28px);
      opacity: .4;
      z-index: 1;
    }

    .notif-card.top {
      z-index: 3;
    }

    .notif-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }

    .notif-icon {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      background: var(--gradient-pink);
      color: var(--white);
      display: grid;
      place-items: center;
      font-weight: 700;
    }

    .notif-app {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .notif-time {
      margin-left: auto;
      font-size: 10px;
      line-height: 15px;
      color: var(--text-disabled);
      font-weight: 700;
    }

    .notif-title {
      margin: 0 0 8px;
      font-size: 20px;
      line-height: 30px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .notif-body {
      margin: 0 0 14px;
      font-size: 14px;
      line-height: 21px;
      color: var(--text-black);
    }

    .notif-kpi {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin: 14px 0;
    }

    .kpi-box {
      padding: 10px;
      border-radius: 12px;
      background: var(--back-gray);
    }

    .kpi-label {
      font-size: 10px;
      line-height: 15px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .kpi-value {
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .swipe-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 12px;
    }

    .reject,
    .accept {
      height: 43px;
      border-radius: 30px;
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .reject {
      background: var(--gradient-disabled);
      color: var(--text-gray);
    }

    .accept {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .game-meter {
      margin: 18px 0 8px;
      padding: 14px;
      background: var(--white);
      border-radius: 13px;
      box-shadow: 0 0 10px rgba(0,0,0,0.08);
    }

    .meter-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .meter-bar {
      height: 10px;
      border-radius: 10px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .meter-fill {
      width: 42%;
      height: 100%;
      border-radius: 10px;
      background: var(--gradient-primary);
      transition: width .35s ease;
    }

    .hint {
      margin: 8px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      text-align: center;
    }

    .settings-card {
      background: var(--white);
      border-radius: 13px;
      padding: 16px;
      box-shadow: 0 0 12px rgba(0,0,0,0.11);
      margin-bottom: 14px;
    }

    .setting-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--ruled-line);
    }

    .setting-row:last-child {
      border-bottom: 0;
    }

    .setting-title {
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .setting-desc {
      margin-top: 2px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .switch {
      width: 52px;
      height: 30px;
      border-radius: 22px;
      background: var(--button-gray);
      padding: 3px;
      flex: 0 0 auto;
      transition: background .2s ease;
    }

    .switch:before {
      content: "";
      display: block;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: var(--white);
      box-shadow: 0 2px 6px rgba(0,0,0,.18);
      transition: transform .2s ease;
    }

    .switch.on {
      background: var(--pink);
    }

    .switch.on:before {
      transform: translateX(22px);
    }

    .frequency {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .chip {
      min-height: 43px;
      border-radius: 22px;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      transition: background .2s ease, color .2s ease, transform .2s ease;
    }

    .chip.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .preview-phone {
      margin-top: 16px;
      padding: 14px;
      border-radius: 16px;
      background: var(--back-blue);
      color: var(--white);
    }

    .preview-title {
      font-size: 12px;
      line-height: 18px;
      color: #bfdbfe;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .preview-bubble {
      background: rgba(255,255,255,.92);
      color: var(--text-black);
      border-radius: 13px;
      padding: 12px;
      animation: pulseBubble 1.8s ease infinite;
    }

    @keyframes pulseBubble {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.015); }
    }

    .flow-card {
      background: var(--white);
      border-radius: 13px;
      padding: 16px;
      box-shadow: 0 0 12px rgba(0,0,0,0.11);
      margin-bottom: 16px;
    }

    .progress {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      margin-bottom: 18px;
    }

    .progress-dot {
      height: 8px;
      border-radius: 8px;
      background: var(--back-gray);
      overflow: hidden;
    }

    .progress-dot.active {
      background: var(--pink);
    }

    .step {
      display: none;
      min-height: 322px;
    }

    .step.active {
      display: block;
      animation: stepIn .28s ease;
    }

    @keyframes stepIn {
      from { opacity: 0; transform: translateX(18px); }
      to { opacity: 1; transform: translateX(0); }
    }

    .phone-notice {
      padding: 14px;
      border-radius: 13px;
      background: var(--back-gray);
      margin-bottom: 16px;
    }

    .phone-notice-title {
      font-size: 14px;
      line-height: 21px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .phone-notice-text {
      margin-top: 4px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .result-panel {
      text-align: center;
      padding: 18px 14px;
      border-radius: 12px;
      background: linear-gradient(180deg, #fff, #fff3f8);
      border: 1px solid #ffd8e8;
    }

    .result-label {
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .result-price {
      font-size: 40px;
      line-height: 54px;
      font-weight: 700;
      color: var(--pink);
    }

    .graph {
      height: 150px;
      margin: 18px 0 8px;
      border-radius: 12px;
      background:
        linear-gradient(to top, rgba(28,38,99,.06) 1px, transparent 1px) 0 0 / 100% 30px,
        var(--white);
      position: relative;
      border: 1px solid var(--ruled-line);
      overflow: hidden;
    }

    .graph svg {
      width: 100%;
      height: 100%;
    }

    .graph-labels {
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .flow-actions {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .primary-btn,
    .pink-btn,
    .white-btn {
      height: 43px;
      border-radius: 30px;
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      transition: transform .16s ease;
    }

    .primary-btn:active,
    .pink-btn:active,
    .white-btn:active {
      transform: scale(.98);
    }

    .primary-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
    }

    .pink-btn {
      background: var(--gradient-pink);
      color: var(--white);
    }

    .white-btn {
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid var(--text-black);
    }

    .auction-list {
      display: grid;
      gap: 8px;
      margin-top: 14px;
    }

    .auction-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 12px;
      border-radius: 12px;
      background: var(--back-gray);
    }

    .dealer {
      font-size: 12px;
      line-height: 18px;
      color: var(--dark-blue);
      font-weight: 700;
    }

    .bid {
      font-size: 14px;
      line-height: 21px;
      color: var(--pink);
      font-weight: 700;
    }

    .bottom-nav {
      position: fixed;
      left: 50%;
      bottom: 0;
      transform: translateX(-50%);
      width: 100%;
      max-width: 430px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      background: rgba(255,255,255,.96);
      border-top: 1px solid var(--ruled-line);
      padding: 8px 8px 10px;
      z-index: 20;
    }

    .nav-btn {
      height: 48px;
      border-radius: 12px;
      background: transparent;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .nav-btn.active {
      background: var(--back-light-pink);
      color: var(--pink);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 72px;
      transform: translateX(-50%) translateY(20px);
      width: calc(100% - 32px);
      max-width: 398px;
      padding: 12px 14px;
      border-radius: 13px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      opacity: 0;
      pointer-events: none;
      transition: opacity .24s ease, transform .24s ease;
      z-index: 30;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    @media (min-width: 431px) {
      body {
        background: linear-gradient(180deg, #dfe8f4, #fafafa);
      }

      .app {
        box-shadow: 0 0 30px rgba(28,38,99,.18);
      }
    }
  </style>
</head>
<body>
  <main class="app">
    <header class="header">
      <div class="header-top">
        <div class="logo">UcarPAC AI Notify</div>
        <div class="date-pill">2026.05.01</div>
      </div>
      <h1 class="hero-title">通知から査定、申込までを<br>1本のゲーム進行にする</h1>
      <p class="hero-text">相場変動・売り時・維持費アラートを、ユーザーが選べる頻度で届ける検証画面。</p>
      <div class="hero-score">
        <div class="score-item">
          <div class="score-label">通知開封率 仮説</div>
          <div class="score-value"><span>+18</span>%</div>
        </div>
        <div class="score-item">
          <div class="score-label">通知経由申込 仮説</div>
          <div class="score-value"><span>1.6</span>x</div>
        </div>
      </div>
    </header>

    <nav class="tabs">
      <button class="tab active" data-screen="copy">文言テスト</button>
      <button class="tab" data-screen="setting">通知設定</button>
      <button class="tab" data-screen="flow">査定導線</button>
    </nav>

    <section class="screen active" id="copy">
      <h2 class="section-title">通知文言テスト</h2>
      <p class="section-note">右に送ると採用、左に送ると見送り。開封したくなる通知をスワイプで選ぶ。</p>

      <article class="car-card">
        <div class="car-image"></div>
        <div class="car-info">
          <div class="car-name">トヨタ ハリアー Z</div>
          <div class="car-meta">2021年式 / 36,400km / パールホワイト</div>
          <div class="price-line">
            <div class="price">312</div>
            <div class="yen">万円</div>
          </div>
          <div class="badge-row">
            <span class="badge">個人情報不要</span>
            <span class="badge blue">電話1社のみ</span>
          </div>
        </div>
      </article>

      <div class="notification-stage" id="notificationStage">
        <article class="notif-card top" data-score="22" data-title="愛車の相場が12万円UPしました">
          <div class="notif-head">
            <div class="notif-icon">AI</div>
            <div class="notif-app">UcarPAC</div>
            <div class="notif-time">今</div>
          </div>
          <h3 class="notif-title">愛車の相場が12万円UPしました</h3>
          <p class="notif-body">ハリアー Zの相場が先週より上昇。今のAI査定価格を30秒で確認できます。</p>
          <div class="notif-kpi">
            <div class="kpi-box">
              <div class="kpi-label">想定開封率</div>
              <div class="kpi-value">18.4%</div>
            </div>
            <div class="kpi-box">
              <div class="kpi-label">申込期待</div>
              <div class="kpi-value">高</div>
            </div>
          </div>
          <div class="swipe-actions">
            <button class="reject">見送り</button>
            <button class="accept">採用</button>
          </div>
        </article>

        <article class="notif-card" data-score="16" data-title="今売ると6か月後より28万円高い予測">
          <div class="notif-head">
            <div class="notif-icon">AI</div>
            <div class="notif-app">UcarPAC</div>
            <div class="notif-time">今</div>
          </div>
          <h3 class="notif-title">今売ると6か月後より28万円高い予測</h3>
          <p class="notif-body">AIが相場推移を更新。売り時スコアが80を超えました。</p>
          <div class="notif-kpi">
            <div class="kpi-box">
              <div class="kpi-label">想定開封率</div>
              <div class="kpi-value">16.9%</div>
            </div>
            <div class="kpi-box">
              <div class="kpi-label">申込期待</div>
              <div class="kpi-value">中</div>
            </div>
          </div>
          <div class="swipe-actions">
            <button class="reject">見送り</button>
            <button class="accept">採用</button>
          </div>
        </article>

        <article class="notif-card" data-score="12" data-title="8,000店の入札チャンスを確認">
          <div class="notif-head">
            <div class="notif-icon">AI</div>
            <div class="notif-app">UcarPAC</div>
            <div class="notif-time">今</div>
          </div>
          <h3 class="notif-title">8,000店の入札チャンスを確認</h3>
          <p class="notif-body">あなたの条件に近い車で高額入札が出ています。電話はUcarPACの1社だけ。</p>
          <div class="notif-kpi">
            <div class="kpi-box">
              <div class="kpi-label">想定開封率</div>
              <div class="kpi-value">14.2%</div>
            </div>
            <div class="kpi-box">
              <div class="kpi-label">申込期待</div>
              <div class="kpi-value">中</div>
            </div>
          </div>
          <div class="swipe-actions">
            <button class="reject">見送り</button>
            <button class="accept">採用</button>
          </div>
        </article>
      </div>

      <div class="game-meter">
        <div class="meter-top">
          <span>通知レベル</span>
          <span id="meterText">42 / 100</span>
        </div>
        <div class="meter-bar">
          <div class="meter-fill" id="meterFill"></div>
        </div>
      </div>
      <p class="hint">カードをドラッグ、またはボタンで文言を評価できます。</p>
    </section>

    <section class="screen" id="setting">
      <h2 class="section-title">通知設定UI</h2>
      <p class="section-note">通知頻度と種類をユーザーが選択。不要通知を減らして、長期利用を守る。</p>

      <div class="settings-card">
        <div class="setting-row">
          <div>
            <div class="setting-title">相場変動通知</div>
            <div class="setting-desc">3万円以上の変動だけ通知</div>
          </div>
          <button class="switch on" data-switch="相場変動通知"></button>
        </div>
