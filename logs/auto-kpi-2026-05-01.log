    .chip {
      min-height: 43px;
      border: 1px solid var(--ruled-line);
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      cursor: pointer;
    }

    .chip.active {
      border-color: var(--dark-blue);
      background: var(--dark-blue);
      color: var(--white);
    }

    .route {
      display: grid;
      gap: 10px;
    }

    .route-step {
      display: grid;
      grid-template-columns: 42px 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 12px;
      border-radius: var(--radius-md);
      border: 1px solid #e6edf5;
      background: #fbfdff;
      transition: border-color 0.2s ease, background 0.2s ease;
    }

    .route-step.current {
      border-color: #40BFFF;
      background: #effaff;
    }

    .step-icon {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 900;
    }

    .step-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .step-desc {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .step-rate {
      color: var(--pink);
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
    }

    .primary-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 43px;
      margin-top: 14px;
      border: 0;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 8px 18px rgba(64,153,255,0.24);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .primary-button:active {
      transform: scale(0.98);
      box-shadow: 0 4px 12px rgba(64,153,255,0.18);
    }

    .pink-button {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 8px 18px rgba(248,76,162,0.24);
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: var(--radius-md);
      font-size: 11px;
      line-height: 16.5px;
    }

    .compare-table th {
      padding: 9px 6px;
      background: var(--dark-blue);
      color: var(--white);
      text-align: left;
      font-weight: 700;
    }

    .compare-table td {
      padding: 9px 6px;
      border-bottom: 1px solid var(--ruled-line);
      background: #fff;
      color: var(--text-black);
      font-weight: 700;
    }

    .compare-table tr:last-child td {
      border-bottom: 0;
    }

    .winner {
      color: var(--pink);
    }

    .source-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .source-list li {
      padding: 10px;
      border-radius: var(--radius-sm);
      background: #f7f9fc;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      width: calc(100% - 32px);
      max-width: 398px;
      padding: 12px 14px;
      border-radius: var(--radius-md);
      background: var(--dark-blue);
      color: var(--white);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
      box-shadow: 0 12px 28px rgba(28,38,99,0.28);
      transform: translate(-50%, 120%);
      opacity: 0;
      transition: transform 0.28s ease, opacity 0.28s ease;
      z-index: 10;
    }

    .toast.show {
      transform: translate(-50%, 0);
      opacity: 1;
    }

    .mini-phone {
      position: relative;
      margin: 2px auto 14px;
      padding: 12px;
      border-radius: 24px;
      background: #111827;
      box-shadow: inset 0 0 0 2px #273244, 0 12px 28px rgba(0,0,0,0.14);
    }

    .phone-screen {
      min-height: 170px;
      padding: 12px;
      border-radius: 16px;
      background: linear-gradient(180deg, #eef7ff 0%, #ffffff 100%);
    }

    .notification-bubble {
      padding: 10px;
      border-radius: 13px;
      background: rgba(255,255,255,0.94);
      border: 1px solid #e5edf7;
      box-shadow: 0 8px 20px rgba(28,38,99,0.12);
      animation: slideNotice 0.55s ease both;
    }

    .car-price {
      margin-top: 14px;
      padding: 12px;
      border-radius: var(--radius-md);
      background: var(--white);
      border: 1px solid #eaf0f7;
    }

    .car-name {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 700;
    }

    .price-main {
      color: var(--dark-blue);
      font-size: 30px;
      line-height: 45px;
      font-weight: 900;
    }

    .price-main span {
      font-size: 15px;
      line-height: 22.5px;
    }

    .price-note {
      color: var(--pink);
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideNotice {
      from {
        opacity: 0;
        transform: translateY(-18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (min-width: 720px) {
      body {
        background: #dfe7f1;
      }

      .app {
        max-width: 960px;
        display: grid;
        grid-template-columns: 390px 1fr;
      }

      .hero {
        min-height: 100vh;
      }

      .content {
        max-height: 100vh;
        overflow-y: auto;
        padding: 24px;
      }

      .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .section.full {
        grid-column: 1 / -1;
      }
    }
  </style>
</head>
<body>
  <div class="app">
