      <button class="nav-btn" data-screen="flow">導線</button>
    </nav>

    <div class="toast" id="toast">設定を更新しました</div>
  </main>

  <script>
    const tabs = document.querySelectorAll('.tab');
    const navButtons = document.querySelectorAll('.nav-btn');
    const screens = document.querySelectorAll('.screen');
    const toast = document.getElementById('toast');

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function setScreen(id) {
      tabs.forEach(tab => tab.classList.toggle('active', tab.dataset.screen === id));
      navButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.screen === id));
      screens.forEach(screen => screen.classList.toggle('active', screen.id === id));
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => setScreen(tab.dataset.screen));
    });

    navButtons.forEach(btn => {
      btn.addEventListener('click', () => setScreen(btn.dataset.screen));
    });

    const stage = document.getElementById('notificationStage');
    const meterFill = document.getElementById('meterFill');
    const meterText = document.getElementById('meterText');
    let meter = 42;

    function refreshCards() {
      const cards = [...stage.querySelectorAll('.notif-card')];
      cards.forEach((card, index) => {
        card.classList.toggle('top', index === 0);
        card.style.zIndex = String(3 - index);
        if (index === 0) {
          card.style.transform = 'translateX(0) rotate(0deg) scale(1)';
          card.style.opacity = '1';
        }
        if (index === 1) {
          card.style.transform = 'scale(.96) translateY(14px)';
          card.style.opacity = '.7';
        }
        if (index === 2) {
          card.style.transform = 'scale(.92) translateY(28px)';
          card.style.opacity = '.4';
        }
      });
      bindTopCard();
    }

    function updateMeter(delta) {
      meter = Math.max(0, Math.min(100, meter + delta));
      meterFill.style.width = meter + '%';
      meterText.textContent = meter + ' / 100';
    }

    function decideCard(card, accepted) {
      const title = card.dataset.title;
      const score = Number(card.dataset.score || 0);
      card.style.transform = accepted ? 'translateX(120%) rotate(12deg)' : 'translateX(-120%) rotate(-12deg)';
      card.style.opacity = '0';
      updateMeter(accepted ? score : -6);
      showToast(accepted ? '採用: ' + title : '見送りました');
      setTimeout(() => {
        stage.appendChild(card);
        refreshCards();
      }, 260);
    }

    function bindTopCard() {
      const top = stage.querySelector('.notif-card.top');
      if (!top || top.dataset.bound === 'true') return;
      top.dataset.bound = 'true';

      let startX = 0;
      let currentX = 0;
      let dragging = false;

      top.addEventListener('pointerdown', event => {
        dragging = true;
        startX = event.clientX;
        top.setPointerCapture(event.pointerId);
      });

      top.addEventListener('pointermove', event => {
        if (!dragging) return;
        currentX = event.clientX - startX;
        top.style.transform = `translateX(${currentX}px) rotate(${currentX / 16}deg)`;
      });

      top.addEventListener('pointerup', () => {
        if (!dragging) return;
        dragging = false;
        if (currentX > 80) {
          decideCard(top, true);
        } else if (currentX < -80) {
          decideCard(top, false);
        } else {
          top.style.transform = 'translateX(0) rotate(0deg)';
        }
        currentX = 0;
      });

      top.querySelector('.accept').addEventListener('click', () => decideCard(top, true));
      top.querySelector('.reject').addEventListener('click', () => decideCard(top, false));
    }

    refreshCards();

    const switches = document.querySelectorAll('.switch');
    const previewBubble = document.getElementById('previewBubble');

    switches.forEach(item => {
      item.addEventListener('click', () => {
        item.classList.toggle('on');
        const state = item.classList.contains('on') ? 'オン' : 'オフ';
        showToast(item.dataset.switch + 'を' + state + 'にしました');
      });
    });

    const frequencyMessages = {
      '控えめ': '重要な相場変動だけ通知します。ハリアー Zの価格が大きく動いた時にお知らせします。',
      '標準': 'ハリアー Zの相場が12万円UP。今のAI査定価格を確認できます。',
      '積極的': '売り時スコア86。相場UP、入札見込み、維持費変化をまとめて確認できます。'
    };

    document.querySelectorAll('.chip').forEach(chip => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('.chip').forEach(item => item.classList.remove('active'));
        chip.classList.add('active');
        previewBubble.textContent = frequencyMessages[chip.dataset.frequency];
        showToast('通知頻度を' + chip.dataset.frequency + 'に変更しました');
      });
    });

    document.getElementById('saveSettings').addEventListener('click', () => {
      showToast('通知設定を保存しました。次回通知から反映されます');
    });

    const steps = document.querySelectorAll('.step');
    const dots = document.querySelectorAll('.progress-dot');
    let currentStep = 0;

    function renderStep() {
      steps.forEach((step, index) => step.classList.toggle('active', index === currentStep));
      dots.forEach((dot, index) => dot.classList.toggle('active', index <= currentStep));
    }

    document.querySelectorAll('.next-step').forEach(button => {
      button.addEventListener('click', () => {
        currentStep = Math.min(steps.length - 1, currentStep + 1);
        renderStep();
        if (currentStep === 1) showToast('AI査定を更新しました');
        if (currentStep === 2) showToast('入札見込みを取得しました');
        if (currentStep === 3) showToast('申込前の確認まで到達しました');
      });
    });

    document.getElementById('applyButton').addEventListener('click', () => {
      showToast('通知経由申込として計測されました');
    });

    document.getElementById('resetFlow').addEventListener('click', () => {
      currentStep = 0;
      renderStep();
      showToast('導線を最初に戻しました');
    });
  </script>
</body>
</html>
