    <section class="research">
      <h2 class="section-title">検証材料と反映メモ</h2>

      <div class="research-grid">
        <article class="source-card">
          <h3>通知文言テスト</h3>
          <p>
            Firebase Notifications Composerは、通知メッセージ改善のためにAnalyticsベースのA/Bテストを利用できる。
            出典: Firebase Cloud Messaging documentation, 参照日: 2026-05-29,
            <a href="https://firebase.google.com/docs/cloud-messaging/send/firebase-console?hl=ja">https://firebase.google.com/docs/cloud-messaging/send/firebase-console?hl=ja</a>
          </p>
        </article>

        <article class="source-card">
          <h3>通知設定UI</h3>
          <p>
            通知はユーザーが内容を判断できるよう、簡潔で十分な文脈を持つ本文が推奨される。
            出典: Apple Human Interface Guidelines Notifications, 参照日: 2026-05-29,
            <a href="https://developer.apple.com/design/human-interface-guidelines/notifications">https://developer.apple.com/design/human-interface-guidelines/notifications</a>
          </p>
        </article>

        <article class="source-card">
          <h3>KPIベンチマーク</h3>
          <p>
            Push通知の直接開封率、opt-in、月間送信数は業界や運用戦略で大きく変わるため、アプリ内KPIで日次差分を見る。
            出典: Airship Mobile App Push Notification Benchmarks for 2025, 参照日: 2026-05-29,
            <a href="https://www.airship.com/resources/benchmark-report/mobile-app-push-notification-benchmarks-for-2023/">https://www.airship.com/resources/benchmark-report/mobile-app-push-notification-benchmarks-for-2023/</a>
          </p>
        </article>
      </div>

      <div class="result-card">
        <div class="scene-label">kpi-history反映案</div>
        <div class="notification-title">push-open-rate / push-apply-count</div>
        <div class="notification-body">
          2026-05-29の日次差分として、A案「相場UP通知」を暫定勝ち筋、頻度は週2回、種類は相場変動と売り時アラートを初期ONに設定。
          通知タップ後はAI査定更新画面へ直行し、価格更新後に売却相談CTAを表示する。
        </div>
      </div>
    </section>
  </main>

  <script>
    const variants = [
      {
        tag: 'A案',
        title: '愛車の相場が12万円UP',
        body: 'プリウス Sの相場が先週より上昇。個人情報なしでAI査定を更新できます。',
        open: '13.8%',
        restart: '7.4%',
        apply: '4.1%',
        score: '13.8%',
        toast: 'A案「相場UP」を保存しました'
      },
      {
        tag: 'B案',
        title: '今売ると3ヶ月後より高い予測',
        body: 'AIが相場の下落タイミングを検知。売り時シミュレーションを確認しましょう。',
        open: '12.1%',
        restart: '6.8%',
        apply: '3.7%',
        score: '12.1%',
        toast: 'B案「売り時」を保存しました'
      },
      {
        tag: 'C案',
        title: '今月の維持費が18,400円増えています',
        body: 'ガソリン代と保険料を反映。愛車の価値と出費をまとめて確認できます。',
        open: '10.9%',
        restart: '6.2%',
        apply: '2.9%',
        score: '10.9%',
        toast: 'C案「出費連動」を保存しました'
      }
    ];

    const scenes = ['sceneTest', 'sceneSettings', 'sceneRoute'];
    const labels = [
      'Step 1 / 通知文言テスト',
      'Step 2 / 通知設定UI',
      'Step 3 / 通知→査定導線'
    ];

    let currentVariant = 0;
    let currentScene = 0;
    let questPoint = 0;
    let routeStep = 0;
    let dragStartX = 0;
    let dragging = false;

    const variantCard = document.getElementById('variantCard');
    const toast = document.getElementById('toast');
    const screen = document.getElementById('screen');

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1700);
    }

    function addPoint(value) {
      questPoint += value;
      document.getElementById('questCoin').textContent = questPoint;
      screen.classList.remove('screen-flash');
      void screen.offsetWidth;
      screen.classList.add('screen-flash');
    }

    function setScene(index) {
      currentScene = Math.max(0, Math.min(index, scenes.length - 1));
      scenes.forEach((id, sceneIndex) => {
        document.getElementById(id).classList.toggle('active', sceneIndex === currentScene);
      });
      document.querySelectorAll('.progress-step').forEach((step, stepIndex) => {
        step.classList.toggle('active', stepIndex <= currentScene);
      });
      document.getElementById('sceneLabel').textContent = labels[currentScene];
      addPoint(5);
    }

    function renderVariant(index) {
      currentVariant = (index + variants.length) % variants.length;
      const data = variants[currentVariant];
      document.getElementById('variantTag').textContent = data.tag;
      document.getElementById('noticeTitle').textContent = data.title;
      document.getElementById('noticeBody').textContent = data.body;
      document.getElementById('metricOpen').textContent = data.open;
      document.getElementById('metricRestart').textContent = data.restart;
      document.getElementById('metricApply').textContent = data.apply;
      document.getElementById('variantScore').textContent = data.score;
      document.getElementById('heroOpenRate').textContent = data.open;
      document.getElementById('heroApplyRate').textContent = data.apply;
      document.querySelectorAll('.chip[data-variant]').forEach((chip) => {
        chip.classList.toggle('selected', Number(chip.dataset.variant) === currentVariant);
      });
      showToast(data.toast);
      addPoint(3);
    }

    function nextVariant() {
      variantCard.style.transform = 'translateX(28px) rotate(2deg)';
      window.setTimeout(() => {
        renderVariant(currentVariant + 1);
        variantCard.style.transform = 'translateX(0) rotate(0)';
      }, 160);
    }

    function prevVariant() {
      variantCard.style.transform = 'translateX(-28px) rotate(-2deg)';
      window.setTimeout(() => {
        renderVariant(currentVariant - 1);
        variantCard.style.transform = 'translateX(0) rotate(0)';
      }, 160);
    }

    function updateFrequency(value) {
      const labelsByValue = {
        1: '週1回',
        2: '週2回',
        3: '週3回',
        4: '重要時のみ',
        5: '毎日'
      };
      document.getElementById('frequencyLabel').textContent = labelsByValue[value];
      showToast(`通知頻度を${labelsByValue[value]}に変更しました`);
      addPoint(2);
    }

    function advanceRoute() {
      routeStep = Math.min(routeStep + 1, 2);
      document.querySelectorAll('.route-node').forEach((node) => {
        node.classList.toggle('done', Number(node.dataset.node) <= routeStep);
      });
      if (routeStep === 1) {
        showToast('AI査定を更新しました。価格は142万円です');
      } else if (routeStep === 2) {
        showToast('売却相談CTAを表示しました');
      }
      addPoint(6);
    }

    document.getElementById('startDemo').addEventListener('click', () => {
      setScene(0);
      showToast('通知クエストを開始しました');
    });

    document.getElementById('jumpSettings').addEventListener('click', () => {
      setScene(1);
      showToast('通知設定に移動しました');
    });

    document.getElementById('nextVariant').addEventListener('click', nextVariant);
    document.getElementById('prevVariant').addEventListener('click', prevVariant);

    document.querySelectorAll('.chip[data-variant]').forEach((chip) => {
      chip.addEventListener('click', () => {
        renderVariant(Number(chip.dataset.variant));
      });
    });

    document.getElementById('backToTest').addEventListener('click', () => {
      setScene(0);
    });

    document.getElementById('goRoute').addEventListener('click', () => {
      setScene(2);
      showToast('通知タップ後の導線を開始しました');
    });

    document.getElementById('frequencyRange').addEventListener('input', (event) => {
      updateFrequency(event.target.value);
    });

    document.querySelectorAll('.switch').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('on');
        const title = toggle.closest('.setting-item').querySelector('.setting-title').textContent;
        const enabled = toggle.classList.contains('on') ? 'ON' : 'OFF';
        showToast(`${title}を${enabled}にしました`);
        addPoint(2);
      });
    });

    document.getElementById('advanceRoute').addEventListener('click', advanceRoute);

    document.getElementById('applyNow').addEventListener('click', () => {
      routeStep = 2;
      document.querySelectorAll('.route-node').forEach((node) => {
        node.classList.add('done');
      });
      showToast('申込導線の検証完了: 通知経由申込数に反映');
      addPoint(12);
    });

    variantCard.addEventListener('pointerdown', (event) => {
      dragging = true;
      dragStartX = event.clientX;
      variantCard.setPointerCapture(event.pointerId);
    });

    variantCard.addEventListener('pointermove', (event) => {
      if (!dragging) return;
      const diff = event.clientX - dragStartX;
      const rotate = diff / 32;
      variantCard.style.transform = `translateX(${diff}px) rotate(${rotate}deg)`;
    });

    variantCard.addEventListener('pointerup', (event) => {
      if (!dragging) return;
      dragging = false;
      const diff = event.clientX - dragStartX;
      if (diff > 70) {
        prevVariant();
      } else if (diff < -70) {
        nextVariant();
      } else {
        variantCard.style.transform = 'translateX(0) rotate(0)';
      }
    });

    window.setTimeout(() => {
      showToast('A案が暫定トップです。スワイプで比較できます');
    }, 700);
  </script>
</body>
</html>
