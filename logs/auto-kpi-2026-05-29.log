                      <path d="M12 72 C52 62, 72 58, 108 48 C150 36, 178 42, 212 28 C248 16, 270 24, 292 18" fill="none" stroke="url(#lineGrad)" stroke-width="5" stroke-linecap="round"></path>
                      <circle cx="212" cy="28" r="7" fill="#f84ca2"></circle>
