  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App 通知最適化プロトタイプ',
      description: 'A案: 感情に訴える通知最適化UI',
      storageHours: 24
    };

    const tabs = document.querySelectorAll('[data-tab]');
    const sections = document.querySelectorAll('.section');
    const tabButtons = document.querySelectorAll('.tab-button');
    const navItems = document.querySelectorAll('.nav-item');
    const toast = document.getElementById('toast');

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove('show');
      }, 1800);
    }

    function switchTab(tabName) {
      sections.forEach(section => {
        section.classList.toggle('active', section.id === tabName);
      });

      tabButtons.forEach(button => {
        button.classList.toggle('active', button.dataset.tab === tabName);
      });

      navItems.forEach(item => {
        item.classList.toggle('active', item.dataset.tab === tabName);
      });

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    tabs.forEach(button => {
      button.addEventListener('click', () => {
        switchTab(button.dataset.tab);
      });
    });

    const variationCards = document.querySelectorAll('#copy .variation-card');
    const previewTitle = document.getElementById('previewTitle');
    const previewBody = document.getElementById('previewBody');
    const preview = document.getElementById('notificationPreview');
    const openRate = document.getElementById('openRate');
    const applyCount = document.getElementById('applyCount');

    variationCards.forEach(card => {
      card.addEventListener('click', () => {
        variationCards.forEach(item => item.classList.remove('selected'));
        card.classList.add('selected');

        previewTitle.textContent = card.dataset.title;
        previewBody.textContent = card.dataset.body;
        openRate.textContent = card.dataset.rate;
        applyCount.textContent = card.dataset.apply.replace('件', '');

        preview.style.animation = 'none';
        preview.offsetHeight;
        preview.style.animation = 'floatIn 420ms ease';

        showToast('通知プレビューを更新しました');
      });
    });

    document.getElementById('previewTap').addEventListener('click', () => {
      switchTab('journey');
      showJourneyStage(0);
      showToast('通知タップ後の導線を表示しました');
    });

    const toggles = document.querySelectorAll('.toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('active');
        const label = toggle.dataset.toggle || '通知';
        const enabled = toggle.classList.contains('active');
        showToast(`${label}を${enabled ? 'オン' : 'オフ'}にしました`);
      });
    });

    const chips = document.querySelectorAll('.chip');
    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const parent = chip.parentElement;
        if (parent && parent.children.length === 4 && chip.textContent.includes('週')) {
          parent.querySelectorAll('.chip').forEach(item => item.classList.remove('active'));
          chip.classList.add('active');
        } else if (parent && parent.children.length === 4 && chip.textContent === '毎日') {
          parent.querySelectorAll('.chip').forEach(item => item.classList.remove('active'));
          chip.classList.add('active');
        } else if (parent && parent.children.length === 4 && chip.textContent === '大きな変化時のみ') {
          parent.querySelectorAll('.chip').forEach(item => item.classList.remove('active'));
          chip.classList.add('active');
        } else {
          chip.classList.toggle('active');
        }
        showToast('通知条件を更新しました');
      });
    });

    const thresholdRange = document.getElementById('thresholdRange');
    const thresholdValue = document.getElementById('thresholdValue');
    const settingSummary = document.getElementById('settingSummary');

    thresholdRange.addEventListener('input', () => {
      thresholdValue.textContent = thresholdRange.value;
      settingSummary.textContent = `${thresholdRange.value}万円以上の相場変化だけ通知します`;
    });

    document.getElementById('saveSettings').addEventListener('click', () => {
      showToast('通知設定を保存しました');
    });

    const journeyCards = document.querySelectorAll('[data-stage-target]');
    const journeyStages = document.querySelectorAll('.journey-stage');
    const stepDots = document.querySelectorAll('.step-dot');

    function showJourneyStage(index) {
      journeyStages.forEach((stage, stageIndex) => {
        stage.classList.toggle('active', stageIndex === index);
      });

      stepDots.forEach((dot, dotIndex) => {
        dot.classList.toggle('active', dotIndex === index);
      });

      journeyCards.forEach(card => {
        card.classList.toggle('selected', Number(card.dataset.stageTarget) === index);
      });
    }

    journeyCards.forEach(card => {
      card.addEventListener('click', () => {
        showJourneyStage(Number(card.dataset.stageTarget));
      });
    });

    document.querySelectorAll('.next-stage').forEach(button => {
      button.addEventListener('click', () => {
        const current = Array.from(journeyStages).findIndex(stage => stage.classList.contains('active'));
        const next = Math.min(current + 1, journeyStages.length - 1);
        showJourneyStage(next);
        showToast(next === 1 ? 'AI査定更新へ進みました' : '売却相談の確認へ進みました');
      });
    });

    document.getElementById('applyButton').addEventListener('click', () => {
      showToast('通知経由申込として計測しました');
    });

    document.getElementById('laterButton').addEventListener('click', () => {
      showToast('相場を保存し、次回の通知条件に反映しました');
    });
  </script>
</body>
