      background: var(--warm);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .journey-phone {
      border-radius: 28px;
      background: #141926;
      padding: 10px;
      box-shadow: 0 12px 34px rgba(28,38,99,0.18);
    }

    .journey-screen {
      min-height: 612px;
      border-radius: 22px;
      background: #fffaf2;
      overflow: hidden;
      position: relative;
    }

    .journey-stage {
      display: none;
      min-height: 580px;
      padding: 0 14px 18px;
      animation: slideUp 260ms ease;
    }

    .journey-stage.active {
      display: block;
    }

    .warm-header {
      margin: 10px 0 12px;
      border-radius: 16px;
      padding: 16px;
      background: var(--gradient-warm);
      position: relative;
      overflow: hidden;
    }

    .warm-header::after {
      content: "";
      position: absolute;
      right: -18px;
      top: -20px;
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: rgba(255,255,255,0.6);
    }

    .warm-small {
      position: relative;
      z-index: 1;
      margin: 0;
      color: var(--pink);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .warm-title {
      position: relative;
      z-index: 1;
      margin: 8px 0 0;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 30px;
      font-weight: 700;
    }

    .warm-text {
      position: relative;
      z-index: 1;
      margin: 6px 0 0;
      color: var(--text-black);
      font-size: 13px;
      line-height: 19.5px;
    }

    .price-card {
      border-radius: 13px;
      background: var(--white);
      padding: 16px;
      box-shadow: var(--shadow);
      margin-bottom: 12px;
    }

    .car-name {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .car-detail {
      margin: 4px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
    }

    .price-main {
      display: flex;
      align-items: flex-end;
      gap: 6px;
      margin-top: 12px;
      color: var(--pink);
    }

    .price-number {
      font-size: 40px;
      line-height: 54px;
      font-weight: 700;
    }

    .price-unit {
      padding-bottom: 9px;
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .price-change {
      width: fit-content;
      margin-top: 8px;
      padding: 6px 10px;
      border-radius: 22px;
      background: #fff0d9;
      color: #a75000;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .mini-chart {
      margin-top: 16px;
      height: 116px;
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0), rgba(255,255,255,0.72)),
        repeating-linear-gradient(0deg, #f4f4f4 0, #f4f4f4 1px, transparent 1px, transparent 28px);
      position: relative;
      overflow: hidden;
    }

    .chart-line {
      position: absolute;
      left: 18px;
      right: 18px;
      top: 28px;
      height: 58px;
      border-bottom: 4px solid var(--pink);
      border-radius: 0 0 60px 18px;
      transform: skewY(-9deg);
    }

    .chart-dot {
      position: absolute;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--pink);
      border: 3px solid var(--white);
      box-shadow: 0 2px 8px rgba(248,76,162,0.32);
    }

    .dot-a {
      left: 22px;
      top: 78px;
    }

    .dot-b {
      left: 136px;
      top: 52px;
    }

    .dot-c {
      right: 22px;
      top: 34px;
    }

    .chart-labels {
      position: absolute;
      left: 14px;
      right: 14px;
      bottom: 8px;
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    .primary-button {
      width: 240px;
      max-width: 100%;
      min-height: 43px;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      display: block;
      margin: 16px auto 0;
      box-shadow: 0 8px 18px rgba(77,180,255,0.28);
      transition: transform 180ms ease;
    }

    .primary-button:active {
      transform: scale(0.97);
    }

    .pink-button {
      width: 240px;
      max-width: 100%;
      min-height: 43px;
      border-radius: 30px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      display: block;
      margin: 12px auto 0;
      box-shadow: 0 8px 18px rgba(248,76,162,0.24);
      transition: transform 180ms ease;
    }

    .pink-button:active {
      transform: scale(0.97);
    }

    .outline-button {
      width: 240px;
      max-width: 100%;
      min-height: 43px;
      border-radius: 30px;
      background: var(--white);
      border: 1px solid var(--text-black);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      display: block;
      margin: 12px auto 0;
    }

    .stepper {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin: 12px 0;
    }

    .step-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #d9d9d9;
    }

    .step-dot.active {
      width: 24px;
      border-radius: 8px;
      background: var(--pink);
    }

    .form-card {
      border-radius: 13px;
      background: var(--white);
      padding: 16px;
      box-shadow: var(--shadow);
      margin-bottom: 12px;
    }

    .field-label {
      margin: 0 0 8px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .underline-input {
      width: 100%;
      height: 42px;
      border: 0;
      border-bottom: 2px solid var(--dark-blue);
      background: transparent;
      text-align: center;
      color: var(--dark-blue);
      font-size: 24px;
      line-height: 36px;
      font-weight: 700;
      outline: none;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .trust-badge {
      min-height: 30px;
      padding: 6px 10px;
      border-radius: 22px;
      background: var(--back-light-pink);
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 700;
    }

    .auction-card {
      border-radius: 13px;
      background: var(--back-blue);
      padding: 16px;
      color: var(--white);
      box-shadow: var(--shadow);
      margin-bottom: 12px;
    }

    .auction-title {
      margin: 0;
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .auction-price {
      margin: 8px 0 0;
      color: #bfdbfe;
      font-size: 12px;
      line-height: 18px;
    }

    .auction-price strong {
      display: block;
      margin-top: 4px;
      color: var(--white);
      font-size: 32px;
      line-height: 48px;
    }

    .progress-list {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .progress-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: rgba(255,255,255,0.86);
      font-size: 12px;
      line-height: 18px;
    }

    .progress-check {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--pink);
      position: relative;
      flex: 0 0 auto;
    }

    .progress-check::after {
      content: "";
      position: absolute;
      left: 7px;
      top: 4px;
      width: 5px;
      height: 9px;
      border-right: 2px solid var(--white);
      border-bottom: 2px solid var(--white);
      transform: rotate(45deg);
    }

    .bottom-nav {
      position: sticky;
      bottom: 0;
      z-index: 30;
      height: 72px;
      background: rgba(255,255,255,0.94);
      border-top: 1px solid rgba(28,38,99,0.08);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      padding: 8px 20px 10px;
      gap: 8px;
      backdrop-filter: blur(14px);
    }

    .nav-item {
      border-radius: 16px;
      background: transparent;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
    }

    .nav-item.active {
      background: var(--warm);
      color: var(--dark-blue);
    }

    .nav-icon {
      width: 18px;
      height: 18px;
      border-radius: 5px;
      border: 2px solid currentColor;
      position: relative;
    }

    .nav-icon.bell::after {
      content: "";
      position: absolute;
      left: 5px;
      bottom: -5px;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: currentColor;
    }

    .nav-icon.setting::before,
    .nav-icon.route::before {
      content: "";
      position: absolute;
      inset: 4px;
      border-radius: 50%;
      background: currentColor;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 92px;
      width: min(340px, calc(100vw - 40px));
      transform: translateX(-50%) translateY(24px);
      opacity: 0;
      pointer-events: none;
      border-radius: 13px;
      padding: 14px 16px;
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: var(--shadow);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
      transition: opacity 180ms ease, transform 180ms ease;
      z-index: 100;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .source-note {
      margin: 16px 0 0;
      padding: 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.76);
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes floatIn {
      from {
        opacity: 0;
        transform: translateY(-12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (min-width: 720px) {
      .shell {
        max-width: 980px;
      }

      .hero {
        padding: 32px;
      }

      .hero-card {
        min-height: 300px;
        padding: 32px;
      }

      .hero h1 {
        max-width: 540px;
        font-size: 40px;
        line-height: 54px;
      }

      .hero-text {
        max-width: 520px;
        font-size: 16px;
        line-height: 24px;
      }

      .screen-tabs,
      .section {
        max-width: 900px;
        margin: 0 auto;
      }

      .section.active {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
      }

      .section-title,
      .section-lead,
      .variation-list,
      .settings-panel,
      .source-note {
        grid-column: 1;
      }

      .phone-frame,
      .journey-phone {
        grid-column: 2;
        grid-row: 1 / span 6;
        margin-top: 8px;
      }

      .kpi-strip {
        grid-column: 1;
      }

      .bottom-nav {
        max-width: 430px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 24px 24px 0 0;
        margin: 0 auto;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <main class="shell">
      <header class="top-bar">
        <div class="brand">
          <span class="brand-mark"></span>
          <span>UcarPAC</span>
        </div>
        <div class="status-pill">通知最適化 A案</div>
      </header>

      <section class="hero">
        <div class="hero-card">
          <div class="eyebrow">2026-05-29 日次差分</div>
          <h1>通知が、売り時の不安にそっと寄り添う。</h1>
          <p class="hero-text">
            愛車の相場変化をやさしく伝え、個人情報なしのAI査定から売却相談まで迷わず進める体験です。
          </p>
          <div class="hand-note">「今見るだけ」でも安心して戻れる導線</div>
        </div>
      </section>

      <nav class="screen-tabs" aria-label="画面切替">
        <button class="tab-button active" data-tab="copy">文言テスト</button>
        <button class="tab-button" data-tab="settings">通知設定</button>
        <button class="tab-button" data-tab="journey">査定導線</button>
      </nav>

      <section class="section active" id="copy">
        <div>
          <h2 class="section-title">通知文言テスト</h2>
          <p class="section-lead">
            不安を煽らず、価格上昇や売り時の期待を具体的に伝える通知案を比較します。
          </p>

          <div class="variation-list">
            <button class="variation-card selected" data-title="愛車の相場が12万円UPしています" data-body="プリウス Sの相場が先月より上昇。個人情報なしでAI査定を更新できます。" data-rate="18.6%" data-apply="42件">
              <div class="variation-meta">
                <span class="variation-label">A-1 期待訴求</span>
                <span class="variation-score">想定開封率 18.6%</span>
              </div>
              <p class="variation-title">愛車の相場が12万円UPしています</p>
              <p class="variation-copy">変化額を明示して、見る理由を一瞬で伝える。</p>
            </button>

            <button class="variation-card" data-title="売るなら今？3か月後の相場を予測しました" data-body="ヴォクシー ZSの将来予測を更新。高く売れるタイミングを確認しましょう。" data-rate="16.9%" data-apply="35件">
              <div class="variation-meta">
                <span class="variation-label">A-2 売り時訴求</span>
                <span class="variation-score">想定開封率 16.9%</span>
              </div>
              <p class="variation-title">売るなら今？3か月後の相場を予測しました</p>
              <p class="variation-copy">判断材料を届けて、再起動の理由を作る。</p>
            </button>

            <button class="variation-card" data-title="営業電話なしで、今の価値だけ確認できます" data-body="ハリアー プレミアムのAI査定を更新。個人情報入力なしで相場チェックできます。" data-rate="15.8%" data-apply="31件">
              <div class="variation-meta">
                <span class="variation-label">A-3 安心訴求</span>
                <span class="variation-score">想定開封率 15.8%</span>
              </div>
              <p class="variation-title">営業電話なしで、今の価値だけ確認できます</p>
              <p class="variation-copy">電話不安を先回りして、離脱心理を下げる。</p>
            </button>
          </div>

          <div class="kpi-strip">
            <div class="kpi-card">
              <p class="kpi-label">プッシュ通知開封率</p>
              <p class="kpi-value" id="openRate">18.6%</p>
              <p class="kpi-note">選択中の文言案</p>
            </div>
            <div class="kpi-card">
              <p class="kpi-label">通知経由申込数</p>
              <p class="kpi-value" id="applyCount">42</p>
              <p class="kpi-note">日次見込み</p>
            </div>
          </div>
        </div>

        <div class="phone-frame">
          <div class="phone-screen">
            <div class="mock-status">
              <span>9:41</span>
              <span>5G  82%</span>
            </div>

            <div class="notification-preview" id="notificationPreview">
              <div class="notification-head">
                <div class="app-mini">
                  <span class="app-icon"></span>
                  <span>UcarPAC</span>
                </div>
                <span class="time">今</span>
              </div>
              <p class="notification-title" id="previewTitle">愛車の相場が12万円UPしています</p>
              <p class="notification-body" id="previewBody">プリウス Sの相場が先月より上昇。個人情報なしでAI査定を更新できます。</p>
              <div class="emotion-row">
                <div class="emotion-badge">営業電話なし</div>
                <div class="emotion-badge">1分で確認</div>
              </div>
              <button class="pink-button" id="previewTap">通知をタップして確認</button>
            </div>

            <div class="warm-header">
              <p class="warm-small">今日の相場メモ</p>
              <p class="warm-title">プリウス Sの価格が上向きです</p>
              <p class="warm-text">相場変化を逃さないよう、AI査定結果を更新しておきましょう。</p>
            </div>

            <div class="price-card" style="margin: 0 12px 12px;">
              <p class="car-name">トヨタ プリウス S</p>
              <p class="car-detail">2019年式 / 走行距離 42,000km / ホワイトパール</p>
              <div class="price-main">
                <span class="price-number">168</span>
                <span class="price-unit">万円</span>
              </div>
              <div class="price-change">前月比 +12万円</div>
              <div class="mini-chart">
                <div class="chart-line"></div>
                <span class="chart-dot dot-a"></span>
                <span class="chart-dot dot-b"></span>
                <span class="chart-dot dot-c"></span>
                <div class="chart-labels">
                  <span>3月</span>
                  <span>4月</span>
                  <span>5月</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <p class="source-note">
          検証メモ: KPIは「通知開封率」「通知経由申込数」を文言別に比較。主要主張の出典URLと確認日は research-2026-05-29.md 側に紐づける想定。
        </p>
      </section>

      <section class="section" id="settings">
        <div>
          <h2 class="section-title">通知設定UI</h2>
          <p class="section-lead">
            通知頻度と種類をユーザー自身が選べるようにして、不要な通知による削除不安を下げます。
          </p>

          <div class="settings-panel">
            <div class="setting-card">
              <div class="setting-header">
                <div>
                  <p class="setting-title">相場変化のお知らせ</p>
                  <p class="setting-desc">愛車の価格が大きく変わった時だけ通知します。</p>
                </div>
                <button class="toggle active" data-toggle="相場変化">
                  <span class="toggle-knob"></span>
                </button>
              </div>
              <div class="quiet-box">現在: 5万円以上の変化があった時に通知</div>
            </div>

            <div class="setting-card">
              <div class="setting-header">
                <div>
                  <p class="setting-title">通知頻度</p>
                  <p class="setting-desc">多すぎる通知を避け、必要なタイミングだけ受け取れます。</p>
                </div>
              </div>
              <div class="chip-grid">
                <button class="chip">毎日</button>
                <button class="chip active">週2回</button>
                <button class="chip">週1回</button>
                <button class="chip">大きな変化時のみ</button>
              </div>
            </div>

            <div class="setting-card">
              <div class="setting-header">
                <div>
                  <p class="setting-title">通知したい内容</p>
                  <p class="setting-desc">売却検討の温度感に合わせて選択できます。</p>
                </div>
              </div>
              <div class="chip-grid">
                <button class="chip active">相場UP</button>
                <button class="chip active">売り時予測</button>
                <button class="chip">出費サマリー</button>
                <button class="chip active">オークション状況</button>
              </div>
            </div>

            <div class="setting-card">
              <div class="range-wrap">
                <div class="range-output">
                  <span class="range-caption">通知する価格変化</span>
                  <span class="range-value"><span id="thresholdValue">5</span>万円以上</span>
                </div>
                <input class="range" id="thresholdRange" type="range" min="3" max="20" value="5">
                <div class="quiet-box" id="settingSummary">5万円以上の相場変化だけ通知します</div>
              </div>
            </div>
          </div>
        </div>

        <div class="phone-frame">
          <div class="phone-screen">
            <div class="mock-status">
              <span>9:41</span>
              <span>5G  82%</span>
            </div>

            <div class="warm-header">
              <p class="warm-small">通知設定</p>
              <p class="warm-title">必要な知らせだけ、やさしく届く</p>
              <p class="warm-text">相場が気になる時期も、まだ売らない時期も、自分のペースで調整できます。</p>
            </div>

            <div class="setting-card" style="margin: 0 12px 12px;">
              <div class="setting-header">
                <div>
                  <p class="setting-title">今週の通知予定</p>
                  <p class="setting-desc">火曜・金曜の朝9時に相場変化を確認</p>
                </div>
              </div>
              <div class="badge-row">
                <span class="trust-badge">相場UPのみ</span>
                <span class="trust-badge">営業電話なし</span>
                <span class="trust-badge">いつでも停止</span>
              </div>
            </div>

            <div class="price-card" style="margin: 0 12px 12px;">
              <p class="car-name">ホンダ N-BOX G</p>
