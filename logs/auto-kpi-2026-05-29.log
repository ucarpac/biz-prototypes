      padding: 5px 12px;
      color: var(--pink);
      background: var(--back-light-pink);
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 700;
    }

    h1 {
      margin: 16px 0 12px;
      color: var(--dark-blue);
      font-size: 32px;
      font-weight: 800;
      line-height: 1.5;
      letter-spacing: 0;
    }

    .lead {
      margin: 0 0 16px;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 1.5;
    }

    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
    }

    .badge {
      min-height: 30px;
      padding: 6px 12px;
      color: var(--white);
      background: var(--dark-blue);
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 700;
      box-shadow: var(--shadow-light);
    }

    .badge.pink {
      background: var(--pink);
    }

    .badge.blue {
      color: var(--dark-blue);
      background: var(--gradient-primary);
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .primary-button,
    .pink-button,
    .white-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 43px;
      padding: 0 20px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 800;
      transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
      white-space: nowrap;
    }

    .primary-button {
      color: var(--dark-blue);
      background: var(--gradient-primary);
      box-shadow: 0 8px 20px rgba(64,153,255,0.28);
    }

    .pink-button {
      color: var(--white);
      background: var(--gradient-pink);
      box-shadow: 0 8px 20px rgba(248,76,162,0.28);
    }

    .white-button {
      color: var(--dark-blue);
      background: var(--white);
      border: 1px solid var(--text-black);
    }

    .primary-button:active,
    .pink-button:active,
    .white-button:active,
    .chip:active,
    .mini-button:active {
      transform: scale(0.96);
    }

    .phone-wrap {
      display: flex;
      justify-content: center;
      min-height: 620px;
    }

    .phone {
      width: min(100%, 375px);
      min-height: 610px;
      padding: 14px;
      background: #101735;
      border-radius: 34px;
      box-shadow: var(--shadow-heavy);
      position: relative;
    }

    .phone::before {
      content: "";
      position: absolute;
      top: 8px;
      left: 50%;
      width: 86px;
      height: 18px;
      background: #0b1029;
      border-radius: 0 0 14px 14px;
      transform: translateX(-50%);
      z-index: 4;
    }

    .screen {
      min-height: 582px;
      overflow: hidden;
      background: var(--back-white);
      border-radius: 24px;
      position: relative;
    }

    .app-status {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 42px;
      padding: 10px 18px 0;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
    }

    .signal {
      display: inline-flex;
      gap: 4px;
      align-items: center;
    }

    .signal span {
      width: 5px;
      background: var(--dark-blue);
      border-radius: 5px;
    }

    .signal span:nth-child(1) {
      height: 7px;
    }

    .signal span:nth-child(2) {
      height: 10px;
    }

    .signal span:nth-child(3) {
      height: 13px;
    }

    .app-shell {
      padding: 8px 16px 18px;
    }

    .app-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }

    .app-title {
      color: var(--dark-blue);
      font-size: 18px;
      font-weight: 800;
    }

    .coin {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      color: var(--white);
      background: var(--pink);
      border-radius: 50%;
      font-size: 16px;
      font-weight: 900;
      box-shadow: 0 6px 18px rgba(248,76,162,0.35);
      animation: pulse 1800ms ease-in-out infinite;
    }

    .progress-track {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
      margin-bottom: 16px;
    }

    .progress-step {
      height: 7px;
      background: #d9e1eb;
      border-radius: 8px;
      overflow: hidden;
    }

    .progress-step span {
      display: block;
      width: 0;
      height: 100%;
      background: var(--gradient-primary);
      border-radius: inherit;
      transition: width 360ms ease;
    }

    .progress-step.active span {
      width: 100%;
    }

    .scene {
      display: none;
      min-height: 454px;
      animation: sceneIn 280ms ease both;
    }

    .scene.active {
      display: block;
    }

    .scene-label {
      margin-bottom: 8px;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
    }

    .diagnosis-card,
    .setting-card,
    .route-card,
    .result-card,
    .source-card {
      width: 100%;
      padding: 16px;
      background: var(--white);
      border: 1px solid #cddced;
      border-radius: 13px;
      box-shadow: var(--shadow-light);
    }

    .diagnosis-card {
      min-height: 260px;
      touch-action: pan-y;
      position: relative;
      transform: translateX(0) rotate(0);
      transition: transform 220ms ease, opacity 220ms ease, border-color 220ms ease;
    }

    .card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .variant-tag {
      min-width: 54px;
      min-height: 30px;
      padding: 6px 10px;
      text-align: center;
      color: var(--white);
      background: var(--dark-blue);
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 900;
    }

    .score {
      color: var(--pink);
      font-size: 26px;
      font-weight: 900;
      line-height: 1.5;
    }

    .notification-preview {
      padding: 14px;
      background: #f2f6fb;
      border-radius: var(--radius-md);
      border: 1px solid #d9e5f2;
      margin-bottom: 14px;
    }

    .notification-app {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
    }

    .app-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      color: var(--white);
      background: var(--pink);
      border-radius: 6px;
      font-size: 12px;
      font-weight: 900;
    }

    .notification-title {
      color: var(--dark-blue);
      font-size: 16px;
      font-weight: 800;
      line-height: 1.5;
    }

    .notification-body {
      margin-top: 4px;
      color: var(--text-black);
      font-size: 13px;
      line-height: 1.5;
    }

    .metric-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 14px;
    }

    .metric {
      padding: 10px 8px;
      background: var(--back-white);
      border-radius: var(--radius-md);
      text-align: center;
    }

    .metric strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
    }

    .metric span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
    }

    .swipe-hint {
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 700;
    }

    .swipe-pill {
      min-width: 94px;
      padding: 7px 10px;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      border-radius: var(--radius-chip);
      text-align: center;
      animation: nudge 1300ms ease-in-out infinite;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 12px 0 16px;
    }

    .chip {
      min-height: 43px;
      padding: 0 14px;
      color: var(--text-black);
      background: var(--white);
      border: 1px solid var(--ruled-line);
      border-radius: var(--radius-chip);
      font-size: 13px;
      font-weight: 800;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .chip.selected {
      color: var(--white);
      background: var(--dark-blue);
    }

    .setting-list {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .setting-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 13px;
      background: var(--back-white);
      border-radius: var(--radius-md);
      border: 1px solid #e4e9f1;
    }

    .setting-title {
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
    }

    .setting-desc {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
      margin-top: 2px;
    }

    .switch {
      width: 52px;
      height: 30px;
      padding: 3px;
      background: #d2d7e4;
      border-radius: 20px;
      transition: background 180ms ease;
    }

    .switch span {
      display: block;
      width: 24px;
      height: 24px;
      background: var(--white);
      border-radius: 50%;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
      transition: transform 180ms ease;
    }

    .switch.on {
      background: var(--pink);
    }

    .switch.on span {
      transform: translateX(22px);
    }

    .slider-wrap {
      margin: 16px 0;
      padding: 14px;
      background: var(--white);
      border: 1px solid #e4e9f1;
      border-radius: var(--radius-md);
    }

    .slider-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
    }

    input[type="range"] {
      width: 100%;
      accent-color: var(--pink);
    }

    .route-stage {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .route-node {
      display: grid;
      grid-template-columns: 42px 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 12px;
      background: var(--white);
      border: 1px solid #d9e5f2;
      border-radius: var(--radius-md);
      opacity: 0.45;
      transform: translateY(6px);
      transition: opacity 260ms ease, transform 260ms ease, border-color 260ms ease;
    }

    .route-node.done {
      opacity: 1;
      transform: translateY(0);
      border-color: var(--button-link);
    }

    .node-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      color: var(--white);
      background: var(--dark-blue);
      border-radius: 50%;
      font-size: 18px;
      font-weight: 900;
    }

    .node-title {
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 800;
    }

    .node-desc {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
    }

    .checkmark {
      width: 24px;
      height: 24px;
      color: var(--white);
      background: var(--pink);
      border-radius: 50%;
      text-align: center;
      line-height: 24px;
      font-weight: 900;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .route-node.done .checkmark {
      opacity: 1;
      transform: scale(1);
    }

    .chart {
      height: 132px;
      margin: 14px 0;
      padding: 12px;
      background: linear-gradient(180deg, #ffffff 0%, #f2f7ff 100%);
      border: 1px solid #dce8f5;
      border-radius: var(--radius-md);
      position: relative;
      overflow: hidden;
    }

    .chart svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .car-price {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      margin-top: 12px;
      padding: 14px;
      background: var(--back-blue);
      border-radius: var(--radius-md);
      color: var(--white);
    }

    .price-label {
      font-size: 12px;
      color: var(--text-light-blue, #bfdbfe);
    }

    .price-value {
      font-size: 28px;
      font-weight: 900;
      line-height: 1.5;
    }

    .price-diff {
      min-width: 74px;
      padding: 8px 10px;
      color: var(--white);
      background: var(--pink);
      border-radius: var(--radius-chip);
      text-align: center;
      font-size: 13px;
      font-weight: 900;
    }

    .bottom-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 16px;
    }

    .mini-button {
      min-height: 43px;
      border-radius: var(--radius-button);
      font-size: 13px;
      font-weight: 800;
      transition: transform 180ms ease, opacity 180ms ease;
    }

    .mini-button.primary {
      color: var(--dark-blue);
      background: var(--gradient-primary);
    }

    .mini-button.pink {
      color: var(--white);
      background: var(--gradient-pink);
    }

    .mini-button.ghost {
      color: var(--dark-blue);
      background: var(--white);
      border: 1px solid #cddced;
    }

    .toast {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 78px;
      padding: 14px;
      color: var(--white);
      background: rgba(9,19,85,0.94);
      border-radius: var(--radius-md);
      font-size: 12px;
      font-weight: 700;
      opacity: 0;
      pointer-events: none;
      transform: translateY(20px);
      transition: opacity 220ms ease, transform 220ms ease;
      z-index: 8;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    .tabbar {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      height: 64px;
      background: var(--white);
      border-top: 1px solid #e4e9f1;
      border-radius: 0 0 24px 24px;
      overflow: hidden;
    }

    .tab {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--text-disabled);
      font-size: 10px;
      font-weight: 800;
      gap: 2px;
    }

    .tab.active {
      color: var(--pink);
    }

    .tab-icon {
      font-size: 17px;
      line-height: 1;
    }

    .research {
      display: grid;
      gap: 14px;
      margin-top: 24px;
    }

    .section-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 22px;
      font-weight: 800;
      line-height: 1.5;
    }

    .research-grid {
      display: grid;
      gap: 12px;
    }

    .source-card {
      padding: 14px;
    }

    .source-card h3 {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
    }

    .source-card p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.5;
    }

    .source-card a {
      color: #0056BA;
      font-weight: 700;
      word-break: break-all;
    }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-top: 14px;
    }

    .kpi-card {
      padding: 16px;
      color: var(--white);
      background: var(--back-blue);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-light);
    }

    .kpi-card strong {
      display: block;
      font-size: 26px;
      line-height: 1.5;
    }

    .kpi-card span {
      display: block;
      color: var(--text-light-blue, #bfdbfe);
      font-size: 12px;
      line-height: 1.5;
    }

    .screen-flash {
      animation: flash 520ms ease;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.08);
      }
    }

    @keyframes sceneIn {
      from {
        opacity: 0;
        transform: translateX(16px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes nudge {
      0%, 100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(7px);
      }
    }

    @keyframes flash {
      0% {
        background-color: rgba(248,76,162,0.18);
      }
      100% {
        background-color: transparent;
      }
    }

    @media (min-width: 760px) {
      .page {
        padding: 28px 24px 56px;
      }

      .hero {
        grid-template-columns: 1fr 410px;
        gap: 38px;
      }

      h1 {
        font-size: 40px;
      }

      .lead {
        font-size: 16px;
      }

      .research-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .kpi-strip {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    @media (max-width: 360px) {
      .hero-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .primary-button,
      .pink-button,
      .white-button {
        width: 100%;
      }

      .metric-row {
        grid-template-columns: 1fr;
      }

      .bottom-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App 通知最適化プロトタイプ',
      description: 'プッシュ通知の開封率と通知経由申込数を検証する社内プロトタイプ',
      ttlHours: 24
    };
  </script>

  <main class="page">
    <div class="topbar">
      <a class="back-link" href="../index.html">Reports に戻る</a>
      <div class="date-pill">更新日 2026-05-29</div>
    </div>

    <section class="hero">
      <div class="hero-copy">
        <span class="eyebrow">日次差分 / プッシュ通知の最適化</span>
        <h1>通知タップからAI査定、申込までをゲーム感覚で進める</h1>
        <p class="lead">
          愛車の相場変動、売り時、出費管理の通知をユーザー自身が選び、通知文言テストから申込導線までを一画面で検証するプロトタイプです。
        </p>
        <div class="hero-badges">
          <span class="badge pink">個人情報不要</span>
          <span class="badge blue">AI査定</span>
          <span class="badge">電話1社のみ</span>
          <span class="badge">8,000店が入札</span>
        </div>
        <div class="hero-actions">
          <button class="primary-button" id="startDemo">診断を開始</button>
          <button class="white-button" id="jumpSettings">通知設定を見る</button>
        </div>
        <div class="kpi-strip">
          <div class="kpi-card">
            <strong id="heroOpenRate">13.8%</strong>
            <span>想定開封率</span>
          </div>
          <div class="kpi-card">
            <strong id="heroApplyRate">4.1%</strong>
            <span>通知経由申込率</span>
          </div>
          <div class="kpi-card">
            <strong>3案</strong>
            <span>通知文言テスト</span>
          </div>
          <div class="kpi-card">
            <strong>24h</strong>
            <span>認証保持</span>
          </div>
        </div>
      </div>

      <div class="phone-wrap">
        <div class="phone">
          <div class="screen" id="screen">
            <div class="app-status">
              <span>9:41</span>
              <span class="signal"><span></span><span></span><span></span></span>
            </div>

            <div class="app-shell">
              <div class="app-header">
                <div>
                  <div class="app-title">通知クエスト</div>
                  <div class="scene-label" id="sceneLabel">Step 1 / 通知文言テスト</div>
                </div>
                <div class="coin" id="questCoin">0</div>
              </div>

              <div class="progress-track">
                <div class="progress-step active"><span></span></div>
                <div class="progress-step"><span></span></div>
                <div class="progress-step"><span></span></div>
              </div>

              <section class="scene active" id="sceneTest">
                <div class="diagnosis-card" id="variantCard">
                  <div class="card-top">
                    <div>
                      <div class="variant-tag" id="variantTag">A案</div>
                    </div>
                    <div class="score" id="variantScore">13.8%</div>
                  </div>

                  <div class="notification-preview">
                    <div class="notification-app">
                      <span class="app-icon">U</span>
                      <span>UcarPAC</span>
                      <span>今</span>
                    </div>
                    <div class="notification-title" id="noticeTitle">愛車の相場が12万円UP</div>
                    <div class="notification-body" id="noticeBody">
                      プリウス Sの相場が先週より上昇。個人情報なしでAI査定を更新できます。
                    </div>
                  </div>

                  <div class="metric-row">
                    <div class="metric">
                      <strong id="metricOpen">13.8%</strong>
                      <span>開封率</span>
                    </div>
                    <div class="metric">
                      <strong id="metricRestart">7.4%</strong>
                      <span>再起動率</span>
                    </div>
                    <div class="metric">
                      <strong id="metricApply">4.1%</strong>
                      <span>申込率</span>
                    </div>
                  </div>

                  <div class="swipe-hint">
                    <span>左右にスワイプして文言を比較</span>
                    <span class="swipe-pill">次の案へ</span>
                  </div>
                </div>

                <div class="chips" aria-label="通知文言選択">
