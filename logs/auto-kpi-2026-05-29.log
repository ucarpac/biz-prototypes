    }

    .comparison td {
      color: var(--text-black);
      font-weight: 700;
    }

    .comparison tr:last-child td {
      border-bottom: 0;
    }

    .source-list {
      display: grid;
      gap: 8px;
    }

    .source-item {
      padding: 11px 12px;
      border-radius: 12px;
      background: var(--white);
      border: 1px solid #e7edf5;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      word-break: break-word;
    }

    .source-item strong {
      display: block;
      color: var(--dark-blue);
      font-size: 11px;
      line-height: 16.5px;
      margin-bottom: 2px;
    }

    .log-card {
      border-left: 4px solid var(--pink);
    }

    .log-line {
      display: grid;
      grid-template-columns: 86px 1fr;
      gap: 8px;
      padding: 7px 0;
      border-bottom: 1px solid #edf1f4;
      font-size: 11px;
      line-height: 16.5px;
    }

    .log-line:last-child {
      border-bottom: 0;
    }

    .log-key {
      color: var(--dark-blue);
      font-weight: 900;
    }

    .log-value {
      color: var(--text-black);
      font-weight: 700;
    }

    @media (min-width: 720px) {
      .page {
        padding: 28px;
      }

      .shell {
        width: min(100%, 960px);
        display: grid;
        grid-template-columns: 340px 1fr;
        align-items: stretch;
      }

      .hero {
        min-height: 100%;
        padding: 32px 24px;
      }

      .content {
        padding: 24px;
      }

      .kpi-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .variant-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .journey {
        grid-template-columns: repeat(3, 1fr);
      }

      .cta-row {
        flex-direction: row;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="shell">
      <header class="hero">
        <a class="back-link" href="../index.html">Reports に戻る</a>
        <h1 class="hero-title">通知最適化<br>データ検証ダッシュボード</h1>
        <p class="hero-copy">
          相場変動・売り時・出費管理を通知で再起動につなげ、AI査定から申込までの導線を短くする検証画面。
        </p>
        <div class="hero-badges">
          <span class="badge pink">個人情報不要</span>
          <span class="badge">AI査定</span>
          <span class="badge">電話1社のみ</span>
          <span class="badge">8,000社入札</span>
        </div>
      </header>

      <div class="content">
        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">KPIスナップショット</h2>
              <p class="section-note">通知開封率・通知経由申込数の改善余地を可視化</p>
            </div>
            <span class="mini-date">2026-05-29</span>
          </div>

          <div class="kpi-grid">
            <article class="card kpi-card">
              <div class="kpi-label">通知開封率</div>
              <div class="kpi-value" id="kpiOpen">10.8<span class="unit">%</span></div>
              <div class="kpi-delta">目標 12.0%</div>
              <div class="progress"><span id="barOpen" style="width: 90%;"></span></div>
            </article>

            <article class="card kpi-card">
              <div class="kpi-label">通知経由再起動</div>
              <div class="kpi-value" id="kpiLaunch">1,284</div>
              <div class="kpi-delta">前週比 +18%</div>
              <div class="progress"><span id="barLaunch" style="width: 76%;"></span></div>
            </article>

            <article class="card kpi-card">
              <div class="kpi-label">AI査定遷移率</div>
              <div class="kpi-value" id="kpiAssess">37.2<span class="unit">%</span></div>
              <div class="kpi-delta">目標 42.0%</div>
              <div class="progress"><span id="barAssess" style="width: 72%;"></span></div>
            </article>

            <article class="card kpi-card">
              <div class="kpi-label">通知経由申込数</div>
              <div class="kpi-value" id="kpiApply">146</div>
              <div class="kpi-delta">目標 220件</div>
              <div class="progress"><span id="barApply" style="width: 66%;"></span></div>
            </article>
          </div>

          <article class="card wide-card">
            <div class="chart-legend">
              <span>通知配信から申込までの7日推移</span>
              <span>開封率 / 申込数</span>
            </div>
            <div class="chart-wrap">
              <svg viewBox="0 0 360 170" role="img" aria-label="通知KPI推移グラフ">
                <line x1="34" y1="18" x2="34" y2="138" stroke="#dce4ef" stroke-width="1"/>
                <line x1="34" y1="138" x2="344" y2="138" stroke="#dce4ef" stroke-width="1"/>
                <line x1="34" y1="108" x2="344" y2="108" stroke="#eef2f7" stroke-width="1"/>
                <line x1="34" y1="78" x2="344" y2="78" stroke="#eef2f7" stroke-width="1"/>
                <line x1="34" y1="48" x2="344" y2="48" stroke="#eef2f7" stroke-width="1"/>
                <path d="M34 118 C74 112 80 96 112 98 C154 101 158 70 191 72 C226 74 232 56 268 58 C304 60 312 42 344 38" fill="none" stroke="#F84CA2" stroke-width="4" stroke-linecap="round"/>
                <path d="M34 130 C70 126 82 119 112 121 C150 123 160 105 191 103 C230 100 236 90 268 88 C304 85 314 76 344 70" fill="none" stroke="#4099FF" stroke-width="4" stroke-linecap="round"/>
                <circle cx="34" cy="118" r="4" fill="#F84CA2"/>
                <circle cx="112" cy="98" r="4" fill="#F84CA2"/>
                <circle cx="191" cy="72" r="4" fill="#F84CA2"/>
                <circle cx="268" cy="58" r="4" fill="#F84CA2"/>
                <circle cx="344" cy="38" r="4" fill="#F84CA2"/>
                <circle cx="34" cy="130" r="4" fill="#4099FF"/>
                <circle cx="112" cy="121" r="4" fill="#4099FF"/>
                <circle cx="191" cy="103" r="4" fill="#4099FF"/>
                <circle cx="268" cy="88" r="4" fill="#4099FF"/>
                <circle cx="344" cy="70" r="4" fill="#4099FF"/>
                <text x="34" y="160" font-size="10" fill="#737373">月</text>
                <text x="108" y="160" font-size="10" fill="#737373">火</text>
                <text x="187" y="160" font-size="10" fill="#737373">水</text>
                <text x="264" y="160" font-size="10" fill="#737373">木</text>
                <text x="336" y="160" font-size="10" fill="#737373">金</text>
              </svg>
            </div>
          </article>
        </section>

        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">1. 通知文言テスト</h2>
              <p class="section-note">相場変動を中心に、売却意欲別の訴求を比較</p>
            </div>
          </div>

          <div class="variant-grid">
            <button class="variant-card active" data-variant="up">
              <div class="variant-top">
                <span class="variant-name">相場UP型</span>
                <span class="variant-score">A案</span>
              </div>
              <p class="variant-body">愛車の相場が12万円UP。今のAI査定額を確認しませんか？</p>
              <div class="variant-meta">
                <span class="chip">価格変動</span>
                <span class="chip">再起動狙い</span>
                <span class="chip">申込期待 高</span>
              </div>
            </button>

            <button class="variant-card" data-variant="timing">
              <div class="variant-top">
                <span class="variant-name">売り時提案型</span>
                <span class="variant-score">B案</span>
              </div>
              <p class="variant-body">3ヶ月後より今が有利。ハリアーの売り時予測を更新しました。</p>
              <div class="variant-meta">
                <span class="chip">将来予測</span>
                <span class="chip">AI査定訴求</span>
                <span class="chip">検討層向け</span>
              </div>
            </button>

            <button class="variant-card" data-variant="cost">
              <div class="variant-top">
                <span class="variant-name">出費管理型</span>
                <span class="variant-score">C案</span>
              </div>
              <p class="variant-body">今月の維持費は42,800円。相場とあわせて売却判断できます。</p>
              <div class="variant-meta">
                <span class="chip">リテンション</span>
                <span class="chip">出費管理</span>
                <span class="chip">削除率対策</span>
              </div>
            </button>

            <button class="variant-card" data-variant="auction">
              <div class="variant-top">
                <span class="variant-name">オークション型</span>
                <span class="variant-score">D案</span>
              </div>
              <p class="variant-body">8,000店が競る最高額へ。電話1社のみで売却相談できます。</p>
              <div class="variant-meta">
                <span class="chip">差別化</span>
                <span class="chip">電話1社</span>
                <span class="chip">申込直前</span>
              </div>
            </button>
          </div>

          <div class="simulation">
            <div class="phone-notice" id="noticePreview">
              <div class="notice-app"><span class="app-dot"></span>UcarPAC App・いま</div>
              <div class="notice-title" id="noticeTitle">愛車の相場が12万円UP</div>
              <p class="notice-body" id="noticeBody">トヨタ ハリアーのAI査定額を更新しました。個人情報なしで今の相場を確認できます。</p>
            </div>
            <div class="sim-metrics">
              <div class="sim-metric">
                <div class="sim-label">予測開封率</div>
                <div class="sim-value" id="simOpen">10.8%</div>
              </div>
              <div class="sim-metric">
                <div class="sim-label">予測申込数 / 週</div>
                <div class="sim-value" id="simApply">146</div>
              </div>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">2. 通知設定UI</h2>
              <p class="section-note">ユーザーが頻度と種類を選び、通知疲れを抑える</p>
            </div>
          </div>

          <article class="card settings-card">
            <div class="field-group">
              <div class="field-label">
                <span>通知頻度</span>
                <span class="field-value" id="frequencyLabel">週2〜3回</span>
              </div>
              <div class="segmented">
                <button class="segment" data-frequency="daily">毎日</button>
                <button class="segment active" data-frequency="weekly">週2〜3回</button>
                <button class="segment" data-frequency="important">重要のみ</button>
              </div>
            </div>

            <div class="field-group">
              <div class="field-label">
                <span>通知の種類</span>
                <span class="field-value" id="typeCount">3件ON</span>
              </div>
              <div class="toggle-list">
                <button class="toggle-row" data-toggle="price">
                  <span class="toggle-text">
                    <span class="toggle-title">相場変動</span>
                    <span class="toggle-sub">愛車の価格が大きく動いた時</span>
                  </span>
                  <span class="switch on"></span>
                </button>

                <button class="toggle-row" data-toggle="timing">
                  <span class="toggle-text">
                    <span class="toggle-title">売り時予測</span>
                    <span class="toggle-sub">3ヶ月後・6ヶ月後の予測更新</span>
                  </span>
                  <span class="switch on"></span>
                </button>

                <button class="toggle-row" data-toggle="cost">
                  <span class="toggle-text">
                    <span class="toggle-title">出費サマリー</span>
                    <span class="toggle-sub">給油・保険・車検の月次まとめ</span>
                  </span>
                  <span class="switch on"></span>
                </button>

                <button class="toggle-row" data-toggle="auction">
                  <span class="toggle-text">
                    <span class="toggle-title">オークション進捗</span>
                    <span class="toggle-sub">入札更新・最高額更新・終了前</span>
                  </span>
                  <span class="switch"></span>
                </button>
              </div>
            </div>

            <div class="field-group">
              <div class="field-label">
                <span>週あたり上限</span>
                <span class="field-value"><span id="rangeValue">3</span>通</span>
              </div>
              <input class="range" id="weeklyRange" type="range" min="1" max="7" value="3">
            </div>

            <div class="preference-result">
              <div class="pref-box">
                <strong id="fatigueScore">低</strong>
                <span>通知疲れリスク</span>
              </div>
              <div class="pref-box">
                <strong id="expectedLift">+18%</strong>
                <span>再起動見込み</span>
              </div>
            </div>
          </article>
        </section>

        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">3. 通知→査定導線</h2>
              <p class="section-note">通知タップ後にAI査定と申込CTAまで迷わせない</p>
            </div>
          </div>

          <div class="journey">
            <article class="journey-step">
              <div class="step-num">1</div>
              <div>
                <div class="step-title">通知タップ</div>
                <div class="step-text">「相場が12万円UP」から車両別の査定画面へ直接遷移。</div>
                <div class="step-data">
                  <span class="data-pill">想定CTR 10.8%</span>
                  <span class="data-pill">深いリンク</span>
                </div>
              </div>
            </article>

            <article class="journey-step">
              <div class="step-num">2</div>
              <div>
                <div class="step-title">AI査定更新</div>
                <div class="step-text">ハリアー Z Leather Packageの現在価格と6ヶ月予測を表示。</div>
                <div class="step-data">
                  <span class="data-pill">現在 318万円</span>
                  <span class="data-pill">6ヶ月後 292万円</span>
                </div>
              </div>
            </article>

            <article class="journey-step">
              <div class="step-num">3</div>
              <div>
                <div class="step-title">売却相談CTA</div>
                <div class="step-text">電話1社・8,000社入札を添えて、申込フォームへ接続。</div>
                <div class="step-data">
                  <span class="data-pill">申込CVR 11.4%</span>
                  <span class="data-pill">手数料無料</span>
                </div>
              </div>
            </article>
          </div>

          <div class="cta-row">
            <button class="primary-button" id="runJourney">通知タップを再現</button>
            <button class="pink-button" id="applyButton">売却相談へ進む</button>
          </div>
        </section>

        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">比較表</h2>
              <p class="section-note">通知で伝えるべき差別化ポイント</p>
            </div>
          </div>

          <table class="comparison">
            <thead>
              <tr>
                <th>訴求</th>
                <th>UcarPAC</th>
                <th>競合との差</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>AI査定</td>
                <td>現在相場と将来予測をアプリ内で確認</td>
                <td>主要買取競合では独自訴求</td>
              </tr>
              <tr>
                <td>通知導線</td>
                <td>車両別の査定結果へ直接遷移</td>
                <td>再入力を減らし、再起動後の離脱を抑制</td>
              </tr>
              <tr>
                <td>電話負担</td>
                <td>電話1社のみ</td>
                <td>一括査定の電話ラッシュ不安を回避</td>
              </tr>
              <tr>
                <td>申込理由</td>
                <td>8,000社入札・最高額オークション</td>
                <td>価格納得感を通知から申込まで維持</td>
              </tr>
            </tbody>
          </table>
        </section>

        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">反映ログ</h2>
              <p class="section-note">index更新・generation-log追記・kpi-history反映用メモ</p>
            </div>
          </div>

          <article class="card log-card">
            <div class="log-line">
              <span class="log-key">index</span>
              <span class="log-value">通知最適化ダッシュボードを追加。切り口: プッシュ通知の最適化。</span>
            </div>
            <div class="log-line">
              <span class="log-key">generation</span>
              <span class="log-value">B案 / データドリブン / 2026-05-29 / SVGチャート・進捗バー・通知設定UI。</span>
            </div>
            <div class="log-line">
              <span class="log-key">kpi-history</span>
              <span class="log-value">対象KPI: プッシュ通知開封率 10.8%、通知経由申込数 146件、目標 220件。</span>
            </div>
          </article>
        </section>

        <section class="section">
          <div class="section-head">
            <div>
              <h2 class="section-title">出典</h2>
              <p class="section-note">主要主張の参照URLと参照日</p>
            </div>
          </div>

          <div class="source-list">
            <div class="source-item">
              <strong>Firebase Cloud Messaging Documentation</strong>
              通知の配信・トピック・メッセージング設計の参照。URL: https://firebase.google.com/docs/cloud-messaging / 参照日: 2026-05-29
            </div>
            <div class="source-item">
              <strong>OneSignal Push Notification Best Practices</strong>
              パーソナライズ、セグメント、配信頻度、通知許諾のベストプラクティス参照。URL: https://onesignal.com/blog/push-notification-best-practices/ / 参照日: 2026-05-29
            </div>
            <div class="source-item">
              <strong>Airship Mobile App Experience Benchmarks</strong>
              プッシュ通知の許諾・継続利用・エンゲージメント改善のベンチマーク参照。URL: https://www.airship.com/resources/ / 参照日: 2026-05-29
            </div>
            <div class="source-item">
              <strong>Apple Human Interface Guidelines - Notifications</strong>
              ユーザー制御、通知の文脈性、頻度配慮の参照。URL: https://developer.apple.com/design/human-interface-guidelines/notifications / 参照日: 2026-05-29
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <script>
    const variants = {
      up: {
        title: "愛車の相場が12万円UP",
        body: "トヨタ ハリアーのAI査定額を更新しました。個人情報なしで今の相場を確認できます。",
        open: "10.8%",
        apply: "146",
        kpiOpen: "10.8",
        kpiLaunch: "1,284",
        kpiAssess: "37.2",
        kpiApply: "146",
        bars: [90, 76, 72, 66]
      },
      timing: {
        title: "今売る方が26万円有利かも",
        body: "6ヶ月後の予測相場と比較できます。ハリアーの売り時をAI査定で確認しましょう。",
        open: "12.4%",
        apply: "174",
        kpiOpen: "12.4",
        kpiLaunch: "1,438",
        kpiAssess: "40.6",
        kpiApply: "174",
        bars: [100, 84, 78, 79]
      },
      cost: {
        title: "今月の維持費は42,800円",
        body: "ガソリン代と保険料を反映しました。相場と出費をあわせて売却タイミングを確認できます。",
        open: "9.6%",
        apply: "121",
        kpiOpen: "9.6",
        kpiLaunch: "1,096",
        kpiAssess: "32.8",
        kpiApply: "121",
        bars: [80, 65, 63, 55]
      },
      auction: {
        title: "8,000店が競る最高額へ",
        body: "電話は1社のみ。AI査定額を見てから、アプリで売却相談へ進めます。",
        open: "11.7%",
        apply: "192",
        kpiOpen: "11.7",
        kpiLaunch: "1,356",
        kpiAssess: "39.4",
        kpiApply: "192",
        bars: [97, 80, 76, 87]
      }
    };

    const noticePreview = document.getElementById("noticePreview");
    const noticeTitle = document.getElementById("noticeTitle");
    const noticeBody = document.getElementById("noticeBody");
    const simOpen = document.getElementById("simOpen");
    const simApply = document.getElementById("simApply");
    const kpiOpen = document.getElementById("kpiOpen");
    const kpiLaunch = document.getElementById("kpiLaunch");
    const kpiAssess = document.getElementById("kpiAssess");
    const kpiApply = document.getElementById("kpiApply");
    const barOpen = document.getElementById("barOpen");
    const barLaunch = document.getElementById("barLaunch");
    const barAssess = document.getElementById("barAssess");
    const barApply = document.getElementById("barApply");

    document.querySelectorAll(".variant-card").forEach((card) => {
      card.addEventListener("click", () => {
        document.querySelectorAll(".variant-card").forEach((item) => item.classList.remove("active"));
        card.classList.add("active");
        const data = variants[card.dataset.variant];
        noticeTitle.textContent = data.title;
        noticeBody.textContent = data.body;
        simOpen.textContent = data.open;
        simApply.textContent = data.apply;
        kpiOpen.innerHTML = data.kpiOpen + '<span class="unit">%</span>';
        kpiLaunch.textContent = data.kpiLaunch;
        kpiAssess.innerHTML = data.kpiAssess + '<span class="unit">%</span>';
        kpiApply.textContent = data.kpiApply;
        barOpen.style.width = data.bars[0] + "%";
        barLaunch.style.width = data.bars[1] + "%";
        barAssess.style.width = data.bars[2] + "%";
        barApply.style.width = data.bars[3] + "%";
        noticePreview.style.animation = "none";
        requestAnimationFrame(() => {
          noticePreview.style.animation = "slideIn 420ms ease both";
        });
      });
    });

    const frequencyLabel = document.getElementById("frequencyLabel");
    document.querySelectorAll(".segment").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".segment").forEach((item) => item.classList.remove("active"));
        button.classList.add("active");
        if (button.dataset.frequency === "daily") {
          frequencyLabel.textContent = "毎日";
        }
        if (button.dataset.frequency === "weekly") {
          frequencyLabel.textContent = "週2〜3回";
        }
        if (button.dataset.frequency === "important") {
          frequencyLabel.textContent = "重要のみ";
        }
        updatePreference();
      });
    });

    const typeCount = document.getElementById("typeCount");
    document.querySelectorAll(".toggle-row").forEach((row) => {
      row.addEventListener("click", () => {
        row.querySelector(".switch").classList.toggle("on");
        updatePreference();
      });
    });

    const weeklyRange = document.getElementById("weeklyRange");
    const rangeValue = document.getElementById("rangeValue");
    const fatigueScore = document.getElementById("fatigueScore");
    const expectedLift = document.getElementById("expectedLift");

    weeklyRange.addEventListener("input", () => {
      rangeValue.textContent = weeklyRange.value;
      updatePreference();
    });

    function updatePreference() {
      const onCount = document.querySelectorAll(".switch.on").length;
      const frequency = document.querySelector(".segment.active").dataset.frequency;
      const weeklyMax = Number(weeklyRange.value);
      typeCount.textContent = onCount + "件ON";

      let fatigue = "低";
      let lift = 12 + onCount * 2;

      if (frequency === "daily") {
        fatigue = weeklyMax >= 5 ? "高" : "中";
        lift += 5;
      }

      if (frequency === "weekly") {
        fatigue = weeklyMax >= 5 ? "中" : "低";
        lift += 2;
      }

      if (frequency === "important") {
        fatigue = "低";
        lift -= 2;
      }

      if (weeklyMax >= 6) {
        fatigue = "高";
      }

      if (onCount <= 1) {
        lift -= 4;
      }

      fatigueScore.textContent = fatigue;
      expectedLift.textContent = "+" + Math.max(4, lift) + "%";
    }

    document.getElementById("runJourney").addEventListener("click", () => {
      noticePreview.scrollIntoView({ behavior: "smooth", block: "center" });
      noticePreview.style.animation = "none";
      requestAnimationFrame(() => {
        noticePreview.style.animation = "slideIn 420ms ease both";
      });
    });

    document.getElementById("applyButton").addEventListener("click", () => {
      document.getElementById("applyButton").textContent = "申込導線を確認中";
      setTimeout(() => {
        document.getElementById("applyButton").textContent = "売却相談へ進む";
      }, 1200);
    });
  </script>
</body>
</html>
