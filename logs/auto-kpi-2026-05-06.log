      line-height: 16.5px;
      font-weight: 700;
      text-align: right;
    }

    .chart {
      height: 148px;
      position: relative;
      border-left: 2px solid rgba(28,38,99,0.14);
      border-bottom: 2px solid rgba(28,38,99,0.14);
      overflow: hidden;
    }

    .chart::before,
    .chart::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      height: 1px;
      background: rgba(28,38,99,0.08);
    }

    .chart::before {
      top: 42px;
    }

    .chart::after {
      top: 88px;
    }

    .line {
      position: absolute;
      left: 10px;
      right: 8px;
      bottom: 20px;
      height: 92px;
    }

    .line svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .dot {
      position: absolute;
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: var(--pink);
      border: 3px solid var(--white);
      box-shadow: 0 2px 8px rgba(248,76,162,0.35);
    }

    .dot.d1 {
      left: 8%;
      bottom: 52px;
    }

    .dot.d2 {
      left: 38%;
      bottom: 66px;
    }

    .dot.d3 {
      left: 68%;
      bottom: 38px;
    }

    .dot.d4 {
      left: 90%;
      bottom: 24px;
    }

    .expense-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 12px;
      margin-top: 12px;
    }

    .expense-item {
      padding: 10px 12px;
      border-radius: 12px;
      background: var(--back-gray);
    }

    .expense-item strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
    }

    .expense-item span {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 16.5px;
      font-weight: 700;
    }

    .compare-panel {
      position: relative;
      z-index: 2;
      width: min(90%, 351px);
      margin: 24px auto 0;
      padding: 16px;
      border-radius: 13px;
      background: rgba(255,255,255,0.95);
      box-shadow: 0 12px 32px rgba(28,38,99,0.14);
      border: 2px solid rgba(248,76,162,0.2);
    }

    .compare-title {
      margin: 0 0 12px;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 900;
      text-align: center;
    }

    .compare-list {
      display: grid;
      gap: 8px;
    }

    .compare-row {
