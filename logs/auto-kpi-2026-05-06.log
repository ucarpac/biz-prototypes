    }

    .message-text {
      margin: 0;
      color: var(--text-black);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 700;
    }

    .graph-card {
      position: relative;
      z-index: 2;
      width: min(90%, 351px);
      margin: 20px auto 0;
      padding: 16px;
      background: rgba(255,255,255,0.94);
      border-radius: 13px;
      box-shadow: 0 10px 28px rgba(28,38,99,0.13);
    }

    .graph-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
