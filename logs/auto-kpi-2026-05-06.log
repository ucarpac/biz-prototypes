  <div class="toast" id="toast">検証案を選択しました</div>

  <script>
    window.PROTO_AUTH_CONFIG = {
      title: "UcarPAC App ASO改善プロトタイプ",
      description: "ストアPVからDL率改善の検証画面"
    };

    const shots = document.querySelectorAll(".store-shot");
    const tabs = document.querySelectorAll(".tab");
    const toast = document.getElementById("toast");
    const mainProgress = document.getElementById("mainProgress");
    const currentBar = document.getElementById("currentBar");

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => {
        toast.classList.remove("show");
      }, 1800);
    }

    function selectShot(target) {
      shots.forEach((shot) => {
        shot.classList.toggle("is-selected", shot === target);
      });
      const title = target.querySelector(".shot-title").textContent;
      showToast(title + "を選択しました");
    }

    shots.forEach((shot) => {
      shot.addEventListener("click", () => {
        selectShot(shot);
      });
    });

    document.querySelectorAll("[data-action]").forEach((button) => {
      button.addEventListener("click", (event) => {
        event.stopPropagation();
        showToast(button.dataset.action);
        const parent = button.closest(".store-shot");
        if (parent) {
          selectShot(parent);
        }
      });
    });

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((item) => item.classList.remove("active"));
        tab.classList.add("active");

        const target = tab.dataset.target;
        shots.forEach((shot) => {
          const visible = target === "all" || shot.dataset.kind === target;
          shot.style.display = visible ? "" : "none";
        });

        showToast(tab.textContent + "を表示中");
      });
    });

    let raised = false;
    window.setInterval(() => {
      raised = !raised;
      mainProgress.style.width = raised ? "76%" : "69.2%";
      currentBar.style.width = raised ? "73%" : "69.2%";
    }, 2600);
  </script>
</body>
