  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App ASO Store Screenshot Prototype',
      description: 'ストアPVからDL率改善のためのスクリーンショット検証案',
      ttlHours: 24
    };

    const tabs = document.querySelectorAll('.tab');
    const cards = document.querySelectorAll('.store-card');
    const feedback = document.getElementById('feedback');
    const filterButtons = document.querySelectorAll('[data-filter]');
    const ctaButtons = document.querySelectorAll('[data-reaction]');

    function showScreen(id) {
      cards.forEach((card) => {
        if (window.matchMedia('(min-width: 760px)').matches) {
          card.classList.remove('hidden');
        } else {
          card.classList.toggle('hidden', card.id !== id);
        }
      });

      tabs.forEach((tab) => {
        tab.classList.toggle('active', tab.dataset.target === id);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        showScreen(tab.dataset.target);
        feedback.textContent = tab.textContent + ' のスクリーンショットを表示しました。';
      });
    });

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const target = button.dataset.filter === 'a' ? 'screen-a' : 'screen-b';
        showScreen(target);
        document.getElementById(target).scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    ctaButtons.forEach((button) => {
      button.addEventListener('click', () => {
        feedback.textContent = button.dataset.reaction;
        button.animate(
          [
            { transform: 'scale(1)' },
            { transform: 'scale(1.04)' },
            { transform: 'scale(1)' }
          ],
          {
            duration: 260,
            easing: 'ease-out'
          }
        );
      });
    });

    window.addEventListener('resize', () => {
      const active = document.querySelector('.tab.active');
      showScreen(active ? active.dataset.target : 'screen-a');
    });
  </script>
</body>
