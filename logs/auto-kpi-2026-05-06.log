      color: var(--dark-blue);
      font-weight: 700;
    }

    .dashboard {
      display: grid;
      gap: 16px;
    }

    .dash-card {
      background: var(--white);
      border-radius: 13px;
      padding: 16px;
      box-shadow: var(--shadow);
    }

    .dash-card h3 {
      margin: 0 0 12px;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
    }

    .funnel {
      display: grid;
      gap: 10px;
    }

    .funnel-row {
      display: grid;
      grid-template-columns: 84px 1fr 50px;
      gap: 8px;
      align-items: center;
      font-size: 12px;
    }

    .funnel-label {
      color: var(--text-gray);
      font-weight: 700;
    }

    .funnel-value {
      color: var(--dark-blue);
      font-weight: 700;
      text-align: right;
    }

    .insight-list {
      display: grid;
      gap: 10px;
    }

    .insight {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 10px;
      align-items: start;
    }

    .insight-num {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--back-light-pink);
      color: var(--pink);
      display: grid;
      place-items: center;
      font-size: 12px;
      font-weight: 700;
    }

    .insight-text {
      font-size: 12px;
      color: var(--text-gray);
      line-height: 18px;
    }

    .insight-text strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      margin-bottom: 2px;
    }

    .source-card {
      margin-top: 16px;
      padding: 14px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: var(--shadow-soft);
      font-size: 10px;
      color: var(--text-gray);
      line-height: 15px;
    }

    .source-card strong {
      color: var(--dark-blue);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 20px;
      transform: translateX(-50%) translateY(80px);
      width: min(92%, 340px);
      padding: 12px 16px;
      border-radius: var(--radius-md);
      background: var(--back-blue);
      color: var(--white);
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 12px 28px rgba(0,0,0,0.22);
      opacity: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
      z-index: 20;
      text-align: center;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    .pulse {
      animation: pulse 1.8s ease-in-out infinite;
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(248,76,162,0.34);
      }
      70% {
        box-shadow: 0 0 0 14px rgba(248,76,162,0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(248,76,162,0);
      }
    }

    @media (min-width: 760px) {
      .hero {
        padding-top: 40px;
      }

      .hero h1 {
        font-size: 40px;
        line-height: 54px;
        max-width: 760px;
      }

      .hero p {
        max-width: 680px;
        font-size: 16px;
        line-height: 24px;
      }

      .kpi-grid {
        grid-template-columns: 1.4fr repeat(3, 1fr);
      }

      .kpi-card.primary {
        grid-column: auto;
      }

      .screen-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .dashboard {
        grid-template-columns: 1fr 1fr;
      }

      .section {
        padding: 24px 16px;
      }

      .phone-screen {
        min-height: 540px;
      }
    }
  </style>
</head>
