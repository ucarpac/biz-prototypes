  <script>
    window.PROTO_AUTH_CONFIG = {
      title: 'UcarPAC App ASO Prototype',
      description: 'ストアPVからDL率25%を目指すスクリーンショット検証プロトタイプ',
      expiresHours: 24
    };

    const screens = document.getElementById('screens');
    const stage = document.getElementById('stage');
    const tabs = Array.from(document.querySelectorAll('.tab-button'));
    const dots = Array.from(document.querySelectorAll('.dot'));
    const progressFill = document.getElementById('progressFill');
    const progressCount = document.getElementById('progressCount');
    const prevButton = document.getElementById('prevButton');
    const nextButton = document.getElementById('nextButton');
    const choices = Array.from(document.querySelectorAll('.choice'));
    const diagnosisResult = document.getElementById('diagnosisResult');
    const ctaButtons = Array.from(document.querySelectorAll('[data-pulse]'));

    let currentIndex = 0;
    let startX = 0;
    let currentX = 0;
    let dragging = false;

    function isDesktop() {
      return window.matchMedia('(min-width: 820px)').matches;
    }

    function updateView(index) {
      currentIndex = Math.max(0, Math.min(2, index));
      if (!isDesktop()) {
        screens.style.transform = 'translateX(' + (-currentIndex * 100) + '%)';
      } else {
        screens.style.transform = 'translateX(0)';
      }

      tabs.forEach(function(tab, tabIndex) {
        tab.classList.toggle('active', tabIndex === currentIndex);
      });

      dots.forEach(function(dot, dotIndex) {
        dot.classList.toggle('active', dotIndex === currentIndex);
      });

      progressFill.style.width = ((currentIndex + 1) / 3 * 100) + '%';
      progressCount.textContent = (currentIndex + 1) + ' / 3';
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        updateView(Number(tab.dataset.index));
      });
    });

    prevButton.addEventListener('click', function() {
      updateView(currentIndex - 1);
    });

    nextButton.addEventListener('click', function() {
      updateView(currentIndex + 1);
    });

    stage.addEventListener('pointerdown', function(event) {
      if (isDesktop()) return;
      dragging = true;
      startX = event.clientX;
      currentX = event.clientX;
      screens.style.transition = 'none';
    });

    stage.addEventListener('pointermove', function(event) {
      if (!dragging || isDesktop()) return;
      currentX = event.clientX;
      const diff = currentX - startX;
      const base = -currentIndex * stage.clientWidth;
      screens.style.transform = 'translateX(' + (base + diff) + 'px)';
    });

    stage.addEventListener('pointerup', function() {
      if (!dragging || isDesktop()) return;
      dragging = false;
      screens.style.transition = 'transform 360ms cubic-bezier(.2,.8,.2,1)';
      const diff = currentX - startX;
      if (diff < -46) {
        updateView(currentIndex + 1);
      } else if (diff > 46) {
        updateView(currentIndex - 1);
      } else {
        updateView(currentIndex);
      }
    });

    stage.addEventListener('pointercancel', function() {
      if (!dragging) return;
      dragging = false;
      screens.style.transition = 'transform 360ms cubic-bezier(.2,.8,.2,1)';
      updateView(currentIndex);
    });

    choices.forEach(function(choice) {
      choice.addEventListener('click', function() {
        choices.forEach(function(item) {
          item.classList.remove('selected');
        });
        choice.classList.add('selected');
        diagnosisResult.textContent = choice.dataset.result;
        diagnosisResult.classList.add('show');
        updateView(Number(choice.dataset.target));
      });
    });

    ctaButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        const original = button.textContent;
        button.textContent = button.dataset.pulse;
        button.style.background = 'var(--gradient-pink)';
        button.style.color = 'var(--white)';
        setTimeout(function() {
          button.textContent = original;
          button.style.background = 'var(--gradient-primary)';
          button.style.color = 'var(--dark-blue)';
        }, 1200);
      });
    });

    window.addEventListener('resize', function() {
      stage.classList.toggle('desktop', isDesktop());
      updateView(currentIndex);
    });

    stage.classList.toggle('desktop', isDesktop());
    updateView(0);
  </script>
</body>
