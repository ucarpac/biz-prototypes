      overflow: hidden;
    }

    .screenshot.android-shot {
      padding-top: 18px;
    }

    .soft-cloud {
      position: absolute;
      width: 150px;
      height: 76px;
      border-radius: 999px;
      background: rgba(255,255,255,0.52);
      filter: blur(1px);
      top: 76px;
      right: -46px;
    }

    .soft-cloud.small {
      width: 104px;
      height: 54px;
      top: 178px;
      left: -28px;
      background: rgba(255,240,184,0.54);
    }

    .hand-note {
      display: inline-block;
      transform: rotate(-2deg);
      margin-top: 6px;
      padding: 6px 12px;
      border-radius: 12px;
      background: var(--soft-yellow);
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 19.5px;
      font-weight: 800;
      box-shadow: 0 6px 14px rgba(255,179,107,0.2);
    }

    .shot-head {
      position: relative;
      z-index: 2;
    }

    .shot-eyebrow {
      color: var(--pink);
      font-size: 13px;
