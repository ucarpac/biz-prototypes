<!-- A案: 感情に訴えるアプローチ。ユーザーの不安や期待に寄り添い、安心感を与えるデザイン。暖色系のアクセント、手書き風要素、親しみやすいイラスト的表現 -->
<!DOCTYPE html>
<html lang="ja">
<script src="../auth.js"></script>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UcarPAC App ASO Store Screenshot Prototype</title>
  <style>
    :root {
      --pink: #F84CA2;
      --dark-blue: #1c2663;
      --white: #FFFFFF;
      --text-black: #404040;
      --text-gray: #737373;
      --text-disabled: #B3B3B3;
      --text-placeholder: rgba(28,38,99,0.3);
      --button-gray: #CACEE2;
      --button-link: #4099FF;
      --back-white: #FAFAFA;
      --back-gray: #EDF1F4;
      --back-blue: #091355;
      --back-dark-blue: #0a1348;
      --back-light-pink: #ffd8e8;
      --warm: #fff3e7;
      --warm-deep: #ffb36b;
      --soft-yellow: #fff0b8;
      --mint: #dcfff3;
      --error: #EB4646;
      --ruled-line: #F2F2F2;
      --border-gray: #7C7C7C;
      --shadow: rgba(0,0,0,0.11);
      --gradient-primary: linear-gradient(90deg, #1ddcff, #4db4ff);
      --gradient-pink: linear-gradient(90deg, #f84ca2, #f84ca2);
      --gradient-warm: linear-gradient(135deg, #fff7ed 0%, #ffd8e8 52%, #e9f8ff 100%);
      --font-sans: 'Noto Sans JP', 'Hiragino Sans', system-ui, sans-serif;
      --font-number: 'Noto Sans JP', system-ui, sans-serif;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --radius-sm: 5px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-chip: 22px;
      --radius-button: 30px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background: var(--back-white);
      color: var(--text-black);
      font-family: var(--font-sans);
      line-height: 1.5;
    }

    button {
      font-family: inherit;
    }

    .page {
      width: 100%;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 8% 4%, rgba(255, 216, 232, 0.8), transparent 26%),
        radial-gradient(circle at 92% 18%, rgba(255, 240, 184, 0.85), transparent 24%),
        var(--back-white);
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      padding: 12px 16px;
      background: rgba(250, 250, 250, 0.92);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(28,38,99,0.08);
    }

    .topbar-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--dark-blue);
      font-weight: 700;
      font-size: 16px;
      line-height: 24px;
    }

    .brand-mark {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: var(--gradient-pink);
      display: grid;
      place-items: center;
      color: var(--white);
      box-shadow: 0 4px 16px rgba(248,76,162,0.24);
    }

    .status-pill {
      border: 1px solid rgba(248,76,162,0.22);
      color: var(--pink);
      background: var(--white);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      white-space: nowrap;
    }

    .hero {
      max-width: 1120px;
      margin: 0 auto;
      padding: 28px 16px 18px;
    }

    .hero-grid {
      display: grid;
      gap: 20px;
      align-items: center;
    }

    .hero-copy {
      padding: 8px 0 0;
    }

    .kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: 999px;
      background: var(--warm);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      line-height: 18px;
      border: 1px solid rgba(255,179,107,0.4);
    }

    .kicker-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--pink);
      box-shadow: 0 0 0 5px rgba(248,76,162,0.14);
    }

    h1 {
      margin: 14px 0 8px;
      color: var(--dark-blue);
      font-size: 32px;
      line-height: 48px;
      letter-spacing: 0;
    }

    .lead {
      margin: 0;
      color: var(--text-gray);
      font-size: 15px;
      line-height: 22.5px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .app-button {
      min-width: 182px;
      height: 43px;
      border: 0;
      border-radius: var(--radius-button);
      padding: 0 18px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      box-shadow: 0 7px 18px rgba(77,180,255,0.24);
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .app-button.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 7px 18px rgba(248,76,162,0.24);
    }

    .app-button:active {
      transform: translateY(1px) scale(0.99);
    }

    .metric-panel {
      width: 100%;
      max-width: 351px;
      min-height: 128px;
      border-radius: 13px;
      background: var(--white);
      border: 1px solid rgba(64,64,64,0.06);
      padding: 16px;
      box-shadow: 0 8px 24px var(--shadow);
    }

    .metric-label {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .metric-row {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      margin-top: 8px;
    }

    .metric-value {
      color: var(--dark-blue);
      font-size: 36px;
      line-height: 44px;
      font-weight: 800;
    }

    .metric-value span {
      color: var(--pink);
    }

    .metric-note {
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      text-align: right;
    }

    .tabs {
      max-width: 1120px;
      margin: 0 auto;
      padding: 10px 16px 0;
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .tabs::-webkit-scrollbar {
      display: none;
    }

    .tab {
      min-width: 116px;
      min-height: 43px;
      border-radius: var(--radius-chip);
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      font-size: 14px;
      font-weight: 700;
      line-height: 21px;
      cursor: pointer;
      padding: 0 16px;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .tab.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
    }

    .screen-stage {
      max-width: 1120px;
      margin: 0 auto;
      padding: 20px 16px 42px;
    }

    .screens {
      display: grid;
      gap: 18px;
    }

    .store-card {
      background: var(--white);
      border-radius: 16px;
      padding: 16px;
      box-shadow: 0 12px 34px rgba(28,38,99,0.12);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .store-card.hidden {
      display: none;
    }

    .store-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .store-title {
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 800;
      margin: 0;
    }

    .store-type {
      color: var(--pink);
      background: var(--back-light-pink);
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      white-space: nowrap;
    }

    .phone-frame {
      width: min(100%, 375px);
      margin: 0 auto;
      border-radius: 34px;
      padding: 10px;
      background: #182155;
      box-shadow: 0 18px 42px rgba(9,19,85,0.22);
    }

    .phone-frame.android {
      border-radius: 26px;
      background: #222;
    }

    .phone-screen {
      position: relative;
      min-height: 690px;
      border-radius: 26px;
      overflow: hidden;
      background: var(--gradient-warm);
    }

    .phone-frame.android .phone-screen {
      border-radius: 18px;
    }

    .notch {
      width: 104px;
      height: 26px;
      border-radius: 0 0 16px 16px;
      background: #182155;
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
    }

    .android-bar {
      height: 20px;
      display: flex;
      justify-content: flex-end;
