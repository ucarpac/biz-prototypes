    }

    .shot-cta {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 18px;
      z-index: 3;
      height: 52px;
      border: 0;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 15px;
      line-height: 22.5px;
      font-weight: 900;
      box-shadow: 0 10px 24px rgba(77,180,255,0.28);
      cursor: pointer;
    }

    .shot-cta.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 10px 24px rgba(248,76,162,0.28);
    }

    .reaction {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 16px 42px;
    }

    .reaction-box {
      background: var(--back-blue);
      color: var(--white);
      border-radius: 16px;
      padding: 18px;
