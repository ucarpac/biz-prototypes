      min-height: 43px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-black);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      border: 1px solid var(--ruled-line);
      transition: transform 180ms ease, background 180ms ease, color 180ms ease;
    }

    .tab-button.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .stage {
      position: relative;
      width: 100%;
      overflow: hidden;
      padding-bottom: 10px;
    }

    .screens {
      display: flex;
      gap: 16px;
      transition: transform 360ms cubic-bezier(.2,.8,.2,1);
      touch-action: pan-y;
      user-select: none;
    }

    .screen-card {
      min-width: 100%;
      display: flex;
      justify-content: center;
      padding: 0 2px;
    }

    .store-shot {
      width: min(100%, 375px);
      min-height: 812px;
      border-radius: 28px;
      overflow: hidden;
      background: var(--white);
      box-shadow: var(--shadow-heavy);
      border: 10px solid #101522;
      position: relative;
    }

    .phone-status {
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 18px;
      color: var(--dark-blue);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      background: var(--white);
    }

    .status-dots {
      display: flex;
      gap: 4px;
      align-items: center;
    }

    .status-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--dark-blue);
      opacity: 0.75;
    }

    .shot-inner {
      min-height: 784px;
      padding: 18px 16px 22px;
      position: relative;
    }

    .shot-a .shot-inner {
      background:
        linear-gradient(180deg, rgba(255,216,232,0.64) 0%, #ffffff 42%, #f6fbff 100%);
    }

    .shot-b .shot-inner {
      background:
        linear-gradient(180deg, #ffffff 0%, #eef8ff 46%, #ffffff 100%);
    }

    .shot-c .shot-inner {
      background:
        linear-gradient(180deg, #091355 0%, #18277d 42%, #ffffff 42%, #ffffff 100%);
    }

    .store-label {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 6px 12px;
      border-radius: var(--radius-chip);
      background: var(--back-blue);
      color: var(--white);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .shot-c .store-label {
      background: var(--white);
      color: var(--dark-blue);
    }

    .shot-title {
      margin: 16px 0 0;
      color: var(--dark-blue);
      font-size: 32px;
      line-height: 48px;
      font-weight: 700;
      letter-spacing: 0;
    }

    .shot-c .shot-title {
      color: var(--white);
    }

    .shot-lead {
      margin: 8px 0 0;
      color: var(--text-gray);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
    }

    .shot-c .shot-lead {
      color: var(--text-light-blue, #bfdbfe);
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 6px 10px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid #CDDCED;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      box-shadow: 0 4px 12px rgba(28,38,99,0.07);
    }

    .badge.pink {
      background: var(--pink);
      color: var(--white);
      border-color: var(--pink);
    }

    .mock-app {
      margin: 18px auto 0;
      width: 90%;
      max-width: 351px;
      border-radius: 18px;
      background: var(--white);
      box-shadow: var(--shadow-medium);
      overflow: hidden;
      border: 1px solid #CDDCED;
    }

    .mock-app-head {
      padding: 16px;
      background: var(--back-blue);
      color: var(--white);
    }

    .mock-app-head.light {
      background: var(--white);
      color: var(--dark-blue);
      border-bottom: 1px solid var(--ruled-line);
    }

    .mock-kicker {
      margin: 0;
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      opacity: 0.78;
    }

    .mock-title {
      margin: 4px 0 0;
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
    }

    .car-card {
      margin: 16px;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      border: 1px solid #CDDCED;
      box-shadow: var(--shadow-light);
    }

    .car-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .car-thumb {
      width: 86px;
      height: 58px;
      border-radius: 12px;
      background:
        linear-gradient(160deg, #dfe8ff, #ffffff 58%),
        var(--back-gray);
      position: relative;
      flex: 0 0 auto;
    }

    .car-thumb::before {
      content: "";
      position: absolute;
      left: 11px;
      right: 11px;
      bottom: 15px;
      height: 18px;
      border-radius: 10px 14px 7px 7px;
      background: var(--dark-blue);
    }

    .car-thumb::after {
      content: "";
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 28px;
      height: 14px;
      border-radius: 12px 12px 2px 2px;
      background: #6fc2ff;
    }

    .wheel {
      position: absolute;
      bottom: 10px;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: #101522;
    }

    .wheel.left {
      left: 22px;
    }

    .wheel.right {
      right: 22px;
    }

    .car-meta {
      flex: 1;
      min-width: 0;
    }

    .car-name {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .car-spec {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .price-panel {
      margin: 0 16px 16px;
      padding: 16px;
      border-radius: 12px;
      background: linear-gradient(180deg, #ffffff, #f7fbff);
      border: 1px solid #CDDCED;
    }

    .price-label {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .price-main {
      margin: 4px 0 0;
      color: var(--pink);
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 54px;
      font-weight: 700;
    }

    .price-main span {
      color: var(--dark-blue);
      font-family: var(--font-sans);
      font-size: 18px;
      line-height: 27px;
    }

    .range-bar {
      margin-top: 10px;
      height: 12px;
      border-radius: 999px;
      background: var(--back-gray);
      overflow: hidden;
      position: relative;
    }

    .range-fill {
      height: 100%;
      width: 74%;
      border-radius: 999px;
      background: var(--gradient-primary);
      animation: growBar 1200ms ease both;
    }

    .range-pin {
      position: absolute;
      left: 69%;
      top: -4px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--pink);
      border: 3px solid var(--white);
      box-shadow: 0 4px 12px rgba(248,76,162,0.28);
      animation: pulsePin 1400ms ease-in-out infinite;
    }

    .cta-button {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 240px;
      min-height: 43px;
      margin: 16px auto 0;
      border-radius: var(--radius-button);
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 21px;
      font-weight: 700;
      box-shadow: 0 8px 18px rgba(77,180,255,0.26);
      transition: transform 160ms ease, filter 160ms ease;
    }

    .cta-button:active {
      transform: scale(0.97);
      filter: brightness(0.98);
    }

    .stepper {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      margin: 16px 16px 0;
    }

    .step {
      min-height: 42px;
      border-radius: 12px;
      background: var(--back-gray);
      display: grid;
      place-items: center;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .step.active {
      background: var(--dark-blue);
      color: var(--white);
      transform: translateY(-2px);
    }

    .chart-card {
      margin: 16px;
      padding: 16px;
      border-radius: 12px;
      background: var(--white);
      box-shadow: var(--shadow-light);
      border: 1px solid #CDDCED;
    }

    .chart-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .chart-sub {
      margin: 2px 0 0;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .chart {
      margin-top: 14px;
      height: 138px;
      position: relative;
      background:
        linear-gradient(to top, #edf1f4 1px, transparent 1px) 0 0 / 100% 34px,
        linear-gradient(180deg, #ffffff, #f8fcff);
      border-radius: 12px;
      overflow: hidden;
    }

    .chart svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .chart-path {
      fill: none;
      stroke: #F84CA2;
      stroke-width: 5;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: drawLine 1600ms ease forwards;
    }

    .chart-path.future {
      stroke: #4db4ff;
      stroke-dasharray: 8 8;
      animation-delay: 500ms;
    }

    .chart-caption {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .expense-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin: 16px;
    }

    .expense-tile {
      min-height: 88px;
      border-radius: 12px;
      padding: 12px;
      background: var(--white);
      box-shadow: var(--shadow-light);
      border: 1px solid #CDDCED;
    }

    .expense-label {
      margin: 0;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 700;
    }

    .expense-value {
      margin: 4px 0 0;
      color: var(--dark-blue);
      font-size: 22px;
      line-height: 33px;
      font-weight: 700;
    }

    .expense-value.pink {
      color: var(--pink);
    }

    .ring {
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background: conic-gradient(var(--pink) 0 58%, #4db4ff 58% 82%, var(--back-gray) 82% 100%);
      margin: 8px auto 0;
      position: relative;
      animation: spinIn 900ms ease both;
    }

    .ring::after {
      content: "58%";
      position: absolute;
      inset: 10px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--white);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .compare-board {
      margin: 22px auto 0;
      width: 90%;
      max-width: 351px;
      border-radius: 18px;
      background: var(--white);
      box-shadow: var(--shadow-heavy);
      overflow: hidden;
    }

    .compare-header {
      padding: 16px;
      background: var(--gradient-pink);
      color: var(--white);
      text-align: center;
    }

    .compare-header p {
      margin: 0;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .compare-header strong {
      display: block;
      margin-top: 2px;
      font-size: 32px;
      line-height: 48px;
      font-weight: 700;
    }

    .compare-list {
      padding: 10px 16px 16px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1fr 82px 82px;
      align-items: center;
      min-height: 50px;
      gap: 8px;
      border-bottom: 1px solid var(--ruled-line);
      color: var(--text-black);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .compare-row:last-child {
      border-bottom: 0;
    }

    .compare-cell {
      text-align: center;
      min-height: 34px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      background: var(--back-gray);
      color: var(--text-gray);
    }

    .compare-cell.win {
      background: var(--dark-blue);
      color: var(--white);
      animation: pop 600ms ease both;
    }

    .zero-call {
      margin: 18px 16px 0;
      border-radius: 16px;
      padding: 14px;
      background: var(--back-blue);
      color: var(--white);
      position: relative;
      overflow: hidden;
    }

    .zero-call::before {
      content: "";
      position: absolute;
      right: -24px;
      top: -24px;
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: rgba(29,220,255,0.18);
    }

    .zero-call p {
      margin: 0;
      position: relative;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
    }

    .zero-call strong {
      display: block;
      margin-top: 2px;
      position: relative;
      color: var(--back-light-blue);
      font-size: 26px;
      line-height: 39px;
      font-weight: 700;
    }

    .floating-score {
      position: absolute;
      right: 18px;
      bottom: 18px;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
      box-shadow: 0 10px 22px rgba(77,180,255,0.3);
      animation: floatScore 1800ms ease-in-out infinite;
    }

    .source-note {
      margin: 16px auto 0;
      width: 90%;
      max-width: 351px;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 15px;
      font-weight: 400;
    }

    .swipe-hint {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      margin-top: 14px;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--text-disabled);
      transition: width 180ms ease, background 180ms ease;
    }

    .dot.active {
      width: 22px;
      background: var(--pink);
    }

    .bottom-actions {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin: 16px auto 0;
      width: 100%;
      max-width: 351px;
    }

    .round-action {
      width: 43px;
      height: 43px;
      border-radius: 50%;
      background: var(--white);
      color: var(--dark-blue);
      border: 1px solid #CDDCED;
      box-shadow: var(--shadow-light);
      font-size: 18px;
      line-height: 27px;
      font-weight: 700;
    }

    .diagnosis {
      width: 100%;
      max-width: 351px;
      margin: 16px auto 0;
      padding: 16px;
      border-radius: 13px;
      background: var(--white);
      box-shadow: var(--shadow-light);
      border: 1px solid #CDDCED;
    }

    .diagnosis-title {
      margin: 0;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 24px;
      font-weight: 700;
    }

    .diagnosis-copy {
      margin: 4px 0 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 18px;
      font-weight: 400;
    }

    .choice-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-top: 12px;
    }

    .choice {
      min-height: 43px;
      border-radius: var(--radius-chip);
      background: var(--white);
      color: var(--text-black);
      border: 1px solid var(--ruled-line);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .choice.selected {
      background: var(--pink);
      color: var(--white);
      transform: translateY(-2px);
    }

    .diagnosis-result {
      margin-top: 12px;
      min-height: 48px;
      border-radius: 12px;
      padding: 12px;
      background: var(--back-gray);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 220ms ease, transform 220ms ease;
    }

    .diagnosis-result.show {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes growBar {
      from {
        width: 0;
      }
      to {
        width: 74%;
      }
    }

    @keyframes pulsePin {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.18);
      }
    }

    @keyframes drawLine {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes spinIn {
      from {
        transform: rotate(-120deg) scale(0.82);
        opacity: 0;
      }
      to {
        transform: rotate(0deg) scale(1);
        opacity: 1;
      }
    }

    @keyframes pop {
      from {
        transform: scale(0.92);
        opacity: 0.4;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    @keyframes floatScore {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-8px);
      }
    }

    @media (min-width: 820px) {
      .page {
        padding-top: 24px;
      }

      .hero {
        text-align: center;
      }

      .hero h1 {
        font-size: 32px;
        line-height: 48px;
      }

      .screens {
        gap: 24px;
      }

      .screen-card {
        min-width: calc((100% - 48px) / 3);
      }

      .stage.desktop .screens {
        transform: translateX(0) !important;
      }

      .bottom-actions,
      .swipe-hint {
        display: none;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header class="topbar">
      <div class="brand">
        <div class="brand-mark" aria-hidden="true"></div>
        <div class="brand-text">
          <p class="brand-name">UcarPAC App</p>
          <p class="brand-sub">ASO Store PV → DL Prototype</p>
        </div>
      </div>
      <div class="goal-chip">17.3% → 25%</div>
    </header>

    <section class="hero">
      <h1>ストアスクショでDL前の不安をゲーム感覚で解消</h1>
      <p>AI査定、出費管理、電話0本の価値を3枚のストア画像で順番に体験させる検証案。</p>
    </section>

    <section class="control-panel" aria-label="スクショ選択">
      <div class="progress-row">
        <span class="progress-label">ASO訴求ステップ</span>
        <span class="progress-count" id="progressCount">1 / 3</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <div class="tabs">
        <button class="tab-button active" type="button" data-index="0">AI査定</button>
        <button class="tab-button" type="button" data-index="1">出費管理</button>
        <button class="tab-button" type="button" data-index="2">電話0本</button>
      </div>
    </section>

    <section class="stage" id="stage" aria-label="ストアスクショプレビュー">
      <div class="screens" id="screens">
        <article class="screen-card">
          <div class="store-shot shot-a">
            <div class="phone-status">
              <span>9:41</span>
              <span class="status-dots">
                <span class="status-dot"></span>
                <span class="status-dot"></span>
                <span class="status-dot"></span>
              </span>
            </div>
            <div class="shot-inner">
              <span class="store-label">iOS Store Screenshot A</span>
              <h2 class="shot-title">AIが<br>あなたの愛車を査定</h2>
              <p class="shot-lead">個人情報なしで、今の相場をすぐ確認。</p>
              <div class="badge-row">
                <span class="badge pink">個人情報不要</span>
                <span class="badge">約30秒でチェック</span>
              </div>

              <div class="mock-app">
                <div class="mock-app-head">
                  <p class="mock-kicker">AI査定スコア</p>
                  <p class="mock-title">入力あと1問で精度アップ</p>
                </div>
                <div class="car-card">
                  <div class="car-row">
                    <div class="car-thumb">
                      <span class="wheel left"></span>
                      <span class="wheel right"></span>
                    </div>
                    <div class="car-meta">
                      <p class="car-name">トヨタ ハリアー</p>
                      <p class="car-spec">2020年式 / Z / 42,000km</p>
                    </div>
                  </div>
                </div>
                <div class="price-panel">
                  <p class="price-label">AI査定価格</p>
                  <p class="price-main">248<span>万円</span></p>
                  <div class="range-bar">
                    <div class="range-fill"></div>
                    <div class="range-pin"></div>
                  </div>
                </div>
                <div class="stepper">
                  <div class="step active">車種</div>
                  <div class="step active">年式</div>
                  <div class="step active">距離</div>
                  <div class="step">写真</div>
                </div>
