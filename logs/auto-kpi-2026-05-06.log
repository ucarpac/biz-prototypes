      font-weight: 900;
      margin: 4px 0 0;
    }

    .shot-title .marker {
      background: linear-gradient(transparent 58%, rgba(255,240,184,0.9) 58%);
    }

    .shot-sub {
      color: var(--text-black);
      font-size: 14px;
      line-height: 21px;
      margin: 8px 0 0;
      font-weight: 600;
    }

    .car-illustration {
      position: relative;
      z-index: 2;
      margin: 22px auto 12px;
      width: 272px;
      height: 138px;
    }

    .car-body {
      position: absolute;
      left: 20px;
      right: 20px;
      bottom: 28px;
      height: 62px;
      border-radius: 48px 52px 24px 24px;
      background: linear-gradient(180deg, #ffffff, #eaf8ff);
      border: 3px solid var(--dark-blue);
      box-shadow: 0 10px 20px rgba(28,38,99,0.13);
    }

    .car-top {
      position: absolute;
      left: 72px;
      top: 26px;
      width: 126px;
      height: 60px;
      border-radius: 54px 54px 8px 8px;
      background: linear-gradient(180deg, #ffffff, #dff5ff);
      border: 3px solid var(--dark-blue);
    }

    .car-window {
      position: absolute;
      left: 88px;
      top: 40px;
      width: 94px;
      height: 34px;
      border-radius: 28px 28px 6px 6px;
      background: #bfeeff;
      border: 2px solid var(--dark-blue);
    }

    .wheel {
      position: absolute;
      bottom: 16px;
      width: 42px;
      height: 42px;
      border-radius: 999px;
      background: var(--dark-blue);
      border: 7px solid #ffffff;
      box-shadow: 0 0 0 3px var(--dark-blue);
    }

    .wheel.left {
      left: 54px;
    }

    .wheel.right {
      right: 54px;
    }

    .heart {
      position: absolute;
      right: 18px;
      top: 8px;
      width: 34px;
      height: 34px;
      transform: rotate(12deg);
      animation: pulse 1800ms ease-in-out infinite;
    }

    .heart::before,
    .heart::after {
      content: "";
      position: absolute;
      width: 18px;
      height: 28px;
      background: var(--pink);
      border-radius: 18px 18px 0 0;
      transform-origin: 0 100%;
    }

    .heart::before {
      left: 17px;
      transform: rotate(-45deg);
    }

    .heart::after {
      left: 0;
      transform: rotate(45deg);
      transform-origin: 100% 100%;
    }

    .price-card {
      position: relative;
      z-index: 2;
      width: min(90%, 351px);
      margin: 0 auto;
      padding: 16px;
      border-radius: 13px;
      background: rgba(255,255,255,0.94);
      box-shadow: 0 10px 30px rgba(28,38,99,0.14);
