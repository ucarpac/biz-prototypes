  <script>
    const chartSeries = {
      week: [182, 183, 181, 184, 183, 185, 184.2],
      month: [191, 189, 188.5, 187, 186.3, 185.4, 184.2],
      future: [184.2, 183.4, 181.1, 179.5, 176.2, 174.1, 171.8]
    };

    function renderLineChart(key) {
      const svg = document.getElementById("forecast-chart-a");
      const line = document.getElementById("forecast-line-a");
      const area = document.getElementById("forecast-area-a");
      const dots = document.getElementById("forecast-dots-a");
      const data = chartSeries[key];
      const width = 320;
      const height = 170;
      const left = 10;
      const right = 310;
      const top = 18;
      const bottom = 148;
      const max = Math.max(...data) + 2;
      const min = Math.min(...data) - 2;

      const points = data.map((value, index) => {
        const x = left + (index * (right - left) / (data.length - 1));
        const y = bottom - ((value - min) / (max - min)) * (bottom - top);
        return [x, y];
      });

      const path = points.map((point, index) => `${index === 0 ? "M" : "L"} ${point[0]} ${point[1]}`).join(" ");
      const areaPath = `${path} L ${points[points.length - 1][0]} ${bottom} L ${points[0][0]} ${bottom} Z`;
      line.setAttribute("d", path);
      area.setAttribute("d", areaPath);
      dots.innerHTML = points.map((point, index) => (
        `<circle cx="${point[0]}" cy="${point[1]}" r="${index === points.length - 1 ? 5.5 : 4}" fill="${index === points.length - 1 ? '#F84CA2' : '#ffffff'}" opacity="${index === points.length - 1 ? 1 : 0.85}"></circle>`
      )).join("");
      svg.setAttribute("data-series-active", key);
    }

    document.querySelectorAll(".tabs").forEach((group) => {
      group.addEventListener("click", (event) => {
        const button = event.target.closest(".tab");
        if (!button) return;
        group.querySelectorAll(".tab").forEach((tab) => tab.classList.remove("active"));
        button.classList.add("active");
        renderLineChart(button.dataset.series);
      });
    });

    const compareModes = {
      calls: `
        <tr>
