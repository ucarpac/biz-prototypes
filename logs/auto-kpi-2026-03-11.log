  <script>
    const tabs = Array.from(document.querySelectorAll(".tab"));
    const cards = Array.from(document.querySelectorAll(".phone-card"));
    const autoplayBtn = document.getElementById("autoplayBtn");
    const evidenceBtn = document.getElementById("evidenceBtn");
    const evidencePanel = document.getElementById("evidencePanel");
    const cvrSlider = document.getElementById("cvrSlider");
    const cvrFill = document.getElementById("cvrFill");
    const cvrRing = document.getElementById("cvrRing");
    const ringValue = document.getElementById("ringValue");
    const gainText = document.getElementById("gainText");
    const barFills = document.querySelectorAll(".bar-fill");
    let current = "a";
    let autoplay = null;

    function setScreen(id) {
      current = id;
      tabs.forEach((tab) => tab.classList.toggle("active", tab.dataset.screen === id));
      cards.forEach((card) => card.classList.toggle("active", card.dataset.card === id));
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        setScreen(tab.dataset.screen);
        stopAutoplay();
      });
    });

    function updateMeter(value) {
      const numeric = Number(value);
      const degrees = (numeric / 25) * 360;
      cvrFill.style.width = numeric + "%";
      cvrRing.style.background = "conic-gradient(#f84ca2 0deg, #f84ca2 " + degrees + "deg, rgba(28,38,99,0.08) " + degrees + "deg)";
      ringValue.innerHTML = numeric.toFixed(1) + "<span>CVR</span>";
      const additional = Math.round((numeric - 17.3) * 100);
      gainText.textContent = additional > 0 ? "+" + additional + " DL の余地" : "基準値";
    }

    cvrSlider.addEventListener("input", (event) => updateMeter(event.target.value));
    updateMeter(cvrSlider.value);

    function startAutoplay() {
      autoplay = setInterval(() => {
        const order = ["a", "b", "c"];
        const next = order[(order.indexOf(current) + 1) % order.length];
        setScreen(next);
      }, 2600);
      autoplayBtn.textContent = "自動切替 ON";
      autoplayBtn.setAttribute("aria-pressed", "true");
    }

    function stopAutoplay() {
      if (autoplay) {
        clearInterval(autoplay);
        autoplay = null;
      }
      autoplayBtn.textContent = "自動切替 OFF";
      autoplayBtn.setAttribute("aria-pressed", "false");
    }

    autoplayBtn.addEventListener("click", () => {
      if (autoplay) {
        stopAutoplay();
      } else {
        startAutoplay();
      }
    });

    evidenceBtn.addEventListener("click", () => {
      evidencePanel.classList.toggle("hidden");
      evidenceBtn.textContent = evidencePanel.classList.contains("hidden") ? "根拠を表示" : "根拠を隠す";
      if (!evidencePanel.classList.contains("hidden")) {
        evidencePanel.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        barFills.forEach((fill) => {
          fill.style.width = fill.dataset.width;
        });
      });
    }, { threshold: 0.25 });

    observer.observe(document.querySelector(".layout"));
  </script>
