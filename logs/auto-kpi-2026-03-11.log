      font-size: 34px;
      line-height: 46px;
      font-weight: 900;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .hero-copy p {
      margin: 8px 0 0;
      font-size: 14px;
      line-height: 21px;
      color: var(--text-gray);
    }

    .floating-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      align-self: flex-start;
      margin-top: 4px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.86);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      box-shadow: 0 10px 24px rgba(28, 38, 99, 0.08);
    }

    .floating-cta::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--pink);
      box-shadow: 0 0 0 6px rgba(248, 76, 162, 0.12);
      animation: pulse 1.8s infinite;
    }

    .card {
      position: relative;
      border-radius: 24px;
      padding: 18px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(255, 255, 255, 0.9);
      box-shadow: 0 18px 42px rgba(28, 38, 99, 0.09);
      overflow: hidden;
    }

    .card.outline {
      background: rgba(255, 255, 255, 0.7);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 10px 24px rgba(28, 38, 99, 0.06);
    }

    .eyebrow {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .eyebrow strong {
      color: var(--dark-blue);
    }

    .estimate-wrap {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 12px;
      align-items: center;
    }

    .car-stage {
      position: relative;
      min-height: 230px;
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(191, 219, 254, 0.38)),
        radial-gradient(circle at 50% 80%, rgba(28, 38, 99, 0.08), transparent 44%);
      overflow: hidden;
    }

    .car-stage::before {
      content: "";
      position: absolute;
      inset: 16px 20px auto;
      height: 110px;
      border-radius: 999px;
      background: radial-gradient(circle at center, rgba(29, 220, 255, 0.28), transparent 70%);
      filter: blur(8px);
    }

    .scan-line {
      position: absolute;
      inset: 18px 24px 18px auto;
      width: 48%;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(29, 220, 255, 0), rgba(29, 220, 255, 0.38), rgba(29, 220, 255, 0));
      transform: translateX(120%);
      opacity: 0;
    }

    .car-stage.scanning .scan-line {
      opacity: 1;
      animation: sweep 1.2s ease-in-out 2;
    }

    .car-art {
      position: absolute;
      inset: auto 18px 24px 18px;
      width: calc(100% - 36px);
      height: 130px;
    }

    .metric-block {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .number-kicker {
      font-size: 11px;
      line-height: 16px;
      font-weight: 700;
      color: var(--text-gray);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .number {
      font-family: var(--font-number);
      font-size: 40px;
      line-height: 46px;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
    }

    .number small {
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 700;
      margin-left: 6px;
    }

    .range-box {
      padding: 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.96), rgba(28, 38, 99, 0.94));
      color: var(--white);
    }

    .range-box .range-label {
      font-size: 12px;
      line-height: 18px;
      color: rgba(255, 255, 255, 0.76);
    }

    .range-box .range-value {
      margin-top: 6px;
      font-size: 31px;
      line-height: 40px;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .confidence-meter {
      display: grid;
      gap: 8px;
      margin-top: 6px;
    }

    .meter-bar {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(28, 38, 99, 0.08);
    }

    .meter-fill {
      width: 38%;
      height: 100%;
      border-radius: inherit;
      background: var(--gradient-primary);
      transition: width 560ms ease;
    }

    .screen.a.revealed .meter-fill {
      width: 92%;
    }

    .meter-copy {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .step-ribbon {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 14px;
    }

    .step-pill {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: center;
      justify-content: center;
      min-height: 72px;
      padding: 10px 8px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(28, 38, 99, 0.08);
      text-align: center;
    }

    .step-pill strong {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      background: var(--dark-blue);
      color: var(--white);
      font-size: 12px;
    }

    .step-pill span {
      font-size: 11px;
      line-height: 16px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .feature-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .feature-card {
      padding: 14px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.86);
      text-align: center;
      box-shadow: 0 10px 24px rgba(28, 38, 99, 0.06);
    }

    .feature-card strong {
      display: block;
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
    }

    .feature-card span {
      display: block;
      margin-top: 2px;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .primary-btn,
    .ghost-btn,
    .tiny-toggle {
      appearance: none;
      border: 0;
      cursor: pointer;
      font-family: inherit;
      transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease, background 160ms ease, color 160ms ease;
    }

    .primary-btn {
      width: 100%;
      min-height: 52px;
      border-radius: 999px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 900;
      letter-spacing: 0.01em;
      box-shadow: 0 18px 28px rgba(64, 153, 255, 0.24);
    }

    .primary-btn.alt {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 18px 28px rgba(248, 76, 162, 0.22);
    }

    .ghost-btn {
      min-height: 44px;
      padding: 0 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.82);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.08);
    }

    .primary-btn:active,
    .ghost-btn:active,
    .tiny-toggle:active,
    .nav-chip:active {
      transform: scale(0.98);
    }

    .forecast-layout {
      display: grid;
      gap: 12px;
    }

    .forecast-top {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .pill-group {
      display: inline-flex;
      gap: 6px;
      padding: 4px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.05);
    }

    .tiny-toggle {
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      background: transparent;
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 800;
    }

    .tiny-toggle.active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 8px 18px rgba(28, 38, 99, 0.16);
    }

    .forecast-number {
      font-family: var(--font-number);
      font-size: 34px;
      line-height: 42px;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
    }

    .forecast-number small {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 700;
      margin-left: 6px;
      color: var(--text-gray);
    }

    .graph-card {
      position: relative;
      padding: 12px 12px 8px;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.98), rgba(28, 38, 99, 0.92));
      color: var(--white);
      overflow: hidden;
    }

    .graph-card::before {
      content: "";
      position: absolute;
      inset: auto auto -40px -18px;
      width: 120px;
      height: 120px;
      border-radius: 999px;
      background: rgba(29, 220, 255, 0.12);
      filter: blur(2px);
    }

    .graph-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: baseline;
      margin-bottom: 8px;
      position: relative;
      z-index: 1;
    }

    .graph-head strong {
      font-size: 14px;
      line-height: 21px;
    }

    .graph-head span {
      font-size: 11px;
      line-height: 16px;
      color: rgba(255, 255, 255, 0.72);
    }

    .graph-shell {
      position: relative;
      height: 154px;
      border-radius: 16px;
      overflow: hidden;
    }

    .graph-grid {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
      background-size: 100% 38px, 56px 100%;
      opacity: 0.6;
    }

    .graph-line {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
    }

    .graph-line path.main {
      fill: url(#forecastFill);
      stroke: #1ddcff;
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: d 360ms ease;
    }

    .graph-line circle {
      fill: #f84ca2;
      stroke: #ffffff;
      stroke-width: 3;
      transition: cx 360ms ease, cy 360ms ease;
    }

    .graph-axis {
      display: flex;
      justify-content: space-between;
      position: relative;
      z-index: 1;
      margin-top: 6px;
      font-size: 11px;
      line-height: 16px;
      color: rgba(255, 255, 255, 0.72);
    }

    .expense-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .expense-card {
      padding: 14px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(28, 38, 99, 0.06);
      text-align: center;
    }

    .expense-card strong {
      display: block;
      font-size: 18px;
      line-height: 27px;
      color: var(--dark-blue);
    }

    .expense-card span {
      display: block;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .mission-strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 16px;
      border-radius: 20px;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.12), rgba(29, 220, 255, 0.12));
      border: 1px solid rgba(248, 76, 162, 0.16);
    }

    .mission-strip strong {
      display: block;
      font-size: 13px;
      line-height: 20px;
      color: var(--dark-blue);
    }

    .mission-strip span {
      display: block;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .ring {
      position: relative;
      width: 68px;
      height: 68px;
      flex-shrink: 0;
    }

    .ring svg {
      width: 100%;
      height: 100%;
      transform: rotate(-90deg);
    }

    .ring .track-ring {
      stroke: rgba(28, 38, 99, 0.08);
      stroke-width: 10;
      fill: none;
    }

    .ring .value-ring {
      stroke: url(#ringGradient);
      stroke-width: 10;
      fill: none;
      stroke-linecap: round;
      stroke-dasharray: 164;
      stroke-dashoffset: 28;
      animation: riseRing 1.2s ease;
    }

    .ring-value {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      text-align: center;
      font-size: 13px;
      line-height: 18px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-hero {
      padding: 18px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.98), rgba(28, 38, 99, 0.94));
      color: var(--white);
      box-shadow: 0 22px 40px rgba(9, 19, 85, 0.2);
    }

    .compare-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .compare-top strong {
      font-size: 14px;
      line-height: 21px;
    }

    .call-bubble {
      margin: 18px auto 14px;
      width: 170px;
      height: 170px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 50% 35%, rgba(29, 220, 255, 0.44), transparent 44%),
        radial-gradient(circle at 50% 70%, rgba(248, 76, 162, 0.18), transparent 56%),
        rgba(255, 255, 255, 0.08);
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.12),
        0 22px 40px rgba(0, 0, 0, 0.18);
      position: relative;
      overflow: hidden;
    }

    .call-bubble::before {
      content: "";
      position: absolute;
      inset: 14px;
      border-radius: inherit;
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .call-bubble strong {
      display: block;
      font-family: var(--font-number);
      font-size: 70px;
      line-height: 70px;
      letter-spacing: -0.06em;
    }

    .call-bubble span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.76);
    }

    .compare-tabs {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 10px 0 14px;
    }

    .compare-tab {
      appearance: none;
      border: 0;
      min-height: 42px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.72);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .compare-tab.active {
      background: rgba(255, 255, 255, 0.96);
      color: var(--dark-blue);
      transform: translateY(-1px);
    }

    .compare-table {
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 78px 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
    }

    .compare-row strong {
      font-size: 12px;
      line-height: 18px;
      color: rgba(255, 255, 255, 0.78);
    }

    .bar-track {
      height: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: inherit;
      width: var(--w, 50%);
      background: var(--gradient-primary);
      transition: width 320ms ease, background 320ms ease;
    }

    .compare-row span {
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
      color: var(--white);
    }

    .compare-note {
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.1);
      font-size: 12px;
      line-height: 18px;
      color: rgba(255, 255, 255, 0.78);
    }

    .bullet-badges {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .bullet-badge {
      padding: 14px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.84);
      text-align: center;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.06);
    }

    .bullet-badge strong {
      display: block;
      font-size: 16px;
      line-height: 24px;
      color: var(--dark-blue);
    }

    .bullet-badge span {
      display: block;
      margin-top: 2px;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .footer-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-top: auto;
    }

    .caption {
      font-size: 10px;
      line-height: 15px;
      color: var(--text-gray);
    }

    .caption strong {
      color: var(--dark-blue);
    }

    .controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
      padding: 0 4px;
    }

    .pager {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      flex: 1;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.16);
      transition: width 180ms ease, background 180ms ease;
    }

    .dot.active {
      width: 32px;
      background: var(--dark-blue);
    }

    .control-btn {
      appearance: none;
      border: 0;
      min-width: 88px;
      min-height: 44px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.88);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.08);
    }

    .toolbox {
      margin-top: 18px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);
      box-shadow: 0 16px 36px rgba(28, 38, 99, 0.08);
    }

    .toolbox h2 {
      margin: 0;
      font-size: 16px;
      line-height: 24px;
      color: var(--dark-blue);
    }

    .toolbox p {
      margin: 6px 0 14px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .persona-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .persona-btn {
      appearance: none;
      border: 0;
      min-height: 52px;
      padding: 8px 10px;
      border-radius: 18px;
      background: rgba(28, 38, 99, 0.06);
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .persona-btn.active {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      transform: translateY(-2px);
      box-shadow: 0 12px 20px rgba(64, 153, 255, 0.18);
    }

    .persona-readout {
      margin-top: 12px;
      padding: 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(28, 38, 99, 0.06);
      font-size: 13px;
      line-height: 20px;
      color: var(--dark-blue);
    }

    .persona-readout strong {
      display: block;
      margin-bottom: 6px;
      font-size: 12px;
      line-height: 18px;
      color: var(--pink);
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    @keyframes drift {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(0, 14px, 0); }
    }

    @keyframes pulse {
      0% { transform: scale(0.92); box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.18); }
      70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(248, 76, 162, 0); }
      100% { transform: scale(0.92); box-shadow: 0 0 0 0 rgba(248, 76, 162, 0); }
    }

    @keyframes sweep {
      0% { transform: translateX(120%); }
      50% { transform: translateX(-10%); }
      100% { transform: translateX(-120%); }
    }

    @keyframes cueSlide {
      0% { background-position: 0% 50%; }
      100% { background-position: 200% 50%; }
    }

    @keyframes riseRing {
      from { stroke-dashoffset: 164; }
      to { stroke-dashoffset: 28; }
    }

    @media (min-width: 768px) {
      body {
        padding-top: 36px;
      }

      .page {
        max-width: 510px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="ambient-orb one"></div>
    <div class="ambient-orb two"></div>

    <section class="prototype-meta">
      <div>
        <strong>UcarPAC ストアスクショ検証</strong>
        <span>375px基準 / スワイプでA・B・Cを切り替え</span>
      </div>
      <div class="mode-pill">C案 / Interactive</div>
    </section>

    <nav class="nav-chips" aria-label="Store screenshots">
      <button class="nav-chip active" data-index="0">スクショA<br>AI査定</button>
      <button class="nav-chip" data-index="1">スクショB<br>出費管理</button>
      <button class="nav-chip" data-index="2">スクショC<br>電話0本</button>
    </nav>

    <div class="hint-row">
      <span>App Store / Google Play 用の縦長ビジュアルを1画面で確認</span>
      <span class="swipe-cue">左右スワイプ</span>
    </div>

    <section class="viewer" id="viewer">
      <div class="track" id="track">
        <div class="panel">
