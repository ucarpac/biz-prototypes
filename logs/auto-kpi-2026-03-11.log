  <script>
    (function () {
      const track = document.getElementById("track");
      const viewer = document.getElementById("viewer");
      const chips = Array.from(document.querySelectorAll(".nav-chip"));
      const dots = Array.from(document.querySelectorAll(".dot"));
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const jumpButtons = Array.from(document.querySelectorAll("[data-index]"));
      let current = 0;
      let startX = 0;
      let deltaX = 0;

      function updateStage(index) {
        current = Math.max(0, Math.min(2, index));
        document.documentElement.style.setProperty("--stage-index", String(current));
        chips.forEach((chip, idx) => chip.classList.toggle("active", idx === current));
        dots.forEach((dot, idx) => dot.classList.toggle("active", idx === current));
      }

      jumpButtons.forEach((button) => {
        button.addEventListener("click", () => {
          updateStage(Number(button.dataset.index));
        });
      });

      prevBtn.addEventListener("click", () => updateStage(current - 1));
      nextBtn.addEventListener("click", () => updateStage(current + 1));

      viewer.addEventListener("pointerdown", (event) => {
        startX = event.clientX;
        deltaX = 0;
      });

      viewer.addEventListener("pointermove", (event) => {
        if (!startX) return;
        deltaX = event.clientX - startX;
      });

      function endSwipe() {
        if (Math.abs(deltaX) > 48) {
          if (deltaX < 0) updateStage(current + 1);
          if (deltaX > 0) updateStage(current - 1);
        }
        startX = 0;
        deltaX = 0;
      }

      viewer.addEventListener("pointerup", endSwipe);
      viewer.addEventListener("pointercancel", endSwipe);
      viewer.addEventListener("pointerleave", () => {
        if (startX) endSwipe();
      });

      const screenA = document.getElementById("screenA");
      const carStage = document.getElementById("carStage");
      const confidenceValue = document.getElementById("confidenceValue");
      const estimateValue = document.getElementById("estimateValue");
      const meterLabel = document.getElementById("meterLabel");
      const scanBtn = document.getElementById("scanBtn");

      function runScan() {
        screenA.classList.remove("revealed");
        carStage.classList.remove("scanning");
        confidenceValue.innerHTML = '38<small>%</small>';
        estimateValue.textContent = "¥2.98M";
        meterLabel.textContent = "写真待ち";

        window.setTimeout(() => {
          carStage.classList.add("scanning");
        }, 20);

        window.setTimeout(() => {
          screenA.classList.add("revealed");
          confidenceValue.innerHTML = '92<small>%</small>';
          estimateValue.textContent = "¥3.18M";
          meterLabel.textContent = "高精度";
        }, 980);

        window.setTimeout(() => {
          carStage.classList.remove("scanning");
        }, 2600);
      }

      scanBtn.addEventListener("click", runScan);

      const forecastSets = {
        "3m": {
          title: "AI予測価値 ¥2,930,000",
          delta: "現在比 -¥90,000",
          area: "M0 112 C40 98 74 90 112 88 C146 87 184 96 208 102 C235 109 268 116 320 90 L320 154 L0 154 Z",
          points: [
            [112, 88],
            [208, 102],
            [320, 90]
          ]
        },
        "6m": {
          title: "AI予測価値 ¥2,860,000",
          delta: "現在比 -¥160,000",
          area: "M0 112 C42 102 74 97 112 98 C145 99 180 110 208 117 C236 124 272 127 320 112 L320 154 L0 154 Z",
          points: [
            [112, 98],
            [208, 117],
            [320, 112]
          ]
        },
        "cost": {
          title: "維持費込み実質価値 ¥2,780,000",
          delta: "6ヶ月維持費反映 -¥240,000",
          area: "M0 112 C38 104 72 103 112 108 C148 113 180 122 208 128 C236 133 270 136 320 124 L320 154 L0 154 Z",
          points: [
            [112, 108],
            [208, 128],
            [320, 124]
          ]
        }
      };

      const forecastButtons = Array.from(document.querySelectorAll("[data-forecast]"));
      const forecastBtn = document.getElementById("forecastBtn");
      const forecastTitle = document.getElementById("forecastTitle");
      const forecastDelta = document.getElementById("forecastDelta");
      const forecastArea = document.getElementById("forecastArea");
      const point1 = document.getElementById("point1");
      const point2 = document.getElementById("point2");
      const point3 = document.getElementById("point3");
      let forecastIndex = 0;
      const forecastOrder = ["3m", "6m", "cost"];

      function applyForecast(key) {
        const data = forecastSets[key];
        forecastButtons.forEach((button) => button.classList.toggle("active", button.dataset.forecast === key));
        forecastTitle.textContent = data.title;
        forecastDelta.textContent = data.delta;
        forecastArea.setAttribute("d", data.area);
        [point1, point2, point3].forEach((point, idx) => {
          point.setAttribute("cx", data.points[idx][0]);
          point.setAttribute("cy", data.points[idx][1]);
        });
        forecastIndex = forecastOrder.indexOf(key);
      }

      forecastButtons.forEach((button) => {
        button.addEventListener("click", () => applyForecast(button.dataset.forecast));
      });

      forecastBtn.addEventListener("click", () => {
        const next = (forecastIndex + 1) % forecastOrder.length;
        applyForecast(forecastOrder[next]);
      });

      const compareTabs = Array.from(document.querySelectorAll("[data-compare]"));
      const compareBtn = document.getElementById("compareBtn");
      const compareHeadline = document.getElementById("compareHeadline");
      const callCount = document.getElementById("callCount");
      const callLabel = document.getElementById("callLabel");
      const barCalls = document.getElementById("barCalls");
      const barStress = document.getElementById("barStress");
      const barSpeed = document.getElementById("barSpeed");
      const barCallsLabel = document.getElementById("barCallsLabel");
      const barStressLabel = document.getElementById("barStressLabel");
      const barSpeedLabel = document.getElementById("barSpeedLabel");
      const compareNote = document.getElementById("compareNote");
      const compareStates = {
        ucarpac: {
          headline: "UcarPACは相場チェック中の営業電話 0本",
          count: "0",
          label: "相場チェック中の電話",
          calls: "6%",
          stress: "12%",
          speed: "92%",
          callsLabel: "0本",
          stressLabel: "かなり低い",
          speedLabel: "すぐ見られる",
          note: "個人情報なしでAI査定開始。売却相談に進んだあとだけ、必要なやり取りへ進みます。"
        },
        mota: {
          headline: "MOTA型は上位3社からの連絡が前提",
          count: "3",
          label: "結果後に連絡の可能性",
          calls: "54%",
          stress: "48%",
          speed: "68%",
          callsLabel: "最大3社",
          stressLabel: "比較的ある",
          speedLabel: "翌日待ち",
          note: "入札結果の明確さはある一方、結果確認まで待機が必要で、連絡も複数発生しやすい想定です。"
        },
        ikkatsu: {
          headline: "一括査定型は複数社とのやり取りが発生",
          count: "10",
          label: "連絡が集中しやすい",
          calls: "94%",
          stress: "92%",
          speed: "58%",
          callsLabel: "最大10社",
          stressLabel: "高い",
          speedLabel: "入力後対応多め",
          note: "比較対象が多いぶん、電話や日程調整の負担が重くなりやすい構図を視覚化しています。"
        }
      };
      let compareOrder = ["ucarpac", "mota", "ikkatsu"];
      let compareIndex = 0;

      function applyCompare(key) {
        const data = compareStates[key];
        compareTabs.forEach((tab) => tab.classList.toggle("active", tab.dataset.compare === key));
        compareHeadline.textContent = data.headline;
        callCount.textContent = data.count;
        callLabel.textContent = data.label;
        barCalls.style.setProperty("--w", data.calls);
        barStress.style.setProperty("--w", data.stress);
        barSpeed.style.setProperty("--w", data.speed);
        barCallsLabel.textContent = data.callsLabel;
        barStressLabel.textContent = data.stressLabel;
        barSpeedLabel.textContent = data.speedLabel;
        compareNote.textContent = data.note;
        compareIndex = compareOrder.indexOf(key);
      }

      compareTabs.forEach((tab) => {
        tab.addEventListener("click", () => applyCompare(tab.dataset.compare));
      });

      compareBtn.addEventListener("click", () => {
        const next = (compareIndex + 1) % compareOrder.length;
        applyCompare(compareOrder[next]);
      });

      const personaButtons = Array.from(document.querySelectorAll("[data-persona]"));
      const personaReadout = document.getElementById("personaReadout");
      const personaTexts = {
        price: "価格だけ先に知りたい層には、スクショAの「AI査定」とスクショCの「電話0本」を連続で見せる設計が効きます。",
        timing: "売り時を迷う層には、スクショBの将来予測グラフが刺さります。出費管理と未来価格を一緒に見せると滞在理由が増えます。",
