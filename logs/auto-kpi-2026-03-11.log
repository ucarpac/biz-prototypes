      font-weight: 700;
      cursor: pointer;
      transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease;
    }

    .ghost-btn {
      background: white;
      color: var(--dark-blue);
      border: 1px solid rgba(28, 38, 99, 0.09);
    }

    .ghost-btn:hover,
    .cta-btn:hover,
    .tab:hover {
      transform: translateY(-1px);
    }

    .cta-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 14px 28px rgba(44, 190, 255, 0.25);
    }

    .layout {
      display: grid;
      gap: 18px;
      margin-top: 18px;
    }

    .screens {
      display: grid;
      gap: 18px;
    }

    .phone-card {
      position: relative;
      padding: 14px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(28, 38, 99, 0.08);
      box-shadow: 0 24px 60px rgba(20, 32, 90, 0.1);
      transition: transform 0.35s ease, box-shadow 0.35s ease, opacity 0.35s ease, border-color 0.35s ease;
      opacity: 0.9;
    }

    .phone-card.active {
      transform: translateY(-4px);
      box-shadow: 0 30px 72px rgba(20, 32, 90, 0.16);
      border-color: rgba(248, 76, 162, 0.22);
      opacity: 1;
    }

    .screen-label {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      margin-bottom: 12px;
      padding: 0 4px;
    }

    .screen-label strong {
      color: var(--dark-blue);
      font-size: 14px;
    }

    .screen-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(29, 220, 255, 0.13);
    }

    .phone {
      position: relative;
      width: min(100%, 360px);
      margin: 0 auto;
      border-radius: 36px;
      padding: 10px;
      background: linear-gradient(180deg, #091355, #1d2e93);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14), 0 25px 45px rgba(11, 23, 77, 0.32);
    }

    .phone.android {
      border-radius: 28px;
    }

    .screen {
      position: relative;
      min-height: 680px;
      overflow: hidden;
      border-radius: 28px;
      background: white;
    }

    .android .screen {
      border-radius: 20px;
    }

    .notch,
    .camera {
      position: absolute;
      z-index: 3;
      left: 50%;
      transform: translateX(-50%);
      background: #030512;
    }

    .notch {
      top: 8px;
      width: 120px;
      height: 28px;
      border-radius: 0 0 18px 18px;
    }

    .camera {
      top: 12px;
      width: 64px;
      height: 8px;
      border-radius: 99px;
    }

    .android .camera {
      top: 10px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      box-shadow: 0 0 0 3px rgba(3, 5, 18, 0.18);
    }

    .shot {
      position: relative;
      min-height: 680px;
      padding: 18px 18px 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .shot.a {
      background:
        radial-gradient(circle at top right, rgba(248, 76, 162, 0.3), transparent 26%),
        radial-gradient(circle at 10% 20%, rgba(29, 220, 255, 0.28), transparent 26%),
        var(--gradient-night);
      color: white;
    }

    .shot.b {
      background:
        radial-gradient(circle at 85% 10%, rgba(111, 194, 255, 0.2), transparent 20%),
        radial-gradient(circle at 10% 5%, rgba(248, 76, 162, 0.14), transparent 18%),
        var(--gradient-sky);
      color: var(--text-black);
    }

    .shot.c {
      background:
        radial-gradient(circle at 88% 10%, rgba(248, 76, 162, 0.14), transparent 18%),
        radial-gradient(circle at 0% 18%, rgba(29, 220, 255, 0.18), transparent 20%),
        linear-gradient(180deg, #ffffff, #f7f9fe 56%, #eef4ff 100%);
      color: var(--text-black);
    }

    .status {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 18px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
      opacity: 0.9;
    }

    .store-chip-row,
    .mini-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .store-chip,
    .mini-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .store-chip {
      color: white;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(8px);
    }

    .shot.b .store-chip,
    .shot.c .store-chip {
      color: var(--dark-blue);
      background: rgba(28, 38, 99, 0.05);
      border: 1px solid rgba(28, 38, 99, 0.07);
    }

    .mini-chip {
      min-height: 28px;
      padding: 0 10px;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.14);
    }

    .shot.b .mini-chip,
    .shot.c .mini-chip {
      background: white;
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .headline {
      margin: 0;
      font-size: 32px;
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.04em;
    }

    .headline span {
      color: var(--pink);
    }

    .subcopy {
      margin: 0;
      font-size: 13px;
      line-height: 1.7;
      opacity: 0.92;
    }

    .stack {
      display: grid;
      gap: 12px;
    }

    .glass,
    .panel,
    .compare-card {
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow: 0 18px 32px rgba(7, 16, 70, 0.2);
    }

    .glass {
      padding: 16px;
      background: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(12px);
    }

    .shot.b .panel,
    .shot.c .panel,
    .shot.b .compare-card,
    .shot.c .compare-card {
      box-shadow: 0 18px 36px rgba(16, 28, 76, 0.09);
    }

    .panel {
      padding: 16px;
      background: white;
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .muted {
      opacity: 0.76;
      font-size: 12px;
    }

    .price {
      font-family: var(--font-number);
      font-size: 42px;
      line-height: 1;
      letter-spacing: 0.01em;
    }

    .price small {
      font-family: var(--font-sans);
      font-size: 16px;
      font-weight: 700;
      margin-left: 4px;
    }

    .delta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      background: rgba(248, 76, 162, 0.16);
      color: #ffd3ea;
    }

    .shot.b .delta,
    .shot.c .delta {
      color: #a1125f;
      background: rgba(248, 76, 162, 0.1);
    }

    .value-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 4px;
    }

    .value-box {
      padding: 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
      text-align: center;
    }

    .shot.b .value-box,
    .shot.c .value-box {
      background: #f6f8ff;
    }

    .value-box strong {
      display: block;
      font-family: var(--font-number);
      font-size: 18px;
      color: inherit;
    }

    .value-box span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      opacity: 0.8;
    }

    .chart-card {
      display: grid;
      gap: 12px;
    }

    .chart-wrap {
      padding: 12px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.1);
    }

    .shot.b .chart-wrap,
    .shot.c .chart-wrap {
      background: #f7f9ff;
      border: 1px solid rgba(28, 38, 99, 0.06);
    }

    .axis-row {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      font-size: 10px;
      opacity: 0.72;
    }

    .fact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .fact {
      padding: 12px;
      border-radius: 18px;
      background: white;
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .fact strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      margin-bottom: 4px;
    }

    .fact p {
      margin: 0;
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .expense-bars {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      gap: 6px;
    }

    .expense-item .row strong {
      font-size: 12px;
      color: var(--dark-blue);
    }

    .bar-track {
      width: 100%;
      height: 10px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.08);
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      width: 0;
      transition: width 1.1s cubic-bezier(.22, 1, .36, 1);
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
    }

    .bar-fill.pink {
      background: linear-gradient(90deg, #f84ca2, #ff88c2);
    }

    .bar-fill.dark {
      background: linear-gradient(90deg, #1c2663, #3850d7);
    }

    .cta-card {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      min-height: 62px;
      padding: 14px 16px;
      border-radius: 22px;
      background: white;
      box-shadow: 0 16px 28px rgba(15, 25, 82, 0.16);
    }

    .cta-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
    }

    .cta-card span {
      display: block;
      margin-top: 4px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .cta-pill {
      min-width: 118px;
      min-height: 40px;
      border-radius: 999px;
      padding: 0 14px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-weight: 800;
      display: grid;
      place-items: center;
      animation: pulse 2.8s ease-in-out infinite;
    }

    .compare-card {
      padding: 16px;
      background: white;
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .compare-header {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      margin-bottom: 12px;
    }

    .compare-badge {
      min-height: 30px;
      padding: 0 12px;
      border-radius: 999px;
      display: inline-grid;
      place-items: center;
      background: rgba(248, 76, 162, 0.12);
      color: #a1125f;
      font-size: 11px;
      font-weight: 800;
    }

    .compare-table {
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 88px 1fr 1fr 1fr;
      gap: 8px;
      align-items: center;
      font-size: 11px;
      text-align: center;
    }

    .compare-row > div {
      padding: 10px 6px;
      border-radius: 14px;
      background: #f7f9ff;
      min-height: 42px;
      display: grid;
      place-items: center;
    }

    .compare-row .head {
      background: transparent;
      justify-items: start;
      padding-left: 0;
      color: var(--text-gray);
      font-weight: 700;
    }

    .compare-row .best {
      background: linear-gradient(90deg, rgba(29, 220, 255, 0.18), rgba(77, 180, 255, 0.24));
      color: var(--dark-blue);
      font-weight: 800;
    }

    .compare-row .warn {
      background: rgba(248, 76, 162, 0.08);
      color: #9a205f;
      font-weight: 700;
    }

    .compare-bars {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .compare-bar-line {
      display: grid;
      gap: 6px;
    }

    .compare-bar-line .row {
      align-items: flex-end;
      font-size: 11px;
    }

    .compare-bar-line strong {
      color: var(--dark-blue);
    }

    .source-note {
      margin-top: 10px;
      font-size: 10px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .evidence-panel {
      padding: 18px;
      display: grid;
      gap: 14px;
    }

    .evidence-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .evidence-head h2 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 18px;
    }

    .evidence-grid {
      display: grid;
      gap: 12px;
    }

    .evidence-card {
      padding: 14px;
      border-radius: 18px;
      background: white;
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .evidence-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      margin-bottom: 6px;
    }

    .evidence-card p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .evidence-card a {
      color: var(--text-under-blue);
      word-break: break-all;
    }

    .scenario-box {
      padding: 16px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(28, 38, 99, 0.04), rgba(248, 76, 162, 0.04));
      border: 1px solid rgba(28, 38, 99, 0.08);
    }

    .scenario-box strong {
      display: block;
      color: var(--dark-blue);
      margin-bottom: 8px;
      font-size: 14px;
    }

    .scenario-box p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .footer-note {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(28, 38, 99, 0.04);
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .hidden {
      display: none !important;
    }

    @keyframes pulse {
      0%, 100% { transform: translateY(0) scale(1); box-shadow: 0 12px 24px rgba(44, 190, 255, 0.18); }
      50% { transform: translateY(-1px) scale(1.02); box-shadow: 0 18px 32px rgba(44, 190, 255, 0.28); }
    }

    @media (min-width: 760px) {
      .page {
        padding-top: 26px;
      }

      .hero {
        padding: 26px 24px 24px;
      }

      .hero-grid {
        grid-template-columns: 1.2fr 1fr;
      }

      .layout {
        grid-template-columns: 1.35fr 0.9fr;
        align-items: start;
      }

      .screens {
        grid-template-columns: repeat(3, 1fr);
      }

      .phone-card {
        height: 100%;
      }

      .screen {
        min-height: 720px;
      }

      .shot {
        min-height: 720px;
      }

      .evidence-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 759px) {
      .hero {
        border-radius: 24px;
      }

      .phone-card:not(.active) {
        transform: scale(0.985);
      }

      .compare-row {
        grid-template-columns: 78px 1fr 1fr 1fr;
      }

      .headline {
        font-size: 29px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="hero">
      <div class="hero-top">
        <div class="eyebrow">ASO検証 / ストアPV→DL率改善 / 2026-03-11</div>
        <div>
          <h1>17.3% → <span style="color:#f84ca2;">25%</span> を狙う<br>データドリブンなストアスクショ案</h1>
          <p class="hero-copy">
            Appleでは検索面に最初の1〜3枚が出る可能性があり、Google Playでは訴求別のカスタム掲載面が使えます。
            そこで、UcarPACの差別化要素を「AI査定」「出費管理＋将来予測」「電話0本で相場チェック」に分解し、
            数字・比較表・グラフ中心でCVR改善仮説を1画面ずつ明確化します。
          </p>
        </div>
      </div>

      <div class="hero-grid">
        <div class="metric-panel">
          <div class="metric-head">
            <div>
              <div class="metric-title">ストア詳細ページ閲覧 → DL CVR</div>
              <div class="metric-sub">内部基準値 17.3% / KPI 25.0%</div>
            </div>
            <div class="pill" style="padding:8px 12px;border-radius:999px;background:rgba(248,76,162,0.1);color:#a1125f;font-size:11px;font-weight:800;">+7.7pt 必要</div>
          </div>

          <div class="meter-row">
            <div class="meter-main">
              <div class="ring" id="cvrRing">
                <div class="ring-value" id="ringValue">17.3<span>CVR</span></div>
              </div>
              <div class="progress-wrap">
                <div class="progress-labels">
                  <strong style="color:#1c2663;">現在値</strong>
                  <strong style="color:#1c2663;">目標 25.0%</strong>
                </div>
                <div class="progress-track">
                  <div class="progress-target"></div>
                  <div class="progress-fill" id="cvrFill"></div>
                </div>
                <div class="gain-line">
                  <span>ストアPV 10,000件あたり</span>
                  <strong id="gainText">+770 DL の余地</strong>
                </div>
                <input id="cvrSlider" class="kpi-slider" type="range" min="17.3" max="25" step="0.1" value="17.3" />
              </div>
            </div>
          </div>
        </div>

        <div class="control-panel">
          <div class="tab-row" id="tabs">
            <button class="tab active" data-screen="a">A / iOS
              <small>AI査定を最初の1枚で理解</small>
            </button>
            <button class="tab" data-screen="b">B / Android
              <small>出費管理＋将来予測を同時訴求</small>
            </button>
            <button class="tab" data-screen="c">C / 比較
              <small>電話0本で相場チェックを数値化</small>
            </button>
          </div>
          <div class="toggle-row">
            <button class="ghost-btn" id="autoplayBtn" aria-pressed="false">自動切替 OFF</button>
            <button class="cta-btn" id="evidenceBtn">根拠を表示</button>
          </div>
        </div>
      </div>
    </section>

    <section class="layout">
      <div class="screens" id="screens">
        <article class="phone-card active" data-card="a">
          <div class="screen-label">
            <strong>ストアスクショA</strong>
            <span class="screen-tag">iOS向け / AI査定訴求</span>
          </div>
          <div class="phone ios">
            <div class="screen">
              <div class="notch"></div>
              <div class="shot a">
                <div class="status">
                  <span>9:41</span>
                  <span>5G 100%</span>
                </div>
                <div class="store-chip-row">
                  <span class="store-chip">個人情報なし</span>
                  <span class="store-chip">最短45秒</span>
                  <span class="store-chip">3か月先まで予測</span>
                </div>
                <h2 class="headline">AIがあなたの愛車を<br><span>即査定</span></h2>
                <p class="subcopy">2021年 ハリアー Z Leather Package / 34,800km / パールホワイトの相場をリアルタイム推定</p>

                <div class="glass stack">
                  <div class="row">
                    <div>
                      <div class="muted">現在のAI査定</div>
                      <div class="price">318<span style="font-size:28px;">.2</span><small>万円</small></div>
                    </div>
                    <div class="delta">3か月後 -9.4万円</div>
                  </div>

                  <div class="value-grid">
                    <div class="value-box">
                      <strong>318.2</strong>
                      <span>今の想定</span>
                    </div>
                    <div class="value-box">
                      <strong>308.8</strong>
                      <span>3か月後</span>
                    </div>
                    <div class="value-box">
                      <strong>296.1</strong>
                      <span>6か月後</span>
                    </div>
                  </div>

                  <div class="chart-card">
                    <div class="row">
                      <strong style="font-size:13px;">価値推移グラフ</strong>
                      <span class="mini-chip">誤差幅 ±6.2万円</span>
                    </div>
                    <div class="chart-wrap">
                      <svg viewBox="0 0 320 170" width="100%" height="170" aria-label="AI査定の将来予測グラフ">
                        <defs>
                          <linearGradient id="lineFillA" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="rgba(29,220,255,0.5)"></stop>
                            <stop offset="100%" stop-color="rgba(29,220,255,0.02)"></stop>
                          </linearGradient>
                        </defs>
                        <g opacity="0.18" stroke="#ffffff">
                          <line x1="24" y1="28" x2="24" y2="140"></line>
                          <line x1="24" y1="140" x2="296" y2="140"></line>
                          <line x1="24" y1="56" x2="296" y2="56"></line>
                          <line x1="24" y1="84" x2="296" y2="84"></line>
                          <line x1="24" y1="112" x2="296" y2="112"></line>
                        </g>
                        <path d="M24 40 C60 44, 86 60, 116 66 S182 92, 206 96 S258 116, 296 128 L296 140 L24 140 Z" fill="url(#lineFillA)"></path>
