      background: linear-gradient(180deg, rgba(255,216,232,0.55), rgba(255,255,255,0.92));
      padding: 14px 12px;
      position: relative;
      overflow: hidden;
    }

    .forecast-mini::after {
      content: "";
      position: absolute;
      right: -18px;
      bottom: -18px;
      width: 88px;
      height: 88px;
      background: radial-gradient(circle, rgba(255,154,99,0.22), transparent 66%);
      border-radius: 50%;
    }

    .metric-value {
      font-size: 24px;
      line-height: 1.1;
      font-weight: 800;
      color: var(--pink);
      letter-spacing: -0.04em;
    }

    .metric-value small {
      font-size: 14px;
      color: var(--dark-blue);
      margin-left: 2px;
    }

    .metric-note {
      margin-top: 8px;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .chip-row {
      margin-top: 12px;
    }

    .chip-row button,
    .metric-toggle button,
    .compare-switch button {
      padding: 10px 14px;
      border-radius: var(--radius-chip);
      font-size: 12px;
      font-weight: 700;
      color: var(--text-gray);
      background: rgba(255,255,255,0.78);
      border: 1px solid rgba(28,38,99,0.08);
      transition: all var(--transition);
    }

    .chip-row button.active,
    .metric-toggle button.active,
    .compare-switch button.active {
      color: var(--white);
      background: var(--dark-blue);
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.2);
    }

    .chart-card {
      margin-top: 14px;
      padding: 16px;
    }

    .chart-heading {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
    }

    .chart-heading strong {
      display: block;
      color: var(--dark-blue);
      font-size: 16px;
      line-height: 1.5;
    }

    .chart-heading span {
      display: block;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
      margin-top: 2px;
    }

    .price-tag {
      padding: 8px 10px;
      border-radius: 16px;
      background: rgba(255,216,232,0.62);
      color: var(--pink);
      font-weight: 800;
      font-size: 11px;
      white-space: nowrap;
    }

    .chart-box {
      position: relative;
      height: 152px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,251,255,0.78)),
        linear-gradient(90deg, rgba(28,38,99,0.04) 1px, transparent 1px),
        linear-gradient(rgba(28,38,99,0.04) 1px, transparent 1px);
      background-size: auto, 25% 100%, 100% 25%;
      overflow: hidden;
    }

    .line-svg {
      position: absolute;
      inset: 14px 12px 18px;
      width: calc(100% - 24px);
      height: calc(100% - 32px);
    }

    .line-svg path {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 440;
      stroke-dashoffset: 440;
      animation: draw 1.2s ease forwards;
    }

    .line-shadow {
      stroke: rgba(248, 76, 162, 0.16);
      stroke-width: 12;
    }

    .line-main {
      stroke: var(--pink);
      stroke-width: 4;
    }

    .point-marker {
      position: absolute;
      top: 42%;
      left: 58%;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--white);
      border: 4px solid var(--pink);
      box-shadow: 0 0 0 8px rgba(248,76,162,0.14);
      transition: left 380ms ease, top 380ms ease;
    }

    .axis-labels {
      position: absolute;
      left: 12px;
      right: 12px;
      bottom: 8px;
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .cta-row {
      margin-top: auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding-top: 14px;
    }

    .primary-btn,
    .ghost-btn {
      width: 100%;
      min-height: 48px;
      border-radius: 999px;
      border: 0;
      font-family: inherit;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: transform var(--transition), box-shadow var(--transition), opacity var(--transition);
    }

    .primary-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 16px 30px rgba(77, 180, 255, 0.28);
    }

    .ghost-btn {
      background: rgba(255,255,255,0.88);
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.08);
    }

    .primary-btn:active,
    .ghost-btn:active {
      transform: scale(0.98);
    }

    .small-foot {
      font-size: 11px;
      line-height: 1.6;
      color: var(--text-gray);
      text-align: center;
    }

    .list-card {
      margin-top: 14px;
      padding: 16px;
    }

    .list-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 12px;
    }

    .mini-tile {
      border-radius: 18px;
      padding: 12px;
      background: rgba(255,255,255,0.78);
      min-height: 88px;
      border: 1px solid rgba(28,38,99,0.05);
    }

    .mini-tile .tile-label {
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .mini-tile .tile-value {
      margin-top: 8px;
      font-size: 22px;
      line-height: 1.2;
      color: var(--dark-blue);
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .mini-tile .tile-value small {
      font-size: 12px;
      margin-left: 4px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .mini-tile.accent {
      background: linear-gradient(180deg, rgba(221,248,243,0.9), rgba(255,255,255,0.84));
    }

    .mini-tile.pinkish {
      background: linear-gradient(180deg, rgba(255,216,232,0.92), rgba(255,255,255,0.86));
    }

    .metric-toggle {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .bars {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 10px;
      height: 140px;
      margin-top: 12px;
    }

    .bar-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .bar-wrap {
      width: 100%;
      flex: 1;
      display: flex;
      align-items: flex-end;
    }

    .bar {
      width: 100%;
      border-radius: 18px 18px 8px 8px;
      transform-origin: bottom center;
      animation: grow 900ms ease both;
      box-shadow: inset 0 -8px 0 rgba(28,38,99,0.08);
    }

    .bar.gas { background: linear-gradient(180deg, #ffd172, #ffaf4d); height: 54%; }
    .bar.insurance { background: linear-gradient(180deg, #8ad6ff, #4db4ff); height: 46%; }
    .bar.maintenance { background: linear-gradient(180deg, #ff9fcf, #f84ca2); height: 32%; }
    .bar.tax { background: linear-gradient(180deg, #c8d0ff, #8c98ef); height: 26%; }

    .bar-col span {
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 700;
      text-align: center;
      line-height: 1.4;
    }

    .forecast-panel,
    .expense-panel {
      transition: opacity var(--transition), transform var(--transition);
    }

    .is-hidden {
      display: none;
    }

    .progress-card {
      margin-top: 14px;
      padding: 14px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,248,241,0.82));
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .ring {
      width: 74px;
      height: 74px;
      border-radius: 50%;
      background:
        radial-gradient(closest-side, #fff 73%, transparent 74%),
        conic-gradient(var(--pink) 0 212deg, rgba(28,38,99,0.08) 212deg 360deg);
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .ring strong {
      font-size: 15px;
      color: var(--dark-blue);
      line-height: 1.1;
      text-align: center;
    }

    .compare-card {
      margin-top: 14px;
      padding: 18px 16px;
    }

    .compare-switch {
      display: flex;
      gap: 8px;
      margin: 12px 0 14px;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr 0.95fr;
      gap: 8px;
      align-items: stretch;
    }

    .compare-col {
      border-radius: 18px;
      padding: 14px 12px;
      background: rgba(255,255,255,0.8);
      border: 1px solid rgba(28,38,99,0.06);
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 198px;
    }

    .compare-col.highlight {
      background: linear-gradient(180deg, rgba(255,216,232,0.96), rgba(255,255,255,0.88));
      border-color: rgba(248,76,162,0.28);
      box-shadow: 0 16px 26px rgba(248,76,162,0.14);
    }

    .compare-col h3 {
      margin: 0;
      font-size: 14px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .compare-col p {
      margin: 0;
      font-size: 10px;
      line-height: 1.55;
      color: var(--text-gray);
    }

    .call-count {
      margin-top: 2px;
      font-size: 28px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -0.05em;
      color: var(--dark-blue);
      transition: transform 220ms ease;
    }

    .call-count.bump {
      transform: scale(1.08);
    }

    .call-count.pink {
      color: var(--pink);
    }

    .count-label {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
      font-weight: 700;
    }

    .quiet-phone {
      margin-top: auto;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.84);
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
    }

    .quiet-phone .icon {
      width: 32px;
      height: 32px;
      border-radius: 12px;
      background: linear-gradient(180deg, #fff, #ffe7f2);
      position: relative;
      flex-shrink: 0;
    }

    .quiet-phone .icon::before {
      content: "";
      position: absolute;
      inset: 7px 10px;
      border-radius: 7px;
      border: 2px solid var(--pink);
    }

    .quiet-phone .icon::after {
      content: "";
      position: absolute;
      right: 4px;
      top: 4px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--warm-orange);
      box-shadow: 0 0 0 2px rgba(255,255,255,0.8);
    }

    .row-divider {
      height: 1px;
      background: var(--ruled-line);
      margin: 2px 0;
    }

    .story-line {
      margin-top: 12px;
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.84);
      font-size: 11px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .story-line strong {
      color: var(--dark-blue);
    }

    .foot-tags {
      margin-top: 14px;
    }

    .foot-tag {
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(28,38,99,0.06);
    }

    .spark {
      position: absolute;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: radial-gradient(circle, #fff 0%, #ffd6e8 52%, rgba(255,214,232,0) 72%);
      animation: float 3.1s ease-in-out infinite;
      opacity: 0.72;
      pointer-events: none;
    }

    .spark.s1 { top: 96px; left: 20px; animation-delay: -0.4s; }
    .spark.s2 { top: 154px; right: 24px; animation-delay: -1.1s; }
    .spark.s3 { bottom: 186px; left: 30px; animation-delay: -0.8s; }
    .spark.s4 { bottom: 90px; right: 40px; animation-delay: -1.6s; }

    .hint {
      position: absolute;
      right: 18px;
      bottom: 144px;
      padding: 9px 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.9);
      color: var(--dark-blue);
      font-family: var(--font-note);
      font-size: 13px;
      font-weight: 700;
      transform: rotate(5deg);
      box-shadow: 0 12px 22px rgba(28, 38, 99, 0.08);
    }

    .focus-outline {
      box-shadow:
        0 26px 64px rgba(28,38,99,0.18),
        0 0 0 4px rgba(248,76,162,0.1),
        inset 0 1px 0 rgba(255,255,255,0.86);
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes draw {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes grow {
      from {
        transform: scaleY(0.25);
        opacity: 0.3;
      }
      to {
        transform: scaleY(1);
        opacity: 1;
      }
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        opacity: 1;
      }
      50% {
        transform: scale(1.18);
        opacity: 0.76;
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0) scale(1);
      }
      50% {
        transform: translateY(-10px) scale(1.12);
      }
    }

    @media (min-width: 980px) {
      .prototype {
        padding: 28px 24px 72px;
      }

      .gallery {
        grid-template-columns: repeat(3, minmax(300px, 1fr));
        align-items: start;
      }

      .phone {
        display: block;
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .phone.active,
      .phone {
        box-shadow:
          0 24px 56px rgba(28, 38, 99, 0.16),
          inset 0 1px 0 rgba(255,255,255,0.86);
      }

      .phone.active.focus-outline {
        transform: translateY(-8px);
      }
    }

    @media (max-width: 979px) {
      .screen-switch {
        width: 100%;
      }

      .screen-switch button {
        flex: 1 1 100px;
      }
    }
  </style>
</head>
<body>
  <div class="prototype">
    <section class="intro">
      <div class="eyebrow">
        <span class="dot"></span>
        ストアPV→DL率改善向け スクリーンショット案
      </div>
      <h1>迷いを安心に変える、UcarPACのストアスクショ A/B/C</h1>
      <p>
        AI査定の安心感、出費管理の継続価値、そして「相場チェックまで電話0本」の差別化を、
        暖色アクセントとやわらかい質感で感情的に伝える1ファイルプロトタイプです。
      </p>
      <div class="screen-switch" aria-label="スクリーン切り替え">
        <button type="button" class="active" data-screen="a">スクショA</button>
        <button type="button" data-screen="b">スクショB</button>
        <button type="button" data-screen="c">スクショC</button>
      </div>
    </section>

    <main class="gallery">
      <section class="phone ios active focus-outline" data-id="a">
        <div class="phone-shell">
          <div class="notch"></div>
          <span class="spark s1"></span>
          <span class="spark s2"></span>
          <span class="spark s3"></span>
          <span class="spark s4"></span>
          <div class="status">
            <span>9:41</span>
            <div class="icons">
              <span class="sig"></span>
              <span class="wifi"></span>
              <span class="battery"></span>
            </div>
          </div>
          <div class="scene">
            <div class="scene-top">
              <div class="brand">
                <span class="brand-mark"></span>
                <span>UcarPAC</span>
              </div>
              <span class="platform">iOS向け / AI査定</span>
            </div>

            <div class="hero-card">
              <div class="badge-row">
                <span class="badge pink">個人情報なしでOK</span>
                <span class="badge blue">いま売らなくても安心</span>
              </div>
              <h2 class="hero-title">売るか迷う今こそ、<br>AIで相場を見て安心</h2>
              <p class="hero-sub">
                トヨタ プリウス S 2019年 / 42,300km。
                30秒の入力で、いまの相場も、少し先の売り時も見えてきます。
              </p>
              <div class="quick-stats">
                <span class="badge">査定開始 30秒</span>
                <span class="badge">8,000店オークション対応</span>
              </div>
              <span class="note">まずは金額だけ見たい人へ</span>
              <div class="car-illustration" aria-hidden="true">
                <div class="car-cloud">売らなくても<br>見てOK</div>
                <div class="car-body">
                  <div class="wheel"></div>
                </div>
              </div>
            </div>

            <div class="price-card">
              <div class="price-main">
                <div class="price-label">AI査定の参考価格</div>
                <div class="price-value">132.8<small>万円</small></div>
                <div class="price-caption">
                  全国の落札傾向と走行距離から推定。
                  営業電話なしで、まず相場感だけ確認できます。
                </div>
              </div>
              <div class="forecast-mini">
                <div class="price-label">選択中の未来予測</div>
                <div class="metric-value" id="forecast-value">129.4<small>万円</small></div>
                <div class="metric-note" id="forecast-note">
                  3か月後の予想。値下がり前に動く目安として使えます。
                </div>
              </div>
            </div>

            <div class="chip-row" aria-label="未来予測期間">
              <button type="button" data-period="1m">1か月後</button>
              <button type="button" class="active" data-period="3m">3か月後</button>
              <button type="button" data-period="6m">6か月後</button>
            </div>

            <div class="chart-card">
              <div class="chart-heading">
                <div>
                  <strong>いまの相場と、これからの変化</strong>
                  <span>査定価格の見通しをやさしく可視化</span>
                </div>
                <div class="price-tag" id="chart-tag">3か月後 -3.4万円</div>
              </div>
              <div class="chart-box">
                <svg class="line-svg" viewBox="0 0 320 120" preserveAspectRatio="none" aria-hidden="true">
                  <path class="line-shadow" d="M8 20 C70 24, 100 40, 156 48 S245 70, 312 96"></path>
                  <path class="line-main" d="M8 20 C70 24, 100 40, 156 48 S245 70, 312 96"></path>
                </svg>
                <div class="point-marker" id="point-marker"></div>
                <div class="axis-labels">
                  <span>いま</span>
                  <span>1か月</span>
                  <span>3か月</span>
                  <span>6か月</span>
                </div>
              </div>
            </div>

            <div class="cta-row">
              <button type="button" class="primary-btn">30秒でAI査定をはじめる</button>
              <button type="button" class="ghost-btn">個人情報なしで相場だけ見る</button>
              <div class="small-foot">ストア訴求案: 「AIがあなたの愛車を査定」「個人情報なしで相場チェック」</div>
            </div>
          </div>
        </div>
      </section>

      <section class="phone android" data-id="b">
        <div class="phone-shell">
          <div class="punch-hole"></div>
          <span class="spark s1"></span>
          <span class="spark s2"></span>
          <span class="spark s3"></span>
          <span class="spark s4"></span>
          <div class="status">
            <span>12:30</span>
            <div class="icons">
              <span class="sig"></span>
              <span class="wifi"></span>
              <span class="battery"></span>
            </div>
          </div>
          <div class="scene">
            <div class="scene-top">
              <div class="brand">
                <span class="brand-mark"></span>
                <span>UcarPAC</span>
              </div>
              <span class="platform">Android向け / 出費管理</span>
            </div>

            <div class="hero-card">
              <div class="badge-row">
                <span class="badge pink">出費も価値も見える化</span>
                <span class="badge blue">将来予測つき</span>
              </div>
              <h2 class="hero-title">維持費も売り時も、<br>ひと目でわかる</h2>
              <p class="hero-sub">
                ホンダ N-BOX Custom 2020年 / 26,900km。
                家計簿のように管理しながら、愛車の価値変化までまとめてチェック。
              </p>
              <div class="quick-stats">
                <span class="badge">今月の出費 34,200円</span>
                <span class="badge">6か月後予想 149.8万円</span>
              </div>
              <span class="note">つづけるほど、判断しやすい</span>
            </div>

            <div class="list-card">
              <div class="chart-heading">
                <div>
                  <strong>維持費ダッシュボード</strong>
                  <span>クルマにかかるお金をやさしく整理</span>
                </div>
              </div>
              <div class="list-grid">
                <div class="mini-tile accent">
                  <div class="tile-label">今月のガソリン</div>
                  <div class="tile-value">8,400<small>円</small></div>
                </div>
                <div class="mini-tile pinkish">
                  <div class="tile-label">今月の保険按分</div>
                  <div class="tile-value">6,800<small>円</small></div>
                </div>
                <div class="mini-tile">
                  <div class="tile-label">駐車場</div>
                  <div class="tile-value">12,000<small>円</small></div>
                </div>
                <div class="mini-tile">
                  <div class="tile-label">整備積立</div>
                  <div class="tile-value">7,000<small>円</small></div>
                </div>
