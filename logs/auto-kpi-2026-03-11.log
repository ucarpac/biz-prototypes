  <script>
    const chartSeries = {
      week: [182, 183, 181, 184, 183, 185, 184.2],
      month: [191, 189, 188.5, 187, 186.3, 185.4, 184.2],
      future: [184.2, 183.4, 181.1, 179.5, 176.2, 174.1, 171.8]
    };

    function renderLineChart(key) {
      const svg = document.getElementById("forecast-chart-a");
      const line = document.getElementById("forecast-line-a");
      const area = document.getElementById("forecast-area-a");
      const dots = document.getElementById("forecast-dots-a");
      const data = chartSeries[key];
      const width = 320;
      const height = 170;
      const left = 10;
      const right = 310;
      const top = 18;
      const bottom = 148;
      const max = Math.max(...data) + 2;
      const min = Math.min(...data) - 2;

      const points = data.map((value, index) => {
        const x = left + (index * (right - left) / (data.length - 1));
        const y = bottom - ((value - min) / (max - min)) * (bottom - top);
        return [x, y];
      });

      const path = points.map((point, index) => `${index === 0 ? "M" : "L"} ${point[0]} ${point[1]}`).join(" ");
      const areaPath = `${path} L ${points[points.length - 1][0]} ${bottom} L ${points[0][0]} ${bottom} Z`;
      line.setAttribute("d", path);
      area.setAttribute("d", areaPath);
      dots.innerHTML = points.map((point, index) => (
        `<circle cx="${point[0]}" cy="${point[1]}" r="${index === points.length - 1 ? 5.5 : 4}" fill="${index === points.length - 1 ? '#F84CA2' : '#ffffff'}" opacity="${index === points.length - 1 ? 1 : 0.85}"></circle>`
      )).join("");
      svg.setAttribute("data-series-active", key);
    }

    document.querySelectorAll(".tabs").forEach((group) => {
      group.addEventListener("click", (event) => {
        const button = event.target.closest(".tab");
        if (!button) return;
        group.querySelectorAll(".tab").forEach((tab) => tab.classList.remove("active"));
        button.classList.add("active");
        renderLineChart(button.dataset.series);
      });
    });

    const compareModes = {
      calls: `
        <tr>
          <td>相場確認時の電話</td>
          <td class="highlight-col yes">0本</td>
          <td class="warn">最大3社</td>
          <td class="no">最大10社</td>
        </tr>
        <tr>
          <td>個人情報なし査定</td>
          <td class="highlight-col yes">対応</td>
          <td class="no">非対応</td>
          <td class="no">非対応</td>
        </tr>
        <tr>
          <td>将来予測グラフ</td>
          <td class="highlight-col yes">あり</td>
          <td class="no">なし</td>
          <td class="no">なし</td>
        </tr>
        <tr>
          <td>売却時のやりとり</td>
          <td class="highlight-col yes">1社のみ</td>
          <td class="warn">上位3社</td>
          <td class="no">複数社</td>
        </tr>
      `,
      features: `
        <tr>
          <td>AI査定</td>
          <td class="highlight-col yes">対応</td>
          <td class="no">非対応</td>
          <td class="no">非対応</td>
        </tr>
        <tr>
          <td>出費管理</td>
          <td class="highlight-col yes">対応</td>
          <td class="no">非対応</td>
          <td class="no">非対応</td>
        </tr>
        <tr>
          <td>入札社数</td>
          <td class="highlight-col yes">8,000社</td>
          <td class="warn">数百社</td>
          <td class="no">最大10社</td>
        </tr>
        <tr>
          <td>アプリ体験</td>
          <td class="highlight-col yes">ネイティブ</td>
          <td class="no">Web中心</td>
          <td class="no">Web中心</td>
        </tr>
      `
    };

    document.querySelectorAll(".compare-toggle").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".compare-toggle").forEach((toggle) => toggle.classList.remove("active"));
        button.classList.add("active");
        document.getElementById("compare-body").innerHTML = compareModes[button.dataset.compare];
      });
    });

    document.querySelectorAll("[data-progress]").forEach((bar, index) => {
      setTimeout(() => {
        bar.style.width = `${bar.dataset.progress}%`;
      }, 200 + index * 120);
    });

    document.querySelectorAll("[data-cta]").forEach((button) => {
      button.addEventListener("click", () => {
        const original = button.textContent;
        button.textContent = "シミュレーション更新中...";
        button.style.opacity = "0.88";
        setTimeout(() => {
          button.textContent = "AI査定結果をチェック";
          button.style.opacity = "1";
          setTimeout(() => {
            button.textContent = original;
          }, 1800);
        }, 900);
      });
    });

    renderLineChart("week");
  </script>
</body>
