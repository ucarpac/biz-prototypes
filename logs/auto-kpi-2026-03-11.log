      line-height: 27px;
      color: var(--dark-blue);
    }

    .expense-card span {
      display: block;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .mission-strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 16px;
      border-radius: 20px;
      background: linear-gradient(90deg, rgba(248, 76, 162, 0.12), rgba(29, 220, 255, 0.12));
      border: 1px solid rgba(248, 76, 162, 0.16);
    }

    .mission-strip strong {
      display: block;
      font-size: 13px;
      line-height: 20px;
      color: var(--dark-blue);
    }

    .mission-strip span {
      display: block;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .ring {
      position: relative;
      width: 68px;
      height: 68px;
      flex-shrink: 0;
    }

    .ring svg {
      width: 100%;
      height: 100%;
      transform: rotate(-90deg);
    }

    .ring .track-ring {
      stroke: rgba(28, 38, 99, 0.08);
      stroke-width: 10;
      fill: none;
    }

    .ring .value-ring {
      stroke: url(#ringGradient);
      stroke-width: 10;
      fill: none;
      stroke-linecap: round;
      stroke-dasharray: 164;
      stroke-dashoffset: 28;
      animation: riseRing 1.2s ease;
    }

    .ring-value {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      text-align: center;
      font-size: 13px;
      line-height: 18px;
      font-weight: 900;
      color: var(--dark-blue);
    }

    .compare-hero {
      padding: 18px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(9, 19, 85, 0.98), rgba(28, 38, 99, 0.94));
      color: var(--white);
      box-shadow: 0 22px 40px rgba(9, 19, 85, 0.2);
    }

    .compare-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .compare-top strong {
      font-size: 14px;
      line-height: 21px;
    }

    .call-bubble {
      margin: 18px auto 14px;
      width: 170px;
      height: 170px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 50% 35%, rgba(29, 220, 255, 0.44), transparent 44%),
        radial-gradient(circle at 50% 70%, rgba(248, 76, 162, 0.18), transparent 56%),
        rgba(255, 255, 255, 0.08);
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.12),
        0 22px 40px rgba(0, 0, 0, 0.18);
      position: relative;
      overflow: hidden;
    }

    .call-bubble::before {
      content: "";
      position: absolute;
      inset: 14px;
      border-radius: inherit;
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .call-bubble strong {
      display: block;
      font-family: var(--font-number);
      font-size: 70px;
      line-height: 70px;
      letter-spacing: -0.06em;
    }

    .call-bubble span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      line-height: 18px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.76);
    }

    .compare-tabs {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 10px 0 14px;
    }

    .compare-tab {
      appearance: none;
      border: 0;
      min-height: 42px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.72);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .compare-tab.active {
      background: rgba(255, 255, 255, 0.96);
      color: var(--dark-blue);
      transform: translateY(-1px);
    }

    .compare-table {
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 78px 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.08);
    }

    .compare-row strong {
      font-size: 12px;
      line-height: 18px;
      color: rgba(255, 255, 255, 0.78);
    }

    .bar-track {
      height: 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: inherit;
      width: var(--w, 50%);
      background: var(--gradient-primary);
      transition: width 320ms ease, background 320ms ease;
    }

    .compare-row span {
      font-size: 12px;
      line-height: 18px;
      font-weight: 800;
      color: var(--white);
    }

    .compare-note {
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.1);
      font-size: 12px;
      line-height: 18px;
      color: rgba(255, 255, 255, 0.78);
    }

    .bullet-badges {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .bullet-badge {
      padding: 14px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.84);
      text-align: center;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.06);
    }

    .bullet-badge strong {
      display: block;
      font-size: 16px;
      line-height: 24px;
      color: var(--dark-blue);
    }

    .bullet-badge span {
      display: block;
      margin-top: 2px;
      font-size: 11px;
      line-height: 16px;
      color: var(--text-gray);
    }

    .footer-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-top: auto;
    }

    .caption {
      font-size: 10px;
      line-height: 15px;
      color: var(--text-gray);
    }

    .caption strong {
      color: var(--dark-blue);
    }

    .controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
      padding: 0 4px;
    }

    .pager {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      flex: 1;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(28, 38, 99, 0.16);
      transition: width 180ms ease, background 180ms ease;
    }

    .dot.active {
      width: 32px;
      background: var(--dark-blue);
    }

    .control-btn {
      appearance: none;
      border: 0;
      min-width: 88px;
      min-height: 44px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.88);
      color: var(--dark-blue);
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(28, 38, 99, 0.08);
    }

    .toolbox {
      margin-top: 18px;
      padding: 16px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);
      box-shadow: 0 16px 36px rgba(28, 38, 99, 0.08);
    }

    .toolbox h2 {
      margin: 0;
      font-size: 16px;
      line-height: 24px;
      color: var(--dark-blue);
    }

    .toolbox p {
      margin: 6px 0 14px;
      font-size: 12px;
      line-height: 18px;
      color: var(--text-gray);
    }

    .persona-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .persona-btn {
      appearance: none;
      border: 0;
      min-height: 52px;
      padding: 8px 10px;
      border-radius: 18px;
      background: rgba(28, 38, 99, 0.06);
      color: var(--text-gray);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .persona-btn.active {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      transform: translateY(-2px);
      box-shadow: 0 12px 20px rgba(64, 153, 255, 0.18);
    }

    .persona-readout {
      margin-top: 12px;
      padding: 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(28, 38, 99, 0.06);
      font-size: 13px;
      line-height: 20px;
      color: var(--dark-blue);
    }

    .persona-readout strong {
      display: block;
      margin-bottom: 6px;
      font-size: 12px;
      line-height: 18px;
      color: var(--pink);
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    @keyframes drift {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(0, 14px, 0); }
    }

    @keyframes pulse {
      0% { transform: scale(0.92); box-shadow: 0 0 0 0 rgba(248, 76, 162, 0.18); }
      70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(248, 76, 162, 0); }
      100% { transform: scale(0.92); box-shadow: 0 0 0 0 rgba(248, 76, 162, 0); }
    }

    @keyframes sweep {
      0% { transform: translateX(120%); }
      50% { transform: translateX(-10%); }
      100% { transform: translateX(-120%); }
    }

    @keyframes cueSlide {
      0% { background-position: 0% 50%; }
      100% { background-position: 200% 50%; }
    }

    @keyframes riseRing {
      from { stroke-dashoffset: 164; }
      to { stroke-dashoffset: 28; }
    }

    @media (min-width: 768px) {
      body {
        padding-top: 36px;
      }

      .page {
        max-width: 510px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="ambient-orb one"></div>
    <div class="ambient-orb two"></div>

    <section class="prototype-meta">
      <div>
        <strong>UcarPAC ストアスクショ検証</strong>
        <span>375px基準 / スワイプでA・B・Cを切り替え</span>
      </div>
      <div class="mode-pill">C案 / Interactive</div>
    </section>

    <nav class="nav-chips" aria-label="Store screenshots">
      <button class="nav-chip active" data-index="0">スクショA<br>AI査定</button>
      <button class="nav-chip" data-index="1">スクショB<br>出費管理</button>
      <button class="nav-chip" data-index="2">スクショC<br>電話0本</button>
    </nav>

    <div class="hint-row">
      <span>App Store / Google Play 用の縦長ビジュアルを1画面で確認</span>
      <span class="swipe-cue">左右スワイプ</span>
    </div>

    <section class="viewer" id="viewer">
      <div class="track" id="track">
        <div class="panel">
          <article class="screen a" id="screenA">
            <div class="screen-inner">
              <div class="status-bar">
                <span>9:41</span>
                <span class="signal" aria-hidden="true">
                  <i></i><i></i><i></i><i></i>
                </span>
              </div>

              <div class="chip-row">
                <span class="tag primary">iOS向け</span>
                <span class="tag soft">個人情報不要</span>
                <span class="tag pink">最短45秒</span>
              </div>

              <div class="hero-copy">
                <h1>AIがあなたの<br>愛車を査定</h1>
                <p>トヨタ ハリアー Z Leather Package 2021年式 / 24,800km を想定したリアルなダミーデータです。</p>
              </div>

              <div class="floating-cta">3タップで相場チェックを開始</div>

              <section class="card">
                <div class="eyebrow">
                  <strong>AI査定ライブ</strong>
                  <span>写真・装備・走行距離から判定</span>
                </div>

                <div class="estimate-wrap">
                  <div class="car-stage" id="carStage">
                    <div class="scan-line"></div>
                    <svg class="car-art" viewBox="0 0 260 130" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="ハリアーのイメージ">
                      <path d="M38 86C42 73 54 62 73 56L109 43C122 38 140 35 158 35H185C196 35 204 38 209 45L222 63C234 66 243 74 246 86L248 97C249 105 243 112 235 112H230C228 99 217 90 204 90C191 90 180 99 178 112H90C88 99 77 90 64 90C51 90 40 99 38 112H32C23 112 17 105 18 96L20 89C22 82 29 77 38 76V86Z" fill="#1C2663"/>
                      <path d="M86 57L112 47C123 43 134 41 149 41H183C189 41 193 42 196 47L205 59H86V57Z" fill="#40BFFF"/>
                      <circle cx="65" cy="111" r="18" fill="#111A4A"/>
                      <circle cx="65" cy="111" r="8" fill="#DDE7F3"/>
                      <circle cx="203" cy="111" r="18" fill="#111A4A"/>
                      <circle cx="203" cy="111" r="8" fill="#DDE7F3"/>
                      <path d="M24 82H247" stroke="rgba(255,255,255,0.18)" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                  </div>

                  <div class="metric-block">
                    <div>
                      <div class="number-kicker">AI Confidence</div>
                      <div class="number" id="confidenceValue">38<small>%</small></div>
                    </div>

                    <div class="range-box">
                      <div class="range-label">現在の想定レンジ</div>
                      <div class="range-value" id="estimateValue">¥2.98M</div>
                    </div>

                    <div class="confidence-meter">
                      <div class="meter-copy">
                        <span>査定の精度</span>
                        <span id="meterLabel">写真待ち</span>
                      </div>
                      <div class="meter-bar">
                        <div class="meter-fill"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="step-ribbon">
                  <div class="step-pill">
                    <strong>1</strong>
                    <span>車両登録</span>
                  </div>
                  <div class="step-pill">
                    <strong>2</strong>
                    <span>写真診断</span>
                  </div>
                  <div class="step-pill">
                    <strong>3</strong>
                    <span>相場表示</span>
                  </div>
                </div>
              </section>

              <div class="feature-strip">
                <div class="feature-card">
                  <strong>8,000社</strong>
                  <span>売却時に入札</span>
                </div>
                <div class="feature-card">
                  <strong>0件</strong>
                  <span>相場確認中の電話</span>
                </div>
                <div class="feature-card">
                  <strong>6ヶ月</strong>
                  <span>先まで予測</span>
                </div>
              </div>

              <button class="primary-btn" id="scanBtn">AIスキャンを再生する</button>

              <div class="footer-row">
                <div class="caption"><strong>訴求メモ:</strong> ストア1枚目は「AI査定」と「個人情報不要」を最優先で視認させる構成。</div>
                <button class="ghost-btn" data-index="1">次のスクショ</button>
              </div>
            </div>
          </article>
        </div>

        <div class="panel">
          <article class="screen b" id="screenB">
            <div class="screen-inner">
              <div class="status-bar">
                <span>10:08</span>
                <span class="signal" aria-hidden="true">
                  <i></i><i></i><i></i><i></i>
                </span>
              </div>

              <div class="chip-row">
                <span class="tag primary">Android向け</span>
                <span class="tag soft">出費管理</span>
                <span class="tag pink">将来予測</span>
              </div>

              <div class="hero-copy">
                <h1>出費も未来価格も<br>ひと目で追える</h1>
                <p>給油・保険・駐車場を記録すると、AI査定の変動と維持費のバランスが同じ画面でわかります。</p>
              </div>

              <section class="card outline">
                <div class="forecast-layout">
                  <div class="forecast-top">
                    <div>
                      <div class="number-kicker">今月の維持費</div>
                      <div class="forecast-number">¥48,700<small>3月</small></div>
                    </div>
                    <div class="pill-group" aria-label="Forecast view">
                      <button class="tiny-toggle active" data-forecast="3m">3ヶ月後</button>
                      <button class="tiny-toggle" data-forecast="6m">6ヶ月後</button>
                      <button class="tiny-toggle" data-forecast="cost">維持費込み</button>
                    </div>
                  </div>

                  <div class="graph-card">
                    <div class="graph-head">
                      <strong id="forecastTitle">AI予測価値 ¥2,930,000</strong>
                      <span id="forecastDelta">現在比 -¥90,000</span>
                    </div>

                    <div class="graph-shell">
                      <div class="graph-grid"></div>
                      <svg class="graph-line" viewBox="0 0 320 154" xmlns="http://www.w3.org/2000/svg" aria-label="将来予測グラフ">
                        <defs>
                          <linearGradient id="forecastFill" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#1ddcff" stop-opacity="0.34"></stop>
                            <stop offset="100%" stop-color="#1ddcff" stop-opacity="0"></stop>
                          </linearGradient>
                        </defs>
                        <path id="forecastArea" class="main" d="M0 112 C40 98 74 90 112 88 C146 87 184 96 208 102 C235 109 268 116 320 90 L320 154 L0 154 Z"></path>
                        <circle id="point1" cx="112" cy="88" r="7"></circle>
                        <circle id="point2" cx="208" cy="102" r="7"></circle>
                        <circle id="point3" cx="320" cy="90" r="7"></circle>
                      </svg>
                    </div>

                    <div class="graph-axis">
                      <span>現在</span>
                      <span>3ヶ月</span>
                      <span>6ヶ月</span>
                    </div>
                  </div>
                </div>
              </section>

              <div class="expense-grid">
                <div class="expense-card">
                  <strong>¥12,400</strong>
                  <span>給油 4回</span>
                </div>
                <div class="expense-card">
                  <strong>¥18,300</strong>
                  <span>保険 月割</span>
                </div>
                <div class="expense-card">
                  <strong>¥18,000</strong>
                  <span>駐車場</span>
                </div>
              </div>

              <div class="mission-strip">
                <div>
                  <strong>記録ミッション達成まであと1日</strong>
                  <span>7日連続で入力すると予測精度がさらに安定</span>
                </div>
                <div class="ring">
                  <svg viewBox="0 0 68 68" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <defs>
                      <linearGradient id="ringGradient" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#1ddcff"></stop>
                        <stop offset="100%" stop-color="#f84ca2"></stop>
                      </linearGradient>
                    </defs>
                    <circle class="track-ring" cx="34" cy="34" r="26"></circle>
                    <circle class="value-ring" cx="34" cy="34" r="26"></circle>
                  </svg>
                  <div class="ring-value">6/7</div>
                </div>
              </div>

              <div class="bullet-badges">
                <div class="bullet-badge">
                  <strong>相場推移</strong>
                  <span>毎週アップデート</span>
                </div>
                <div class="bullet-badge">
                  <strong>年額試算</strong>
                  <span>¥584,400</span>
                </div>
                <div class="bullet-badge">
                  <strong>売り時提案</strong>
                  <span>6月上旬が有利</span>
                </div>
              </div>

              <button class="primary-btn alt" id="forecastBtn">予測パターンを切り替える</button>

              <div class="footer-row">
                <div class="caption"><strong>訴求メモ:</strong> Android向けはダッシュボード感を強め、資産管理アプリに近い「日々見る理由」を強化。</div>
                <button class="ghost-btn" data-index="2">次のスクショ</button>
              </div>
            </div>
          </article>
        </div>

        <div class="panel">
          <article class="screen c" id="screenC">
            <div class="screen-inner">
              <div class="status-bar">
                <span>8:32</span>
                <span class="signal" aria-hidden="true">
                  <i></i><i></i><i></i><i></i>
                </span>
              </div>

              <div class="chip-row">
                <span class="tag primary">競合比較</span>
                <span class="tag soft">電話0本で相場チェック</span>
                <span class="tag pink">売却相談時のみ1社対応</span>
              </div>

              <div class="hero-copy">
                <h1>まずは0本。<br>売る時だけ次へ</h1>
                <p>「いま相場だけ見たい」段階では営業電話なし。比較画面で違いをそのまま伝えるストア3枚目です。</p>
              </div>

              <section class="compare-hero">
                <div class="compare-top">
                  <strong id="compareHeadline">UcarPACは相場チェック中の営業電話 0本</strong>
                  <span class="tag soft">比較スライド</span>
                </div>

                <div class="call-bubble">
                  <div>
                    <strong id="callCount">0</strong>
                    <span id="callLabel">相場チェック中の電話</span>
                  </div>
                </div>

                <div class="compare-tabs">
                  <button class="compare-tab active" data-compare="ucarpac">UcarPAC</button>
                  <button class="compare-tab" data-compare="mota">MOTA型</button>
                  <button class="compare-tab" data-compare="ikkatsu">一括査定型</button>
                </div>

                <div class="compare-table">
                  <div class="compare-row">
                    <strong>電話本数</strong>
                    <div class="bar-track"><div class="bar-fill" id="barCalls" style="--w: 6%;"></div></div>
                    <span id="barCallsLabel">0本</span>
                  </div>
                  <div class="compare-row">
                    <strong>手間</strong>
                    <div class="bar-track"><div class="bar-fill" id="barStress" style="--w: 12%;"></div></div>
                    <span id="barStressLabel">かなり低い</span>
                  </div>
                  <div class="compare-row">
                    <strong>相場把握</strong>
                    <div class="bar-track"><div class="bar-fill" id="barSpeed" style="--w: 92%;"></div></div>
                    <span id="barSpeedLabel">すぐ見られる</span>
                  </div>
                </div>

                <div class="compare-note" id="compareNote">個人情報なしでAI査定開始。売却相談に進んだあとだけ、必要なやり取りへ進みます。</div>
              </section>

              <div class="bullet-badges">
                <div class="bullet-badge">
                  <strong>0本</strong>
                  <span>相場チェック中</span>
                </div>
                <div class="bullet-badge">
                  <strong>1社</strong>
                  <span>売却相談時のみ</span>
                </div>
                <div class="bullet-badge">
                  <strong>8,000社</strong>
                  <span>入札ネットワーク</span>
                </div>
              </div>

              <section class="card outline">
                <div class="eyebrow">
                  <strong>競合との違い</strong>
                  <span>訴求コピーをタップで切替</span>
                </div>
                <div class="step-ribbon">
                  <div class="step-pill">
                    <strong>0</strong>
                    <span>まずは相場だけ</span>
                  </div>
                  <div class="step-pill">
                    <strong>1</strong>
                    <span>売る時だけ相談</span>
                  </div>
                  <div class="step-pill">
                    <strong>高</strong>
                    <span>8,000社が入札</span>
                  </div>
                </div>
              </section>

              <button class="primary-btn" id="compareBtn">比較パターンを切り替える</button>

              <div class="footer-row">
                <div class="caption"><strong>訴求メモ:</strong> 「電話1社」の強みを保ちつつ、ストアでは初期体験の安心感として「電話0本」を前面化。</div>
                <button class="ghost-btn" data-index="0">Aへ戻る</button>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <div class="controls">
      <button class="control-btn" id="prevBtn">前へ</button>
      <div class="pager" aria-label="Page indicators">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
      <button class="control-btn" id="nextBtn">次へ</button>
    </div>

    <section class="toolbox">
      <h2>想定ペルソナ切替</h2>
      <p>訴求の軸を確認するため、下のボタンで「どの悩みからDLされるか」を切り替えられます。</p>
      <div class="persona-grid">
        <button class="persona-btn active" data-persona="price">相場を知りたい</button>
        <button class="persona-btn" data-persona="timing">売り時を逃したくない</button>
        <button class="persona-btn" data-persona="stress">電話が嫌だ</button>
      </div>
      <div class="persona-readout" id="personaReadout">
        <strong>Current Persona</strong>
        価格だけ先に知りたい層には、スクショAの「AI査定」とスクショCの「電話0本」を連続で見せる設計が効きます。
      </div>
    </section>
  </div>

  <script>
    (function () {
      const viewer = document.getElementById("viewer");
      const chips = Array.from(document.querySelectorAll(".nav-chip"));
      const dots = Array.from(document.querySelectorAll(".dot"));
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const jumpButtons = Array.from(document.querySelectorAll("[data-index]"));
      let current = 0;
      let startX = 0;
      let deltaX = 0;

      function updateStage(index) {
        current = Math.max(0, Math.min(2, index));
        document.documentElement.style.setProperty("--stage-index", String(current));
        chips.forEach((chip, idx) => chip.classList.toggle("active", idx === current));
        dots.forEach((dot, idx) => dot.classList.toggle("active", idx === current));
      }

      jumpButtons.forEach((button) => {
        button.addEventListener("click", () => {
          updateStage(Number(button.dataset.index));
        });
      });

      prevBtn.addEventListener("click", () => updateStage(current - 1));
      nextBtn.addEventListener("click", () => updateStage(current + 1));

      viewer.addEventListener("pointerdown", (event) => {
        startX = event.clientX;
        deltaX = 0;
      });

      viewer.addEventListener("pointermove", (event) => {
        if (!startX) return;
        deltaX = event.clientX - startX;
      });

      function endSwipe() {
        if (Math.abs(deltaX) > 48) {
          if (deltaX < 0) updateStage(current + 1);
          if (deltaX > 0) updateStage(current - 1);
        }
        startX = 0;
        deltaX = 0;
      }

      viewer.addEventListener("pointerup", endSwipe);
      viewer.addEventListener("pointercancel", endSwipe);
      viewer.addEventListener("pointerleave", () => {
        if (startX) endSwipe();
      });

      const screenA = document.getElementById("screenA");
      const carStage = document.getElementById("carStage");
      const confidenceValue = document.getElementById("confidenceValue");
      const estimateValue = document.getElementById("estimateValue");
      const meterLabel = document.getElementById("meterLabel");
      const scanBtn = document.getElementById("scanBtn");

      function runScan() {
        screenA.classList.remove("revealed");
        carStage.classList.remove("scanning");
        confidenceValue.innerHTML = '38<small>%</small>';
        estimateValue.textContent = "¥2.98M";
        meterLabel.textContent = "写真待ち";

        window.setTimeout(() => {
          carStage.classList.add("scanning");
        }, 20);

        window.setTimeout(() => {
          screenA.classList.add("revealed");
          confidenceValue.innerHTML = '92<small>%</small>';
          estimateValue.textContent = "¥3.18M";
          meterLabel.textContent = "高精度";
        }, 980);

        window.setTimeout(() => {
          carStage.classList.remove("scanning");
        }, 2600);
      }

      scanBtn.addEventListener("click", runScan);

      const forecastSets = {
        "3m": {
          title: "AI予測価値 ¥2,930,000",
          delta: "現在比 -¥90,000",
          area: "M0 112 C40 98 74 90 112 88 C146 87 184 96 208 102 C235 109 268 116 320 90 L320 154 L0 154 Z",
          points: [
            [112, 88],
            [208, 102],
            [320, 90]
          ]
        },
        "6m": {
          title: "AI予測価値 ¥2,860,000",
          delta: "現在比 -¥160,000",
          area: "M0 112 C42 102 74 97 112 98 C145 99 180 110 208 117 C236 124 272 127 320 112 L320 154 L0 154 Z",
          points: [
            [112, 98],
            [208, 117],
            [320, 112]
          ]
        },
        "cost": {
          title: "維持費込み実質価値 ¥2,780,000",
          delta: "6ヶ月維持費反映 -¥240,000",
          area: "M0 112 C38 104 72 103 112 108 C148 113 180 122 208 128 C236 133 270 136 320 124 L320 154 L0 154 Z",
          points: [
            [112, 108],
            [208, 128],
            [320, 124]
          ]
        }
      };

      const forecastButtons = Array.from(document.querySelectorAll("[data-forecast]"));
      const forecastBtn = document.getElementById("forecastBtn");
      const forecastTitle = document.getElementById("forecastTitle");
      const forecastDelta = document.getElementById("forecastDelta");
      const forecastArea = document.getElementById("forecastArea");
      const point1 = document.getElementById("point1");
      const point2 = document.getElementById("point2");
      const point3 = document.getElementById("point3");
      let forecastIndex = 0;
      const forecastOrder = ["3m", "6m", "cost"];

      function applyForecast(key) {
        const data = forecastSets[key];
        forecastButtons.forEach((button) => button.classList.toggle("active", button.dataset.forecast === key));
        forecastTitle.textContent = data.title;
        forecastDelta.textContent = data.delta;
        forecastArea.setAttribute("d", data.area);
        [point1, point2, point3].forEach((point, idx) => {
          point.setAttribute("cx", data.points[idx][0]);
          point.setAttribute("cy", data.points[idx][1]);
        });
        forecastIndex = forecastOrder.indexOf(key);
      }

      forecastButtons.forEach((button) => {
        button.addEventListener("click", () => applyForecast(button.dataset.forecast));
      });

      forecastBtn.addEventListener("click", () => {
        const next = (forecastIndex + 1) % forecastOrder.length;
        applyForecast(forecastOrder[next]);
      });

      const compareTabs = Array.from(document.querySelectorAll("[data-compare]"));
      const compareBtn = document.getElementById("compareBtn");
      const compareHeadline = document.getElementById("compareHeadline");
      const callCount = document.getElementById("callCount");
      const callLabel = document.getElementById("callLabel");
      const barCalls = document.getElementById("barCalls");
      const barStress = document.getElementById("barStress");
      const barSpeed = document.getElementById("barSpeed");
      const barCallsLabel = document.getElementById("barCallsLabel");
      const barStressLabel = document.getElementById("barStressLabel");
      const barSpeedLabel = document.getElementById("barSpeedLabel");
      const compareNote = document.getElementById("compareNote");
      const compareStates = {
        ucarpac: {
          headline: "UcarPACは相場チェック中の営業電話 0本",
          count: "0",
          label: "相場チェック中の電話",
          calls: "6%",
          stress: "12%",
          speed: "92%",
          callsLabel: "0本",
          stressLabel: "かなり低い",
          speedLabel: "すぐ見られる",
          note: "個人情報なしでAI査定開始。売却相談に進んだあとだけ、必要なやり取りへ進みます。"
        },
        mota: {
          headline: "MOTA型は上位3社からの連絡が前提",
          count: "3",
          label: "結果後に連絡の可能性",
          calls: "54%",
          stress: "48%",
          speed: "68%",
          callsLabel: "最大3社",
          stressLabel: "比較的ある",
          speedLabel: "翌日待ち",
          note: "入札結果の明確さはある一方、結果確認まで待機が必要で、連絡も複数発生しやすい想定です。"
        },
        ikkatsu: {
          headline: "一括査定型は複数社とのやり取りが発生",
          count: "10",
          label: "連絡が集中しやすい",
          calls: "94%",
          stress: "92%",
          speed: "58%",
          callsLabel: "最大10社",
          stressLabel: "高い",
          speedLabel: "入力後対応多め",
          note: "比較対象が多いぶん、電話や日程調整の負担が重くなりやすい構図を視覚化しています。"
        }
      };
      const compareOrder = ["ucarpac", "mota", "ikkatsu"];
      let compareIndex = 0;

      function applyCompare(key) {
        const data = compareStates[key];
        compareTabs.forEach((tab) => tab.classList.toggle("active", tab.dataset.compare === key));
        compareHeadline.textContent = data.headline;
        callCount.textContent = data.count;
        callLabel.textContent = data.label;
        barCalls.style.setProperty("--w", data.calls);
        barStress.style.setProperty("--w", data.stress);
        barSpeed.style.setProperty("--w", data.speed);
        barCallsLabel.textContent = data.callsLabel;
        barStressLabel.textContent = data.stressLabel;
        barSpeedLabel.textContent = data.speedLabel;
        compareNote.textContent = data.note;
        compareIndex = compareOrder.indexOf(key);
      }

      compareTabs.forEach((tab) => {
        tab.addEventListener("click", () => applyCompare(tab.dataset.compare));
      });

      compareBtn.addEventListener("click", () => {
        const next = (compareIndex + 1) % compareOrder.length;
        applyCompare(compareOrder[next]);
      });

      const personaButtons = Array.from(document.querySelectorAll("[data-persona]"));
      const personaReadout = document.getElementById("personaReadout");
      const personaTexts = {
        price: "価格だけ先に知りたい層には、スクショAの「AI査定」とスクショCの「電話0本」を連続で見せる設計が効きます。",
        timing: "売り時を迷う層には、スクショBの将来予測グラフが刺さります。出費管理と未来価格を一緒に見せると滞在理由が増えます。",
        stress: "営業電話への不安が強い層には、スクショCを先に見せる構成が有効です。初回接触の心理ハードルを明確に下げられます。"
      };

      personaButtons.forEach((button) => {
        button.addEventListener("click", () => {
          personaButtons.forEach((item) => item.classList.toggle("active", item === button));
          personaReadout.innerHTML = "<strong>Current Persona</strong>" + personaTexts[button.dataset.persona];
        });
      });

      updateStage(0);
      applyForecast("3m");
      applyCompare("ucarpac");
      runScan();
    })();
  </script>
</body>
</html>
