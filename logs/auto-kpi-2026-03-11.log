        body: "売却検討が先のユーザーにも残る理由をつくる構成。出費管理と将来予測を並べて、日常利用と将来売却をつなぎます。",
        hook: "「売らない期間も使う価値」を見せて継続利用を促す",
        hint: "将来売却層や保有コスト意識が高いユーザーに向いており、アンインストール抑制まで含めた訴求に相性が良いです。"
      },
      {
        title: "C / 競合比較: 相場チェックまでは電話0本",
        body: "競合との差を一瞬で読ませる構成。『複数社から電話が来そう』という先入観を打ち消し、検討開始の心理負荷を下げます。",
        hook: "「まず0本、売却時も1社だけ」でストレスを見える化",
        hint: "電話負荷の懸念が強い市場では強力ですが、単独先頭よりAかBの2枚目以降に置く運用も検討価値があります。"
      }
    ];

    const track = document.getElementById("track");
    const dotNav = Array.from(document.querySelectorAll("#dotNav button"));
    const metaTitle = document.getElementById("metaTitle");
    const metaBody = document.getElementById("metaBody");
    const metaHook = document.getElementById("metaHook");
    const metaHint = document.getElementById("metaHint");
    const slideCount = document.getElementById("slideCount");
    const railFill = document.getElementById("railFill");
    const swipeSurface = document.getElementById("swipeSurface");

    let current = 0;
    let startX = 0;
    let diffX = 0;

    function setSlide(index) {
      current = (index + slides.length) % slides.length;
      track.style.transform = "translateX(" + (current * -100) + "%)";
      dotNav.forEach((button, i) => {
        button.classList.toggle("active", i === current);
      });
      metaTitle.textContent = slides[current].title;
      metaBody.textContent = slides[current].body;
      metaHook.textContent = slides[current].hook;
      metaHint.textContent = slides[current].hint;
      slideCount.textContent = String(current + 1);
      railFill.style.width = ((current + 1) / slides.length) * 100 + "%";
    }

    dotNav.forEach((button) => {
      button.addEventListener("click", () => setSlide(Number(button.dataset.index)));
    });

    document.getElementById("prevBtn").addEventListener("click", () => setSlide(current - 1));
    document.getElementById("nextBtn").addEventListener("click", () => setSlide(current + 1));

    swipeSurface.addEventListener("touchstart", (event) => {
      startX = event.touches[0].clientX;
    }, { passive: true });

    swipeSurface.addEventListener("touchmove", (event) => {
      diffX = event.touches[0].clientX - startX;
    }, { passive: true });

    swipeSurface.addEventListener("touchend", () => {
      if (Math.abs(diffX) > 45) {
        setSlide(current + (diffX < 0 ? 1 : -1));
      }
      startX = 0;
      diffX = 0;
    });

    let mouseDown = false;
    swipeSurface.addEventListener("mousedown", (event) => {
      mouseDown = true;
      startX = event.clientX;
    });
    window.addEventListener("mousemove", (event) => {
      if (!mouseDown) return;
      diffX = event.clientX - startX;
    });
    window.addEventListener("mouseup", () => {
      if (!mouseDown) return;
      if (Math.abs(diffX) > 45) {
        setSlide(current + (diffX < 0 ? 1 : -1));
      }
      mouseDown = false;
      startX = 0;
      diffX = 0;
    });

    const estimateValue = document.getElementById("estimateValue");
    const estimateDelta = document.getElementById("estimateDelta");
    const estimateCard = document.getElementById("estimateCard");
    const bars = [
      document.getElementById("bar1"),
      document.getElementById("bar2"),
      document.getElementById("bar3"),
      document.getElementById("bar4")
    ];

    document.getElementById("refreshEstimate").addEventListener("click", () => {
      const base = 2184000 + Math.floor((Math.random() - 0.3) * 160000);
      const delta = 28000 + Math.floor(Math.random() * 54000);
      estimateValue.textContent = base.toLocaleString("ja-JP") + "円";
      estimateDelta.textContent = "3か月後 +" + delta.toLocaleString("ja-JP") + "円 予測";
      const heights = [
        36 + Math.floor(Math.random() * 16),
        44 + Math.floor(Math.random() * 20),
        62 + Math.floor(Math.random() * 18),
        52 + Math.floor(Math.random() * 18)
      ];
      bars.forEach((bar, index) => {
        bar.style.setProperty("--height", heights[index] + "px");
        bar.classList.remove("flash");
        void bar.offsetWidth;
        bar.classList.add("flash");
      });
      estimateCard.classList.remove("flash");
      void estimateCard.offsetWidth;
      estimateCard.classList.add("flash");
    });

    const costValue = document.getElementById("costValue");
    const futureValue = document.getElementById("futureValue");
    const futureChip = document.getElementById("futureChip");
    const fuelBar = document.getElementById("fuelBar");
    const insuranceBar = document.getElementById("insuranceBar");
    const parkingBar = document.getElementById("parkingBar");
    const sparkBars = document.getElementById("sparkBars");
    let addCount = 0;

    document.getElementById("addExpense").addEventListener("click", () => {
      addCount += 1;
      const total = 27600 + addCount * 1800;
      const future = 2256000 + addCount * 12000;
      costValue.textContent = total.toLocaleString("ja-JP") + "円";
      futureValue.textContent = future.toLocaleString("ja-JP") + "円";
      futureChip.textContent = addCount % 2 === 0 ? "売却判断の材料が増加" : "6か月後が狙い目";
      fuelBar.style.width = Math.min(88, 64 + addCount * 4) + "%";
      insuranceBar.style.width = Math.min(72, 46 + addCount * 3) + "%";
      parkingBar.style.width = Math.min(74, 52 + addCount * 2) + "%";
      Array.from(sparkBars.children).forEach((bar, index) => {
        const next = 38 + index * 10 + Math.min(10, addCount * 2);
        bar.style.setProperty("--h", next + "%");
        bar.classList.remove("flash");
        void bar.offsetWidth;
        bar.classList.add("flash");
      });
      sparkBars.parentElement.classList.remove("flash");
      void sparkBars.parentElement.offsetWidth;
      sparkBars.parentElement.classList.add("flash");
    });

    const zeroValue = document.getElementById("zeroValue");
    const ucarpacRisk = document.getElementById("ucarpacRisk");
    const topRisk = document.getElementById("topRisk");
    const bulkRisk = document.getElementById("bulkRisk");
    const compareNote = document.getElementById("compareNote");
    let compareToggle = false;

    document.getElementById("replayCompare").addEventListener("click", () => {
      compareToggle = !compareToggle;
      zeroValue.textContent = compareToggle ? "0" : "0";
      ucarpacRisk.style.width = compareToggle ? "8%" : "10%";
      topRisk.style.width = compareToggle ? "52%" : "46%";
      bulkRisk.style.width = compareToggle ? "94%" : "88%";
      compareNote.textContent = compareToggle
        ? "比較テキストは『電話0本』だけで終わらせず、次の流れも補足すると誤認を避けられます。『相場チェックでは0本、売却相談後は1社のみ。』"
        : "差別化メッセージは「0本」で止めず、次の一文で信頼化するのが有効です。 「AI査定で相場を見る段階では電話0本。売ると決めた後も1社だけ。」";
      compareNote.classList.remove("flash");
      void compareNote.offsetWidth;
      compareNote.classList.add("flash");
    });

    const state = { timing: null, priority: null };
    const stepMark1 = document.getElementById("stepMark1");
    const stepMark2 = document.getElementById("stepMark2");
    const stepMark3 = document.getElementById("stepMark3");
    const stepLine = document.getElementById("stepLine");
    const resultTitle = document.getElementById("resultTitle");
    const resultBody = document.getElementById("resultBody");
    const resultCard = document.getElementById("resultCard");

    function updateDiagnostic() {
      stepMark1.classList.toggle("active", true);
      stepMark2.classList.toggle("active", Boolean(state.timing));
      stepMark3.classList.toggle("active", Boolean(state.timing && state.priority));
      stepLine.style.setProperty("--step-fill", state.timing ? "100%" : "0%");

      if (!state.timing || !state.priority) {
        resultTitle.textContent = state.timing ? "次は訴求価値を選択" : "まだ選択中です";
        resultBody.textContent = state.timing
          ? "もう1つ選ぶと、先頭に置くべきスクショ候補を自動で提案します。"
          : "2つの質問に答えると、先頭に置くべきスクショ候補とその理由を自動で切り替えます。";
        return;
      }

      let recommendation = 0;
      let title = "";
      let body = "";

      if (state.priority === "cost") {
        recommendation = 1;
        title = "先頭候補は B / 出費管理 + 将来予測";
        body = "売却時期が先でも使い続ける理由を前面化できます。継続利用の価値を見せたいときに最も強い並びです。";
      } else if (state.priority === "easy") {
        recommendation = 2;
        title = "先頭候補は C / 電話0本比較";
        body = "電話ストレスの不安を最初に除去する構成です。検討ハードルが高い流入に向いています。";
      } else if (state.timing === "now") {
        recommendation = 2;
        title = "先頭候補は C → A の順";
        body = "高く早く売りたい層には、連絡負荷の少なさで不安を解消してからAI査定の具体価値へつなぐ流れが効きます。";
      } else {
        recommendation = 0;
        title = "先頭候補は A / AI査定";
        body = "まず価格を知りたいユーザーには、最短で相場が見える価値を先頭に出す構成が最も自然です。";
      }

      resultTitle.textContent = title;
      resultBody.textContent = body;
      resultCard.classList.remove("flash");
      void resultCard.offsetWidth;
      resultCard.classList.add("flash");
      setSlide(recommendation);
    }

    document.querySelectorAll(".option").forEach((button) => {
      button.addEventListener("click", () => {
        const group = button.dataset.group;
        const value = button.dataset.value;
        state[group] = value;
        document.querySelectorAll('.option[data-group="' + group + '"]').forEach((target) => {
          target.classList.toggle("active", target === button);
        });
        updateDiagnostic();
      });
    });

    setSlide(0);
    updateDiagnostic();
  </script>
</body>
</html>
