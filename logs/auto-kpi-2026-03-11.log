  <script>
    const screenButtons = document.querySelectorAll(".screen-switch button");
    const phones = document.querySelectorAll(".phone");

    function activateScreen(id) {
      screenButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.screen === id);
      });

      phones.forEach((phone) => {
        const isActive = phone.dataset.id === id;
        phone.classList.toggle("active", isActive);
        phone.classList.toggle("focus-outline", isActive);
      });
    }

    screenButtons.forEach((button) => {
      button.addEventListener("click", () => activateScreen(button.dataset.screen));
    });

    const forecastMap = {
      "1m": {
        value: "131.7",
        note: "1か月後の予想。まだ高値圏で、動きやすいタイミングです。",
        tag: "1か月後 -1.1万円",
        left: "42%",
        top: "33%"
      },
      "3m": {
        value: "129.4",
        note: "3か月後の予想。値下がり前に動く目安として使えます。",
        tag: "3か月後 -3.4万円",
        left: "58%",
        top: "42%"
      },
      "6m": {
        value: "124.7",
        note: "6か月後の予想。走行距離増加で価格が下がりやすい想定です。",
        tag: "6か月後 -8.1万円",
        left: "84%",
        top: "71%"
      }
    };

    const periodButtons = document.querySelectorAll("[data-period]");
    const forecastValue = document.getElementById("forecast-value");
    const forecastNote = document.getElementById("forecast-note");
    const chartTag = document.getElementById("chart-tag");
    const pointMarker = document.getElementById("point-marker");

    function setPeriod(period) {
      const data = forecastMap[period];
      forecastValue.innerHTML = data.value + "<small>万円</small>";
      forecastNote.textContent = data.note;
      chartTag.textContent = data.tag;
      pointMarker.style.left = data.left;
      pointMarker.style.top = data.top;

      periodButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.period === period);
      });
    }

    periodButtons.forEach((button) => {
      button.addEventListener("click", () => setPeriod(button.dataset.period));
    });

    const metricButtons = document.querySelectorAll("[data-metric]");
    const expensePanel = document.getElementById("expense-panel");
    const forecastPanel = document.getElementById("forecast-panel");

    function setMetric(metric) {
      metricButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.metric === metric);
      });

      const showingExpense = metric === "expense";
      expensePanel.classList.toggle("is-hidden", !showingExpense);
      forecastPanel.classList.toggle("is-hidden", showingExpense);
    }

    metricButtons.forEach((button) => {
      button.addEventListener("click", () => setMetric(button.dataset.metric));
    });

    const compareButtons = document.querySelectorAll("[data-mode]");
    const ucarCount = document.getElementById("ucar-count");
    const bulkCount = document.getElementById("bulk-count");
    const otherCount = document.getElementById("other-count");
    const ucarLabel = document.getElementById("ucar-label");
    const bulkLabel = document.getElementById("bulk-label");
    const otherLabel = document.getElementById("other-label");
    const compareStory = document.getElementById("compare-story");
    const compareSubcopy = document.getElementById("compare-subcopy");

    const compareModes = {
      browse: {
        ucarCount: "0本",
        bulkCount: "5〜10本",
        otherCount: "申込後",
        ucarLabel: "相場チェック時の電話",
        bulkLabel: "相場確認後に想定される連絡",
        otherLabel: "価格把握のタイミング",
        subcopy: "「とりあえず知りたい」段階での心理負担を比較",
        story: "訴求の芯: まずは相場だけ知りたい人にとって、UcarPACは「電話が鳴る前に安心できる」入口をつくれます。"
      },
      sell: {
        ucarCount: "1社",
        bulkCount: "5〜10社",
        otherCount: "1社",
        ucarLabel: "売却申込後のやりとり",
        bulkLabel: "売却申込後のやりとり",
        otherLabel: "売却申込後のやりとり",
        subcopy: "売却フェーズでも、やりとり負荷の少なさを比較",
        story: "訴求の芯: 売ると決めた後も、UcarPACは1社対応で進めやすい。相場確認から売却まで負荷の低さが一貫します。"
      }
    };

    function bump(node) {
      node.classList.remove("bump");
      void node.offsetWidth;
      node.classList.add("bump");
    }

    function setCompareMode(mode) {
      const data = compareModes[mode];
      compareButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.mode === mode);
      });

      ucarCount.textContent = data.ucarCount;
      bulkCount.textContent = data.bulkCount;
      otherCount.textContent = data.otherCount;
      ucarLabel.textContent = data.ucarLabel;
      bulkLabel.textContent = data.bulkLabel;
      otherLabel.textContent = data.otherLabel;
      compareSubcopy.textContent = data.subcopy;
      compareStory.innerHTML = "<strong>" + data.story.split(":")[0] + ":</strong>" + data.story.split(":").slice(1).join(":");

      [ucarCount, bulkCount, otherCount].forEach(bump);
    }

    compareButtons.forEach((button) => {
      button.addEventListener("click", () => setCompareMode(button.dataset.mode));
    });

    setPeriod("3m");
    setMetric("expense");
    setCompareMode("browse");
    activateScreen("a");
  </script>
</body>
