      --radius-button: 30px;
      --panel: rgba(255, 255, 255, 0.78);
      --panel-strong: rgba(255, 255, 255, 0.92);
      --surface-shadow: 0 20px 60px rgba(14, 27, 91, 0.16);
      --phone-shadow: 0 40px 100px rgba(7, 14, 50, 0.35);
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: var(--font-sans);
      background:
        radial-gradient(circle at 15% 15%, rgba(248, 76, 162, 0.18), transparent 26%),
        radial-gradient(circle at 85% 10%, rgba(29, 220, 255, 0.22), transparent 24%),
        linear-gradient(180deg, #f7fbff 0%, #eef3ff 45%, #fdf6fb 100%);
      color: var(--text-black);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(28, 38, 99, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(28, 38, 99, 0.03) 1px, transparent 1px);
      background-size: 24px 24px;
      mask-image: radial-gradient(circle at center, black 40%, transparent 78%);
    }

    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 16px 48px;
      position: relative;
      z-index: 1;
    }

    .hero {
      display: grid;
      gap: 14px;
      margin-bottom: 24px;
    }

    .eyebrow {
      width: fit-content;
      padding: 10px 16px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(255, 255, 255, 0.74);
      box-shadow: 0 10px 30px rgba(17, 34, 110, 0.08);
      backdrop-filter: blur(14px);
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(28px, 5vw, 50px);
      line-height: 1.15;
      letter-spacing: -0.04em;
      color: var(--dark-blue);
      max-width: 760px;
    }

    .hero p {
      margin: 0;
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-gray);
      max-width: 760px;
    }

    .layout {
      display: grid;
      gap: 24px;
      align-items: start;
      grid-template-columns: minmax(0, 390px) minmax(0, 1fr);
    }

    .phone-stage {
      position: sticky;
      top: 24px;
      display: grid;
      gap: 16px;
      justify-items: center;
    }

    .phone-frame {
      width: min(100%, 375px);
      aspect-ratio: 375 / 812;
      padding: 12px;
      border-radius: 40px;
      background:
        linear-gradient(180deg, #1d255f 0%, #090f31 45%, #10183f 100%);
      box-shadow: var(--phone-shadow);
      position: relative;
      overflow: hidden;
    }

    .phone-frame::before {
      content: "";
      position: absolute;
      top: 10px;
      left: 50%;
      width: 132px;
      height: 26px;
      transform: translateX(-50%);
      border-radius: 0 0 18px 18px;
      background: #070d27;
      z-index: 3;
    }

    .screen {
      height: 100%;
      border-radius: 30px;
      overflow: hidden;
      position: relative;
      background: #fff;
    }

    .track {
      display: flex;
      height: 100%;
      transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
    }

    .slide {
      min-width: 100%;
      height: 100%;
      position: relative;
      padding: 18px 18px 22px;
      overflow: hidden;
    }

    .slide::before,
    .slide::after {
      content: "";
      position: absolute;
      border-radius: 999px;
      opacity: 0.8;
      filter: blur(8px);
      pointer-events: none;
    }

    .slide-a {
      background:
        radial-gradient(circle at 78% 12%, rgba(29, 220, 255, 0.35), transparent 24%),
        radial-gradient(circle at 14% 84%, rgba(248, 76, 162, 0.32), transparent 24%),
        linear-gradient(180deg, #071145 0%, #10206f 52%, #08143e 100%);
      color: var(--white);
    }

    .slide-a::before {
      width: 180px;
      height: 180px;
      top: -56px;
      right: -40px;
      background: rgba(29, 220, 255, 0.18);
      animation: float 7s ease-in-out infinite;
    }

    .slide-a::after {
      width: 140px;
      height: 140px;
      left: -40px;
      bottom: 140px;
      background: rgba(248, 76, 162, 0.16);
      animation: float 8s ease-in-out infinite reverse;
    }

    .slide-b {
      background:
        radial-gradient(circle at 14% 12%, rgba(248, 76, 162, 0.18), transparent 24%),
        radial-gradient(circle at 84% 18%, rgba(29, 220, 255, 0.22), transparent 24%),
        linear-gradient(180deg, #fffdfd 0%, #eff7ff 55%, #f8fbff 100%);
      color: var(--dark-blue);
    }

    .slide-b::before {
      width: 160px;
      height: 160px;
      right: -34px;
      top: 96px;
      background: rgba(29, 220, 255, 0.14);
      animation: float 9s ease-in-out infinite;
    }

    .slide-b::after {
      width: 120px;
      height: 120px;
      left: -24px;
      bottom: 100px;
      background: rgba(248, 76, 162, 0.12);
      animation: float 6s ease-in-out infinite reverse;
    }

    .slide-c {
      background:
        radial-gradient(circle at 80% 15%, rgba(248, 76, 162, 0.25), transparent 22%),
        radial-gradient(circle at 18% 80%, rgba(29, 220, 255, 0.2), transparent 20%),
        linear-gradient(180deg, #0b154a 0%, #18235f 48%, #0c1232 100%);
      color: var(--white);
    }

    .slide-c::before {
      width: 200px;
      height: 200px;
      top: -80px;
      left: -50px;
      background: rgba(29, 220, 255, 0.12);
      animation: float 10s ease-in-out infinite;
    }

    .slide-c::after {
      width: 160px;
      height: 160px;
      bottom: -40px;
      right: -24px;
      background: rgba(248, 76, 162, 0.14);
      animation: float 7s ease-in-out infinite reverse;
    }

    .statusbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      margin-bottom: 18px;
      position: relative;
      z-index: 2;
    }

    .status-icons {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: currentColor;
      opacity: 0.8;
    }

    .platform {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      width: fit-content;
      margin-bottom: 14px;
      backdrop-filter: blur(14px);
      border: 1px solid rgba(255, 255, 255, 0.16);
    }

    .slide-a .platform,
    .slide-c .platform {
      background: rgba(255, 255, 255, 0.12);
      color: #dff5ff;
    }

    .slide-b .platform {
      background: rgba(255, 255, 255, 0.84);
      color: var(--dark-blue);
      box-shadow: 0 10px 22px rgba(28, 38, 99, 0.08);
      border-color: rgba(64, 153, 255, 0.12);
    }

    .screenshot-label {
      font-size: 10px;
      font-weight: 700;
      opacity: 0.82;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .slide-title {
      margin: 0;
      font-size: 32px;
      line-height: 1.12;
      letter-spacing: -0.05em;
      position: relative;
      z-index: 2;
    }

    .slide-copy {
      margin: 10px 0 0;
      font-size: 14px;
      line-height: 1.6;
      max-width: 290px;
      position: relative;
      z-index: 2;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
      position: relative;
      z-index: 2;
    }

    .badge {
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      backdrop-filter: blur(10px);
    }

    .slide-a .badge,
    .slide-c .badge {
      background: rgba(255, 255, 255, 0.12);
      color: #f4fbff;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .slide-b .badge {
      background: rgba(255, 255, 255, 0.9);
      color: var(--dark-blue);
      box-shadow: 0 8px 24px rgba(17, 36, 110, 0.08);
    }

    .price-card,
    .glass-card,
    .compare-card,
    .soft-card {
      position: relative;
      z-index: 2;
      border-radius: 24px;
      padding: 16px;
      overflow: hidden;
    }

    .price-card {
      margin-top: 18px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.08));
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.14);
      backdrop-filter: blur(16px);
    }

    .car-meta {
      font-size: 11px;
      line-height: 1.5;
      opacity: 0.9;
      margin-bottom: 10px;
    }

    .price-big {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      margin-bottom: 12px;
    }

    .price-big strong {
      font-size: 38px;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 900;
    }

    .price-big span {
      font-size: 12px;
      padding-bottom: 5px;
      opacity: 0.86;
    }

    .delta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(29, 220, 255, 0.16);
      color: #c1f4ff;
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .chart {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      align-items: end;
      gap: 8px;
      height: 86px;
      margin: 12px 0 6px;
    }

    .bar-wrap {
      display: grid;
      gap: 8px;
      justify-items: center;
    }

    .bar {
      width: 100%;
      border-radius: 12px 12px 6px 6px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(29, 220, 255, 0.36));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
      height: var(--height, 40px);
      transform-origin: bottom;
      animation: growBar 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .bar.hot {
      background: linear-gradient(180deg, #ffd2e8 0%, #f84ca2 100%);
    }

    .bar-label {
      font-size: 10px;
      opacity: 0.72;
    }

    .step-flow {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .step-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.09);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .step-number {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 12px;
      font-weight: 800;
      background: rgba(255, 255, 255, 0.16);
      flex-shrink: 0;
    }

    .step-item.active {
      background: rgba(29, 220, 255, 0.18);
      border-color: rgba(29, 220, 255, 0.34);
      transform: translateX(4px);
    }

    .step-item small {
      display: block;
      font-size: 10px;
      opacity: 0.72;
    }

    .step-item strong {
      display: block;
      font-size: 12px;
      line-height: 1.5;
    }

    .shot-button {
      margin-top: 14px;
      width: 100%;
      min-height: 43px;
      border: 0;
      border-radius: 999px;
      font: inherit;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .shot-button:hover {
      transform: translateY(-1px);
    }

    .shot-button:active {
      transform: translateY(1px) scale(0.99);
    }

    .slide-a .shot-button {
      color: var(--dark-blue);
      background: var(--gradient-primary);
      box-shadow: 0 14px 28px rgba(29, 220, 255, 0.28);
    }

    .dashboard-stack {
      display: grid;
      gap: 12px;
      margin-top: 18px;
      position: relative;
      z-index: 2;
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 16px 36px rgba(17, 36, 110, 0.1);
      border: 1px solid rgba(64, 153, 255, 0.08);
    }

    .card-title {
      margin: 0 0 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-gray);
      letter-spacing: 0.04em;
    }

    .cost-flex {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 14px;
      align-items: center;
    }

    .donut {
      width: 92px;
      height: 92px;
      border-radius: 50%;
      background:
        radial-gradient(circle at center, #ffffff 42%, transparent 43%),
        conic-gradient(#f84ca2 0 26%, #4db4ff 26% 63%, #1c2663 63% 87%, #d9e6ff 87% 100%);
      display: grid;
      place-items: center;
      position: relative;
    }

    .donut::after {
      content: "3/4";
      width: 58px;
      height: 58px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 16px;
      font-weight: 900;
      color: var(--dark-blue);
      background: #fff;
      box-shadow: 0 10px 18px rgba(17, 36, 110, 0.08);
    }

    .cost-values strong {
      display: block;
      font-size: 30px;
      line-height: 1;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
      margin-bottom: 8px;
    }

    .cost-values p {
      margin: 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .expense-list {
      display: grid;
      gap: 10px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 10px;
      font-size: 12px;
      color: var(--dark-blue);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    .expense-bar {
      height: 8px;
      border-radius: 999px;
      background: #e5eefb;
      overflow: hidden;
    }

    .expense-bar span {
      display: block;
      height: 100%;
      width: var(--fill, 60%);
      border-radius: inherit;
      background: linear-gradient(90deg, #1ddcff, #f84ca2);
      transition: width 0.4s ease;
    }

    .forecast-box {
      background: linear-gradient(135deg, rgba(28, 38, 99, 0.96), rgba(14, 23, 80, 0.94));
      color: #fff;
      border-radius: 22px;
      padding: 16px;
      position: relative;
      overflow: hidden;
    }

    .forecast-box::after {
      content: "";
      position: absolute;
      inset: auto -20px -40px auto;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: rgba(29, 220, 255, 0.14);
      filter: blur(4px);
    }

    .forecast-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: start;
    }

    .forecast-top strong {
      display: block;
      font-size: 26px;
      line-height: 1;
      letter-spacing: -0.04em;
      margin-top: 4px;
    }

    .forecast-chip {
      padding: 8px 10px;
      border-radius: 999px;
      background: rgba(248, 76, 162, 0.18);
      color: #ffd4e9;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .spark {
      display: flex;
      align-items: end;
      gap: 6px;
      height: 72px;
      margin-top: 12px;
    }

    .spark span {
      width: 18%;
      border-radius: 10px 10px 4px 4px;
      height: var(--h, 40%);
      background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(29,220,255,0.35));
      animation: growBar 0.8s ease;
    }

    .android-footer {
      margin-top: 12px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .slide-b .shot-button {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 14px 30px rgba(248, 76, 162, 0.22);
    }

    .compare-zone {
      margin-top: 18px;
      display: grid;
      gap: 12px;
      position: relative;
      z-index: 2;
    }

    .hero-zero {
      display: grid;
      grid-template-columns: 104px 1fr;
      gap: 14px;
      align-items: center;
      padding: 16px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(255,255,255,0.14), rgba(255,255,255,0.06));
      border: 1px solid rgba(255,255,255,0.12);
      backdrop-filter: blur(16px);
    }

    .zero-bubble {
      width: 104px;
      height: 104px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #d7f4ff 28%, #1ddcff 65%, #4db4ff 100%);
      color: var(--dark-blue);
      box-shadow: 0 20px 40px rgba(29, 220, 255, 0.26);
      animation: pulse 2.6s ease-in-out infinite;
    }

    .zero-bubble strong {
      display: block;
      font-size: 46px;
      line-height: 1;
      letter-spacing: -0.06em;
    }

    .zero-bubble span {
      display: block;
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    .hero-zero p {
      margin: 6px 0 0;
      font-size: 12px;
      line-height: 1.6;
      color: #d8eaff;
    }

    .compare-card {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.1);
      backdrop-filter: blur(12px);
    }

    .compare-row {
      display: grid;
      grid-template-columns: 92px 1fr auto;
      gap: 10px;
      align-items: center;
      margin-top: 10px;
      font-size: 12px;
    }

    .compare-bar {
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.14);
      overflow: hidden;
    }

    .compare-bar span {
      display: block;
      height: 100%;
      width: var(--risk, 40%);
      border-radius: inherit;
      background: linear-gradient(90deg, #f84ca2, #ff8ec2);
      transition: width 0.5s ease;
    }

    .compare-bar.cool span {
      background: linear-gradient(90deg, #1ddcff, #4db4ff);
    }

    .compare-note {
      padding: 14px;
      border-radius: 20px;
      background: rgba(29, 220, 255, 0.14);
      font-size: 12px;
      line-height: 1.7;
      color: #e8f9ff;
      border: 1px solid rgba(29, 220, 255, 0.18);
    }

    .slide-c .shot-button {
      background: #fff;
      color: var(--dark-blue);
      box-shadow: 0 14px 32px rgba(10, 19, 72, 0.28);
    }

    .swipe-hint {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 999px;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.72);
      backdrop-filter: blur(12px);
      box-shadow: 0 12px 26px rgba(17, 36, 110, 0.08);
      font-size: 12px;
      font-weight: 700;
      animation: nudge 2.4s ease-in-out infinite;
    }

    .swipe-arrows {
      display: flex;
      gap: 6px;
    }

    .swipe-arrows span {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      background: linear-gradient(180deg, #fff, #edf4ff);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.9);
    }

    .panel-stack {
      display: grid;
      gap: 18px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid rgba(255, 255, 255, 0.46);
      border-radius: 28px;
      padding: 20px;
      box-shadow: var(--surface-shadow);
      backdrop-filter: blur(18px);
    }

    .panel h2 {
      margin: 0 0 10px;
      font-size: 20px;
      line-height: 1.3;
      color: var(--dark-blue);
      letter-spacing: -0.03em;
    }

    .panel p {
      margin: 0;
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .panel-top {
      display: grid;
      gap: 12px;
    }

    .meta-grid {
      margin-top: 18px;
      display: grid;
      gap: 14px;
      grid-template-columns: 1.15fr 0.85fr;
    }

    .meta-card {
      border-radius: 22px;
      padding: 16px;
      background: var(--panel-strong);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.68);
    }

    .meta-card small {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 8px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .meta-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 18px;
      line-height: 1.45;
      letter-spacing: -0.03em;
    }

    .meta-card span {
      display: block;
      margin-top: 8px;
      font-size: 13px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .nav-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .nav-button {
      min-height: 43px;
      border: 0;
      border-radius: 999px;
      padding: 0 18px;
      font: inherit;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      color: var(--dark-blue);
      background: var(--gradient-primary);
      box-shadow: 0 12px 22px rgba(29, 220, 255, 0.16);
      transition: transform 0.16s ease, opacity 0.16s ease;
    }

    .nav-button.secondary {
      background: #fff;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.12);
    }

    .nav-button:active {
      transform: scale(0.98);
    }

    .dot-nav {
      display: flex;
      gap: 10px;
      margin-top: 16px;
      flex-wrap: wrap;
    }

    .dot-nav button {
      border: 0;
      border-radius: 18px;
      padding: 10px 12px;
      font: inherit;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.76);
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.08);
      cursor: pointer;
      transition: all 0.22s ease;
    }

    .dot-nav button.active {
      color: #fff;
      background: var(--dark-blue);
      box-shadow: 0 14px 28px rgba(28, 38, 99, 0.2);
      transform: translateY(-1px);
    }

    .progress-rail {
      height: 10px;
      border-radius: 999px;
      background: #e8efff;
      overflow: hidden;
      margin-top: 18px;
    }

    .progress-rail span {
      display: block;
      height: 100%;
      width: 33.33%;
      border-radius: inherit;
      background: linear-gradient(90deg, #f84ca2, #4db4ff);
      transition: width 0.45s ease;
    }

    .diagnostic {
      display: grid;
      gap: 18px;
    }

    .stepper {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .stepper span {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: #edf2ff;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 900;
      transition: all 0.2s ease;
    }

    .stepper span.active {
      background: var(--dark-blue);
      color: #fff;
      box-shadow: 0 10px 22px rgba(28, 38, 99, 0.16);
    }

    .stepper-line {
      flex: 1;
      min-width: 28px;
      height: 6px;
      border-radius: 999px;
      background: #edf2ff;
      overflow: hidden;
      position: relative;
    }

    .stepper-line::after {
      content: "";
      position: absolute;
      inset: 0;
      width: var(--step-fill, 0%);
      background: linear-gradient(90deg, #f84ca2, #4db4ff);
      transition: width 0.35s ease;
    }

    .question h3 {
      margin: 0 0 10px;
      font-size: 16px;
      color: var(--dark-blue);
    }

    .option-grid {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .option {
      min-height: 43px;
      border: 0;
      border-radius: 22px;
      padding: 10px 14px;
      background: #fff;
      color: var(--text-black);
      font: inherit;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: inset 0 0 0 1px #e3e8f7;
      transition: all 0.18s ease;
    }

    .option.active {
      background: var(--dark-blue);
      color: #fff;
      box-shadow: 0 14px 28px rgba(28, 38, 99, 0.18);
      transform: translateY(-1px);
    }

    .result-card {
      padding: 18px;
      border-radius: 22px;
      background: linear-gradient(135deg, rgba(28, 38, 99, 0.98), rgba(17, 30, 102, 0.94));
      color: #fff;
      overflow: hidden;
      position: relative;
    }

    .result-card::after {
      content: "";
      position: absolute;
      width: 180px;
      height: 180px;
      border-radius: 50%;
      background: rgba(29, 220, 255, 0.12);
      right: -50px;
      bottom: -80px;
      filter: blur(6px);
    }

    .result-card small {
      display: block;
      font-size: 11px;
      letter-spacing: 0.08em;
      opacity: 0.72;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .result-card strong {
      display: block;
      font-size: 22px;
      line-height: 1.4;
      margin-bottom: 8px;
      letter-spacing: -0.03em;
      position: relative;
      z-index: 1;
    }

    .result-card p {
      color: #d7e6ff;
      position: relative;
      z-index: 1;
    }

    .metric-strip {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .metric {
      padding: 16px;
      border-radius: 20px;
      background: #fff;
      box-shadow: inset 0 0 0 1px rgba(28, 38, 99, 0.06);
    }

    .metric small {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .metric strong {
      display: block;
      font-size: 26px;
      line-height: 1;
      color: var(--dark-blue);
      letter-spacing: -0.04em;
      margin-bottom: 6px;
    }

    .metric span {
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .tiny-note {
      margin-top: 14px;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .flash {
      animation: flash 0.6s ease;
    }

    @keyframes growBar {
      from {
        transform: scaleY(0.2);
        opacity: 0.4;
      }
      to {
        transform: scaleY(1);
        opacity: 1;
      }
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 20px 40px rgba(29, 220, 255, 0.26);
      }
      50% {
        transform: scale(1.04);
        box-shadow: 0 24px 50px rgba(29, 220, 255, 0.34);
      }
    }

    @keyframes nudge {
      0%, 100% {
        transform: translateX(0);
      }
      35% {
        transform: translateX(-4px);
      }
      70% {
        transform: translateX(4px);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(12px);
      }
    }

    @keyframes flash {
      0% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.03);
      }
      100% {
        transform: scale(1);
      }
    }

    @media (max-width: 960px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .phone-stage {
        position: static;
      }

      .panel {
        padding: 18px;
      }

      .meta-grid,
      .metric-strip {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 420px) {
      .page {
        padding: 16px 12px 36px;
      }

      .slide {
        padding: 16px 16px 20px;
      }

      .slide-title {
        font-size: 30px;
      }

      .price-big strong {
        font-size: 34px;
      }

      .hero-zero {
        grid-template-columns: 1fr;
      }

      .zero-bubble {
        margin: 0 auto;
      }
    }
  </style>
</head>
