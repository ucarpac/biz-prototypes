      filter: saturate(1.03);
    }

    .expense-total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .expense-amount {
      color: var(--dark-blue);
      font-size: 34px;
      line-height: 1.15;
      letter-spacing: -0.03em;
      font-weight: 900;
    }

    .expense-meta {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
      font-weight: 700;
      text-align: right;
    }

    .expense-list {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .expense-item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      font-size: 12px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .expense-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
    }

    .expense-bar {
      position: relative;
      height: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: #eef3f8;
    }

    .expense-fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 50%;
      border-radius: inherit;
      transition: width var(--transition);
    }

    .forecast-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .forecast-box {
      padding: 12px;
      border-radius: 12px;
      text-align: center;
      background: rgba(255,255,255,.94);
    }

    .forecast-box strong {
      display: block;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 1.35;
      font-weight: 900;
    }

    .forecast-box span {
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.5;
      font-weight: 700;
    }

    .mini-graph {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 12px;
      background: #fffdfb;
      border: 1px solid rgba(28,38,99,.05);
    }

    .memory-strip {
      display: grid;
      gap: 10px;
      margin: 16px 16px 0;
    }

    .memory-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255,255,255,.92);
      box-shadow: var(--shadow-light);
    }

    .memory-icon {
      flex: 0 0 34px;
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: #fff0c7;
      font-size: 16px;
    }

    .memory-text strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.5;
    }

    .memory-text span {
      display: block;
      color: var(--text-gray);
      font-size: 11px;
      line-height: 1.6;
      font-weight: 700;
    }

    .compare-hero {
      position: relative;
      z-index: 2;
      padding: 14px 18px 0;
    }

    .compare-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .compare-badge {
      min-width: 112px;
      min-height: 58px;
      padding: 10px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,.94);
      box-shadow: var(--shadow-light);
      text-align: center;
    }

    .compare-badge strong {
      display: block;
      color: var(--pink);
      font-size: 28px;
      line-height: 1.1;
      font-weight: 900;
    }

    .compare-badge span {
      display: block;
      color: var(--text-gray);
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
    }

    .compare-toggle {
      position: relative;
      z-index: 2;
      display: flex;
      gap: 8px;
      margin: 14px 18px 0;
      padding: 6px;
      border-radius: 999px;
      background: rgba(255,255,255,.92);
      box-shadow: var(--shadow-light);
    }

    .compare-btn {
      flex: 1;
      min-height: 38px;
      padding: 0 10px;
      font-size: 12px;
    }

    .compare-table {
      position: relative;
      z-index: 2;
      margin: 14px 16px 0;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,.94);
      box-shadow: var(--shadow-light);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: 1.1fr repeat(4, 1fr);
      gap: 8px;
    }

    .compare-head,
    .compare-cell {
      padding: 10px 8px;
      border-radius: 12px;
      text-align: center;
      font-size: 11px;
      line-height: 1.5;
    }

    .compare-head {
      background: #f7f9fc;
      color: var(--text-gray);
      font-weight: 900;
    }

    .compare-head.ucarpac,
    .compare-cell.ucarpac {
      background: rgba(248,76,162,.12);
      color: var(--dark-blue);
    }

    .compare-cell {
      background: #fff;
      color: var(--dark-blue);
      box-shadow: inset 0 0 0 1px rgba(28,38,99,.05);
    }

    .compare-cell strong {
      display: block;
      font-size: 18px;
      line-height: 1.2;
      font-weight: 900;
    }

    .compare-cell span {
      display: block;
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.5;
      font-weight: 700;
      color: var(--text-gray);
    }

    .compare-quote {
      position: relative;
      z-index: 2;
      margin: 14px 16px 0;
      padding: 14px;
      border-radius: 16px;
      background: rgba(255,255,255,.94);
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.8;
      font-weight: 800;
      box-shadow: var(--shadow-light);
    }

    .screen-footer {
      position: relative;
      z-index: 2;
      margin: 14px 16px 0;
      padding: 10px 14px 16px;
      color: #6f7593;
      font-size: 11px;
      line-height: 1.7;
      font-weight: 700;
    }

    .bottom-notes {
      margin-top: 24px;
      padding: 18px;
      border-radius: 26px;
      background: rgba(255,255,255,.78);
      border: 1px solid rgba(255,255,255,.82);
      box-shadow: var(--shadow-medium);
      display: grid;
      gap: 12px;
    }

    .bottom-notes h3 {
      margin: 0;
      color: var(--dark-blue);
      font-size: 20px;
      line-height: 1.5;
      font-weight: 900;
    }

    .notes-grid {
      display: grid;
      gap: 12px;
    }

    .note-card {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,.94);
      box-shadow: var(--shadow-light);
    }

    .note-card strong {
      display: block;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
      font-weight: 900;
    }

    .note-card span {
      display: block;
      margin-top: 4px;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
      font-weight: 700;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%) translateY(18px);
      min-width: 240px;
      max-width: calc(100vw - 32px);
      padding: 12px 16px;
      border-radius: 16px;
      background: rgba(9,19,85,.92);
      color: var(--white);
      font-size: 12px;
      line-height: 1.6;
      text-align: center;
      box-shadow: var(--shadow-heavy);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition), transform var(--transition);
      z-index: 60;
    }

    .toast.visible {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.08); }
    }

    @keyframes floatNote {
      0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
      50% { transform: translateY(-6px) rotate(var(--r, 0deg)); }
    }

    @keyframes drawLine {
      to { stroke-dashoffset: 0; }
    }

    @media (min-width: 980px) {
      .screens {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        align-items: start;
      }

      .shot {
        height: 100%;
      }
    }

    @media (max-width: 768px) {
      .hero-grid {
        grid-template-columns: 1fr;
      }

      .doodle {
        margin: 4px auto 0;
      }

      .compare-top {
        flex-direction: column;
      }

      .compare-badge {
        width: fit-content;
      }
    }

    @media (max-width: 420px) {
      .page {
        padding-inline: 10px;
      }

      .hero-wrap,
      .controls,
      .shot,
      .bottom-notes {
        padding-inline: 14px;
      }

      .hero h2,
      .compare-top h2 {
        font-size: 29px;
      }

      .price {
        font-size: 34px;
      }

      .expense-amount {
        font-size: 28px;
      }

      .compare-grid {
        gap: 6px;
      }

      .compare-head,
      .compare-cell {
        padding: 10px 6px;
      }

      .compare-cell strong {
        font-size: 17px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="hero-wrap">
      <div class="eyebrow">
        <span class="pulse"></span>
        ASO検証 2026.04.06 / ストアPV→DL率 改善案
      </div>
      <h1>安心できる理由を先に見せて、<br>ダウンロードの迷いをほどく。</h1>
      <p class="lead">
        いま知りたいのは、機能一覧ではなく<strong>「このアプリなら怖くなさそう」</strong>という直感です。
        そこで今回は、<span class="marker">AI査定の安心感</span>、<span class="marker">出費管理と将来予測の納得感</span>、
        <span class="marker">電話0本で見始められる気軽さ</span>を、暖かくやわらかい表現でストアスクショに落とし込みました。
      </p>
      <div class="kpi-strip">
        <div class="kpi-pill"><strong>現状</strong> ストアPV→DL率 17.3%</div>
        <div class="kpi-pill"><strong>目標</strong> 25%</div>
        <div class="kpi-pill">訴求軸 AI査定 / 出費管理 / 電話0本</div>
        <div class="kpi-pill">前提 個人情報なしで相場チェック可能</div>
      </div>
    </header>

    <section class="controls">
      <div class="control-row">
        <div class="control-label">注目するスクショ</div>
        <button class="tab-btn active" data-focus="a" type="button">A / AI査定</button>
        <button class="tab-btn" data-focus="b" type="button">B / 出費管理</button>
        <button class="tab-btn" data-focus="c" type="button">C / 電話0本</button>
      </div>
      <div class="control-row">
        <div class="control-label">車種を切替</div>
        <button class="vehicle-btn active" data-vehicle="prius" type="button">プリウス</button>
        <button class="vehicle-btn" data-vehicle="serena" type="button">セレナ</button>
        <button class="vehicle-btn" data-vehicle="nbox" type="button">N-BOX</button>
      </div>
      <div class="control-row">
        <div class="control-label">利用シーン</div>
        <button class="mode-btn active" data-mode="check" type="button">まずは相場を見る</button>
        <button class="mode-btn" data-mode="sell" type="button">売る相談まで進む</button>
      </div>
    </section>

    <section class="screens">
      <article class="shot focused" data-shot="a">
        <div class="shot-head">
          <div>
            <div class="shot-tag">iOS向け / スクショA</div>
            <h2 class="shot-title">AI査定を主役にして、<br>「まず入れてみよう」を作る。</h2>
            <p class="shot-desc">
              はじめの1枚は、愛車の価値が見える安心感をまっすぐ伝えます。
              セールス感ではなく、やさしく背中を押すトーンで不安を下げる設計です。
            </p>
          </div>
          <div class="shot-note">
            <strong>狙い</strong><br>
            価格を見たい比較検討層に、
            「個人情報なしで試せる」入口を強く印象づけます。
          </div>
        </div>

        <div class="phone">
          <div class="screen ai">
            <div class="status-bar">
              <span>9:41</span>
              <span>UcarPAC</span>
              <span>100%</span>
            </div>

            <div class="sticky note-a1" style="--r:-7deg;">あとで売るでも<br>だいじょうぶ。</div>
            <div class="sticky alt note-a2" style="--r:6deg;">電話なしで<br>相場だけ見れる</div>

            <section class="hero">
              <div class="hero-grid">
                <div>
                  <h2 id="aHook">AIがあなたの愛車を査定</h2>
                  <p id="aSupport">
                    相場が見えると、気持ちは少し軽くなる。
                    まだ売らなくても、まずは今日の価値を知るところから。
                  </p>
                  <div class="badge-row">
                    <div class="mini-badge pink">個人情報なしで開始</div>
                    <div class="mini-badge yellow">将来予測つき</div>
                    <div class="mini-badge blue">8,000社の相場学習</div>
                  </div>
                </div>
                <div class="doodle" aria-hidden="true">
                  <div class="blob"></div>
                  <div class="face"><div class="smile"></div></div>
                  <div class="car"></div>
                </div>
              </div>
            </section>

            <section class="card">
              <div class="card-head">
                <div>
                  <h3 class="card-title" id="aName">トヨタ プリウス Z</h3>
                  <p class="card-caption" id="aMeta">2021年式 / 28,400km / アティチュードブラックマイカ</p>
                </div>
                <div class="price" id="aPrice">2,186,000<span class="yen">円</span></div>
              </div>

              <div class="pill-row">
                <div class="pill" id="aPill1">AI精度 89%</div>
                <div class="pill" id="aPill2">査定完了まで 約60秒</div>
                <div class="pill" id="aPill3">売り時メモも保存可能</div>
              </div>

              <div class="graph">
                <svg viewBox="0 0 320 120" preserveAspectRatio="none" aria-hidden="true">
                  <path class="graph-area" id="aArea" d=""></path>
                  <path class="graph-line" id="aLine" d=""></path>
                  <circle class="graph-dot" id="aDot0" cx="0" cy="0" r="6"></circle>
                  <circle class="graph-dot" id="aDot1" cx="0" cy="0" r="6"></circle>
                  <circle class="graph-dot" id="aDot2" cx="0" cy="0" r="6"></circle>
                </svg>
                <div class="graph-labels">
                  <span id="aNowLabel">いま 218.6万円</span>
                  <span id="aThreeLabel">3ヶ月後 214.2万円</span>
                  <span id="aSixLabel">6ヶ月後 207.1万円</span>
                </div>
              </div>

              <div class="three-grid">
                <div class="mini-stat">
                  <strong id="aStatNow">218.6万</strong>
                  <span>現在の予測</span>
                </div>
                <div class="mini-stat">
                  <strong id="aStatThree">214.2万</strong>
                  <span>3ヶ月後</span>
                </div>
                <div class="mini-stat">
                  <strong id="aStatSix">207.1万</strong>
                  <span>6ヶ月後</span>
                </div>
              </div>

              <button class="primary-btn" type="button" data-toast="写真からAI査定を開始する想定です。">写真でAI査定をはじめる</button>
              <button class="secondary-btn" type="button" data-toast="売り時メモを保存する想定です。">あとで売るメモを残す</button>
            </section>

            <section class="card dark">
              <div class="card-head">
                <div>
                  <h3 class="card-title">いま急がなくても大丈夫</h3>
                  <p class="card-caption" id="aRelief">半年後に約11.5万円下がる見込み。判断材料があれば、焦らなくていい。</p>
                </div>
              </div>
              <div class="pill-row">
                <div class="pill">値下がりの気配を通知</div>
                <div class="pill">気になる時だけ戻ればOK</div>
              </div>
            </section>

            <div class="screen-footer">
              スクショAの想定コピー:
              「AIがあなたの愛車を査定」
              「個人情報なしで相場チェック」
            </div>
          </div>
        </div>
      </article>

      <article class="shot" data-shot="b">
        <div class="shot-head">
          <div>
            <div class="shot-tag android">Android向け / スクショB</div>
            <h2 class="shot-title">出費管理と将来予測で、<br>“いま売る理由”までやさしく見せる。</h2>
            <p class="shot-desc">
              2枚目では、車を持ち続けるコストと価値の変化を一緒に見せます。
              売却だけでなく、日々の家計感覚にも寄り添う見せ方です。
            </p>
          </div>
          <div class="shot-note">
            <strong>狙い</strong><br>
            一度DLした後の継続利用イメージを持たせ、
            「入れておく意味」を強めます。
          </div>
        </div>

        <div class="phone android">
          <div class="screen life">
            <div class="status-bar">
              <span>9:41</span>
              <span>UcarPAC</span>
              <span>100%</span>
            </div>

            <div class="sticky note-b1" style="--r:-6deg;">毎月の出費も<br>ちゃんと見える</div>

            <section class="hero">
              <div class="hero-grid">
                <div>
                  <h2 id="bHook">出費も、売り時も、<br>まとめて見える。</h2>
                  <p id="bSupport">
                    ガソリンも保険も車検も、積み重なる前に気づけると、
                    次の判断がしやすくなります。
                  </p>
                  <div class="badge-row">
                    <div class="mini-badge yellow">出費管理つき</div>
                    <div class="mini-badge pink">将来予測あり</div>
                    <div class="mini-badge blue">アプリで継続チェック</div>
                  </div>
                </div>
                <div class="doodle" aria-hidden="true">
                  <div class="blob" style="background:linear-gradient(180deg,#fffefa 0%,#eef8ff 100%);"></div>
                  <div class="face" style="background:#fff4db;"><div class="smile"></div></div>
                  <div class="car blue"></div>
                </div>
              </div>
            </section>

            <section class="card">
              <div class="expense-total">
                <div>
                  <h3 class="card-title">今月の維持費</h3>
                  <p class="card-caption" id="bMeta">トヨタ プリウス Z / 月次サマリー</p>
                </div>
                <div>
                  <div class="expense-amount" id="bTotal">38,200円</div>
                  <div class="expense-meta" id="bAnnual">年間見込み 458,400円</div>
                </div>
              </div>

              <div class="expense-list">
                <div class="expense-item">
                  <span class="expense-dot" style="background:#F84CA2;"></span>
                  <div class="expense-bar"><div class="expense-fill" id="fill1"></div></div>
                  <span id="expense1">ガソリン 8,600円</span>
                </div>
                <div class="expense-item">
                  <span class="expense-dot" style="background:#ffb15e;"></span>
                  <div class="expense-bar"><div class="expense-fill" id="fill2"></div></div>
                  <span id="expense2">保険 6,400円</span>
                </div>
                <div class="expense-item">
                  <span class="expense-dot" style="background:#52bfff;"></span>
                  <div class="expense-bar"><div class="expense-fill" id="fill3"></div></div>
                  <span id="expense3">駐車場 18,000円</span>
                </div>
                <div class="expense-item">
                  <span class="expense-dot" style="background:#1c2663;"></span>
                  <div class="expense-bar"><div class="expense-fill" id="fill4"></div></div>
                  <span id="expense4">洗車・整備 5,200円</span>
                </div>
              </div>

              <div class="forecast-card">
                <div class="forecast-box">
                  <strong id="bThree">214.2万</strong>
                  <span>3ヶ月後の予測価格</span>
                </div>
                <div class="forecast-box">
                  <strong id="bSix">207.1万</strong>
                  <span>6ヶ月後の予測価格</span>
                </div>
              </div>

              <div class="mini-graph">
                <svg viewBox="0 0 300 92" preserveAspectRatio="none" aria-hidden="true">
                  <path class="graph-area" id="bArea" d=""></path>
                  <path class="graph-line" id="bLine" d=""></path>
                  <circle class="graph-dot" id="bDot0" cx="0" cy="0" r="5.5"></circle>
                  <circle class="graph-dot" id="bDot1" cx="0" cy="0" r="5.5"></circle>
                  <circle class="graph-dot" id="bDot2" cx="0" cy="0" r="5.5"></circle>
                </svg>
              </div>

              <button class="primary-btn" type="button" data-toast="出費管理を有効化する想定です。">出費管理をはじめる</button>
              <button class="ghost-btn" type="button" data-toast="売り時通知を保存する想定です。">売り時の通知を受け取る</button>
            </section>

            <div class="memory-strip">
              <div class="memory-card">
                <div class="memory-icon">⛽</div>
                <div class="memory-text">
                  <strong id="memory1">今月はガソリン代が先月比 +1,400円</strong>
                  <span>細かな変化が見えると、売る判断も納得しやすい。</span>
                </div>
              </div>
              <div class="memory-card">
                <div class="memory-icon">📉</div>
                <div class="memory-text">
                  <strong id="memory2">半年後は約11.5万円の値下がり予測</strong>
                  <span>「まだ先でいいかな」を数字で整理できる。</span>
                </div>
              </div>
            </div>

            <div class="screen-footer">
              スクショBの想定コピー:
              「車の出費、見える化しよう」
              「今売るべき？将来の相場も予測」
