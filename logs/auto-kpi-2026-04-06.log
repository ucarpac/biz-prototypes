            <section class="card">
              <div class="card-head">
                <div>
                  <h3 class="card-title" id="cName">トヨタ プリウス Z の場合</h3>
                  <p class="card-caption" id="cMeta">AI査定価格 218.6万円 / 6ヶ月後 207.1万円予測</p>
