    </section>

    <section class="bottom-notes">
      <h3>このA案で重視していること</h3>
      <div class="notes-grid">
        <div class="note-card">
          <strong>1. 感情の入口を先に作る</strong>
          <span>AIの精度や機能量より先に、「安心して試せる」「急がなくていい」を見せてDLの心理負荷を下げます。</span>
        </div>
        <div class="note-card">
          <strong>2. 売却アプリではなく、判断を助けるアプリに見せる</strong>
          <span>出費管理と将来予測を入れることで、今すぐ売らない層にも存在理由を作ります。</span>
        </div>
        <div class="note-card">
          <strong>3. 競合比較は最後に不安を消すために使う</strong>
          <span>「電話0本」を明示して、MOTA・セルカ・ズバット比較で離脱しそうなユーザーを取り戻します。</span>
        </div>
      </div>
    </section>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    const vehicleData = {
      prius: {
        name: "トヨタ プリウス Z",
        meta: "2021年式 / 28,400km / アティチュードブラックマイカ",
        current: 2186000,
        future3: 2142000,
        future6: 2071000,
        confidence: "AI精度 89%",
        time: "査定完了まで 約60秒",
        memo: "売り時メモも保存可能",
        relief: "半年後に約11.5万円下がる見込み。判断材料があれば、焦らなくていい。",
        monthlyTotal: 38200,
        annualTotal: 458400,
        expenses: [
          { label: "ガソリン", amount: 8600, fill: 36, color: "#F84CA2" },
          { label: "保険", amount: 6400, fill: 27, color: "#ffb15e" },
          { label: "駐車場", amount: 18000, fill: 75, color: "#52bfff" },
          { label: "洗車・整備", amount: 5200, fill: 21, color: "#1c2663" }
        ],
        memory1: "今月はガソリン代が先月比 +1,400円",
        memory2: "半年後は約11.5万円の値下がり予測"
      },
      serena: {
        name: "日産 セレナ e-POWER ハイウェイスターV",
        meta: "2020年式 / 41,200km / プリズムホワイト",
        current: 1948000,
        future3: 1896000,
        future6: 1825000,
        confidence: "AI精度 87%",
        time: "査定完了まで 約75秒",
        memo: "家族の予定に合わせて売り時保存",
        relief: "半年後に約12.3万円下がる見込み。家族の予定とあわせて、落ち着いて決められる。",
        monthlyTotal: 46700,
        annualTotal: 560400,
        expenses: [
          { label: "ガソリン", amount: 11200, fill: 48, color: "#F84CA2" },
          { label: "保険", amount: 7900, fill: 34, color: "#ffb15e" },
          { label: "駐車場", amount: 18000, fill: 77, color: "#52bfff" },
          { label: "洗車・整備", amount: 9600, fill: 41, color: "#1c2663" }
        ],
        memory1: "今月は整備費が入って先月比 +4,200円",
        memory2: "半年後は約12.3万円の値下がり予測"
      },
      nbox: {
        name: "ホンダ N-BOX カスタム Lターボ",
        meta: "2022年式 / 12,900km / プレミアムサンライトホワイト",
        current: 1534000,
        future3: 1516000,
        future6: 1484000,
        confidence: "AI精度 91%",
        time: "査定完了まで 約55秒",
        memo: "日常の出費と一緒に価値を確認",
        relief: "半年後に約5.0万円下がる見込み。軽でも資産価値はしっかり見ておきたい。",
        monthlyTotal: 29100,
        annualTotal: 349200,
        expenses: [
          { label: "ガソリン", amount: 5900, fill: 28, color: "#F84CA2" },
          { label: "保険", amount: 5600, fill: 26, color: "#ffb15e" },
          { label: "駐車場", amount: 12000, fill: 57, color: "#52bfff" },
          { label: "洗車・整備", amount: 5600, fill: 26, color: "#1c2663" }
        ],
        memory1: "今月はガソリン代が先月比 -700円",
        memory2: "半年後は約5.0万円の値下がり予測"
      }
    };

    const refs = {
      aName: document.getElementById("aName"),
      aMeta: document.getElementById("aMeta"),
      aPrice: document.getElementById("aPrice"),
      aPill1: document.getElementById("aPill1"),
      aPill2: document.getElementById("aPill2"),
      aPill3: document.getElementById("aPill3"),
      aNowLabel: document.getElementById("aNowLabel"),
      aThreeLabel: document.getElementById("aThreeLabel"),
      aSixLabel: document.getElementById("aSixLabel"),
      aStatNow: document.getElementById("aStatNow"),
      aStatThree: document.getElementById("aStatThree"),
      aStatSix: document.getElementById("aStatSix"),
      aRelief: document.getElementById("aRelief"),
      aArea: document.getElementById("aArea"),
      aLine: document.getElementById("aLine"),
      aDots: [document.getElementById("aDot0"), document.getElementById("aDot1"), document.getElementById("aDot2")],
      bMeta: document.getElementById("bMeta"),
      bTotal: document.getElementById("bTotal"),
      bAnnual: document.getElementById("bAnnual"),
      bThree: document.getElementById("bThree"),
      bSix: document.getElementById("bSix"),
      bArea: document.getElementById("bArea"),
      bLine: document.getElementById("bLine"),
      bDots: [document.getElementById("bDot0"), document.getElementById("bDot1"), document.getElementById("bDot2")],
      expenseTexts: [
        document.getElementById("expense1"),
        document.getElementById("expense2"),
        document.getElementById("expense3"),
        document.getElementById("expense4")
      ],
      fills: [
        document.getElementById("fill1"),
        document.getElementById("fill2"),
        document.getElementById("fill3"),
        document.getElementById("fill4")
      ],
      memory1: document.getElementById("memory1"),
      memory2: document.getElementById("memory2"),
      cName: document.getElementById("cName"),
      cMeta: document.getElementById("cMeta"),
      cHook: document.getElementById("cHook"),
      cSupport: document.getElementById("cSupport"),
      cBadge: document.getElementById("cBadge"),
      cBadgeNote: document.getElementById("cBadgeNote"),
      cUcar: document.getElementById("cUcar"),
      cUcarNote: document.getElementById("cUcarNote"),
      cQuote: document.getElementById("cQuote"),
      toast: document.getElementById("toast")
    };

    let activeVehicle = "prius";
    let activeMode = "check";

    function formatYen(value) {
      return value.toLocaleString("ja-JP") + "円";
    }

    function formatMan(value) {
      return (value / 10000).toFixed(1).replace(/\.0$/, "") + "万";
    }

    function makePoints(values, width, height, paddingX, paddingY) {
      const min = Math.min(...values) * 0.96;
      const max = Math.max(...values) * 1.02;
      return values.map((value, index) => {
        const x = paddingX + index * ((width - paddingX * 2) / (values.length - 1));
        const y = height - paddingY - ((value - min) / (max - min || 1)) * (height - paddingY * 2);
        return { x, y };
      });
    }

    function linePath(points) {
      return points.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`).join(" ");
    }

    function areaPath(points, height, paddingY) {
      const start = points[0];
      const end = points[points.length - 1];
      return `${linePath(points)} L ${end.x} ${height - paddingY} L ${start.x} ${height - paddingY} Z`;
    }

    function renderGraph(areaEl, lineEl, dots, values, width, height, paddingX, paddingY) {
      const points = makePoints(values, width, height, paddingX, paddingY);
      areaEl.setAttribute("d", areaPath(points, height, paddingY));
      lineEl.setAttribute("d", linePath(points));
      dots.forEach((dot, index) => {
        dot.setAttribute("cx", points[index].x);
        dot.setAttribute("cy", points[index].y);
      });
      lineEl.style.animation = "none";
      requestAnimationFrame(() => {
        lineEl.style.animation = "";
      });
    }

    function setActive(selector, value, attr) {
      document.querySelectorAll(selector).forEach((button) => {
        button.classList.toggle("active", button.getAttribute(attr) === value);
      });
    }

    function setFocus(key) {
      setActive(".tab-btn", key, "data-focus");
      document.querySelectorAll(".shot").forEach((shot) => {
        shot.classList.toggle("focused", shot.dataset.shot === key);
      });
    }

    function applyVehicle() {
      const data = vehicleData[activeVehicle];

      refs.aName.textContent = data.name;
      refs.aMeta.textContent = data.meta;
      refs.aPrice.innerHTML = `${formatYen(data.current).replace("円", "")}<span class="yen">円</span>`;
      refs.aPill1.textContent = data.confidence;
      refs.aPill2.textContent = data.time;
      refs.aPill3.textContent = data.memo;
      refs.aNowLabel.textContent = `いま ${formatMan(data.current)}円`.replace("万円円", "万円");
      refs.aThreeLabel.textContent = `3ヶ月後 ${formatMan(data.future3)}円`.replace("万円円", "万円");
      refs.aSixLabel.textContent = `6ヶ月後 ${formatMan(data.future6)}円`.replace("万円円", "万円");
      refs.aStatNow.textContent = formatMan(data.current);
      refs.aStatThree.textContent = formatMan(data.future3);
      refs.aStatSix.textContent = formatMan(data.future6);
      refs.aRelief.textContent = data.relief;

      refs.bMeta.textContent = `${data.name} / 月次サマリー`;
      refs.bTotal.textContent = formatYen(data.monthlyTotal);
      refs.bAnnual.textContent = `年間見込み ${formatYen(data.annualTotal)}`;
      refs.bThree.textContent = formatMan(data.future3);
      refs.bSix.textContent = formatMan(data.future6);
      refs.memory1.textContent = data.memory1;
      refs.memory2.textContent = data.memory2;

      data.expenses.forEach((item, index) => {
        refs.expenseTexts[index].textContent = `${item.label} ${formatYen(item.amount)}`;
        refs.fills[index].style.width = `${item.fill}%`;
        refs.fills[index].style.background = `linear-gradient(90deg, ${item.color}, rgba(77,180,255,.85))`;
      });

      refs.cName.textContent = `${data.name} の場合`;
      refs.cMeta.textContent = `AI査定価格 ${formatMan(data.current)}円 / 6ヶ月後 ${formatMan(data.future6)}予測`.replace("万円円", "万円");

      renderGraph(refs.aArea, refs.aLine, refs.aDots, [data.current, data.future3, data.future6], 320, 120, 18, 12);
      renderGraph(refs.bArea, refs.bLine, refs.bDots, [data.current, data.future3, data.future6], 300, 92, 16, 10);
    }

    function applyMode() {
      if (activeMode === "check") {
        refs.cHook.innerHTML = "まずは相場だけ。<br>それなら電話0本。";
        refs.cSupport.innerHTML = "比較したいだけなのに電話が鳴る。<br>その不安をなくせば、DLする理由はぐっと明確になります。";
        refs.cBadge.textContent = "0本";
        refs.cBadgeNote.textContent = "相場チェックまで連絡なし";
        refs.cUcar.textContent = "0本";
        refs.cUcarNote.textContent = "相場チェックまで連絡なし";
        refs.cQuote.textContent = "「まだ売るか決めていない」人にとって、いちばん安心なのは“まず見ても何も始まりすぎないこと”。";
      } else {
        refs.cHook.innerHTML = "売る相談に進んでも、<br>やりとりは1社だけ。";
        refs.cSupport.innerHTML = "気持ちが固まったあとも、複数社対応に追われない。<br>最後まで安心感を保てる導線にします。";
        refs.cBadge.textContent = "1社";
        refs.cBadgeNote.textContent = "売却相談に進んでもやりとりは1社のみ";
        refs.cUcar.textContent = "1社";
        refs.cUcarNote.textContent = "オークション後の対応は1社のみ";
        refs.cQuote.textContent = "比較の手間を減らしたい人には、“高く売れる”だけでなく“疲れにくい”ことも価値になる。";
      }

      setActive(".mode-btn", activeMode, "data-mode");
      setActive(".compare-btn", activeMode, "data-compare-mode");
    }

    function showToast(message) {
      refs.toast.textContent = message;
      refs.toast.classList.add("visible");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => {
        refs.toast.classList.remove("visible");
      }, 1800);
    }

    document.querySelectorAll(".tab-btn").forEach((button) => {
      button.addEventListener("click", () => setFocus(button.dataset.focus));
    });

    document.querySelectorAll(".vehicle-btn").forEach((button) => {
      button.addEventListener("click", () => {
        activeVehicle = button.dataset.vehicle;
        setActive(".vehicle-btn", activeVehicle, "data-vehicle");
        applyVehicle();
      });
    });

    document.querySelectorAll(".mode-btn, .compare-btn").forEach((button) => {
      button.addEventListener("click", () => {
        activeMode = button.dataset.mode || button.dataset.compareMode;
        applyMode();
      });
    });

    document.querySelectorAll("[data-toast]").forEach((button) => {
      button.addEventListener("click", () => {
        button.style.transform = "scale(.98)";
        setTimeout(() => {
          button.style.transform = "";
        }, 120);
        showToast(button.dataset.toast);
      });
    });

    applyVehicle();
    applyMode();
    setFocus("a");
  </script>
</body>
</html>
