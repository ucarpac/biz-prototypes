      cursor: pointer;
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, color 0.25s ease;
      box-shadow: 0 8px 18px rgba(0,0,0,0.04);
    }

    .chip:hover,
    .chip:focus-visible {
      transform: translateY(-2px);
      outline: none;
    }

    .chip.is-active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
      box-shadow: 0 12px 24px rgba(28,38,99,0.18);
    }

    .toggle-row {
      max-width: 1120px;
      margin: 0 auto 26px;
      display: flex;
      justify-content: center;
      gap: 12px;
      position: relative;
      z-index: 2;
    }

    .cta {
      width: 182px;
      height: 43px;
      border: 0;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.25s ease, filter 0.25s ease, opacity 0.25s ease;
    }

    .cta.primary {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 10px 24px rgba(77,180,255,0.28);
    }

    .cta.pink {
      background: var(--gradient-pink);
      color: var(--white);
      box-shadow: 0 12px 24px rgba(248,76,162,0.28);
    }

    .cta:hover,
    .cta:focus-visible {
      transform: translateY(-2px) scale(1.01);
      filter: saturate(1.05);
      outline: none;
    }

    .grid {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
      align-items: start;
      position: relative;
      z-index: 1;
    }

    .phone-card {
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
      opacity: 1;
      transform: translateY(0);
      transition: transform 0.35s ease, opacity 0.35s ease;
    }

    .phone-card.is-dim {
      opacity: 0.28;
      transform: scale(0.98);
    }

    .card-meta {
      width: min(100%, 375px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }

    .screen-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      background: rgba(255,255,255,0.9);
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
      box-shadow: 0 6px 16px rgba(0,0,0,0.05);
    }

    .screen-label .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--pink);
      animation: pulse 2s infinite;
    }

    .screen-tag {
      font-size: 11px;
      font-weight: 700;
      color: var(--pink);
      transform: rotate(-4deg);
      padding: 4px 10px;
      border: 2px dashed rgba(248,76,162,0.34);
      border-radius: 999px;
      background: rgba(255,255,255,0.82);
    }

    .phone {
      width: min(100%, 375px);
      background: #11173a;
      border-radius: 36px;
      padding: 12px;
      box-shadow:
        0 30px 80px rgba(28,38,99,0.18),
        inset 0 0 0 1px rgba(255,255,255,0.1);
      position: relative;
      overflow: hidden;
    }

    .phone::before {
      content: "";
      width: 40%;
      height: 28px;
      background: #0c1027;
      position: absolute;
      top: 0;
      left: 30%;
      border-bottom-left-radius: 16px;
      border-bottom-right-radius: 16px;
      z-index: 3;
    }

    .screen {
      width: 100%;
      min-height: 720px;
      background: var(--gradient-warm);
      border-radius: 28px;
      overflow: hidden;
      position: relative;
    }

    .screen::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 80% 10%, rgba(255,255,255,0.58), transparent 28%),
        radial-gradient(circle at 18% 26%, rgba(255,179,106,0.22), transparent 24%);
      pointer-events: none;
    }

    .statusbar {
      position: relative;
      z-index: 2;
      padding: 18px 22px 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 11px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .status-icons {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .bubble, .bubble-alt, .spark {
      position: absolute;
      border-radius: 999px;
      opacity: 0.85;
      animation: floaty 5.6s ease-in-out infinite;
    }

    .bubble {
      width: 94px;
      height: 94px;
      right: -20px;
      top: 120px;
      background: rgba(255,255,255,0.42);
    }

    .bubble-alt {
      width: 56px;
      height: 56px;
      left: -16px;
      top: 240px;
      background: rgba(248,76,162,0.12);
      animation-delay: -2s;
    }

    .spark {
      width: 16px;
      height: 16px;
      right: 34px;
      top: 220px;
      background: rgba(255,179,106,0.44);
      animation-delay: -1.2s;
    }

    .screen-content {
      position: relative;
      z-index: 2;
      padding: 10px 18px 22px;
    }

    .hero {
      background: rgba(255,255,255,0.86);
      border-radius: 26px;
      padding: 18px 18px 20px;
      box-shadow: 0 18px 32px rgba(0,0,0,0.08);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, rgba(248,76,162,0.18), transparent 68%);
      top: -50px;
      right: -30px;
      pointer-events: none;
    }

    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .badge {
      min-height: 30px;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .badge.pink {
      background: rgba(248,76,162,0.12);
      color: var(--pink);
    }

    .badge.blue {
      background: rgba(29,220,255,0.14);
      color: var(--dark-blue);
    }

    .badge.orange {
      background: rgba(255,179,106,0.18);
      color: #9a4d00;
    }

    .hero h2 {
      margin: 0 0 10px;
      color: var(--dark-blue);
      font-size: 28px;
      line-height: 1.35;
      letter-spacing: 0.01em;
    }

    .hero p {
      margin: 0;
      color: var(--text-gray);
      font-size: 13px;
      line-height: 1.75;
    }

    .hand-note {
      margin-top: 14px;
      display: inline-block;
      padding: 8px 12px;
      border-radius: 14px;
      background: #fff6cc;
      color: #8a5b00;
      font-size: 12px;
      font-weight: 700;
      transform: rotate(-3deg);
      box-shadow: 0 8px 16px rgba(138,91,0,0.08);
    }

    .feature-card,
    .graph-card,
    .compare-card,
    .mini-card,
    .list-card {
      margin-top: 14px;
      background: rgba(255,255,255,0.9);
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 14px 26px rgba(0,0,0,0.07);
    }

    .feature-card h3,
    .graph-card h3,
    .compare-card h3,
    .mini-card h3,
    .list-card h3 {
      margin: 0 0 10px;
      font-size: 16px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .price-row,
    .stat-row,
    .mini-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 10px;
    }

    .price {
      font-family: var(--font-number);
      font-size: 36px;
      line-height: 1.2;
      color: var(--dark-blue);
      letter-spacing: 0.01em;
    }

    .delta {
      color: #1f9d66;
      font-size: 12px;
      font-weight: 700;
      background: rgba(184,243,222,0.7);
      padding: 6px 8px;
      border-radius: 999px;
    }

    .caption {
      margin-top: 4px;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .graph {
      margin-top: 10px;
      height: 144px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(29,220,255,0.10), rgba(248,76,162,0.04)),
        repeating-linear-gradient(
          to top,
          rgba(28,38,99,0.06),
          rgba(28,38,99,0.06) 1px,
          transparent 1px,
          transparent 33px
        );
      position: relative;
      overflow: hidden;
    }

    .graph svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .graph .point-labels {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .graph .point-labels span {
      position: absolute;
      font-size: 10px;
      font-weight: 700;
      color: var(--dark-blue);
      background: rgba(255,255,255,0.92);
      padding: 4px 6px;
      border-radius: 999px;
      box-shadow: 0 6px 12px rgba(28,38,99,0.08);
      transform: translate(-50%, -50%);
    }

    .timeline {
      margin-top: 10px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      text-align: center;
    }

    .timeline .step {
      padding: 10px 6px;
      background: rgba(237,241,244,0.72);
      border-radius: 16px;
      font-size: 11px;
      color: var(--text-gray);
    }

    .timeline .step strong {
      display: block;
      margin-bottom: 4px;
      color: var(--dark-blue);
      font-size: 12px;
    }

    .expense-bars {
      display: grid;
      gap: 10px;
      margin-top: 8px;
    }

    .bar-line {
      display: grid;
      grid-template-columns: 70px 1fr auto;
      align-items: center;
      gap: 10px;
      font-size: 12px;
      color: var(--text-gray);
    }

    .bar-track {
      height: 12px;
      border-radius: 999px;
      background: rgba(28,38,99,0.08);
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      background: var(--gradient-primary);
      transition: width 0.5s ease;
    }

    .bar-fill.pink {
      background: linear-gradient(90deg, #ffb36a, #f84ca2);
    }

    .bar-fill.navy {
      background: linear-gradient(90deg, #1c2663, #4db4ff);
    }

    .insight {
      margin-top: 12px;
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,216,232,0.45);
      color: var(--dark-blue);
      font-size: 12px;
      line-height: 1.7;
      font-weight: 700;
    }

    .list-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 10px;
    }

    .list-card li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: rgba(250,250,250,0.95);
      border-radius: 16px;
      border: 1px solid rgba(28,38,99,0.05);
      transition: transform 0.25s ease, background 0.25s ease;
    }

    .list-card li.active {
      background: rgba(29,220,255,0.10);
      transform: translateX(2px);
    }

    .list-card .left {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .list-card .title {
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .list-card .desc {
      font-size: 11px;
      color: var(--text-gray);
    }

    .list-card .value {
      font-size: 12px;
      font-weight: 700;
      color: var(--pink);
      white-space: nowrap;
    }

    .compare-table {
      margin-top: 10px;
      display: grid;
      gap: 10px;
    }

    .compare-row {
      display: grid;
      grid-template-columns: 1fr 96px 96px;
      gap: 8px;
      align-items: center;
      padding: 12px;
      border-radius: 18px;
      background: rgba(250,250,250,0.96);
    }

    .compare-row.head {
      background: transparent;
      padding: 0 2px;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-gray);
    }

    .compare-row .brand {
      font-size: 13px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .compare-row .pill {
      min-height: 34px;
      padding: 6px 8px;
      border-radius: 999px;
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .pill.good {
      background: rgba(184,243,222,0.9);
      color: #117447;
    }

    .pill.bad {
      background: rgba(255,125,125,0.16);
      color: #b33333;
    }

    .pill.neutral {
      background: rgba(237,241,244,0.92);
      color: var(--text-gray);
    }

    .footer-cta {
      margin-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .footer-cta .sub {
      font-size: 11px;
      text-align: center;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .bounce {
      animation: bounceSoft 2.6s infinite;
    }

    .summary {
      max-width: 1120px;
      margin: 28px auto 0;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .summary-card {
      background: rgba(255,255,255,0.84);
      border-radius: 20px;
      padding: 16px;
      box-shadow: 0 16px 32px rgba(28,38,99,0.08);
    }

    .summary-card h4 {
      margin: 0 0 8px;
      color: var(--dark-blue);
      font-size: 14px;
    }

    .summary-card p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.75;
    }

    @keyframes floaty {
      0%, 100% { transform: translateY(0px) translateX(0px); }
      50% { transform: translateY(-10px) translateX(3px); }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 0.9; }
      50% { transform: scale(1.25); opacity: 1; }
    }

    @keyframes bounceSoft {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
    }

    @media (max-width: 1040px) {
      .grid,
      .summary {
        grid-template-columns: 1fr;
      }

      .phone-card.is-dim {
        opacity: 0.52;
      }
    }

    @media (max-width: 480px) {
      .page {
        padding: 16px 10px 32px;
      }

      .toggle-row {
        flex-direction: column;
        align-items: center;
      }

      .cta {
        width: min(100%, 240px);
      }

      .hero h2 {
        font-size: 24px;
      }

      .screen {
        min-height: 700px;
      }

      .compare-row {
        grid-template-columns: 1fr 84px 84px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <span class="doodle one"></span>
    <span class="doodle two"></span>
    <span class="doodle three"></span>

    <section class="intro">
      <div class="eyebrow">
        <span class="heart">♡</span>
        ストアPV→DL率 17.3% から 25% を目指すスクショ検証
      </div>
      <h1>「まずは相場だけ知りたい」気持ちに<br>やさしく寄り添う、3つの訴求画面</h1>
      <p>
        UcarPACの強みであるAI査定・将来予測・出費管理・電話負担の少なさを、
        不安を安心に変えるトーンで再構成したストアスクリーン案です。タップで強調表示を切り替えられます。
      </p>
    </section>

    <div class="toolbar" role="tablist" aria-label="スクリーン選択">
      <button class="chip is-active" data-filter="all" role="tab" aria-selected="true">3画面を表示</button>
      <button class="chip" data-filter="a" role="tab" aria-selected="false">A: AI査定</button>
      <button class="chip" data-filter="b" role="tab" aria-selected="false">B: 出費管理+将来予測</button>
      <button class="chip" data-filter="c" role="tab" aria-selected="false">C: 電話0本訴求</button>
    </div>

    <div class="toggle-row">
      <button class="cta primary" id="animateBtn">アニメーション切替</button>
      <button class="cta pink" id="focusBtn">安心ポイント強調</button>
    </div>

    <main class="grid">
      <section class="phone-card" data-screen="a">
        <div class="card-meta">
          <div class="screen-label"><span class="dot"></span>ストアスクショA / iOS向け</div>
          <div class="screen-tag">個人情報なしでOK</div>
        </div>

        <div class="phone">
          <div class="screen">
            <div class="statusbar">
              <span>9:41</span>
              <div class="status-icons">
                <span>5G</span>
                <span>100%</span>
              </div>
            </div>

            <span class="bubble"></span>
            <span class="bubble-alt"></span>
            <span class="spark"></span>

            <div class="screen-content">
              <div class="hero">
                <div class="badge-row">
                  <span class="badge pink">AI査定</span>
                  <span class="badge blue">最短1分</span>
                  <span class="badge orange">個人情報不要</span>
                </div>
                <h2>愛車の今の価値、<br>やさしくすぐに見える</h2>
                <p>
                  2021年式 トヨタ ヤリスクロス Z / 走行 23,400km をもとに、
                  相場の目安をAIがその場で表示。いきなり申し込みしなくて大丈夫です。
                </p>
                <div class="hand-note">「売るか迷い中」でも気軽に試せます</div>
              </div>

              <div class="feature-card">
                <h3>今日のAI査定</h3>
                <div class="price-row">
                  <div class="price">184.6万円</div>
                  <div class="delta">前月比 +3.2万円</div>
                </div>
                <div class="caption">
                  全国相場データと車両条件を反映した参考価格。まずは相場感を知りたい人向けの入口です。
                </div>
                <div class="timeline">
                  <div class="step"><strong>入力</strong>メーカー / 年式</div>
                  <div class="step"><strong>確認</strong>概算レンジ</div>
                  <div class="step"><strong>安心</strong>営業電話なし</div>
                </div>
              </div>

              <div class="graph-card">
                <h3>3か月先の売り時もチェック</h3>
                <div class="graph">
                  <svg viewBox="0 0 320 144" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="lineA" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="#ffb36a"></stop>
                        <stop offset="100%" stop-color="#f84ca2"></stop>
                      </linearGradient>
                    </defs>
                    <path d="M18,98 C56,80 90,72 122,68 C154,64 188,50 222,44 C252,38 280,30 304,28"
                          fill="none" stroke="url(#lineA)" stroke-width="4.5" stroke-linecap="round"></path>
                    <path d="M18,110 C56,94 90,86 122,82 C154,78 188,64 222,58 C252,52 280,44 304,42"
                          fill="none" stroke="rgba(28,38,99,0.14)" stroke-width="2.5" stroke-dasharray="6 5" stroke-linecap="round"></path>
                    <circle cx="18" cy="98" r="5" fill="#fff" stroke="#ffb36a" stroke-width="3"></circle>
                    <circle cx="122" cy="68" r="5" fill="#fff" stroke="#f84ca2" stroke-width="3"></circle>
                    <circle cx="222" cy="44" r="5" fill="#fff" stroke="#1ddcff" stroke-width="3"></circle>
                    <circle cx="304" cy="28" r="5" fill="#fff" stroke="#4db4ff" stroke-width="3"></circle>
                  </svg>
                  <div class="point-labels">
                    <span style="left: 18px; top: 98px;">今</span>
                    <span style="left: 122px; top: 68px;">1か月後</span>
                    <span style="left: 222px; top: 44px;">2か月後</span>
                    <span style="left: 304px; top: 28px;">3か月後</span>
                  </div>
                </div>
                <div class="caption">予測上限 189.8万円。春の需要期で上振れ見込み。</div>
              </div>

              <div class="footer-cta">
                <button class="cta primary bounce">まずはAI査定してみる</button>
                <div class="sub">申し込み前に相場だけ見られるから、はじめの一歩が軽い。</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="phone-card" data-screen="b">
        <div class="card-meta">
          <div class="screen-label"><span class="dot"></span>ストアスクショB / Android向け</div>
          <div class="screen-tag">出費も価値も見える化</div>
        </div>

        <div class="phone">
          <div class="screen">
            <div class="statusbar">
              <span>12:30</span>
              <div class="status-icons">
                <span>VoLTE</span>
                <span>96%</span>
              </div>
            </div>

            <span class="bubble" style="top: 148px; right: -28px;"></span>
            <span class="bubble-alt" style="top: 290px; left: -18px;"></span>
            <span class="spark" style="top: 210px; right: 46px;"></span>

            <div class="screen-content">
              <div class="hero">
                <div class="badge-row">
                  <span class="badge pink">出費管理</span>
                  <span class="badge blue">将来予測</span>
                  <span class="badge orange">家計にやさしい</span>
                </div>
                <h2>乗り続ける？ 売り時？<br>数字で迷いがほどける</h2>
                <p>
                  2019年式 ホンダ フリード G・Honda SENSING の維持費と資産価値をひとつの画面で確認。
                  「まだ乗る」が正解か、「今が売り時」かを見極めやすくします。
                </p>
