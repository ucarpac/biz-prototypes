  <script>
    (function () {
      const chips = Array.from(document.querySelectorAll('.chip'));
      const cards = Array.from(document.querySelectorAll('.phone-card'));
      const animateBtn = document.getElementById('animateBtn');
      const focusBtn = document.getElementById('focusBtn');
      const bars = Array.from(document.querySelectorAll('.bar-fill'));
      const compareRows = Array.from(document.querySelectorAll('.compare-row:not(.head)'));
      const listItems = Array.from(document.querySelectorAll('.list-card li'));
      const notes = Array.from(document.querySelectorAll('.hand-note'));
      let animationOn = true;
      let focusOn = false;

      function applyFilter(filter) {
        cards.forEach((card) => {
          const isMatch = filter === 'all' || card.dataset.screen === filter;
          card.classList.toggle('is-dim', !isMatch);
        });

        chips.forEach((chip) => {
          const active = chip.dataset.filter === filter;
          chip.classList.toggle('is-active', active);
          chip.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      }

      chips.forEach((chip) => {
        chip.addEventListener('click', function () {
          applyFilter(this.dataset.filter);
        });
      });

      animateBtn.addEventListener('click', function () {
        animationOn = !animationOn;
        document.querySelectorAll('.bubble, .bubble-alt, .spark, .bounce, .dot').forEach((el) => {
          el.style.animationPlayState = animationOn ? 'running' : 'paused';
        });
        notes.forEach((note, index) => {
          note.style.transform = animationOn
            ? (index % 2 === 0 ? 'rotate(-3deg)' : 'rotate(-2deg)')
            : 'rotate(0deg)';
        });
      });

      focusBtn.addEventListener('click', function () {
        focusOn = !focusOn;

        bars.forEach((bar, index) => {
          const widthsOn = ['88%', '72%', '54%'];
          const widthsOff = ['74%', '58%', '42%'];
          bar.style.width = focusOn ? widthsOn[index % widthsOn.length] : widthsOff[index % widthsOff.length];
        });

        compareRows.forEach((row, index) => {
          row.style.transform = focusOn && index === 0 ? 'scale(1.03)' : 'scale(1)';
          row.style.boxShadow = focusOn && index === 0 ? '0 14px 26px rgba(248,76,162,0.14)' : 'none';
        });

        listItems.forEach((item, index) => {
          item.classList.toggle('active', focusOn ? index !== 1 : index === 0);
        });

        document.querySelectorAll('.hero, .feature-card, .graph-card, .compare-card, .mini-card').forEach((card, index) => {
          card.style.boxShadow = focusOn && index % 2 === 0
            ? '0 18px 36px rgba(248,76,162,0.14)'
            : '';
        });
      });

      let current = 0;
      const order = ['all', 'a', 'b', 'c'];

      setInterval(function () {
        current = (current + 1) % order.length;
        applyFilter(order[current]);
      }, 4400);
    })();
  </script>
</body>
</html>
