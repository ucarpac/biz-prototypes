      width: 68px;
      height: 20px;
      top: 48px;
      left: 72px;
      opacity: 0.9;
    }

    .cloud.c2::before {
      width: 24px;
      height: 24px;
      left: 8px;
      top: -8px;
    }

    .cloud.c2::after {
      width: 26px;
      height: 26px;
      right: 10px;
      top: -12px;
    }

    .road {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 24px;
      height: 26px;
      border-radius: 18px;
      background: linear-gradient(90deg, #d8dce9, #cfd6ea);
    }

    .road::after {
      content: "";
      position: absolute;
      left: 14px;
      right: 14px;
      top: 11px;
      height: 4px;
      background: repeating-linear-gradient(
        90deg,
        rgba(255,255,255,0.9) 0 14px,
        transparent 14px 24px
      );
      border-radius: 4px;
    }

    .car {
      position: absolute;
      left: 20px;
      bottom: 32px;
      width: 220px;
      height: 84px;
      animation: bob 3s ease-in-out infinite;
    }

    .car-body {
      position: absolute;
      left: 8px;
      right: 10px;
      bottom: 18px;
      height: 42px;
      background: linear-gradient(90deg, #ff77ba, #f84ca2);
      border-radius: 24px 30px 18px 18px;
      box-shadow: 0 8px 18px rgba(248,76,162,0.18);
    }

    .car-top {
      position: absolute;
      left: 52px;
      bottom: 44px;
      width: 98px;
      height: 32px;
      background: linear-gradient(90deg, #ffd6ea, #ffffff);
      border-radius: 26px 26px 6px 6px;
      border: 2px solid rgba(28,38,99,0.06);
    }

    .window {
      position: absolute;
      top: 7px;
      width: 38px;
      height: 16px;
      background: rgba(113,211,255,0.72);
      border-radius: 12px 12px 4px 4px;
    }

    .window.w1 {
      left: 8px;
    }

    .window.w2 {
      right: 8px;
      width: 30px;
    }

    .wheel {
      position: absolute;
      bottom: 0;
      width: 32px;
      height: 32px;
      background: #25306b;
      border-radius: 50%;
      box-shadow: inset 0 0 0 7px #fff7f1;
    }

    .wheel.left {
      left: 44px;
    }

    .wheel.right {
      right: 36px;
    }

    .heart-badge {
      position: absolute;
      right: 8px;
      bottom: 68px;
      background: #fffdfd;
      color: var(--pink);
      font-weight: 700;
      font-size: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      box-shadow: 0 8px 18px rgba(28,38,99,0.10);
      transform: rotate(4deg);
    }

    .section {
      margin-top: 20px;
    }

    .card {
      background: var(--gradient-card);
      border-radius: var(--radius-card);
      padding: 16px;
      box-shadow: 0 10px 24px rgba(0,0,0,0.07);
      border: 1px solid rgba(255,255,255,0.82);
    }

    .card + .card {
      margin-top: 16px;
    }

    .trust-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: -14px;
    }

    .trust-pill {
      background: rgba(255,255,255,0.92);
      border-radius: 18px;
      padding: 12px 10px;
      text-align: center;
      box-shadow: 0 10px 20px rgba(28,38,99,0.08);
    }

    .trust-pill strong {
      display: block;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .trust-pill span {
      display: block;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-gray);
      margin-top: 2px;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 12px;
    }

    .section-head h2 {
      margin: 0;
      font-size: 22px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .section-head a {
      color: var(--button-link);
      font-size: 12px;
      text-decoration: none;
      font-weight: 700;
    }

    .subcopy {
      margin: 6px 0 0;
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .primary-cta {
      width: 100%;
      min-height: 56px;
      border: 0;
      border-radius: 30px;
      background: var(--gradient-primary);
      color: var(--dark-blue);
      font-size: 15px;
      font-weight: 700;
      font-family: inherit;
      padding: 14px 18px;
      box-shadow: 0 14px 24px rgba(77,180,255,0.22);
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    }

    .primary-cta:active,
    .chip-btn:active,
    .secondary-btn:active,
    .tab-btn:active {
      transform: scale(0.98);
    }

    .secondary-cta {
      width: 100%;
      min-height: 48px;
      border: 0;
      border-radius: 30px;
      background: var(--gradient-pink);
      color: var(--white);
      font-size: 14px;
      font-weight: 700;
      font-family: inherit;
      padding: 12px 18px;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      box-shadow: 0 10px 18px rgba(248,76,162,0.22);
    }

    .cta-stack {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .badge-row,
    .chip-row {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: none;
    }

    .badge-row::-webkit-scrollbar,
    .chip-row::-webkit-scrollbar {
      display: none;
    }

    .badge {
      flex: 0 0 auto;
      padding: 8px 12px;
      border-radius: 999px;
      background: #fff;
      border: 1px solid rgba(248,76,162,0.18);
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .chip-btn {
      flex: 0 0 auto;
      min-height: 43px;
      padding: 10px 16px;
      border-radius: 22px;
      border: 1px solid var(--ruled-line);
      background: var(--white);
      color: var(--text-black);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
    }

    .chip-btn.active {
      background: var(--dark-blue);
      color: var(--white);
      border-color: var(--dark-blue);
      box-shadow: 0 10px 20px rgba(28,38,99,0.16);
    }

    .estimate-panel {
      margin-top: 14px;
      padding: 16px;
      border-radius: 16px;
      background: linear-gradient(180deg, #fff8f1, #ffffff);
      border: 1px solid rgba(248,76,162,0.12);
    }

    .estimate-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .estimate-label {
      font-size: 12px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .number {
      font-family: var(--font-number);
      color: var(--dark-blue);
      letter-spacing: 0.02em;
    }

    .estimate-price {
      margin-top: 4px;
      font-size: 36px;
      line-height: 1.4;
    }

    .estimate-caption {
      margin-top: 8px;
      font-size: 13px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .mini-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(248,76,162,0.10);
      color: var(--pink);
      border-radius: 999px;
      padding: 8px 10px;
      font-size: 11px;
      font-weight: 700;
      white-space: nowrap;
    }

    .trend-card {
      padding: 18px 16px;
    }

    .trend-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .trend-value {
      text-align: right;
    }

    .trend-value strong {
      display: block;
      font-size: 20px;
      color: var(--dark-blue);
      line-height: 1.5;
    }

    .trend-value span {
      display: block;
      font-size: 12px;
      color: #28a164;
      font-weight: 700;
    }

    .chart-wrap {
      margin-top: 16px;
      background: linear-gradient(180deg, #fff6fb, #ffffff);
      border-radius: 16px;
      padding: 14px 10px 8px;
      border: 1px solid rgba(248,76,162,0.10);
    }

    .chart {
      width: 100%;
      height: 150px;
      display: block;
    }

    .chart-labels {
      margin-top: 6px;
      display: flex;
      justify-content: space-between;
      color: var(--text-gray);
      font-size: 11px;
      font-weight: 700;
      padding: 0 6px;
    }

    .story-list {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .story-item {
      display: grid;
      grid-template-columns: 46px 1fr;
      gap: 12px;
      align-items: start;
      padding: 12px;
      border-radius: 14px;
      background: #fff;
      box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    }

    .story-icon {
      width: 46px;
      height: 46px;
      border-radius: 14px;
      background: linear-gradient(180deg, #fff0e7, #ffd8e8);
      display: grid;
      place-items: center;
      font-size: 22px;
    }

    .story-item strong {
      display: block;
      font-size: 14px;
      line-height: 1.5;
      color: var(--dark-blue);
      margin-bottom: 4px;
    }

    .story-item p {
      margin: 0;
      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.7;
    }

    .expense-summary {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 12px;
      margin-top: 14px;
    }

    .expense-box {
      background: #fff;
      border-radius: 16px;
      padding: 14px;
      box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    }

    .expense-box h3,
    .auction-box h3,
    .voice-box h3 {
      margin: 0;
      font-size: 14px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .expense-box .big {
      margin-top: 10px;
      font-size: 28px;
      line-height: 1.4;
      color: var(--dark-blue);
      font-family: var(--font-number);
    }

    .expense-list {
      margin-top: 10px;
      display: grid;
      gap: 8px;
    }

    .expense-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
      color: var(--text-gray);
    }

    .meter {
      margin-top: 10px;
      height: 10px;
      background: #f0f2f8;
      border-radius: 999px;
      overflow: hidden;
    }

    .meter > span {
      display: block;
      height: 100%;
      width: 62%;
      background: linear-gradient(90deg, #ffb26b, #f84ca2);
      border-radius: inherit;
    }

    .auction-box,
    .voice-box {
      margin-top: 16px;
      background: #fff;
      border-radius: 16px;
      padding: 14px;
      box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    }

    .auction-badges {
      display: flex;
      gap: 8px;
      margin-top: 10px;
      flex-wrap: wrap;
    }

    .auction-badges span {
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      background: #f7f9ff;
      color: var(--dark-blue);
    }

    .bid-track {
      margin-top: 12px;
      display: grid;
      gap: 10px;
    }

    .bid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 12px;
      background: linear-gradient(180deg, #fafcff, #f4f8ff);
      border: 1px solid rgba(64,153,255,0.10);
    }

    .bid strong {
      display: block;
      color: var(--dark-blue);
      font-size: 13px;
      line-height: 1.5;
    }

    .bid small {
      color: var(--text-gray);
      font-size: 11px;
    }

    .bid-price {
      font-family: var(--font-number);
      color: var(--dark-blue);
      font-size: 18px;
      white-space: nowrap;
    }

    .voice-box {
      background: linear-gradient(180deg, #fff8f0, #ffffff);
    }

    .voice {
      margin-top: 10px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }

    .voice-avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: linear-gradient(180deg, #ffd0b5, #ffb8c7);
      display: grid;
      place-items: center;
      font-size: 22px;
      flex: 0 0 42px;
    }

    .voice-bubble {
      background: #fff;
      border-radius: 16px 16px 16px 4px;
      padding: 12px;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text-black);
      box-shadow: 0 8px 18px rgba(0,0,0,0.04);
    }

    .form-card {
      padding: 18px 16px;
    }

    .tab-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      margin-top: 14px;
    }

    .tab-btn {
      min-height: 43px;
      border-radius: 22px;
      border: 0;
      background: #fff;
      color: var(--text-black);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: inset 0 0 0 1px rgba(28,38,99,0.08);
      transition: all 0.2s ease;
    }

    .tab-btn.active {
      background: var(--dark-blue);
      color: var(--white);
      box-shadow: 0 12px 20px rgba(28,38,99,0.16);
    }

    .form-group {
      margin-top: 18px;
    }

    .form-group label {
      display: block;
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--text-gray);
      margin-bottom: 8px;
    }

    .underline-input {
      width: 100%;
      border: 0;
      border-bottom: 2px solid var(--text-placeholder);
      background: transparent;
      height: 42px;
      text-align: center;
      font-size: 26px;
      font-weight: 700;
      color: var(--dark-blue);
      outline: none;
      transition: border-color 0.2s ease;
      font-family: inherit;
    }

    .underline-input:focus {
      border-color: var(--dark-blue);
    }

    .helper {
      margin-top: 8px;
      text-align: center;
      font-size: 12px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .helper.error {
      color: var(--error);
      font-weight: 700;
      display: none;
    }

    .result-card {
      margin-top: 16px;
      padding: 16px;
      border-radius: 16px;
      background: linear-gradient(180deg, #fff3f8, #ffffff);
      border: 1px solid rgba(248,76,162,0.12);
      display: none;
    }

    .result-card.show {
      display: block;
      animation: rise 0.35s ease;
    }

    .result-card h3 {
      margin: 0;
      font-size: 18px;
      line-height: 1.5;
      color: var(--dark-blue);
    }

    .result-meta {
      margin-top: 8px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .result-meta span {
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.86);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
    }

    .bottom-nav {
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: 12px;
      width: calc(100% - 24px);
      max-width: 406px;
      background: rgba(255,255,255,0.94);
      backdrop-filter: blur(14px);
      border-radius: 24px;
      box-shadow: 0 14px 28px rgba(28,38,99,0.10);
      padding: 10px 12px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      z-index: 10;
    }

    .nav-item {
      border: 0;
      background: transparent;
      display: grid;
      justify-items: center;
      gap: 4px;
      color: var(--text-gray);
      font-size: 10px;
      font-weight: 700;
      cursor: pointer;
      padding: 4px 0;
      font-family: inherit;
    }

    .nav-item span:first-child {
      font-size: 18px;
    }

    .nav-item.active {
      color: var(--pink);
    }

    .toast {
      position: fixed;
      left: 50%;
      transform: translateX(-50%) translateY(18px);
      bottom: 86px;
      width: calc(100% - 40px);
      max-width: 360px;
      background: rgba(28,38,99,0.92);
      color: #fff;
      padding: 14px 16px;
      border-radius: 16px;
      box-shadow: 0 14px 28px rgba(28,38,99,0.24);
      font-size: 13px;
      line-height: 1.7;
      opacity: 0;
      pointer-events: none;
      transition: 0.25s ease;
      z-index: 11;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .tiny {
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.7;
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.35); opacity: 0.6; }
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (min-width: 768px) {
      .app-shell {
        max-width: 960px;
      }

      main {
        padding: 24px 24px 110px;
      }

      .hero {
        padding: 24px;
        border-radius: 0 0 36px 36px;
      }

      .hero-grid {
        grid-template-columns: 1.1fr 0.9fr;
        gap: 18px;
      }

      .section.dual {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
      }

      .trust-row {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .expense-summary {
        grid-template-columns: 1fr 1fr;
      }

      .bottom-nav {
        max-width: 720px;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <div class="ambient a1"></div>
    <div class="ambient a2"></div>
    <div class="ambient a3"></div>

    <section class="hero">
      <div class="topbar">
        <div class="brand">
          <div class="brand-mark">🚗</div>
          <div class="brand-copy">
            <small>愛車の気持ちに、ちゃんと寄り添う</small>
            <strong>UcarPAC</strong>
          </div>
        </div>
        <div class="mood-chip">個人情報なしで試せます</div>
      </div>

      <div class="hero-grid">
        <div>
          <div class="eyebrow">
            <span class="dot"></span>
            今の不安も、売る日の期待も、ひとつの画面で。
          </div>
          <h1>「まだ売らないかも」でも<br>安心して相場を見られる。</h1>
          <p>
            AIがあなたの愛車のいまの価値をやさしく可視化。
            3ヶ月後の予測や維持費もまとめて見えるから、急がず納得して判断できます。
          </p>
          <div class="hand-note">まずは電話なしで、そっと確かめましょう。</div>
          <div class="cta-stack">
            <button class="primary-cta" id="heroCta">愛車の相場を見てみる</button>
            <button class="secondary-cta" id="warmCta">電話1社だけの売却相談を知る</button>
          </div>
        </div>

        <div class="illustration">
          <div class="car-scene">
            <div class="sun"></div>
            <div class="cloud c1"></div>
            <div class="cloud c2"></div>
            <div class="heart-badge">あなたの愛車を大切に査定</div>
            <div class="car">
              <div class="car-top">
                <div class="window w1"></div>
                <div class="window w2"></div>
              </div>
              <div class="car-body"></div>
              <div class="wheel left"></div>
              <div class="wheel right"></div>
            </div>
            <div class="road"></div>
          </div>
        </div>
      </div>
    </section>

    <main>
      <div class="trust-row">
        <div class="trust-pill">
          <strong>8,000社</strong>
          <span>が入札する安心感</span>
        </div>
        <div class="trust-pill">
          <strong>電話1社</strong>
          <span>やりとりの負担を軽減</span>
        </div>
        <div class="trust-pill">
          <strong>AI予測</strong>
          <span>今とこれからを比較</span>
        </div>
      </div>

      <section class="section">
        <div class="card">
          <div class="section-head">
            <div>
              <h2>気持ちに合わせて、見たいことを選ぶ</h2>
              <p class="subcopy">「いま知りたい」「売る準備をしたい」「維持費も見たい」を切り替えられます。</p>
            </div>
            <a href="#simulator">かんたん入力へ</a>
          </div>
          <div class="chip-row" id="moodChips">
            <button class="chip-btn active" data-mode="now">まずは今の相場</button>
            <button class="chip-btn" data-mode="later">売り時を考えたい</button>
            <button class="chip-btn" data-mode="cost">維持費も見たい</button>
            <button class="chip-btn" data-mode="auction">高く売る流れを知りたい</button>
          </div>

          <div class="estimate-panel" id="moodPanel">
            <div class="estimate-top">
              <div>
                <div class="estimate-label">トヨタ アクア G 2020年式 / 42,300km</div>
                <div class="estimate-price number" id="estimatePrice">129万円〜146万円</div>
              </div>
