      color: var(--text-gray);
      font-size: 12px;
      line-height: 1.6;
    }

    .price-box {
      margin-top: 16px;
      padding: 16px;
      border-radius: 20px;
      background: linear-gradient(135deg, #fff8fb 0%, #eefaff 100%);
      border: 1px solid rgba(248,76,162,0.12);
    }

    .price-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .price-head span {
      font-size: 12px;
      font-weight: 700;
      color: var(--dark-blue);
    }

    .confidence {
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(29,220,255,0.16);
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 700;
    }

    .price-number {
      display: flex;
      align-items: flex-end;
      gap: 8px;
      margin: 6px 0 10px;
      color: var(--pink);
    }

    .price-number strong {
      font-family: var(--font-number);
      font-size: 50px;
      line-height: 1;
      letter-spacing: 0.01em;
    }

    .price-number small {
      font-size: 18px;
      font-weight: 800;
      color: var(--dark-blue);
      padding-bottom: 7px;
    }

    .helper {
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .graph {
      margin-top: 14px;
      padding: 14px 12px 10px;
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(28,38,99,0.06);
    }

    .graph svg {
      width: 100%;
      height: 124px;
      display: block;
    }

    .graph-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 4px;
      font-size: 10px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .legend {
      display: flex;
      gap: 12px;
      margin-top: 12px;
      flex-wrap: wrap;
    }

    .legend span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .legend i {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }

    .primary-btn,
    .secondary-btn {
      width: 100%;
      min-height: 48px;
      border: none;
      border-radius: var(--radius-button);
      margin-top: 14px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.25s ease;
    }

    .primary-btn {
      background: var(--gradient-primary);
      color: var(--dark-blue);
      box-shadow: 0 12px 24px rgba(77,180,255,0.28);
    }

    .secondary-btn {
      background: #fff;
      color: var(--dark-blue);
      border: 1px solid rgba(28,38,99,0.14);
    }

    .primary-btn:active,
    .secondary-btn:active {
      transform: scale(0.98);
    }

    .trust-row {
      margin: 16px 18px 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .trust {
      padding: 12px 8px;
      text-align: center;
      border-radius: 18px;
      background: rgba(255,255,255,0.88);
      font-size: 11px;
      line-height: 1.5;
      font-weight: 800;
      color: var(--dark-blue);
      box-shadow: var(--shadow-light);
    }

    .trust strong {
      display: block;
      font-size: 18px;
      color: var(--pink);
      margin-bottom: 2px;
    }

    .expense-grid {
      margin: 16px 18px 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .expense-card {
      padding: 14px;
      border-radius: 20px;
      background: rgba(255,255,255,0.92);
      box-shadow: var(--shadow-light);
    }

    .expense-card .icon {
      font-size: 24px;
      margin-bottom: 6px;
    }

    .expense-card h3 {
      margin: 0 0 4px;
      color: var(--dark-blue);
      font-size: 14px;
      line-height: 1.5;
    }

    .expense-card p {
      margin: 0;
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-gray);
    }

    .compare-board {
      margin: 16px 18px 0;
      padding: 18px 16px;
      border-radius: 24px;
      background: linear-gradient(180deg, #fff8fb 0%, #ffffff 100%);
      box-shadow: var(--shadow-light);
      border: 1px solid rgba(248,76,162,0.12);
    }

    .compare-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
    }

    .compare-header h3 {
      margin: 0;
      font-size: 18px;
      color: var(--dark-blue);
      line-height: 1.5;
    }

    .ring {
      width: 76px;
      height: 76px;
      border-radius: 50%;
      background: conic-gradient(var(--pink) 0 0deg, #eceff8 0deg 360deg);
      display: grid;
      place-items: center;
      transition: 0.6s ease;
      box-shadow: inset 0 0 0 7px #fff;
    }

    .ring span {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: #fff;
      display: grid;
      place-items: center;
      color: var(--dark-blue);
      font-size: 11px;
      font-weight: 800;
      text-align: center;
      line-height: 1.2;
    }

    .compare-list {
      display: grid;
      gap: 10px;
    }

    .compare-item {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 10px;
      align-items: center;
      padding: 12px 10px;
      border-radius: 18px;
      background: #fff;
      border: 1px solid rgba(28,38,99,0.06);
    }

    .compare-item .brand {
      font-size: 13px;
      font-weight: 800;
      color: var(--dark-blue);
    }

    .compare-item .call {
      font-size: 24px;
      font-weight: 900;
      color: var(--pink);
      min-width: 48px;
      text-align: right;
    }

    .compare-item .unit {
      font-size: 12px;
      color: var(--text-gray);
      font-weight: 700;
    }

    .note {
      margin-top: 12px;
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-gray);
    }

    .cta-bar {
      margin: 18px 18px 22px;
      padding: 14px 16px;
      border-radius: 20px;
      background: var(--back-blue);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      box-shadow: 0 16px 32px rgba(9,19,85,0.24);
    }

    .cta-bar strong {
      display: block;
      font-size: 14px;
      line-height: 1.5;
    }

    .cta-bar span {
      display: block;
      font-size: 11px;
      line-height: 1.5;
      color: #bfdbfe;
    }

    .cta-mini {
      border: none;
      border-radius: 999px;
      padding: 10px 14px;
      background: #fff;
      color: var(--dark-blue);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
    }

    .footer-caption {
      text-align: center;
      margin-top: 16px;
      font-size: 11px;
      color: var(--text-gray);
      line-height: 1.6;
    }

    .pulse {
      animation: pulse 2.6s infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }

    .hidden {
      display: none !important;
    }

    @media (min-width: 768px) {
      .page {
        max-width: 1080px;
        padding: 24px 20px 56px;
      }

      .header {
        max-width: 680px;
      }

      .deck {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .screen {
        display: block !important;
      }

      .card {
        min-height: 820px;
      }

      .switcher {
        position: relative;
        max-width: 520px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="header">
      <div class="eyebrow">
        <span class="dot"></span>
        ストアPV→DL率 改善プロトタイプ
      </div>
      <h1>不安を減らして、<br>「今ちょっと見てみよう」を増やす。</h1>
      <p class="lead">
        AI査定の安心感、出費管理の納得感、電話負担の少なさを
        ストアスクショ3枚で感情的に伝えるA案です。
