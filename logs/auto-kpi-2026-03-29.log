    <nav class="switcher" aria-label="スクリーン切り替え">
      <button class="active" data-screen="screen-a">A iOS査定</button>
      <button data-screen="screen-b">B Android管理</button>
      <button data-screen="screen-c">C 比較訴求</button>
    </nav>

    <main class="deck">
      <section class="screen active" id="screen-a">
        <article class="card">
          <div class="ios-shell">
            <div class="statusbar">
              <span>9:41</span>
              <span>UcarPAC</span>
              <span>100%</span>
            </div>

            <div class="hero">
              <div class="chip-row">
                <span class="chip hot">個人情報なしでOK</span>
