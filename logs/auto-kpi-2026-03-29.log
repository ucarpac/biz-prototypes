  <script>
    const moodData = {
      now: {
        price: "129万円〜146万円",
        badge: "個人情報の入力はまだ不要",
        caption: "まずは相場だけ確認したい方へ。市場データとAI解析から、おおよその売却レンジをやさしく表示します。",
        trendStrong: "3ヶ月後 +4万円",
        trendDelta: "春需要で上向き予測"
      },
      later: {
        price: "3ヶ月後 133万円〜150万円",
        badge: "売り時の予測をAIがサポート",
        caption: "急いで売らなくても大丈夫。相場の伸びやすい時期を見ながら、納得できるタイミングを探せます。",
        trendStrong: "6ヶ月後 -2万円",
        trendDelta: "夏以降はやや横ばい予測"
      },
      cost: {
        price: "維持費と合わせて総合判断",
        badge: "出費管理と一緒に見られる",
        caption: "査定額だけでなく、毎月の維持費も一緒に比較。持ち続けるコストとのバランスが見えてきます。",
        trendStrong: "年間維持費 約38.9万円",
        trendDelta: "費用負担は平均より低め"
      },
      auction: {
        price: "最高入札 157万円の可能性",
        badge: "8,000社オークションで比較",
        caption: "売却を決めたら、全国の入札でしっかり比較。やりとりは専任1社だけなので心の負担も抑えられます。",
        trendStrong: "電話は1社のみ",
        trendDelta: "一括査定の負担を軽減"
      }
    };

    const moodChips = document.querySelectorAll("#moodChips .chip-btn");
    const estimatePrice = document.getElementById("estimatePrice");
    const estimateBadge = document.getElementById("estimateBadge");
    const estimateCaption = document.getElementById("estimateCaption");
    const trendStrong = document.getElementById("trendStrong");
    const trendDelta = document.getElementById("trendDelta");
    const toast = document.getElementById("toast");

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => {
        toast.classList.remove("show");
      }, 2200);
    }

    moodChips.forEach((chip) => {
      chip.addEventListener("click", () => {
        moodChips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        const mode = chip.dataset.mode;
        const data = moodData[mode];
        estimatePrice.textContent = data.price;
        estimateBadge.textContent = data.badge;
        estimateCaption.textContent = data.caption;
        trendStrong.textContent = data.trendStrong;
        trendDelta.textContent = data.trendDelta;
      });
    });

    document.getElementById("heroCta").addEventListener("click", () => {
      document.getElementById("simulator").scrollIntoView({ behavior: "smooth", block: "start" });
      showToast("愛車の情報を入れると、やさしく相場をお見せします。");
    });

    document.getElementById("warmCta").addEventListener("click", () => {
      showToast("売却相談に進んでも、やりとりは専任1社のみです。");
    });

    const tabs = document.querySelectorAll("#entryTabs .tab-btn");
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");
        const isAi = tab.dataset.tab === "ai";
        showToast(isAi ? "AI査定モードでは写真や装備情報を追加できます。" : "概算モードでは個人情報なしで確認できます。");
      });
    });

    const simulateBtn = document.getElementById("simulateBtn");
    const favoriteBtn = document.getElementById("favoriteBtn");
    const mileageInput = document.getElementById("mileageInput");
    const yearInput = document.getElementById("yearInput");
    const carName = document.getElementById("carName");
    const errorText = document.getElementById("errorText");
    const resultCard = document.getElementById("resultCard");
    const resultPrice = document.getElementById("resultPrice");
    const resultText = document.getElementById("resultText");
    const metaMileage = document.getElementById("metaMileage");
    const metaYear = document.getElementById("metaYear");

    function formatManYen(min, max) {
      return `${min}万円〜${max}万円`;
    }

    function calculateEstimate() {
      const mileage = Number(mileageInput.value);
      const year = Number(yearInput.value);

      if (mileage < 1000 || mileage > 200000 || !year) {
        errorText.style.display = "block";
        resultCard.classList.remove("show");
        return;
      }

      errorText.style.display = "none";

      const baseMin = 118;
      const baseMax = 149;
      const mileagePenalty = Math.round((mileage - 30000) / 5000) * 2;
      const yearBonus = (year - 2018) * 3;

      const min = Math.max(48, baseMin - mileagePenalty + yearBonus);
      const max = Math.max(min + 8, baseMax - Math.round(mileagePenalty * 0.8) + yearBonus);

      const upOrDown = mileage < 50000 ? "今月は相場が底堅く、条件次第で上振れも期待できます。" : "走行距離を考慮しても、需要のある価格帯にしっかり入っています。";

      resultPrice.textContent = formatManYen(min, max);
      resultText.textContent = `${carName.value} の推定結果です。${upOrDown}`;
      metaMileage.textContent = `走行距離 ${mileage.toLocaleString()}km`;
      metaYear.textContent = `${year}年式`;
      resultCard.classList.add("show");

      estimatePrice.textContent = formatManYen(min, max);
      showToast("相場を更新しました。売り時の判断材料として使えます。");
    }

    simulateBtn.addEventListener("click", calculateEstimate);

    favoriteBtn.addEventListener("click", () => {
      showToast("見守り登録しました。相場が動いたら通知する想定です。");
    });

    [mileageInput, yearInput, carName].forEach((input) => {
      input.addEventListener("input", () => {
        if (input === mileageInput || input === yearInput) {
          errorText.style.display = "none";
        }
      });
    });

    const navItems = document.querySelectorAll(".nav-item");
    navItems.forEach((item) => {
      item.addEventListener("click", () => {
        navItems.forEach((n) => n.classList.remove("active"));
        item.classList.add("active");
        showToast(`${item.textContent.trim()} タブのイメージです。`);
      });
    });

    window.addEventListener("load", () => {
      setTimeout(() => {
        showToast("個人情報なしで相場チェックできる安心感を体験できます。");
      }, 500);
    });
  </script>
</body>
</html>
